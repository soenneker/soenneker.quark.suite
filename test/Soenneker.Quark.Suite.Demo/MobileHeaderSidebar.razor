@if (State?.IsMobile == true || State?.OpenMobile == true)
{
    <Sidebar Collapsible="SidebarCollapsible.None"
             Shell="SidebarShell.Navigation"
             MobileMode="SidebarMobileMode.FullScreen"
             MobileShowBackdrop="false"
             MobileShowCloseButton="false"
             MobileTrapFocus="false"
             MobileOffsetTop="calc(3rem + 2px)">
        <MobileContent>
            <NavigationLinks Items="Items" Mode="NavigationLinksMode.Stack" Title="Menu" IsActive="IsActive" />
            @if (IncludeDocsNavigation)
            {
                <NavigationLinks Items="DocsNavigation.SectionLinks" Mode="NavigationLinksMode.Stack" Title="Sections" IsActive="IsActive" />
                <NavigationLinks Items="DocsNavigation.ComponentLinks" Mode="NavigationLinksMode.Stack" Title="Components" IsActive="IsActive" />
                <NavigationLinks Items="DocsNavigation.PrimitiveLinks" Mode="NavigationLinksMode.Stack" Title="Primitives" IsActive="IsActive" />
            }
        </MobileContent>
    </Sidebar>
}

@code {
    [CascadingParameter(Name = "SidebarContextState")]
    public Soenneker.Quark.Dtos.SidebarContextState? State { get; set; }

    [Parameter]
    public IEnumerable<NavigationItem> Items { get; set; } = [];

    [Parameter]
    public Func<NavigationItem, bool>? IsActive { get; set; }

    [Parameter]
    public bool IncludeDocsNavigation { get; set; }
}
