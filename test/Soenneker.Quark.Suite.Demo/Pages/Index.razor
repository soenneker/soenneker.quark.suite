@page "/"

<PageTitle>The Foundation for your Design System - Quark Suite</PageTitle>

<Div Class="flex min-h-0 flex-1 flex-col">
    <Section>
        <Div Class="container-wrapper">
            <Div Class="container mx-auto flex max-w-[90rem] flex-col items-center gap-2 px-6 py-8 text-center md:py-16 lg:py-20 xl:gap-4">
                <Badge AsChild Variant="BadgeVariant.Secondary" Class="bg-muted">
                    <Anchor To="https://github.com/soenneker/soenneker.quark.suite" Target="Target.Blank">
                        Introducing Quark v3
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             class="size-3">
                            <path d="M5 12h14"></path>
                            <path d="m12 5 7 7-7 7"></path>
                        </svg>
                    </Anchor>
                </Badge>
                <H1 Class="leading-tighter max-w-4xl text-balance text-3xl font-semibold tracking-tight text-primary lg:leading-[1.1] xl:text-5xl xl:tracking-tighter">
                    The Foundation for your Design System
                </H1>
                <Paragraph Class="max-w-4xl text-base text-balance text-foreground sm:text-lg">
                    A set of beautifully designed components that you can customize, extend, and build on. Start here then make it your own. Open Source. Open Code.
                </Paragraph>
                <Div Class="flex w-full items-center justify-center gap-2 pt-2 **:data-[slot=button]:shadow-none">
                    <Anchor To="https://github.com/soenneker/soenneker.quark.suite"
                            Target="Target.Blank"
                            Class="inline-flex h-[31px] shrink-0 items-center justify-center gap-1.5 rounded-lg bg-primary px-3 text-sm font-medium whitespace-nowrap text-primary-foreground outline-none transition-all hover:bg-primary/90">
                        New Project
                    </Anchor>
                    <Anchor To="components"
                            Class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-lg px-3 text-sm font-medium whitespace-nowrap text-foreground outline-none transition-all hover:bg-accent hover:text-accent-foreground">
                        View Components
                    </Anchor>
                </Div>
            </Div>
        </Div>
    </Section>

    <Div Class="container-wrapper hidden scroll-mt-24 border-t border-border/50 md:flex">
        <Div Class="container mx-auto flex max-w-[90rem] items-center justify-between gap-4 py-4">
            <Div Class="flex min-w-0 flex-1 items-center overflow-hidden">
                <Div Class="no-scrollbar flex items-center">
                    <Anchor Class="flex h-7 shrink-0 items-center justify-center gap-2 px-4 text-center text-base font-medium text-primary"
                            To="https://ui.shadcn.com/" Target="Target.Blank">Examples</Anchor>
                    <Anchor Class="flex h-7 shrink-0 items-center justify-center gap-2 px-4 text-center text-base font-medium text-muted-foreground transition-colors hover:text-primary"
                            To="https://ui.shadcn.com/examples/dashboard" Target="Target.Blank">Dashboard</Anchor>
                    <Anchor Class="flex h-7 shrink-0 items-center justify-center gap-2 px-4 text-center text-base font-medium text-muted-foreground transition-colors hover:text-primary"
                            To="https://ui.shadcn.com/examples/tasks" Target="Target.Blank">Tasks</Anchor>
                    <Anchor Class="flex h-7 shrink-0 items-center justify-center gap-2 px-4 text-center text-base font-medium text-muted-foreground transition-colors hover:text-primary"
                            To="https://ui.shadcn.com/examples/playground" Target="Target.Blank">Playground</Anchor>
                    <Anchor Class="flex h-7 shrink-0 items-center justify-center gap-2 px-4 text-center text-base font-medium text-muted-foreground transition-colors hover:text-primary"
                            To="https://ui.shadcn.com/examples/authentication" Target="Target.Blank">Authentication</Anchor>
                    <Anchor Class="flex h-7 shrink-0 items-center justify-center gap-2 px-4 text-center text-base font-medium text-muted-foreground transition-colors hover:text-primary"
                            To="https://ui.shadcn.com/examples/rtl" Target="Target.Blank">
                        RTL
                        <Span Class="flex size-2 rounded-full bg-blue-500" title="New"></Span>
                    </Anchor>
                </Div>
            </Div>
            <Div Class="hidden items-center gap-2 md:flex">
                <Label Class="sr-only" For="landing-theme-select">Theme</Label>
                <Select TValue="string" @bind-SelectedValue="themeValue" Class="w-36">
                    <SelectTrigger Id="landing-theme-select">
                        <SelectValue Placeholder="Theme" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectItem TValue="string" ItemValue="@("neutral")" Text="Neutral" />
                        <SelectItem TValue="string" ItemValue="@("slate")" Text="Slate" />
                        <SelectItem TValue="string" ItemValue="@("zinc")" Text="Zinc" />
                    </SelectContent>
                </Select>
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Copy code">
                    <Icon Name="LucideIcon.Copy" />
                </Button>
            </Div>
        </Div>
    </Div>

    <Div Class="container-wrapper section-soft flex-1 pb-6">
        <Div Class="container mx-auto max-w-[90rem] overflow-hidden px-4 sm:px-6">
            <Section Class="-mx-4 mb-4 w-[160vw] overflow-hidden rounded-lg border border-border/50 md:hidden md:w-[150vw]">
                <Image Alt="Dashboard"
                       Class="block w-full dark:hidden"
                       Width="1400"
                       Height="875"
                       Decoding="async"
                       Src="@DashboardLightUrl"
                       SrcSet="@DashboardLightSrcSet" />
                <Image Alt="Dashboard"
                       Class="hidden w-full dark:block"
                       Width="1400"
                       Height="875"
                       Decoding="async"
                       Src="@DashboardDarkUrl"
                       SrcSet="@DashboardDarkSrcSet" />
            </Section>

            <Section Class="hidden md:block">
                <Div Class="mx-auto grid w-full grid-cols-1 gap-8 py-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 xl:gap-6 2xl:gap-8">
                    <Div Class="flex min-w-0 w-full flex-col gap-6 *:min-w-0 *:w-full *:max-w-full">
                        <Div Class="w-full rounded-xl border p-6">
                            <form>
                                <FieldGroup>
                                    <FieldSet>
                                        <FieldLegend>Payment Method</FieldLegend>
                                        <FieldDescription>All transactions are secure and encrypted.</FieldDescription>
                                        <FieldGroup>
                                            <Field>
                                                <FieldLabel For="idx-card-name">Name on Card</FieldLabel>
                                                <Input Id="idx-card-name" Placeholder="John Doe" Required="true" />
                                            </Field>
                                            <Div Class="grid grid-cols-3 gap-4">
                                                <Field Class="col-span-2">
                                                    <FieldLabel For="idx-card-number">Card Number</FieldLabel>
                                                    <Input Id="idx-card-number" Placeholder="1234 5678 9012 3456" Required="true" />
                                                    <FieldDescription>Enter your 16-digit number.</FieldDescription>
                                                </Field>
                                                <Field>
                                                    <FieldLabel For="idx-cvv">CVV</FieldLabel>
                                                    <Input Id="idx-cvv" Placeholder="123" Required="true" />
                                                </Field>
                                            </Div>
                                            <Div Class="grid grid-cols-2 gap-4">
                                                <Field>
                                                    <FieldLabel For="idx-exp-month">Month</FieldLabel>
                                                    <Select TValue="string" SelectedValue="@("")">
                                                        <SelectTrigger Id="idx-exp-month">
                                                            <SelectValue Placeholder="MM" />
                                                        </SelectTrigger>
                                                        <SelectContent>
                                                            @foreach (var month in Months)
                                                            {
                                                                <SelectItem TValue="string" ItemValue="@month" Text="@month" />
                                                            }
                                                        </SelectContent>
                                                    </Select>
                                                </Field>
                                                <Field>
                                                    <FieldLabel For="idx-exp-year">Year</FieldLabel>
                                                    <Select TValue="string" SelectedValue="@("")">
                                                        <SelectTrigger Id="idx-exp-year">
                                                            <SelectValue Placeholder="YYYY" />
                                                        </SelectTrigger>
                                                        <SelectContent>
                                                            @foreach (var year in Years)
                                                            {
                                                                <SelectItem TValue="string" ItemValue="@year" Text="@year" />
                                                            }
                                                        </SelectContent>
                                                    </Select>
                                                </Field>
                                            </Div>
                                        </FieldGroup>
                                    </FieldSet>

                                    <FieldSeparator />

                                    <FieldSet>
                                        <FieldLegend>Billing Address</FieldLegend>
                                        <FieldDescription>The billing address associated with your payment method.</FieldDescription>
                                        <FieldGroup>
                                            <Field Horizontal="true">
                                                <Check Id="idx-same-address" Checked="true" />
                                                <FieldLabel For="idx-same-address" FontWeight="FontWeight.Normal">Same as shipping address</FieldLabel>
                                            </Field>
                                        </FieldGroup>
                                    </FieldSet>

                                    <FieldSet>
                                        <FieldGroup>
                                            <Field>
                                                <FieldLabel For="idx-comments">Comments</FieldLabel>
                                                <TextArea Id="idx-comments" Rows="3" Placeholder="Add any additional comments" Class="resize-none" />
                                            </Field>
                                        </FieldGroup>
                                    </FieldSet>

                                    <Field Horizontal="true">
                                        <Button Type="ButtonType.Submit">Submit</Button>
                                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Cancel</Button>
                                    </Field>
                                </FieldGroup>
                            </form>
                        </Div>
                    </Div>

                    <Div Class="flex min-w-0 w-full flex-col gap-6 *:min-w-0 *:w-full *:max-w-full">
                        <Empty Class="flex-none border border-dashed py-10">
                            <EmptyHeader>
                                <EmptyMedia>
                                    <AvatarGroup Class="grayscale">
                                        <Avatar>
                                            <AvatarFallback>CN</AvatarFallback>
                                        </Avatar>
                                        <Avatar>
                                            <AvatarFallback>LR</AvatarFallback>
                                        </Avatar>
                                        <Avatar>
                                            <AvatarFallback>ER</AvatarFallback>
                                        </Avatar>
                                    </AvatarGroup>
                                </EmptyMedia>
                                <EmptyTitle>No Team Members</EmptyTitle>
                                <EmptyDescription>Invite your team to collaborate on this project.</EmptyDescription>
                            </EmptyHeader>
                            <EmptyContent>
                                <Button Size="ButtonSize.Sm">
                                    <Icon Name="LucideIcon.Plus" />
                                    Invite Members
                                </Button>
                            </EmptyContent>
                        </Empty>

                        <Div Class="flex flex-wrap items-center gap-2">
                            <Badge Class="inline-flex items-center gap-1.5">
                                <Icon Name="LucideIcon.LoaderCircle" Class="size-3 animate-spin" />
                                Syncing
                            </Badge>
                            <Badge Variant="BadgeVariant.Secondary" Class="inline-flex items-center gap-1.5">
                                <Icon Name="LucideIcon.LoaderCircle" Class="size-3 animate-spin" />
                                Updating
                            </Badge>
                            <Badge Variant="BadgeVariant.Outline" Class="inline-flex items-center gap-1.5">
                                <Icon Name="LucideIcon.LoaderCircle" Class="size-3 animate-spin" />
                                Loading
                            </Badge>
                        </Div>

                        <ButtonGroup AriaLabel="Compose message">
                            <ButtonGroup>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Add">
                                    <Icon Name="LucideIcon.Plus" />
                                </Button>
                            </ButtonGroup>
                            <ButtonGroup Class="min-w-[16rem] flex-1">
                                <InputGroup Class="w-full">
                                    <InputGroupInput Placeholder="Send a message..." />
                                    <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                        <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Voice mode">
                                            <Icon Name="LucideIcon.AudioLines" />
                                        </InputGroupButton>
                                    </InputGroupAddon>
                                </InputGroup>
                            </ButtonGroup>
                        </ButtonGroup>

                        <Div Class="w-full">
                            <Field>
                                <FieldLabel>Price Range</FieldLabel>
                                <FieldDescription>
                                    Set your budget range ($<Span Class="font-medium tabular-nums">@PriceRangeMin</Span> - <Span Class="font-medium tabular-nums">@PriceRangeMax</Span>).
                                </FieldDescription>
                                <Slider Values="@priceRange"
                                        ValuesChanged="HandlePriceRangeChanged"
                                        Min="0"
                                        Max="1000"
                                        Step="10"
                                        AriaLabel="Price Range"
                                        Class="mt-2 w-full" />
                            </Field>
                        </Div>

                        <Div Class="grid gap-6">
                            <InputGroup>
                                <InputGroupInput Placeholder="Search..." />
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineStart">
                                    <Icon Name="LucideIcon.Search" />
                                </InputGroupAddon>
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                    <InputGroupText>12 results</InputGroupText>
                                </InputGroupAddon>
                            </InputGroup>

                            <InputGroup>
                                <InputGroupInput Placeholder="example.com" Class="pl-1!" />
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineStart">
                                    <InputGroupText>https://</InputGroupText>
                                </InputGroupAddon>
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                    <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Info">
                                        <Icon Name="LucideIcon.Info" />
                                    </InputGroupButton>
                                </InputGroupAddon>
                            </InputGroup>

                            <InputGroup>
                                <InputGroupTextarea Rows="4" Placeholder="Ask, Search or Chat..." />
                                <InputGroupAddon Align="InputGroupAddonAlign.BlockEnd" Class="w-full justify-start gap-1 px-2.5 pb-2">
                                    <InputGroupButton Variant="ButtonVariant.Outline" Size="ButtonSize.IconXs" aria-label="Add">
                                        <Icon Name="LucideIcon.Plus" />
                                    </InputGroupButton>
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Xs">Auto</Button>
                                    <Span Class="ml-auto text-sm text-muted-foreground">52% used</Span>
                                    <Div Class="h-4 w-px bg-border"></Div>
                                    <InputGroupButton Variant="ButtonVariant.Default" Size="ButtonSize.IconXs" aria-label="Send">
                                        <Icon Name="LucideIcon.ArrowUp" />
                                    </InputGroupButton>
                                </InputGroupAddon>
                            </InputGroup>

                            <InputGroup>
                                <InputGroupInput Placeholder="@("@shadcn")" />
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                    <Span Class="flex size-4 items-center justify-center rounded-full bg-primary text-primary-foreground">
                                        <Icon Name="LucideIcon.Check" Class="size-3" />
                                    </Span>
                                </InputGroupAddon>
                            </InputGroup>
                        </Div>
                    </Div>

                    <Div Class="flex min-w-0 w-full flex-col gap-6 *:min-w-0 *:w-full *:max-w-full">
                        <InputGroup Class="[--radius:9999px]">
                            <InputGroupAddon Align="InputGroupAddonAlign.InlineStart">
                                <InputGroupButton Variant="ButtonVariant.Secondary" Size="ButtonSize.IconXs" aria-label="Info">
                                    <Icon Name="LucideIcon.Info" />
                                </InputGroupButton>
                                <InputGroupText>https://</InputGroupText>
                            </InputGroupAddon>
                            <InputGroupInput />
                            <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Favorite">
                                    <Icon Name="LucideIcon.Star" />
                                </InputGroupButton>
                            </InputGroupAddon>
                        </InputGroup>

                        <Div Class="flex flex-col gap-6">
                            <Item Variant="ItemVariant.Outline">
                                <ItemContent>
                                    <ItemTitle>Two-factor authentication</ItemTitle>
                                    <ItemDescription>Verify via email or phone number.</ItemDescription>
                                </ItemContent>
                                <ItemActions>
                                    <Button Size="ButtonSize.Sm">Enable</Button>
                                </ItemActions>
                            </Item>

                            <Item Variant="ItemVariant.Outline" AsChild="true">
                                <Anchor To="#">
                                    <ItemMedia Variant="ItemMediaVariant.Icon">
                                        <Icon Name="LucideIcon.BadgeCheck" Class="size-5" />
                                    </ItemMedia>
                                    <ItemContent>
                                        <ItemTitle>Your profile has been verified.</ItemTitle>
                                    </ItemContent>
                                    <ItemActions>
                                        <Icon Name="LucideIcon.ChevronRight" Class="size-4" />
                                    </ItemActions>
                                </Anchor>
                            </Item>
                        </Div>

                        <FieldSeparator>Appearance Settings</FieldSeparator>

                        <FieldSet>
                            <FieldLegend>Compute Environment</FieldLegend>
                            <FieldDescription>Select the compute environment for your cluster.</FieldDescription>
                            <FieldGroup>
                                <RadioGroup Name="landing-compute" Value="@computeEnvironment" ValueChanged="HandleComputeEnvironmentChanged" AriaLabel="Compute environment">
                                    <FieldLabel For="landing-kubernetes">
                                        <Field Horizontal="true" Class="rounded-lg border p-2.5">
                                            <FieldContent>
                                                <FieldTitle>Kubernetes</FieldTitle>
                                                <FieldDescription>Run GPU workloads on a K8s configured cluster. This is the default.</FieldDescription>
                                            </FieldContent>
                                            <Radio Id="landing-kubernetes" Value="kubernetes" />
                                        </Field>
                                    </FieldLabel>
                                    <FieldLabel For="landing-vm">
                                        <Field Horizontal="true" Class="rounded-lg border p-2.5">
                                            <FieldContent>
                                                <FieldTitle>Virtual Machine</FieldTitle>
                                                <FieldDescription>Access a VM configured cluster to run workloads. (Coming soon)</FieldDescription>
                                            </FieldContent>
                                            <Radio Id="landing-vm" Value="vm" />
                                        </Field>
                                    </FieldLabel>
                                </RadioGroup>

                                <FieldSeparator />

                                <Field Horizontal="true">
                                    <FieldContent>
                                        <FieldLabel For="idx-gpus">Number of GPUs</FieldLabel>
                                        <FieldDescription>You can add more later.</FieldDescription>
                                    </FieldContent>
                                    <ButtonGroup>
                                        <Input Id="idx-gpus" Value="@gpuCount.ToString()" Class="h-7 w-14! font-mono" />
                                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Decrease" OnClick="DecreaseGpuCount">
                                            <Icon Name="LucideIcon.Minus" />
                                        </Button>
                                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Increase" OnClick="IncreaseGpuCount">
                                            <Icon Name="LucideIcon.Plus" />
                                        </Button>
                                    </ButtonGroup>
                                </Field>

                                <FieldSeparator />

                                <Field Horizontal="true">
                                    <FieldContent>
                                        <FieldLabel For="idx-wallpaper">Wallpaper Tinting</FieldLabel>
                                        <FieldDescription>Allow the wallpaper to be tinted.</FieldDescription>
                                    </FieldContent>
                                    <Switch Id="idx-wallpaper" @bind-Checked="wallpaperTinting" />
                                </Field>
                            </FieldGroup>
                        </FieldSet>
                    </Div>

                    <Div Class="order-first flex min-w-0 w-full flex-col gap-6 *:min-w-0 *:w-full *:max-w-full lg:hidden xl:order-last xl:flex">
                        <InputGroup Class="rounded-xl">
                            <InputGroupAddon Align="InputGroupAddonAlign.BlockStart" Class="w-full justify-start px-2.5 pt-3">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" Class="shadow-none">
                                    <Icon Name="LucideIcon.AtSign" />
                                    Add context
                                </Button>
                            </InputGroupAddon>
                            <InputGroupTextarea Rows="4" Placeholder="Ask, search, or make anything..." />
                            <InputGroupAddon Align="InputGroupAddonAlign.BlockEnd" Class="w-full justify-start gap-1 px-2.5 pb-2">
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconSm" Class="rounded-full" aria-label="Attach file">
                                    <Icon Name="LucideIcon.Paperclip" />
                                </Button>
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Class="rounded-full">Auto</Button>
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Class="rounded-full">
                                    <Icon Name="LucideIcon.Globe" />
                                    All Sources
                                </Button>
                                <Button Variant="ButtonVariant.Default" Size="ButtonSize.IconSm" Class="ml-auto rounded-full" aria-label="Send">
                                    <Icon Name="LucideIcon.ArrowUp" />
                                </Button>
                            </InputGroupAddon>
                        </InputGroup>

                        <ButtonGroup AriaLabel="Inbox actions" Class="flex-wrap">
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Archive</Button>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Report</Button>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Snooze</Button>
                        </ButtonGroup>

                        <Card Class="w-full overflow-hidden">
                            <CardHeader Class="pb-2">
                                <CardTitle Class="text-base">Workspace</CardTitle>
                                <CardDescription>Account and security</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <Tabs Composed="true" SelectedTab="account" Class="w-full">
                                    <TabsList Class="w-full justify-start">
                                        <TabsTrigger Value="account">Account</TabsTrigger>
                                        <TabsTrigger Value="security">Security</TabsTrigger>
                                    </TabsList>
                                    <TabsContent Value="account">
                                        <Div Class="mt-3 space-y-3">
                                            <Div Class="space-y-1.5">
                                                <Label For="idx-tab-name">Name</Label>
                                                <Input Id="idx-tab-name" Value="Ada Lovelace" />
                                            </Div>
                                            <Div Class="space-y-1.5">
                                                <Label For="idx-tab-role">Role</Label>
                                                <Input Id="idx-tab-role" Value="Engineer" />
                                            </Div>
                                        </Div>
                                    </TabsContent>
                                    <TabsContent Value="security">
                                        <Div Class="mt-3 space-y-3">
                                            <Div Class="space-y-1.5">
                                                <Label For="idx-tab-pw">Password</Label>
                                                <Input Id="idx-tab-pw" Type="password" Placeholder="********" />
                                            </Div>
                                            <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Rotate keys</Button>
                                        </Div>
                                    </TabsContent>
                                </Tabs>
                            </CardContent>
                        </Card>

                        <FieldSet Class="rounded-xl border p-4">
                            <FieldGroup>
                                <Field Horizontal="true">
                                    <Check Id="idx-terms" @bind-Checked="termsAccepted" />
                                    <FieldLabel For="idx-terms" FontWeight="FontWeight.Normal">I agree to the terms and conditions</FieldLabel>
                                </Field>
                            </FieldGroup>
                        </FieldSet>

                        <Empty Class="w-full border border-dashed py-6 sm:py-8">
                            <EmptyHeader>
                                <EmptyMedia Variant="EmptyMediaVariant.Icon">
                                    <Icon Name="LucideIcon.LoaderCircle" Class="size-4 animate-spin" />
                                </EmptyMedia>
                                <EmptyTitle>Processing your request</EmptyTitle>
                                <EmptyDescription>Please wait while we process your request. Do not refresh the page.</EmptyDescription>
                            </EmptyHeader>
                            <EmptyContent>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Cancel</Button>
                            </EmptyContent>
                        </Empty>
                    </Div>
                </Div>
            </Section>
        </Div>
    </Div>
</Div>

@code {
    private string themeValue = "neutral";
    private double[] priceRange = [200, 800];
    private string computeEnvironment = "kubernetes";
    private int gpuCount = 8;
    private bool wallpaperTinting = true;
    private bool termsAccepted = true;

    private static readonly string[] Months = ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11", "12"];
    private static readonly string[] Years = ["2026", "2027", "2028", "2029", "2030"];

    private string PriceRangeMin => priceRange[0].ToString("0");
    private string PriceRangeMax => priceRange[^1].ToString("0");

    private Task HandlePriceRangeChanged(double[] values)
    {
        priceRange = values;
        return Task.CompletedTask;
    }

    private Task HandleComputeEnvironmentChanged(string? value)
    {
        computeEnvironment = value ?? "kubernetes";
        return Task.CompletedTask;
    }

    private void DecreaseGpuCount()
    {
        if (gpuCount > 1)
            gpuCount--;
    }

    private void IncreaseGpuCount()
    {
        gpuCount++;
    }

    private const string DashboardLightUrl =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-light.png&w=3840&q=75";

    private const string DashboardLightSrcSet =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-light.png&w=1920&q=75 1x, https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-light.png&w=3840&q=75 2x";

    private const string DashboardDarkUrl =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-dark.png&w=3840&q=75";

    private const string DashboardDarkSrcSet =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-dark.png&w=1920&q=75 1x, https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-dark.png&w=3840&q=75 2x";
}
