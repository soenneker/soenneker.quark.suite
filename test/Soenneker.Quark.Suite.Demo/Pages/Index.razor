@page "/"
@layout LandingLayout

<PageTitle>The Foundation for your Design System - shadcn/ui</PageTitle>

<Div Display="Display.Flex" Flex=@("flex flex-col") Class="flex-1">
<Section Class="border-grid">
    <Div Class="container-wrapper">
        <Div Container="true" Class="flex flex-col items-center gap-2 px-6 py-8 text-center md:py-16 lg:py-20 xl:gap-4">
            <Badge AsChild Variant="BadgeVariant.Secondary" Class="bg-muted">
                <Anchor To="sera">
                    Introducing Sera
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3">
                        <path d="M5 12h14"></path>
                        <path d="m12 5 7 7-7 7"></path>
                    </svg>
                </Anchor>
            </Badge>
            <H1 MaxWidth="MaxWidth.Is4xl" TextWrap="TextWrap.Balance" TextSize='TextSize.ThreeXl.OnXl.Token("5xl")' FontWeight="FontWeight.Semibold" Tracking="Tracking.Tight" TextColor="TextColor.Primary" Class="leading-tighter text-3xl lg:leading-[1.1] lg:font-semibold xl:text-5xl xl:tracking-tighter">
                The Foundation for your Design System
            </H1>
            <Paragraph MaxWidth="MaxWidth.Is4xl" TextSize="TextSize.Base.OnSm.Lg" TextWrap="TextWrap.Balance" TextColor="TextColor.Foreground">
                A set of beautifully designed components that you can customize, extend, and build on. Start here then make it your own. Open Source. Open Code.
            </Paragraph>
            <Div Class="flex w-full items-center justify-center gap-2 pt-2 **:data-[slot=button]:shadow-none">
                <Button AsChild="true" Size="ButtonSize.Sm" Class="h-[31px] rounded-lg">
                    <Anchor To="create">New Project</Anchor>
                </Button>
                <Button AsChild="true" Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Class="rounded-lg">
                    <Anchor To="docs/components">View Components</Anchor>
                </Button>
            </Div>
        </Div>
    </Div>
</Section>

<Div Flex=@("flex-1") Class="container-wrapper pb-6">
<Div Container="true" Overflow="Overflow.Hidden">
<Section Overflow="Overflow.Hidden" Rounded="Rounded.Lg" Border="Border.Is1" BorderColor='BorderColor.Token("border/50")' Class="-mx-4 w-[160vw] md:hidden md:w-[150vw]">
    <Image Alt="Dashboard" Display="Display.Block" Width="Width.IsFull" Height="875" Decoding="async" Src="@DashboardLightUrl" SrcSet="@DashboardLightSrcSet" Class="dark:hidden"/>
    <Image Alt="Dashboard" Width="Width.IsFull" Height="875" Decoding="async" Src="@DashboardDarkUrl" SrcSet="@DashboardDarkSrcSet" Class="hidden dark:block"/>
</Section>

<Section Class="hidden theme-container md:block">
<Div Margin="Margin.Auto.OnX" Display="Display.Grid" Padding="Padding.Is1.OnY" Class="theme-container gap-8 md:grid-cols-2 lg:grid-cols-3 xl:gap-6 xl:grid-cols-4 2xl:gap-8">
<Div Display="Display.Flex" Flex=@("flex flex-col") Gap='Gap.Token("6")' Class="*:[div]:w-full *:[div]:max-w-full">
    <Div Width="Width.IsFull" MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" Padding="Padding.Is6">
        <form>
            <FieldGroup>
                <FieldSet>
                    <FieldLegend>Payment Method</FieldLegend>
                    <FieldDescription>All transactions are secure and encrypted</FieldDescription>

                    <FieldGroup>
                        <Field>
                            <FieldLabel For="idx-card-name">Name on Card</FieldLabel>
                            <Input Id="idx-card-name" Placeholder="John Doe" Required="true"/>
                        </Field>
                        <Grid Columns="GridCols.Is3" Gap="Gap.Is4">
                            <Field Class="col-span-2">
                                <FieldLabel For="idx-card-number">Card Number</FieldLabel>
                                <Input Id="idx-card-number" Placeholder="1234 5678 9012 3456" Required="true"/>
                                <FieldDescription>Enter your 16-digit number.</FieldDescription>
                            </Field>
                            <Field>
                                <FieldLabel For="idx-cvv">CVV</FieldLabel>
                                <Input Id="idx-cvv" Placeholder="123" Required="true"/>
                            </Field>
                        </Grid>
                        <Grid Columns="GridCols.Is2" Gap="Gap.Is4">
                            <Field>
                                <FieldLabel For="idx-exp-month">Month</FieldLabel>
                                <Select TValue="string" SelectedValue="@("")">
                                    <SelectTrigger Id="idx-exp-month">
                                        <SelectValue Placeholder="MM"/>
                                    </SelectTrigger>
                                    <SelectContent>
                                        @foreach (var month in Months)
                                        {
                                            <SelectItem TValue="string" ItemValue="@month" Text="@month"/>
                                        }
                                    </SelectContent>
                                </Select>
                            </Field>
                            <Field>
                                <FieldLabel For="idx-exp-year">Year</FieldLabel>
                                <Select TValue="string" SelectedValue="@("")">
                                    <SelectTrigger Id="idx-exp-year">
                                        <SelectValue Placeholder="YYYY"/>
                                    </SelectTrigger>
                                    <SelectContent>
                                        @foreach (var year in Years)
                                        {
                                            <SelectItem TValue="string" ItemValue="@year" Text="@year"/>
                                        }
                                    </SelectContent>
                                </Select>
                            </Field>
                        </Grid>
                    </FieldGroup>
                </FieldSet>

                <FieldSeparator/>

                <FieldSet>
                    <FieldLegend>Billing Address</FieldLegend>
                    <FieldDescription>The billing address associated with your payment method</FieldDescription>

                    <FieldGroup>
                        <Field Horizontal="true">
                            <Check Id="idx-same-address" Checked="true"/>
                            <FieldLabel For="idx-same-address" FontWeight="FontWeight.Normal">Same as shipping address</FieldLabel>
                        </Field>
                    </FieldGroup>
                </FieldSet>

                <FieldSeparator/>

                <FieldSet>
                    <FieldGroup>
                        <Field>
                            <FieldLabel For="idx-comments">Comments</FieldLabel>
                            <TextArea Id="idx-comments" Rows="3" Placeholder="Add any additional comments" Class="resize-none" />
                        </Field>
                    </FieldGroup>
                </FieldSet>

                <Field Horizontal="true">
                    <Button Type="ButtonType.Submit">Submit</Button>
                    <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Cancel</Button>
                </Field>
            </FieldGroup>
        </form>
    </Div>
</Div>

<Div Display="Display.Flex" Flex=@("flex flex-col") Gap='Gap.Token("6")' Class="*:[div]:w-full *:[div]:max-w-full">
    <Empty Class="py-10">
        <EmptyHeader>
            <EmptyMedia>
                <AvatarGroup>
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>TM</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")"/>
                        <AvatarFallback>TM</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                        <AvatarFallback>TM</AvatarFallback>
                    </Avatar>
                </AvatarGroup>
            </EmptyMedia>
            <EmptyTitle>No Team Members</EmptyTitle>
            <EmptyDescription>Invite your team to collaborate on this project.</EmptyDescription>
        </EmptyHeader>
        <EmptyContent>
            <Button Variant="ButtonVariant.Default" Size="ButtonSize.Sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14"></path>
                    <path d="M12 5v14"></path>
                </svg>
                Invite Members
            </Button>
        </EmptyContent>
    </Empty>

    <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap="Gap.Is2">
        <Badge Display="Display.InlineFlex" ItemsAlign="Items.Center" Gap='Gap.Token("1.5")'>
            <Icon Name="LucideIcon.LoaderCircle" BoxSize="Size.Is3" Animation="Animation.Spin"/>
            Syncing
        </Badge>
        <Badge Variant="BadgeVariant.Secondary" Display="Display.InlineFlex" ItemsAlign="Items.Center" Gap='Gap.Token("1.5")'>
            <Icon Name="LucideIcon.LoaderCircle" BoxSize="Size.Is3" Animation="Animation.Spin"/>
            Updating
        </Badge>
        <Badge Variant="BadgeVariant.Outline" Display="Display.InlineFlex" ItemsAlign="Items.Center" Gap='Gap.Token("1.5")'>
            <Icon Name="LucideIcon.LoaderCircle" BoxSize="Size.Is3" Animation="Animation.Spin"/>
            Loading
        </Badge>
    </Div>

    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2">
        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Add">
            <Icon Name="LucideIcon.Plus"/>
        </Button>
        <InputGroup Flex=@("flex-1")>
            <InputGroupInput Placeholder="Send a message..."/>
            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Voice mode">
                    <Icon Name="LucideIcon.AudioLines"/>
                </InputGroupButton>
            </InputGroupAddon>
        </InputGroup>
    </Div>

    <Div Width="Width.IsFull">
        <Field>
            <FieldTitle>Price Range</FieldTitle>
            <FieldDescription>
                Set your budget range ($<Span FontWeight="FontWeight.Medium" Class="tabular-nums">@PriceRangeMin</Span> - <Span FontWeight="FontWeight.Medium" Class="tabular-nums">@PriceRangeMax</Span>).
            </FieldDescription>
            <Slider Values="@priceRange" ValuesChanged="HandlePriceRangeChanged" Min="0" Max="1000" Step="10" AriaLabel="Price Range" Width="Width.IsFull" Margin="Margin.Is2.FromTop"/>
        </Field>
    </Div>

    <Div Display="Display.Flex" Flex=@("flex flex-col") Gap='Gap.Token("6")'>
        <InputGroup>
            <InputGroupInput Placeholder="Search..."/>
            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                <Icon Name="LucideIcon.Search"/>
            </InputGroupAddon>
            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                <InputGroupText>12 results</InputGroupText>
            </InputGroupAddon>
        </InputGroup>

        <InputGroup>
            <InputGroupInput Placeholder="example.com"/>
            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                <InputGroupText>https://</InputGroupText>
            </InputGroupAddon>
            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Info">
                    <Icon Name="LucideIcon.Info"/>
                </InputGroupButton>
            </InputGroupAddon>
        </InputGroup>

        <Div Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" BoxShadow="BoxShadow.Small">
            <TextArea Rows="4"
                                          Placeholder="Ask, Search or Chat..."
                                          Class="min-h-24 resize-none border-0! bg-transparent px-0 py-0 shadow-none! focus-visible:ring-0!" />
            <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap='Gap.Token("1.5")' Margin="Margin.Is3.FromTop" Padding="Padding.Is3.FromTop" Border="Border.Is1.FromTop">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconXs" aria-label="Add">
                    <Icon Name="LucideIcon.Plus"/>
                </Button>
                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Xs">Auto</Button>
                <Span Margin="Margin.Auto.FromStart" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">52% used</Span>
                <Button Variant="ButtonVariant.Default" Size="ButtonSize.IconXs" Rounded="Rounded.Full" aria-label="Send">
                    <Icon Name="LucideIcon.ArrowUp"/>
                </Button>
            </Div>
        </Div>

        <InputGroup>
            <InputGroupInput Placeholder="@("@shadcn")"/>
            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                <Span Display="Display.Flex" BoxSize="Size.Is4" ItemsAlign="Items.Center" Justify="Justify.Center" Rounded="Rounded.Full" BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.PrimaryForeground">
                    <Icon Name="LucideIcon.Check" BoxSize="Size.Is3"/>
                </Span>
            </InputGroupAddon>
        </InputGroup>
    </Div>
</Div>

<Div Display="Display.Flex" Flex=@("flex flex-col") Gap='Gap.Token("6")' Class="*:[div]:w-full *:[div]:max-w-full">
    <InputGroup Class="[--radius:9999px]">
        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
            <InputGroupButton Variant="ButtonVariant.Secondary" Size="ButtonSize.IconXs" aria-label="Info">
                <Icon Name="LucideIcon.Info"/>
            </InputGroupButton>
            <InputGroupText>https://</InputGroupText>
        </InputGroupAddon>
        <InputGroupInput/>
        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
            <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Favorite">
                <Icon Name="LucideIcon.Star"/>
            </InputGroupButton>
        </InputGroupAddon>
    </InputGroup>

    <Div Display="Display.Flex" Flex=@("flex flex-col") Gap='Gap.Token("6")'>
        <Item Variant="ItemVariant.Outline">
            <ItemContent MinWidth="MinWidth.Is0">
                <ItemTitle>Two-factor authentication</ItemTitle>
                <ItemDescription>Verify via email or phone number.</ItemDescription>
            </ItemContent>
            <ItemActions Shrink="Shrink.Is0">
                <Button Size="ButtonSize.Sm">Enable</Button>
            </ItemActions>
        </Item>

        <Item Variant="ItemVariant.Outline" AsChild="true">
            <Anchor To="#">
                <ItemMedia>
                    <Icon Name="LucideIcon.BadgeCheck" BoxSize="Size.Is5"/>
                </ItemMedia>
                <ItemContent>
                    <ItemTitle>Your profile has been verified.</ItemTitle>
                </ItemContent>
                <ItemActions>
                    <Icon Name="LucideIcon.ChevronRight" BoxSize="Size.Is4"/>
                </ItemActions>
            </Anchor>
        </Item>
    </Div>

    <FieldSeparator Class="my-4">Appearance Settings</FieldSeparator>

    <FieldSet>
        <FieldLegend>Compute Environment</FieldLegend>
        <FieldDescription>Select the compute environment for your cluster.</FieldDescription>
        <FieldGroup>
            <RadioGroup Name="landing-compute" Value="@computeEnvironment" ValueChanged="HandleComputeEnvironmentChanged" AriaLabel="Compute environment">
                <FieldLabel For="landing-kubernetes">
                    <Field Horizontal="true">
                        <FieldContent>
                            <FieldTitle>Kubernetes</FieldTitle>
                            <FieldDescription>Run GPU workloads on a K8s configured cluster. This is the default.</FieldDescription>
                        </FieldContent>
                        <Radio Id="landing-kubernetes" Value="kubernetes"/>
                    </Field>
                </FieldLabel>
                <FieldLabel For="landing-vm">
                    <Field Horizontal="true">
                        <FieldContent>
                            <FieldTitle>Virtual Machine</FieldTitle>
                            <FieldDescription>Access a VM configured cluster to run workloads. (Coming soon)</FieldDescription>
                        </FieldContent>
                        <Radio Id="landing-vm" Value="vm"/>
                    </Field>
                </FieldLabel>
            </RadioGroup>

            <FieldSeparator/>

            <Field Horizontal="true">
                <FieldContent>
                    <FieldLabel For="idx-gpus">Number of GPUs</FieldLabel>
                    <FieldDescription>You can add more later.</FieldDescription>
                </FieldContent>
                <ButtonGroup>
                    <Input Id="idx-gpus" Value="@gpuCount.ToString()" Class="h-7 w-14! font-mono"/>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Decrease" OnClick="DecreaseGpuCount">
                        <Icon Name="LucideIcon.Minus"/>
                    </Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Increase" OnClick="IncreaseGpuCount">
                        <Icon Name="LucideIcon.Plus"/>
                    </Button>
                </ButtonGroup>
            </Field>

            <FieldSeparator/>

            <Field Horizontal="true">
                <FieldContent>
                    <FieldLabel For="idx-wallpaper">Wallpaper Tinting</FieldLabel>
                    <FieldDescription>Allow the wallpaper to be tinted.</FieldDescription>
                </FieldContent>
                <Switch Id="idx-wallpaper" @bind-Checked="wallpaperTinting"/>
            </Field>
        </FieldGroup>
    </FieldSet>
</Div>

<Div Display="Display.Flex" Flex=@("flex flex-col") Gap='Gap.Token("6")' Class="order-first lg:hidden xl:order-last xl:flex *:[div]:w-full *:[div]:max-w-full">
    <Div Rounded='Rounded.Token("2xl")' Border="Border.Is1" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" BoxShadow="BoxShadow.Small">
        <Div Margin="Margin.Is3.FromBottom">
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" Rounded="Rounded.Full" BoxShadow="BoxShadow.None">
                <Icon Name="LucideIcon.AtSign"/>
                Add context
            </Button>
        </Div>
        <TextArea Rows="4"
                                      Placeholder="Ask, search, or make anything..."
                                      Class="min-h-28 resize-none border-0! bg-transparent px-0 py-0 shadow-none! focus-visible:ring-0!" />
        <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" Margin="Margin.Is3.FromTop" Padding="Padding.Is3.FromTop" Border="Border.Is1.FromTop">
            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconSm" Rounded="Rounded.Full" aria-label="Attach file">
                <Icon Name="LucideIcon.Paperclip"/>
            </Button>
            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Rounded="Rounded.Full" Padding="Padding.Is3.OnX">Auto</Button>
            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Rounded="Rounded.Full" Padding="Padding.Is3.OnX">
                <Icon Name="LucideIcon.Globe"/>
                All Sources
            </Button>
            <Button Variant="ButtonVariant.Default" Size="ButtonSize.IconSm" Rounded="Rounded.Full" Margin="Margin.Auto.FromStart" aria-label="Send">
                <Icon Name="LucideIcon.ArrowUp"/>
            </Button>
        </Div>
    </Div>

    <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Gap="Gap.Is3">
        <ButtonGroup AriaLabel="Inbox actions">
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Back">
                <Icon Name="LucideIcon.ArrowLeft"/>
            </Button>
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Archive</Button>
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Report</Button>
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Snooze</Button>
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="More">
                <Icon Name="LucideIcon.Ellipsis"/>
            </Button>
        </ButtonGroup>
    </Div>

    <FieldLabel For="idx-terms">
        <Field Horizontal="true">
            <Check Id="idx-terms" @bind-Checked="termsAccepted"/>
            <FieldLabel For="idx-terms" Class="line-clamp-1">I agree to the terms and conditions</FieldLabel>
        </Field>
    </FieldLabel>

    <Div Display="Display.Flex" Justify="Justify.Between" Gap="Gap.Is4">
        <ButtonGroup>
            <ButtonGroup AriaLabel="Pagination">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">1</Button>
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">2</Button>
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">3</Button>
            </ButtonGroup>
            <ButtonGroup AriaLabel="Pagination arrows">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Previous">
                    <Icon Name="LucideIcon.ArrowLeft"/>
                </Button>
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Next">
                    <Icon Name="LucideIcon.ArrowRight"/>
                </Button>
            </ButtonGroup>
        </ButtonGroup>
        <ButtonGroup>
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">
                <Icon Name="LucideIcon.Bot"/>
                Copilot
            </Button>
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Open Popover">
                <Icon Name="LucideIcon.ChevronDown"/>
            </Button>
        </ButtonGroup>
    </Div>

    <Card Gap="Gap.Is4"
          Padding="Padding.Is4.OnY"
          BoxShadow="BoxShadow.None">
        <CardContent Padding="Padding.Is4.OnX">
            <form>
                <FieldGroup>
                    <FieldSet>
                        <FieldLegend>How did you hear about us?</FieldLegend>
                        <FieldDescription Class="line-clamp-1">Select the option that best describes how you heard about us.</FieldDescription>
                        <div data-slot="field-group" class="group/field-group @@container/field-group flex w-full flex-row flex-wrap gap-2 [--radius:9999rem]">
                            <FieldLabel For="landing-social-media" Class="w-fit!">
                                <Field Horizontal="true" Gap='Gap.Token("1.5")' Overflow="Overflow.Hidden" Class="px-3! py-1.5! transition-all duration-100 ease-linear group-has-data-[state=checked]/field-label:px-2!">
                                    <Check Id="landing-social-media" Value="social-media" @bind-Checked="heardSocialMedia" IndicatorClass="-ml-6 -translate-x-1 rounded-full transition-all duration-100 ease-linear data-[state=checked]:ml-0 data-[state=checked]:translate-x-0"/>
                                    <FieldTitle>Social Media</FieldTitle>
                                </Field>
                            </FieldLabel>
                            <FieldLabel For="landing-search-engine" Class="w-fit!">
                                <Field Horizontal="true" Gap='Gap.Token("1.5")' Overflow="Overflow.Hidden" Class="px-3! py-1.5! transition-all duration-100 ease-linear group-has-data-[state=checked]/field-label:px-2!">
                                    <Check Id="landing-search-engine" Value="search-engine" @bind-Checked="heardSearchEngine" IndicatorClass="-ml-6 -translate-x-1 rounded-full transition-all duration-100 ease-linear data-[state=checked]:ml-0 data-[state=checked]:translate-x-0"/>
                                    <FieldTitle>Search Engine</FieldTitle>
                                </Field>
                            </FieldLabel>
                            <FieldLabel For="landing-referral" Class="w-fit!">
                                <Field Horizontal="true" Gap='Gap.Token("1.5")' Overflow="Overflow.Hidden" Class="px-3! py-1.5! transition-all duration-100 ease-linear group-has-data-[state=checked]/field-label:px-2!">
                                    <Check Id="landing-referral" Value="referral" @bind-Checked="heardReferral" IndicatorClass="-ml-6 -translate-x-1 rounded-full transition-all duration-100 ease-linear data-[state=checked]:ml-0 data-[state=checked]:translate-x-0"/>
                                    <FieldTitle>Referral</FieldTitle>
                                </Field>
                            </FieldLabel>
                            <FieldLabel For="landing-other" Class="w-fit!">
                                <Field Horizontal="true" Gap='Gap.Token("1.5")' Overflow="Overflow.Hidden" Class="px-3! py-1.5! transition-all duration-100 ease-linear group-has-data-[state=checked]/field-label:px-2!">
                                    <Check Id="landing-other" Value="other" @bind-Checked="heardOther" IndicatorClass="-ml-6 -translate-x-1 rounded-full transition-all duration-100 ease-linear data-[state=checked]:ml-0 data-[state=checked]:translate-x-0"/>
                                    <FieldTitle>Other</FieldTitle>
                                </Field>
                            </FieldLabel>
                        </div>
                    </FieldSet>
                </FieldGroup>
            </form>
        </CardContent>
    </Card>

    <Empty Width="Width.IsFull" Border="Border.Is1" Padding='Padding.Is6.OnY.OnSm.Is8.OnY' Class="border-dashed">
        <EmptyHeader>
            <EmptyMedia Variant="EmptyMediaVariant.Icon">
                <Icon Name="LucideIcon.LoaderCircle" Class="size-4 animate-spin"/>
            </EmptyMedia>
            <EmptyTitle>Processing your request</EmptyTitle>
            <EmptyDescription>Please wait while we process your request. Do not refresh the page.</EmptyDescription>
        </EmptyHeader>
        <EmptyContent>
            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Cancel</Button>
        </EmptyContent>
    </Empty>
</Div>
</Div>
</Section>
</Div>
</Div>
</Div>

@code {
    private double[] priceRange = [200, 800];
    private string computeEnvironment = "kubernetes";
    private int gpuCount = 8;
    private bool wallpaperTinting = true;
    private bool termsAccepted = true;
    private bool heardSocialMedia = true;
    private bool heardSearchEngine;
    private bool heardReferral;
    private bool heardOther;

    private static readonly string[] Months = ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11", "12"];
    private static readonly string[] Years = ["2026", "2027", "2028", "2029", "2030"];

    private string PriceRangeMin => priceRange[0]
        .ToString("0");

    private string PriceRangeMax => priceRange[^1]
        .ToString("0");

    private Task HandlePriceRangeChanged(double[] values)
    {
        priceRange = values;
        return Task.CompletedTask;
    }

    private Task HandleComputeEnvironmentChanged(string? value)
    {
        computeEnvironment = value ?? "kubernetes";
        return Task.CompletedTask;
    }

    private void DecreaseGpuCount()
    {
        if (gpuCount > 1)
            gpuCount--;
    }

    private void IncreaseGpuCount()
    {
        gpuCount++;
    }

    private const string DashboardLightUrl = "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-light.png&w=3840&q=75";

