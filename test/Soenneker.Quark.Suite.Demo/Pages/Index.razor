@page "/"

<PageTitle>Quark Suite</PageTitle>

<div class="min-w-0 flex flex-col">
    <section class="mx-auto grid min-w-0 w-full max-w-6xl gap-10 px-4 pt-16 pb-12 md:px-6 md:pt-24 lg:grid-cols-[minmax(0,1.2fr)_minmax(0,.8fr)] lg:items-center">
        <div class="min-w-0">
            <div class="inline-flex items-center rounded-full border border-border bg-background px-3 py-1 text-xs font-medium text-muted-foreground">
                Blazor component library for .NET
            </div>

            <h1 class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-balance sm:text-5xl md:text-6xl">
                Build modern Blazor apps with components that feel native to Razor.
            </h1>

            <p class="mt-5 max-w-2xl text-base leading-7 text-muted-foreground sm:text-lg">
                Quark Suite is more than a visual port. It is a Blazor-first UI toolkit with polished components,
                type-safe styling APIs, and theming that fits naturally into your .NET application architecture.
            </p>

            <div class="mt-7 flex flex-wrap items-center gap-3">
                <a href="/components" class="inline-flex h-9 items-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90">
                    Browse components
                </a>
                <a href="#getting-started" class="inline-flex h-9 items-center rounded-lg px-3 text-sm font-medium text-foreground transition-colors hover:bg-accent">
                    Getting started
                </a>
            </div>

            <div class="mt-8 grid min-w-0 gap-3 sm:grid-cols-3">
                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <p class="text-sm font-medium">60+ components</p>
                    <p class="mt-1 text-sm text-muted-foreground">Forms, navigation, overlays, media, charts, tables, and more.</p>
                </div>
                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <p class="text-sm font-medium">Type-safe styling</p>
                    <p class="mt-1 text-sm text-muted-foreground">Compose UI with enums and helpers instead of fragile string-only CSS.</p>
                </div>
                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <p class="text-sm font-medium">Theme ready</p>
                    <p class="mt-1 text-sm text-muted-foreground">Use runtime theming with <code>ThemeHost</code> or ship prebuilt CSS.</p>
                </div>
            </div>
        </div>

        <div class="min-w-0 rounded-2xl border border-border bg-card p-4 shadow-sm sm:p-6">
            <div class="flex flex-col gap-3 border-b border-border pb-4 sm:flex-row sm:items-center sm:justify-between">
                <div class="min-w-0">
                    <p class="text-sm font-medium">Quark in a Blazor app</p>
                    <p class="text-xs text-muted-foreground">Minimal setup, familiar .NET flow</p>
                </div>
                <span class="shrink-0 rounded-full border border-border px-2.5 py-1 text-xs text-muted-foreground">Razor + DI</span>
            </div>

            <div id="getting-started" class="mt-4 min-w-0 space-y-4">
                <div class="min-w-0 rounded-xl border border-border bg-background p-4">
                    <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Install</p>
                    <pre class="mt-3 max-w-full overflow-x-auto rounded-lg bg-muted/50 p-3 text-sm leading-6 text-foreground"><code>dotnet add package Soenneker.Quark.Suite</code></pre>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-background p-4">
                    <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Register</p>
                    <pre class="mt-3 max-w-full overflow-x-auto rounded-lg bg-muted/50 p-3 text-sm leading-6 text-foreground"><code>builder.Services.AddQuarkSuiteAsScoped();

var host = builder.Build();
await host.Services.LoadQuarkResources();</code></pre>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-background p-4">
                    <p class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Build UI</p>
                    <pre class="mt-3 max-w-full overflow-x-auto rounded-lg bg-muted/50 p-3 text-sm leading-6 text-foreground"><code>&lt;Button Color="@@Color.Primary"&gt;Save&lt;/Button&gt;

&lt;Input Placeholder="Search..." /&gt;
&lt;Card&gt;...&lt;/Card&gt;</code></pre>
                </div>
            </div>
        </div>
    </section>

    <section class="mx-auto min-w-0 w-full max-w-6xl border-y border-border px-4 py-8 md:px-6 md:py-10">
        <div class="flex min-w-0 flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <div class="min-w-0">
                <p class="text-sm font-medium text-primary">Examples</p>
                <h2 class="mt-1 text-2xl font-semibold tracking-tight">Blazor app patterns, not just component screenshots</h2>
                <p class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">
                    Quark is meant for real Razor pages, dashboards, forms, dialogs, navigation, and data-heavy interfaces. The landing page should feel like that too.
                </p>
            </div>
            <div class="flex flex-wrap gap-2 text-xs text-muted-foreground">
                <span class="rounded-full border border-border px-3 py-1.5">Forms</span>
                <span class="rounded-full border border-border px-3 py-1.5">Data</span>
                <span class="rounded-full border border-border px-3 py-1.5">Navigation</span>
                <span class="rounded-full border border-border px-3 py-1.5">Overlays</span>
                <span class="rounded-full border border-border px-3 py-1.5">Theming</span>
            </div>
        </div>

        <div class="mt-6 grid min-w-0 gap-4 md:grid-cols-3">
            <div class="min-w-0 space-y-4">
                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="space-y-1">
                        <p class="text-sm font-medium">Profile editor</p>
                        <p class="text-xs text-muted-foreground">Typical Blazor form layout with sections, fields, and actions.</p>
                    </div>
                    <div class="mt-4 space-y-3">
                        <div class="space-y-1.5">
                            <label class="text-xs font-medium">Display Name</label>
                            <div class="h-9 rounded-md border border-input bg-background px-3"></div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-xs font-medium">Email</label>
                            <div class="h-9 rounded-md border border-input bg-background px-3"></div>
                        </div>
                        <div class="space-y-1.5">
                            <label class="text-xs font-medium">Bio</label>
                            <div class="h-20 rounded-md border border-input bg-background px-3"></div>
                        </div>
                        <div class="flex justify-end gap-2">
                            <span class="rounded-md border border-border px-3 py-1.5 text-xs">Cancel</span>
                            <span class="rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground">Save</span>
                        </div>
                    </div>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div class="min-w-0">
                            <p class="text-sm font-medium">Theme host</p>
                            <p class="mt-1 text-xs text-muted-foreground">Runtime theme switching for branded apps.</p>
                        </div>
                        <span class="w-fit shrink-0 rounded-full border border-border px-2 py-1 text-[11px]">Live</span>
                    </div>
                    <div class="mt-4 grid grid-cols-3 gap-2">
                        <div class="rounded-lg border border-border bg-background p-3 text-center text-xs">Slate</div>
                        <div class="rounded-lg border border-primary bg-primary/10 p-3 text-center text-xs font-medium">Ocean</div>
                        <div class="rounded-lg border border-border bg-background p-3 text-center text-xs">Graphite</div>
                    </div>
                    <div class="mt-3 rounded-lg border border-border bg-background p-3">
                        <div class="flex items-center justify-between text-xs">
                            <span>Dark mode</span>
                            <span class="h-5 w-9 rounded-full bg-primary/20 p-0.5">
                                <span class="block size-4 rounded-full bg-primary"></span>
                            </span>
                        </div>
                    </div>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <p class="text-sm font-medium">Validation summary</p>
                    <div class="mt-4 space-y-2">
                        <div class="rounded-lg border border-amber-500/30 bg-amber-500/10 p-3 text-xs text-amber-700 dark:text-amber-300">
                            3 fields need attention before the form can be submitted.
                        </div>
                        <div class="rounded-lg border border-border bg-background p-3 text-xs text-muted-foreground">Password must contain at least 12 characters.</div>
                        <div class="rounded-lg border border-border bg-background p-3 text-xs text-muted-foreground">Billing address is required.</div>
                    </div>
                </div>
            </div>

            <div class="min-w-0 space-y-4">
                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <div class="min-w-0">
                            <p class="text-sm font-medium">Operations dashboard</p>
                            <p class="mt-1 text-xs text-muted-foreground">Cards, badges, charts, and status snapshots.</p>
                        </div>
                        <span class="w-fit shrink-0 rounded-full border border-border px-2 py-1 text-[11px]">Server</span>
                    </div>
                    <div class="mt-4 grid grid-cols-2 gap-3">
                        <div class="rounded-lg border border-border bg-background p-3">
                            <p class="text-xs text-muted-foreground">Active users</p>
                            <p class="mt-2 text-lg font-semibold">12,482</p>
                        </div>
                        <div class="rounded-lg border border-border bg-background p-3">
                            <p class="text-xs text-muted-foreground">Deployments</p>
                            <p class="mt-2 text-lg font-semibold">24</p>
                        </div>
                    </div>
                    <div class="mt-3 flex items-end gap-2 rounded-lg border border-border bg-background p-3">
                        <span class="h-12 w-1/6 rounded-sm bg-primary/30"></span>
                        <span class="h-20 w-1/6 rounded-sm bg-primary/45"></span>
                        <span class="h-10 w-1/6 rounded-sm bg-primary/30"></span>
                        <span class="h-24 w-1/6 rounded-sm bg-primary/70"></span>
                        <span class="h-16 w-1/6 rounded-sm bg-primary/45"></span>
                        <span class="h-20 w-1/6 rounded-sm bg-primary"></span>
                    </div>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-sm font-medium">Paged data table</p>
                        <span class="text-xs text-muted-foreground">Server-side</span>
                    </div>
                    <div class="mt-4 min-w-0 overflow-x-auto rounded-lg border border-border bg-background">
                        <div class="grid min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs font-medium text-muted-foreground">
                            <span>Employee</span>
                            <span>Department</span>
                            <span>Status</span>
                        </div>
                        <div class="grid min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs">
                            <span>Olivia Martin</span>
                            <span>Finance</span>
                            <span>Active</span>
                        </div>
                        <div class="grid min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs">
                            <span>Jackson Lee</span>
                            <span>Support</span>
                            <span>Pending</span>
                        </div>
                        <div class="grid min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] px-3 py-2 text-xs">
                            <span>Sophia Chen</span>
                            <span>Platform</span>
                            <span>Active</span>
                        </div>
                    </div>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="flex min-w-0 flex-wrap items-center gap-2 text-xs text-muted-foreground">
                        <span class="rounded-full border border-border px-2 py-1 text-foreground">Sonner</span>
                        <span>Async save</span>
                        <span>Undo</span>
                    </div>
                    <div class="mt-4 space-y-2">
                        <div class="rounded-lg border border-border bg-background p-3">
                            <p class="text-sm font-medium">Template saved</p>
                            <p class="mt-1 text-xs text-muted-foreground">Changes were synced to the current workspace.</p>
                        </div>
                        <div class="rounded-lg border border-border bg-background p-3">
                            <p class="text-sm font-medium">Background job queued</p>
                            <p class="mt-1 text-xs text-muted-foreground">Export will be ready in a few moments.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="min-w-0 space-y-4">
                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <p class="text-sm font-medium">Application shell</p>
                        <p class="text-xs text-muted-foreground">Sidebar + top actions</p>
                    </div>
                    <div class="mt-4 grid gap-3 sm:grid-cols-[92px_1fr]">
                        <div class="rounded-lg border border-border bg-background p-2 text-xs">
                            <div class="rounded-md bg-accent px-2 py-1.5 font-medium">Overview</div>
                            <div class="mt-1 px-2 py-1.5 text-muted-foreground">Projects</div>
                            <div class="mt-1 px-2 py-1.5 text-muted-foreground">Reports</div>
                            <div class="mt-1 px-2 py-1.5 text-muted-foreground">Settings</div>
                        </div>
                        <div class="min-w-0 rounded-lg border border-border bg-background p-3">
                            <div class="flex min-w-0 flex-col gap-2 text-xs sm:flex-row sm:items-center sm:justify-between">
                                <span class="font-medium">Team workspace</span>
                                <span class="w-fit rounded-full border border-border px-2 py-1">Beta</span>
                            </div>
                            <div class="mt-3 h-20 rounded-md border border-dashed border-border"></div>
                        </div>
                    </div>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="space-y-1">
                        <p class="text-sm font-medium">Access request dialog</p>
                        <p class="text-xs text-muted-foreground">Overlays for approvals, confirmations, and workflow gates.</p>
                    </div>
                    <div class="mt-4 rounded-xl border border-border bg-background p-4">
                        <p class="text-sm font-medium">Grant access to staging?</p>
                        <p class="mt-1 text-xs text-muted-foreground">This will allow the release manager to deploy builds and view logs.</p>
                        <div class="mt-4 flex justify-end gap-2">
                            <span class="rounded-md border border-border px-3 py-1.5 text-xs">Cancel</span>
                            <span class="rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground">Approve</span>
                        </div>
                    </div>
                </div>

                <div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div class="min-w-0">
                            <p class="text-sm font-medium">Command + quick actions</p>
                            <p class="mt-1 text-xs text-muted-foreground">Useful for keyboard-first Blazor workflows.</p>
                        </div>
                        <span class="w-fit shrink-0 rounded-md border border-border px-2 py-1 text-[11px]">Ctrl K</span>
                    </div>
                    <div class="mt-4 rounded-lg border border-border bg-background p-3">
                        <p class="text-sm text-muted-foreground">Search pages, commands, or components...</p>
                    </div>
                    <div class="mt-3 space-y-2 text-xs">
                        <div class="flex min-w-0 items-center justify-between gap-3 rounded-lg border border-border bg-background p-3">
                            <span>Open component catalog</span>
                            <span class="text-muted-foreground">Enter</span>
                        </div>
                        <div class="flex min-w-0 items-center justify-between gap-3 rounded-lg border border-border bg-background p-3">
                            <span>Create new page scaffold</span>
                            <span class="text-muted-foreground">Enter</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mx-auto min-w-0 w-full max-w-6xl px-4 pb-14 md:px-6 md:pb-20">
        <div class="min-w-0 rounded-2xl border border-border bg-card p-6 shadow-sm md:p-8">
            <div class="flex min-w-0 flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <div class="min-w-0">
                    <p class="text-sm font-medium text-primary">Start with the essentials</p>
                    <h2 class="mt-1 text-2xl font-semibold tracking-tight">Popular places to begin in Quark Suite</h2>
                    <p class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">
                        These demos are a good first pass if you want to understand how the suite feels in a real Blazor UI.
                    </p>
                </div>
                <a href="/components" class="inline-flex h-9 items-center rounded-lg border border-border px-4 text-sm font-medium transition-colors hover:bg-accent">
                    View all components
                </a>
            </div>

            <div class="mt-6 grid min-w-0 gap-3 sm:grid-cols-2 lg:grid-cols-4">
                <a href="/surfaces/buttons" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Buttons</p>
                    <p class="mt-1 text-sm text-muted-foreground">Core actions, variants, and composition patterns.</p>
                </a>
                <a href="/forms/input-demo" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Inputs</p>
                    <p class="mt-1 text-sm text-muted-foreground">Text entry, fields, and form primitives for app workflows.</p>
                </a>
                <a href="/overlays/modals" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Modals</p>
                    <p class="mt-1 text-sm text-muted-foreground">Dialog-driven flows for confirmation and focused tasks.</p>
                </a>
                <a href="/navigation/sidebar" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Sidebar</p>
                    <p class="mt-1 text-sm text-muted-foreground">A solid starting point for multi-page application shells.</p>
                </a>
                <a href="/forms/selects" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Select</p>
                    <p class="mt-1 text-sm text-muted-foreground">Structured choices with polished styling and interaction.</p>
                </a>
                <a href="/feedback/sonner" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Sonner</p>
                    <p class="mt-1 text-sm text-muted-foreground">Toast feedback that fits naturally into app events.</p>
                </a>
                <a href="/data/charts" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Charts</p>
                    <p class="mt-1 text-sm text-muted-foreground">Visualize data without leaving the same design system.</p>
                </a>
                <a href="/surfaces/cards" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <p class="text-sm font-medium">Cards</p>
                    <p class="mt-1 text-sm text-muted-foreground">Reusable content blocks for dashboards and detail views.</p>
                </a>
            </div>
        </div>
    </section>
</div>
