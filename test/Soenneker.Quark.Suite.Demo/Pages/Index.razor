@page "/"

<PageTitle>Quark Suite</PageTitle>

<Div class="min-w-0 flex flex-col">
    <Section class="mx-auto min-w-0 w-full max-w-6xl px-4 pt-16 pb-12 md:px-6 md:pt-24">
        <Grid Gap='@Gap.Token("10")' Class="lg:grid-cols-[minmax(0,1.2fr)_minmax(0,.8fr)] lg:items-center">
        <Div class="min-w-0">
            <Div class="inline-flex items-center rounded-full border border-border bg-background px-3 py-1 text-xs font-medium text-muted-foreground">
                Blazor component library for .NET
            </Div>

            <H1 class="mt-6 max-w-4xl text-4xl font-semibold tracking-tight text-balance sm:text-5xl md:text-6xl">
                Build modern Blazor apps with components that feel native to Razor.
            </H1>

            <Paragraph class="mt-5 max-w-2xl text-base leading-7 text-muted-foreground sm:text-lg">
                Quark Suite is more than a visual port. It is a Blazor-first UI toolkit with polished components,
                type-safe styling APIs, and theming that fits naturally into your .NET application architecture.
            </Paragraph>

            <Div class="mt-7 flex flex-wrap items-center gap-3">
                <Anchor To="components" class="inline-flex h-9 items-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90">
                    Browse components
                </Anchor>
                <Anchor To="#getting-started" class="inline-flex h-9 items-center rounded-lg px-3 text-sm font-medium text-foreground transition-colors hover:bg-accent">
                    Getting started
                </Anchor>
            </Div>

            <Grid Columns="Columns.Is1.OnSm.Is3" Gap="Gap.Is3" Class="mt-8 min-w-0">
                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Paragraph class="text-sm font-medium">60+ components</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Forms, navigation, overlays, media, tables, and more.</Paragraph>
                </Div>
                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Paragraph class="text-sm font-medium">Type-safe styling</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Compose UI with enums and helpers instead of fragile string-only CSS.</Paragraph>
                </Div>
                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Paragraph class="text-sm font-medium">Theme ready</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Use runtime theming with <Code Inline="true">ThemeHost</Code> or ship prebuilt CSS.</Paragraph>
                </Div>
            </Grid>
        </Div>

        <Div class="min-w-0 rounded-2xl border border-border bg-card p-4 shadow-sm sm:p-6">
            <Div class="flex flex-col gap-3 border-b border-border pb-4 sm:flex-row sm:items-center sm:justify-between">
                <Div class="min-w-0">
                    <Paragraph class="text-sm font-medium">Quark in a Blazor app</Paragraph>
                    <Paragraph class="text-xs text-muted-foreground">Minimal setup, familiar .NET flow</Paragraph>
                </Div>
                <Span class="shrink-0 rounded-full border border-border px-2.5 py-1 text-xs text-muted-foreground">Razor + DI</Span>
            </Div>

            <Div id="getting-started" class="mt-4 min-w-0 space-y-4">
                <Div class="min-w-0 rounded-xl border border-border bg-background p-4">
                    <Paragraph class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Install</Paragraph>
                    <PreCode Class="mt-3 max-w-full overflow-x-auto rounded-lg bg-muted/50 p-3 text-sm leading-6 text-foreground">dotnet add package Soenneker.Quark.Suite</PreCode>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-background p-4">
                    <Paragraph class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Register</Paragraph>
                    <PreCode Class="mt-3 max-w-full overflow-x-auto rounded-lg bg-muted/50 p-3 text-sm leading-6 text-foreground">@("builder.Services.AddQuarkSuiteAsScoped();\n\nvar host = builder.Build();\nawait host.Services.LoadQuarkResources();")</PreCode>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-background p-4">
                    <Paragraph class="text-xs font-medium uppercase tracking-[0.2em] text-muted-foreground">Build UI</Paragraph>
                    <PreCode Class="mt-3 max-w-full overflow-x-auto rounded-lg bg-muted/50 p-3 text-sm leading-6 text-foreground">@("<Button Color=\"primary\">Save</Button>\n\n<Input Placeholder=\"Search...\" />\n<Card>...</Card>")</PreCode>
                </Div>
            </Div>
        </Div>
        </Grid>
    </Section>

    <Section class="mx-auto min-w-0 w-full max-w-6xl border-y border-border px-4 py-8 md:px-6 md:py-10">
        <Div class="flex min-w-0 flex-col gap-3 md:flex-row md:items-end md:justify-between">
            <Div class="min-w-0">
                <Paragraph class="text-sm font-medium text-primary">Examples</Paragraph>
                <H2 class="mt-1 text-2xl font-semibold tracking-tight">Blazor app patterns, not just component screenshots</H2>
                <Paragraph class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">
                    Quark is meant for real Razor pages, dashboards, forms, dialogs, navigation, and data-heavy interfaces. The landing page should feel like that too.
                </Paragraph>
            </Div>
            <Div class="flex flex-wrap gap-2 text-xs text-muted-foreground">
                <Span class="rounded-full border border-border px-3 py-1.5">Forms</Span>
                <Span class="rounded-full border border-border px-3 py-1.5">Data</Span>
                <Span class="rounded-full border border-border px-3 py-1.5">Navigation</Span>
                <Span class="rounded-full border border-border px-3 py-1.5">Overlays</Span>
                <Span class="rounded-full border border-border px-3 py-1.5">Theming</Span>
            </Div>
        </Div>

        <Grid Columns="Columns.Is1.OnMd.Is3" Gap="Gap.Is4" Class="mt-6 min-w-0">
            <Div class="min-w-0 space-y-4">
                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="space-y-1">
                        <Paragraph class="text-sm font-medium">Profile editor</Paragraph>
                        <Paragraph class="text-xs text-muted-foreground">Typical Blazor form layout with sections, fields, and actions.</Paragraph>
                    </Div>
                    <Div class="mt-4 space-y-3">
                        <Div class="space-y-1.5">
                            <Label class="text-xs font-medium">Display Name</Label>
                            <Div class="h-9 rounded-md border border-input bg-background px-3"></Div>
                        </Div>
                        <Div class="space-y-1.5">
                            <Label class="text-xs font-medium">Email</Label>
                            <Div class="h-9 rounded-md border border-input bg-background px-3"></Div>
                        </Div>
                        <Div class="space-y-1.5">
                            <Label class="text-xs font-medium">Bio</Label>
                            <Div class="h-20 rounded-md border border-input bg-background px-3"></Div>
                        </Div>
                        <Div class="flex justify-end gap-2">
                            <Span class="rounded-md border border-border px-3 py-1.5 text-xs">Cancel</Span>
                            <Span class="rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground">Save</Span>
                        </Div>
                    </Div>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <Div class="min-w-0">
                            <Paragraph class="text-sm font-medium">Theme host</Paragraph>
                            <Paragraph class="mt-1 text-xs text-muted-foreground">Runtime theme switching for branded apps.</Paragraph>
                        </Div>
                        <Span class="w-fit shrink-0 rounded-full border border-border px-2 py-1 text-[11px]">Live</Span>
                    </Div>
                    <Grid Columns="Columns.Is3" Gap="Gap.Is2" Class="mt-4">
                        <Div class="rounded-lg border border-border bg-background p-3 text-center text-xs">Slate</Div>
                        <Div class="rounded-lg border border-primary bg-primary/10 p-3 text-center text-xs font-medium">Ocean</Div>
                        <Div class="rounded-lg border border-border bg-background p-3 text-center text-xs">Graphite</Div>
                    </Grid>
                    <Div class="mt-3 rounded-lg border border-border bg-background p-3">
                        <Div class="flex items-center justify-between text-xs">
                            <Span>Dark mode</Span>
                            <Span class="h-5 w-9 rounded-full bg-primary/20 p-0.5">
                                <Span class="block size-4 rounded-full bg-primary"></Span>
                            </Span>
                        </Div>
                    </Div>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Paragraph class="text-sm font-medium">Validation summary</Paragraph>
                    <Div class="mt-4 space-y-2">
                        <Div class="rounded-lg border border-amber-500/30 bg-amber-500/10 p-3 text-xs text-amber-700 dark:text-amber-300">
                            3 fields need attention before the form can be submitted.
                        </Div>
                        <Div class="rounded-lg border border-border bg-background p-3 text-xs text-muted-foreground">Password must contain at least 12 characters.</Div>
                        <Div class="rounded-lg border border-border bg-background p-3 text-xs text-muted-foreground">Billing address is required.</Div>
                    </Div>
                </Div>
            </Div>

            <Div class="min-w-0 space-y-4">
                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                        <Div class="min-w-0">
                            <Paragraph class="text-sm font-medium">Operations dashboard</Paragraph>
                            <Paragraph class="mt-1 text-xs text-muted-foreground">Cards, badges, and status snapshots.</Paragraph>
                        </Div>
                        <Span class="w-fit shrink-0 rounded-full border border-border px-2 py-1 text-[11px]">Server</Span>
                    </Div>
                    <Grid Columns="Columns.Is2" Gap="Gap.Is3" Class="mt-4">
                        <Div class="rounded-lg border border-border bg-background p-3">
                            <Paragraph class="text-xs text-muted-foreground">Active users</Paragraph>
                            <Paragraph class="mt-2 text-lg font-semibold">12,482</Paragraph>
                        </Div>
                        <Div class="rounded-lg border border-border bg-background p-3">
                            <Paragraph class="text-xs text-muted-foreground">Deployments</Paragraph>
                            <Paragraph class="mt-2 text-lg font-semibold">24</Paragraph>
                        </Div>
                    </Grid>
                    <Div class="mt-3 flex items-end gap-2 rounded-lg border border-border bg-background p-3">
                        <Span class="h-12 w-1/6 rounded-sm bg-primary/30"></Span>
                        <Span class="h-20 w-1/6 rounded-sm bg-primary/45"></Span>
                        <Span class="h-10 w-1/6 rounded-sm bg-primary/30"></Span>
                        <Span class="h-24 w-1/6 rounded-sm bg-primary/70"></Span>
                        <Span class="h-16 w-1/6 rounded-sm bg-primary/45"></Span>
                        <Span class="h-20 w-1/6 rounded-sm bg-primary"></Span>
                    </Div>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <Paragraph class="text-sm font-medium">Paged data table</Paragraph>
                        <Span class="text-xs text-muted-foreground">Server-side</Span>
                    </Div>
                    <Div class="mt-4 min-w-0 overflow-x-auto rounded-lg border border-border bg-background">
                        <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs font-medium text-muted-foreground">
                            <Span>Employee</Span>
                            <Span>Department</Span>
                            <Span>Status</Span>
                        </Grid>
                        <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs">
                            <Span>Olivia Martin</Span>
                            <Span>Finance</Span>
                            <Span>Active</Span>
                        </Grid>
                        <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs">
                            <Span>Jackson Lee</Span>
                            <Span>Support</Span>
                            <Span>Pending</Span>
                        </Grid>
                        <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] px-3 py-2 text-xs">
                            <Span>Sophia Chen</Span>
                            <Span>Platform</Span>
                            <Span>Active</Span>
                        </Grid>
                    </Div>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="flex min-w-0 flex-wrap items-center gap-2 text-xs text-muted-foreground">
                        <Span class="rounded-full border border-border px-2 py-1 text-foreground">Sonner</Span>
                        <Span>Async save</Span>
                        <Span>Undo</Span>
                    </Div>
                    <Div class="mt-4 space-y-2">
                        <Div class="rounded-lg border border-border bg-background p-3">
                            <Paragraph class="text-sm font-medium">Template saved</Paragraph>
                            <Paragraph class="mt-1 text-xs text-muted-foreground">Changes were synced to the current workspace.</Paragraph>
                        </Div>
                        <Div class="rounded-lg border border-border bg-background p-3">
                            <Paragraph class="text-sm font-medium">Background job queued</Paragraph>
                            <Paragraph class="mt-1 text-xs text-muted-foreground">Export will be ready in a few moments.</Paragraph>
                        </Div>
                    </Div>
                </Div>
            </Div>

            <Div class="min-w-0 space-y-4">
                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
                        <Paragraph class="text-sm font-medium">Application shell</Paragraph>
                        <Paragraph class="text-xs text-muted-foreground">Sidebar + top actions</Paragraph>
                    </Div>
                    <Grid Gap="Gap.Is3" Class="mt-4 sm:grid-cols-[92px_1fr]">
                        <Div class="rounded-lg border border-border bg-background p-2 text-xs">
                            <Div class="rounded-md bg-accent px-2 py-1.5 font-medium">Overview</Div>
                            <Div class="mt-1 px-2 py-1.5 text-muted-foreground">Projects</Div>
                            <Div class="mt-1 px-2 py-1.5 text-muted-foreground">Reports</Div>
                            <Div class="mt-1 px-2 py-1.5 text-muted-foreground">Settings</Div>
                        </Div>
                        <Div class="min-w-0 rounded-lg border border-border bg-background p-3">
                            <Div class="flex min-w-0 flex-col gap-2 text-xs sm:flex-row sm:items-center sm:justify-between">
                                <Span class="font-medium">Team workspace</Span>
                                <Span class="w-fit rounded-full border border-border px-2 py-1">Beta</Span>
                            </Div>
                            <Div class="mt-3 h-20 rounded-md border border-dashed border-border"></Div>
                        </Div>
                    </Grid>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="space-y-1">
                        <Paragraph class="text-sm font-medium">Access request dialog</Paragraph>
                        <Paragraph class="text-xs text-muted-foreground">Overlays for approvals, confirmations, and workflow gates.</Paragraph>
                    </Div>
                    <Div class="mt-4 rounded-xl border border-border bg-background p-4">
                        <Paragraph class="text-sm font-medium">Grant access to staging?</Paragraph>
                        <Paragraph class="mt-1 text-xs text-muted-foreground">This will allow the release manager to deploy builds and view logs.</Paragraph>
                        <Div class="mt-4 flex justify-end gap-2">
                            <Span class="rounded-md border border-border px-3 py-1.5 text-xs">Cancel</Span>
                            <Span class="rounded-md bg-primary px-3 py-1.5 text-xs text-primary-foreground">Approve</Span>
                        </Div>
                    </Div>
                </Div>

                <Div class="min-w-0 rounded-xl border border-border bg-card p-4 shadow-sm">
                    <Div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <Div class="min-w-0">
                            <Paragraph class="text-sm font-medium">Command + quick actions</Paragraph>
                            <Paragraph class="mt-1 text-xs text-muted-foreground">Useful for keyboard-first Blazor workflows.</Paragraph>
                        </Div>
                        <Span class="w-fit shrink-0 rounded-md border border-border px-2 py-1 text-[11px]">Ctrl K</Span>
                    </Div>
                    <Div class="mt-4 rounded-lg border border-border bg-background p-3">
                        <Paragraph class="text-sm text-muted-foreground">Search pages, commands, or components...</Paragraph>
                    </Div>
                    <Div class="mt-3 space-y-2 text-xs">
                        <Div class="flex min-w-0 items-center justify-between gap-3 rounded-lg border border-border bg-background p-3">
                            <Span>Open component catalog</Span>
                            <Span class="text-muted-foreground">Enter</Span>
                        </Div>
                        <Div class="flex min-w-0 items-center justify-between gap-3 rounded-lg border border-border bg-background p-3">
                            <Span>Create new page scaffold</Span>
                            <Span class="text-muted-foreground">Enter</Span>
                        </Div>
                    </Div>
                </Div>
            </Div>
        </Grid>
    </Section>

    <Section class="mx-auto min-w-0 w-full max-w-6xl px-4 pb-14 md:px-6 md:pb-20">
        <Div class="min-w-0 rounded-2xl border border-border bg-card p-6 shadow-sm md:p-8">
            <Div class="flex min-w-0 flex-col gap-3 md:flex-row md:items-end md:justify-between">
                <Div class="min-w-0">
                    <Paragraph class="text-sm font-medium text-primary">Start with the essentials</Paragraph>
                    <H2 class="mt-1 text-2xl font-semibold tracking-tight">Popular places to begin in Quark Suite</H2>
                    <Paragraph class="mt-2 max-w-2xl text-sm leading-6 text-muted-foreground">
                        These demos are a good first pass if you want to understand how the suite feels in a real Blazor UI.
                    </Paragraph>
                </Div>
                <Anchor To="components" class="inline-flex h-9 items-center rounded-lg border border-border px-4 text-sm font-medium transition-colors hover:bg-accent">
                    View all components
                </Anchor>
            </Div>

            <Grid Columns="Columns.Is1.OnSm.Is2.OnLg.Is4" Gap="Gap.Is3" Class="mt-6 min-w-0">
                <Anchor To="buttons" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <Paragraph class="text-sm font-medium">Buttons</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Core actions, variants, and composition patterns.</Paragraph>
                </Anchor>
                <Anchor To="input-demo" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <Paragraph class="text-sm font-medium">Inputs</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Text entry, fields, and form primitives for app workflows.</Paragraph>
                </Anchor>
                <Anchor To="dialogs" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <Paragraph class="text-sm font-medium">Dialogs</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Dialog-driven flows for confirmation and focused tasks.</Paragraph>
                </Anchor>
                <Anchor To="sidebar" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <Paragraph class="text-sm font-medium">Sidebar</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">A solid starting point for multi-page application shells.</Paragraph>
                </Anchor>
                <Anchor To="selects" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <Paragraph class="text-sm font-medium">Select</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Structured choices with polished styling and interaction.</Paragraph>
                </Anchor>
                <Anchor To="sonner" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <Paragraph class="text-sm font-medium">Sonner</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Toast feedback that fits naturally into app events.</Paragraph>
                </Anchor>
                <Anchor To="cards" class="min-w-0 rounded-xl border border-border bg-background p-4 transition-colors hover:bg-accent/40">
                    <Paragraph class="text-sm font-medium">Cards</Paragraph>
                    <Paragraph class="mt-1 text-sm text-muted-foreground">Reusable content blocks for dashboards and detail views.</Paragraph>
                </Anchor>
            </Grid>
        </Div>
    </Section>
</Div>
