@page "/"

<PageTitle>Quark Suite</PageTitle>

<Div MinWidth="MinWidth.Is0" Display="Display.Flex" Flex="Flex.Column">
<Section class="mx-auto min-w-0 w-full max-w-6xl px-4 pt-16 pb-12 md:px-6 md:pt-24">
    <Grid Gap='Gap.Token("10")' Class="lg:grid-cols-[minmax(0,1.2fr)_minmax(0,.8fr)] lg:items-center">
        <Div MinWidth="MinWidth.Is0">
            <Div Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding='Padding.Token("3").OnX.Token("1").OnY' TextSize="TextSize.Xs" FontWeight="FontWeight.Medium" TextColor="TextColor.MutedForeground">
                Blazor component library for .NET
            </Div>

            <H1 Margin='Margin.Token("6").FromTop' MaxWidth="MaxWidth.Is4xl" TextSize='TextSize.FourXl.OnSm.Token("5xl").OnMd.Token("6xl")' FontWeight="FontWeight.Semibold" LetterSpacing="LetterSpacing.Tight" Class="text-balance">
                Build modern Blazor apps with components that feel native to Razor.
            </H1>

            <Paragraph Margin='Margin.Token("5").FromTop' MaxWidth="MaxWidth.Is2xl" TextSize='TextSize.Base.OnSm.Lg' TextColor="TextColor.MutedForeground" Class="leading-7">
                Quark Suite is more than a visual port. It is a Blazor-first UI toolkit with polished components,
                type-safe styling APIs, and theming that fits naturally into your .NET application architecture.
            </Paragraph>

            <Div Margin='Margin.Token("7").FromTop' Display="Display.Flex" Flex="Flex.Wrap" AlignUtility="Align.ItemsCenter" Gap="Gap.Is3">
                <Anchor To="components" Display="Display.InlineFlex" Height='Height.Token("9")' AlignUtility="Align.ItemsCenter" Rounded="Rounded.Lg" BackgroundColor="BackgroundColor.Primary" Padding='Padding.Token("4").OnX' TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.PrimaryForeground" Class="transition-opacity hover:opacity-90">
                    Browse components
                </Anchor>
                <Anchor To="#getting-started" Display="Display.InlineFlex" Height='Height.Token("9")' AlignUtility="Align.ItemsCenter" Rounded="Rounded.Lg" Padding='Padding.Token("3").OnX' TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground" Class="transition-colors hover:bg-accent">
                    Getting started
                </Anchor>
            </Div>

            <Grid Columns="Columns.Is1.OnSm.Is3" Gap="Gap.Is3" Margin="Margin.Is8.FromTop" Class="min-w-0">
                <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">60+ components</Paragraph>
                    <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Forms, navigation, overlays, media, tables, and more.</Paragraph>
                </Div>
                <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Type-safe styling</Paragraph>
                    <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Compose UI with enums and helpers instead of fragile string-only CSS.</Paragraph>
                </Div>
                <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Theme ready</Paragraph>
                    <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Use runtime theming with <Code Inline="true">ThemeHost</Code> or ship prebuilt CSS.</Paragraph>
                </Div>
            </Grid>
        </Div>

        <Div MinWidth="MinWidth.Is0" Rounded="Rounded.TwoXl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding='Padding.Is4.OnBase.OnAll.OnSm.Is6.OnAll' BoxShadow="BoxShadow.Small">
            <Div class="flex flex-col gap-3 border-b border-border pb-4 sm:flex-row sm:items-center sm:justify-between">
                <Div MinWidth="MinWidth.Is0">
                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Quark in a Blazor app</Paragraph>
                    <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Minimal setup, familiar .NET flow</Paragraph>
                </Div>
                <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("2.5").OnX.Token("1").OnY' TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground" Class="shrink-0">
                    Razor + DI
                </Span>
            </Div>

            <Div id="getting-started" Margin="Margin.Is4.FromTop" MinWidth="MinWidth.Is0" Space="Space.Y.Is4">
                <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4">
                    <Paragraph TextSize="TextSize.Xs" FontWeight="FontWeight.Medium" TextTransform="TextTransform.Uppercase" LetterSpacing='LetterSpacing.Token("[0.2em]")' TextColor="TextColor.MutedForeground">Install</Paragraph>
                    <PreCode Margin="Margin.Is3.FromTop" MaxWidth="MaxWidth.IsFull" OverflowX="Overflow.Auto" Rounded="Rounded.Lg" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3" TextSize="TextSize.Sm" TextColor="TextColor.Foreground" Class="leading-6">dotnet add package Soenneker.Quark.Suite</PreCode>
                </Div>

                <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4">
                    <Paragraph TextSize="TextSize.Xs" FontWeight="FontWeight.Medium" TextTransform="TextTransform.Uppercase" LetterSpacing='LetterSpacing.Token("[0.2em]")' TextColor="TextColor.MutedForeground">Register</Paragraph>
                    <PreCode Margin="Margin.Is3.FromTop" MaxWidth="MaxWidth.IsFull" OverflowX="Overflow.Auto" Rounded="Rounded.Lg" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3" TextSize="TextSize.Sm" TextColor="TextColor.Foreground" Class="leading-6">@("builder.Services.AddQuarkSuiteAsScoped();\n\nvar host = builder.Build();\nawait host.Services.LoadQuarkResources();")</PreCode>
                </Div>

                <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4">
                    <Paragraph TextSize="TextSize.Xs" FontWeight="FontWeight.Medium" TextTransform="TextTransform.Uppercase" LetterSpacing='LetterSpacing.Token("[0.2em]")' TextColor="TextColor.MutedForeground">Build UI</Paragraph>
                    <PreCode Margin="Margin.Is3.FromTop" MaxWidth="MaxWidth.IsFull" OverflowX="Overflow.Auto" Rounded="Rounded.Lg" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3" TextSize="TextSize.Sm" TextColor="TextColor.Foreground" Class="leading-6">@("<Button Color=\"primary\">Save</Button>\n\n<Input Placeholder=\"Search...\" />\n<Card>...</Card>")</PreCode>
                </Div>
            </Div>
        </Div>
    </Grid>
</Section>

<Section class="mx-auto min-w-0 w-full max-w-6xl border-y border-border px-4 py-8 md:px-6 md:py-10">
<Div class="flex min-w-0 flex-col gap-3 md:flex-row md:items-end md:justify-between">
    <Div MinWidth="MinWidth.Is0">
        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.Primary">Examples</Paragraph>
        <H2 Margin="Margin.Is1.FromTop" TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" LetterSpacing="LetterSpacing.Tight">Blazor app patterns, not just component screenshots</H2>
        <Paragraph Margin="Margin.Is2.FromTop" MaxWidth="MaxWidth.Is2xl" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Class="leading-6">
            Quark is meant for real Razor pages, dashboards, forms, dialogs, navigation, and data-heavy interfaces. The landing page should feel like that too.
        </Paragraph>
    </Div>
    <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">
        <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("3").OnX.Token("1.5").OnY'>
            Forms
        </Span>
        <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("3").OnX.Token("1.5").OnY'>
            Data
        </Span>
        <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("3").OnX.Token("1.5").OnY'>
            Navigation
        </Span>
        <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("3").OnX.Token("1.5").OnY'>
            Overlays
        </Span>
        <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("3").OnX.Token("1.5").OnY'>
            Theming
        </Span>
    </Div>
</Div>

<Grid Columns="Columns.Is1.OnMd.Is3" Gap="Gap.Is4" Margin='Margin.Token("6").FromTop' Class="min-w-0">
<Div MinWidth="MinWidth.Is0" Space="Space.Y.Is4">
    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Div Space="Space.Y.Is1">
            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Profile editor</Paragraph>
            <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Typical Blazor form layout with sections, fields, and actions.</Paragraph>
        </Div>
        <Div Margin="Margin.Is4.FromTop" Space="Space.Y.Is3">
            <Div Space='Space.Y.Token("1.5")'>
                <Label TextSize="TextSize.Xs" FontWeight="FontWeight.Medium">Display Name</Label>
                <Div Height='Height.Token("9")' Rounded="Rounded.Md" Border="Border.Is1" BorderColor='BorderColor.Token("input")' BackgroundColor="BackgroundColor.Background" Padding='Padding.Token("3").OnX'>
                </Div>
            </Div>
            <Div Space='Space.Y.Token("1.5")'>
                <Label TextSize="TextSize.Xs" FontWeight="FontWeight.Medium">Email</Label>
                <Div Height='Height.Token("9")' Rounded="Rounded.Md" Border="Border.Is1" BorderColor='BorderColor.Token("input")' BackgroundColor="BackgroundColor.Background" Padding='Padding.Token("3").OnX'>
                </Div>
            </Div>
            <Div Space='Space.Y.Token("1.5")'>
                <Label TextSize="TextSize.Xs" FontWeight="FontWeight.Medium">Bio</Label>
                <Div Height='Height.Token("20")' Rounded="Rounded.Md" Border="Border.Is1" BorderColor='BorderColor.Token("input")' BackgroundColor="BackgroundColor.Background" Padding='Padding.Token("3").OnX'>
                </Div>
            </Div>
            <Div Display="Display.Flex" AlignUtility="Align.JustifyEnd" Gap="Gap.Is2">
                <Span Rounded="Rounded.Md" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("3").OnX.Token("1.5").OnY' TextSize="TextSize.Xs">
                    Cancel
                </Span>
                <Span Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Primary" Padding='Padding.Token("3").OnX.Token("1.5").OnY' TextSize="TextSize.Xs" TextColor="TextColor.PrimaryForeground">
                    Save
                </Span>
            </Div>
        </Div>
    </Div>

    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <Div MinWidth="MinWidth.Is0">
                <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Theme host</Paragraph>
                <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Runtime theme switching for branded apps.</Paragraph>
            </Div>
            <Span Width="Width.IsFit" Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("2").OnX.Token("1").OnY' TextSize='TextSize.Token("[11px]")' Class="shrink-0">
                Live
            </Span>
        </Div>
        <Grid Columns="Columns.Is3" Gap="Gap.Is2" Class="mt-4">
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" TextAlignment="TextAlignment.Center" TextSize="TextSize.Xs">Slate</Div>
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Primary" BackgroundColor='BackgroundColor.Token("primary/10")' Padding="Padding.Is3" TextAlignment="TextAlignment.Center" TextSize="TextSize.Xs" FontWeight="FontWeight.Medium">Ocean</Div>
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" TextAlignment="TextAlignment.Center" TextSize="TextSize.Xs">Graphite</Div>
        </Grid>
        <Div Margin="Margin.Is3.FromTop" Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3">
            <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter.JustifyBetween" TextSize="TextSize.Xs">
                <Span>Dark mode</Span>
                <Span Height='Height.Token("5")' Width='Width.Token("9")' Rounded="Rounded.Full" BackgroundColor='BackgroundColor.Token("primary/20")' Padding='Padding.Token("0.5")'>
                    <Span class="block size-4 rounded-full bg-primary"></Span>
                </Span>
            </Div>
        </Div>
    </Div>

    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Validation summary</Paragraph>
        <Div Margin="Margin.Is4.FromTop" Space="Space.Y.Is2">
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor='BorderColor.Token("amber-500/30")' BackgroundColor='BackgroundColor.Token("amber-500/10")' Padding="Padding.Is3" TextSize="TextSize.Xs" TextColor='TextColor.Token("amber-700")' Class="dark:text-amber-300">
                3 fields need attention before the form can be submitted.
            </Div>
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Password must contain at least 12 characters.</Div>
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Billing address is required.</Div>
        </Div>
    </Div>
</Div>

<Div MinWidth="MinWidth.Is0" Space="Space.Y.Is4">
    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
            <Div MinWidth="MinWidth.Is0">
                <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Operations dashboard</Paragraph>
                <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Cards, badges, and status snapshots.</Paragraph>
            </Div>
            <Span Width="Width.IsFit" Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("2").OnX.Token("1").OnY' TextSize='TextSize.Token("[11px]")' Class="shrink-0">
                Server
            </Span>
        </Div>
        <Grid Columns="Columns.Is2" Gap="Gap.Is3" Class="mt-4">
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3">
                <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Active users</Paragraph>
                <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">12,482</Paragraph>
            </Div>
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3">
                <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Deployments</Paragraph>
                <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">24</Paragraph>
            </Div>
        </Grid>
        <Div Margin="Margin.Is3.FromTop" Display="Display.Flex" AlignUtility="Align.ItemsEnd" Gap="Gap.Is2" Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3">
            <Span Height='Height.Token("12")' Width="Width.Is1of6" Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/30")'></Span>
            <Span Height='Height.Token("20")' Width="Width.Is1of6" Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/45")'></Span>
            <Span Height='Height.Token("10")' Width="Width.Is1of6" Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/30")'></Span>
            <Span Height='Height.Token("24")' Width="Width.Is1of6" Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/70")'></Span>
            <Span Height='Height.Token("16")' Width="Width.Is1of6" Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/45")'></Span>
            <Span Height='Height.Token("20")' Width="Width.Is1of6" Rounded="Rounded.Sm" BackgroundColor="BackgroundColor.Primary"></Span>
        </Div>
    </Div>

    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Paged table</Paragraph>
            <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Server-side</Span>
        </Div>
        <Div class="mt-4 min-w-0 overflow-x-auto rounded-lg border border-border bg-background">
            <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs font-medium text-muted-foreground">
                <Span>Employee</Span>
                <Span>Department</Span>
                <Span>Status</Span>
            </Grid>
            <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs">
                <Span>Olivia Martin</Span>
                <Span>Finance</Span>
                <Span>Active</Span>
            </Grid>
            <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] border-b border-border px-3 py-2 text-xs">
                <Span>Jackson Lee</Span>
                <Span>Support</Span>
                <Span>Pending</Span>
            </Grid>
            <Grid Class="min-w-[19rem] grid-cols-[1.2fr_1fr_.8fr] px-3 py-2 text-xs">
                <Span>Sophia Chen</Span>
                <Span>Platform</Span>
                <Span>Active</Span>
            </Grid>
        </Div>
    </Div>

    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Div Display="Display.Flex" MinWidth="MinWidth.Is0" Flex="Flex.Wrap" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">
            <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("2").OnX.Token("1").OnY' TextColor="TextColor.Foreground">
                Sonner
            </Span>
            <Span>Async save</Span>
            <Span>Undo</Span>
        </Div>
        <Div Margin="Margin.Is4.FromTop" Space="Space.Y.Is2">
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3">
                <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Template saved</Paragraph>
                <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Changes were synced to the current workspace.</Paragraph>
            </Div>
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3">
                <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Background job queued</Paragraph>
                <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Export will be ready in a few moments.</Paragraph>
            </Div>
        </Div>
    </Div>
</Div>

<Div MinWidth="MinWidth.Is0" Space="Space.Y.Is4">
    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Application shell</Paragraph>
            <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Sidebar + top actions</Paragraph>
        </Div>
        <Grid Gap="Gap.Is3" Class="mt-4 sm:grid-cols-[92px_1fr]">
            <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is2" TextSize="TextSize.Xs">
                <Div Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Accent" Padding='Padding.Token("2").OnX.Token("1.5").OnY' FontWeight="FontWeight.Medium">
                    Overview
                </Div>
                <Div class="mt-1 px-2 py-1.5 text-muted-foreground">Projects</Div>
                <Div class="mt-1 px-2 py-1.5 text-muted-foreground">Reports</Div>
                <Div class="mt-1 px-2 py-1.5 text-muted-foreground">Settings</Div>
            </Div>
            <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3">
                <Div class="flex min-w-0 flex-col gap-2 text-xs sm:flex-row sm:items-center sm:justify-between">
                    <Span FontWeight="FontWeight.Medium">Team workspace</Span>
                    <Span Width="Width.IsFit" Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("2").OnX.Token("1").OnY'>
                        Beta
                    </Span>
                </Div>
                <Div class="mt-3 h-20 rounded-md border border-dashed border-border"></Div>
            </Div>
        </Grid>
    </Div>

    <Div MinWidth="MinWidth.Is0" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">
        <Div Space="Space.Y.Is1">
            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Access request dialog</Paragraph>
            <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Overlays for approvals, confirmations, and workflow gates.</Paragraph>
        </Div>
        <Div Margin="Margin.Is4.FromTop" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4">
            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Grant access to staging?</Paragraph>
            <Paragraph Margin="Margin.Is1.FromTop" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">This will allow the release manager to deploy builds and view logs.</Paragraph>
            <Div Margin="Margin.Is4.FromTop" Display="Display.Flex" AlignUtility="Align.JustifyEnd" Gap="Gap.Is2">
                <Span Rounded="Rounded.Md" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Token("3").OnX.Token("1.5").OnY' TextSize="TextSize.Xs">
                    Cancel
                </Span>
                <Span Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Primary" Padding='Padding.Token("3").OnX.Token("1.5").OnY' TextSize="TextSize.Xs" TextColor="TextColor.PrimaryForeground">
                    Approve
                </Span>
            </Div>
        </Div>
    </Div>

