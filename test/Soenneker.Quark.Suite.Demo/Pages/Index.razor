@page "/"
@layout LandingLayout

<PageTitle>The Foundation for your Design System - shadcn/ui</PageTitle>

<Div Display="Display.Flex" Flex="Flex.Display.Fill.Column">
    <Section>
        <Div Class="container-wrapper">
            <Div Class="container flex flex-col items-center gap-2 px-6 py-8 text-center md:py-16 lg:py-20 xl:gap-4">
                <Badge AsChild Variant="BadgeVariant.Secondary" Class="bg-muted">
                    <Anchor To="sera">
                        Introducing Sera
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                             class="size-3">
                            <path d="M5 12h14"></path>
                            <path d="m12 5 7 7-7 7"></path>
                        </svg>
                    </Anchor>
                </Badge>
                <H1 Class="leading-tighter max-w-4xl text-balance text-3xl font-semibold tracking-tight text-primary lg:leading-[1.1] lg:font-semibold xl:text-5xl xl:tracking-tighter">
                    The Foundation for your Design System
                </H1>
                <Paragraph Class="max-w-4xl text-base text-balance text-foreground sm:text-lg">
                    A set of beautifully designed components that you can customize, extend, and build on. Start here then make it your own. Open Source. Open Code.
                </Paragraph>
                <Div Display="Display.Flex"
                     Width="Width.IsFull"
                     AlignUtility="Align.ItemsCenter.JustifyCenter"
                     Gap="Gap.Is2"
                     Padding="Padding.Is2.FromTop"
                     Class="**:data-[slot=button]:shadow-none">
                    <Button AsChild="true" Size="ButtonSize.Sm">
                        <Anchor To="create">New Project</Anchor>
                    </Button>
                    <Button AsChild="true" Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm">
                        <Anchor To="docs/components">View Components</Anchor>
                    </Button>
                </Div>
            </Div>
        </Div>
    </Section>

    <Div Class="container-wrapper flex-1 pb-6">
        <Div Class="container" Overflow="Overflow.Hidden">
            <Section Class="-mx-4 mb-4 w-[160vw] overflow-hidden rounded-lg border border-border/50 md:hidden md:w-[150vw]">
                <Image Alt="Dashboard"
                       Class="block w-full dark:hidden"
                       Width="1400"
                       Height="875"
                       Decoding="async"
                       Src="@DashboardLightUrl"
                       SrcSet="@DashboardLightSrcSet" />
                <Image Alt="Dashboard"
                       Class="hidden w-full dark:block"
                       Width="1400"
                       Height="875"
                       Decoding="async"
                       Src="@DashboardDarkUrl"
                       SrcSet="@DashboardDarkSrcSet" />
            </Section>

            <Section Class="hidden theme-container md:block">
                <Grid Margin="Margin.Auto.OnX"
                      Gap='Gap.Token("6").OnMd.Token("8").OnXl.Token("6").On2xl.Token("8")'
                      Padding='Padding.Token("1")'
                      Class="theme-container md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                    <Div Display="Display.Flex" Flex="Flex.Display.Column" MinWidth="MinWidth.Is0" Width="Width.IsFull" Gap='Gap.Token("6")'>
                        <Div Width="Width.IsFull" MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" Padding="Padding.Is6">
                            <form>
                                <FieldGroup>
                                    <FieldSet>
                                        <FieldLegend>Payment Method</FieldLegend>
                                        <FieldDescription>All transactions are secure and encrypted</FieldDescription>

                                        <FieldGroup>
                                    <Field>
                                        <FieldLabel For="idx-card-name">Name on Card</FieldLabel>
                                        <Input Id="idx-card-name" Placeholder="John Doe" Required="true" />
                                    </Field>
                                    <Grid Columns="Columns.Is3" Gap="Gap.Is4">
                                        <Field Class="col-span-2">
                                            <FieldLabel For="idx-card-number">Card Number</FieldLabel>
                                            <Input Id="idx-card-number" Placeholder="1234 5678 9012 3456" Required="true" />
                                            <FieldDescription>Enter your 16-digit number.</FieldDescription>
                                        </Field>
                                        <Field>
                                            <FieldLabel For="idx-cvv">CVV</FieldLabel>
                                            <Input Id="idx-cvv" Placeholder="123" Required="true" />
                                        </Field>
                                    </Grid>
                                    <Grid Columns="Columns.Is2" Gap="Gap.Is4">
                                        <Field>
                                            <FieldLabel For="idx-exp-month">Month</FieldLabel>
                                            <Select TValue="string" SelectedValue="@("")">
                                                <SelectTrigger Id="idx-exp-month">
                                                    <SelectValue Placeholder="MM" />
                                                </SelectTrigger>
                                                <SelectContent>
                                                    @foreach (var month in Months)
                                                    {
                                                        <SelectItem TValue="string" ItemValue="@month" Text="@month" />
                                                    }
                                                </SelectContent>
                                            </Select>
                                        </Field>
                                        <Field>
                                            <FieldLabel For="idx-exp-year">Year</FieldLabel>
                                            <Select TValue="string" SelectedValue="@("")">
                                                <SelectTrigger Id="idx-exp-year">
                                                    <SelectValue Placeholder="YYYY" />
                                                </SelectTrigger>
                                                <SelectContent>
                                                    @foreach (var year in Years)
                                                    {
                                                        <SelectItem TValue="string" ItemValue="@year" Text="@year" />
                                                    }
                                                </SelectContent>
                                            </Select>
                                        </Field>
                                    </Grid>
                                        </FieldGroup>
                                    </FieldSet>

                                    <FieldSeparator />

                                    <FieldSet>
                                        <FieldLegend>Billing Address</FieldLegend>
                                        <FieldDescription>The billing address associated with your payment method</FieldDescription>

                                        <FieldGroup>
                                            <Field Horizontal="true">
                                                <Check Id="idx-same-address" Checked="true" />
                                                <FieldLabel For="idx-same-address" FontWeight="FontWeight.Normal">Same as shipping address</FieldLabel>
                                            </Field>
                                        </FieldGroup>
                                    </FieldSet>

                                    <FieldSeparator />

                                    <FieldSet>
                                        <FieldGroup>
                                            <Field>
                                                <FieldLabel For="idx-comments">Comments</FieldLabel>
                                                <TextArea Id="idx-comments" Rows="3" Placeholder="Add any additional comments" Class="resize-none" />
                                            </Field>
                                        </FieldGroup>
                                    </FieldSet>

                                    <Field Horizontal="true">
                                        <Button Type="ButtonType.Submit">Submit</Button>
                                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Cancel</Button>
                                    </Field>
                                </FieldGroup>
                            </form>
                        </Div>
                    </Div>

                    <Div Display="Display.Flex" Flex="Flex.Display.Column" MinWidth="MinWidth.Is0" Width="Width.IsFull" Gap='Gap.Token("6")'>
                        <Empty>
                            <EmptyHeader>
                                <EmptyMedia>
                                    <AvatarGroup Class="grayscale">
                                        <Avatar>
                                            <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" />
                                            <AvatarFallback>TM</AvatarFallback>
                                        </Avatar>
                                        <Avatar>
                                            <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")" />
                                            <AvatarFallback>TM</AvatarFallback>
                                        </Avatar>
                                        <Avatar>
                                            <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" />
                                            <AvatarFallback>TM</AvatarFallback>
                                        </Avatar>
                                    </AvatarGroup>
                                </EmptyMedia>
                                <EmptyTitle>No Team Members</EmptyTitle>
                                <EmptyDescription>Invite your team to collaborate on this project.</EmptyDescription>
                            </EmptyHeader>
                            <EmptyContent>
                                <Button Size="ButtonSize.Sm">
                                    <Icon Name="LucideIcon.Plus" />
                                    Invite Members
                                </Button>
                            </EmptyContent>
                        </Empty>

                        <Div Display="Display.Flex" Flex="Flex.Wrap" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                            <Badge Class="inline-flex items-center gap-1.5">
                                <Icon Name="LucideIcon.LoaderCircle" BoxSize="Size.Is3" Animation="Animation.Spin" />
                                Syncing
                            </Badge>
                            <Badge Variant="BadgeVariant.Secondary" Class="inline-flex items-center gap-1.5">
                                <Icon Name="LucideIcon.LoaderCircle" BoxSize="Size.Is3" Animation="Animation.Spin" />
                                Updating
                            </Badge>
                            <Badge Variant="BadgeVariant.Outline" Class="inline-flex items-center gap-1.5">
                                <Icon Name="LucideIcon.LoaderCircle" BoxSize="Size.Is3" Animation="Animation.Spin" />
                                Loading
                            </Badge>
                        </Div>

                        <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Add">
                                <Icon Name="LucideIcon.Plus" />
                            </Button>
                            <InputGroup Class="flex-1">
                                <InputGroupInput Placeholder="Send a message..." />
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                    <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Voice mode">
                                        <Icon Name="LucideIcon.AudioLines" />
                                    </InputGroupButton>
                                </InputGroupAddon>
                            </InputGroup>
                        </Div>

                        <Div Width="Width.IsFull">
                            <Field>
                                <FieldLabel>Price Range</FieldLabel>
                                <FieldDescription>
                                    Set your budget range ($<Span FontWeight="FontWeight.Medium" Class="tabular-nums">@PriceRangeMin</Span> - <Span FontWeight="FontWeight.Medium" Class="tabular-nums">@PriceRangeMax</Span>).
                                </FieldDescription>
                                <Slider Values="@priceRange"
                                        ValuesChanged="HandlePriceRangeChanged"
                                        Min="0"
                                        Max="1000"
                                        Step="10"
                                        AriaLabel="Price Range"
                                        Class="mt-2 w-full" />
                            </Field>
                        </Div>

                        <Div Display="Display.Flex" Flex="Flex.Display.Column" Gap='Gap.Token("6")'>
                            <InputGroup>
                                <InputGroupInput Placeholder="Search..." />
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineStart">
                                    <Icon Name="LucideIcon.Search" />
                                </InputGroupAddon>
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                    <InputGroupText>12 results</InputGroupText>
                                </InputGroupAddon>
                            </InputGroup>

                            <InputGroup>
                                <InputGroupInput Placeholder="example.com" Class="pl-1!" />
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineStart">
                                    <InputGroupText>https://</InputGroupText>
                                </InputGroupAddon>
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                    <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Info">
                                        <Icon Name="LucideIcon.Info" />
                                    </InputGroupButton>
                                </InputGroupAddon>
                            </InputGroup>

                            <Div Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" BoxShadow="BoxShadow.Small">
                                <TextArea Rows="4"
                                          Placeholder="Ask, Search or Chat..."
                                          Class="min-h-24 resize-none border-0! bg-transparent px-0 py-0 shadow-none! focus-visible:ring-0!" />
                                <Div Display="Display.Flex"
                                     AlignUtility="Align.ItemsCenter"
                                     Gap='Gap.Token("1.5")'
                                     Margin="Margin.Is3.FromTop"
                                     Padding="Padding.Is3.FromTop"
                                     Border="Border.Is1.FromTop">
                                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconXs" aria-label="Add">
                                        <Icon Name="LucideIcon.Plus" />
                                    </Button>
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Xs">Auto</Button>
                                    <Span Class="ml-auto text-sm text-muted-foreground">52% used</Span>
                                    <Button Variant="ButtonVariant.Default" Size="ButtonSize.IconXs" Rounded="Rounded.Full" aria-label="Send">
                                        <Icon Name="LucideIcon.ArrowUp" />
                                    </Button>
                                </Div>
                            </Div>

                            <InputGroup>
                                <InputGroupInput Placeholder="@("@shadcn")" />
                                <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                    <Span Class="flex size-4 items-center justify-center rounded-full bg-primary text-primary-foreground">
                                        <Icon Name="LucideIcon.Check" BoxSize="Size.Is3" />
                                    </Span>
                                </InputGroupAddon>
                            </InputGroup>
                        </Div>
                    </Div>

                    <Div Display="Display.Flex" Flex="Flex.Display.Column" MinWidth="MinWidth.Is0" Width="Width.IsFull" Gap='Gap.Token("6")'>
                        <InputGroup Class="[--radius:9999px]">
                            <InputGroupAddon Align="InputGroupAddonAlign.InlineStart">
                                <InputGroupButton Variant="ButtonVariant.Secondary" Size="ButtonSize.IconXs" aria-label="Info">
                                    <Icon Name="LucideIcon.Info" />
                                </InputGroupButton>
                                <InputGroupText>https://</InputGroupText>
                            </InputGroupAddon>
                            <InputGroupInput />
                            <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                                <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs" aria-label="Favorite">
                                    <Icon Name="LucideIcon.Star" />
                                </InputGroupButton>
                            </InputGroupAddon>
                        </InputGroup>

                        <Div Display="Display.Flex" Flex="Flex.Display.Column" Gap='Gap.Token("6")'>
                            <Item Variant="ItemVariant.Outline">
                                <ItemContent Class="min-w-0">
                                    <ItemTitle>Two-factor authentication</ItemTitle>
                                    <ItemDescription>Verify via email or phone number.</ItemDescription>
                                </ItemContent>
                                <ItemActions Class="shrink-0">
                                    <Button Size="ButtonSize.Sm">Enable</Button>
                                </ItemActions>
                            </Item>

                            <Item Variant="ItemVariant.Outline" AsChild="true">
                                <Anchor To="#">
                                    <ItemMedia Variant="ItemMediaVariant.Icon">
                                        <Icon Name="LucideIcon.BadgeCheck" BoxSize="Size.Is5"/>
                                    </ItemMedia>
                                    <ItemContent>
                                        <ItemTitle>Your profile has been verified.</ItemTitle>
                                    </ItemContent>
                                    <ItemActions>
                                        <Icon Name="LucideIcon.ChevronRight" BoxSize="Size.Is4" />
                                    </ItemActions>
                                </Anchor>
                            </Item>
                        </Div>

                        <FieldSeparator>Appearance Settings</FieldSeparator>

                        <FieldSet>
                            <FieldLegend>Compute Environment</FieldLegend>
                            <FieldDescription>Select the compute environment for your cluster.</FieldDescription>
                            <FieldGroup>
                                <RadioGroup Name="landing-compute" Value="@computeEnvironment" ValueChanged="HandleComputeEnvironmentChanged" AriaLabel="Compute environment">
                                    <FieldLabel For="landing-kubernetes">
                                        <Field Horizontal="true"
                                               Class="rounded-xl border p-3.5 transition-colors has-[[role=radio][data-state=checked]]:border-foreground has-[[role=radio][data-state=checked]]:bg-accent/30">
                                            <FieldContent>
                                                <FieldTitle>Kubernetes</FieldTitle>
                                                <FieldDescription>Run GPU workloads on a K8s configured cluster. This is the default.</FieldDescription>
                                            </FieldContent>
                                            <Radio Id="landing-kubernetes" Value="kubernetes" />
                                        </Field>
                                    </FieldLabel>
                                    <FieldLabel For="landing-vm">
                                        <Field Horizontal="true"
                                               Class="rounded-xl border p-3.5 transition-colors has-[[role=radio][data-state=checked]]:border-foreground has-[[role=radio][data-state=checked]]:bg-accent/30">
                                            <FieldContent>
                                                <FieldTitle>Virtual Machine</FieldTitle>
                                                <FieldDescription>Access a VM configured cluster to run workloads. (Coming soon)</FieldDescription>
                                            </FieldContent>
                                            <Radio Id="landing-vm" Value="vm" />
                                        </Field>
                                    </FieldLabel>
                                </RadioGroup>

                                <FieldSeparator />

                                <Field Horizontal="true">
                                    <FieldContent>
                                        <FieldLabel For="idx-gpus">Number of GPUs</FieldLabel>
                                        <FieldDescription>You can add more later.</FieldDescription>
                                    </FieldContent>
                                    <ButtonGroup>
                                        <Input Id="idx-gpus" Value="@gpuCount.ToString()" Class="h-7 w-14! font-mono" />
                                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Decrease" OnClick="DecreaseGpuCount">
                                            <Icon Name="LucideIcon.Minus" />
                                        </Button>
                                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Increase" OnClick="IncreaseGpuCount">
                                            <Icon Name="LucideIcon.Plus" />
                                        </Button>
                                    </ButtonGroup>
                                </Field>

                                <FieldSeparator />

                                <Field Horizontal="true">
                                    <FieldContent>
                                        <FieldLabel For="idx-wallpaper">Wallpaper Tinting</FieldLabel>
                                        <FieldDescription>Allow the wallpaper to be tinted.</FieldDescription>
                                    </FieldContent>
                                    <Switch Id="idx-wallpaper" @bind-Checked="wallpaperTinting" />
                                </Field>
                            </FieldGroup>
                        </FieldSet>
                    </Div>

                    <Div Display="Display.None.OnLg.Flex.OnXl"
                         Flex="Flex.Display.Column"
                         MinWidth="MinWidth.Is0"
                         Width="Width.IsFull"
                         Gap='Gap.Token("6")'
                         Class="order-first xl:order-last">
                        <Div Rounded='Rounded.Token("2xl")' Border="Border.Is1" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is3" BoxShadow="BoxShadow.Small">
                            <Div Margin="Margin.Is3.FromBottom">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" Class="rounded-full shadow-none">
                                    <Icon Name="LucideIcon.AtSign" />
                                    Add context
                                </Button>
                            </Div>
                            <TextArea Rows="4"
                                      Placeholder="Ask, search, or make anything..."
                                      Class="min-h-28 resize-none border-0! bg-transparent px-0 py-0 shadow-none! focus-visible:ring-0!" />
                            <Div Display="Display.Flex"
                                 AlignUtility="Align.ItemsCenter"
                                 Gap="Gap.Is2"
                                 Margin="Margin.Is3.FromTop"
                                 Padding="Padding.Is3.FromTop"
                                 Border="Border.Is1.FromTop">
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconSm" Rounded="Rounded.Full" aria-label="Attach file">
                                    <Icon Name="LucideIcon.Paperclip" />
                                </Button>
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Class="rounded-full px-3">Auto</Button>
                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm" Class="rounded-full px-3">
                                    <Icon Name="LucideIcon.Globe" />
                                    All Sources
                                </Button>
                                <Button Variant="ButtonVariant.Default" Size="ButtonSize.IconSm" Class="ml-auto rounded-full" aria-label="Send">
                                    <Icon Name="LucideIcon.ArrowUp" />
                                </Button>
                            </Div>
                        </Div>

                        <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter.JustifyBetween" Gap="Gap.Is3">
                            <ButtonGroup AriaLabel="Inbox actions">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Back">
                                    <Icon Name="LucideIcon.ArrowLeft" />
                                </Button>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Archive</Button>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Report</Button>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Snooze</Button>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="More">
                                    <Icon Name="LucideIcon.Ellipsis" />
                                </Button>
                            </ButtonGroup>
                        </Div>

                        <Div Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("accent/20")' Padding="Padding.Is4.OnX.Is3.OnY">
                            <Field Horizontal="true" Class="gap-3">
                                <Check Id="idx-terms" @bind-Checked="termsAccepted" />
                                <FieldLabel For="idx-terms" FontWeight="FontWeight.Normal">I agree to the terms and conditions</FieldLabel>
                            </Field>
                        </Div>

                        <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter.JustifyBetween" Gap="Gap.Is4">
                            <ButtonGroup AriaLabel="Pagination">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm">1</Button>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm">2</Button>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm">3</Button>
                            </ButtonGroup>
                            <ButtonGroup AriaLabel="Pagination arrows">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Previous">
                                    <Icon Name="LucideIcon.ArrowLeft" />
                                </Button>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Next">
                                    <Icon Name="LucideIcon.ArrowRight" />
                                </Button>
                            </ButtonGroup>
                            <Select TValue="string" SelectedValue="@("copilot")" Width='Width.Token("32")'>
                                <SelectTrigger>
                                    <SelectValue Placeholder="Assistant" />
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectItem TValue="string" ItemValue="@("copilot")" Text="Copilot" />
                                    <SelectItem TValue="string" ItemValue="@("quark")" Text="Quark" />
                                </SelectContent>
                            </Select>
                        </Div>

                        <Card Class="gap-0 py-0">
                            <CardHeader Class="border-b py-6">
                                <CardTitle>How did you hear about us?</CardTitle>
                                <CardDescription>Select the option that best describes how you found Quark.</CardDescription>
                            </CardHeader>
                            <CardContent Class="py-6">
                                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is3">
                                    <Button Variant="ButtonVariant.Outline" Class="rounded-full bg-accent shadow-none">
                                        <Icon Name="LucideIcon.Check" BoxSize="Size.Is4" />
                                        Social Media
                                    </Button>
                                    <Button Variant="ButtonVariant.Outline" Rounded="Rounded.Full">Search Engine</Button>
                                    <Button Variant="ButtonVariant.Outline" Rounded="Rounded.Full">Referral</Button>
                                    <Button Variant="ButtonVariant.Outline" Rounded="Rounded.Full">Other</Button>
                                </Div>
                            </CardContent>
                        </Card>

                        <Empty Class="w-full border border-dashed py-6 sm:py-8">
                            <EmptyHeader>
                                <EmptyMedia Variant="EmptyMediaVariant.Icon">
                                    <Icon Name="LucideIcon.LoaderCircle" Class="size-4 animate-spin" />
                                </EmptyMedia>
                                <EmptyTitle>Processing your request</EmptyTitle>
                                <EmptyDescription>Please wait while we process your request. Do not refresh the page.</EmptyDescription>
                            </EmptyHeader>
                            <EmptyContent>
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Cancel</Button>
                            </EmptyContent>
                        </Empty>
                    </Div>
                </Grid>
            </Section>
        </Div>
    </Div>
</Div>

@code {
    private double[] priceRange = [200, 800];
    private string computeEnvironment = "kubernetes";
    private int gpuCount = 8;
    private bool wallpaperTinting = true;
    private bool termsAccepted = true;

    private static readonly string[] Months = ["01", "02", "03", "04", "05", "06", "07", "08", "09", "10", "11", "12"];
    private static readonly string[] Years = ["2026", "2027", "2028", "2029", "2030"];

    private string PriceRangeMin => priceRange[0].ToString("0");
    private string PriceRangeMax => priceRange[^1].ToString("0");

    private Task HandlePriceRangeChanged(double[] values)
    {
        priceRange = values;
        return Task.CompletedTask;
    }

    private Task HandleComputeEnvironmentChanged(string? value)
    {
        computeEnvironment = value ?? "kubernetes";
        return Task.CompletedTask;
    }

    private void DecreaseGpuCount()
    {
        if (gpuCount > 1)
            gpuCount--;
    }

    private void IncreaseGpuCount()
    {
        gpuCount++;
    }

    private const string DashboardLightUrl =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-light.png&w=3840&q=75";

    private const string DashboardLightSrcSet =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-light.png&w=1920&q=75 1x, https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-light.png&w=3840&q=75 2x";

    private const string DashboardDarkUrl =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-dark.png&w=3840&q=75";

    private const string DashboardDarkSrcSet =
        "https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-dark.png&w=1920&q=75 1x, https://ui.shadcn.com/_next/image?url=%2Fr%2Fstyles%2Fnew-york-v4%2Fdashboard-01-dark.png&w=3840&q=75 2x";
}
