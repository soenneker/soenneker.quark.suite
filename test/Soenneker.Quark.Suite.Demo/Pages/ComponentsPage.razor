@page "/components"

<PageTitle>Components - Quark Suite</PageTitle>

<div class="mx-auto flex w-full max-w-5xl min-w-0 flex-col gap-8">
    <section class="space-y-2">
        <h1 class="text-3xl font-semibold tracking-tight">Components</h1>
        <p class="max-w-2xl text-base leading-7 text-muted-foreground">
            Here you can find all the components available in the library. We are working on adding more components.
        </p>
    </section>

    <section>
        <div class="grid grid-cols-1 gap-x-10 gap-y-4 sm:grid-cols-2 lg:grid-cols-3 lg:gap-x-16 lg:gap-y-5 xl:gap-x-20">
            @foreach (DocsNavLink item in DocsNavigation.ComponentLinks)
            {
                @if (item.Href is not null)
                {
                    <a href="@item.Href" class="inline-flex items-center gap-2 text-lg font-medium underline-offset-4 transition-colors hover:underline md:text-base">
                        @item.Title
                        @if (item.IsNew)
                        {
                            <span class="size-2 rounded-full bg-blue-500"></span>
                        }
                    </a>
                }
                else
                {
                    <span class="inline-flex items-center gap-2 text-lg font-medium md:text-base">
                        @item.Title
                        @if (item.IsNew)
                        {
                            <span class="size-2 rounded-full bg-blue-500"></span>
                        }
                    </span>
                }
            }
        </div>
    </section>
</div>
