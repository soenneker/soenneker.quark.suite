@page "/components"

<PageTitle>Components - Quark Suite</PageTitle>

<Div data-slot="docs"
     Display="Display.Flex"
     AlignUtility="Align.ItemsStretch"
     ScrollMargin="ScrollMargin.Is24.FromTop"
     Width="Width.IsFull"
     Padding="Padding.Is8.FromBottom"
     class="text-[1.05rem] sm:text-[15px]">
    <Div Flex="Flex.Display.Fill.Column" MinWidth="MinWidth.Is0">
        <Div Height='Height.Token("h-(--top-spacing)")' class="shrink-0"></Div>

        <Div Margin="Margin.Auto.OnX"
             Width="Width.IsFull"
             MinWidth="MinWidth.Is0"
             Flex="Flex.Display.Fill.Column"
             Gap='Gap.Token("6")'
             class="w-full max-w-none px-0 py-6 text-neutral-800 dark:text-neutral-300 sm:max-w-[40rem] lg:py-8">
            <Div Flex="Flex.Display.Column" Gap="Gap.Is2">
                <Div Flex="Flex.Display.Column" Gap="Gap.Is2">
                    <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Xl.OnSm.Base" class="text-[1.05rem] sm:text-balance md:max-w-[80%]">
                        Browse the current Quark component demos and primitives, organized to match the docs experience more closely.
                    </Paragraph>
                </Div>
            </Div>

            <Div Width="Width.IsFull"
                 Flex="Flex.Fill"
                 Padding="Padding.Is16.FromBottom.OnSm.Is0.FromBottom"
                 class="*:data-[slot=alert]:first:mt-0">

                <Grid Columns="Columns.Is2.OnMd.Is3"
                      Gap='Gap.Is4.OnMd.Token("8").Column.OnLg.Token("16").Column.OnLg.Token("6").Row.OnXl.Token("20").Column'>
                    @foreach (var item in DocsNavigation.ComponentLinks)
                    {
                        @if (item.Href is not null)
                        {
                            <Anchor To="@item.Href"
                                    Display="Display.InlineFlex"
                                    Flex="Flex.AlignCenter"
                                    Gap="Gap.Is2"
                                    TextSize="TextSize.Lg.OnMd.Base"
                                    FontWeight="FontWeight.Medium"
                                    class="hover:underline">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <Span BoxSize="Size.Is2" Rounded="Rounded.Full" BackgroundColor='BackgroundColor.Token("blue-500")'></Span>
                                }
                            </Anchor>
                        }
                        else
                        {
                            <Span Display="Display.InlineFlex"
                                  Flex="Flex.AlignCenter"
                                  Gap="Gap.Is2"
                                  TextSize="TextSize.Lg.OnMd.Base"
                                  FontWeight="FontWeight.Medium"
                                  TextColor="TextColor.MutedForeground">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <Span BoxSize="Size.Is2" Rounded="Rounded.Full" BackgroundColor='BackgroundColor.Token("blue-500")'></Span>
                                }
                            </Span>
                        }
                    }
                </Grid>

                <Hr Margin="Margin.Is4.OnY.OnMd.Is8.OnY"/>

                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" class="mb-4">
                    Primitives
                </H2>

                <Grid Columns="Columns.Is2.OnMd.Is3"
                      Gap='Gap.Is4.OnMd.Token("8").Column.OnLg.Token("16").Column.OnLg.Token("6").Row'>
                    @foreach (var item in DocsNavigation.PrimitiveLinks)
                    {
                        @if (item.Href is not null)
                        {
                            <Anchor To="@item.Href"
                                    Display="Display.InlineFlex"
                                    Flex="Flex.AlignCenter"
                                    Gap="Gap.Is2"
                                    TextSize="TextSize.Lg.OnMd.Base"
                                    FontWeight="FontWeight.Medium"
                                    class="hover:underline">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <Span BoxSize="Size.Is2" Rounded="Rounded.Full" BackgroundColor='BackgroundColor.Token("blue-500")'></Span>
                                }
                            </Anchor>
                        }
                        else
                        {
                            <Span Display="Display.InlineFlex"
                                  Flex="Flex.AlignCenter"
                                  Gap="Gap.Is2"
                                  TextSize="TextSize.Lg.OnMd.Base"
                                  FontWeight="FontWeight.Medium"
                                  TextColor="TextColor.MutedForeground">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <Span BoxSize="Size.Is2" Rounded="Rounded.Full" BackgroundColor='BackgroundColor.Token("blue-500")'></Span>
                                }
                            </Span>
                        }
                    }
                </Grid>

                <Hr Margin="Margin.Is4.OnY.OnMd.Is8.OnY"/>

                <Paragraph LineHeight="LineHeight.Large" class="[&:not(:first-child)]:mt-6">
                    Can't find what you need? Try the <Anchor To="" FontWeight="FontWeight.Medium" TextDecoration="TextDecoration.Underline" LinkOffset="LinkOffset.Is4">documentation home</Anchor> for the full demo catalog.
                </Paragraph>
            </Div>

            <Div Display="Display.None.OnSm.Flex"
                 Height="Height.Is16"
                 Width="Width.IsFull"
                 Flex="Flex.AlignCenter"
                 Gap="Gap.Is2"
                 Padding="Padding.Is4.OnX.OnSm.Is0.OnX">
                <Anchor To="accordions"
                        Display="Display.InlineFlex"
                        Height="Height.Is8"
                        Flex="Flex.AlignCenter.JustifyCenter"
                        Gap='Gap.Token("1.5")'
                        Padding="Padding.Is3.OnX"
                        TextSize="TextSize.Sm"
                        FontWeight="FontWeight.Medium"
                        TextColor="TextColor.SecondaryForeground"
                        BackgroundColor="BackgroundColor.Secondary"
                        Rounded="Rounded.Md"
                        BoxShadow="BoxShadow.None"
                        Transition="Transition.All"
                        class="ml-auto hover:bg-secondary/80">
                    Accordion
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14"/>
                        <path d="m13 18 6-6-6-6"/>
                    </svg>
                </Anchor>
            </Div>
        </Div>
    </Div>
</Div>