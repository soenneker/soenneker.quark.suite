@page "/components"

<PageTitle>Components - Quark Suite</PageTitle>

<Div data-slot="docs" class="-mx-4 -my-6 flex scroll-mt-24 items-stretch pb-8 text-[1.05rem] sm:text-[15px] md:-mx-6 lg:-mx-8 lg:-my-8 xl:w-full">
    <Div Flex="Flex.Display.Fill.Column" MinWidth="MinWidth.Is0">
        <Div class="h-(--top-spacing) shrink-0"></Div>

        <Div Margin="Margin.Auto.OnX"
             Width="Width.IsFull"
             MinWidth="MinWidth.Is0"
             Flex="Flex.Display.Fill.Column"
             Gap='@Gap.Token("6")'
             Padding="Padding.Is4.OnX.Is6.OnY.Is0.OnX.OnMd.Is8.OnY.OnLg"
             class="max-w-[40rem] text-neutral-800 dark:text-neutral-300">
            <Div Flex="Flex.Display.Column" Gap="Gap.Is2">
                <Div Flex="Flex.Display.Column" Gap="Gap.Is2">
                    <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter.JustifyBetween.ItemsStart.OnMd">
                        <H1 TextSize="TextSize.Is2" FontWeight="FontWeight.Semibold" LetterSpacing="LetterSpacing.Tight" class="scroll-m-24 sm:text-3xl">Components</H1>
                    </Div>

                    <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Is5.OnSm" class="text-[1.05rem] sm:text-balance md:max-w-[80%]">
                        Here you can find all the components available in the library. We are working on adding more components.
                    </Paragraph>
                </Div>
            </Div>

            <Div Width="Width.IsFull" Flex="Flex.Fill" class="pb-16 *:data-[slot=alert]:first:mt-0 sm:pb-0">
                <Div Grid="Grid.Display.Cols(2).Cols(3).OnMd"
                     Gap='@Gap.Is4.Token("8").Column.OnMd.Token("16").Column.OnLg.Token("6").Row.OnLg.Token("20").Column.OnXl'>
                    @foreach (DocsNavLink item in DocsNavigation.ComponentLinks)
                    {
                        @if (item.Href is not null)
                        {
                            <Anchor To="@item.Href"
                                    Display="Display.InlineFlex"
                                    Flex="Flex.AlignCenter"
                                    Gap="Gap.Is2"
                                    TextSize="TextSize.Lg.Is5.OnMd"
                                    FontWeight="FontWeight.Medium"
                                    class="underline-offset-4 hover:underline">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <Span BoxSize="Size.Is2" class="rounded-full bg-blue-500"></Span>
                                }
                            </Anchor>
                        }
                        else
                        {
                            <Span Display="Display.InlineFlex"
                                  Flex="Flex.AlignCenter"
                                  Gap="Gap.Is2"
                                  TextSize="TextSize.Lg.Is5.OnMd"
                                  FontWeight="FontWeight.Medium"
                                  TextColor="TextColor.MutedForeground">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <Span BoxSize="Size.Is2" class="rounded-full bg-blue-500"></Span>
                                }
                            </Span>
                        }
                    }
                </Div>

                <Hr Margin="Margin.Is4.OnY.Is8.OnY.OnMd" />

                <Paragraph LineHeight="LineHeight.Large" class="[&:not(:first-child)]:mt-6">
                    Can't find what you need? Try the <Anchor To="" FontWeight="FontWeight.Medium" class="underline underline-offset-4">documentation home</Anchor> for the full demo catalog.
                </Paragraph>
            </Div>

            <Div Display="Display.None.Flex.OnSm"
                 Height='@Height.Token("16")'
                 Width="Width.IsFull"
                 Flex="Flex.AlignCenter"
                 Gap="Gap.Is2"
                 Padding="Padding.Is4.OnX.Is0.OnX.OnSm">
                <Anchor To="surfaces/accordions"
                        Display="Display.InlineFlex"
                        Height="Height.Is8"
                        Flex="Flex.AlignCenter.JustifyCenter"
                        Gap='@Gap.Token("1.5")'
                        Padding="Padding.Is3.OnX"
                        TextSize="TextSize.Is6"
                        FontWeight="FontWeight.Medium"
                        TextColor="TextColor.SecondaryForeground"
                        BackgroundColor="BackgroundColor.Secondary"
                        BorderRadius="BorderRadius.Md"
                        BoxShadow="BoxShadow.None"
                        Transition="Transition.All"
                        class="ml-auto hover:bg-secondary/80">
                    Accordion
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14" />
                        <path d="m13 18 6-6-6-6" />
                    </svg>
                </Anchor>
            </Div>
        </Div>
    </Div>
</Div>
