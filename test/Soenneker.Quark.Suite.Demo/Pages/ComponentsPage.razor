@page "/components"

<PageTitle>Components - Quark Suite</PageTitle>

<div data-slot="docs" class="-mx-4 -my-6 flex scroll-mt-24 items-stretch pb-8 text-[1.05rem] sm:text-[15px] md:-mx-6 lg:-mx-8 lg:-my-8 xl:w-full">
    <div class="flex min-w-0 flex-1 flex-col">
        <div class="h-(--top-spacing) shrink-0"></div>

        <div class="mx-auto flex w-full max-w-[40rem] min-w-0 flex-1 flex-col gap-6 px-4 py-6 text-neutral-800 md:px-0 lg:py-8 dark:text-neutral-300">
            <div class="flex flex-col gap-2">
                <div class="flex flex-col gap-2">
                    <div class="flex items-center justify-between md:items-start">
                        <h1 class="scroll-m-24 text-3xl font-semibold tracking-tight sm:text-3xl">Components</h1>
                    </div>

                    <p class="text-[1.05rem] text-muted-foreground sm:text-base sm:text-balance md:max-w-[80%]">
                        Here you can find all the components available in the library. We are working on adding more components.
                    </p>
                </div>
            </div>

            <div class="w-full flex-1 pb-16 *:data-[slot=alert]:first:mt-0 sm:pb-0">
                <div class="grid grid-cols-2 gap-4 md:grid-cols-3 md:gap-x-8 lg:gap-x-16 lg:gap-y-6 xl:gap-x-20">
                    @foreach (DocsNavLink item in DocsNavigation.ComponentLinks)
                    {
                        @if (item.Href is not null)
                        {
                            <a href="@item.Href" class="inline-flex items-center gap-2 text-lg font-medium underline-offset-4 hover:underline md:text-base">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <span class="size-2 rounded-full bg-blue-500"></span>
                                }
                            </a>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-2 text-lg font-medium text-muted-foreground md:text-base">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <span class="size-2 rounded-full bg-blue-500"></span>
                                }
                            </span>
                        }
                    }
                </div>

                <hr class="my-4 md:my-8" />

                <p class="leading-relaxed [&:not(:first-child)]:mt-6">
                    Can't find what you need? Try the <a class="font-medium underline underline-offset-4" href="/">documentation home</a> for the full demo catalog.
                </p>
            </div>

            <div class="hidden h-16 w-full items-center gap-2 px-4 sm:flex sm:px-0">
                <a class="ml-auto inline-flex items-center justify-center gap-1.5 rounded-md bg-secondary px-3 text-sm font-medium text-secondary-foreground shadow-none transition-all hover:bg-secondary/80 h-8" href="/surfaces/accordions">
                    Accordion
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M5 12h14" />
                        <path d="m13 18 6-6-6-6" />
                    </svg>
                </a>
            </div>
        </div>
    </div>
</div>
