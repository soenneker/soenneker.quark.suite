@page "/installation"

<PageTitle>Installation - Quark Suite</PageTitle>

<Div data-slot="docs"
     Display="Display.Flex"
     ItemsAlign="Items.Stretch"
     ScrollMargin="ScrollMargin.Is24.FromTop"
     Width="Width.IsFull"
     Padding="Padding.Is8.FromBottom"
     class="text-[1.05rem] sm:text-[15px]">
    <Div Flex="Flex.Is1" FlexDirection="FlexDirection.Col" MinWidth="MinWidth.Is0">
        <Div Height='Height.Token("h-(--top-spacing)")' Shrink="Shrink.Is0"></Div>

        <Div Margin="Margin.Auto.OnX"
             Width="Width.IsFull"
             MinWidth="MinWidth.Is0"
             Flex=@("flex flex-1 flex-col")
             Gap='Gap.Token("6")'
             class="w-full max-w-none px-0 py-6 text-neutral-800 dark:text-neutral-300 sm:max-w-[40rem] lg:py-8">
            <Div Flex=@("flex flex-col") Gap="Gap.Is2">
                <H1 ScrollMargin="ScrollMargin.Is24.FromTop" TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold" Tracking="Tracking.Tight" TextAlign="TextAlign.Start">Installation</H1>

                <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Xl.OnSm.Base" class="text-[1.05rem] sm:text-balance md:max-w-[80%]">
                    Add Quark Suite to a Blazor app, register its services, and include the generated styles.
                </Paragraph>
            </Div>

            <Div Space="Space.Y.Is8" Width="Width.IsFull" class="*:data-[slot=alert]:first:mt-0">
                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Install packages</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Install Quark Suite and the build-time generators that produce the local Tailwind stylesheet and icon assets used by your app.
                    </Paragraph>
                    <CodeEditor Text="@InstallPackagesCode" Language="shell" ReadOnly="true" AutoHeight="true" Minimap="false" ShowCopyButton="true" />
                    <Paragraph Leading="Leading.Relaxed">
                        Theme generation is optional. Add it when the app owns custom shadcn-compatible theme tokens.
                    </Paragraph>
                    <CodeEditor Text="@ThemePackageCode" Language="shell" ReadOnly="true" AutoHeight="true" Minimap="false" ShowCopyButton="true" />
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Enable build generation</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Enable the Tailwind generator in the app project so the Quark stylesheet is built with the classes used by your Razor files.
                    </Paragraph>
                    <CodeEditor Text="@BuildGenerationCode" Language="xml" ReadOnly="true" AutoHeight="true" Minimap="false" ShowCopyButton="true" />
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Register services</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Register Quark Suite during application startup so components and supporting services are available through dependency injection.
                    </Paragraph>
                    <CodeEditor Text="@RegisterServicesCode" Language="csharp" ReadOnly="true" AutoHeight="true" Minimap="false" ShowCopyButton="true" />
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Add styles</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Reference the generated stylesheet from `index.html`. The generator writes the CSS file into the app's `wwwroot/css` folder.
                    </Paragraph>
                    <CodeEditor Text="@StylesCode" Language="html" ReadOnly="true" AutoHeight="true" Minimap="false" ShowCopyButton="true" />
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">What the packages do</H2>
                    <UnorderedList Class="list-inside list-disc space-y-2">
                        <UnorderedListItem><Strong><Anchor Href="https://github.com/soenneker/soenneker.quark.suite" Target="Target.Blank">Soenneker.Quark.Suite</Anchor>:</Strong> the component library and shared Quark primitives.</UnorderedListItem>
                        <UnorderedListItem><Strong><Anchor Href="https://github.com/soenneker/soenneker.quark.gen.tailwind" Target="Target.Blank">Soenneker.Quark.Gen.Tailwind</Anchor>:</Strong> runs at build time and emits `wwwroot/css/quark-tailwind.css` and `wwwroot/css/quark-tailwind.min.css` for the app.</UnorderedListItem>
                        <UnorderedListItem><Strong><Anchor Href="https://github.com/soenneker/soenneker.quark.gen.tailwind.manifest" Target="Target.Blank">Soenneker.Quark.Gen.Tailwind.Manifest</Anchor>:</Strong> scans the app for builder-derived Tailwind classes so generated CSS includes the utilities used by Razor components.</UnorderedListItem>
                        <UnorderedListItem><Strong><Anchor Href="https://github.com/soenneker/soenneker.lucide.icons" Target="Target.Blank">Soenneker.Lucide.Icons</Anchor>:</Strong> provides the Lucide icon SVG catalog used by Quark icon components.</UnorderedListItem>
                        <UnorderedListItem><Strong><Anchor Href="https://github.com/soenneker/soenneker.quark.gen.lucide" Target="Target.Blank">Soenneker.Quark.Gen.Lucide</Anchor>:</Strong> generates the app-local Lucide icon map and service registration code used by `Icon`.</UnorderedListItem>
                        <UnorderedListItem><Strong><Anchor Href="https://github.com/soenneker/soenneker.quark.gen.themes" Target="Target.Blank">Soenneker.Quark.Gen.Themes</Anchor>:</Strong> optionally generates theme CSS from Quark theme definitions.</UnorderedListItem>
                    </UnorderedList>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Use components</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Import the Quark namespace and compose components directly in Razor.
                    </Paragraph>
                    <CodeEditor Text="@UseComponentsCode" Language="razor" ReadOnly="true" AutoHeight="true" Minimap="false" ShowCopyButton="true" />
                </Section>
            </Div>
        </Div>
    </Div>
</Div>

@code {
    private const string InstallPackagesCode =
@"dotnet add package Soenneker.Quark.Suite
dotnet add package Soenneker.Quark.Gen.Tailwind
dotnet add package Soenneker.Quark.Gen.Tailwind.Manifest
dotnet add package Soenneker.Lucide.Icons
dotnet add package Soenneker.Quark.Gen.Lucide";

    private const string ThemePackageCode = "dotnet add package Soenneker.Quark.Gen.Themes";

    private const string BuildGenerationCode =
@"<PropertyGroup>
    <TailwindGeneratorBuildEnabled>true</TailwindGeneratorBuildEnabled>
</PropertyGroup>";

    private const string RegisterServicesCode = "builder.Services.AddQuarkSuiteAsScoped();";

    private const string StylesCode = @"<link href=""css/quark-tailwind.min.css"" rel=""stylesheet"" />";

    private const string UseComponentsCode =
@"@using Soenneker.Quark

<Button Variant=""ButtonVariant.Default"">
    Save changes
</Button>";
}
