@page "/feedback/progresses"
@using Microsoft.Extensions.Logging

@inject ILogger<Index> Logger

<PageTitle>Progress - Quark Suite</PageTitle>

<Div Class="space-y-8 max-w-4xl">
    <Div Class="space-y-6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic Progress" Description="Progress bar with a value." Code="@(@"<Progress Value=""25""/>")">
                <Div Margin="Margin.Is3.FromEnd">
                    <Progress Value="25" Margin="Margin.Is3.FromBottom"/>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Different Values" Description="Progress bars at various completion levels." Code="@(@"<Progress Value=""60""/>
<Progress Value=""90""/>")">
                <Div Margin="Margin.Is3.FromEnd" Space="Space.Y.Is3">
                    <Progress Value="60"/>
                    <Progress Value="90"/>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code{

    protected override void OnInitialized()
    {
    }

}
