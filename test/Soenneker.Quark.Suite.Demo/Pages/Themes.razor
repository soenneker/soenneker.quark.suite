@page "/themes"

<PageTitle>Themes - Quark Suite</PageTitle>

<Div data-slot="docs"
     Display="Display.Flex"
     ItemsAlign="Items.Stretch"
     ScrollMargin="ScrollMargin.Is24.FromTop"
     Width="Width.IsFull"
     Padding="Padding.Is8.FromBottom"
     class="text-[1.05rem] sm:text-[15px]">
    <Div Flex="Flex.Is1" FlexDirection="FlexDirection.Col" MinWidth="MinWidth.Is0">
        <Div Height='Height.Token("h-(--top-spacing)")' Shrink="Shrink.Is0"></Div>

        <Div Margin="Margin.Auto.OnX"
             Width="Width.IsFull"
             MinWidth="MinWidth.Is0"
             Flex=@("flex flex-1 flex-col")
             Gap='Gap.Token("6")'
             class="w-full max-w-none px-0 py-6 text-neutral-800 dark:text-neutral-300 sm:max-w-[40rem] lg:py-8">
            <Div Flex=@("flex flex-col") Gap="Gap.Is2">
                <H1 ScrollMargin="ScrollMargin.Is24.FromTop" TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold" Tracking="Tracking.Tight" TextAlign="TextAlign.Start">Themes</H1>

                <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Xl.OnSm.Base" class="text-[1.05rem] sm:text-balance md:max-w-[80%]">
                    Generate Quark theme CSS at compile time from a strongly typed Theme definition.
                </Paragraph>
            </Div>

            <Div Space="Space.Y.Is8" Width="Width.IsFull" class="*:data-[slot=alert]:first:mt-0">
                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Install generator</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Theme generation lives in the Soenneker.Quark.Gen.Themes package. Reference it as a build-time dependency in the app that owns the theme.
                    </Paragraph>
                    <PreCode Language="bash">dotnet add package Soenneker.Quark.Gen.Themes</PreCode>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Create a theme</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Add GenerateQuarkThemeCss to a class with exactly one public static method or property returning Theme. The factory can optionally take IServiceProvider.
                    </Paragraph>
                    <PreCode Language="csharp">using Soenneker.Quark;
using Soenneker.Quark.Gen.Themes;
using Soenneker.Quark.Tokens;

[GenerateQuarkThemeCss("wwwroot/css/quark-theme.css")]
public static class AppTheme
{
    public static Theme Build() => new()
    {
        Name = "App",
        Tokens = new ThemeTokens
        {
            Light =
            {
                Primary = "oklch(0.623 0.214 259.815)",
                PrimaryForeground = "oklch(0.985 0 0)"
            },
            Dark =
            {
                Primary = "oklch(0.809 0.105 251.813)",
                PrimaryForeground = "oklch(0.205 0 0)"
            }
        },
        Anchors = new AnchorOptions
        {
            Selector = "a",
            DecorationLine = DecorationLine.None,
            TextColor = "#2563ba"
        },
        Buttons = new ButtonOptions
        {
            BackgroundColor = "#2563eb",
            TextColor = "#ffffff",
            Rounded = "0.5rem",
            Padding = "0.5rem 1rem"
        },
        Cards = new CardOptions
        {
            BackgroundColor = "#ffffff",
            Rounded = "0.75rem",
            BoxShadow = "0 0.25rem 0.75rem rgba(0,0,0,0.08)"
        }
    };
}</PreCode>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Use the emitted CSS</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        The generator writes the requested CSS file and, by default, a minified sibling. Reference the generated stylesheet after Quark's base styles.
                    </Paragraph>
                    <PreCode Language="html">&lt;link rel="stylesheet" href="_content/Soenneker.Quark.Suite/css/quark-tailwind.css" /&gt;
&lt;link rel="stylesheet" href="css/quark-theme.css" /&gt;</PreCode>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Tailwind theme output</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        The same Theme also emits tailwind/quark-theme.generated.css unless TailwindThemeOutputFilePath is overridden. Import that file into the Tailwind input when the app should replace the baked-in shadcn theme variables during the Tailwind build.
                    </Paragraph>
                    <PreCode Language="css">@("@import \"./quark-theme.generated.css\";")</PreCode>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Generated options</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        BuildUnminified, BuildMinified, and TailwindThemeOutputFilePath can be set on the attribute when an app needs different output behavior.
                    </Paragraph>
                    <PreCode Language="csharp">[GenerateQuarkThemeCss(
    "wwwroot/css/quark-theme.css",
    BuildUnminified = true,
    BuildMinified = true,
    TailwindThemeOutputFilePath = "tailwind/quark-theme.generated.css")]</PreCode>
                </Section>
            </Div>
        </Div>
    </Div>
</Div>
