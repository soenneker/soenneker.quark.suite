@page "/introduction"

<PageTitle>Introduction - Quark Suite</PageTitle>

<Div data-slot="docs"
     Display="Display.Flex"
     ItemsAlign="Items.Stretch"
     ScrollMargin="ScrollMargin.Is24.FromTop"
     Width="Width.IsFull"
     Padding="Padding.Is8.FromBottom"
     class="text-[1.05rem] sm:text-[15px]">
    <Div Flex="Flex.Is1" FlexDirection="FlexDirection.Col" MinWidth="MinWidth.Is0">
        <Div Height='Height.Token("h-(--top-spacing)")' Shrink="Shrink.Is0"></Div>

        <Div Margin="Margin.Auto.OnX"
             Width="Width.IsFull"
             MinWidth="MinWidth.Is0"
             Flex=@("flex flex-1 flex-col")
             Gap='Gap.Token("6")'
             class="w-full max-w-none px-0 py-6 text-neutral-800 dark:text-neutral-300 sm:max-w-[40rem] lg:py-8">
            <Div Flex=@("flex flex-col") Gap="Gap.Is2">
                <H1 ScrollMargin="ScrollMargin.Is24.FromTop" TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold" Tracking="Tracking.Tight" TextAlign="TextAlign.Start">Introduction</H1>

                <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Xl.OnSm.Base" class="text-[1.05rem] sm:text-balance md:max-w-[80%]">
                    Quark Suite is a Blazor component library inspired by shadcn/ui, built around composable primitives, semantic markup, and Tailwind-friendly styling.
                </Paragraph>
            </Div>

            <Div Space="Space.Y.Is8" Width="Width.IsFull" class="*:data-[slot=alert]:first:mt-0">
                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">What is Quark?</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Quark components render native HTML where possible and expose consistent parameters for spacing, color, layout, and accessibility attributes.
                        The suite is intended to be practical in product apps while still keeping the underlying markup easy to reason about.
                    </Paragraph>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Principles</H2>
                    <UnorderedList Class="list-inside list-disc space-y-2">
                        <UnorderedListItem>Composable components that work well together.</UnorderedListItem>
                        <UnorderedListItem>Semantic primitives for layout, typography, navigation, and media.</UnorderedListItem>
                        <UnorderedListItem>Tailwind-compatible class output with Quark builder parameters when useful.</UnorderedListItem>
                        <UnorderedListItem>Accessible defaults with escape hatches for application-specific markup.</UnorderedListItem>
                    </UnorderedList>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Next steps</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Start with the <Anchor To="installation" FontWeight="FontWeight.Medium" DecorationLine="DecorationLine.Underline" LinkOffset="LinkOffset.Is4">installation guide</Anchor>,
                        then browse the component catalog for examples and API behavior.
                    </Paragraph>
                </Section>
            </Div>
        </Div>
    </Div>
</Div>
