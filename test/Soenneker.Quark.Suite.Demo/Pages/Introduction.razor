@page "/introduction"

<PageTitle>Introduction - Quark Suite</PageTitle>

<Div data-slot="docs"
     Display="Display.Flex"
     ItemsAlign="Items.Stretch"
     ScrollMargin="ScrollMargin.Is24.FromTop"
     Width="Width.IsFull"
     Padding="Padding.Is8.FromBottom"
     class="text-[1.05rem] sm:text-[15px]">
    <Div Flex="Flex.Is1" FlexDirection="FlexDirection.Col" MinWidth="MinWidth.Is0">
        <Div Height='Height.Token("h-(--top-spacing)")' Shrink="Shrink.Is0"></Div>

        <Div Margin="Margin.Auto.OnX"
             Width="Width.IsFull"
             MinWidth="MinWidth.Is0"
             Flex=@("flex flex-1 flex-col")
             Gap='Gap.Token("8")'
             class="w-full max-w-none px-0 py-4 text-neutral-800 dark:text-neutral-300 sm:max-w-[48rem] lg:py-6">
            <Div class="relative overflow-hidden rounded-lg border bg-background p-6 shadow-sm sm:p-8">
                <Div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-sky-500 via-emerald-500 to-amber-500"></Div>

                <Div Flex=@("flex flex-col") Gap="Gap.Is5">
                    <Div Flex=@("flex flex-col") Gap="Gap.Is3">
                        <Badge Variant="BadgeVariant.Secondary" Class="w-fit gap-1.5 rounded-full px-3">
                            <Icon Name="LucideIcon.Sparkles" Class="size-3.5" aria-hidden="true" />
                            Blazor components for application UI
                        </Badge>

                        <H1 ScrollMargin="ScrollMargin.Is24.FromTop"
                            TextSize="TextSize.FourXl.OnSm.ThreeXl"
                            FontWeight="FontWeight.Semibold"
                            Tracking="Tracking.Tight"
                            TextAlign="TextAlign.Start"
                            class="max-w-[40rem] text-balance">
                            Build shadcn-style interfaces in Razor.
                        </H1>

                        <Paragraph TextColor="TextColor.MutedForeground"
                                   TextSize="TextSize.Xl.OnSm.Base"
                                   Leading="Leading.Relaxed"
                                   class="max-w-[42rem] text-[1.05rem] text-balance">
                            Quark Suite gives Blazor apps a practical component layer: styled components when you want defaults, primitives when you need control, and typed Tailwind helpers when raw class strings are not enough.
                        </Paragraph>
                    </Div>

                    <Div Flex=@("flex flex-wrap") Gap="Gap.Is3">
                        <Button AsChild="true">
                            <Anchor Href="installation">
                                Install Quark
                                <Icon Name="LucideIcon.ArrowRight" Class="size-4" aria-hidden="true" />
                            </Anchor>
                        </Button>

                        <Button AsChild="true" Variant="ButtonVariant.Outline">
                            <Anchor Href="components">
                                Browse components
                            </Anchor>
                        </Button>
                    </Div>

                    <Grid Columns="GridCols.Is1.OnMd.Is3" Gap="Gap.Is3">
                        <Div class="rounded-lg border bg-muted/35 p-4">
                            <Icon Name="LucideIcon.Boxes" Class="mb-3 size-5 text-sky-600 dark:text-sky-400" aria-hidden="true" />
                            <H3 TextSize="TextSize.Base" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Component model</H3>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed" class="mt-1">
                                Familiar shadcn/ui patterns translated into Razor composition.
                            </Paragraph>
                        </Div>

                        <Div class="rounded-lg border bg-muted/35 p-4">
                            <Icon Name="LucideIcon.WandSparkles" Class="mb-3 size-5 text-emerald-600 dark:text-emerald-400" aria-hidden="true" />
                            <H3 TextSize="TextSize.Base" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Typed styling</H3>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed" class="mt-1">
                                Tailwind utilities through parameters, builders, and raw classes.
                            </Paragraph>
                        </Div>

                        <Div class="rounded-lg border bg-muted/35 p-4">
                            <Icon Name="LucideIcon.Code" Class="mb-3 size-5 text-amber-600 dark:text-amber-400" aria-hidden="true" />
                            <H3 TextSize="TextSize.Base" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">HTML first</H3>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed" class="mt-1">
                                Semantic primitives keep output readable and accessible.
                            </Paragraph>
                        </Div>
                    </Grid>
                </Div>
            </Div>

            <Div Space="Space.Y.Is8" Width="Width.IsFull" class="*:data-[slot=alert]:first:mt-0">
                <Section Space="Space.Y.Is4" class="border-l-2 border-sky-500/70 pl-5">
                    <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">What Quark is</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        Quark provides Razor components for common application UI: buttons, dialogs, forms, layout primitives, tables, navigation, typography, and data-display components. It is meant for product interfaces where the markup needs to stay understandable and the API should feel native to Blazor.
                    </Paragraph>
                    <Paragraph Leading="Leading.Relaxed">
                        The components render ordinary HTML elements where possible and expose typed parameters for layout, spacing, color, typography, accessibility attributes, and component-specific behavior. You can stay in the component API for common work and drop down to plain HTML, classes, styles, and attributes whenever the application needs it.
                    </Paragraph>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Why use it</H2>
                    <Grid Columns="GridCols.Is1.OnMd.Is2" Gap="Gap.Is3">
                        <Div class="rounded-lg border bg-muted/30 p-4">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" class="mb-2">
                                <Icon Name="LucideIcon.ShieldCheck" Class="size-4 text-sky-600 dark:text-sky-400" aria-hidden="true" />
                                <H3 TextSize="TextSize.Base" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Accessible shape</H3>
                            </Div>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed">
                                Components keep semantic elements, ARIA hooks, and keyboard behavior close to the surface instead of burying them behind opaque wrappers.
                            </Paragraph>
                        </Div>

                        <Div class="rounded-lg border bg-muted/30 p-4">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" class="mb-2">
                                <Icon Name="LucideIcon.Braces" Class="size-4 text-emerald-600 dark:text-emerald-400" aria-hidden="true" />
                                <H3 TextSize="TextSize.Base" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">C# ergonomics</H3>
                            </Div>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed">
                                Variants, sizes, layout, and many utilities are available as typed parameters, so refactors get compiler help and editor completion.
                            </Paragraph>
                        </Div>

                        <Div class="rounded-lg border bg-muted/30 p-4">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" class="mb-2">
                                <Icon Name="LucideIcon.Paintbrush" Class="size-4 text-amber-600 dark:text-amber-400" aria-hidden="true" />
                                <H3 TextSize="TextSize.Base" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Design-system friendly</H3>
                            </Div>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed">
                                Theme tokens and utility classes are first-class, so teams can keep shadcn-compatible defaults or replace them with their own system.
                            </Paragraph>
                        </Div>

                        <Div class="rounded-lg border bg-muted/30 p-4">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" class="mb-2">
                                <Icon Name="LucideIcon.Terminal" Class="size-4 text-rose-600 dark:text-rose-400" aria-hidden="true" />
                                <H3 TextSize="TextSize.Base" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Build-time support</H3>
                            </Div>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed">
                                Generators collect Tailwind utilities, icon usage, and optional theme CSS so the app owns the output it ships.
                            </Paragraph>
                        </Div>
                    </Grid>
                </Section>

                <Section Space="Space.Y.Is4" class="border-l-2 border-emerald-500/70 pl-5">
                    <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Relationship to shadcn/ui</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        <Anchor Href="https://ui.shadcn.com/" Target="Target.Blank" FontWeight="FontWeight.Medium" DecorationLine="DecorationLine.Underline" LinkOffset="LinkOffset.Is4">shadcn/ui</Anchor> is the reference point for many component APIs, variants, slots, and visual contracts. Quark ports that style of component composition to Blazor, while using Razor parameters and .NET types instead of React props.
                    </Paragraph>
                    <Paragraph Leading="Leading.Relaxed">
                        When a component maps to a shadcn/ui pattern, Quark keeps the naming and behavior recognizable. When Blazor needs a different shape, Quark favors Razor-native APIs over a forced React copy.
                    </Paragraph>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">How the pieces fit</H2>
                    <Grid Columns="GridCols.Is1.OnMd.Is2" Gap="Gap.Is4">
                        <Div class="rounded-lg border p-5">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" class="mb-3">
                                <Icon Name="LucideIcon.Layers" Class="size-5 text-sky-600 dark:text-sky-400" aria-hidden="true" />
                                <H3 TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Components</H3>
                            </Div>
                            <Paragraph TextColor="TextColor.MutedForeground" Leading="Leading.Relaxed">
                                Use components when you want finished UI with consistent defaults: buttons, dialogs, fields, tables, navigation, feedback, and data display. They are the fastest path for screens that should already look like part of the system.
                            </Paragraph>
                        </Div>

                        <Div class="rounded-lg border p-5">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" class="mb-3">
                                <Icon Name="LucideIcon.GitBranch" Class="size-5 text-emerald-600 dark:text-emerald-400" aria-hidden="true" />
                                <H3 TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Primitives</H3>
                            </Div>
                            <Paragraph TextColor="TextColor.MutedForeground" Leading="Leading.Relaxed">
                                Use primitives when the behavior matters but the visual treatment belongs to your app. They keep composition flexible for custom surfaces, internal design systems, and edge cases that should not fight a prebuilt component.
                            </Paragraph>
                        </Div>
                    </Grid>
                </Section>

                <Section Space="Space.Y.Is4" class="border-l-2 border-amber-500/70 pl-5">
                    <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Relationship to Tailwind</H2>
                    <Paragraph Leading="Leading.Relaxed">
                        <Anchor Href="https://tailwindcss.com/" Target="Target.Blank" FontWeight="FontWeight.Medium" DecorationLine="DecorationLine.Underline" LinkOffset="LinkOffset.Is4">Tailwind CSS</Anchor> is the styling layer. Quark builder parameters emit Tailwind utility classes, and the demo/app build uses Quark generators to collect the utilities used by Razor files and produce the app stylesheet.
                    </Paragraph>
                    <Paragraph Leading="Leading.Relaxed">
                        You can use typed builders for common utilities, raw <Code>Class</Code> values for exact Tailwind selectors, and theme tokens for shadcn-compatible colors. This keeps simple styling typed without blocking advanced Tailwind usage.
                    </Paragraph>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Stack and theming</H2>
                    <Div class="grid gap-3 sm:grid-cols-2">
                        <Div class="rounded-lg border bg-background p-4">
                            <Strong>Blazor and Razor</Strong>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed" class="mt-1">
                                Components are authored for .NET apps and favor Razor-native APIs over React-shaped copies.
                            </Paragraph>
                        </Div>
                        <Div class="rounded-lg border bg-background p-4">
                            <Strong>Tailwind utilities</Strong>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed" class="mt-1">
                                Styling remains inspectable because utilities are generated into the app stylesheet.
                            </Paragraph>
                        </Div>
                        <Div class="rounded-lg border bg-background p-4">
                            <Strong>CSS variables</Strong>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed" class="mt-1">
                                Theme values flow through shadcn-style tokens for light, dark, sidebar, series, and surface colors.
                            </Paragraph>
                        </Div>
                        <Div class="rounded-lg border bg-background p-4">
                            <Strong>OKLCH palettes</Strong>
                            <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Leading="Leading.Relaxed" class="mt-1">
                                Generated Tailwind colors use modern color tokens while still compiling down to ordinary CSS.
                            </Paragraph>
                        </Div>
                    </Div>
                </Section>

                <Section Space="Space.Y.Is4">
                    <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">What Quark gives you</H2>
                    <UnorderedList Class="grid list-none gap-3 sm:grid-cols-2">
                        <UnorderedListItem>Blazor components modeled after shadcn/ui patterns where those patterns make sense.</UnorderedListItem>
                        <UnorderedListItem>Typed Tailwind builders for layout, spacing, typography, color, borders, sizing, effects, and responsive modifiers.</UnorderedListItem>
                        <UnorderedListItem>Semantic primitives such as <Code>Div</Code>, <Code>Section</Code>, <Code>Paragraph</Code>, <Code>Anchor</Code>, <Code>Grid</Code>, and <Code>Stack</Code>.</UnorderedListItem>
                        <UnorderedListItem>Escape hatches through <Code>Class</Code>, <Code>Style</Code>, ARIA attributes, data attributes, and unmatched Razor attributes.</UnorderedListItem>
                        <UnorderedListItem>Build-time generation for Tailwind output, icon usage, and optional shadcn-compatible theme CSS.</UnorderedListItem>
                    </UnorderedList>
                </Section>

                <Section class="rounded-lg border bg-muted/30 p-5">
                    <Div Display="Display.Flex" Flex=@("flex-col gap-4 sm:flex-row sm:items-center sm:justify-between")>
                        <Div Space="Space.Y.Is2">
                            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">Next steps</H2>
                            <Paragraph TextColor="TextColor.MutedForeground" Leading="Leading.Relaxed">
                                Start with installation, scan properties for the typed builder model, then browse components and primitives to see the API in context.
                            </Paragraph>
                        </Div>

                        <Div Flex=@("flex flex-wrap") Gap="Gap.Is2">
                            <Button AsChild="true" ButtonSize="ButtonSize.Sm">
                                <Anchor Href="installation">Installation</Anchor>
                            </Button>
                            <Button AsChild="true" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Sm">
                                <Anchor Href="properties">Properties</Anchor>
                            </Button>
                            <Button AsChild="true" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Sm">
                                <Anchor Href="components">Components</Anchor>
                            </Button>
                        </Div>
                    </Div>
                </Section>
            </Div>
        </Div>
    </Div>
</Div>
