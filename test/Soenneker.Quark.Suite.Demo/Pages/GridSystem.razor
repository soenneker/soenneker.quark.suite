@page "/grid-system"

<PageTitle>Grid System - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is6xl">
    <Div Space="Space.Y.Is3">
        <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Xl.OnSm.Base" class="text-[1.05rem] sm:text-balance">
            Quark's grid system is a thin, typed layer over CSS grid and Tailwind grid utilities.
            The examples below are live layouts; resize the viewport to see the responsive builders change columns and spans.
        </Paragraph>
    </Div>

    <Div Space="Space.Y.Is8" Width="Width.IsFull">
        <DemoSection Title="Responsive Columns"
                     Description="One column by default, two at md, and four at xl."
                     Code="@ResponsiveColumnsCode"
                     CodeLanguage="razor"
                     PreviewAlign="start"
                     PreviewClass="preview relative flex w-full justify-start p-4"
                     PreviewInnerClass="w-full">
            <Grid Columns="GridCols.Is1.OnMd.Is2.OnXl.Is4" Gap="Gap.Is4" Width="Width.IsFull">
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Shadow="Shadow.Sm">
                    <Strong>Pipeline</Strong>
                    <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">32 active deals</Paragraph>
                </Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Shadow="Shadow.Sm">
                    <Strong>Booked</Strong>
                    <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">$84.2k this month</Paragraph>
                </Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Shadow="Shadow.Sm">
                    <Strong>Conversion</Strong>
                    <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">18.4% qualified</Paragraph>
                </Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Shadow="Shadow.Sm">
                    <Strong>Response</Strong>
                    <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">1h 12m median</Paragraph>
                </Div>
            </Grid>
        </DemoSection>

        <DemoSection Title="Dashboard Spans"
                     Description="GridItem spans create hierarchy without breaking the mobile stack."
                     Code="@DashboardSpansCode"
                     CodeLanguage="razor"
                     PreviewAlign="start"
                     PreviewClass="preview relative flex w-full justify-start p-4"
                     PreviewInnerClass="w-full">
            <Grid Columns="GridCols.Is1.OnMd.Is4" Gap="Gap.Is4" Width="Width.IsFull">
                <GridItem ColumnSpan="ColumnSpan.Is1.OnMd.Is2" RowSpan="RowSpan.Is1.OnMd.Is2" Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Shadow="Shadow.Sm" Class="min-h-48">
                    <Strong>Revenue trend</Strong>
                    <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Primary panel spans two of four tracks from md upward.</Paragraph>
                    <Div Margin="Margin.Is4.FromTop" Display="Display.Flex" ItemsAlign="Items.End" Gap="Gap.Is2" Class="h-24">
                        <Div BackgroundColor='BackgroundColor.Token("primary/25")' Rounded="Rounded.Sm" Width='Width.Token("12%")' Class="h-10"></Div>
                        <Div BackgroundColor='BackgroundColor.Token("primary/35")' Rounded="Rounded.Sm" Width='Width.Token("12%")' Class="h-16"></Div>
                        <Div BackgroundColor='BackgroundColor.Token("primary/45")' Rounded="Rounded.Sm" Width='Width.Token("12%")' Class="h-12"></Div>
                        <Div BackgroundColor='BackgroundColor.Token("primary/60")' Rounded="Rounded.Sm" Width='Width.Token("12%")' Class="h-20"></Div>
                        <Div BackgroundColor='BackgroundColor.Token("primary/80")' Rounded="Rounded.Sm" Width='Width.Token("12%")' Class="h-24"></Div>
                    </Div>
                </GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">
                    <Strong>Open value</Strong>
                    <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm">$240k</Paragraph>
                </GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">
                    <Strong>Next actions</Strong>
                    <Paragraph Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm">14 due today</Paragraph>
                </GridItem>
            </Grid>
        </DemoSection>

        <DemoSection Title="Responsive Form Grid"
                     Description="Fields stay single-column on small screens and pair up when horizontal space exists."
                     Code="@FormGridCode"
                     CodeLanguage="razor"
                     PreviewAlign="start"
                     PreviewClass="preview relative flex w-full justify-start p-4"
                     PreviewInnerClass="w-full">
            <Grid Columns="GridCols.Is1.OnMd.Is2" Gap="Gap.Is4" Width="Width.IsFull">
                <Div Space="Space.Y.Is2">
                    <Strong>Company</Strong>
                    <Div Border="Border.Is1" Rounded="Rounded.Lg" Padding="Padding.Is3" BackgroundColor="BackgroundColor.Card">Acme Systems</Div>
                </Div>
                <Div Space="Space.Y.Is2">
                    <Strong>Owner</Strong>
                    <Div Border="Border.Is1" Rounded="Rounded.Lg" Padding="Padding.Is3" BackgroundColor="BackgroundColor.Card">Jordan Lee</Div>
                </Div>
                <GridItem ColumnSpan="ColumnSpan.Is1.OnMd.Is2" Space="Space.Y.Is2">
                    <Strong>Notes</Strong>
                    <Div Border="Border.Is1" Rounded="Rounded.Lg" Padding="Padding.Is3" BackgroundColor="BackgroundColor.Card" Class="min-h-24">Enterprise renewal with procurement review next week.</Div>
                </GridItem>
            </Grid>
        </DemoSection>

        <DemoSection Title="Rows And Inline Grid"
                     Description="Rows are useful for fixed-format panels; inline grids fit compact toolbar content."
                     Code="@RowsAndInlineCode"
                     CodeLanguage="razor"
                     PreviewAlign="start"
                     PreviewClass="preview relative flex w-full justify-start p-4"
                     PreviewInnerClass="w-full">
            <Div Space="Space.Y.Is4" Width="Width.IsFull">
                <Grid Columns="GridCols.Is2" Rows="GridRows.Is3" Gap="Gap.Is2" Width="Width.IsFull">
                    <Div Rounded="Rounded.Md" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3">A1</Div>
                    <Div Rounded="Rounded.Md" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3">A2</Div>
                    <Div Rounded="Rounded.Md" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3">B1</Div>
                    <Div Rounded="Rounded.Md" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3">B2</Div>
                    <Div Rounded="Rounded.Md" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3">C1</Div>
                    <Div Rounded="Rounded.Md" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is3">C2</Div>
                </Grid>

                <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Span TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Status</Span>
                    <Grid Inline="true" Columns="GridCols.Is3" Gap="Gap.Is1">
                        <Div Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/20")' Padding="Padding.OnX.Is2">New</Div>
                        <Div Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/30")' Padding="Padding.OnX.Is2">Won</Div>
                        <Div Rounded="Rounded.Sm" BackgroundColor='BackgroundColor.Token("primary/40")' Padding="Padding.OnX.Is2">Lost</Div>
                    </Grid>
                </Div>
            </Div>
        </DemoSection>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold" TextAlign="TextAlign.Start">When to use grid</H2>
            <UnorderedList Class="list-inside list-disc space-y-2">
                <UnorderedListItem>Use <Code>Grid</Code> when both rows and columns matter, or when cards, fields, metrics, or panels need predictable tracks.</UnorderedListItem>
                <UnorderedListItem>Use <Code>Stack</Code> for one-dimensional flows where items simply move vertically or horizontally.</UnorderedListItem>
                <UnorderedListItem>Use <Code>Container</Code> for page width and gutters, then place <Code>Grid</Code> inside it when the content needs tracks.</UnorderedListItem>
                <UnorderedListItem>Use raw <Code>Class</Code> for unusual CSS grid values that are not worth promoting to a typed builder.</UnorderedListItem>
            </UnorderedList>
            <Paragraph Leading="Leading.Relaxed">
                For focused component examples, see the <Anchor Href="components/grids" FontWeight="FontWeight.Medium" DecorationLine="DecorationLine.Underline" LinkOffset="LinkOffset.Is4">Grid component page</Anchor>.
            </Paragraph>
        </Section>
    </Div>
</Div>

