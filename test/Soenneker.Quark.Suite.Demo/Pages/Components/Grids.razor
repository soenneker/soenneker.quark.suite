@page "/grids"

<PageTitle>Grid - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is6xl">
    <Div Space="Space.Y.Is3">
        <H1>Grid</H1>
        <Paragraph>
            `Grid` is a small wrapper around CSS grid utilities. Use `Columns` for column tracks, `Rows` for row
            tracks, and `GridItem` when a child needs to span or position itself differently.
        </Paragraph>
    </Div>

    <Div Space="Space.Y.Is6">
        <DemoSection Title="Basic Columns"
                     Description="Start with a fixed number of GridCols."
                     Code="@(@"<Grid Columns=""@GridCols.Is3"" Gap=""Gap.Is4"">
    <Div Class=""rounded-lg border p-4"">One</Div>
    <Div Class=""rounded-lg border p-4"">Two</Div>
    <Div Class=""rounded-lg border p-4"">Three</Div>
</Grid>")"
CodeLanguage="razor">
            <Grid Columns="GridCols.Is3" Gap="Gap.Is4">
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">One</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Two</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Three</Div>
            </Grid>
        </DemoSection>

        <DemoSection Title="Responsive Columns"
                     Description="Chain breakpoints when the layout should change by screen size."
                     Code="@(@"<Grid Columns=""@GridCols.Is2.OnXl.Is1"" Gap=""Gap.Is4"">
    <Div Class=""rounded-lg border p-4"">One</Div>
    <Div Class=""rounded-lg border p-4"">Two</Div>
    <Div Class=""rounded-lg border p-4"">Three</Div>
    <Div Class=""rounded-lg border p-4"">Four</Div>
</Grid>")"
CodeLanguage="razor">
            <Grid Columns="GridCols.Is2.OnXl.Is1" Gap="Gap.Is4">
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">One</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Two</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Three</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Four</Div>
            </Grid>
        </DemoSection>

        <DemoSection Title="Item Spans"
                     Description="Use `GridItem` when a child needs to span columns or GridRows."
                     Code="@(@"<Grid Columns=""@GridCols.Is3"" Gap=""Gap.Is4"">
    <GridItem ColumnSpan=""@ColumnSpan.Is2"" Class=""rounded-lg border p-4"">Featured</GridItem>
    <GridItem Class=""rounded-lg border p-4"">Side</GridItem>
    <GridItem Class=""rounded-lg border p-4"">Bottom left</GridItem>
    <GridItem Class=""rounded-lg border p-4"">Bottom right</GridItem>
</Grid>")"
CodeLanguage="razor">
            <Grid Columns="GridCols.Is3" Gap="Gap.Is4">
                <GridItem ColumnSpan="ColumnSpan.Is2" Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Featured</GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Side</GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Bottom left</GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Bottom right</GridItem>
            </Grid>
        </DemoSection>

        <DemoSection Title="Responsive Rows"
                     Description="`Rows` works the same way when you want to control row tracks."
                     Code="@(@"<Grid Columns=""@GridCols.Is2"" Rows=""@GridRows.Is3.OnXl.Is2"" Gap=""Gap.Is3"">
    <Div Class=""rounded-lg border p-4"">One</Div>
    <Div Class=""rounded-lg border p-4"">Two</Div>
    <Div Class=""rounded-lg border p-4"">Three</Div>
    <Div Class=""rounded-lg border p-4"">Four</Div>
    <Div Class=""rounded-lg border p-4"">Five</Div>
    <Div Class=""rounded-lg border p-4"">Six</Div>
</Grid>")"
CodeLanguage="razor">
            <Grid Columns="GridCols.Is2" Rows="GridRows.Is3.OnXl.Is2" Gap="Gap.Is3">
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">One</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">Two</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">Three</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">Four</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">Five</Div>
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor='BackgroundColor.Token("muted/40")' Padding="Padding.Is4">Six</Div>
            </Grid>
        </DemoSection>

        <DemoSection Title="Responsive Item Spans"
                     Description="`GridItem` spans can respond to breakpoints the same way as the grid itself."
                     Code="@(@"<Grid Columns=""@GridCols.Is1.OnMd.Is4"" Gap=""Gap.Is3"">
    <GridItem ColumnSpan=""@ColumnSpan.Is1.OnMd.Is2"" RowSpan=""@RowSpan.Is1.OnMd.Is2"" Class=""rounded-lg border p-4"">
        Feature
    </GridItem>
    <GridItem Class=""rounded-lg border p-4"">One</GridItem>
    <GridItem Class=""rounded-lg border p-4"">Two</GridItem>
    <GridItem Class=""rounded-lg border p-4"">Three</GridItem>
</Grid>")"
CodeLanguage="razor">
            <Grid Columns="GridCols.Is1.OnMd.Is4" Gap="Gap.Is3">
                <GridItem ColumnSpan="ColumnSpan.Is1.OnMd.Is2" RowSpan="RowSpan.Is1.OnMd.Is2" Class="rounded-lg border bg-muted/40 p-4 shadow-sm">
                    Feature
                </GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">One</GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Two</GridItem>
                <GridItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" BoxShadow="BoxShadow.Small">Three</GridItem>
            </Grid>
        </DemoSection>

        <DemoSection Title="Element Parameters"
                     Description="`Grid` still supports normal element parameters like `Class`, `Margin`, and `Id`."
                     Code="@(@"<Grid Id=""overview"" Columns=""@GridCols.Is2"" Gap=""Gap.Is3"" Margin=""Margin.Is4.FromBottom"" Class=""rounded-xl border p-4"">
    <Div Class=""rounded-lg bg-muted/40 p-4"">Left</Div>
    <Div Class=""rounded-lg bg-muted/40 p-4"">Right</Div>
</Grid>")"
CodeLanguage="razor">
            <Grid Id="overview" Columns="GridCols.Is2" Gap="Gap.Is3" Margin="Margin.Is4.FromBottom" Class="rounded-xl border p-4">
                <Div Class="rounded-lg bg-muted/40 p-4">
                    <Paragraph Margin="Margin.Is0">Left</Paragraph>
                </Div>
                <Div Class="rounded-lg bg-muted/40 p-4">
                    <Paragraph Margin="Margin.Is0">Right</Paragraph>
                </Div>
            </Grid>
        </DemoSection>
    </Div>
</Div>
