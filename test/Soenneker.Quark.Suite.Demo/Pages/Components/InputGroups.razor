@page "/input-groups"

<PageTitle>Input Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                Description="Add addons, buttons, and helper content to inputs."
                Code="@BasicCode"
                CodeLanguage="razor">
                <InputGroup Class="max-w-xs">
                    <InputGroupInput @bind-Value="_search" Placeholder="Search..." />
                    <InputGroupAddon>
                        <Icon Name="LucideIcon.Search" />
                    </InputGroupAddon>
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">12 results</InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="inline-start"
                Description="Use align=&quot;inline-start&quot; to position the addon at the start of the input."
                Code="@InlineStartCode"
                CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_search" Placeholder="Search..." />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                        <Icon Name="LucideIcon.Search" />
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="inline-end"
                Description="Use align=&quot;inline-end&quot; to position the addon at the end of the input."
                Code="@InlineEndCode"
                CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_password" Placeholder="Enter password" Type="InputType.Password" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <Icon Name="LucideIcon.EyeOff" />
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="block-start"
                Description="Use align=&quot;block-start&quot; to position the addon above the input."
                Code="@BlockStartCode"
                CodeLanguage="razor">
                <Div Class="grid w-full gap-2">
                    <InputGroup>
                        <InputGroupInput @bind-Value="_fullName" Placeholder="Enter your name" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockStart">
                            <InputGroupText>Full Name</InputGroupText>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupTextarea @bind-Value="_script" Rows="5" Placeholder="console.log('Hello, world!');" Class="font-mono text-sm" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockStart">
                            <Icon Name="LucideIcon.FileCode" />
                            <InputGroupText>script.js</InputGroupText>
                            <InputGroupButton Class="ml-auto">
                                <Icon Name="LucideIcon.Copy" />
                                Copy
                            </InputGroupButton>
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="block-end"
                Description="Use align=&quot;block-end&quot; to position the addon below the input."
                Code="@BlockEndCode"
                CodeLanguage="razor">
                <Div Class="grid w-full gap-2">
                    <InputGroup>
                        <InputGroupInput @bind-Value="_amount" Placeholder="Enter amount" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockEnd">
                            <InputGroupText>USD</InputGroupText>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupTextarea @bind-Value="_feedback" Rows="4" Placeholder="Write a comment..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockEnd">
                            <InputGroupText>0/280</InputGroupText>
                            <InputGroupButton Class="ml-auto">Post</InputGroupButton>
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icon"
                Description="Use icon addons at either inline edge."
                Code="@IconCode"
                CodeLanguage="razor">
                <Div Class="grid w-full max-w-sm gap-2">
                    <InputGroup>
                        <InputGroupInput @bind-Value="_iconSearch" Placeholder="Search..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <Icon Name="LucideIcon.Search" />
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_email" Placeholder="Enter your email" Type="InputType.Email" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <Icon Name="LucideIcon.Mail" />
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_card" Placeholder="Card number" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <Icon Name="LucideIcon.CreditCard" />
                        </InputGroupAddon>
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <Icon Name="LucideIcon.Check" />
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_cardAlt" Placeholder="Card number" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <Icon Name="LucideIcon.CreditCard" />
                        </InputGroupAddon>
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupButton Size="ButtonSize.IconXs" aria-label="Favorite">
                                <Icon Name="LucideIcon.Star" />
                            </InputGroupButton>
                            <InputGroupButton Size="ButtonSize.IconXs" aria-label="Info">
                                <Icon Name="LucideIcon.Info" />
                            </InputGroupButton>
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Text"
                Description="Text addons are useful for currency, domains, usernames, and counters."
                Code="@TextCode"
                CodeLanguage="razor">
                <Div Class="grid w-full max-w-sm gap-2">
                    <InputGroup>
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <InputGroupText>$</InputGroupText>
                        </InputGroupAddon>
                        <InputGroupInput @bind-Value="_price" Placeholder="0.00" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupText>USD</InputGroupText>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <InputGroupText>https://</InputGroupText>
                        </InputGroupAddon>
                        <InputGroupInput @bind-Value="_domain" Placeholder="example.com" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupText>.com</InputGroupText>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_username" Placeholder="Enter your username" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupText>@("@company.com")</InputGroupText>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_message" Placeholder="Enter your message" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupText>120 characters left</InputGroupText>
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button"
                Description="Buttons can be composed inside addon slots."
                Code="@ButtonCode"
                CodeLanguage="razor">
                <Div Class="grid w-full max-w-sm gap-2">
                    <InputGroup>
                        <InputGroupInput @bind-Value="_url" Placeholder="https://x.com/shadcn" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupButton>
                                <Icon Name="LucideIcon.Copy" />
                                Copy
                            </InputGroupButton>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <InputGroupText>https://</InputGroupText>
                        </InputGroupAddon>
                        <InputGroupInput @bind-Value="_shortUrl" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupButton Size="ButtonSize.IconXs" aria-label="Copy">
                                <Icon Name="LucideIcon.Copy" />
                            </InputGroupButton>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_query" Placeholder="Type to search..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupButton>Search</InputGroupButton>
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Kbd"
                Description="Kbd addons reinforce command shortcuts."
                Code="@KbdCode"
                CodeLanguage="razor">
                <InputGroup Class="max-w-sm">
                    <InputGroupInput @bind-Value="_command" Placeholder="Search..." />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                        <Icon Name="LucideIcon.Search" />
                    </InputGroupAddon>
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <KbdGroup>
                            <Kbd>⌘</Kbd>
                            <Kbd>K</Kbd>
                        </KbdGroup>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown"
                Description="Dropdown triggers can live inside input-group buttons."
                Code="@DropdownCode"
                CodeLanguage="razor">
                <Div Class="grid w-full max-w-sm gap-2">
                    <InputGroup>
                        <InputGroupInput @bind-Value="_fileName" Placeholder="Enter file name" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <Dropdown>
                                <DropdownToggle AsChild="true">
                                    <InputGroupButton Size="ButtonSize.IconXs" aria-label="More">
                                        <Icon Name="LucideIcon.Ellipsis" />
                                    </InputGroupButton>
                                </DropdownToggle>
                                <DropdownMenu>
                                    <DropdownItem>Rename</DropdownItem>
                                    <DropdownItem>Duplicate</DropdownItem>
                                    <DropdownItem>Delete</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_searchQuery" Placeholder="Enter search query" />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <Dropdown>
                                <DropdownToggle AsChild="true">
                                    <InputGroupButton>
                                        Search In...
                                        <Icon Name="LucideIcon.ChevronDown" />
                                    </InputGroupButton>
                                </DropdownToggle>
                                <DropdownMenu>
                                    <DropdownItem>Documentation</DropdownItem>
                                    <DropdownItem>Components</DropdownItem>
                                    <DropdownItem>Examples</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Spinner"
                Description="Spinner addons can communicate background work without stealing focus."
                Code="@SpinnerCode"
                CodeLanguage="razor">
                <Div Class="grid w-full max-w-sm gap-2">
                    <InputGroup>
                        <InputGroupInput @bind-Value="_spinnerSearch" Placeholder="Searching..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <Spinner BoxSize="Size.Is3" />
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_processing" Placeholder="Processing..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <Spinner BoxSize="Size.Is3" />
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_saving" Placeholder="Saving changes..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupText>Saving...</InputGroupText>
                            <Spinner BoxSize="Size.Is3" />
                        </InputGroupAddon>
                    </InputGroup>

                    <InputGroup>
                        <InputGroupInput @bind-Value="_refreshing" Placeholder="Refreshing data..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <InputGroupText>Please wait...</InputGroupText>
                            <Spinner BoxSize="Size.Is3" />
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Textarea"
                Description="Textarea input groups use block addons for editor-like controls."
                Code="@TextareaCode"
                CodeLanguage="razor">
                <InputGroup>
                    <InputGroupTextarea @bind-Value="_script" Rows="6" Placeholder="console.log('Hello, world!');" Class="font-mono text-sm" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockEnd">
                        <InputGroupText>Line 1, Column 1</InputGroupText>
                        <InputGroupButton Class="ml-auto">Run</InputGroupButton>
                        <InputGroupText>script.js</InputGroupText>
                        <InputGroupButton Size="ButtonSize.IconXs" aria-label="Copy">
                            <Icon Name="LucideIcon.Copy" />
                        </InputGroupButton>
                        <InputGroupButton Size="ButtonSize.IconXs" aria-label="More">
                            <Icon Name="LucideIcon.Ellipsis" />
                        </InputGroupButton>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Input"
                Description="Custom controls can participate in the same focus styling by using the input-group control slot."
                Code="@CustomCode"
                CodeLanguage="razor">
                <InputGroup>
                    <TextArea data-slot="input-group-control"
                              Placeholder="Autoresize textarea..."
                              Rows="4"
                              Width="Width.IsFull"
                              Border="Border.Is0"
                              BackgroundColor="BackgroundColor.Transparent"
                              Padding='Padding.Token("2.5").OnX.Is2.OnY'
                              TextSize="TextSize.Sm"
                              Class="resize-y min-h-24 flex-1 rounded-none shadow-none ring-0 focus-visible:ring-0 dark:bg-transparent" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockEnd">
                        <InputGroupButton Class="ml-auto">Submit</InputGroupButton>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                Description="Input group layouts also work correctly in right-to-left contexts."
                Code="@RtlCode"
                CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End" Class="grid gap-2">
                        <InputGroup>
                            <InputGroupInput @bind-Value="_rtlValue" Placeholder="بحث..." />
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                                <Icon Name="LucideIcon.Search" />
                            </InputGroupAddon>
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">١٢ نتيجة</InputGroupAddon>
                        </InputGroup>

                        <InputGroup>
                            <InputGroupInput @bind-Value="_rtlSaving" Placeholder="جاري حفظ التغييرات..." />
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                                <InputGroupText>جاري الحفظ...</InputGroupText>
                                <Spinner BoxSize="Size.Is3" />
                            </InputGroupAddon>
                        </InputGroup>

                        <InputGroup>
                            <InputGroupTextarea @bind-Value="_rtlTextarea" Rows="4" Placeholder="اكتب تعليقًا..." />
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockStart">
                                <InputGroupText>منطقة النص</InputGroupText>
                            </InputGroupAddon>
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockEnd">
                                <InputGroupText>٠/٢٨٠</InputGroupText>
                                <InputGroupButton Class="mr-auto">نشر</InputGroupButton>
                            </InputGroupAddon>
                        </InputGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

