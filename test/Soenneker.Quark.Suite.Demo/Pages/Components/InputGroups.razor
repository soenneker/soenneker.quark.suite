@page "/input-groups"

<PageTitle>Input Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Prefix text" Description="Inline start addons are useful for usernames, handles, and compact metadata."
                        Code="@(@"<InputGroup>
    <InputGroupAddon Align=""InputGroupAddonAlign.InlineStart"">@</InputGroupAddon>
    <InputGroupInput @bind-Value=""_username"" Placeholder=""username"" />
</InputGroup>")">
                <InputGroup>
                    <InputGroupAddon Align="InputGroupAddonAlign.InlineStart">
                        <InputGroupText>@("@")</InputGroupText>
                    </InputGroupAddon>
                    <InputGroupInput @bind-Value="_username" Placeholder="username" />
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Suffix text" Description="Inline end addons work well for units, domains, and other contextual suffixes."
                        Code="@(@"<InputGroup>
    <InputGroupInput @bind-Value=""_website"" Placeholder=""acme"" />
    <InputGroupAddon Align=""InputGroupAddonAlign.InlineEnd"">
        <InputGroupText>.com</InputGroupText>
    </InputGroupAddon>
</InputGroup>")">
                <InputGroup>
                    <InputGroupInput @bind-Value="_website" Placeholder="acme" />
                    <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                        <InputGroupText>.com</InputGroupText>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Inline action" Description="Trailing buttons make search and command-style inputs feel more complete."
                        Code="@(@"<InputGroup>
    <InputGroupInput @bind-Value=""_query"" Placeholder=""Search..."" />
    <InputGroupAddon Align=""InputGroupAddonAlign.InlineEnd"">
        <InputGroupButton Variant=""ButtonVariant.Ghost"" Size=""ButtonSize.IconSm"">Go</InputGroupButton>
    </InputGroupAddon>
</InputGroup>")">
                <InputGroup>
                    <InputGroupInput @bind-Value="_query" Placeholder="Search..." />
                    <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                        <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconSm">Go</InputGroupButton>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Keyboard hint" Description="Use text addons to reinforce keyboard shortcuts and command patterns."
                        Code="@(@"<InputGroup>
    <InputGroupInput @bind-Value=""_command"" Placeholder=""Run a command"" />
    <InputGroupAddon Align=""InputGroupAddonAlign.InlineEnd"">
        <InputGroupText>Ctrl K</InputGroupText>
    </InputGroupAddon>
</InputGroup>")">
                <InputGroup>
                    <InputGroupInput @bind-Value="_command" Placeholder="Run a command" />
                    <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                        <InputGroupText>Ctrl K</InputGroupText>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Textarea" Description="Switch to block-start addons when the main control becomes multi-line."
                        Code="@(@"<InputGroup>
    <InputGroupAddon Align=""InputGroupAddonAlign.BlockStart"">
        <InputGroupText>Message</InputGroupText>
    </InputGroupAddon>
    <InputGroupTextarea @bind-Value=""_message"" Rows=""4"" Placeholder=""Type your message..."" />
</InputGroup>")">
                <InputGroup>
                    <InputGroupAddon Align="InputGroupAddonAlign.BlockStart">
                        <InputGroupText>Message</InputGroupText>
                    </InputGroupAddon>
                    <InputGroupTextarea @bind-Value="_message" Rows="4" Placeholder="Type your message..." />
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Trailing status" Description="Inline trailing content can communicate background work without stealing focus."
                        Code="@(@"<InputGroup>
    <InputGroupInput @bind-Value=""_apiKey"" Placeholder=""Paste an API key"" />
    <InputGroupAddon Align=""InputGroupAddonAlign.InlineEnd"">
        <InputGroupText>Syncing</InputGroupText>
    </InputGroupAddon>
</InputGroup>")">
                <InputGroup>
                    <InputGroupInput @bind-Value="_apiKey" Placeholder="Paste an API key" />
                    <InputGroupAddon Align="InputGroupAddonAlign.InlineEnd">
                        <InputGroupText>Syncing</InputGroupText>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _username;
    private string? _website;
    private string? _query;
    private string? _command;
    private string? _message;
    private string? _apiKey;
}
