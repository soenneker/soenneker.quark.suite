@page "/input-groups"

<PageTitle>Input Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                        Description="A basic input group with an input and addon."
                        Code="@BasicCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_search" Placeholder="Search..." />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <Icon Name="LucideIcon.Search" />
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="inline-start"
                        Description="Place the addon visually at the start of the input."
                        Code="@InlineStartCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_username" Placeholder="username" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                        <InputGroupText>@("@")</InputGroupText>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="inline-end"
                        Description="Place the addon visually at the end of the input."
                        Code="@InlineEndCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_website" Placeholder="acme" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <Icon Name="LucideIcon.Globe" />
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="block-start"
                        Description="Use block-start for textarea-style controls with addons above."
                        Code="@BlockStartCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockStart">
                        <InputGroupText>Message</InputGroupText>
                    </InputGroupAddon>
                    <InputGroupTextarea @bind-Value="_message" Rows="4" Placeholder="Type your message..." />
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="block-end"
                        Description="Use block-end to place helper content below the control."
                        Code="@BlockEndCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupTextarea @bind-Value="_feedback" Rows="4" Placeholder="Share feedback..." />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockEnd">
                        <InputGroupText>Press Enter to submit</InputGroupText>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icon"
                        Description="Inline end addons also work well for compact iconography."
                        Code="@IconCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_website" Placeholder="acme" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <Icon Name="LucideIcon.Globe" />
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Text"
                        Description="Text addons are useful for usernames, handles, and compact metadata."
                        Code="@TextCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_username" Placeholder="username" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                        <InputGroupText>@("@")</InputGroupText>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button"
                        Description="Trailing buttons make search and command-style inputs feel more complete."
                        Code="@ButtonCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_query" Placeholder="Search..." />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <InputGroupButton Variant="ButtonVariant.Ghost" Size="ButtonSize.IconSm">Go</InputGroupButton>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Kbd"
                        Description="Use text addons to reinforce keyboard shortcuts and command patterns."
                        Code="@KbdCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_command" Placeholder="Run a command" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <InputGroupText>Ctrl K</InputGroupText>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown"
                        Description="Input groups can host more complex controls inside the addon slot."
                        Code="@DropdownCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_environment" Placeholder="Choose an environment" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <Dropdown>
                            <DropdownToggle Class="flex items-center gap-1 rounded-sm px-1.5 py-1 text-xs text-muted-foreground hover:bg-accent hover:text-foreground">
                                Env
                                <Icon Name="LucideIcon.ChevronDown" BoxSize="Size.Is3" />
                            </DropdownToggle>
                            <DropdownMenu>
                                <DropdownItem>Development</DropdownItem>
                                <DropdownItem>Staging</DropdownItem>
                                <DropdownItem>Production</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Spinner"
                        Description="Inline trailing content can communicate background work without stealing focus."
                        Code="@SpinnerCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupInput @bind-Value="_apiKey" Placeholder="Paste an API key" />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                        <Spinner BoxSize="Size.Is3" />
                    </InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Textarea"
                        Description="Switch to block-start addons when the main control becomes multi-line."
                        Code="@TextareaCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.BlockStart">
                        <InputGroupText>Message</InputGroupText>
                    </InputGroupAddon>
                    <InputGroupTextarea @bind-Value="_message" Rows="4" Placeholder="Type your message..." />
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Input"
                        Description="Custom controls can participate in the same focus styling by using the input-group control slot."
                        Code="@CustomCode"
                        CodeLanguage="razor">
                <InputGroup>
                    <textarea data-slot="input-group-control"
                              class="min-h-24 w-full resize-y rounded-md border-0 bg-transparent px-3 py-2 text-sm outline-none"
                              placeholder="Custom control"></textarea>
                </InputGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                        Description="Input group layouts also work correctly in right-to-left contexts."
                        Code="@RtlCode"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End">
                        <InputGroup>
                            <InputGroupInput @bind-Value="_rtlValue" Placeholder="ابحث..." />
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                                <Icon Name="LucideIcon.Search" />
                            </InputGroupAddon>
                        </InputGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Search..."" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
        <Icon Name=""LucideIcon.Search"" />
    </InputGroupAddon>
</InputGroup>";

    private const string InlineStartCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""username"" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineStart"">
        <InputGroupText>@</InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string InlineEndCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""acme"" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
        <Icon Name=""LucideIcon.Globe"" />
    </InputGroupAddon>
</InputGroup>";

    private const string BlockStartCode =
@"<InputGroup>
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.BlockStart"">
        <InputGroupText>Message</InputGroupText>
    </InputGroupAddon>
    <InputGroupTextarea Rows=""4"" Placeholder=""Type your message..."" />
</InputGroup>";

    private const string BlockEndCode =
@"<InputGroup>
    <InputGroupTextarea Rows=""4"" Placeholder=""Share feedback..."" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.BlockEnd"">
        <InputGroupText>Press Enter to submit</InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string IconCode = InlineEndCode;
    private const string TextCode = InlineStartCode;

    private const string ButtonCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Search..."" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
        <InputGroupButton Variant=""ButtonVariant.Ghost"" Size=""ButtonSize.IconSm"">Go</InputGroupButton>
    </InputGroupAddon>
</InputGroup>";

    private const string KbdCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Run a command"" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
        <InputGroupText>Ctrl K</InputGroupText>
    </InputGroupAddon>
</InputGroup>";

    private const string DropdownCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Choose an environment"" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
        <Dropdown>
            <DropdownToggle>Env</DropdownToggle>
        </Dropdown>
    </InputGroupAddon>
</InputGroup>";

    private const string SpinnerCode =
@"<InputGroup>
    <InputGroupInput Placeholder=""Paste an API key"" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
        <Spinner BoxSize=""Size.Is3"" />
    </InputGroupAddon>
</InputGroup>";

    private const string TextareaCode = BlockStartCode;

    private const string CustomCode =
@"<InputGroup>
    <textarea data-slot=""input-group-control"" placeholder=""Custom control""></textarea>
</InputGroup>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <InputGroup>
        <InputGroupInput Placeholder=""ابحث..."" />
        <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
            <Icon Name=""LucideIcon.Search"" />
        </InputGroupAddon>
    </InputGroup>
</DirectionProvider>";

    private string? _search;
    private string? _username;
    private string? _website;
    private string? _query;
    private string? _command;
    private string? _message;
    private string? _apiKey;
    private string? _feedback;
    private string? _environment;
    private string? _rtlValue;
}
