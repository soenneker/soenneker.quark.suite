@page "/separators"

<PageTitle>Separator - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="A simple horizontal separator for dividing adjacent blocks of content."
                         Code="@DemoCode">
                <Div Class="w-full max-w-md">
                    <Paragraph Margin="Margin.Is0" FontWeight="FontWeight.Medium">Radix primitives</Paragraph>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                        Visual or semantic dividers for content-heavy layouts.
                    </Paragraph>
                    <Separator Class="my-4" />
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Use separators when spacing alone no longer communicates grouping clearly enough.
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use vertical separators to split compact inline navigation and toolbar content."
                         Code="@VerticalCode">
                <Div Class="flex h-5 items-center space-x-4 text-sm">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Menu"
                         Description="Group related actions with separators to create clear menu sections."
                         Code="@MenuCode">
                <Div Class="w-64 rounded-lg border bg-card p-2 shadow-sm">
                    <Button Variant="ButtonVariant.Ghost" Width="Width.IsFull" AlignUtility="Align.JustifyStart">Profile</Button>
                    <Button Variant="ButtonVariant.Ghost" Width="Width.IsFull" AlignUtility="Align.JustifyStart">Billing</Button>
                    <Button Variant="ButtonVariant.Ghost" Width="Width.IsFull" AlignUtility="Align.JustifyStart">Settings</Button>
                    <Separator Class="my-2" />
                    <Button Variant="ButtonVariant.Ghost" Width="Width.IsFull" AlignUtility="Align.JustifyStart">Team</Button>
                    <Button Variant="ButtonVariant.Ghost" Width="Width.IsFull" AlignUtility="Align.JustifyStart">Invite users</Button>
                    <Separator Class="my-2" />
                    <Button Variant="ButtonVariant.Ghost" Class="w-full justify-start text-destructive hover:text-destructive">
                        Delete workspace
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="List"
                         Description="Horizontal separators help long lists scan more like grouped content instead of one continuous block."
                         Code="@ListCode">
                <Div Class="w-full max-w-md rounded-lg border bg-card">
                    <Div Class="px-4 py-3">
                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Margin="Margin.Is0">General</Paragraph>
                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                            Manage your public profile and preferences.
                        </Paragraph>
                    </Div>
                    <Separator />
                    <Div Class="px-4 py-3">
                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Margin="Margin.Is0">Notifications</Paragraph>
                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                            Choose when email and push notifications should be delivered.
                        </Paragraph>
                    </Div>
                    <Separator />
                    <Div Class="px-4 py-3">
                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Margin="Margin.Is0">Security</Paragraph>
                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                            Review sign-in activity and rotate recovery codes.
                        </Paragraph>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Separators remain useful in right-to-left layouts for both horizontal and vertical grouping."
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <Div class="w-full max-w-md text-right">
                        <Div Class="flex h-5 items-center justify-end space-x-reverse space-x-4 text-sm">
                            <Div>المدونة</Div>
                            <Separator Orientation="SeparatorOrientation.Vertical" />
                            <Div>التوثيق</Div>
                            <Separator Orientation="SeparatorOrientation.Vertical" />
                            <Div>المصدر</Div>
                        </Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

