@page "/separators"

<PageTitle>Separator - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Visually or semantically separates content."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div>
                    <Div Space="Space.Y.Is1">
                        <H4 TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Class="leading-none">shadcn/ui</H4>
                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                            The Foundation for your Design System
                        </Paragraph>
                    </Div>
                    <Separator Margin="Margin.Is4.OnY" />
                    <Paragraph TextSize="TextSize.Sm" Margin="Margin.Is0">
                        A set of beautifully designed components that you can customize, extend, and build on.
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Vertical separators between labeled sections."
                         Code="@MenuCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2" TextSize="TextSize.Sm" Class="md:gap-4">
                    <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is1">
                        <Span FontWeight="FontWeight.Medium">Settings</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Manage preferences</Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is1">
                        <Span FontWeight="FontWeight.Medium">Account</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Profile & security</Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" Class="hidden md:block" />
                    <Div Class="hidden flex-col gap-1 md:flex">
                        <Span FontWeight="FontWeight.Medium">Help</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Support & docs</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Menu"
                         Description="Horizontal separators between compact list GridRows."
                         Code="@ListCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" Flex=@("flex-col") Gap="Gap.Is2" TextSize="TextSize.Sm">
                    <dl class="m-0 flex items-center justify-between">
                        <dt Margin="Margin.Is0">Item 1</dt>
                        <dd class="m-0 text-muted-foreground">Value 1</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt Margin="Margin.Is0">Item 2</dt>
                        <dd class="m-0 text-muted-foreground">Value 2</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt Margin="Margin.Is0">Item 3</dt>
                        <dd class="m-0 text-muted-foreground">Value 3</dd>
                    </dl>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="List"
                         Description="Non-decorative separators stay in the accessibility tree with the expected orientation metadata."
                         Code="@SemanticCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is4" TextSize="TextSize.Sm">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is3">
                        <Span>Overview</Span>
                        <Separator Decorative="false" Orientation="SeparatorOrientation.Vertical" />
                        <Span>Details</Span>
                    </Div>
                    <Separator Decorative="false" />
                    <Div TextColor="TextColor.MutedForeground">Semantic separators can be announced by assistive technology when they convey structure.</Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="The same separator treatment in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" MaxWidth="MaxWidth.IsSm" Flex=@("flex-col") Gap="Gap.Is4" TextSize="TextSize.Sm">
                        <Div Display="Display.Flex" Flex=@("flex-col") Gap='Gap.Token("1.5")'>
                            <Div FontWeight="FontWeight.Medium" Leading="Leading.None">Component Library</Div>
                            <Div TextColor="TextColor.MutedForeground">الأساس لنظام التصميم الخاص بك</Div>
                        </Div>
                        <Separator />
                        <Div>مجموعة من المكونات المصممة بشكل جميل يمكنك تخصيصها وتوسيعها والبناء عليها.</Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Vertical separators for simple inline groups."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Height='Height.Token("5")' ItemsAlign="Items.Center" Gap="Gap.Is4" TextSize="TextSize.Sm">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

