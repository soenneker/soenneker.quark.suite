@page "/components/separator"

<PageTitle>Separator - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Visually or semantically separates content."
                         Code="@DemoCode"
                         CodeLanguage="razor"
                         PreviewClass="@SeparatorPreviewClass">
                <Div Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" Display="Display.Flex" Flex="@("flex-col")" Gap="Gap.Is4" TextSize="TextSize.Sm">
                    <Div Display="Display.Flex" Flex="@("flex-col")" Gap='Gap.Token("1.5")'>
                        <Div FontWeight="FontWeight.Medium" Leading="Leading.None">shadcn/ui</Div>
                        <Div TextColor="TextColor.MutedForeground">
                            The Foundation for your Design System
                        </Div>
                    </Div>
                    <Separator />
                    <Div>
                        A set of beautifully designed components that you can customize, extend, and build on.
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use orientation=&quot;vertical&quot; for a vertical separator."
                         Code="@VerticalCode"
                         CodeLanguage="razor"
                         PreviewClass="@SeparatorPreviewClass">
                <Div Width="Width.Auto" Display="Display.Flex" Height='Height.Token("5")' ItemsAlign="Items.Center" Gap="Gap.Is4" TextSize="TextSize.Sm" Class="w-fit">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Menu"
                         Description="Vertical separators between menu items with descriptions."
                         Code="@MenuCode"
                         CodeLanguage="razor"
                         PreviewClass="@SeparatorPreviewClass">
                <Div Width="Width.Auto" Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is4" TextSize="TextSize.Sm" Class="w-fit">
                    <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is1" Class="min-w-max">
                        <Span FontWeight="FontWeight.Medium">Settings</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Manage preferences</Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" Class="hidden sm:block" />
                    <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is1" Class="hidden min-w-max sm:flex">
                        <Span FontWeight="FontWeight.Medium">Account</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Profile &amp; security</Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is1" Class="min-w-max">
                        <Span FontWeight="FontWeight.Medium">Help</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Support &amp; docs</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="List"
                         Description="Horizontal separators between list items."
                         Code="@ListCode"
                         CodeLanguage="razor"
                         PreviewClass="@SeparatorPreviewClass">
                <Div Display="Display.Flex" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" Flex=@("flex-col") Gap="Gap.Is2" TextSize="TextSize.Sm">
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 1</dt>
                        <dd class="m-0 text-muted-foreground">Value 1</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 2</dt>
                        <dd class="m-0 text-muted-foreground">Value 2</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 3</dt>
                        <dd class="m-0 text-muted-foreground">Value 3</dd>
                    </dl>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         PreviewClass="@SeparatorPreviewClass">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is4" TextSize="TextSize.Sm" TextAlign="TextAlign.End">
                        <Div Display="Display.Flex" Flex=@("flex-col") Gap='Gap.Token("1.5")'>
                            <Div FontWeight="FontWeight.Medium" Leading="Leading.None">shadcn/ui</Div>
                            <Div TextColor="TextColor.MutedForeground">الأساس لنظام التصميم الخاص بك</Div>
                        </Div>
                        <Separator />
                        <Div>مجموعة من المكونات المصممة بشكل جميل يمكنك تخصيصها وتوسيعها والبناء عليها.</Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string SeparatorPreviewClass = "preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start";

    private const string DemoCode =
@"<Div Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsSm"" Display=""Display.Flex"" Flex=""@(""flex-col"")"" Gap=""Gap.Is4"" TextSize=""TextSize.Sm"">
    <Div Display=""Display.Flex"" Flex=""@(""flex-col"")"" Gap='Gap.Token(""1.5"")'>
        <Div FontWeight=""FontWeight.Medium"" Leading=""Leading.None"">shadcn/ui</Div>
        <Div TextColor=""TextColor.MutedForeground"">
            The Foundation for your Design System
        </Div>
    </Div>
    <Separator />
    <Div>
        A set of beautifully designed components that you can customize, extend, and build on.
    </Div>
</Div>";

    private const string MenuCode =
@"<Div Width=""Width.Auto"" Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is4"" TextSize=""TextSize.Sm"" Class=""w-fit"">
    <Div Display=""Display.Flex"" Flex=@(""flex-col"") Gap=""Gap.Is1"" Class=""min-w-max"">
        <Span FontWeight=""FontWeight.Medium"">Settings</Span>
        <Span TextSize=""TextSize.Xs"" TextColor=""TextColor.MutedForeground"">Manage preferences</Span>
    </Div>
    <Separator Orientation=""SeparatorOrientation.Vertical"" Class=""hidden sm:block"" />
    <Div Display=""Display.Flex"" Flex=@(""flex-col"") Gap=""Gap.Is1"" Class=""hidden min-w-max sm:flex"">
        <Span FontWeight=""FontWeight.Medium"">Account</Span>
        <Span TextSize=""TextSize.Xs"" TextColor=""TextColor.MutedForeground"">Profile &amp; security</Span>
    </Div>
    <Separator Orientation=""SeparatorOrientation.Vertical"" />
    <Div Display=""Display.Flex"" Flex=@(""flex-col"") Gap=""Gap.Is1"" Class=""min-w-max"">
        <Span FontWeight=""FontWeight.Medium"">Help</Span>
        <Span TextSize=""TextSize.Xs"" TextColor=""TextColor.MutedForeground"">Support &amp; docs</Span>
    </Div>
</Div>";

    private const string ListCode =
@"<Div Display=""Display.Flex"" Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsSm"" Flex=@(""flex-col"") Gap=""Gap.Is2"" TextSize=""TextSize.Sm"">
    <dl class=""m-0 flex items-center justify-between"">
        <dt class=""m-0"">Item 1</dt>
        <dd class=""m-0 text-muted-foreground"">Value 1</dd>
    </dl>
    <Separator />
    <dl class=""m-0 flex items-center justify-between"">
        <dt class=""m-0"">Item 2</dt>
        <dd class=""m-0 text-muted-foreground"">Value 2</dd>
    </dl>
    <Separator />
    <dl class=""m-0 flex items-center justify-between"">
        <dt class=""m-0"">Item 3</dt>
        <dd class=""m-0 text-muted-foreground"">Value 3</dd>
    </dl>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsSm"" Display=""Display.Flex"" Flex=@(""flex-col"") Gap=""Gap.Is4"" TextSize=""TextSize.Sm"" TextAlign=""TextAlign.End"">
        <Div Display=""Display.Flex"" Flex=@(""flex-col"") Gap='Gap.Token(""1.5"")'>
            <Div FontWeight=""FontWeight.Medium"" Leading=""Leading.None"">shadcn/ui</Div>
            <Div TextColor=""TextColor.MutedForeground"">الأساس لنظام التصميم الخاص بك</Div>
        </Div>
        <Separator />
        <Div>مجموعة من المكونات المصممة بشكل جميل يمكنك تخصيصها وتوسيعها والبناء عليها.</Div>
    </Div>
</DirectionProvider>";

    private const string VerticalCode =
@"<Div Width=""Width.Auto"" Display=""Display.Flex"" Height='Height.Token(""5"")' ItemsAlign=""Items.Center"" Gap=""Gap.Is4"" TextSize=""TextSize.Sm"" Class=""w-fit"">
    <Div>Blog</Div>
    <Separator Orientation=""SeparatorOrientation.Vertical"" />
    <Div>Docs</Div>
    <Separator Orientation=""SeparatorOrientation.Vertical"" />
    <Div>Source</Div>
</Div>";
}
