@page "/separators"

<PageTitle>Separator - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Horizontal rule between a heading block and body text."
                         Code="@DemoCode">
                <Div Class="flex max-w-sm flex-col gap-4 text-sm">
                    <Div Class="flex flex-col gap-1.5">
                        <Div Class="leading-none font-medium">shadcn/ui</Div>
                        <Div Class="text-muted-foreground">
                            The Foundation for your Design System
                        </Div>
                    </Div>
                    <Separator />
                    <Div>
                        A set of beautifully designed components that you can customize, extend,
                        and build on.
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Vertical separators for inline groups."
                         Code="@VerticalCode">
                <Div Class="flex h-5 items-center gap-4 text-sm">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Menu"
                         Description="Vertical separators between labeled sections."
                         Code="@MenuCode">
                <Div Class="flex items-center gap-2 text-sm md:gap-4">
                    <Div Class="flex flex-col gap-1">
                        <Span Class="font-medium">Settings</Span>
                        <Span Class="text-xs text-muted-foreground">
                            Manage preferences
                        </Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div Class="flex flex-col gap-1">
                        <Span Class="font-medium">Account</Span>
                        <Span Class="text-xs text-muted-foreground">
                            Profile & security
                        </Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" Class="hidden md:block" />
                    <Div Class="hidden flex-col gap-1 md:flex">
                        <Span Class="font-medium">Help</Span>
                        <Span Class="text-xs text-muted-foreground">Support & docs</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="List"
                         Description="Horizontal separators between compact list rows."
                         Code="@ListCode">
                <Div Class="flex w-full max-w-sm flex-col gap-2 text-sm">
                    <dl class="flex items-center justify-between m-0">
                        <dt class="m-0">Item 1</dt>
                        <dd class="m-0 text-muted-foreground">Value 1</dd>
                    </dl>
                    <Separator />
                    <dl class="flex items-center justify-between m-0">
                        <dt class="m-0">Item 2</dt>
                        <dd class="m-0 text-muted-foreground">Value 2</dd>
                    </dl>
                    <Separator />
                    <dl class="flex items-center justify-between m-0">
                        <dt class="m-0">Item 3</dt>
                        <dd class="m-0 text-muted-foreground">Value 3</dd>
                    </dl>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Same layout with right-to-left text direction."
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex max-w-sm flex-col gap-4 text-sm">
                        <Div Class="flex flex-col gap-1.5">
                            <Div Class="leading-none font-medium">shadcn/ui</Div>
                            <Div Class="text-muted-foreground">
                                الأساس لنظام التصميم الخاص بك
                            </Div>
                        </Div>
                        <Separator />
                        <Div>
                            مجموعة من المكونات المصممة بشكل جميل يمكنك تخصيصها وتوسيعها والبناء عليها.
                        </Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

