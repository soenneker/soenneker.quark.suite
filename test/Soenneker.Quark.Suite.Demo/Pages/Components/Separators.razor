@page "/separators"

<PageTitle>Separator - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical separator"
                         Description="Use vertical separators to split compact inline navigation and toolbar content."
                         Code="@VerticalCode">
                <Div Class="flex h-5 items-center space-x-4 text-sm">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="In a menu"
                         Description="Group related actions with separators to create clear menu sections."
                         Code="@MenuCode">
                <Div Class="w-64 rounded-lg border bg-card p-2 shadow-sm">
                    <Button Variant="ButtonVariant.Ghost" Class="w-full justify-start">Profile</Button>
                    <Button Variant="ButtonVariant.Ghost" Class="w-full justify-start">Billing</Button>
                    <Button Variant="ButtonVariant.Ghost" Class="w-full justify-start">Settings</Button>
                    <Separator Class="my-2" />
                    <Button Variant="ButtonVariant.Ghost" Class="w-full justify-start">Team</Button>
                    <Button Variant="ButtonVariant.Ghost" Class="w-full justify-start">Invite users</Button>
                    <Separator Class="my-2" />
                    <Button Variant="ButtonVariant.Ghost" Class="w-full justify-start text-destructive hover:text-destructive">
                        Delete workspace
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="In a list"
                         Description="Horizontal separators help long lists scan more like grouped content instead of one continuous block."
                         Code="@ListCode">
                <Div Class="w-full max-w-md rounded-lg border bg-card">
                    <Div Class="px-4 py-3">
                        <Paragraph Class="text-sm font-medium" Margin="Margin.Is0">General</Paragraph>
                        <Paragraph Class="text-sm text-muted-foreground" Margin="Margin.Is0">
                            Manage your public profile and preferences.
                        </Paragraph>
                    </Div>
                    <Separator />
                    <Div Class="px-4 py-3">
                        <Paragraph Class="text-sm font-medium" Margin="Margin.Is0">Notifications</Paragraph>
                        <Paragraph Class="text-sm text-muted-foreground" Margin="Margin.Is0">
                            Choose when email and push notifications should be delivered.
                        </Paragraph>
                    </Div>
                    <Separator />
                    <Div Class="px-4 py-3">
                        <Paragraph Class="text-sm font-medium" Margin="Margin.Is0">Security</Paragraph>
                        <Paragraph Class="text-sm text-muted-foreground" Margin="Margin.Is0">
                            Review sign-in activity and rotate recovery codes.
                        </Paragraph>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string VerticalCode =
@"<Div Class=""flex h-5 items-center space-x-4 text-sm"">
    <Div>Blog</Div>
    <Separator Orientation=""SeparatorOrientation.Vertical"" />
    <Div>Docs</Div>
    <Separator Orientation=""SeparatorOrientation.Vertical"" />
