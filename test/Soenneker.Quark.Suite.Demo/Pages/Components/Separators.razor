@page "/separators"

<PageTitle>Separator - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Visually or semantically separates content."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div>
                    <Div Space="Space.Y.Is1">
                        <H4 TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Class="leading-none">shadcn/ui</H4>
                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                            The Foundation for your Design System
                        </Paragraph>
                    </Div>
                    <Separator Margin="Margin.Is4.OnY" />
                    <Div TextSize="TextSize.Sm">
                        A set of beautifully designed components that you can customize, extend, and build on.
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use orientation=&quot;vertical&quot; for a vertical separator."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Height='Height.Token("5")' ItemsAlign="Items.Center" Gap="Gap.Is4" TextSize="TextSize.Sm">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Menu"
                         Description="Vertical separators between menu items with descriptions."
                         Code="@MenuCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is4" TextSize="TextSize.Sm">
                    <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is1">
                        <Span FontWeight="FontWeight.Medium">Settings</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Manage preferences</Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div Display="Display.Flex" Flex=@("flex-col") Gap="Gap.Is1">
                        <Span FontWeight="FontWeight.Medium">Account</Span>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Profile &amp; security</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="List"
                         Description="Horizontal separators between list items."
                         Code="@ListCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" Flex=@("flex-col") Gap="Gap.Is2" TextSize="TextSize.Sm">
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 1</dt>
                        <dd class="m-0 text-muted-foreground">Value 1</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 2</dt>
                        <dd class="m-0 text-muted-foreground">Value 2</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 3</dt>
                        <dd class="m-0 text-muted-foreground">Value 3</dd>
                    </dl>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <Div Space="Space.Y.Is8" Width="Width.IsFull">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Width="Width.IsFull">
                        <Select TValue="string" SelectedValue="@("ar")">
                            <SelectTrigger Class="w-44">
                                <SelectValue />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem TValue="string" ItemValue="@("ar")" Text="Arabic (العربية)" />
                                <SelectItem TValue="string" ItemValue="@("en")" Text="English" />
                            </SelectContent>
                        </Select>
                        <Icon Name="LucideIcon.Info" Class="size-4" TextColor="TextColor.MutedForeground" />
                    </Div>
                    <DirectionProvider Dir="rtl">
                        <Div Display="Display.Flex" MaxWidth="MaxWidth.IsSm" Flex=@("flex-col") Gap="Gap.Is4" TextSize="TextSize.Sm" TextAlign="TextAlign.End">
                            <Div Display="Display.Flex" Flex=@("flex-col") Gap='Gap.Token("1.5")'>
                                <Div FontWeight="FontWeight.Medium" Leading="Leading.None">shadcn/ui</Div>
                                <Div TextColor="TextColor.MutedForeground">الأساس لنظام التصميم الخاص بك</Div>
                            </Div>
                            <Separator />
                            <Div>مجموعة من المكونات المصممة بشكل جميل يمكنك تخصيصها وتوسيعها والبناء عليها.</Div>
                        </Div>
                    </DirectionProvider>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

