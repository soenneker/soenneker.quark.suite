@page "/surfaces/separators"

<PageTitle>Separators - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection Title="Separator demo"
                     Description="Latest shadcn v4 separator examples for horizontal and vertical orientations."
                     Code="@SeparatorCode">
            <Div>
                <Div Class="space-y-1">
                    <Paragraph Class="text-sm leading-none font-medium" Margin="Margin.Is0">Radix Primitives</Paragraph>
                    <Paragraph Class="text-sm text-muted-foreground" Margin="Margin.Is0">
                        An open-source UI component library.
                    </Paragraph>
                </Div>
                <Separator Class="my-4" />
                <Div Class="flex h-5 items-center space-x-4 text-sm">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private const string SeparatorCode =
@"<Div>
    <Div Class=""space-y-1"">
        <Paragraph Class=""text-sm leading-none font-medium"">Radix Primitives</Paragraph>
        <Paragraph Class=""text-sm text-muted-foreground"">An open-source UI component library.</Paragraph>
    </Div>
    <Separator Class=""my-4"" />
    <Div Class=""flex h-5 items-center space-x-4 text-sm"">
        <Div>Blog</Div>
        <Separator Orientation=""SeparatorOrientation.Vertical"" />
        <Div>Docs</Div>
        <Separator Orientation=""SeparatorOrientation.Vertical"" />
        <Div>Source</Div>
    </Div>
</Div>";
}
