@page "/separators"

<PageTitle>Separator - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="The shadcn separator layout with a horizontal rule above inline vertical dividers."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div>
                    <Div Class="space-y-1">
                        <H4 TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Class="leading-none">Radix Primitives</H4>
                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                            An open-source UI component library.
                        </Paragraph>
                    </Div>
                    <Separator Class="my-4" />
                    <Div Class="flex h-5 items-center space-x-4 text-sm">
                        <Div>Blog</Div>
                        <Separator Orientation="SeparatorOrientation.Vertical" />
                        <Div>Docs</Div>
                        <Separator Orientation="SeparatorOrientation.Vertical" />
                        <Div>Source</Div>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextColor="TextColor.MutedForeground">
                    Menu-like layouts, stacked content separators, and right-to-left text.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Menu"
                         Description="Vertical separators between labeled sections."
                         Code="@MenuCode"
                         CodeLanguage="razor">
                <Div Class="flex items-center gap-2 text-sm md:gap-4">
                    <Div Class="flex flex-col gap-1">
                        <Span Class="font-medium">Settings</Span>
                        <Span Class="text-xs text-muted-foreground">Manage preferences</Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div Class="flex flex-col gap-1">
                        <Span Class="font-medium">Account</Span>
                        <Span Class="text-xs text-muted-foreground">Profile & security</Span>
                    </Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" Class="hidden md:block" />
                    <Div Class="hidden flex-col gap-1 md:flex">
                        <Span Class="font-medium">Help</Span>
                        <Span Class="text-xs text-muted-foreground">Support & docs</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="List"
                         Description="Horizontal separators between compact list rows."
                         Code="@ListCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full max-w-sm flex-col gap-2 text-sm">
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 1</dt>
                        <dd class="m-0 text-muted-foreground">Value 1</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 2</dt>
                        <dd class="m-0 text-muted-foreground">Value 2</dd>
                    </dl>
                    <Separator />
                    <dl class="m-0 flex items-center justify-between">
                        <dt class="m-0">Item 3</dt>
                        <dd class="m-0 text-muted-foreground">Value 3</dd>
                    </dl>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="The same separator treatment in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex max-w-sm flex-col gap-4 text-sm">
                        <Div Class="flex flex-col gap-1.5">
                            <Div Class="font-medium leading-none">Component Library</Div>
                            <Div Class="text-muted-foreground">الأساس لنظام التصميم الخاص بك</Div>
                        </Div>
                        <Separator />
                        <Div>مجموعة من المكونات المصممة بشكل جميل يمكنك تخصيصها وتوسيعها والبناء عليها.</Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Vertical separators for simple inline groups."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Div Class="flex h-5 items-center gap-4 text-sm">
                    <Div>Blog</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Docs</Div>
                    <Separator Orientation="SeparatorOrientation.Vertical" />
                    <Div>Source</Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

