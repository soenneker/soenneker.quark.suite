@page "/components/text-shimmer"

<PageTitle>Text Shimmer - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <DemoSection Code="@DefaultCode" CodeLanguage="razor">
        <Div Class="flex min-h-24 items-center justify-center">
            <TextShimmer Class="text-sm text-muted-foreground">
                Thinking through your request...
            </TextShimmer>
        </Div>
    </DemoSection>

    <DemoSection Title="Repeat delay" Code="@RepeatDelayCode" CodeLanguage="razor">
        <Div Class="flex min-h-24 items-center justify-center">
            <TextShimmer Duration="1.2" RepeatDelay="0.8" Class="text-sm text-muted-foreground">
                Generating response...
            </TextShimmer>
        </Div>
    </DemoSection>

    <DemoSection Title="Angled" Code="@AngledCode" CodeLanguage="razor">
        <Div Class="flex min-h-24 items-center justify-center">
            <TextShimmer Angle="24" Spread="32" Duration="1.5" Class="text-sm font-medium text-muted-foreground">
                Re-ranking search results
            </TextShimmer>
        </Div>
    </DemoSection>

    <DemoSection Title="Inverted" Code="@InvertedCode" CodeLanguage="razor">
        <Div Class="flex min-h-24 items-center justify-center rounded-md bg-foreground">
            <TextShimmer Invert="true" Class="text-sm text-background">
                Processing tool output...
            </TextShimmer>
        </Div>
    </DemoSection>

    <DemoSection Title="As Custom Element" Code="@CustomElementCode" CodeLanguage="razor">
        <Div Class="flex min-h-24 items-center justify-center">
            <TextShimmer Tag="p" Class="m-0 text-sm text-muted-foreground">
                Compiling component registry
            </TextShimmer>
        </Div>
    </DemoSection>

    <DemoSection Title="Custom Highlight Color" Code="@CustomColorCode" CodeLanguage="razor">
        <Div Class="flex min-h-24 items-center justify-center">
            <TextShimmer Color="hsl(var(--primary))" Duration="1.4" Class="text-sm text-muted-foreground">
                Syncing vector index
            </TextShimmer>
        </Div>
    </DemoSection>

    <DemoSection Title="Slow Sweep" Code="@SlowSweepCode" CodeLanguage="razor">
        <Div Class="flex min-h-24 items-center justify-center">
            <TextShimmer Duration="2.5" Spread="18" Class="text-sm text-muted-foreground">
                Analyzing conversation context
            </TextShimmer>
        </Div>
    </DemoSection>
</Div>

@code {
    private const string DefaultCode =
@"<TextShimmer Class=""text-sm text-muted-foreground"">
    Thinking through your request...
</TextShimmer>";

    private const string RepeatDelayCode =
@"<TextShimmer Duration=""1.2"" RepeatDelay=""0.8"" Class=""text-sm text-muted-foreground"">
    Generating response...
</TextShimmer>";

    private const string AngledCode =
@"<TextShimmer Angle=""24"" Spread=""32"" Duration=""1.5"" Class=""text-sm font-medium text-muted-foreground"">
    Re-ranking search results
</TextShimmer>";

    private const string InvertedCode =
@"<TextShimmer Invert=""true"" Class=""text-sm text-background"">
    Processing tool output...
</TextShimmer>";

    private const string CustomElementCode =
@"<TextShimmer Tag=""p"" Class=""m-0 text-sm text-muted-foreground"">
    Compiling component registry
</TextShimmer>";

    private const string CustomColorCode =
@"<TextShimmer Color=""hsl(var(--primary))"" Duration=""1.4"" Class=""text-sm text-muted-foreground"">
    Syncing vector index
</TextShimmer>";

    private const string SlowSweepCode =
@"<TextShimmer Duration=""2.5"" Spread=""18"" Class=""text-sm text-muted-foreground"">
    Analyzing conversation context
</TextShimmer>";
}
