                            <Button Variant=""ButtonVariant.Ghost"" Size=""ButtonSize.Sm"" Class=""group w-full justify-start transition-none hover:bg-accent hover:text-accent-foreground"">
                                <Icon Name=""LucideIcon.ChevronRight"" Class=""transition-transform group-data-[state=open]:rotate-90"" />
                                <Icon Name=""LucideIcon.Folder"" />
                                components
                            </Button>
                        </CollapsibleTrigger>
                        <CollapsibleContent Class=""mt-1 ml-5"">
                            ...
                        </CollapsibleContent>
                    </Collapsible>
                </Div>
            </Tab>
            <Tab Name=""outline"" Title=""Outline"">
                <Div class=""mt-3 flex flex-col gap-2 rounded-md border p-3 text-sm"">
                    <Paragraph FontWeight=""FontWeight.Medium"" Margin=""Margin.Is0"">login-form.tsx</Paragraph>
                    <Paragraph TextColor=""TextColor.MutedForeground"" Margin=""Margin.Is0"">LoginForm</Paragraph>
                    <Paragraph TextColor=""TextColor.MutedForeground"" Margin=""Margin.Is0"">SocialButtons</Paragraph>
                    <Paragraph TextColor=""TextColor.MutedForeground"" Margin=""Margin.Is0"">PasswordField</Paragraph>
                </Div>
            </Tab>
        </Tabs>
    </CardHeader>
