@page "/collapsibles"

<PageTitle>Collapsible - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="An interactive component which expands/collapses a panel."
                         Code="@OrderCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full justify-center">
                    <Collapsible Open="_orderOpen" OpenChanged="OnOrderOpenChanged" Class="flex w-[350px] max-w-full flex-col gap-2">
                        <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Gap="Gap.Is4" Padding="Padding.Is4.OnX">
                            <div class="m-0 whitespace-nowrap text-sm font-semibold">Order #4189</div>
                            <CollapsibleTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Ghost"
                                        Size="ButtonSize.IconSm"
                                        Class="group"
                                        BoxSize="Size.Is8">
                                    <Icon Name="LucideIcon.ChevronsUpDown" Class="transition-transform duration-200 group-data-[state=open]:rotate-180" />
                                    <Span ScreenReader="ScreenReader.Only">Toggle details</Span>
                                </Button>
                            </CollapsibleTrigger>
                        </Div>
                        <Div Class="flex items-center justify-between rounded-md border px-4 py-2 text-sm">
                            <Span TextColor="TextColor.MutedForeground">Status</Span>
                            <Span FontWeight="FontWeight.Medium">Shipped</Span>
                        </Div>
                        <CollapsibleContent Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                            <Div Class="rounded-md border px-4 py-2 text-sm">
                                <Div Class="text-muted-foreground">Shipping address</Div>
                                <Div Class="font-medium">100 Market St, San Francisco</Div>
                            </Div>
                            <Div Class="rounded-md border px-4 py-2 text-sm">
                                <Div Class="text-muted-foreground">Items</Div>
                                <Div Class="font-medium">2x Studio Headphones</Div>
                            </Div>
                        </CollapsibleContent>
                    </Collapsible>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <CardBody>
                        <Collapsible Open="_basicOpen" OpenChanged="OnBasicOpenChanged" Class="rounded-md data-[state=open]:bg-muted">
                        <CollapsibleTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Ghost"
                                    Width="Width.IsFull"
                                    Justify="Justify.Start"
                                    Class="group">
                                Product details
                                <Icon Name="LucideIcon.ChevronDown" Class="ml-auto transition-transform group-data-[state=open]:rotate-180" />
                            </Button>
                        </CollapsibleTrigger>
                            <CollapsibleContent Display="Display.Flex" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Start" Gap="Gap.Is2" Padding='Padding.Token("2.5").OnAll.Is0.FromTop' TextSize="TextSize.Sm">
                                <Div>
                                    This panel can be expanded or collapsed to reveal additional content.
                                </Div>
                                <Button Size="ButtonSize.Xs">Learn More</Button>
                            </CollapsibleContent>
                        </Collapsible>
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Settings Panel"
                         Description="Use a trigger button to reveal additional settings."
                         Code="@SettingsCode"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <CardHeader>
                        <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is0">Radius</Paragraph>
                        <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Margin="Margin.Is0">
                            Set the corner radius of the element.
                        </Paragraph>
                    </CardHeader>
                    <CardBody>
                        <Collapsible Open="_settingsOpen"
                                     OpenChanged="OnSettingsOpenChanged"
                                     Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <FieldGroup Class="grid w-full grid-cols-2 gap-2">
                                <Field>
                                    <FieldLabel For="radius-top-left" ScreenReader="ScreenReader.Only">Radius X</FieldLabel>
                                    <Input Id="radius-top-left" Placeholder="0" Value="4" />
                                </Field>
                                <Field>
                                    <FieldLabel For="radius-top-right" ScreenReader="ScreenReader.Only">Radius Y</FieldLabel>
                                    <Input Id="radius-top-right" Placeholder="0" Value="4" />
                                </Field>
                                <CollapsibleContent Class="col-span-full grid grid-cols-subgrid gap-2">
                                    <Field>
                                        <FieldLabel For="radius-bottom-left" ScreenReader="ScreenReader.Only">Radius bottom left</FieldLabel>
                                        <Input Id="radius-bottom-left" Placeholder="0" Value="4" />
                                    </Field>
                                    <Field>
                                        <FieldLabel For="radius-bottom-right" ScreenReader="ScreenReader.Only">Radius bottom right</FieldLabel>
                                        <Input Id="radius-bottom-right" Placeholder="0" Value="4" />
                                    </Field>
                                </CollapsibleContent>
                            </FieldGroup>
                            <CollapsibleTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon">
                                    @if (_settingsOpen)
                                    {
                                        <Icon Name="LucideIcon.Minus" />
                                    }
                                    else
                                    {
                                        <Icon Name="LucideIcon.Plus" />
                                    }
                                </Button>
                            </CollapsibleTrigger>
                        </Collapsible>
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="File Tree"
                         Description="Use nested collapsibles to build a file tree."
                         Code="@FileTreeCode"
                         CodeLanguage="razor">
                <Card Class="mx-auto w-full max-w-[16rem] gap-2">
                    <CardHeader>
                        <Tabs SelectedTab="@_fileTreeTab"
                              OnSelectedTabChanged="OnFileTreeTabChanged"
                              Justified="true"
                              Width="Width.IsFull">
                            <Tab Name="explorer" Title="Explorer">
                                <Div Margin="Margin.Is3.FromTop" Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                    <Collapsible Open="_componentsOpen" OpenChanged="OnComponentsOpenChanged">
                                        <CollapsibleTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost"
                                                    Size="ButtonSize.Sm"
                                                    Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                <Icon Name="LucideIcon.Folder" />
                                                components
                                            </Button>
                                        </CollapsibleTrigger>
                                        <CollapsibleContent Class="mt-1 ml-5">
                                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                <Collapsible Open="_uiOpen" OpenChanged="OnUiOpenChanged">
                                                    <CollapsibleTrigger AsChild="true">
                                                        <Button Variant="ButtonVariant.Ghost"
                                                                Size="ButtonSize.Sm"
                                                                Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                            <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                            <Icon Name="LucideIcon.Folder" />
                                                            ui
                                                        </Button>
                                                    </CollapsibleTrigger>
                                                    <CollapsibleContent Class="mt-1 ml-5">
                                                        <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                            <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                                <Icon Name="LucideIcon.File" />
                                                                button.tsx
                                                            </Button>
                                                            <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                                <Icon Name="LucideIcon.File" />
                                                                card.tsx
                                                            </Button>
                                                            <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                                <Icon Name="LucideIcon.File" />
                                                                dialog.tsx
                                                            </Button>
                                                        </Div>
                                                    </CollapsibleContent>
                                                </Collapsible>
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    login-form.tsx
                                                </Button>
                                            </Div>
                                        </CollapsibleContent>
                                    </Collapsible>
                                    <Collapsible Open="_libOpen" OpenChanged="OnLibOpenChanged">
                                        <CollapsibleTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost"
                                                    Size="ButtonSize.Sm"
                                                    Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                <Icon Name="LucideIcon.Folder" />
                                                lib
                                            </Button>
                                        </CollapsibleTrigger>
                                        <CollapsibleContent Class="mt-1 ml-5">
                                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    utils.ts
                                                </Button>
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    api.ts
                                                </Button>
                                            </Div>
                                        </CollapsibleContent>
                                    </Collapsible>
                                    <Collapsible Open="_hooksOpen" OpenChanged="OnHooksOpenChanged">
                                        <CollapsibleTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost"
                                                    Size="ButtonSize.Sm"
                                                    Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                <Icon Name="LucideIcon.Folder" />
                                                hooks
                                            </Button>
                                        </CollapsibleTrigger>
                                        <CollapsibleContent Class="mt-1 ml-5">
                                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    use-mobile.ts
                                                </Button>
                                            </Div>
                                        </CollapsibleContent>
                                    </Collapsible>
                                    <Collapsible Open="_typesOpen" OpenChanged="OnTypesOpenChanged">
                                        <CollapsibleTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost"
                                                    Size="ButtonSize.Sm"
                                                    Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                <Icon Name="LucideIcon.Folder" />
                                                types
                                            </Button>
                                        </CollapsibleTrigger>
                                        <CollapsibleContent Class="mt-1 ml-5">
                                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    index.ts
                                                </Button>
                                            </Div>
                                        </CollapsibleContent>
                                    </Collapsible>
                                    <Collapsible Open="_publicOpen" OpenChanged="OnPublicOpenChanged">
                                        <CollapsibleTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost"
                                                    Size="ButtonSize.Sm"
                                                    Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                <Icon Name="LucideIcon.Folder" />
                                                public
                                            </Button>
                                        </CollapsibleTrigger>
                                        <CollapsibleContent Class="mt-1 ml-5">
                                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    favicon.ico
                                                </Button>
                                            </Div>
                                        </CollapsibleContent>
                                    </Collapsible>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        app.tsx
                                    </Button>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        layout.tsx
                                    </Button>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        globals.css
                                    </Button>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        package.json
                                    </Button>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        tsconfig.json
                                    </Button>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        README.md
                                    </Button>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        .gitignore
                                    </Button>
                                </Div>
                            </Tab>
                            <Tab Name="outline" Title="Outline">
                                <Div Margin="Margin.Is3.FromTop" Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is2" Rounded="Rounded.Md" Border="Border.Is1" Padding="Padding.Is3" TextSize="TextSize.Sm">
                                    <Paragraph FontWeight="FontWeight.Medium" Margin="Margin.Is0">login-form.tsx</Paragraph>
                                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">LoginForm</Paragraph>
                                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">SocialButtons</Paragraph>
                                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">PasswordField</Paragraph>
                                </Div>
                            </Tab>
                        </Tabs>
                    </CardHeader>
                    <CardBody />
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" Justify="Justify.Center">
                        <Collapsible Open="_rtlOpen" OpenChanged="OnRtlOpenChanged" Width="Width.IsFull" MaxWidth='MaxWidth.Token("[350px]")' Space="Space.Y.Is2" TextAlign="TextAlign.End">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Space="Space.X.Is4" Padding="Padding.Is4.OnX">
                                <Div TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">الطلب #4189</Div>
                                <CollapsibleTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Ghost"
                                            Size="ButtonSize.IconSm"
                                            Class="group"
                                            BoxSize="Size.Is8">
                                        <Icon Name="LucideIcon.ChevronsUpDown" Class="transition-transform duration-200 group-data-[state=open]:rotate-180" />
                                        <Span ScreenReader="ScreenReader.Only">Toggle details</Span>
                                    </Button>
                                </CollapsibleTrigger>
                            </Div>
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Rounded="Rounded.Md" Border="Border.Is1" Padding="Padding.Is4.OnX.Is2.OnY" TextSize="TextSize.Sm">
                                <Span TextColor="TextColor.MutedForeground">الحالة</Span>
                                <Span FontWeight="FontWeight.Medium">تم الشحن</Span>
                            </Div>
                            <CollapsibleContent Space="Space.Y.Is2">
                                <Div Class="rounded-md border px-4 py-2 text-sm">
                                    <Div FontWeight="FontWeight.Medium">عنوان الشحن</Div>
                                    <Div TextColor="TextColor.MutedForeground">100 Market St, San Francisco</Div>
                                </Div>
                            </CollapsibleContent>
                        </Collapsible>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

    </Div>
</Div>

@code {
    private bool _orderOpen;
    private bool _basicOpen;
    private bool _settingsOpen;
    private bool _rtlOpen;
    private string _fileTreeTab = "explorer";
    private bool _componentsOpen;
    private bool _uiOpen;
    private bool _libOpen;
    private bool _hooksOpen;
    private bool _typesOpen;
    private bool _publicOpen;

    private const string OrderCode =
@"<Div Class=""flex w-full justify-center"">
    <Collapsible Open=""_orderOpen"" OpenChanged=""OnOrderOpenChanged"" Class=""flex w-[350px] max-w-full flex-col gap-2"">
        <Div class=""flex items-center justify-between gap-4 px-4"">
            <H4 class=""m-0 whitespace-nowrap text-sm font-semibold"">Order #4189</H4>
            <CollapsibleTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Ghost"" Size=""ButtonSize.IconSm"" Class=""group size-8"">
                    <Icon Name=""LucideIcon.ChevronsUpDown"" Class=""transition-transform duration-200 group-data-[state=open]:rotate-180"" />
                    <Span class=""sr-only"">Toggle details</Span>
                </Button>
            </CollapsibleTrigger>
        </Div>
        <Div class=""flex items-center justify-between rounded-md border px-4 py-2 text-sm"">
