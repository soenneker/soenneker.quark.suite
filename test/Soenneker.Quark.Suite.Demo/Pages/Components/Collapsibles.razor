    private Task OnOrderOpenChanged(bool value)
    {
        _orderOpen = value;
        return Task.CompletedTask;
    }

    private Task OnBasicOpenChanged(bool value)
    {
        _basicOpen = value;
        return Task.CompletedTask;
    }

    private Task OnSettingsOpenChanged(bool value)
    {
        _settingsOpen = value;
        return Task.CompletedTask;
    }

    private Task OnRtlOpenChanged(bool value)
    {
        _rtlOpen = value;
        return Task.CompletedTask;
    }

    private Task OnComponentsOpenChanged(bool value)
    {
        _componentsOpen = value;
        return Task.CompletedTask;
    }

    private Task OnUiOpenChanged(bool value)
    {
        _uiOpen = value;
        return Task.CompletedTask;
    }

    private Task OnLibOpenChanged(bool value)
    {
        _libOpen = value;
        return Task.CompletedTask;
    }

    private Task OnFileTreeTabChanged(string value)
    {
        _fileTreeTab = value;
        return Task.CompletedTask;
    }
}
