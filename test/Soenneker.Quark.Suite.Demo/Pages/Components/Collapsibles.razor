@page "/collapsibles"

<PageTitle>Collapsible - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Order summary with status row and expandable shipping and line items."
                         Code="@OrderCode"
                         CodeLanguage="razor">
                <Collapsible Open="_orderOpen" OpenChanged="OnOrderOpenChanged" Class="flex w-[350px] flex-col gap-2">
                    <Div class="flex items-center justify-between gap-4 px-4">
                        <Div TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Order #4189</Div>
                        <CollapsibleTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Ghost"
                                    Size="ButtonSize.IconSm"
                                    Class="group size-8">
                                <Icon Name="LucideIcon.ChevronsUpDown" Class="transition-transform duration-200 group-data-[state=open]:rotate-180" />
                                <Span class="sr-only">Toggle details</Span>
                            </Button>
                        </CollapsibleTrigger>
                    </Div>
                    <Div class="flex items-center justify-between rounded-md border px-4 py-2 text-sm">
                        <Span TextColor="TextColor.MutedForeground">Status</Span>
                        <Span FontWeight="FontWeight.Medium">Shipped</Span>
                    </Div>
                    <CollapsibleContent Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                        <Div Rounded="Rounded.Md" Border="Border.Is1" Padding='Padding.Is4.OnX.Is2.OnY' TextSize="TextSize.Sm">
                            <Paragraph FontWeight="FontWeight.Medium" Margin="Margin.Is0">Shipping address</Paragraph>
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">100 Market St, San Francisco</Paragraph>
                        </Div>
                        <Div Rounded="Rounded.Md" Border="Border.Is1" Padding='Padding.Is4.OnX.Is2.OnY' TextSize="TextSize.Sm">
                            <Paragraph FontWeight="FontWeight.Medium" Margin="Margin.Is0">Items</Paragraph>
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">2x Studio Headphones</Paragraph>
                        </Div>
                    </CollapsibleContent>
                </Collapsible>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="Product details inside a compact card."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <CardBody>
                        <Collapsible Open="_basicOpen" OpenChanged="OnBasicOpenChanged" Class="rounded-md data-[state=open]:bg-muted">
                        <CollapsibleTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Ghost"
                                    Width="Width.IsFull"
                                    Justify="Justify.Start"
                                    Class="group">
                                Product details
                                <Icon Name="LucideIcon.ChevronDown" Class="ml-auto transition-transform group-data-[state=open]:rotate-180" />
                            </Button>
                        </CollapsibleTrigger>
                            <CollapsibleContent Class="flex flex-col items-start gap-2 p-2.5 pt-0 text-sm">
                                <Div>
                                    This panel can be expanded or collapsed to reveal additional content.
                                </Div>
                                <Button Size="ButtonSize.Xs">Learn More</Button>
                            </CollapsibleContent>
                        </Collapsible>
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Settings Panel"
                         Description="Expandable fields for corner radius, with a compact toggle trigger."
                         Code="@SettingsCode"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <CardHeader>
                        <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is0">Radius</Paragraph>
                        <Paragraph TextColor="TextColor.MutedForeground" TextSize="TextSize.Sm" Margin="Margin.Is0">
                            Set the corner radius of the element.
                        </Paragraph>
                    </CardHeader>
                    <CardBody>
                        <Collapsible Open="_settingsOpen"
                                     OpenChanged="OnSettingsOpenChanged"
                                     Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <FieldGroup Class="grid w-full grid-cols-2 gap-2">
                                <Field>
                                    <FieldLabel For="radius-top-left" ScreenReader="ScreenReader.Only">Radius top left</FieldLabel>
                                    <Input Id="radius-top-left" Placeholder="0" Value="4" />
                                </Field>
                                <Field>
                                    <FieldLabel For="radius-top-right" ScreenReader="ScreenReader.Only">Radius top right</FieldLabel>
                                    <Input Id="radius-top-right" Placeholder="0" Value="4" />
                                </Field>
                                <CollapsibleContent Class="col-span-full grid grid-cols-subgrid gap-2">
                                    <Field>
                                        <FieldLabel For="radius-bottom-left" ScreenReader="ScreenReader.Only">Radius bottom left</FieldLabel>
                                        <Input Id="radius-bottom-left" Placeholder="0" Value="4" />
                                    </Field>
                                    <Field>
                                        <FieldLabel For="radius-bottom-right" ScreenReader="ScreenReader.Only">Radius bottom right</FieldLabel>
                                        <Input Id="radius-bottom-right" Placeholder="0" Value="4" />
                                    </Field>
                                </CollapsibleContent>
                            </FieldGroup>
                            <CollapsibleTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon">
                                    @if (_settingsOpen)
                                    {
                                        <Icon Name="LucideIcon.Minus" />
                                    }
                                    else
                                    {
                                        <Icon Name="LucideIcon.Plus" />
                                    }
                                </Button>
                            </CollapsibleTrigger>
                        </Collapsible>
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="File Tree"
                         Description="Nested folders and files using stacked collapsibles inside a small explorer card."
                         Code="@FileTreeCode"
                         CodeLanguage="razor">
                <Card Class="mx-auto w-full max-w-[16rem] gap-2">
                    <CardHeader>
                        <Tabs SelectedTab="@_fileTreeTab"
                              OnSelectedTabChanged="OnFileTreeTabChanged"
                              Justified="true"
                              Width="Width.IsFull">
                            <Tab Name="explorer" Title="Explorer">
                                <Div class="mt-3 flex flex-col gap-1">
                                    <Collapsible Open="_componentsOpen" OpenChanged="OnComponentsOpenChanged">
                                        <CollapsibleTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost"
                                                    Size="ButtonSize.Sm"
                                                    Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                <Icon Name="LucideIcon.Folder" />
                                                components
                                            </Button>
                                        </CollapsibleTrigger>
                                        <CollapsibleContent Class="mt-1 ml-5">
                                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                <Collapsible Open="_uiOpen" OpenChanged="OnUiOpenChanged">
                                                    <CollapsibleTrigger AsChild="true">
                                                        <Button Variant="ButtonVariant.Ghost"
                                                                Size="ButtonSize.Sm"
                                                                Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                            <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                            <Icon Name="LucideIcon.Folder" />
                                                            ui
                                                        </Button>
                                                    </CollapsibleTrigger>
                                                    <CollapsibleContent Class="mt-1 ml-5">
                                                        <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                            <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                                <Icon Name="LucideIcon.File" />
                                                                button.tsx
                                                            </Button>
                                                            <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                                <Icon Name="LucideIcon.File" />
                                                                card.tsx
                                                            </Button>
                                                            <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                                <Icon Name="LucideIcon.File" />
                                                                dialog.tsx
                                                            </Button>
                                                        </Div>
                                                    </CollapsibleContent>
                                                </Collapsible>
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    login-form.tsx
                                                </Button>
                                            </Div>
                                        </CollapsibleContent>
                                    </Collapsible>
                                    <Collapsible Open="_libOpen" OpenChanged="OnLibOpenChanged">
                                        <CollapsibleTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost"
                                                    Size="ButtonSize.Sm"
                                                    Width="Width.IsFull" Justify="Justify.Start" Class="group transition-none hover:bg-accent hover:text-accent-foreground">
                                                <Icon Name="LucideIcon.ChevronRight" Class="transition-transform group-data-[state=open]:rotate-90" />
                                                <Icon Name="LucideIcon.Folder" />
                                                lib
                                            </Button>
                                        </CollapsibleTrigger>
                                        <CollapsibleContent Class="mt-1 ml-5">
                                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is1">
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    utils.ts
                                                </Button>
                                                <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                                    <Icon Name="LucideIcon.File" />
                                                    api.ts
                                                </Button>
                                            </Div>
                                        </CollapsibleContent>
                                    </Collapsible>
                                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" Width="Width.IsFull" Justify="Justify.Start" Gap="Gap.Is2" TextColor="TextColor.Foreground">
                                        <Icon Name="LucideIcon.File" />
                                        package.json
                                    </Button>
                                </Div>
                            </Tab>
                            <Tab Name="outline" Title="Outline">
                                <Div class="mt-3 flex flex-col gap-2 rounded-md border p-3 text-sm">
                                    <Paragraph FontWeight="FontWeight.Medium" Margin="Margin.Is0">login-form.tsx</Paragraph>
                                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">LoginForm</Paragraph>
                                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">SocialButtons</Paragraph>
                                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">PasswordField</Paragraph>
                                </Div>
                            </Tab>
                        </Tabs>
                    </CardHeader>
                    <CardBody />
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Order-style layout with inherited RTL direction."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" Justify="Justify.Center">
                        <Collapsible Open="_rtlOpen" OpenChanged="OnRtlOpenChanged" Class="flex w-[350px] flex-col gap-2 text-right">
                            <Div class="flex items-center justify-between gap-4 px-4">
                                <Div TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">الطلب #4189</Div>
                                <CollapsibleTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Ghost"
                                            Size="ButtonSize.IconSm"
                                            Class="group size-8">
                                        <Icon Name="LucideIcon.ChevronsUpDown" Class="transition-transform duration-200 group-data-[state=open]:rotate-180" />
                                        <Span class="sr-only">تبديل التفاصيل</Span>
                                    </Button>
                                </CollapsibleTrigger>
                            </Div>
                            <Div class="flex items-center justify-between rounded-md border px-4 py-2 text-sm">
                                <Span TextColor="TextColor.MutedForeground">الحالة</Span>
                                <Span FontWeight="FontWeight.Medium">تم الشحن</Span>
                            </Div>
                            <CollapsibleContent Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                                <Div Rounded="Rounded.Md" Border="Border.Is1" Padding='Padding.Is4.OnX.Is2.OnY' TextSize="TextSize.Sm">
                                    <Paragraph FontWeight="FontWeight.Medium" Margin="Margin.Is0">عنوان الشحن</Paragraph>
                                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">100 Market St, San Francisco</Paragraph>
                                </Div>
                            </CollapsibleContent>
                        </Collapsible>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

    </Div>
</Div>

@code {
    private bool _orderOpen;
    private bool _basicOpen;
    private bool _settingsOpen;
    private bool _rtlOpen;
    private string _fileTreeTab = "explorer";
    private bool _componentsOpen;
    private bool _uiOpen;
    private bool _libOpen;

    private const string OrderCode =
@"<Collapsible Open=""_orderOpen"" OpenChanged=""OnOrderOpenChanged"" Class=""flex w-[350px] flex-col gap-2"">
    <Div class=""flex items-center justify-between gap-4 px-4"">
        <Div class=""text-sm font-semibold"">Order #4189</Div>
        <CollapsibleTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Ghost"" Size=""ButtonSize.IconSm"" Class=""group size-8"">
