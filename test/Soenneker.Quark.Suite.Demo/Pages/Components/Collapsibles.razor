    private Task OnOrderOpenChanged(bool value)
    {
        _orderOpen = value;
        return Task.CompletedTask;
    }

    private Task OnBasicOpenChanged(bool value)
    {
        _basicOpen = value;
        return Task.CompletedTask;
    }

    private Task OnSettingsOpenChanged(bool value)
    {
        _settingsOpen = value;
        return Task.CompletedTask;
    }

    private Task OnRtlOpenChanged(bool value)
