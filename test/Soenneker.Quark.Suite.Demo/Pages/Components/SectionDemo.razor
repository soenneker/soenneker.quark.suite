@page "/section-demo"

<PageTitle>Section - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Basic Sections" Code="@_basicSectionsCode">
            <Div Space="Space.Y.Is4">
                <Section>
                    <Paragraph FontWeight="FontWeight.Semibold">Section 1</Paragraph>
                    <Paragraph>Creates HTML &lt;section&gt; for semantic content organization.</Paragraph>
                </Section>
                <Section>
                    <Paragraph FontWeight="FontWeight.Semibold">Section 2</Paragraph>
                    <Paragraph>Helps organize content into logical groups.</Paragraph>
                </Section>
            </Div>
        </DemoSection>

        <DemoSection Title="Light Background" Code="@(@"<Section BackgroundColor=""BackgroundColor.Muted"" Padding=""Padding.Is3"">...")">
            <Section BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is3" Rounded="Rounded.Lg">
                <Paragraph TextColor="TextColor.Primary" FontWeight="FontWeight.Semibold">Light Background</Paragraph>
                <Paragraph>Section with light background and padding.</Paragraph>
            </Section>
        </DemoSection>

        <DemoSection Title="Primary Background" Code="@(@"<Section BackgroundColor=""BackgroundColor.Primary"" TextColor=""TextColor.White"">...")">
            <Section BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is3" Rounded="Rounded.Lg">
                <Paragraph FontWeight="FontWeight.Semibold">Primary Background</Paragraph>
                <Paragraph>Section with primary background and white text.</Paragraph>
            </Section>
        </DemoSection>

        <DemoSection Title="Bordered Section" Code="@(@"<Section Class=""border border-success"">...")">
            <Section Class="rounded-lg border border-success p-4">
                <Paragraph TextColor="TextColor.Accent" FontWeight="FontWeight.Semibold">Bordered Section</Paragraph>
                <Paragraph>Section with success-colored border using Tailwind.</Paragraph>
            </Section>
        </DemoSection>

        <DemoSection Title="Interactive Section" Code="@(@"<Section>...<Button @onclick=""HandleClick"">Click Me!</Button></Section>")">
            <Section BackgroundColor="BackgroundColor.Muted" TextColor="TextColor.Foreground" Padding="Padding.Is3" Rounded="Rounded.Lg">
                <Paragraph FontWeight="FontWeight.Semibold">Interactive Content</Paragraph>
                <Paragraph>Section with interactive elements.</Paragraph>
                <Div Class="mt-2 flex items-center gap-2">
                    <Button BackgroundColor="BackgroundColor.Primary" @onclick="HandleSectionClick">Click Me!</Button>
                    <Text>Click count: @_clickCount</Text>
                </Div>
            </Section>
        </DemoSection>

        <DemoSection Title="Custom Styling" Code="@(@"<Section Class=""bg-gradient-to-br from-violet-500 to-purple-700"">...")">
            <Section Class="rounded-xl bg-gradient-to-br from-violet-500 to-purple-700 p-5 text-white shadow-lg">
                <Paragraph FontWeight="FontWeight.Semibold">Gradient Section</Paragraph>
                <Paragraph>Custom gradient with rounded corners and shadow via Tailwind.</Paragraph>
            </Section>
        </DemoSection>

        <DemoSection Title="Accessibility" Description="Use Role and AriaLabel for screen readers." Code="@(@"<Section Role=""region"" AriaLabel=""Important Information"">...")">
            <Section Role="region" AriaLabel="Important Information" Class="rounded-lg border p-4">
                <Paragraph FontWeight="FontWeight.Semibold">Accessible Section</Paragraph>
                <Paragraph>Proper ARIA attributes for accessibility.</Paragraph>
            </Section>
        </DemoSection>
    </Div>
</Div>

@code {
    private int _clickCount;

    private static readonly string _basicSectionsCode = @"<Section>
    <H3>Section 1</H3>
    <Paragraph>Content for section 1.</Paragraph>
</Section>
<Section BackgroundColor=""BackgroundColor.Muted"" Padding=""Padding.Is3"">
    <H3>Section 2</H3>
    <Paragraph>Content for section 2.</Paragraph>
</Section>";

    private void HandleSectionClick(MouseEventArgs args)
    {
        _clickCount++;
        StateHasChanged();
    }
}
