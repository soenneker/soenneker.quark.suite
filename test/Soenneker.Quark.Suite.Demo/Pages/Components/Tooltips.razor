@page "/tooltips"

<PageTitle>Tooltips - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <TooltipProvider DelayDuration="150">
        <Div Space="Space.Y.Is6">
            <Section Space="Space.Y.Is4">
                <DemoSection Title="Demo"
                             Description="Tooltips work well for terse helper text on icon buttons and compact controls."
                             Code="@BasicCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center" data-testid="quark-tooltip-basic-demo">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Hover</Button>
                            </TooltipTrigger>
                            <TooltipContent>
                                <Paragraph>Add to library</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextColor="TextColor.MutedForeground">
                    Side placement, shortcuts, disabled controls, and RTL behavior beyond the lead shadcn-equivalent demo.
                </Paragraph>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Side"
                             Description="Choose the side that best fits the surrounding layout."
                             Code="@SidesCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("40")' Flex="Flex.Wrap" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is5" data-testid="quark-tooltip-side-demo">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Top</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="top">
                                <Paragraph>Default placement</Paragraph>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Right</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="right">
                                <Paragraph>Helpful context on the right</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Left</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="left">
                                <Paragraph>Helpful context on the left</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="With Keyboard Shortcut"
                             Description="Pair tooltips with shortcuts so users discover faster paths without leaving the current screen."
                             Code="@ShortcutCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">
                                    Command palette
                                    <Span Margin="Margin.Is2.FromStart" Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is1">
                                        <KbdChip>Ctrl</KbdChip>
                                        <KbdChip>K</KbdChip>
                                    </Span>
                                </Button>
                            </TooltipTrigger>
                            <TooltipContent Side="bottom">
                                <Paragraph>Open the quick action palette</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Disabled Button"
                             Description="Wrap disabled controls in a neutral element so the tooltip can still explain why the action is unavailable."
                             Code="@DisabledCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Span Display="Display.InlineFlex">
                                    <Button Variant="ButtonVariant.Outline" Disabled="true">Invite user</Button>
                                </Span>
                            </TooltipTrigger>
                            <TooltipContent>
                                <Paragraph>Upgrade to the team plan to invite additional users.</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="RTL"
                             Description="Tooltip side placement also works in right-to-left layouts."
                             Code="@RtlCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center">
                        <DirectionProvider Dir="rtl">
                            <Tooltip>
                                <TooltipTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline">تحويم</Button>
                                </TooltipTrigger>
                                <TooltipContent Side="right">
                                    <Paragraph>إضافة إلى المكتبة</Paragraph>
                                </TooltipContent>
                            </Tooltip>
                        </DirectionProvider>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Tooltip In Dialog"
                             Description="A tooltip opened from within modal dialog content should still be exposed and positioned correctly."
                             Code="@DialogCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("40")' ItemsAlign="Items.Center" Justify="Justify.Center" data-testid="quark-tooltip-dialog-demo">
                        <Dialog>
                            <DialogTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Open tooltip dialog</Button>
                            </DialogTrigger>
                            <DialogContent MaxWidth="MaxWidth.IsMd">
                                <DialogHeader>
                                    <DialogTitle>Tooltip dialog</DialogTitle>
                                    <DialogDescription>
                                        Hover the nested trigger to reveal tooltip content inside the dialog.
                                    </DialogDescription>
                                </DialogHeader>

                                <Div Display="Display.Flex" Justify="Justify.Center">
                                    <Tooltip>
                                        <TooltipTrigger AsChild="true">
                                            <Button Variant="ButtonVariant.Outline" AriaLabel="Show nested tooltip">Hover for tooltip</Button>
                                        </TooltipTrigger>
                                        <TooltipContent>
                                            <Paragraph>Nested tooltip</Paragraph>
                                        </TooltipContent>
                                    </Tooltip>
                                </Div>
                            </DialogContent>
                        </Dialog>
                    </Div>
                </DemoSection>
            </Section>
        </Div>
    </TooltipProvider>
</Div>

