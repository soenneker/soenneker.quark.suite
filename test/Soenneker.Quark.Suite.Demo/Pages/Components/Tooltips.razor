@page "/overlays/tooltips"

<PageTitle>Tooltip - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <TooltipProvider DelayDuration="150">
        <Div Space="Space.Y.Is6">
            <Section Space="Space.Y.Is4">
                <DemoSection Title="Basic tooltip"
                             Description="Adapted from the shadcn tooltip demo with an outline trigger and simple helper text."
                             Code="@TooltipCode">
                    <Div Class="flex min-h-32 items-center justify-center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Hover</Button>
                            </TooltipTrigger>
                            <TooltipContent>
                                <p>Add to library</p>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Sides and keyboard hint"
                             Description="Switch placement and pair tooltips with keyboard shortcuts for richer affordances.">
                    <Div Class="flex min-h-40 flex-wrap items-center justify-center gap-6">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Top</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="top">
                                <p>Default placement</p>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Right</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="right">
                                <p>Helpful context on the right</p>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">
                                    Command palette
                                    <Span Class="ml-2 flex items-center gap-1">
                                        <KbdChip>Ctrl</KbdChip>
                                        <KbdChip>K</KbdChip>
                                    </Span>
                                </Button>
                            </TooltipTrigger>
                            <TooltipContent Side="bottom">
                                <p>Open the quick action palette</p>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>
        </Div>
    </TooltipProvider>
</Div>

@code {
    private const string TooltipCode =
@"<Tooltip>
    <TooltipTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Hover</Button>
    </TooltipTrigger>
    <TooltipContent>
        <p>Add to library</p>
    </TooltipContent>
</Tooltip>";
}
