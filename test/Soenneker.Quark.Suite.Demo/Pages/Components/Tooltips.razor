@page "/tooltips"

<PageTitle>Tooltips - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <TooltipProvider DelayDuration="150">
        <Div Space="Space.Y.Is6">
            <Section Space="Space.Y.Is4">
                <DemoSection
                             Description="A popup that displays information related to an element when the element receives keyboard focus or the mouse hovers over it."
                             Code="@BasicCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center" data-testid="quark-tooltip-basic-demo">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Hover</Button>
                            </TooltipTrigger>
                            <TooltipContent>
                                <p>Add to library</p>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Side"
                             Description="Choose the side that best fits the surrounding layout."
                             Code="@SidesCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("40")' Flex="Flex.Wrap" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is5" data-testid="quark-tooltip-side-demo">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Left</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="Side.Left">
                                <p>Add to library</p>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Top</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="Side.Top">
                                <p>Add to library</p>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Bottom</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="Side.Bottom">
                                <p>Add to library</p>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Right</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="Side.Right">
                                <p>Add to library</p>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="With Keyboard Shortcut"
                             Description="Pair tooltips with shortcuts so users discover faster paths without leaving the current screen."
                             Code="@ShortcutCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm">
                                    <Icon Name="LucideIcon.Save" />
                                </Button>
                            </TooltipTrigger>
                            <TooltipContent>
                                Save Changes <KbdChip>S</KbdChip>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Disabled Button"
                             Description="Wrap disabled controls in a neutral element so the tooltip can still explain why the action is unavailable."
                             Code="@DisabledCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Span Class="inline-block w-fit">
                                    <Button Variant="ButtonVariant.Outline" Disabled="true">Disabled</Button>
                                </Span>
                            </TooltipTrigger>
                            <TooltipContent>
                                <p>This feature is currently unavailable</p>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="RTL"
                             Description="Tooltip side placement also works in right-to-left layouts."
                             Code="@RtlCode"
                             CodeLanguage="razor">
                    <Div Display="Display.Flex" MinHeight='Height.Token("32")' ItemsAlign="Items.Center" Justify="Justify.Center">
                        <DirectionProvider Dir="rtl">
                            <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is3">
                                <Tooltip>
                                    <TooltipTrigger AsChild="true">
                                        <Button Variant="ButtonVariant.Outline">يسار</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="Side.Left">
                                        <p>إضافة إلى المكتبة</p>
                                    </TooltipContent>
                                </Tooltip>
                                <Tooltip>
                                    <TooltipTrigger AsChild="true">
                                        <Button Variant="ButtonVariant.Outline">أعلى</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="Side.Top">
                                        <p>إضافة إلى المكتبة</p>
                                    </TooltipContent>
                                </Tooltip>
                                <Tooltip>
                                    <TooltipTrigger AsChild="true">
                                        <Button Variant="ButtonVariant.Outline">أسفل</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="Side.Bottom">
                                        <p>إضافة إلى المكتبة</p>
                                    </TooltipContent>
                                </Tooltip>
                                <Tooltip>
                                    <TooltipTrigger AsChild="true">
                                        <Button Variant="ButtonVariant.Outline">يمين</Button>
                                    </TooltipTrigger>
                                    <TooltipContent Side="Side.Right">
                                        <p>إضافة إلى المكتبة</p>
                                    </TooltipContent>
                                </Tooltip>
                            </Div>
                        </DirectionProvider>
                    </Div>
                </DemoSection>
            </Section>
        </Div>
    </TooltipProvider>
</Div>

