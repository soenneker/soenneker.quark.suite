@page "/tooltips"

<PageTitle>Tooltips - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <TooltipProvider DelayDuration="150">
        <Div Space="Space.Y.Is6">
            <Section Space="Space.Y.Is4">
                <DemoSection Title="Basic"
                             Description="Tooltips work well for terse helper text on icon buttons and compact controls."
                             Code="@BasicCode"
                             CodeLanguage="razor">
                    <Div Class="flex min-h-32 items-center justify-center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Hover</Button>
                            </TooltipTrigger>
                            <TooltipContent>
                                <Paragraph>Add to library</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Side"
                             Description="Choose the side that best fits the surrounding layout."
                             Code="@SidesCode"
                             CodeLanguage="razor">
                    <Div Class="flex min-h-40 flex-wrap items-center justify-center gap-6">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Top</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="top">
                                <Paragraph>Default placement</Paragraph>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Right</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="right">
                                <Paragraph>Helpful context on the right</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Left</Button>
                            </TooltipTrigger>
                            <TooltipContent Side="left">
                                <Paragraph>Helpful context on the left</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="With Keyboard Shortcut"
                             Description="Pair tooltips with shortcuts so users discover faster paths without leaving the current screen."
                             Code="@ShortcutCode"
                             CodeLanguage="razor">
                    <Div Class="flex min-h-32 items-center justify-center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">
                                    Command palette
                                    <Span Class="ml-2 flex items-center gap-1">
                                        <KbdChip>Ctrl</KbdChip>
                                        <KbdChip>K</KbdChip>
                                    </Span>
                                </Button>
                            </TooltipTrigger>
                            <TooltipContent Side="bottom">
                                <Paragraph>Open the quick action palette</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="Disabled Button"
                             Description="Wrap disabled controls in a neutral element so the tooltip can still explain why the action is unavailable."
                             Code="@DisabledCode"
                             CodeLanguage="razor">
                    <Div Class="flex min-h-32 items-center justify-center">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <span class="inline-flex">
                                    <Button Variant="ButtonVariant.Outline" Disabled="true">Invite user</Button>
                                </span>
                            </TooltipTrigger>
                            <TooltipContent>
                                <Paragraph>Upgrade to the team plan to invite additional users.</Paragraph>
                            </TooltipContent>
                        </Tooltip>
                    </Div>
                </DemoSection>
            </Section>

            <Section Space="Space.Y.Is4">
                <DemoSection Title="RTL"
                             Description="Tooltip side placement also works in right-to-left layouts."
                             Code="@RtlCode"
                             CodeLanguage="razor">
                    <Div Class="flex min-h-32 items-center justify-center">
                        <DirectionProvider Dir="rtl">
                            <Tooltip>
                                <TooltipTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline">تحويم</Button>
                                </TooltipTrigger>
                                <TooltipContent Side="right">
                                    <Paragraph>إضافة إلى المكتبة</Paragraph>
                                </TooltipContent>
                            </Tooltip>
                        </DirectionProvider>
                    </Div>
                </DemoSection>
            </Section>
        </Div>
    </TooltipProvider>
</Div>

@code {
    private const string BasicCode =
@"<Tooltip>
    <TooltipTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Hover</Button>
    </TooltipTrigger>
    <TooltipContent>
        <Paragraph>Add to library</Paragraph>
    </TooltipContent>
</Tooltip>";

    private const string SidesCode =
@"<Tooltip><TooltipTrigger AsChild=""true""><Button Variant=""ButtonVariant.Outline"">Top</Button></TooltipTrigger><TooltipContent Side=""top"">...</TooltipContent></Tooltip>
<Tooltip><TooltipTrigger AsChild=""true""><Button Variant=""ButtonVariant.Outline"">Right</Button></TooltipTrigger><TooltipContent Side=""right"">...</TooltipContent></Tooltip>
<Tooltip><TooltipTrigger AsChild=""true""><Button Variant=""ButtonVariant.Outline"">Left</Button></TooltipTrigger><TooltipContent Side=""left"">...</TooltipContent></Tooltip>";

    private const string ShortcutCode =
@"<Tooltip>
    <TooltipTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">
            Command palette
            <Span Class=""ml-2 flex items-center gap-1"">
                <KbdChip>Ctrl</KbdChip>
                <KbdChip>K</KbdChip>
            </Span>
        </Button>
    </TooltipTrigger>
    <TooltipContent Side=""bottom"">
        <Paragraph>Open the quick action palette</Paragraph>
    </TooltipContent>
</Tooltip>";

    private const string DisabledCode =
@"<Tooltip>
    <TooltipTrigger AsChild=""true"">
        <span class=""inline-flex"">
            <Button Variant=""ButtonVariant.Outline"" Disabled=""true"">Invite user</Button>
        </span>
    </TooltipTrigger>
    <TooltipContent>
        <Paragraph>Upgrade to the team plan to invite additional users.</Paragraph>
    </TooltipContent>
</Tooltip>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Tooltip>
        <TooltipTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">تحويم</Button>
        </TooltipTrigger>
        <TooltipContent Side=""right"">
            <Paragraph>إضافة إلى المكتبة</Paragraph>
        </TooltipContent>
    </Tooltip>
</DirectionProvider>";
}
