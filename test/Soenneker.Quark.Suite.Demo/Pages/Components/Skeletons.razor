@page "/skeletons"

<PageTitle>Skeleton - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Avatar circle with two text lines."
                         Code="@DemoCode">
                <Div Class="flex items-center gap-4">
                    <Skeleton Class="h-12 w-12 rounded-full" />
                    <Div Class="space-y-2">
                        <Skeleton Class="h-4 w-[250px]" />
                        <Skeleton Class="h-4 w-[200px]" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Code="@AvatarCode">
                <Div Class="flex w-fit items-center gap-4">
                    <Skeleton Class="size-10 shrink-0 rounded-full" />
                    <Div Class="grid gap-2">
                        <Skeleton Class="h-4 w-[150px]" />
                        <Skeleton Class="h-4 w-[100px]" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Card"
                         Code="@CardCode">
                <Card Class="w-full max-w-xs">
                    <CardHeader>
                        <Skeleton Class="h-4 w-2/3" />
                        <Skeleton Class="h-4 w-1/2" />
                    </CardHeader>
                    <CardBody>
                        <Skeleton Class="aspect-video w-full" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Text"
                         Code="@TextCode">
                <Div Class="flex w-full max-w-xs flex-col gap-2">
                    <Skeleton Class="h-4 w-full" />
                    <Skeleton Class="h-4 w-full" />
                    <Skeleton Class="h-4 w-3/4" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Code="@FormCode">
                <Div Class="flex w-full max-w-xs flex-col gap-7">
                    <Div Class="flex flex-col gap-3">
                        <Skeleton Class="h-4 w-20" />
                        <Skeleton Class="h-8 w-full" />
                    </Div>
                    <Div Class="flex flex-col gap-3">
                        <Skeleton Class="h-4 w-24" />
                        <Skeleton Class="h-8 w-full" />
                    </Div>
                    <Skeleton Class="h-8 w-24" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Table"
                         Code="@TableCode">
                <Div Class="flex w-full max-w-sm flex-col gap-2">
                    @for (var index = 0; index < 5; index++)
                    {
                        <Div Class="flex gap-4">
                            <Skeleton Class="h-4 flex-1" />
                            <Skeleton Class="h-4 w-24" />
                            <Skeleton Class="h-4 w-20" />
                        </Div>
                    }
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex items-center gap-4">
                        <Skeleton Class="h-12 w-12 rounded-full" />
                        <Div Class="space-y-2">
                            <Skeleton Class="h-4 w-[250px]" />
                            <Skeleton Class="h-4 w-[200px]" />
                        </Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Div Class=""flex items-center gap-4"">
    <Skeleton Class=""h-12 w-12 rounded-full"" />
    <Div Class=""space-y-2"">
        <Skeleton Class=""h-4 w-[250px]"" />
        <Skeleton Class=""h-4 w-[200px]"" />
    </Div>
</Div>";

    private const string AvatarCode =
@"<Div Class=""flex w-fit items-center gap-4"">
    <Skeleton Class=""size-10 shrink-0 rounded-full"" />
    <Div Class=""grid gap-2"">
        <Skeleton Class=""h-4 w-[150px]"" />
        <Skeleton Class=""h-4 w-[100px]"" />
    </Div>
</Div>";

    private const string CardCode =
@"<Card Class=""w-full max-w-xs"">
    <CardHeader>
        <Skeleton Class=""h-4 w-2/3"" />
        <Skeleton Class=""h-4 w-1/2"" />
    </CardHeader>
    <CardBody>
        <Skeleton Class=""aspect-video w-full"" />
    </CardBody>
</Card>";

    private const string TextCode =
@"<Div Class=""flex w-full max-w-xs flex-col gap-2"">
    <Skeleton Class=""h-4 w-full"" />
    <Skeleton Class=""h-4 w-full"" />
    <Skeleton Class=""h-4 w-3/4"" />
</Div>";

    private const string FormCode =
@"<Div Class=""flex w-full max-w-xs flex-col gap-7"">
    <Div Class=""flex flex-col gap-3"">
        <Skeleton Class=""h-4 w-20"" />
        <Skeleton Class=""h-8 w-full"" />
    </Div>
    <Div Class=""flex flex-col gap-3"">
        <Skeleton Class=""h-4 w-24"" />
        <Skeleton Class=""h-8 w-full"" />
