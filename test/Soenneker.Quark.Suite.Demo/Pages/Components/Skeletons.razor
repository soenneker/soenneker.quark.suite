@page "/skeletons"

<PageTitle>Skeleton - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Use to show a placeholder while content is loading."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="flex items-center space-x-4">
                    <Skeleton Class="h-12 w-12 rounded-full" />
                    <Div Space="Space.Y.Is2">
                        <Skeleton Class="h-4 w-[250px]" />
                        <Skeleton Class="h-4 w-[200px]" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Description="Compact avatar row with two skeleton text lines."
                         Code="@AvatarCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFit" ItemsAlign="Items.Center" Gap="Gap.Is4">
                    <Skeleton Class="size-10 shrink-0 rounded-full" />
                    <Div Display="Display.Grid" Gap="Gap.Is2">
                        <Skeleton Class="h-4 w-[150px]" />
                        <Skeleton Class="h-4 w-[100px]" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Card"
                         Description="Card header and media placeholder block."
                         Code="@CardCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <CardHeader>
                        <Skeleton Class="h-4 w-2/3" />
                        <Skeleton Class="h-4 w-1/2" />
                    </CardHeader>
                    <CardBody>
                        <Skeleton Class="aspect-video w-full" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Text"
                         Description="Stacked lines for paragraph placeholders."
                         Code="@TextCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                    <Skeleton Class="h-4 w-full" />
                    <Skeleton Class="h-4 w-full" />
                    <Skeleton Class="h-4 w-3/4" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="Label and field skeletons for form layouts."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" FlexDirection="FlexDirection.Col" Gap='Gap.Token("7")'>
                    <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is3">
                        <Skeleton Class="h-4 w-20" />
                        <Skeleton Class="h-8 w-full" />
                    </Div>
                    <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is3">
                        <Skeleton Class="h-4 w-24" />
                        <Skeleton Class="h-8 w-full" />
                    </Div>
                    <Skeleton Class="h-8 w-24" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Table"
                         Description="Repeating row skeletons for tabular data."
                         Code="@TableCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                    @for (var index = 0; index < 5; index++)
                    {
                        <Div Display="Display.Flex" Gap="Gap.Is4">
                            <Skeleton Class="h-4 flex-1" />
                            <Skeleton Class="h-4 w-24" />
                            <Skeleton Class="h-4 w-20" />
                        </Div>
                    }
                </Div>
            </DemoSection>
        </Section><Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Skeleton layout inherits direction for RTL."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is4">
                        <Skeleton Class="h-12 w-12 rounded-full" />
                        <Div Space="Space.Y.Is2">
                            <Skeleton Class="h-4 w-[250px]" />
                            <Skeleton Class="h-4 w-[200px]" />
                        </Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

