@page "/skeletons"

<PageTitle>Skeleton - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Avatar circle with two text lines."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="flex items-center gap-4">
                    <Skeleton Class="h-12 w-12 rounded-full" />
                    <Div Space="Space.Y.Is2">
                        <Skeleton Class="h-4 w-[250px]" />
                        <Skeleton Class="h-4 w-[200px]" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Extended skeleton layouts beyond the reference avatar-and-text demo above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Description="Compact avatar row with two skeleton text lines."
                         Code="@AvatarCode"
                         CodeLanguage="razor">
                <Div Class="flex w-fit items-center gap-4">
                    <Skeleton Class="size-10 shrink-0 rounded-full" />
                    <Div Display="Display.Grid" Gap="Gap.Is2">
                        <Skeleton Class="h-4 w-[150px]" />
                        <Skeleton Class="h-4 w-[100px]" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Card"
                         Description="Card header and media placeholder block."
                         Code="@CardCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <CardHeader>
                        <Skeleton Class="h-4 w-2/3" />
                        <Skeleton Class="h-4 w-1/2" />
                    </CardHeader>
                    <CardBody>
                        <Skeleton Class="aspect-video w-full" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Text"
                         Description="Stacked lines for paragraph placeholders."
                         Code="@TextCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full max-w-xs flex-col gap-2">
                    <Skeleton Class="h-4 w-full" />
                    <Skeleton Class="h-4 w-full" />
                    <Skeleton Class="h-4 w-3/4" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="Label and field skeletons for form layouts."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full max-w-xs flex-col gap-7">
                    <Div Display="Display.Flex" FlexDirection="FlexDirection.Column" Gap="Gap.Is3">
                        <Skeleton Class="h-4 w-20" />
                        <Skeleton Class="h-8 w-full" />
                    </Div>
                    <Div Display="Display.Flex" FlexDirection="FlexDirection.Column" Gap="Gap.Is3">
                        <Skeleton Class="h-4 w-24" />
                        <Skeleton Class="h-8 w-full" />
                    </Div>
                    <Skeleton Class="h-8 w-24" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Table"
                         Description="Repeating row skeletons for tabular data."
                         Code="@TableCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full max-w-sm flex-col gap-2">
                    @for (var index = 0; index < 5; index++)
                    {
                        <Div Class="flex gap-4">
                            <Skeleton Class="h-4 flex-1" />
                            <Skeleton Class="h-4 w-24" />
                            <Skeleton Class="h-4 w-20" />
                        </Div>
                    }
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Skeleton layout inherits direction for RTL."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex items-center gap-4">
                        <Skeleton Class="h-12 w-12 rounded-full" />
                        <Div Space="Space.Y.Is2">
                            <Skeleton Class="h-4 w-[250px]" />
                            <Skeleton Class="h-4 w-[200px]" />
                        </Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

