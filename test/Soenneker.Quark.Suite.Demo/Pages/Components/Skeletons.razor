@page "/skeletons"

<PageTitle>Skeleton - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Text"
                        Description="Use short skeleton rows to stand in for loading copy."
                        Code="@(@"<Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[250px]"")"" />
<Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[200px]"")"" />
<Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[300px]"")"" />")">
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4">
                    <Div Space="Space.Y.Is3">
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[250px]"))" />
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[200px]"))" />
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[300px]"))" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                        Description="Circle skeletons are useful for pending profile images and author rows."
                        Code="@(@"<Div Display=""Display.Flex"" AlignUtility=""Align.ItemsCenter"" Space=""Space.X.Is4"">
    <Skeleton Height=""Height.Token(""12"")"" Width=""Width.Token(""12"")"" Rounded=""Rounded.Full"" />
    <Div Space=""Space.Y.Is2"">
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[180px]"")"" />
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[120px]"")"" />
    </Div>
</Div>")">
                <Div MaxWidth="MaxWidth.IsSm" Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4">
                    <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Space="Space.X.Is4">
                        <Skeleton Height="@(Height.Token("12"))" Width="@(Width.Token("12"))" Rounded="Rounded.Full" />
                        <Div Space="Space.Y.Is2">
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[180px]"))" />
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[120px]"))" />
                        </Div>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Card"
                        Description="Compose multiple skeletons together to preview a card layout."
                        Code="@(@"<Div Display=""Display.Flex"" AlignUtility=""Align.ItemsCenter"" Space=""Space.X.Is4"">
    <Skeleton Height=""Height.Token(""12"")"" Width=""Width.Token(""12"")"" Rounded=""Rounded.Full"" />
    <Div Space=""Space.Y.Is2"">
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[250px]"")"" />
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[200px]"")"" />
    </Div>
</Div>")">
                <Div MaxWidth="MaxWidth.IsSm" Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4">
                    <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Space="Space.X.Is4">
                        <Skeleton Height="@(Height.Token("12"))" Width="@(Width.Token("12"))" Rounded="Rounded.Full" />
                        <Div Space="Space.Y.Is2">
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[250px]"))" />
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[200px]"))" />
                        </Div>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                        Description="Mix line, block, and button placeholders for pending forms."
                        Code="@(@"<Div Class=""grid gap-4 max-w-md"">
    <Div Class=""grid gap-2"">
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[120px]"")"" />
        <Skeleton Height=""Height.Token(""10"")"" Width=""Width.IsFull"" />
    </Div>
    <Div Class=""grid gap-2"">
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[160px]"")"" />
        <Skeleton Height=""Height.Token(""24"")"" Width=""Width.IsFull"" />
    </Div>
    <Skeleton Height=""Height.Token(""10"")"" Width=""Width.Token(""[140px]"")"" />
</Div>")">
                <Div Class="grid max-w-md gap-4 rounded-lg border bg-card p-4">
                    <Div Class="grid gap-2">
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[120px]"))" />
                        <Skeleton Height="@(Height.Token("10"))" Width="Width.IsFull" />
                    </Div>
                    <Div Class="grid gap-2">
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[160px]"))" />
                        <Skeleton Height="@(Height.Token("24"))" Width="Width.IsFull" />
                    </Div>
                    <Skeleton Height="@(Height.Token("10"))" Width="@(Width.Token("[140px]"))" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Table"
                        Description="Table skeletons give data-heavy pages a steadier loading experience."
                        Code="@(@"<Div Class=""rounded-lg border"">
    <Div Class=""grid grid-cols-4 gap-4 border-b p-4"">
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[80px]"")"" />
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[90px]"")"" />
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[70px]"")"" />
        <Skeleton Height=""Height.Token(""4"")"" Width=""Width.Token(""[60px]"")"" />
    </Div>
    <!-- repeated rows -->
</Div>")">
                <Div Class="overflow-hidden rounded-lg border bg-card">
                    <Div Class="grid grid-cols-4 gap-4 border-b p-4">
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[80px]"))" />
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[90px]"))" />
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[70px]"))" />
                        <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[60px]"))" />
                    </Div>
                    @for (var i = 0; i < 3; i++)
                    {
                        <Div Class="grid grid-cols-4 gap-4 border-b p-4 last:border-b-0">
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[120px]"))" />
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[100px]"))" />
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[80px]"))" />
                            <Skeleton Height="@(Height.Token("4"))" Width="@(Width.Token("[90px]"))" />
                        </Div>
                    }
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>
