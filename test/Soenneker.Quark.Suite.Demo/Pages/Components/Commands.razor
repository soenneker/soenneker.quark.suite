@page "/commands"
@using System.Linq

<PageTitle>Command - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Searchable command surface with grouped actions, icons, disabled items, and shortcuts."
                         Code="@CommandCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Type a command or search..." />
                        <CommandList>
                            <CommandEmpty>No results found.</CommandEmpty>
                            <CommandGroup Heading="Suggestions">
                                <CommandItem SearchValue="Calendar" OnSelect="@(() => SelectAction("Calendar"))">
                                    <Icon Name="LucideIcon.Calendar" />
                                    <Span>Calendar</Span>
                                </CommandItem>
                                <CommandItem SearchValue="Search Emoji" OnSelect="@(() => SelectAction("Search Emoji"))">
                                    <Icon Name="LucideIcon.Smile" />
                                    <Span>Search Emoji</Span>
                                </CommandItem>
                                <CommandItem SearchValue="Calculator" Disabled="true">
                                    <Icon Name="LucideIcon.Calculator" />
                                    <Span>Calculator</Span>
                                </CommandItem>
                            </CommandGroup>
                            <CommandSeparator />
                            <CommandGroup Heading="Settings">
                                <CommandItem SearchValue="Profile" OnSelect="@(() => SelectAction("Profile"))">
                                    <Icon Name="LucideIcon.User" />
                                    <Span>Profile</Span>
                                    <CommandShortcut>Ctrl+P</CommandShortcut>
                                </CommandItem>
                                <CommandItem SearchValue="Billing" OnSelect="@(() => SelectAction("Billing"))">
                                    <Icon Name="LucideIcon.CreditCard" />
                                    <Span>Billing</Span>
                                    <CommandShortcut>Ctrl+B</CommandShortcut>
                                </CommandItem>
                                <CommandItem SearchValue="Settings" OnSelect="@(() => SelectAction("Settings"))">
                                    <Icon Name="LucideIcon.Settings" />
                                    <Span>Settings</Span>
                                    <CommandShortcut>Ctrl+S</CommandShortcut>
                                </CommandItem>
                            </CommandGroup>
                        </CommandList>
                    </Command>
                </Div>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Last action:
                    <Span FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground">@_lastAction</Span>
                </Paragraph>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="The standard command menu with input, empty state, groups, and separators."
                         Code="@CommandCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Type a command or search..." />
                        <CommandList>
                            <CommandEmpty>No results found.</CommandEmpty>
                            <CommandGroup Heading="Suggestions">
                                <CommandItem SearchValue="Calendar">Calendar</CommandItem>
                                <CommandItem SearchValue="Search Emoji">Search Emoji</CommandItem>
                                <CommandItem SearchValue="Calculator" Disabled="true">Calculator</CommandItem>
                            </CommandGroup>
                            <CommandSeparator />
                            <CommandGroup Heading="Settings">
                                <CommandItem SearchValue="Profile">Profile</CommandItem>
                                <CommandItem SearchValue="Billing">Billing</CommandItem>
                                <CommandItem SearchValue="Settings">Settings</CommandItem>
                            </CommandGroup>
                        </CommandList>
                    </Command>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Shortcuts"
                         Description="Shortcut hints sit at the trailing edge of command items."
                         Code="@CommandShortcutsCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Search keyboard shortcuts..." />
                        <CommandList>
                            @foreach (var action in Actions.Take(4))
                            {
                                <CommandItem SearchValue="@action.Title" OnSelect="@(() => SelectAction(action.Title))">
                                    <Span>@action.Title</Span>
                                    <CommandShortcut>@action.Shortcut</CommandShortcut>
                                </CommandItem>
                            }
                        </CommandList>
                    </Command>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Groups"
                         Description="Use CommandGroup and CommandSeparator to structure larger command sets."
                         Code="@CommandGroupsCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Search grouped commands..." />
                        <CommandList>
                            <CommandEmpty>No grouped commands match your search.</CommandEmpty>
                            <CommandGroup Heading="Suggestions">
                                <CommandItem SearchValue="Calendar" OnSelect="@(() => SelectAction("Calendar"))">Calendar</CommandItem>
                                <CommandItem SearchValue="Search emoji" OnSelect="@(() => SelectAction("Search emoji"))">Search emoji</CommandItem>
                            </CommandGroup>
                            <CommandSeparator />
                            <CommandGroup Heading="Settings">
                                <CommandItem SearchValue="Profile" OnSelect="@(() => SelectAction("Profile"))">Profile</CommandItem>
                                <CommandItem SearchValue="Billing" OnSelect="@(() => SelectAction("Billing"))">Billing</CommandItem>
                                <CommandItem SearchValue="Team" OnSelect="@(() => SelectAction("Team"))">Team</CommandItem>
                            </CommandGroup>
                        </CommandList>
                    </Command>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable"
                         Description="Long command sets scroll inside the list instead of expanding the surface."
                         Code="@CommandScrollableCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Search long list..." />
                        <CommandList MaxHeight='Height.Token("56")' OverflowY="Overflow.Y.Auto">
                            <CommandEmpty>No results found.</CommandEmpty>
                            @foreach (var item in ScrollableActions)
                            {
                                <CommandItem SearchValue="@item" OnSelect="@(() => SelectAction(item))">@item</CommandItem>
                            }
                        </CommandList>
                    </Command>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Command items mirror correctly in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                        <Command>
                            <CommandInput Placeholder="ابحث عن اجراء..." />
                            <CommandList>
                                <CommandEmpty>لا توجد نتائج.</CommandEmpty>
                                <CommandGroup Heading="اقتراحات">
                                    <CommandItem SearchValue="التقويم">التقويم</CommandItem>
                                    <CommandItem SearchValue="الاعدادات">الاعدادات</CommandItem>
                                </CommandGroup>
                            </CommandList>
                        </Command>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Command Dialog"
                         Description="Use CommandDialog when the command menu should open as a modal palette."
                         Code="@CommandDialogCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Outline" OnClick="@OpenCommandDialog">
                    Open command palette
                </Button>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Dialog selection:
                    <Span FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground">@_dialogSelection</Span>
                </Paragraph>
                <CommandDialog Visible="_commandDialogOpen"
                               VisibleChanged="OnCommandDialogOpenChanged"
                               Title="Workspace actions"
                               Description="Search workspace actions">
                    <CommandInput Placeholder="Type a command or search..." />
                    <CommandList>
                        <CommandEmpty>No results found.</CommandEmpty>
                        <CommandGroup Heading="Actions">
                            <CommandItem SearchValue="Profile" OnSelect="@(() => SelectDialogAction("Profile"))">Profile</CommandItem>
                            <CommandItem SearchValue="Billing" OnSelect="@(() => SelectDialogAction("Billing"))">Billing</CommandItem>
                            <CommandItem SearchValue="Settings" OnSelect="@(() => SelectDialogAction("Settings"))">Settings</CommandItem>
                        </CommandGroup>
                    </CommandList>
                </CommandDialog>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private static readonly CommandAction[] Actions =
    [
        new("Calendar", "Ctrl+K"),
        new("Search emoji", "Ctrl+E"),
        new("Billing", "Ctrl+B"),
        new("Settings", "Ctrl+,"),
        new("Invite teammates", "Ctrl+I")
    ];

    private static readonly string[] ScrollableActions =
    [
        "Account",
        "API Keys",
        "Billing",
        "Changelog",
        "Dashboard",
        "Deployments",
        "Docs",
        "Integrations",
        "Members",
        "Notifications",
        "Projects",
        "Security",
        "Settings",
        "Support",
        "Usage"
    ];

    private string _lastAction = "None";
    private string _dialogSelection = "None";
    private bool _commandDialogOpen;

    private Task SelectAction(string title)
    {
        _lastAction = title;
        return Task.CompletedTask;
    }

    private Task OpenCommandDialog(MouseEventArgs _)
    {
        _commandDialogOpen = true;
        return Task.CompletedTask;
    }

    private Task OnCommandDialogOpenChanged(bool value)
    {
        _commandDialogOpen = value;
        return Task.CompletedTask;
    }

    private Task SelectDialogAction(string title)
    {
        _dialogSelection = title;
        _commandDialogOpen = false;
        return Task.CompletedTask;
    }

    private sealed record CommandAction(string Title, string Shortcut);

    private const string CommandCode =
@"<Command>
    <CommandInput Placeholder=""Type a command or search..."" />
    <CommandList>
        <CommandEmpty>No results found.</CommandEmpty>
        <CommandGroup Heading=""Suggestions"">...</CommandGroup>
        <CommandSeparator />
        <CommandGroup Heading=""Settings"">...</CommandGroup>
    </CommandList>
</Command>";

    private const string CommandShortcutsCode =
@"<CommandItem SearchValue=""Calendar"">
    Calendar
    <CommandShortcut>Ctrl+K</CommandShortcut>
</CommandItem>";

    private const string CommandGroupsCode =
@"<CommandList>
    <CommandGroup Heading=""Suggestions"">...</CommandGroup>
    <CommandSeparator />
    <CommandGroup Heading=""Settings"">...</CommandGroup>
</CommandList>";

    private const string CommandScrollableCode =
@"<CommandList MaxHeight='Height.Token(""56"")' OverflowY=""Overflow.Y.Auto"">
    ...
</CommandList>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Command>
        <CommandInput Placeholder=""ابحث عن اجراء..."" />
        <CommandList>
            <CommandEmpty>لا توجد نتائج.</CommandEmpty>
            <CommandGroup Heading=""اقتراحات"">...</CommandGroup>
        </CommandList>
    </Command>
</DirectionProvider>";

    private const string CommandDialogCode =
@"<Button OnClick=""OpenCommandDialog"">Open command palette</Button>
<CommandDialog Visible=""_commandDialogOpen""
               VisibleChanged=""OnCommandDialogOpenChanged""
               Title=""Workspace actions""
               Description=""Search workspace actions"">
    <CommandInput Placeholder=""Type a command or search..."" />
    <CommandList>
        <CommandGroup Heading=""Actions"">
            <CommandItem SearchValue=""Billing"" OnSelect=""@(() => SelectDialogAction(""Billing""))"">Billing</CommandItem>
        </CommandGroup>
    </CommandList>
</CommandDialog>";
}
