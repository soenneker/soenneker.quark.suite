@page "/commands"
@using System.Linq

<PageTitle>Command - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Searchable command surface with grouped actions, icons, disabled items, and shortcuts."
                         Code="@CommandCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Type a command or search..." />
                        <CommandList>
                            <CommandEmpty>No results found.</CommandEmpty>
                            <CommandGroup Heading="Suggestions">
                                <CommandItem SearchValue="Calendar" OnSelect="@(() => SelectAction("Calendar"))">
                                    <Icon Name="LucideIcon.Calendar" />
                                    <Span>Calendar</Span>
                                </CommandItem>
                                <CommandItem SearchValue="Search Emoji" OnSelect="@(() => SelectAction("Search Emoji"))">
                                    <Icon Name="LucideIcon.Smile" />
                                    <Span>Search Emoji</Span>
                                </CommandItem>
                                <CommandItem SearchValue="Calculator" Disabled="true">
                                    <Icon Name="LucideIcon.Calculator" />
                                    <Span>Calculator</Span>
                                </CommandItem>
                            </CommandGroup>
                            <CommandSeparator />
                            <CommandGroup Heading="Settings">
                                <CommandItem SearchValue="Profile" OnSelect="@(() => SelectAction("Profile"))">
                                    <Icon Name="LucideIcon.User" />
                                    <Span>Profile</Span>
                                    <CommandShortcut>Ctrl+P</CommandShortcut>
                                </CommandItem>
                                <CommandItem SearchValue="Billing" OnSelect="@(() => SelectAction("Billing"))">
                                    <Icon Name="LucideIcon.CreditCard" />
                                    <Span>Billing</Span>
                                    <CommandShortcut>Ctrl+B</CommandShortcut>
                                </CommandItem>
                                <CommandItem SearchValue="Settings" OnSelect="@(() => SelectAction("Settings"))">
                                    <Icon Name="LucideIcon.Settings" />
                                    <Span>Settings</Span>
                                    <CommandShortcut>Ctrl+S</CommandShortcut>
                                </CommandItem>
                            </CommandGroup>
                        </CommandList>
                    </Command>
                </Div>

                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Last action:
                    <Span FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground">@_lastAction</Span>
                </Paragraph>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Command Dialog"
                         Description="The shadcn command dialog pattern for a command palette overlay."
                         Code="@CommandDialogCode"
                         CodeLanguage="razor">
                <Div Space="Space.Y.Is3">
                    <Button Variant="ButtonVariant.Outline" OnClick="OpenDialog">Open command palette</Button>

                    <CommandDialog Title="Workspace actions"
                                   Visible="_dialogOpen"
                                   VisibleChanged="OnDialogVisibilityChanged">
                        <CommandInput Placeholder="Search workspace actions..." />
                        <CommandList>
                            <CommandEmpty>No workspace actions match your search.</CommandEmpty>

                            @foreach (var action in Actions)
                            {
                                <CommandItem SearchValue="@action.Title" OnSelect="@(() => SelectDialogAction(action.Title))">
                                    <Span>@action.Title</Span>
                                    <CommandShortcut>@action.Shortcut</CommandShortcut>
                                </CommandItem>
                            }
                        </CommandList>
                    </CommandDialog>

                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                        Dialog selection:
                        <Span FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground">@_dialogSelection</Span>
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextColor="TextColor.MutedForeground">
                    Shortcut-only lists, grouped variants, and long scrolling command sets.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Shortcuts"
                         Description="Shortcut hints can be rendered inline at the end of each command item."
                         Code="@CommandShortcutsCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Search keyboard shortcuts..." />
                        <CommandList>
                            @foreach (var action in Actions.Take(4))
                            {
                                <CommandItem SearchValue="@action.Title">
                                    <Span>@action.Title</Span>
                                    <CommandShortcut>@action.Shortcut</CommandShortcut>
                                </CommandItem>
                            }
                        </CommandList>
                    </Command>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Groups"
                         Description="Use `CommandGroup`, `CommandSeparator`, and `CommandEmpty` to structure larger command sets."
                         Code="@CommandGroupsCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Search grouped commands..." />
                        <CommandList>
                            <CommandEmpty>No grouped commands match your search.</CommandEmpty>
                            <CommandGroup Heading="Suggestions">
                                <CommandItem SearchValue="Calendar" OnSelect="@(() => SelectAction("Calendar"))">Calendar</CommandItem>
                                <CommandItem SearchValue="Search emoji" OnSelect="@(() => SelectAction("Search emoji"))">Search emoji</CommandItem>
                            </CommandGroup>
                            <CommandSeparator />
                            <CommandGroup Heading="Settings">
                                <CommandItem SearchValue="Profile" OnSelect="@(() => SelectAction("Profile"))">Profile</CommandItem>
                                <CommandItem SearchValue="Billing" OnSelect="@(() => SelectAction("Billing"))">Billing</CommandItem>
                                <CommandItem SearchValue="Team" OnSelect="@(() => SelectAction("Team"))">Team</CommandItem>
                            </CommandGroup>
                        </CommandList>
                    </Command>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable"
                         Description="Long command sets should scroll inside the list instead of expanding the whole surface."
                         Code="@CommandScrollableCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Class="shadow-sm">
                    <Command>
                        <CommandInput Placeholder="Search long list..." />
                        <CommandList MaxHeight='Height.Token("56")' OverflowY="Overflow.Y.Auto">
                            <CommandEmpty>No results found.</CommandEmpty>
                            @foreach (var item in ScrollableActions)
                            {
                                <CommandItem SearchValue="@item" OnSelect="@(() => SelectAction(item))">@item</CommandItem>
                            }
                        </CommandList>
                    </Command>
                </Div>
            </DemoSection>
        </Section>

    </Div>
</Div>

@code {
    private static readonly CommandAction[] Actions =
    [
        new("Calendar", "Ctrl+K"),
        new("Search emoji", "Ctrl+E"),
        new("Billing", "Ctrl+B"),
        new("Settings", "Ctrl+,"),
        new("Invite teammates", "Ctrl+I")
    ];

    private static readonly string[] ScrollableActions =
    [
        "Account",
        "API Keys",
        "Billing",
        "Changelog",
        "Dashboard",
        "Deployments",
        "Docs",
        "Integrations",
        "Members",
        "Notifications",
        "Projects",
        "Security",
        "Settings",
        "Support",
        "Usage"
    ];

    private string _lastAction = "None";

    private bool _dialogOpen;
    private string _dialogSelection = "None";

    private Task OpenDialog(MouseEventArgs _)
    {
        _dialogOpen = true;
        return Task.CompletedTask;
    }

    private Task OnDialogVisibilityChanged(bool value)
    {
        _dialogOpen = value;
        return Task.CompletedTask;
    }

    private Task SelectAction(string title)
    {
        _lastAction = title;
        return Task.CompletedTask;
    }

    private Task SelectDialogAction(string title)
    {
        _dialogSelection = title;
        _dialogOpen = false;
        return Task.CompletedTask;
    }

    private sealed record CommandAction(string Title, string Shortcut);

    private const string CommandCode =
@"<Command>
    <CommandInput Placeholder=""Type a command or search..."" />
    <CommandList>
        <CommandEmpty>No results found.</CommandEmpty>
        <CommandGroup Heading=""Suggestions"">
            <CommandItem SearchValue=""Calendar"">
                <Icon Name=""LucideIcon.Calendar"" />
                <Span>Calendar</Span>
            </CommandItem>
            <CommandItem SearchValue=""Search Emoji"">
                <Icon Name=""LucideIcon.Smile"" />
                <Span>Search Emoji</Span>
            </CommandItem>
            <CommandItem SearchValue=""Calculator"" Disabled=""true"">
                <Icon Name=""LucideIcon.Calculator"" />
                <Span>Calculator</Span>
            </CommandItem>
        </CommandGroup>
        <CommandSeparator />
        <CommandGroup Heading=""Settings"">
            <CommandItem SearchValue=""Profile"">
                <Icon Name=""LucideIcon.User"" />
                <Span>Profile</Span>
                <CommandShortcut>Ctrl+P</CommandShortcut>
            </CommandItem>
            <CommandItem SearchValue=""Billing"">
                <Icon Name=""LucideIcon.CreditCard"" />
                <Span>Billing</Span>
                <CommandShortcut>Ctrl+B</CommandShortcut>
            </CommandItem>
            <CommandItem SearchValue=""Settings"">
                <Icon Name=""LucideIcon.Settings"" />
                <Span>Settings</Span>
                <CommandShortcut>Ctrl+S</CommandShortcut>
            </CommandItem>
        </CommandGroup>
    </CommandList>
</Command>";

    private const string CommandShortcutsCode =
@"<CommandItem SearchValue=""Calendar"">Calendar<CommandShortcut>Ctrl+K</CommandShortcut></CommandItem>";

    private const string CommandGroupsCode =
@"<CommandList>
    <CommandGroup Heading=""Suggestions"">...</CommandGroup>
    <CommandSeparator />
    <CommandGroup Heading=""Settings"">...</CommandGroup>
</CommandList>";

    private const string CommandScrollableCode =
@"<CommandList MaxHeight='Height.Token(""56"")' OverflowY=""Overflow.Y.Auto"">...</CommandList>";

    private const string CommandDialogCode =
@"<CommandDialog Title=""Workspace actions"" Visible=""_dialogOpen"" VisibleChanged=""OnDialogVisibilityChanged"">
    <CommandInput Placeholder=""Search..."" />
    <CommandList>...</CommandList>
</CommandDialog>";
}
