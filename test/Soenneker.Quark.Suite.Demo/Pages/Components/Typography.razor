@page "/typography"

<PageTitle>Typography - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Headings" Description="H1 through H6 and Paragraph." Code="@(@"<H1>Heading 1</H1>
<H2>Heading 2</H2>
<Paragraph>This is a paragraph of text.</Paragraph>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <H1>Heading 1</H1>
                <H2>Heading 2</H2>
                <H3>Heading 3</H3>
                <H4>Heading 4</H4>
                <H5>Heading 5</H5>
                <H6>Heading 6</H6>
            </Div>
        </DemoSection>

        <DemoSection Title="Heading Colors" Description="TextColor on H1-H6 using semantic and Tailwind palette tokens." Code="@(@"<H4 TextColor=""TextColor.Primary"">Primary</H4>
<H4 TextColor=""TextColor.Accent"">Accent</H4>
<H4 TextColor=""TextColor.Token(""amber-600"")"">Amber</H4>")"
CodeLanguage="razor">
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is4.Column.Is2.Row">
                <H4 TextColor="TextColor.Primary" Margin="Margin.Is0">Primary</H4>
                <H4 TextColor="TextColor.Accent" Margin="Margin.Is0">Accent</H4>
                <H4 TextColor='TextColor.Token("amber-600")' Margin="Margin.Is0">Amber</H4>
                <H4 TextColor="TextColor.Destructive" Margin="Margin.Is0">Destructive</H4>
                <H4 TextColor='TextColor.Token("sky-600")' Margin="Margin.Is0">Sky</H4>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Elements" Description="Text with TextColor for semantic styling." Code="@(@"<Text>Regular text</Text>
<Text TextColor=""TextColor.Primary"">Primary text</Text>
<Text TextColor=""TextColor.Accent"">Accent text</Text>
<Text TextColor=""TextColor.Destructive"">Destructive text</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Text>Regular text element.</Text>
                <Text TextColor="TextColor.Primary">Primary text.</Text>
                <Text TextColor="TextColor.Accent">Accent text.</Text>
                <Text TextColor="TextColor.Destructive">Destructive text.</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Sizes" Description="Text Size (Small, Default, Large, ExtraLarge)." Code="@(@"<Text Size=""Size.Small"" Display=""Display.Block"">Small text</Text>
<Text Size=""Size.Default"" Display=""Display.Block"">Default text</Text>
<Text Size=""Size.Large"" Display=""Display.Block"">Large text</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Text Size="Size.Small" Display="Display.Block">Small text</Text>
                <Text Size="Size.Default" Display="Display.Block">Default text</Text>
                <Text Size="Size.Large" Display="Display.Block">Large text</Text>
                <Text Size="Size.ExtraLarge" Display="Display.Block">Extra Large text</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Formatting" Description="Strong, em, Small, underlined, strikethrough." Code="@(@"<Strong>Strong (bold)</Strong>
<Text><em>Italic using em</em></Text>
<Small>Small text</Small>
<Text><u>Underlined</u></Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Strong>Strong (bold)</Strong>
                <Text Display="Display.Block"><em>Italic using em</em></Text>
                <Small Display="Display.Block">Small text</Small>
                <Text Display="Display.Block"><u>Underlined</u></Text>
                <Text Display="Display.Block"><s>Strikethrough</s></Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Blockquote" Description="Blockquotes are useful for callouts, testimonials, and cited notes." Code="@(@"<blockquote class=""border-l-2 pl-6 italic text-muted-foreground"">Quoted text</blockquote>")"
        CodeLanguage="razor">
            <blockquote class="border-l-2 pl-6 italic text-muted-foreground">
                "After moving the dashboard to Quark, the whole team could ship UI changes faster."
            </blockquote>
        </DemoSection>

        <DemoSection Title="Code & PreCode" Description="Inline Code and PreCode blocks." Code="@(@"<Code>Inline code</Code>
<PreCode Class=""block"">Code block\nPreserves formatting</PreCode>
<Code TextColor=""TextColor.Destructive"">Error: 404</Code>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Code>Inline code</Code>
                <PreCode Display="Display.Block">@("Code block\nPreserves formatting")</PreCode>
                <Code TextColor="TextColor.Destructive">Error: 404</Code>
            </Div>
        </DemoSection>

        <Div Display="Display.Grid" Gap='Gap.Token("6")' Class="md:grid-cols-2">
            <DemoSection Title="Unordered" Code="@(@"<UnorderedList>
    <UnorderedListItem>First item</UnorderedListItem>
    <UnorderedListItem>Second item</UnorderedListItem>
</UnorderedList>")"
CodeLanguage="razor">
                <UnorderedList>
                    <UnorderedListItem>First item</UnorderedListItem>
                    <UnorderedListItem>Second item</UnorderedListItem>
                    <UnorderedListItem>Third item</UnorderedListItem>
                </UnorderedList>
            </DemoSection>
            <DemoSection Title="Ordered" Code="@(@"<OrderedList>
    <OrderedListItem>First numbered item</OrderedListItem>
    <OrderedListItem>Second numbered item</OrderedListItem>
</OrderedList>")"
CodeLanguage="razor">
                <OrderedList>
                    <OrderedListItem>First numbered item</OrderedListItem>
                    <OrderedListItem>Second numbered item</OrderedListItem>
                    <OrderedListItem>Third numbered item</OrderedListItem>
                </OrderedList>
            </DemoSection>
        </Div>

        <DemoSection Title="Table" Description="Use regular semantic tables for dense, structured content." Code="@(@"<table class=""w-full text-sm""><thead>...</thead><tbody>...</tbody></table>")"
        CodeLanguage="razor">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead class="border-b">
                        <tr>
                            <th class="py-2 text-left font-medium">Plan</th>
                            <th class="py-2 text-left font-medium">Seats</th>
                            <th class="py-2 text-left font-medium">Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="border-b">
                            <td Padding="Padding.Is2.OnY">Starter</td>
                            <td Padding="Padding.Is2.OnY">3</td>
                            <td Padding="Padding.Is2.OnY">$9</td>
                        </tr>
                        <tr>
                            <td Padding="Padding.Is2.OnY">Team</td>
                            <td Padding="Padding.Is2.OnY">10</td>
                            <td Padding="Padding.Is2.OnY">$29</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </DemoSection>

        <DemoSection Title="Line Breaks & Separators" Description="Br and Hr components." Code="@(@"<Text>First line.</Text>
<Br/>
<Text>Second line after break.</Text>
<Hr/>
<Text>Content below horizontal rule.</Text>")"
CodeLanguage="razor">
            <Text>First line.</Text>
            <Br/>
            <Text>Second line after break.</Text>
            <Hr/>
            <Text>Content below horizontal rule.</Text>
        </DemoSection>

        <DemoSection Title="Text Utilities" Description="TextTransform, FontWeight, FontStyle on Text." Code="@(@"<Text TextTransform=""TextTransform.Uppercase"" Display=""Display.Block"">uppercase</Text>
<Text TextTransform=""TextTransform.Lowercase"" Display=""Display.Block"">LOWERCASE</Text>
<Text FontWeight=""FontWeight.Bold"" Display=""Display.Block"">Bold</Text>
<Text FontStyle=""FontStyle.Italic"" Display=""Display.Block"">Italic</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Text TextTransform="TextTransform.Uppercase" Display="Display.Block">uppercase</Text>
                <Text TextTransform="TextTransform.Lowercase" Display="Display.Block">LOWERCASE</Text>
                <Text FontWeight="FontWeight.Bold" Display="Display.Block">Bold</Text>
                <Text FontStyle="FontStyle.Italic" Display="Display.Block">Italic</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Lead" Description="Lead copy should feel more prominent than body copy without becoming a heading." Code="@(@"<Paragraph TextSize=""TextSize.Xl"" TextColor=""TextColor.MutedForeground"">Lead paragraph</Paragraph>")"
        CodeLanguage="razor">
            <Paragraph TextSize="TextSize.Xl" TextColor="TextColor.MutedForeground">Ship composable UI primitives faster with a design system that still feels native to Blazor.</Paragraph>
        </DemoSection>

        <DemoSection Title="Large" Description="Large supporting text helps introduce sections or summarize the next block of content." Code="@(@"<Text Size=""Size.Large"">Large text</Text>")"
        CodeLanguage="razor">
            <Text Size="Size.Large">This workspace contains all the tools needed to assemble a modern product dashboard.</Text>
        </DemoSection>

        <DemoSection Title="Muted" Description="Muted text is useful for secondary metadata and subtle helper copy." Code="@(@"<Text TextColor=""TextColor.MutedForeground"">Muted text</Text>")"
        CodeLanguage="razor">
            <Text TextColor="TextColor.MutedForeground">Last synced 3 minutes ago from the production region.</Text>
        </DemoSection>

        <DemoSection Title="Display Headings" Description="DisplaySize on H1–H3 for large display text." Code="@(@"<H1 DisplaySize=""DisplaySize.Is1"">Display 1</H1>
<H2 DisplaySize=""DisplaySize.Is2"">Display 2</H2>
<H3 DisplaySize=""DisplaySize.Is3"">Display 3</H3>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <H1 DisplaySize="DisplaySize.Is1">Display 1</H1>
                <H2 DisplaySize="DisplaySize.Is2">Display 2</H2>
                <H3 DisplaySize="DisplaySize.Is3">Display 3</H3>
            </Div>
        </DemoSection>

        <DemoSection Title="RTL" Description="Typography should remain readable and well-spaced in right-to-left layouts too." Code="@(@"<Div dir=""rtl"" Space=""Space.Y.Is2"" TextAlignment=""TextAlignment.End""><H4>مرحبا</H4><Paragraph>RTL sample text.</Paragraph></Div>")"
        CodeLanguage="razor">
            <Div dir="rtl" Space="Space.Y.Is2" TextAlignment="TextAlignment.End">
                <H4>مرحبا بكم في كوارك</H4>
                <Paragraph>هذا مثال بسيط يوضح كيف تبدو المسافات والمحاذاة في اتجاه من اليمين إلى اليسار.</Paragraph>
            </Div>
        </DemoSection>
    </Div>
</Div>
