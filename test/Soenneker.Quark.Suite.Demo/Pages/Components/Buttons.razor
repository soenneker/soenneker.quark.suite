@page "/buttons"

<PageTitle>Button - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Display the full size matrix, including compact and icon variants.">
                <Div Class="flex flex-col items-start gap-8 sm:flex-row">
                    <Div Class="flex items-start gap-2">
                        <Button Size="ButtonSize.Xs" Variant="ButtonVariant.Outline">Extra Small</Button>
                        <Button Size="ButtonSize.IconXs" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                    <Div Class="flex items-start gap-2">
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Small</Button>
                        <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                    <Div Class="flex items-start gap-2">
                        <Button Variant="ButtonVariant.Outline">Default</Button>
                        <Button Size="ButtonSize.Icon" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                    <Div Class="flex items-start gap-2">
                        <Button Size="ButtonSize.Lg" Variant="ButtonVariant.Outline">Large</Button>
                        <Button Size="ButtonSize.IconLg" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Default" Description="The default button is the primary action.">
                <Button>Button</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline" Description="Outline buttons provide a lighter emphasis level for secondary actions.">
                <Button Variant="ButtonVariant.Outline">Outline</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Secondary" Description="Secondary buttons provide an alternate filled emphasis level.">
                <Button Variant="ButtonVariant.Secondary">Secondary</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Ghost" Description="Ghost buttons stay quiet until hover or focus.">
                <Button Variant="ButtonVariant.Ghost">Ghost</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Destructive" Description="Use destructive buttons for irreversible actions.">
                <Button Variant="ButtonVariant.Destructive">Delete</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link" Description="Link buttons keep button semantics while adopting link styling.">
                <Button Variant="ButtonVariant.Link">Link</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icon" Description="Icon buttons keep the same sizing and accessibility hooks as the rest of the button set.">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Upload">
                    <Icon Name="LucideIcon.ArrowUpRight" />
                </Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icon" Description="Inline icons inherit the button spacing and alignment rules automatically.">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">
                    <Icon Name="LucideIcon.GitBranch" />
                    New Branch
                </Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Rounded" Description="Rounded utility classes produce a pill-style action button.">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" Class="rounded-full" aria-label="Up">
                    <Icon Name="LucideIcon.ArrowUp" />
                </Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Spinner" Description="A spinner can be rendered inline at either edge of the button content.">
                <Div Class="flex gap-2">
                    <Button Variant="ButtonVariant.Outline" Disabled="true">
                        <Spinner Size="Size.Small" />
                        Generating
                    </Button>
                    <Button Variant="ButtonVariant.Secondary" Disabled="true">
                        Downloading
                        <Spinner Size="Size.Small" />
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button Group" Description="The button page links to grouped actions, so the demo mirrors that compact action cluster.">
                <ButtonGroup AriaLabel="Message actions">
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Archive</Button>
                        <Button Variant="ButtonVariant.Outline">Report</Button>
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Snooze</Button>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="More actions">
                            <Icon Name="LucideIcon.Ellipsis" />
                        </Button>
                    </ButtonGroup>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="As Child" Description="Buttons can pass their styling and data attributes into a child Quark component.">
                <Button AsChild="true">
                    <Anchor To="input-demo">Login</Anchor>
                </Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples showcase extra Quark behaviors beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Navigation Button" Description="Quark buttons can navigate directly without wrapping a child anchor.">
                <Div Class="flex flex-wrap gap-3">
                    <Button Type="ButtonType.Link" To="badges">Go to Badge</Button>
                    <Button Type="ButtonType.Link" To="badges" Variant="ButtonVariant.Outline">Outline Link</Button>
                    <Button Type="ButtonType.Link" To="badges" Disabled="true">Disabled Link</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button Types" Description="Button, submit, and reset types are available for forms and dialogs.">
                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is4">
                    <Button Type="ButtonType.Button">Type: Button</Button>
                    <Button Type="ButtonType.Submit" Variant="ButtonVariant.Default">Type: Submit</Button>
                    <Button Type="ButtonType.Reset" Variant="ButtonVariant.Secondary">Type: Reset</Button>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>
