@page "/buttons"

<PageTitle>Button - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
    <Section Space="Space.Y.Is4">
        <DemoSection Title="Variants" Description="All standard button variants." Code="@(@"<Button Variant=""ButtonVariant.Default"">Default</Button>
<Button Variant=""ButtonVariant.Destructive"">Destructive</Button>
<Button Variant=""ButtonVariant.Outline"">Outline</Button>
<Button Variant=""ButtonVariant.Secondary"">Secondary</Button>
<Button Variant=""ButtonVariant.Ghost"">Ghost</Button>
<Button Variant=""ButtonVariant.Link"">Link</Button>")">
            <Div class="flex flex-wrap gap-4">
                <Button>No Variant</Button>
                <Button Variant="ButtonVariant.Default">Default</Button>
                <Button Variant="ButtonVariant.Destructive">Destructive</Button>
                <Button Variant="ButtonVariant.Outline">Outline</Button>
                <Button Variant="ButtonVariant.Secondary">Secondary</Button>
                <Button Variant="ButtonVariant.Ghost">Ghost</Button>
                <Button Variant="ButtonVariant.Link">Link</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="As Link" Description="Buttons can navigate when configured as links without losing the button styling." Code="@(@"<Button Type=""ButtonType.Link"" To=""badges"">Go to Badge</Button>
<Button Type=""ButtonType.Link"" To=""badges"" Variant=""ButtonVariant.Outline"">Outline Link</Button>
<Button Type=""ButtonType.Link"" To=""badges"" Disabled=""true"">Disabled Link</Button>")">
            <Div class="space-y-2">
                <Button Type="@ButtonType.Link" To="badges">Go to Badge</Button>
                <Button Type="@ButtonType.Link" To="badges" Variant="ButtonVariant.Outline">Outline Link</Button>
                <Button Type="@ButtonType.Link" To="badges" Disabled="true">Disabled Link</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Size" Description="Default, small, large, and icon sizes." Code="@(@"<Button Size=""ButtonSize.Sm"">Small</Button>
<Button Size=""ButtonSize.Default"">Default</Button>
<Button Size=""ButtonSize.Lg"">Large</Button>
<Button Size=""ButtonSize.Icon"" aria-label=""Icon"">→</Button>
<Button Size=""ButtonSize.IconXs"" aria-label=""Icon small"">-</Button>
<Button Size=""ButtonSize.IconLg"" aria-label=""Icon large"">→</Button>")">
            <Div class="flex flex-wrap gap-4 items-center">
                <Button Size="ButtonSize.Sm">Small</Button>
                <Button Size="ButtonSize.Default">Default</Button>
                <Button Size="ButtonSize.Lg">Large</Button>
                <Button Size="ButtonSize.Icon" aria-label="Icon">→</Button>
                <Button Size="ButtonSize.IconXs" aria-label="Icon small">-</Button>
                <Button Size="ButtonSize.IconLg" aria-label="Icon large">→</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Disabled" Description="Disabled buttons keep the layout stable while clearly communicating that the action is unavailable." Code="@(@"<Button Disabled=""true"">Default Disabled</Button>
<Button Variant=""ButtonVariant.Destructive"" Disabled=""true"">Destructive Disabled</Button>
<Button Variant=""ButtonVariant.Outline"" Disabled=""true"">Outline Disabled</Button>
<Button Variant=""ButtonVariant.Secondary"" Disabled=""true"">Secondary Disabled</Button>
<Button Variant=""ButtonVariant.Ghost"" Disabled=""true"">Ghost Disabled</Button>")">
            <Div class="flex flex-wrap gap-4">
                <Button Disabled="true">Default Disabled</Button>
                <Button Variant="ButtonVariant.Destructive" Disabled="true">Destructive Disabled</Button>
                <Button Variant="ButtonVariant.Outline" Disabled="true">Outline Disabled</Button>
                <Button Variant="ButtonVariant.Secondary" Disabled="true">Secondary Disabled</Button>
                <Button Variant="ButtonVariant.Ghost" Disabled="true">Ghost Disabled</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Interactive" Description="Click handlers and event callbacks." Code="@(@"<Button OnClick=""HandleClick"">Click Me</Button>
<Button OnClick=""IncrementCounter"">Clicked @_counter times</Button>
<Button Variant=""ButtonVariant.Outline"" OnClick=""ResetCounter"">Reset</Button>")">
            <Div class="space-y-4">
                <Div class="flex gap-4 items-center">
                    <Button OnClick="HandleClick">Click Me</Button>
                    <Span class="text-sm">@_clickMessage</Span>
                </Div>
                <Div class="flex gap-4 items-center">
                    <Button OnClick="IncrementCounter">Clicked @_counter times</Button>
                    <Button Variant="ButtonVariant.Outline" OnClick="ResetCounter">Reset</Button>
                </Div>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Button types" Description="Button, submit, and reset types help the component fit naturally into forms and dialogs." Code="@(@"<Button Type=""ButtonType.Button"">Type: Button</Button>
<Button Type=""ButtonType.Submit"" Variant=""ButtonVariant.Default"">Type: Submit</Button>
<Button Type=""ButtonType.Reset"" Variant=""ButtonVariant.Secondary"">Type: Reset</Button>")">
            <Div class="flex flex-wrap gap-4">
                <Button Type="@ButtonType.Button">Type: Button</Button>
                <Button Type="@ButtonType.Submit" Variant="ButtonVariant.Default">Type: Submit</Button>
                <Button Type="@ButtonType.Reset" Variant="ButtonVariant.Secondary">Type: Reset</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Custom variants" Description="Override classes when you need branded or product-specific button treatments." Code="@(@"<Button Class=""bg-green-600 text-white hover:bg-green-700"">Success</Button>
<Button Class=""bg-amber-500 text-white hover:bg-amber-600"">Warning</Button>
<Button Class=""bg-gradient-to-r from-purple-500 to-pink-500 text-white hover:from-purple-600 hover:to-pink-600 border-0"">Brand</Button>")">
            <Div class="flex flex-wrap gap-4">
                <Button Class="bg-green-600 text-white hover:bg-green-700">Success</Button>
                <Button Class="bg-amber-500 text-white hover:bg-amber-600">Warning</Button>
                <Button Class="bg-gradient-to-r from-purple-500 to-pink-500 text-white hover:from-purple-600 hover:to-pink-600 border-0">Brand</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Icon" Description="Use icon sizes when the button only needs a compact visual affordance." Code="@(@"<Button Size=""ButtonSize.Icon"" Variant=""ButtonVariant.Outline"" aria-label=""Settings""><Icon Name=""LucideIcon.Settings"" /></Button>
<Button Size=""ButtonSize.IconSm"" Variant=""ButtonVariant.Ghost"" aria-label=""Close""><Icon Name=""LucideIcon.X"" /></Button>")">
            <Div class="flex flex-wrap items-center gap-4">
                <Button Size="ButtonSize.Icon" Variant="ButtonVariant.Outline" aria-label="Settings"><Icon Name="LucideIcon.Settings" /></Button>
                <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Ghost" aria-label="Close"><Icon Name="LucideIcon.X" /></Button>
                <Button Size="ButtonSize.IconLg" Variant="ButtonVariant.Secondary" aria-label="Add"><Icon Name="LucideIcon.Plus" /></Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="With Icon" Description="Add inline icons when the label benefits from stronger visual scanning." Code="@(@"<Button><Icon Name=""LucideIcon.Download"" />Download</Button>
<Button Variant=""ButtonVariant.Outline"">Share<Icon Name=""LucideIcon.ArrowUpRight"" /></Button>")">
            <Div class="flex flex-wrap items-center gap-4">
                <Button><Icon Name="LucideIcon.Download" />Download</Button>
                <Button Variant="ButtonVariant.Outline">Share<Icon Name="LucideIcon.ArrowUpRight" /></Button>
                <Button Variant="ButtonVariant.Secondary"><Icon Name="LucideIcon.Mail" />Invite user</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Rounded" Description="Rounded utility classes let you match pill-style buttons from the shadcn docs." Code="@(@"<Button Class=""rounded-full"">Rounded</Button>
<Button Variant=""ButtonVariant.Outline"" Class=""rounded-full"">Outline Rounded</Button>")">
            <Div class="flex flex-wrap gap-4">
                <Button Class="rounded-full">Rounded</Button>
                <Button Variant="ButtonVariant.Outline" Class="rounded-full">Outline Rounded</Button>
                <Button Variant="ButtonVariant.Secondary" Class="rounded-full px-6">Continue</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Spinner" Description="Show loading state by rendering a spinner inside the button." Code="@(@"<Button Disabled=""true""><Spinner Size=""Size.Small"" />Saving</Button>")">
            <Div class="flex flex-wrap gap-4">
                <Button Disabled="true"><Spinner Size="Size.Small" />Saving</Button>
                <Button Variant="ButtonVariant.Outline" Disabled="true"><Spinner Size="Size.Small" />Loading</Button>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Button Group" Description="The shadcn button docs also highlight button groups for compact action clusters." Code="@(@"<ButtonGroup>
    <Button Variant=""ButtonVariant.Outline"">Back</Button>
    <Button Variant=""ButtonVariant.Outline"">Next</Button>
</ButtonGroup>")">
            <ButtonGroup>
                <Button Variant="ButtonVariant.Outline">Back</Button>
                <Button Variant="ButtonVariant.Outline">Next</Button>
            </ButtonGroup>
        </DemoSection>
    </Section>
    </Div>
</Div>

@code {
    private string _clickMessage = "";
    private int _counter;

    private Task HandleClick(MouseEventArgs args)
    {
        _clickMessage = $"Button clicked at {DateTime.Now:HH:mm:ss}";
        return Task.CompletedTask;
    }

    private Task IncrementCounter(MouseEventArgs args)
    {
        _counter++;
        return Task.CompletedTask;
    }

    private Task ResetCounter(MouseEventArgs args)
    {
        _counter = 0;
        return Task.CompletedTask;
    }
}
