@page "/buttons"

<PageTitle>Buttons - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays a button or a component that looks like a button."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Button Variant="ButtonVariant.Outline">Button</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Submit">
                        <Icon Name="LucideIcon.ArrowUp" />
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Use the size parameter to change the size of the button."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col.OnSm.Row" ItemsAlign="Items.Start" Gap='Gap.Token("8")'>
                    <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                        <Button Size="ButtonSize.Xs" Variant="ButtonVariant.Outline">Extra Small</Button>
                        <Button Size="ButtonSize.IconXs" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                    <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Small</Button>
                        <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                    <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                        <Button Variant="ButtonVariant.Outline">Default</Button>
                        <Button Size="ButtonSize.Icon" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                    <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                        <Button Size="ButtonSize.Lg" Variant="ButtonVariant.Outline">Large</Button>
                        <Button Size="ButtonSize.IconLg" Variant="ButtonVariant.Outline" aria-label="Submit">
                            <Icon Name="LucideIcon.ArrowUpRight" />
                        </Button>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Default"
                         Description="The default button is the primary action."
                         Code="@DefaultCode"
                         CodeLanguage="razor">
                <Button>Button</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                         Description="Outline buttons provide a lighter emphasis level for secondary actions."
                         Code="@OutlineCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Outline">Outline</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Secondary"
                         Description="Secondary buttons provide an alternate filled emphasis level."
                         Code="@SecondaryCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Secondary">Secondary</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Ghost"
                         Description="Ghost buttons stay quiet until hover or focus."
                         Code="@GhostCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Ghost">Ghost</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Destructive"
                         Description="Use destructive buttons for irreversible actions."
                         Code="@DestructiveCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Destructive">Destructive</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link"
                         Description="Link buttons keep button semantics while adopting link styling."
                         Code="@LinkCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Link">Link</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icon"
                         Description="Icon buttons keep the same sizing and accessibility hooks as the rest of the button set."
                         Code="@IconCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon">
                    <Icon Name="LucideIcon.CircleArrowUp" />
                </Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icon"
                         Description="Remember to add the data-icon attribute to the icon for the correct spacing."
                         Code="@WithIconCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Gap="Gap.Is2">
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">
                        <Icon Name="LucideIcon.GitBranch" />
                        New Branch
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Rounded"
                         Description="Use the rounded-full class to make the button rounded."
                         Code="@RoundedCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" Rounded="Rounded.Full">
                    <Icon Name="LucideIcon.ArrowUp" />
                </Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Spinner"
                         Description="Render a Spinner component inside the button to show a loading state. Remember to add the data-icon attribute to the spinner for the correct spacing."
                         Code="@SpinnerCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2">
                    <Button Variant="ButtonVariant.Outline" Disabled="true">
                        <Spinner data-icon="inline-start" />
                        Generating
                    </Button>
                    <Button Variant="ButtonVariant.Secondary" Disabled="true">
                        <Spinner data-icon="inline-start" />
                        Downloading
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button Group"
                         Description="To create a button group, use the ButtonGroup component."
                         Code="@ButtonGroupCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <ButtonGroup Class="hidden sm:flex">
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Go Back">
                            <Icon Name="LucideIcon.ArrowLeft" />
                        </Button>
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Archive</Button>
                        <Button Variant="ButtonVariant.Outline">Report</Button>
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Snooze</Button>
                        <Dropdown>
                            <DropdownToggle AsChild="true">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="More Options">
                                    <Icon Name="LucideIcon.Ellipsis" />
                                </Button>
                            </DropdownToggle>
                            <DropdownMenu RightAligned="true" Class="w-40">
                                <DropdownItem>Mark as Read</DropdownItem>
                                <DropdownItem>Archive</DropdownItem>
                                <DropdownDivider />
                                <DropdownItem>Snooze</DropdownItem>
                                <DropdownItem>Add to Calendar</DropdownItem>
                                <DropdownItem>Add to List</DropdownItem>
                                <DropdownDivider />
                                <DropdownItem Variant="destructive">Trash</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </ButtonGroup>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="As Child"
                         Description="You can use the AsChild prop on Button to make another component look like a button."
                         Code="@AsChildCode"
                         CodeLanguage="razor">
                <Button AsChild="true">
                    <Anchor To="/login">Login</Anchor>
                </Button>
            </DemoSection>
        </Section><Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Buttons preserve icon and text placement in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2" dir="rtl">
                    <Button Variant="ButtonVariant.Outline">زر</Button>
                    <Button Variant="ButtonVariant.Destructive">حذف</Button>
                    <Button Variant="ButtonVariant.Outline">
                        إرسال
                        <Icon Name="LucideIcon.ArrowRight" data-icon="inline-end" />
                    </Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Add">
                        <Icon Name="LucideIcon.Plus" />
                    </Button>
                    <Button Variant="ButtonVariant.Secondary" Disabled="true">
                        <Spinner data-icon="inline-start" />
                        جاري التحميل
                    </Button>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

