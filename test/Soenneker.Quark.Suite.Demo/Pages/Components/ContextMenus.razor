                    <ContextMenuSeparator />
                    <ContextMenuItem>Developer Tools</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem Variant=""destructive"">Delete</ContextMenuItem>
                </ContextMenuSubContent>
            </ContextMenuSub>
            <ContextMenuSeparator />
            <ContextMenuCheckboxItem @bind-Checked=""showBookmarks"">Show Bookmarks</ContextMenuCheckboxItem>
            <ContextMenuCheckboxItem @bind-Checked=""showFullUrls"">Show Full URLs</ContextMenuCheckboxItem>
            <ContextMenuSeparator />
            <ContextMenuRadioGroup>
                <ContextMenuLabel Inset=""true"">People</ContextMenuLabel>
                <ContextMenuRadioItem Selected=""true"">Pedro Duarte</ContextMenuRadioItem>
                <ContextMenuRadioItem>Colm Tuite</ContextMenuRadioItem>
            </ContextMenuRadioGroup>
        </Div>
    </ContextMenuContent>
</ContextMenu>";

    private const string SubmenuCode =
@"<ContextMenu>
    <ContextMenuTrigger Class=""flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm"">
        Right click for more tools
    </ContextMenuTrigger>
    <ContextMenuContent>
        <Div Class=""w-56"">
            <ContextMenuItem>Save page<ContextMenuShortcut>Ctrl+S</ContextMenuShortcut></ContextMenuItem>
            <ContextMenuItem>Duplicate tab<ContextMenuShortcut>Ctrl+D</ContextMenuShortcut></ContextMenuItem>
            <ContextMenuSub>
                <ContextMenuSubTrigger>More tools</ContextMenuSubTrigger>
                <ContextMenuSubContent Class=""w-44"">
                    <ContextMenuItem>Downloads</ContextMenuItem>
                    <ContextMenuItem>Task manager</ContextMenuItem>
                    <ContextMenuSeparator />
                    <ContextMenuItem>Developer tools</ContextMenuItem>
                </ContextMenuSubContent>
            </ContextMenuSub>
        </Div>
    </ContextMenuContent>
</ContextMenu>";

    private const string CheckboxCode =
@"<ContextMenu>
    <ContextMenuTrigger Class=""flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm"">
        Right click for view options
    </ContextMenuTrigger>
    <ContextMenuContent>
        <Div Class=""w-56"">
            <ContextMenuLabel>View</ContextMenuLabel>
            <ContextMenuSeparator />
            <ContextMenuCheckboxItem @bind-Checked=""showBookmarks"">Show bookmarks bar</ContextMenuCheckboxItem>
            <ContextMenuCheckboxItem @bind-Checked=""showFullUrls"">Show full URLs</ContextMenuCheckboxItem>
            <ContextMenuCheckboxItem @bind-Checked=""showLineNumbers"">Show line numbers</ContextMenuCheckboxItem>
        </Div>
    </ContextMenuContent>
</ContextMenu>";

    private const string RadioCode =
@"<ContextMenu>
    <ContextMenuTrigger Class=""flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm"">
        Right click for layout choices
    </ContextMenuTrigger>
    <ContextMenuContent>
        <Div Class=""w-56"">
            <ContextMenuLabel>Density</ContextMenuLabel>
            <ContextMenuSeparator />
            <ContextMenuRadioGroup>
                <ContextMenuRadioItem Selected=""true"">Comfortable</ContextMenuRadioItem>
                <ContextMenuRadioItem>Compact</ContextMenuRadioItem>
            </ContextMenuRadioGroup>
            <ContextMenuSeparator />
            <ContextMenuItem Variant=""destructive"">Delete project</ContextMenuItem>
        </Div>
