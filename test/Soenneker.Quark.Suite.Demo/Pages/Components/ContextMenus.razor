@page "/context-menus"

<PageTitle>Context Menus - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Browser-style context menu with shortcuts, submenu, checkboxes, and radio items."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <ContextMenu>
                    <ContextMenuTrigger Class="flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm">
                        Right click here
                    </ContextMenuTrigger>
                    <ContextMenuContent>
                        <Div Class="w-52">
                            <ContextMenuItem Inset="true">
                                Back
                                <ContextMenuShortcut>Cmd+[</ContextMenuShortcut>
                            </ContextMenuItem>
                            <ContextMenuItem Inset="true" Disabled="true">
                                Forward
                                <ContextMenuShortcut>Cmd+]</ContextMenuShortcut>
                            </ContextMenuItem>
                            <ContextMenuItem Inset="true">
                                Reload
                                <ContextMenuShortcut>Cmd+R</ContextMenuShortcut>
                            </ContextMenuItem>
                            <ContextMenuSub>
                                <ContextMenuSubTrigger Inset="true">More Tools</ContextMenuSubTrigger>
                                <ContextMenuSubContent Class="w-44">
                                    <ContextMenuItem>Save Page...</ContextMenuItem>
                                    <ContextMenuItem>Create Shortcut...</ContextMenuItem>
                                    <ContextMenuItem>Name Window...</ContextMenuItem>
                                    <ContextMenuSeparator />
                                    <ContextMenuItem>Developer Tools</ContextMenuItem>
                                    <ContextMenuSeparator />
                                    <ContextMenuItem Variant="destructive">Delete</ContextMenuItem>
                                </ContextMenuSubContent>
                            </ContextMenuSub>
                            <ContextMenuSeparator />
                            <ContextMenuCheckboxItem @bind-Checked="_showBookmarks">
                                Show Bookmarks
                            </ContextMenuCheckboxItem>
                            <ContextMenuCheckboxItem @bind-Checked="_showFullUrls">
                                Show Full URLs
                            </ContextMenuCheckboxItem>
                            <ContextMenuSeparator />
                            <ContextMenuRadioGroup>
                                <ContextMenuLabel Inset="true">People</ContextMenuLabel>
                                <ContextMenuRadioItem Selected="@IsPedroSelected" SelectedChanged="@(selected => OnPersonSelected("pedro", selected))">
                                    Pedro Duarte
                                </ContextMenuRadioItem>
                                <ContextMenuRadioItem Selected="@IsColmSelected" SelectedChanged="@(selected => OnPersonSelected("colm", selected))">
                                    Colm Tuite
                                </ContextMenuRadioItem>
                            </ContextMenuRadioGroup>
                        </Div>
                    </ContextMenuContent>
                </ContextMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu and shortcuts"
                         Description="Use nested actions and shortcuts for denser command palettes."
                         Code="@SubmenuCode"
                         CodeLanguage="razor">
                <ContextMenu>
                    <ContextMenuTrigger Class="flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm">
                        Right click for more tools
                    </ContextMenuTrigger>
                    <ContextMenuContent>
                        <Div Class="w-56">
                            <ContextMenuItem>
                                Save page
                                <ContextMenuShortcut>Ctrl+S</ContextMenuShortcut>
                            </ContextMenuItem>
                            <ContextMenuItem>
                                Duplicate tab
                                <ContextMenuShortcut>Ctrl+D</ContextMenuShortcut>
                            </ContextMenuItem>
                            <ContextMenuSub>
                                <ContextMenuSubTrigger>More tools</ContextMenuSubTrigger>
                                <ContextMenuSubContent Class="w-44">
                                    <ContextMenuItem>Downloads</ContextMenuItem>
                                    <ContextMenuItem>Task manager</ContextMenuItem>
                                    <ContextMenuSeparator />
                                    <ContextMenuItem>Developer tools</ContextMenuItem>
                                    <ContextMenuSeparator />
                                    <ContextMenuItem Variant="destructive">Delete tab</ContextMenuItem>
                                </ContextMenuSubContent>
                            </ContextMenuSub>
                        </Div>
                    </ContextMenuContent>
                </ContextMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkboxes"
                         Description="Checkbox items work well for toggles that can be enabled independently."
                         Code="@CheckboxCode"
                         CodeLanguage="razor">
                <ContextMenu>
                    <ContextMenuTrigger Class="flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm">
                        Right click for view options
                    </ContextMenuTrigger>
                    <ContextMenuContent>
                        <Div Class="w-56">
                            <ContextMenuLabel>View</ContextMenuLabel>
                            <ContextMenuSeparator />
                            <ContextMenuCheckboxItem @bind-Checked="_showBookmarks">
                                Show bookmarks bar
                            </ContextMenuCheckboxItem>
                            <ContextMenuCheckboxItem @bind-Checked="_showFullUrls">
                                Show full URLs
                            </ContextMenuCheckboxItem>
                            <ContextMenuCheckboxItem @bind-Checked="_showLineNumbers">
                                Show line numbers
                            </ContextMenuCheckboxItem>
                        </Div>
                    </ContextMenuContent>
                </ContextMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio items"
                         Description="Radio groups keep one active option selected while leaving room for destructive actions below."
                         Code="@RadioCode"
                         CodeLanguage="razor">
                <ContextMenu>
                    <ContextMenuTrigger Class="flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm">
                        Right click for layout choices
                    </ContextMenuTrigger>
                    <ContextMenuContent>
                        <Div Class="w-56">
                            <ContextMenuLabel>Density</ContextMenuLabel>
                            <ContextMenuSeparator />
                            <ContextMenuRadioGroup>
                                <ContextMenuRadioItem Selected="@IsComfortableSelected" SelectedChanged="@(selected => OnDensitySelected("comfortable", selected))">
                                    Comfortable
                                </ContextMenuRadioItem>
                                <ContextMenuRadioItem Selected="@IsCompactSelected" SelectedChanged="@(selected => OnDensitySelected("compact", selected))">
                                    Compact
                                </ContextMenuRadioItem>
                            </ContextMenuRadioGroup>
                            <ContextMenuSeparator />
                            <ContextMenuItem Variant="destructive">Delete project</ContextMenuItem>
                        </Div>
                    </ContextMenuContent>
                </ContextMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Context menus should also support right-to-left content and alignment."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div class="text-right">
                        <ContextMenu>
                            <ContextMenuTrigger Class="flex h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm">
                                انقر بزر الماوس الأيمن لعرض الإجراءات
                            </ContextMenuTrigger>
                            <ContextMenuContent>
                                <Div Class="w-52">
                                    <ContextMenuItem>رجوع</ContextMenuItem>
                                    <ContextMenuItem>إعادة تحميل</ContextMenuItem>
                                    <ContextMenuSeparator />
                                    <ContextMenuItem Variant="destructive">حذف</ContextMenuItem>
                                </Div>
                            </ContextMenuContent>
                        </ContextMenu>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _showBookmarks = true;
    private bool _showFullUrls;
    private bool _showLineNumbers = true;
    private string _selectedDensity = "comfortable";
    private string _selectedPerson = "pedro";
    private bool IsComfortableSelected => _selectedDensity == "comfortable";
    private bool IsCompactSelected => _selectedDensity == "compact";
    private bool IsPedroSelected => _selectedPerson == "pedro";
    private bool IsColmSelected => _selectedPerson == "colm";

    private void OnDensitySelected(string density, bool selected)
    {
        if (selected)
            _selectedDensity = density;
    }

    private void OnPersonSelected(string person, bool selected)
    {
        if (selected)
            _selectedPerson = person;
    }

    private const string BasicCode =
@"<ContextMenu>
