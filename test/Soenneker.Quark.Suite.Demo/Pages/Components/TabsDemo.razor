@page "/tabs"

<PageTitle>Tabs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="The shadcn account/password tabs layout using explicit list, trigger, and content composition."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div class="flex w-full max-w-sm flex-col gap-6">
                    <Tabs Composed="true" SelectedTab="account" Class="w-full max-w-sm">
                        <TabsList>
                            <TabsTrigger Value="account">Account</TabsTrigger>
                            <TabsTrigger Value="password">Password</TabsTrigger>
                        </TabsList>
                        <TabsContent Value="account">
                            <Card Class="mt-4">
                                <CardHeader>
                                    <CardTitle>Account</CardTitle>
                                    <CardDescription>
                                        Make changes to your account here. Click save when you're done.
                                    </CardDescription>
                                </CardHeader>
                                <CardContent Class="grid gap-6">
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-name">Name</Label>
                                        <Input Id="tabs-demo-name" Value="Pedro Duarte" />
                                    </Div>
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-username">Username</Label>
                                        <Input Id="tabs-demo-username" Value="@UsernameSample" />
                                    </Div>
                                </CardContent>
                                <CardFooter>
                                    <Button>Save changes</Button>
                                </CardFooter>
                            </Card>
                        </TabsContent>
                        <TabsContent Value="password">
                            <Card Class="mt-4">
                                <CardHeader>
                                    <CardTitle>Password</CardTitle>
                                    <CardDescription>
                                        Change your password here. After saving, you'll be logged out.
                                    </CardDescription>
                                </CardHeader>
                                <CardContent Class="grid gap-6">
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-current">Current password</Label>
                                        <Input Id="tabs-demo-current" Type="password" />
                                    </Div>
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-new">New password</Label>
                                        <Input Id="tabs-demo-new" Type="password" />
                                    </Div>
                                </CardContent>
                                <CardFooter>
                                    <Button>Save password</Button>
                                </CardFooter>
                            </Card>
                        </TabsContent>
                    </Tabs>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Alternate list styles, orientation, disabled tabs, icons, RTL, and controlled state.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Line"
                         Description="Use `TabsListVariant.Line` for the line-style trigger list."
                         Code="@LineCode"
                         CodeLanguage="razor">
                <Tabs TabsListVariant="TabsListVariant.Line" Class="w-[400px]">
                    <TabsList>
                        <TabsTrigger Value="overview">Overview</TabsTrigger>
                        <TabsTrigger Value="analytics">Analytics</TabsTrigger>
                        <TabsTrigger Value="reports">Reports</TabsTrigger>
                    </TabsList>
                    <TabsContent Value="overview">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Overview content.
                        </Div>
                    </TabsContent>
                    <TabsContent Value="analytics">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Analytics content.
                        </Div>
                    </TabsContent>
                    <TabsContent Value="reports">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Reports content.
                        </Div>
                    </TabsContent>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Render the triggers in a side rail."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Tabs Vertical="true" Class="w-full max-w-2xl">
                    <TabsList>
                        <TabsTrigger Value="account-vertical">Account</TabsTrigger>
                        <TabsTrigger Value="password-vertical">Password</TabsTrigger>
                        <TabsTrigger Value="notifications-vertical">Notifications</TabsTrigger>
                    </TabsList>
                    <TabsContent Value="account-vertical">
                        <Card>
                            <CardHeader>
                                <CardTitle>Account</CardTitle>
                                <CardDescription>Manage your profile and public details.</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <Paragraph Margin="Margin.Is0">This panel demonstrates vertical tab content.</Paragraph>
                            </CardContent>
                        </Card>
                    </TabsContent>
                    <TabsContent Value="password-vertical">
                        <Card>
                            <CardHeader>
                                <CardTitle>Password</CardTitle>
                                <CardDescription>Update authentication settings.</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <Paragraph Margin="Margin.Is0">Use the arrow keys to move between vertical tabs.</Paragraph>
                            </CardContent>
                        </Card>
                    </TabsContent>
                    <TabsContent Value="notifications-vertical">
                        <Card>
                            <CardHeader>
                                <CardTitle>Notifications</CardTitle>
                                <CardDescription>Choose which updates you want to receive.</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <Paragraph Margin="Margin.Is0">Vertical layout keeps the tab list visible beside the content.</Paragraph>
                            </CardContent>
                        </Card>
                    </TabsContent>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disabled triggers are skipped by keyboard navigation and cannot be selected."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Tabs Class="w-[400px]">
                    <TabsList>
                        <TabsTrigger Value="enabled">Enabled</TabsTrigger>
                        <TabsTrigger Value="disabled" Disabled="true">Disabled</TabsTrigger>
                        <TabsTrigger Value="active">Another enabled</TabsTrigger>
                    </TabsList>
                    <TabsContent Value="enabled">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            This tab can be selected normally.
                        </Div>
                    </TabsContent>
                    <TabsContent Value="disabled">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            This content is unreachable because the trigger is disabled.
                        </Div>
                    </TabsContent>
                    <TabsContent Value="active">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            This is another enabled tab.
                        </Div>
                    </TabsContent>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons"
                         Description="Tab triggers can include icons."
                         Code="@IconsCode"
                         CodeLanguage="razor">
                <Tabs Class="w-[420px]">
                    <TabsList>
                        <TabsTrigger Value="home-icon"><span data-icon="inline-start"><Icon Name="LucideIcon.House" /></span>Home</TabsTrigger>
                        <TabsTrigger Value="members-icon"><span data-icon="inline-start"><Icon Name="LucideIcon.Users" /></span>Members</TabsTrigger>
                        <TabsTrigger Value="settings-icon"><span data-icon="inline-start"><Icon Name="LucideIcon.Cog" /></span>Settings</TabsTrigger>
                    </TabsList>
                    <TabsContent Value="home-icon">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Home content with an icon in the trigger.
                        </Div>
                    </TabsContent>
                    <TabsContent Value="members-icon">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Members content with an icon in the trigger.
                        </Div>
                    </TabsContent>
                    <TabsContent Value="settings-icon">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Settings content with an icon in the trigger.
                        </Div>
                    </TabsContent>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Manual activation"
                         Description="Radix manual mode: arrow keys move focus; Space or Enter activates the focused tab (click still activates immediately)."
                         Code="@ManualActivationCode"
                         CodeLanguage="razor">
                <Tabs Composed="true"
                      ActivationMode="TabsActivationMode.Manual"
                      SelectedTab="ma-a"
                      Class="w-full max-w-sm">
                    <TabsList>
                        <TabsTrigger Value="ma-a">Tab A</TabsTrigger>
                        <TabsTrigger Value="ma-b">Tab B</TabsTrigger>
                    </TabsList>
                    <TabsContent Value="ma-a">
                        <Paragraph Margin="Margin.Is0" Class="mt-4 text-sm text-muted-foreground">Panel A — use arrows to move focus, then Space/Enter to show.</Paragraph>
                    </TabsContent>
                    <TabsContent Value="ma-b">
                        <Paragraph Margin="Margin.Is0" Class="mt-4 text-sm text-muted-foreground">Panel B</Paragraph>
                    </TabsContent>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Tabs respect inherited direction in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Tabs TabsListVariant="TabsListVariant.Line" Dir="rtl" Class="w-[400px]">
                        <TabsList>
                            <TabsTrigger Value="rtl-account">الحساب</TabsTrigger>
                            <TabsTrigger Value="rtl-password">كلمة المرور</TabsTrigger>
                        </TabsList>
                        <TabsContent Value="rtl-account">
                            <Div class="mt-4 rounded-md border border-border p-4 text-right text-sm text-muted-foreground">
                                مثال على علامات التبويب باتجاه من اليمين إلى اليسار.
                            </Div>
                        </TabsContent>
                        <TabsContent Value="rtl-password">
                            <Div class="mt-4 rounded-md border border-border p-4 text-right text-sm text-muted-foreground">
                                اتجاه المكوّن يورث بشكل صحيح من الحاوية.
                            </Div>
                        </TabsContent>
                    </Tabs>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Controlled tabs"
                         Description="@ControlledDescription"
                         Code="@ControlledCode"
                         CodeLanguage="razor">
                <Div class="space-y-4">
                    <Tabs SelectedTab="@_controlledTab" OnSelectedTabChanged="OnControlledTabChanged" Class="w-[400px]">
                        <TabsList>
                            <TabsTrigger Value="overview-controlled">Overview</TabsTrigger>
                            <TabsTrigger Value="activity-controlled">Activity</TabsTrigger>
                            <TabsTrigger Value="settings-controlled">Settings</TabsTrigger>
                        </TabsList>
                        <TabsContent Value="overview-controlled">
                            <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                                Parent-controlled content for Overview.
                            </Div>
                        </TabsContent>
                        <TabsContent Value="activity-controlled">
                            <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                                Parent-controlled content for Activity.
                            </Div>
                        </TabsContent>
                        <TabsContent Value="settings-controlled">
                            <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                                Parent-controlled content for Settings.
                            </Div>
                        </TabsContent>
                    </Tabs>
                    <Div class="flex flex-wrap gap-2">
                        <Button Size="ButtonSize.Sm" OnClick="SelectOverviewControlled">Overview</Button>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="SelectActivityControlled">Activity</Button>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="SelectSettingsControlled">Settings</Button>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

