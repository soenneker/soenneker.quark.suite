@page "/tabs"

<PageTitle>Tabs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="The shadcn account/password tabs layout using explicit list, trigger, and content composition."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div class="flex w-full max-w-sm flex-col gap-6">
                    <Tabs Composed="true" SelectedTab="account" Class="w-full max-w-sm">
                        <TabsList>
                            <TabsTrigger Value="account">Account</TabsTrigger>
                            <TabsTrigger Value="password">Password</TabsTrigger>
                        </TabsList>
                        <TabsContent Value="account">
                            <Card Class="mt-4">
                                <CardHeader>
                                    <CardTitle>Account</CardTitle>
                                    <CardDescription>
                                        Make changes to your account here. Click save when you're done.
                                    </CardDescription>
                                </CardHeader>
                                <CardBody Class="grid gap-6">
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-name">Name</Label>
                                        <Input Id="tabs-demo-name" Value="Pedro Duarte" />
                                    </Div>
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-username">Username</Label>
                                        <Input Id="tabs-demo-username" Value="@UsernameSample" />
                                    </Div>
                                </CardBody>
                                <CardFooter>
                                    <Button>Save changes</Button>
                                </CardFooter>
                            </Card>
                        </TabsContent>
                        <TabsContent Value="password">
                            <Card Class="mt-4">
                                <CardHeader>
                                    <CardTitle>Password</CardTitle>
                                    <CardDescription>
                                        Change your password here. After saving, you'll be logged out.
                                    </CardDescription>
                                </CardHeader>
                                <CardBody Class="grid gap-6">
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-current">Current password</Label>
                                        <Input Id="tabs-demo-current" Type="password" />
                                    </Div>
                                    <Div Class="grid gap-3">
                                        <Label For="tabs-demo-new">New password</Label>
                                        <Input Id="tabs-demo-new" Type="password" />
                                    </Div>
                                </CardBody>
                                <CardFooter>
                                    <Button>Save password</Button>
                                </CardFooter>
                            </Card>
                        </TabsContent>
                    </Tabs>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Alternate list styles, orientation, disabled tabs, icons, RTL, and controlled state.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Line"
                         Description="Use `TabsListVariant.Line` for the line-style trigger list."
                         Code="@LineCode"
                         CodeLanguage="razor">
                <Tabs TabsListVariant="TabsListVariant.Line" Class="w-[400px]">
                    <Tab Name="overview" Title="Overview">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Overview content.
                        </Div>
                    </Tab>
                    <Tab Name="analytics" Title="Analytics">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Analytics content.
                        </Div>
                    </Tab>
                    <Tab Name="reports" Title="Reports">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Reports content.
                        </Div>
                    </Tab>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Render the triggers in a side rail."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Tabs Vertical="true" Class="w-full max-w-2xl">
                    <Tab Name="account-vertical" Title="Account">
                        <Card>
                            <CardHeader>
                                <CardTitle>Account</CardTitle>
                                <CardDescription>Manage your profile and public details.</CardDescription>
                            </CardHeader>
                            <CardBody>
                                <Paragraph Margin="Margin.Is0">This panel demonstrates vertical tab content.</Paragraph>
                            </CardBody>
                        </Card>
                    </Tab>
                    <Tab Name="password-vertical" Title="Password">
                        <Card>
                            <CardHeader>
                                <CardTitle>Password</CardTitle>
                                <CardDescription>Update authentication settings.</CardDescription>
                            </CardHeader>
                            <CardBody>
                                <Paragraph Margin="Margin.Is0">Use the arrow keys to move between vertical tabs.</Paragraph>
                            </CardBody>
                        </Card>
                    </Tab>
                    <Tab Name="notifications-vertical" Title="Notifications">
                        <Card>
                            <CardHeader>
                                <CardTitle>Notifications</CardTitle>
                                <CardDescription>Choose which updates you want to receive.</CardDescription>
                            </CardHeader>
                            <CardBody>
                                <Paragraph Margin="Margin.Is0">Vertical layout keeps the tab list visible beside the content.</Paragraph>
                            </CardBody>
                        </Card>
                    </Tab>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disabled triggers are skipped by keyboard navigation and cannot be selected."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Tabs Class="w-[400px]">
                    <Tab Name="enabled" Title="Enabled">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            This tab can be selected normally.
                        </Div>
                    </Tab>
                    <Tab Name="disabled" Title="Disabled" Disabled="true">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            This content is unreachable because the trigger is disabled.
                        </Div>
                    </Tab>
                    <Tab Name="active" Title="Another enabled">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            This is another enabled tab.
                        </Div>
                    </Tab>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons"
                         Description="Tab triggers can include icons."
                         Code="@IconsCode"
                         CodeLanguage="razor">
                <Tabs Class="w-[420px]">
                    <Tab Name="home-icon" Title="Home" Icon="LucideIcon.House">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Home content with an icon in the trigger.
                        </Div>
                    </Tab>
                    <Tab Name="members-icon" Title="Members" Icon="LucideIcon.Users">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Members content with an icon in the trigger.
                        </Div>
                    </Tab>
                    <Tab Name="settings-icon" Title="Settings" Icon="LucideIcon.Cog">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Settings content with an icon in the trigger.
                        </Div>
                    </Tab>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Tabs respect inherited direction in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Tabs TabsListVariant="TabsListVariant.Line" Class="w-[400px]">
                        <Tab Name="rtl-account" Title="الحساب">
                            <Div class="mt-4 rounded-md border border-border p-4 text-right text-sm text-muted-foreground">
                                مثال على علامات التبويب باتجاه من اليمين إلى اليسار.
                            </Div>
                        </Tab>
                        <Tab Name="rtl-password" Title="كلمة المرور">
                            <Div class="mt-4 rounded-md border border-border p-4 text-right text-sm text-muted-foreground">
                                اتجاه المكوّن يورث بشكل صحيح من الحاوية.
                            </Div>
                        </Tab>
                    </Tabs>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Controlled tabs"
                         Description="@ControlledDescription"
                         Code="@ControlledCode"
                         CodeLanguage="razor">
                <Div class="space-y-4">
                    <Tabs SelectedTab="@_controlledTab" OnSelectedTabChanged="OnControlledTabChanged" Class="w-[400px]">
                        <Tab Name="overview-controlled" Title="Overview">
                            <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                                Parent-controlled content for Overview.
                            </Div>
                        </Tab>
                        <Tab Name="activity-controlled" Title="Activity">
                            <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                                Parent-controlled content for Activity.
                            </Div>
                        </Tab>
                        <Tab Name="settings-controlled" Title="Settings">
                            <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                                Parent-controlled content for Settings.
                            </Div>
                        </Tab>
                    </Tabs>
                    <Div class="flex flex-wrap gap-2">
                        <Button Size="ButtonSize.Sm" OnClick="SelectOverviewControlled">Overview</Button>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="SelectActivityControlled">Activity</Button>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="SelectSettingsControlled">Settings</Button>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

