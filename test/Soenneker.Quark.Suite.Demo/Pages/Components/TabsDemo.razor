    private const string ControlledCode = """
        <Tabs SelectedTab="_controlledTab" OnSelectedTabChanged="OnControlledTabChanged" Class="w-[400px]">
            <Tab Name="overview-controlled" Title="Overview">
                <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                    Parent-controlled content for Overview.
                </Div>
            </Tab>
            <Tab Name="activity-controlled" Title="Activity">
                <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                    Parent-controlled content for Activity.
                </Div>
            </Tab>
            <Tab Name="settings-controlled" Title="Settings">
                <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                    Parent-controlled content for Settings.
                </Div>
            </Tab>
        </Tabs>
        """;

    private const string DynamicCode = """
        <Tabs SelectedTab="_dynamicSelectedTab" OnSelectedTabChanged="OnDynamicTabChanged" Class="w-full max-w-2xl">
            @foreach (var tab in _dynamicTabs)
            {
                <Tab Name="@tab.Name" Title="@tab.Title">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        @tab.Content
                    </Div>
                </Tab>
            }
        </Tabs>
        """;

    private string _controlledTab = "overview-controlled";
    private string _dynamicSelectedTab = "release-1";
    private readonly List<DynamicTabModel> _dynamicTabs =
    [
        new("release-1", "Release 1", "Release 1 notes and rollout details."),
        new("release-2", "Release 2", "Release 2 notes and rollout details.")
    ];

    private int _dynamicCounter = 3;

    private sealed record DynamicTabModel(string Name, string Title, string Content);

    private Task OnControlledTabChanged(string tab)
    {
        _controlledTab = tab;
        return Task.CompletedTask;
    }

    private Task OnDynamicTabChanged(string tab)
    {
        _dynamicSelectedTab = tab;
        return Task.CompletedTask;
    }

    private Task SelectOverviewControlled()
    {
        _controlledTab = "overview-controlled";
        return Task.CompletedTask;
    }

    private Task SelectActivityControlled()
    {
        _controlledTab = "activity-controlled";
        return Task.CompletedTask;
    }

    private Task SelectSettingsControlled()
    {
        _controlledTab = "settings-controlled";
        return Task.CompletedTask;
    }

    private Task AddDynamicTab()
    {
        var name = $"release-{_dynamicCounter}";
        _dynamicTabs.Add(new DynamicTabModel(name, $"Release {_dynamicCounter}", $"Release {_dynamicCounter} notes and rollout details."));
        _dynamicSelectedTab = name;
        _dynamicCounter++;
        return Task.CompletedTask;
    }

    private Task RemoveDynamicTab()
    {
        if (_dynamicTabs.Count == 0)
            return Task.CompletedTask;

        _dynamicTabs.RemoveAt(_dynamicTabs.Count - 1);
        _dynamicSelectedTab = _dynamicTabs.Count > 0 ? _dynamicTabs[^1].Name : string.Empty;
        return Task.CompletedTask;
    }

    private Task ResetDynamicTabs()
    {
        _dynamicTabs.Clear();
        _dynamicTabs.Add(new DynamicTabModel("release-1", "Release 1", "Release 1 notes and rollout details."));
        _dynamicTabs.Add(new DynamicTabModel("release-2", "Release 2", "Release 2 notes and rollout details."));
        _dynamicSelectedTab = "release-1";
        _dynamicCounter = 3;
        return Task.CompletedTask;
    }
}
