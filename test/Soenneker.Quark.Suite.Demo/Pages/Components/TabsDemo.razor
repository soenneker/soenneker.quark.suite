@page "/tabs"

<PageTitle>Tabs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection Title="Line"
                     Description="Use `TabsListVariant.Line` for the line style shown in the shadcn docs."
                     Code="@LineCode"
                     CodeLanguage="razor">
            <Tabs TabsListVariant="TabsListVariant.Line" Class="w-[400px]">
                <Tab Name="overview" Title="Overview">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        Overview content.
                    </Div>
                </Tab>
                <Tab Name="analytics" Title="Analytics">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        Analytics content.
                    </Div>
                </Tab>
                <Tab Name="reports" Title="Reports">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        Reports content.
                    </Div>
                </Tab>
            </Tabs>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Vertical"
                     Description="Use `Vertical=true` to render the triggers on the side like the shadcn vertical example."
                     Code="@VerticalCode"
                     CodeLanguage="razor">
            <Tabs Vertical="true" Class="w-full max-w-2xl">
                <Tab Name="account-vertical" Title="Account">
                    <Card>
                        <CardHeader>
                            <CardTitle>Account</CardTitle>
                            <CardDescription>Manage your profile and public details.</CardDescription>
                        </CardHeader>
                        <CardBody>
                            <Paragraph Margin="Margin.Is0">This panel demonstrates vertical tab content.</Paragraph>
                        </CardBody>
                    </Card>
                </Tab>
                <Tab Name="password-vertical" Title="Password">
                    <Card>
                        <CardHeader>
                            <CardTitle>Password</CardTitle>
                            <CardDescription>Update authentication settings.</CardDescription>
                        </CardHeader>
                        <CardBody>
                            <Paragraph Margin="Margin.Is0">Use the arrow keys to move between vertical tabs.</Paragraph>
                        </CardBody>
                    </Card>
                </Tab>
                <Tab Name="notifications-vertical" Title="Notifications">
                    <Card>
                        <CardHeader>
                            <CardTitle>Notifications</CardTitle>
                            <CardDescription>Choose which updates you want to receive.</CardDescription>
                        </CardHeader>
                        <CardBody>
                            <Paragraph Margin="Margin.Is0">Vertical layout keeps the tab list visible beside the content.</Paragraph>
                        </CardBody>
                    </Card>
                </Tab>
            </Tabs>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Disabled"
                     Description="Disabled triggers are skipped by keyboard navigation and cannot be selected."
                     Code="@DisabledCode"
                     CodeLanguage="razor">
            <Tabs Class="w-[400px]">
                <Tab Name="enabled" Title="Enabled">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        This tab can be selected normally.
                    </Div>
                </Tab>
                <Tab Name="disabled" Title="Disabled" Disabled="true">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        This content is unreachable because the trigger is disabled.
                    </Div>
                </Tab>
                <Tab Name="active" Title="Another enabled">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        This is another enabled tab.
                    </Div>
                </Tab>
            </Tabs>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Icons"
                     Description="Set the `Icon` parameter to show the tabs-with-icons pattern from shadcn."
                     Code="@IconsCode"
                     CodeLanguage="razor">
            <Tabs Class="w-[420px]">
                <Tab Name="home-icon" Title="Home" Icon="LucideIcon.House">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        Home content with an icon in the trigger.
                    </Div>
                </Tab>
                <Tab Name="members-icon" Title="Members" Icon="LucideIcon.Users">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        Members content with an icon in the trigger.
                    </Div>
                </Tab>
                <Tab Name="settings-icon" Title="Settings" Icon="LucideIcon.Cog">
                    <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                        Settings content with an icon in the trigger.
                    </Div>
                </Tab>
            </Tabs>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="RTL"
                     Description="Tabs now respect inherited direction, so the shadcn RTL example is possible in Quark."
                     Code="@RtlCode"
                     CodeLanguage="razor">
            <DirectionProvider Dir="rtl">
                <Tabs TabsListVariant="TabsListVariant.Line" Class="w-[400px]">
                    <Tab Name="rtl-account" Title="الحساب">
                        <Div class="mt-4 rounded-md border border-border p-4 text-right text-sm text-muted-foreground">
                            مثال على علامات التبويب باتجاه من اليمين إلى اليسار.
                        </Div>
                    </Tab>
                    <Tab Name="rtl-password" Title="كلمة المرور">
                        <Div class="mt-4 rounded-md border border-border p-4 text-right text-sm text-muted-foreground">
                            اتجاه المكوّن الآن يُورث بشكل صحيح بدلاً من فرض `ltr`.
                        </Div>
                    </Tab>
                </Tabs>
            </DirectionProvider>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <Div Space="Space.Y.Is2">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                Account/password cards, parent-controlled selection, and dynamic tab lists.
            </Paragraph>
        </Div>

        <DemoSection Title="Account"
                     Description="Account and password panels inside tab content, common in form layouts."
                     Code="@AccountCode"
                     CodeLanguage="razor">
            <Tabs Class="w-[400px]">
                <Tab Name="account" Title="Account">
                    <Card Class="mt-4">
                        <CardHeader>
                            <CardTitle>Account</CardTitle>
                            <CardDescription>Make changes to your account here. Click save when you're done.</CardDescription>
                        </CardHeader>
                        <CardBody Class="space-y-4">
                            <Field>
                                <FieldLabel For="tabs-account-name">Name</FieldLabel>
                                <Input Id="tabs-account-name" Value="Pedro Duarte" />
                            </Field>
                            <Field>
                                <FieldLabel For="tabs-account-username">Username</FieldLabel>
                                <Input Id="tabs-account-username" Value="@UsernameSample" />
                            </Field>
                        </CardBody>
                        <CardFooter Class="justify-end">
                            <Button>Save changes</Button>
                        </CardFooter>
                    </Card>
                </Tab>
                <Tab Name="password" Title="Password">
                    <Card Class="mt-4">
                        <CardHeader>
                            <CardTitle>Password</CardTitle>
                            <CardDescription>Change your password here. After saving, you'll be logged out.</CardDescription>
                        </CardHeader>
                        <CardBody Class="space-y-4">
                            <Field>
                                <FieldLabel For="tabs-current-password">Current password</FieldLabel>
                                <Input Id="tabs-current-password" Type="password" />
                            </Field>
                            <Field>
                                <FieldLabel For="tabs-new-password">New password</FieldLabel>
                                <Input Id="tabs-new-password" Type="password" />
                            </Field>
                        </CardBody>
                        <CardFooter Class="justify-end">
                            <Button>Save password</Button>
                        </CardFooter>
                    </Card>
                </Tab>
            </Tabs>
        </DemoSection>

        <DemoSection Title="Controlled tabs"
                     Description="@($"Selected tab: {_controlledTab}.")"
                     Code="@ControlledCode"
                     CodeLanguage="razor">
            <Div class="space-y-4">
                <Tabs SelectedTab="_controlledTab" OnSelectedTabChanged="OnControlledTabChanged" Class="w-[400px]">
                    <Tab Name="overview-controlled" Title="Overview">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Parent-controlled content for Overview.
                        </Div>
                    </Tab>
                    <Tab Name="activity-controlled" Title="Activity">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Parent-controlled content for Activity.
                        </Div>
                    </Tab>
                    <Tab Name="settings-controlled" Title="Settings">
                        <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                            Parent-controlled content for Settings.
                        </Div>
                    </Tab>
                </Tabs>

                <Div class="flex flex-wrap gap-2">
                    <Button Size="ButtonSize.Sm" OnClick="SelectOverviewControlled">Overview</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="SelectActivityControlled">Activity</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="SelectSettingsControlled">Settings</Button>
                </Div>
            </Div>
        </DemoSection>

        <DemoSection Title="Dynamic tabs"
                     Description="@($"Add and remove tabs dynamically. Current count: {_dynamicTabs.Count}.")"
                     Code="@DynamicCode"
                     CodeLanguage="razor">
            <Div class="space-y-4">
                <Tabs SelectedTab="_dynamicSelectedTab" OnSelectedTabChanged="OnDynamicTabChanged" Class="w-full max-w-2xl">
                    @foreach (var tab in _dynamicTabs)
                    {
                        <Tab Name="@tab.Name" Title="@tab.Title">
                            <Div class="mt-4 rounded-md border border-border p-4 text-sm text-muted-foreground">
                                @tab.Content
                            </Div>
                        </Tab>
                    }
                </Tabs>

                <Div class="flex flex-wrap gap-2">
                    <Button Size="ButtonSize.Sm" OnClick="AddDynamicTab">Add tab</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="RemoveDynamicTab">Remove last</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="ResetDynamicTabs">Reset</Button>
                </Div>
            </Div>
        </DemoSection>
    </Section>
</Div>

