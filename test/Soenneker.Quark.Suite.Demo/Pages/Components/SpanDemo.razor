@page "/span-demo"

<PageTitle>Span - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is6">
        <DemoSection Title="Basic" Code="@(@"<Paragraph>Text with <Span>span inline</Span> in paragraph.</Paragraph>
<Span TextColor=""TextColor.Primary"">Styled span</Span>")">
            <Paragraph>Text with <Span>span elements</Span> for inline content.</Paragraph>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is6">
        <DemoSection Title="Colors & Font Styling" Description="TextColor, FontWeight, TextDecoration on Span." Code="@(@"<Span TextColor=""TextColor.Primary"">Primary</Span>
<Span TextColor=""TextColor.Accent"">Success</Span>
<Span FontWeight=""FontWeight.Bold"">Bold</Span>
<Span TextDecoration=""TextDecoration.Underline"">Underline</Span>")">
            <Div Space="Space.Y.Is2">
                <Paragraph>Colors: <Span TextColor="TextColor.Primary">Primary</Span> <Span TextColor="TextColor.Accent">Success</Span> <Span TextColor="TextColor.Destructive">Danger</Span></Paragraph>
                <Paragraph>Weights: <Span FontWeight="FontWeight.Light">Light</Span> <Span FontWeight="FontWeight.Bold">Bold</Span></Paragraph>
                <Paragraph Margin="Margin.Is0">Decoration: <Span TextDecoration="TextDecoration.Underline">Underline</Span> <Span TextDecoration="TextDecoration.LineThrough">Strikethrough</Span></Paragraph>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is6">
        <DemoSection Title="Forms & Badges" Description="Span for required indicator, character count, and tags." Code="@(@"<Label Form=""true"">Username <Span TextColor=""TextColor.Destructive"">*</Span></Label>
<Span Class=""rounded bg-green-600 px-2 py-0.5 text-white"">Active</Span>
<Span Class=""rounded bg-amber-500 px-2 py-0.5 text-white"">Beta</Span>")">
        <Div Space="Space.Y.Is4">
            <Div Space="Space.Y.Is1">
                <Label Form="true">Username <Span TextColor="TextColor.Destructive">*</Span></Label>
                <TextInput Id="span-username" Placeholder="Enter username" @bind-Value="_usernameValue" Class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm"/>
                <Small TextColor="TextColor.MutedForeground">Characters remaining: <Span TextColor="TextColor.Accent">@AvailableChars</Span></Small>
            </Div>
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                <Span Class="rounded bg-green-600 px-2 py-0.5 text-white">Active</Span>
                <Span Class="rounded bg-amber-500 px-2 py-0.5 text-white">Beta</Span>
                <Span Class="rounded bg-secondary px-2 py-0.5 text-white">Tag 1</Span>
            </Div>
        </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is6">
        <DemoSection Title="Interactive" Description="Span with onclick." Code="@(@"<Span TextColor=""TextColor.Primary"" Class=""cursor-pointer hover:underline"" @onclick=""HandleClick"">Click me</Span>")">
            <Paragraph>
                <Span TextColor="TextColor.Primary" Class="cursor-pointer hover:underline" @onclick="HandleClick" Title="Click me!">Click me</Span>
                <Span TextColor="TextColor.Accent" Class="ml-4 cursor-pointer hover:underline" @onclick="HandleClick2" Title="Click me too!">Click me too</Span>
            </Paragraph>
            <Small TextColor="TextColor.MutedForeground">Clicks: @_clickCount1, @_clickCount2</Small>
        </DemoSection>
    </Section>
</Div>

@code {
    private int _clickCount1;
    private int _clickCount2;
    private string _usernameValue = string.Empty;

    private int AvailableChars => Math.Max(0, 20 - (_usernameValue?.Length ?? 0));

    private void HandleClick(MouseEventArgs _) { _clickCount1++; StateHasChanged(); }
    private void HandleClick2(MouseEventArgs _) { _clickCount2++; StateHasChanged(); }
}
