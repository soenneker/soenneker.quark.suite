@page "/sheets"

<PageTitle>Sheet - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Extends the Dialog component to display content that complements the main content of the screen."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Sheet>
                    <SheetTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </SheetTrigger>
                    <SheetContent>
                        <SheetHeader>
                            <SheetTitle>Edit profile</SheetTitle>
                            <SheetDescription>
                                Make changes to your profile here. Click save when you're done.
                            </SheetDescription>
                        </SheetHeader>
                        <Div Class="grid flex-1 auto-rows-min gap-6 px-4">
                            <Div Display="Display.Grid" Gap="Gap.Is3">
                                <Label For="sheet-demo-name">Name</Label>
                                <Input Id="sheet-demo-name" Value="Pedro Duarte" />
                            </Div>
                            <Div Display="Display.Grid" Gap="Gap.Is3">
                                <Label For="sheet-demo-username">Username</Label>
                                <Input Id="sheet-demo-username" Value="@("@peduarte")" />
                            </Div>
                        </Div>
                        <SheetFooter>
                            <Button>Save changes</Button>
                            <SheetClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Close</Button>
                            </SheetClose>
                        </SheetFooter>
                    </SheetContent>
                </Sheet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Side variants, close-button changes, RTL layout, imperative visibility, and scrollable content.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Side"
                         Description="Sheets can slide in from top, right, bottom, or left via `Side`."
                         Code="@SidesCode"
                         CodeLanguage="razor">
                <Div Class="grid grid-cols-2 gap-2">
                    @foreach (var side in _sheetSides)
                    {
                        <Sheet>
                            <SheetTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">@side</Button>
                            </SheetTrigger>
                            <SheetContent Side="@side">
                                <SheetHeader>
                                    <SheetTitle>Edit profile</SheetTitle>
                                    <SheetDescription>
                                        Make changes to your profile here. Click save when you're done.
                                    </SheetDescription>
                                </SheetHeader>
                                <Div Display="Display.Grid" Gap="Gap.Is4" Padding="Padding.Is4.OnY">
                                    <Div Class="grid grid-cols-4 items-center gap-4">
                                        <Label For="@($"sheet-side-name-{side}")" TextAlign="TextAlign.End">
                                            Name
                                        </Label>
                                        <Input Id="@($"sheet-side-name-{side}")" Value="Pedro Duarte" Class="col-span-3" />
                                    </Div>
                                    <Div Class="grid grid-cols-4 items-center gap-4">
                                        <Label For="@($"sheet-side-username-{side}")" TextAlign="TextAlign.End">
                                            Username
                                        </Label>
                                        <Input Id="@($"sheet-side-username-{side}")" Value="@("@peduarte")" Class="col-span-3" />
                                    </Div>
                                </Div>
                                <SheetFooter>
                                    <SheetClose AsChild="true">
                                        <Button>Save changes</Button>
                                    </SheetClose>
                                </SheetFooter>
                            </SheetContent>
                        </Sheet>
                    }
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="No Close Button"
                         Description="Hide the sheet corner close control when dismissal uses footer actions only."
                         Code="@NoCloseCode"
                         CodeLanguage="razor">
                <Sheet>
                    <SheetTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">No Close Button</Button>
                    </SheetTrigger>
                    <SheetContent ShowCloseButton="false">
                        <SheetHeader>
                            <SheetTitle>No Close Button</SheetTitle>
                            <SheetDescription>
                                This sheet doesn't have a close button in the top-right corner. You can only close it using the button below.
                            </SheetDescription>
                        </SheetHeader>
                        <SheetFooter>
                            <SheetClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Close</Button>
                            </SheetClose>
                        </SheetFooter>
                    </SheetContent>
                </Sheet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Sheet chrome and content in a right-to-left context."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Sheet>
                            <SheetTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">افتح اللوحة</Button>
                            </SheetTrigger>
                            <SheetContent Side="left">
                                <SheetHeader>
                                    <SheetTitle>تعديل الملف الشخصي</SheetTitle>
                                    <SheetDescription>
                                        حدّث معلوماتك هنا ثم احفظ التغييرات.
                                    </SheetDescription>
                                </SheetHeader>
                                <Div class="grid flex-1 auto-rows-min gap-6 px-4">
                                    <Div Display="Display.Grid" Gap="Gap.Is3">
                                        <Label For="sheet-rtl-name">الاسم</Label>
                                        <Input Id="sheet-rtl-name" Value="Pedro Duarte" />
                                    </Div>
                                    <Div Display="Display.Grid" Gap="Gap.Is3">
                                        <Label For="sheet-rtl-username">اسم المستخدم</Label>
                                        <Input Id="sheet-rtl-username" Value="@("@peduarte")" />
                                    </Div>
                                </Div>
                                <SheetFooter>
                                    <Button>حفظ</Button>
                                    <SheetClose AsChild="true">
                                        <Button Variant="ButtonVariant.Outline">إغلاق</Button>
                                    </SheetClose>
                                </SheetFooter>
                            </SheetContent>
                        </Sheet>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable Content"
                         Description="Programmatically open a wide activity drawer with `Visible` binding."
                         Code="@ScrollableCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Outline" OnClick="@(() => _showScrollable = true)">Open activity drawer</Button>
            </DemoSection>
        </Section>
    </Div>
</Div>

<Sheet @bind-Visible="_showScrollable">
    <SheetContent Side="right">
        <SheetHeader>
            <SheetTitle>Recent activity</SheetTitle>
            <SheetDescription>
                Review a longer stream of events without leaving the current page.
            </SheetDescription>
        </SheetHeader>
        <Div Class="grid flex-1 gap-4 px-4">
            @for (var i = 1; i <= 12; i++)
            {
                <Div Class="rounded-lg border p-4">
                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Margin="Margin.Is0">Deployment @i</Paragraph>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Completed successfully and promoted to production.
                    </Paragraph>
                </Div>
            }
        </Div>
        <SheetFooter>
            <Button Variant="ButtonVariant.Outline" OnClick="@(() => _showScrollable = false)">Dismiss</Button>
            <Button OnClick="@(() => _showScrollable = false)">Review details</Button>
        </SheetFooter>
    </SheetContent>
</Sheet>

@code {
