                <SelectItem TValue=""string"" ItemValue=""@(""ar"")"" Text=""Arabic (العربية)"" />
                <SelectItem TValue=""string"" ItemValue=""@(""en"")"" Text=""English"" />
            </SelectContent>
        </Select>
        <Icon Name=""LucideIcon.Info"" Class=""size-4"" />
    </Div>
    <DirectionProvider Dir=""rtl"">
        <Div Width=""Width.IsFull"" Display=""Display.Flex"" Justify=""Justify.Center"">
        <Sheet>
            <SheetTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">فتح</Button>
            </SheetTrigger>
            <SheetContent Side=""Soenneker.Bradix.Side.Left"">
                <SheetHeader>
                    <SheetTitle>تعديل الملف الشخصي</SheetTitle>
                    <SheetDescription>
                        حدّث معلوماتك هنا ثم احفظ التغييرات.
                    </SheetDescription>
                </SheetHeader>
                <Div class=""grid flex-1 auto-rows-min gap-6 px-4"">
                    <Div class=""grid gap-3"">
                        <Label For=""sheet-rtl-name"">الاسم</Label>
                        <Input Id=""sheet-rtl-name"" Value=""Pedro Duarte"" />
                    </Div>
                    <Div class=""grid gap-3"">
                        <Label For=""sheet-rtl-username"">اسم المستخدم</Label>
                        <Input Id=""sheet-rtl-username"" Value=""@peduarte"" />
                    </Div>
                </Div>
                <SheetFooter>
                    <Button>حفظ</Button>
                    <SheetClose AsChild=""true"">
                        <Button Variant=""ButtonVariant.Outline"">إغلاق</Button>
                    </SheetClose>
                </SheetFooter>
            </SheetContent>
        </Sheet>
        </Div>
    </DirectionProvider>
</Div>";

    private const string NoCloseCode =
@"<Sheet>
    <SheetTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Sheet</Button>
    </SheetTrigger>
    <SheetContent ShowCloseButton=""false"">
        <SheetHeader>
            <SheetTitle>No Close Button</SheetTitle>
            <SheetDescription>
                This sheet doesn't have a close button in the top-right corner. You can only close it using the button below.
            </SheetDescription>
        </SheetHeader>
        <SheetFooter>
            <SheetClose AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">Close</Button>
            </SheetClose>
