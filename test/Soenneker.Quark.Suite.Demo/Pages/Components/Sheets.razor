@page "/components/sheet"

<PageTitle>Sheet - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Extends the Dialog component to display content that complements the main content of the screen."
                         Code="@DemoCode"
                         CodeLanguage="razor"
                         PreviewClass="@SheetPreviewClass">
                <Sheet>
                    <SheetTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </SheetTrigger>
                    <SheetContent>
                        <SheetHeader>
                            <SheetTitle>Edit profile</SheetTitle>
                            <SheetDescription>
                                Make changes to your profile here. Click save when you're done.
                            </SheetDescription>
                        </SheetHeader>
                        <Div Display="Display.Grid" Flex="Flex.Is1" Gap="Gap.Is6" Padding="Padding.Is4.OnX" Class="auto-rows-min">
                            <Div Display="Display.Grid" Gap="Gap.Is3">
                                <Label For="sheet-demo-name">Name</Label>
                                <Input Id="sheet-demo-name" Value="Pedro Duarte" />
                            </Div>
                            <Div Display="Display.Grid" Gap="Gap.Is3">
                                <Label For="sheet-demo-username">Username</Label>
                                <Input Id="sheet-demo-username" Value="@("@peduarte")" />
                            </Div>
                        </Div>
                        <SheetFooter>
                            <Button>Save changes</Button>
                            <SheetClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Close</Button>
                            </SheetClose>
                        </SheetFooter>
                    </SheetContent>
                </Sheet>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Side"
                         Description="Use the side prop on SheetContent to set the edge of the screen where the sheet appears. Values are top, right, bottom, or left."
                         Code="@SidesCode"
                         CodeLanguage="razor"
                         PreviewClass="@SheetPreviewClass">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is2">
                    @foreach (var side in _sheetSides)
                    {
                        <Sheet>
                            <SheetTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">@side</Button>
                            </SheetTrigger>
                            <SheetContent Side="@side">
                                <SheetHeader>
                                    <SheetTitle>Edit profile</SheetTitle>
                                    <SheetDescription>
                                        Make changes to your profile here. Click save when you're done.
                                    </SheetDescription>
                                </SheetHeader>
                                <Div Class="no-scrollbar overflow-y-auto px-4">
                                    @for (var i = 0; i < 10; i++)
                                    {
                                        <p class="mb-2 leading-relaxed">@LoremText</p>
                                    }
                                </Div>
                                <SheetFooter>
                                    <SheetClose AsChild="true">
                                        <Button>Save changes</Button>
                                    </SheetClose>
                                    <SheetClose AsChild="true">
                                        <Button Variant="ButtonVariant.Outline">Cancel</Button>
                                    </SheetClose>
                                </SheetFooter>
                            </SheetContent>
                        </Sheet>
                    }
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="No Close Button"
                         Description="Use showCloseButton={false} on SheetContent to hide the close button."
                         Code="@NoCloseCode"
                         CodeLanguage="razor"
                         PreviewClass="@SheetPreviewClass">
                <Sheet>
                    <SheetTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Sheet</Button>
                    </SheetTrigger>
                    <SheetContent ShowCloseButton="false">
                        <SheetHeader>
                            <SheetTitle>No Close Button</SheetTitle>
                            <SheetDescription>
                                This sheet doesn't have a close button in the top-right corner. Click outside to close.
                            </SheetDescription>
                        </SheetHeader>
                    </SheetContent>
                </Sheet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         PreviewClass="@SheetPreviewClass">
                <DirectionProvider Dir="rtl">
                    <Sheet>
                        <SheetTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">فتح</Button>
                        </SheetTrigger>
                        <SheetContent Side="Side.Left" dir="rtl">
                            <SheetHeader>
                                <SheetTitle>تعديل الملف الشخصي</SheetTitle>
                                <SheetDescription>
                                    قم بإجراء تغييرات على ملفك الشخصي هنا. انقر حفظ عند الانتهاء.
                                </SheetDescription>
                            </SheetHeader>
                            <FieldGroup Class="gap-5 px-4">
                                <Field>
                                    <FieldLabel For="sheet-rtl-name">الاسم</FieldLabel>
                                    <Input Id="sheet-rtl-name" Value="Pedro Duarte" />
                                </Field>
                                <Field>
                                    <FieldLabel For="sheet-rtl-username">اسم المستخدم</FieldLabel>
                                    <Input Id="sheet-rtl-username" Value="peduarte" />
                                </Field>
                            </FieldGroup>
                            <SheetFooter>
                                <Button>حفظ التغييرات</Button>
                                <SheetClose AsChild="true">
                                    <Button Variant="ButtonVariant.Outline">إغلاق</Button>
                                </SheetClose>
                            </SheetFooter>
                        </SheetContent>
                    </Sheet>
                </DirectionProvider>
            </DemoSection>
        </Section>

    </Div>
</Div>

@code {
    private const string SheetPreviewClass = "preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start";

    private readonly Side[] _sheetSides =
    [
        Side.Top,
        Side.Right,
        Side.Bottom,
        Side.Left
    ];

    private const string LoremText = "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.";

    private const string DemoCode =
@"<Sheet>
    <SheetTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open</Button>
    </SheetTrigger>
    <SheetContent>
        <SheetHeader>
            <SheetTitle>Edit profile</SheetTitle>
            <SheetDescription>
                Make changes to your profile here. Click save when you're done.
            </SheetDescription>
        </SheetHeader>
        <Div Display=""Display.Grid"" Flex=""Flex.Is1"" Gap=""Gap.Is6"" Padding=""Padding.Is4.OnX"" Class=""auto-rows-min"">
            <Div Display=""Display.Grid"" Gap=""Gap.Is3"">
                <Label For=""sheet-demo-name"">Name</Label>
                <Input Id=""sheet-demo-name"" Value=""Pedro Duarte"" />
            </Div>
            <Div Display=""Display.Grid"" Gap=""Gap.Is3"">
                <Label For=""sheet-demo-username"">Username</Label>
                <Input Id=""sheet-demo-username"" Value=""@(""@peduarte"")"" />
            </Div>
        </Div>
        <SheetFooter>
            <Button>Save changes</Button>
            <SheetClose AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">Close</Button>
            </SheetClose>
        </SheetFooter>
    </SheetContent>
</Sheet>";

    private const string SidesCode =
@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is2"">
    @foreach (var side in _sheetSides)
    {
        <Sheet>
            <SheetTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">@side</Button>
            </SheetTrigger>
            <SheetContent Side=""@side"">
                <SheetHeader>
                    <SheetTitle>Edit profile</SheetTitle>
                    <SheetDescription>
                        Make changes to your profile here. Click save when you're done.
                    </SheetDescription>
                </SheetHeader>
                <Div Class=""no-scrollbar overflow-y-auto px-4"">
                    @for (var i = 0; i < 10; i++)
                    {
                        <p class=""mb-2 leading-relaxed"">@LoremText</p>
                    }
                </Div>
                <SheetFooter>
                    <SheetClose AsChild=""true"">
                        <Button>Save changes</Button>
                    </SheetClose>
                    <SheetClose AsChild=""true"">
                        <Button Variant=""ButtonVariant.Outline"">Cancel</Button>
                    </SheetClose>
                </SheetFooter>
            </SheetContent>
        </Sheet>
    }
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Sheet>
        <SheetTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">فتح</Button>
        </SheetTrigger>
        <SheetContent Side=""Side.Left"" dir=""rtl"">
            <SheetHeader>
                <SheetTitle>تعديل الملف الشخصي</SheetTitle>
                <SheetDescription>
                    قم بإجراء تغييرات على ملفك الشخصي هنا. انقر حفظ عند الانتهاء.
                </SheetDescription>
            </SheetHeader>
            <FieldGroup Class=""gap-5 px-4"">
                <Field>
                    <FieldLabel For=""sheet-rtl-name"">الاسم</FieldLabel>
                    <Input Id=""sheet-rtl-name"" Value=""Pedro Duarte"" />
                </Field>
                <Field>
                    <FieldLabel For=""sheet-rtl-username"">اسم المستخدم</FieldLabel>
                    <Input Id=""sheet-rtl-username"" Value=""peduarte"" />
                </Field>
            </FieldGroup>
            <SheetFooter>
                <Button>حفظ التغييرات</Button>
                <SheetClose AsChild=""true"">
                    <Button Variant=""ButtonVariant.Outline"">إغلاق</Button>
                </SheetClose>
            </SheetFooter>
        </SheetContent>
    </Sheet>
</DirectionProvider>";

    private const string NoCloseCode =
@"<Sheet>
    <SheetTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Sheet</Button>
    </SheetTrigger>
    <SheetContent ShowCloseButton=""false"">
        <SheetHeader>
            <SheetTitle>No Close Button</SheetTitle>
            <SheetDescription>
                This sheet doesn't have a close button in the top-right corner. Click outside to close.
            </SheetDescription>
        </SheetHeader>
    </SheetContent>
</Sheet>";
}
