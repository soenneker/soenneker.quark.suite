@page "/scroll-area"

<PageTitle>Scroll Area - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Augments native scroll functionality for custom, cross-browser styling."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <ScrollArea Height='Height.Token("72")' Width='Width.Token("48")' Rounded="Rounded.Md" Border="Border.Default">
                    <Div Padding="Padding.Is4">
                        <H4 TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Margin="Margin.Is4.FromBottom" Leading="Leading.None">Tags</H4>
                        @for (var i = 0; i < _tags.Length; i++)
                        {
                            var index = i;

                            <Div TextSize="TextSize.Sm">@_tags[index]</Div>

                            @if (index < _tags.Length - 1)
                            {
                                <Separator Margin="Margin.Is2.OnY" />
                            }
                        }
                    </Div>
                </ScrollArea>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Horizontal"
                         Description="Horizontal scroll areas help showcase collections without forcing every item into a narrow grid."
                         Code="@HorizontalCode"
                         CodeLanguage="razor">
                <ScrollArea Width='Width.Token("96")' Rounded="Rounded.Md" Border="Border.Default" Whitespace="Whitespace.Nowrap" ShowHorizontalScrollBar="true">
                    <Div Display="Display.Flex" Width="Width.IsMax" Space="Space.X.Is4" Padding="Padding.Is4">
                        @foreach (var artwork in _works)
                        {
                            <Figure Shrink="Shrink.Is0">
                                <Div Overflow="Overflow.Hidden" Rounded="Rounded.Md">
                                    <Image Source="@artwork.Art" Alt="@($"Photo by {artwork.Artist}")" Width="300" Height="400" Class="aspect-[3/4] h-fit w-fit object-cover" />
                                </Div>
                                <Figcaption Class="pt-2 text-xs text-muted-foreground">
                                    Photo by <Span FontWeight="FontWeight.Semibold" TextColor="TextColor.Foreground">@artwork.Artist</Span>
                                </Figcaption>
                            </Figure>
                        }
                    </Div>
                </ScrollArea>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Scroll areas can also present content naturally in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <ScrollArea Height='Height.Token("72")' Width='Width.Token("48")' Rounded="Rounded.Md" Border="Border.Default" TextAlign="TextAlign.End" ForceMountScrollBars="true">
                        <Div Padding="Padding.Is4">
                            @for (var i = 0; i < _arabicNotes.Length; i++)
                            {
                                var index = i;

                                <Div Space="Space.Y.Is1">
                                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" Margin="Margin.Is0">@_arabicNotes[index].Title</Paragraph>
                                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">@_arabicNotes[index].Description</Paragraph>
                                </Div>

                                @if (index < _arabicNotes.Length - 1)
                                {
                                    <Separator Margin="Margin.Is4.OnY" />
                                }
                            }
                        </Div>
                    </ScrollArea>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private static readonly string[] _tags = Enumerable.Range(1, 50)
        .Select(index => $"v1.2.0-beta.{50 - index + 1}")
        .ToArray();

    private static readonly (string Artist, string Art)[] _works =
    [
        ("Ornella Binni", "https://images.unsplash.com/photo-1465869185982-5a1a7522cbcb?auto=format&fit=crop&w=300&q=80"),
        ("Tom Byrom", "https://images.unsplash.com/photo-1548516173-3cabfa4607e9?auto=format&fit=crop&w=300&q=80"),
        ("Vladimir Malyavko", "https://images.unsplash.com/photo-1494337480532-3725c85fd2ab?auto=format&fit=crop&w=300&q=80")
    ];

    private static readonly (string Title, string Description)[] _arabicNotes =
    [
        ("المصادقة", "تمت إضافة حماية إعادة تشغيل الجلسة وتدوير السر الافتراضي للكوكيز."),
        ("الفوترة", "تم تحسين تذكيرات الفواتير وآليات إعادة المحاولة للبطاقات المنتهية."),
        ("عمليات النشر", "تم تبسيط الموافقات وإضافة ملخص إنتاج أكثر هدوءًا."),
        ("المراقبة", "تم توسيع تصفية السجلات لتقليل ضوضاء الوظائف الخلفية."),
        ("المحرر", "تم تقليل تكلفة العرض الأولي للجداول الكبيرة وقوائم الأوامر.")
    ];

    private const string VerticalCode =
@"<ScrollArea Height='Height.Token(""72"")' Width='Width.Token(""48"")' Rounded=""Rounded.Md"" Border=""Border.Default"">
    <Div Padding=""Padding.Is4"">
        <H4 TextSize=""TextSize.Sm"" FontWeight=""FontWeight.Medium"" Margin=""Margin.Is4.FromBottom"" Leading=""Leading.None"">Tags</H4>
        @foreach (var tag in tags)
        {
            <Div TextSize=""TextSize.Sm"">@tag</Div>
            <Separator Margin=""Margin.Is2.OnY"" />
        }
    </Div>
</ScrollArea>";

    private const string HorizontalCode =
@"<ScrollArea Width='Width.Token(""96"")' Rounded=""Rounded.Md"" Border=""Border.Default"" Whitespace=""Whitespace.Nowrap"" ShowHorizontalScrollBar=""true"">
    <Div Display=""Display.Flex"" Width=""Width.IsMax"" Space=""Space.X.Is4"" Padding=""Padding.Is4"">
        @foreach (var artwork in works)
        {
            <Figure Shrink=""Shrink.Is0"">
                <Div Overflow=""Overflow.Hidden"" Rounded=""Rounded.Md"">
                    <Image Source=""@artwork.Art"" Alt=""@($""Photo by {artwork.Artist}"")"" Width=""300"" Height=""400"" Class=""aspect-[3/4] h-fit w-fit object-cover"" />
                </Div>
                <Figcaption Class=""pt-2 text-xs text-muted-foreground"">
                    Photo by <Span FontWeight=""FontWeight.Semibold"" TextColor=""TextColor.Foreground"">@artwork.Artist</Span>
                </Figcaption>
            </Figure>
        }
    </Div>
</ScrollArea>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <ScrollArea Height='Height.Token(""72"")' Width='Width.Token(""48"")' Rounded=""Rounded.Md"" Border=""Border.Default"" TextAlign=""TextAlign.End"" ForceMountScrollBars=""true"">
        <Div Padding=""Padding.Is4"">
            @foreach (var note in arabicNotes)
            {
                <Div Class=""space-y-1"">...</Div>
                <Separator Margin=""Margin.Is4.OnY"" />
            }
        </Div>
    </ScrollArea>
</DirectionProvider>";
}
