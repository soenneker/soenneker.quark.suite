@page "/paginations"

<PageTitle>Paginations - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Simple" Description="@_basicDescription"
                        Code="@(@"<Pagination>
    <PaginationItem Disabled=""@(currentPage == 1)"">
        <PaginationLink OnClick=""@(() => GoToPage(1))"">Previous</PaginationLink>
    </PaginationItem>
    ...
</Pagination>")">
                <Pagination>
            <PaginationItem Disabled="@(_currentPage == 1)">
                <PaginationLink OnClick="@(() => GoToPage(1))">Previous</PaginationLink>
            </PaginationItem>
            <PaginationItem Active="@(_currentPage == 1)">
                <PaginationLink OnClick="@(() => GoToPage(1))">1</PaginationLink>
            </PaginationItem>
            <PaginationItem Active="@(_currentPage == 2)">
                <PaginationLink OnClick="@(() => GoToPage(2))">2</PaginationLink>
            </PaginationItem>
            <PaginationItem Active="@(_currentPage == 3)">
                <PaginationLink OnClick="@(() => GoToPage(3))">3</PaginationLink>
            </PaginationItem>
            <PaginationItem Disabled="@(_currentPage == 3)">
                <PaginationLink OnClick="@(() => GoToPage(_currentPage + 1))">Next</PaginationLink>
            </PaginationItem>
        </Pagination>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons Only" Description="Use compact icon labels when the surrounding UI already provides pagination context.">
                <Pagination>
                    <PaginationItem Disabled="true">
                        <PaginationLink aria-label="Previous page">‹</PaginationLink>
                    </PaginationItem>
                    <PaginationItem Active="true">
                        <PaginationLink>1</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink>2</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink aria-label="Next page">›</PaginationLink>
                    </PaginationItem>
                </Pagination>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Different current pages" Description="Page 1, 3, and 5 of 5 examples." Code="@(@"<Pagination>
    <PaginationItem Disabled=""true""><PaginationLink>Previous</PaginationLink></PaginationItem>
    <PaginationItem Active=""true""><PaginationLink>1</PaginationLink></PaginationItem>
    <PaginationItem><PaginationLink>2</PaginationLink></PaginationItem>
    <PaginationItem><PaginationLink>3</PaginationLink></PaginationItem>
    <PaginationItem><PaginationLink>Next</PaginationLink></PaginationItem>
</Pagination>")">
                <Div Space="Space.Y.Is4">
                    <Div>
                        <H5 TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.MutedForeground">Page 1 of 5</H5>
                        <Pagination>
            <PaginationItem Disabled="true">
                <PaginationLink>Previous</PaginationLink>
            </PaginationItem>
            <PaginationItem Active="true">
                <PaginationLink>1</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>2</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>3</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>4</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>5</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>Next</PaginationLink>
            </PaginationItem>
        </Pagination>
                    </Div>
                    <Div Margin="Margin.Is3.FromEnd">
                        <H5 TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.MutedForeground">Page 3 of 5</H5>
                        <Pagination>
            <PaginationItem>
                <PaginationLink>Previous</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>1</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>2</PaginationLink>
            </PaginationItem>
            <PaginationItem Active="true">
                <PaginationLink>3</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>4</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>5</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>Next</PaginationLink>
            </PaginationItem>
        </Pagination>
                    </Div>
                    <Div>
                        <H5 TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.MutedForeground">Page 5 of 5</H5>
                        <Pagination>
            <PaginationItem>
                <PaginationLink>Previous</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>1</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>2</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>3</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>4</PaginationLink>
            </PaginationItem>
            <PaginationItem Active="true">
                <PaginationLink>5</PaginationLink>
            </PaginationItem>
            <PaginationItem Disabled="true">
                <PaginationLink>Next</PaginationLink>
            </PaginationItem>
        </Pagination>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

