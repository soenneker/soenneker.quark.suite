@page "/paginations"

<PageTitle>Paginations - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Pagination with page navigation, next and previous links."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Pagination>
                    <PaginationContent>
                        <PaginationItem>
                            <PaginationPrevious To="#" />
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#">1</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#" Active="true">2</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#">3</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationEllipsis />
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationNext To="#" />
                        </PaginationItem>
                    </PaginationContent>
                </Pagination>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="Simple"
                         Description="Use only page-number links when adjacent UI already provides the pagination context."
                         Code="@SimpleCode"
                         CodeLanguage="razor">
                <Pagination>
                    <PaginationContent>
                        <PaginationItem>
                            <PaginationLink>1</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink Active="true">2</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink>3</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink>4</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink>5</PaginationLink>
                        </PaginationItem>
                    </PaginationContent>
                </Pagination>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons Only"
                         Description="Use only previous and next controls when a table or page-size selector provides the rest of the context."
                         Code="@IconsOnlyCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Gap="Gap.Is4">
                    <Field Width="Width.IsFit">
                        <FieldLabel For="rows-per-page">Rows per page</FieldLabel>
                        <Select TValue="string" SelectedValue="@("25")">
                            <SelectTrigger Id="rows-per-page" Width='Width.Token("20")'>
                                <SelectValue Placeholder="25" />
                            </SelectTrigger>
                            <SelectContent Align="Alignment.Start">
                                <SelectItem TValue="string" ItemValue="@("10")" Text="10" />
                                <SelectItem TValue="string" ItemValue="@("25")" Text="25" />
                                <SelectItem TValue="string" ItemValue="@("50")" Text="50" />
                                <SelectItem TValue="string" ItemValue="@("100")" Text="100" />
                            </SelectContent>
                        </Select>
                    </Field>
                    <Pagination Margin="Margin.Is0.OnX" Width="Width.Auto">
                        <PaginationContent>
                            <PaginationItem>
                                <PaginationPrevious />
                            </PaginationItem>
                            <PaginationItem>
                                <PaginationNext />
                            </PaginationItem>
                        </PaginationContent>
                    </Pagination>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="The previous and next icons flip correctly in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Id="pagination-rtl-demo" Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Pagination>
                            <PaginationContent>
                                <PaginationItem>
                                    <PaginationPrevious Text="السابق" />
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationLink>١</PaginationLink>
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationLink Active="true">٢</PaginationLink>
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationLink>٣</PaginationLink>
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationNext Text="التالي" />
                                </PaginationItem>
                            </PaginationContent>
                        </Pagination>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Interactive"
                         Description="@($"Click to change page; current page {_currentPage} of 5.")"
                         Code="@InteractiveCode"
                         CodeLanguage="razor">
                <Div Id="pagination-interactive-demo">
                    <Pagination>
                        <PaginationContent>
                            <PaginationItem>
                                <PaginationPrevious Id="pagination-interactive-previous" Disabled="@(_currentPage == 1)" OnClick="@(() => GoToPage(_currentPage - 1))" />
                            </PaginationItem>
                            @for (var i = 1; i <= 5; i++)
                            {
                                var pageNumber = i;
                                <PaginationItem>
                                    <PaginationLink Id="@($"pagination-interactive-page-{pageNumber}")" Active="@(_currentPage == pageNumber)" OnClick="@(() => GoToPage(pageNumber))">@pageNumber</PaginationLink>
                                </PaginationItem>
                            }
                            <PaginationItem>
                                <PaginationNext Id="pagination-interactive-next" Disabled="@(_currentPage == 5)" OnClick="@(() => GoToPage(_currentPage + 1))" />
                            </PaginationItem>
                        </PaginationContent>
                    </Pagination>
                    <Div Margin="Margin.Is4.FromTop" Display="Display.Flex" FlexWrap="FlexWrap.Wrap" ItemsAlign="Items.Center" Gap="Gap.Is2">
                        <Paragraph Id="pagination-interactive-state" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Current page: <Strong>@_currentPage</Strong> of 5</Paragraph>
                        <Button Id="pagination-interactive-first" Size="ButtonSize.Sm" OnClick="@(() => GoToPage(1))">Go to First</Button>
                        <Button Id="pagination-interactive-last" Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="@(() => GoToPage(5))">Go to Last</Button>
                        <Button Id="pagination-interactive-random" Variant="ButtonVariant.Secondary" Size="ButtonSize.Sm" OnClick="@GoToRandomPage">Random Page</Button>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Pagination>
    <PaginationContent>
        <PaginationItem>
            <PaginationPrevious To=""#"" />
        </PaginationItem>
        <PaginationItem>
            <PaginationLink To=""#"">1</PaginationLink>
        </PaginationItem>
        <PaginationItem>
            <PaginationLink To=""#"" Active=""true"">2</PaginationLink>
        </PaginationItem>
        <PaginationItem>
            <PaginationLink To=""#"">3</PaginationLink>
        </PaginationItem>
        <PaginationItem>
            <PaginationEllipsis />
        </PaginationItem>
        <PaginationItem>
            <PaginationNext To=""#"" />
        </PaginationItem>
    </PaginationContent>
</Pagination>";

    private const string SimpleCode =
@"<Pagination>
    <PaginationContent>
        <PaginationItem>
            <PaginationLink>1</PaginationLink>
        </PaginationItem>
        <PaginationItem>
            <PaginationLink Active=""true"">2</PaginationLink>
        </PaginationItem>
        <PaginationItem>
            <PaginationLink>3</PaginationLink>
        </PaginationItem>
        <PaginationItem>
            <PaginationLink>4</PaginationLink>
        </PaginationItem>
        <PaginationItem>
            <PaginationLink>5</PaginationLink>
        </PaginationItem>
    </PaginationContent>
</Pagination>";

    private const string IconsOnlyCode =
@"<Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Justify=""Justify.Between"" Gap=""Gap.Is4"">
    <Field Width=""Width.IsFit"">
        <FieldLabel For=""rows-per-page"">Rows per page</FieldLabel>
        <Select TValue=""string"" SelectedValue=""@(""25"")"">
            <SelectTrigger Id=""rows-per-page"" Width='Width.Token(""20"")'>
                <SelectValue Placeholder=""25"" />
            </SelectTrigger>
            <SelectContent Align=""Alignment.Start"">
                <SelectItem TValue=""string"" ItemValue=""@(""10"")"" Text=""10"" />
                <SelectItem TValue=""string"" ItemValue=""@(""25"")"" Text=""25"" />
                <SelectItem TValue=""string"" ItemValue=""@(""50"")"" Text=""50"" />
                <SelectItem TValue=""string"" ItemValue=""@(""100"")"" Text=""100"" />
            </SelectContent>
        </Select>
    </Field>
    <Pagination Margin=""Margin.Is0.OnX"" Width=""Width.Auto"">
        <PaginationContent>
            <PaginationItem>
                <PaginationPrevious />
            </PaginationItem>
            <PaginationItem>
                <PaginationNext />
            </PaginationItem>
        </PaginationContent>
    </Pagination>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Width=""Width.IsFull"" TextAlign=""TextAlign.End"">
        <Pagination>
            <PaginationContent>
                <PaginationItem>
                    <PaginationPrevious Text=""السابق"" />
                </PaginationItem>
                <PaginationItem>
                    <PaginationLink>١</PaginationLink>
                </PaginationItem>
                <PaginationItem>
                    <PaginationLink Active=""true"">٢</PaginationLink>
                </PaginationItem>
                <PaginationItem>
                    <PaginationLink>٣</PaginationLink>
                </PaginationItem>
                <PaginationItem>
                    <PaginationNext Text=""التالي"" />
                </PaginationItem>
            </PaginationContent>
        </Pagination>
    </Div>
</DirectionProvider>";

    private const string InteractiveCode =
@"<Pagination>
    <PaginationContent>
        <PaginationItem>
            <PaginationPrevious Disabled=""@(_currentPage == 1)"" OnClick=""@(() => GoToPage(_currentPage - 1))"" />
        </PaginationItem>
        @for (var i = 1; i <= 5; i++)
        {
            <PaginationItem>
                <PaginationLink Active=""@(_currentPage == i)"" OnClick=""@(() => GoToPage(i))"">@i</PaginationLink>
            </PaginationItem>
        }
        <PaginationItem>
            <PaginationNext Disabled=""@(_currentPage == 5)"" OnClick=""@(() => GoToPage(_currentPage + 1))"" />
        </PaginationItem>
    </PaginationContent>
</Pagination>";

    private int _currentPage = 1;

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= 5)
        {
            _currentPage = page;
            StateHasChanged();
        }
    }

    private void GoToRandomPage()
    {
        var random = new Random();
        _currentPage = random.Next(1, 6);
        StateHasChanged();
    }
}
