@page "/paginations"

<PageTitle>Paginations - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Code="@DemoCode">
                <Pagination>
                    <PaginationPrevious Disabled="true" />
                    <PaginationItem>
                        <PaginationLink>1</PaginationLink>
                    </PaginationItem>
                    <PaginationItem Active="true">
                        <PaginationLink Active="true">2</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink>3</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationEllipsis />
                    </PaginationItem>
                    <PaginationNext />
                </Pagination>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Simple"
                         Description="Use only page-number links when adjacent UI already provides the pagination context."
                         Code="@SimpleCode">
                <Pagination>
                    <PaginationItem>
                        <PaginationLink>1</PaginationLink>
                    </PaginationItem>
                    <PaginationItem Active="true">
                        <PaginationLink Active="true">2</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink>3</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink>4</PaginationLink>
                    </PaginationItem>
                    <PaginationItem>
                        <PaginationLink>5</PaginationLink>
                    </PaginationItem>
                </Pagination>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons Only"
                         Description="Use only previous and next controls when a table or page-size selector provides the rest of the context."
                         Code="@IconsOnlyCode">
                <Div Class="flex items-center justify-between gap-4">
                    <Field class="w-fit">
                        <FieldLabel For="rows-per-page">Rows per page</FieldLabel>
                        <Select TValue="string" SelectedValue="@("25")">
                            <SelectTrigger Id="rows-per-page" Class="w-20">
                                <SelectValue Placeholder="25" />
                            </SelectTrigger>
                            <SelectContent Align="start">
                                <SelectItem TValue="string" ItemValue="@("10")" Text="10" />
                                <SelectItem TValue="string" ItemValue="@("25")" Text="25" />
                                <SelectItem TValue="string" ItemValue="@("50")" Text="50" />
                                <SelectItem TValue="string" ItemValue="@("100")" Text="100" />
                            </SelectContent>
                        </Select>
                    </Field>
                    <Pagination Class="mx-0 w-auto">
                        <PaginationPrevious />
                        <PaginationNext />
                    </Pagination>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="The previous and next icons flip correctly in right-to-left layouts."
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <Div class="w-full text-right">
                        <Pagination>
                            <PaginationPrevious Text="السابق" />
                            <PaginationItem>
                                <PaginationLink>١</PaginationLink>
                            </PaginationItem>
                            <PaginationItem Active="true">
                                <PaginationLink Active="true">٢</PaginationLink>
                            </PaginationItem>
                            <PaginationItem>
                                <PaginationLink>٣</PaginationLink>
                            </PaginationItem>
                            <PaginationNext Text="التالي" />
                        </Pagination>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show Quark-specific interactive patterns beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Interactive"
                         Description="@($"Click to change page; current page {_currentPage} of 5.")"
                         Code="@InteractiveCode">
                <Pagination>
                    <PaginationPrevious Disabled="@(_currentPage == 1)" OnClick="@(() => GoToPage(_currentPage - 1))" />
                    @for (var i = 1; i <= 5; i++)
                    {
                        <PaginationItem Active="@(_currentPage == i)">
                            <PaginationLink Active="@(_currentPage == i)" OnClick="@(() => GoToPage(i))">@i</PaginationLink>
                        </PaginationItem>
                    }
                    <PaginationNext Disabled="@(_currentPage == 5)" OnClick="@(() => GoToPage(_currentPage + 1))" />
                </Pagination>
                <Div Class="flex flex-wrap gap-2 items-center mt-4">
                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Current page: <Strong>@_currentPage</Strong> of 5</Paragraph>
                    <Button Size="ButtonSize.Sm" OnClick="@(() => GoToPage(1))">Go to First</Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="@(() => GoToPage(5))">Go to Last</Button>
                    <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Sm" OnClick="@GoToRandomPage">Random Page</Button>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Pagination>
    <PaginationPrevious Disabled=""true"" />
    <PaginationItem>
        <PaginationLink>1</PaginationLink>
    </PaginationItem>
    <PaginationItem Active=""true"">
        <PaginationLink Active=""true"">2</PaginationLink>
    </PaginationItem>
    <PaginationItem>
        <PaginationLink>3</PaginationLink>
    </PaginationItem>
    <PaginationItem>
        <PaginationEllipsis />
    </PaginationItem>
    <PaginationNext />
</Pagination>";

    private const string SimpleCode =
@"<Pagination>
    <PaginationItem>
        <PaginationLink>1</PaginationLink>
    </PaginationItem>
    <PaginationItem Active=""true"">
        <PaginationLink Active=""true"">2</PaginationLink>
    </PaginationItem>
    <PaginationItem>
        <PaginationLink>3</PaginationLink>
    </PaginationItem>
    <PaginationItem>
        <PaginationLink>4</PaginationLink>
    </PaginationItem>
    <PaginationItem>
        <PaginationLink>5</PaginationLink>
    </PaginationItem>
</Pagination>";

    private const string IconsOnlyCode =
@"<Div Class=""flex items-center justify-between gap-4"">
    <Field class=""w-fit"">
        <FieldLabel For=""rows-per-page"">Rows per page</FieldLabel>
        <Select TValue=""string"" SelectedValue=""@(""25"")"">
            <SelectTrigger Id=""rows-per-page"" Class=""w-20"">
                <SelectValue Placeholder=""25"" />
            </SelectTrigger>
            <SelectContent Align=""start"">
                <SelectItem TValue=""string"" ItemValue=""@(""10"")"" Text=""10"" />
                <SelectItem TValue=""string"" ItemValue=""@(""25"")"" Text=""25"" />
                <SelectItem TValue=""string"" ItemValue=""@(""50"")"" Text=""50"" />
                <SelectItem TValue=""string"" ItemValue=""@(""100"")"" Text=""100"" />
            </SelectContent>
        </Select>
    </Field>
    <Pagination Class=""mx-0 w-auto"">
        <PaginationPrevious />
        <PaginationNext />
    </Pagination>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div class=""w-full text-right"">
        <Pagination>
            <PaginationPrevious Text=""السابق"" />
            <PaginationItem>
                <PaginationLink>١</PaginationLink>
            </PaginationItem>
            <PaginationItem Active=""true"">
                <PaginationLink Active=""true"">٢</PaginationLink>
            </PaginationItem>
            <PaginationItem>
                <PaginationLink>٣</PaginationLink>
            </PaginationItem>
            <PaginationNext Text=""التالي"" />
        </Pagination>
    </Div>
</DirectionProvider>";

    private const string InteractiveCode =
@"<Pagination>
    <PaginationPrevious Disabled=""@(_currentPage == 1)"" OnClick=""@(() => GoToPage(_currentPage - 1))"" />
    @for (var i = 1; i <= 5; i++)
    {
        <PaginationItem Active=""@(_currentPage == i)"">
            <PaginationLink Active=""@(_currentPage == i)"" OnClick=""@(() => GoToPage(i))"">@i</PaginationLink>
        </PaginationItem>
    }
    <PaginationNext Disabled=""@(_currentPage == 5)"" OnClick=""@(() => GoToPage(_currentPage + 1))"" />
</Pagination>";

    private int _currentPage = 1;

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= 5)
        {
            _currentPage = page;
            StateHasChanged();
        }
    }

    private void GoToRandomPage()
    {
        var random = new Random();
        _currentPage = random.Next(1, 6);
        StateHasChanged();
    }
}
