@page "/paginations"

<PageTitle>Pagination - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Pagination with page navigation, next and previous links."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Pagination>
                    <PaginationContent>
                        <PaginationItem>
                            <PaginationPrevious To="#" />
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#">1</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#" Active="true">2</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#">3</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationEllipsis />
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationNext To="#" />
                        </PaginationItem>
                    </PaginationContent>
                </Pagination>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Simple"
                         Description="A simple pagination with only page numbers."
                         Code="@SimpleCode"
                         CodeLanguage="razor">
                <Pagination>
                    <PaginationContent>
                        <PaginationItem>
                            <PaginationLink To="#">1</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#" Active="true">2</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#">3</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#">4</PaginationLink>
                        </PaginationItem>
                        <PaginationItem>
                            <PaginationLink To="#">5</PaginationLink>
                        </PaginationItem>
                    </PaginationContent>
                </Pagination>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons Only"
                         Description="Use just the previous and next buttons without page numbers. This is useful for data tables with a rows per page selector."
                         Code="@IconsOnlyCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Gap="Gap.Is4">
                    <Field Width="Width.IsFit">
                        <FieldLabel For="rows-per-page">Rows per page</FieldLabel>
                        <Select TValue="string" SelectedValue="@("25")">
                            <SelectTrigger Id="rows-per-page" Width='Width.Token("20")'>
                                <SelectValue Placeholder="25" />
                            </SelectTrigger>
                            <SelectContent Align="Alignment.Start">
                                <SelectItem TValue="string" ItemValue="@("10")" Text="10" />
                                <SelectItem TValue="string" ItemValue="@("25")" Text="25" />
                                <SelectItem TValue="string" ItemValue="@("50")" Text="50" />
                                <SelectItem TValue="string" ItemValue="@("100")" Text="100" />
                            </SelectContent>
                        </Select>
                    </Field>
                    <Pagination Margin="Margin.Is0.OnX" Width="Width.Auto">
                        <PaginationContent>
                            <PaginationItem>
                                <PaginationPrevious To="#" />
                            </PaginationItem>
                            <PaginationItem>
                                <PaginationNext To="#" />
                            </PaginationItem>
                        </PaginationContent>
                    </Pagination>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="The previous and next icons flip correctly in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Id="pagination-rtl-demo" Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Pagination>
                            <PaginationContent>
                                <PaginationItem>
                                    <PaginationPrevious To="#" />
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationLink To="#">١</PaginationLink>
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationLink To="#" Active="true">٢</PaginationLink>
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationLink To="#">٣</PaginationLink>
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationEllipsis />
                                </PaginationItem>
                                <PaginationItem>
                                    <PaginationNext To="#" />
                                </PaginationItem>
                            </PaginationContent>
                        </Pagination>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Pagination>
    <PaginationContent>
