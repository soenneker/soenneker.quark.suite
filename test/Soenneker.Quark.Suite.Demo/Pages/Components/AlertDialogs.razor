@page "/alert-dialogs"

<PageTitle>Alert Dialogs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
                     Description="A modal dialog that interrupts the user with important content and expects a response."
                     Code="@DefaultCode"
                     CodeLanguage="razor">
            <AlertDialog @bind-Visible="_showDefaultAlert" CloseOnBackdropClick="false">
                <AlertDialogTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Outline">Show Dialog</Button>
                </AlertDialogTrigger>
                <AlertDialogContent>
                    <AlertDialogHeader>
                        <AlertDialogTitle>Are you absolutely sure?</AlertDialogTitle>
                        <AlertDialogDescription>
                            This action cannot be undone. This will permanently delete your account from our servers.
                        </AlertDialogDescription>
                    </AlertDialogHeader>
                    <AlertDialogFooter>
                        <AlertDialogCancel>Cancel</AlertDialogCancel>
                        <AlertDialogAction OnAction="HandleContinue">Continue</AlertDialogAction>
                    </AlertDialogFooter>
                </AlertDialogContent>
            </AlertDialog>
        </DemoSection>

        <DemoSection Title="Basic"
                     Description="A basic alert dialog with a title, description, and cancel and continue buttons."
                     Code="@BasicCode"
                     CodeLanguage="razor">
            <AlertDialog @bind-Visible="_showBasicAlert" CloseOnBackdropClick="false">
                <AlertDialogTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Outline">Show Dialog</Button>
                </AlertDialogTrigger>
                <AlertDialogContent>
                    <AlertDialogHeader>
                        <AlertDialogTitle>Are you absolutely sure?</AlertDialogTitle>
                        <AlertDialogDescription>
                            This action cannot be undone. This will permanently delete your account and remove your data from our servers.
                        </AlertDialogDescription>
                    </AlertDialogHeader>
                    <AlertDialogFooter>
                        <AlertDialogCancel>Cancel</AlertDialogCancel>
                        <AlertDialogAction OnAction="HandleContinue">Continue</AlertDialogAction>
                    </AlertDialogFooter>
                </AlertDialogContent>
            </AlertDialog>
        </DemoSection>

        <DemoSection Title="Small"
                     Description="Use the size='sm' prop to make the alert dialog smaller."
            Code="@SmallCode"
                     CodeLanguage="razor">
            <AlertDialog @bind-Visible="_showSmallAlert" CloseOnBackdropClick="false">
                <AlertDialogTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Outline">Show Dialog</Button>
                </AlertDialogTrigger>
                <AlertDialogContent Size="sm">
                    <AlertDialogHeader>
                        <AlertDialogTitle>Allow accessory to connect?</AlertDialogTitle>
                        <AlertDialogDescription>
                            Do you want to allow the USB accessory to connect to this device?
                        </AlertDialogDescription>
                    </AlertDialogHeader>
                    <AlertDialogFooter>
                        <AlertDialogCancel>Don't allow</AlertDialogCancel>
                        <AlertDialogAction>Allow</AlertDialogAction>
                    </AlertDialogFooter>
                </AlertDialogContent>
            </AlertDialog>
        </DemoSection>

        <DemoSection Title="Media"
                     Description="Use the AlertDialogMedia component to add a media element such as an icon or image to the alert dialog."
            Code="@MediaCode"
                     CodeLanguage="razor">
            <AlertDialog @bind-Visible="_showMediaAlert" CloseOnBackdropClick="false">
                <AlertDialogTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Outline">Share Project</Button>
                </AlertDialogTrigger>
                <AlertDialogContent>
                    <AlertDialogHeader>
                        <AlertDialogMedia>
                            <Icon Name="LucideIcon.CircleFadingPlus" />
                        </AlertDialogMedia>
                        <AlertDialogTitle>Share this project?</AlertDialogTitle>
                        <AlertDialogDescription>
                            Anyone with the link will be able to view and edit this project.
                        </AlertDialogDescription>
                    </AlertDialogHeader>
                    <AlertDialogFooter>
                        <AlertDialogCancel>Cancel</AlertDialogCancel>
                        <AlertDialogAction>Share</AlertDialogAction>
                    </AlertDialogFooter>
                </AlertDialogContent>
            </AlertDialog>
        </DemoSection>

        <DemoSection Title="Small with Media"
                     Description="Use the size='sm' prop to make the alert dialog smaller and the AlertDialogMedia component to add a media element such as an icon or image to the alert dialog."
            Code="@SmallMediaCode"
                     CodeLanguage="razor">
            <AlertDialog @bind-Visible="_showSmallMediaAlert" CloseOnBackdropClick="false">
                <AlertDialogTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Outline">Show Dialog</Button>
                </AlertDialogTrigger>
                <AlertDialogContent Size="sm">
                    <AlertDialogHeader>
                        <AlertDialogMedia>
                            <Icon Name="LucideIcon.Bluetooth" />
                        </AlertDialogMedia>
                        <AlertDialogTitle>Allow accessory to connect?</AlertDialogTitle>
                        <AlertDialogDescription>
                            Do you want to allow the USB accessory to connect to this device?
                        </AlertDialogDescription>
                    </AlertDialogHeader>
                    <AlertDialogFooter>
                        <AlertDialogCancel>Don't allow</AlertDialogCancel>
                        <AlertDialogAction>Allow</AlertDialogAction>
                    </AlertDialogFooter>
                </AlertDialogContent>
            </AlertDialog>
        </DemoSection>

        <DemoSection Title="Destructive"
                     Description="Use the AlertDialogAction component to add a destructive action button to the alert dialog."
            Code="@DestructiveCode"
                     CodeLanguage="razor">
            <AlertDialog @bind-Visible="_showDestructiveAlert" CloseOnBackdropClick="false">
                <AlertDialogTrigger AsChild="true">
                    <Button Variant="ButtonVariant.Destructive">Delete Chat</Button>
                </AlertDialogTrigger>
                <AlertDialogContent Size="sm">
                    <AlertDialogHeader>
                        <AlertDialogMedia Class="bg-destructive/10 text-destructive dark:bg-destructive/20 dark:text-destructive">
                            <Icon Name="LucideIcon.Trash2" />
                        </AlertDialogMedia>
                        <AlertDialogTitle>Delete chat?</AlertDialogTitle>
                        <AlertDialogDescription>
                            This will permanently delete this chat conversation. View <a href="#">Settings</a> delete any memories saved during this chat.
                        </AlertDialogDescription>
                    </AlertDialogHeader>
                    <AlertDialogFooter>
                        <AlertDialogCancel>Cancel</AlertDialogCancel>
                        <AlertDialogAction Variant="ButtonVariant.Destructive" OnAction="HandleDelete">Delete</AlertDialogAction>
                    </AlertDialogFooter>
                </AlertDialogContent>
            </AlertDialog>
        </DemoSection>

        <DemoSection Title="RTL"
                     Description="Alert dialogs read naturally in right-to-left layouts."
                     Code="@RtlCode"
                     CodeLanguage="razor">
            <DirectionProvider Dir="rtl">
                <Div Display="Display.Flex" Gap="Gap.Is2" FlexWrap="FlexWrap.Wrap" Justify="Justify.Center">
                    <AlertDialog @bind-Visible="_showRtlAlert" CloseOnBackdropClick="false">
                        <AlertDialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">إظهار الحوار</Button>
                        </AlertDialogTrigger>
                        <AlertDialogContent>
                            <AlertDialogHeader>
                                <AlertDialogTitle>هل أنت متأكد تمامًا؟</AlertDialogTitle>
                                <AlertDialogDescription>
                                    لا يمكن التراجع عن هذا الإجراء. سيؤدي هذا إلى حذف حسابك نهائيًا من خوادمنا.
                                </AlertDialogDescription>
                            </AlertDialogHeader>
                            <AlertDialogFooter>
                                <AlertDialogCancel>عدم السماح</AlertDialogCancel>
                                <AlertDialogAction OnAction="HandleContinue">السماح</AlertDialogAction>
                            </AlertDialogFooter>
                        </AlertDialogContent>
                    </AlertDialog>

                    <AlertDialog @bind-Visible="_showRtlSmallAlert" CloseOnBackdropClick="false">
                        <AlertDialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">إظهار الحوار (صغير)</Button>
                        </AlertDialogTrigger>
                        <AlertDialogContent Size="sm">
                            <AlertDialogHeader>
                                <AlertDialogMedia>
                                    <Icon Name="LucideIcon.Bluetooth" />
                                </AlertDialogMedia>
                                <AlertDialogTitle>السماح للملحق بالاتصال؟</AlertDialogTitle>
                                <AlertDialogDescription>
                                    هل تريد السماح لملحق USB بالاتصال بهذا الجهاز؟
                                </AlertDialogDescription>
                            </AlertDialogHeader>
                            <AlertDialogFooter>
                                <AlertDialogCancel>عدم السماح</AlertDialogCancel>
                                <AlertDialogAction OnAction="HandleContinue">السماح</AlertDialogAction>
                            </AlertDialogFooter>
                        </AlertDialogContent>
                    </AlertDialog>
                </Div>
            </DirectionProvider>
        </DemoSection>
    </Section>
</Div>

