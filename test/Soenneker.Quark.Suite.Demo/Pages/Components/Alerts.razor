@page "/alerts"

<PageTitle>Alerts - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
                     Description="Official shadcn alert example."
                     PreviewClass="preview relative flex w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-auto sm:h-72 p-6"
                     Code="@DemoCode"
                     CodeLanguage="razor">
            <Div Display="Display.Grid" Width="Width.IsFull" MaxWidth="MaxWidth.IsMd" ItemsAlign="Items.Start" Gap="Gap.Is4">
                <Alert>
                    <Icon Name="LucideIcon.CircleCheck"/>
                    <AlertTitle>Payment successful</AlertTitle>
                    <AlertDescription>
                        Your payment of $29.99 has been processed. A receipt has been sent to your email address.
                    </AlertDescription>
                </Alert>

                <Alert>
                    <Icon Name="LucideIcon.Info"/>
                    <AlertTitle>New feature available</AlertTitle>
                    <AlertDescription>
                        We've added dark mode support. You can enable it in your account settings.
                    </AlertDescription>
                </Alert>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Basic"
                     Description="A basic alert with an icon, title and description."
                     PreviewClass="preview relative flex w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-auto sm:h-72 p-6"
                     Code="@BasicCode"
                     CodeLanguage="razor">
            <Alert MaxWidth="MaxWidth.IsMd">
                <Icon Name="LucideIcon.CircleCheck"/>
                <AlertTitle>Account updated successfully</AlertTitle>
                <AlertDescription>
                    Your profile information has been saved. Changes will be reflected immediately.
                </AlertDescription>
            </Alert>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Destructive"
                     Description="Use Variant=&quot;AlertVariant.Destructive&quot; to create a destructive alert."
                     PreviewClass="preview relative flex w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-auto sm:h-72 p-6"
                     Code="@DestructiveCode"
                     CodeLanguage="razor">
            <Alert Variant="AlertVariant.Destructive" MaxWidth="MaxWidth.IsMd">
                <Icon Name="LucideIcon.CircleAlert"/>
                <AlertTitle>Payment failed</AlertTitle>
                <AlertDescription>
                    Your payment could not be processed. Please check your payment method and try again.
                </AlertDescription>
            </Alert>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Action"
                     Description="Use AlertAction to place an action element in the alert."
                     PreviewClass="preview relative flex w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-auto sm:h-72 p-6"
                     Code="@ActionCode"
                     CodeLanguage="razor">
            <Alert MaxWidth="MaxWidth.IsMd">
                <AlertTitle>Dark mode is now available</AlertTitle>
                <AlertDescription>
                    Enable it under your profile settings to get started.
                </AlertDescription>
                <AlertAction>
                    <Button Size="ButtonSize.Xs">Enable</Button>
                </AlertAction>
            </Alert>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Custom Colors"
                     Description="Use custom classes on the Alert component for custom alert colors."
                     PreviewClass="preview relative flex w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-auto sm:h-72 p-6"
                     Code="@CustomColorsCode"
                     CodeLanguage="razor">
            <Alert Class="max-w-md border-amber-200/60 bg-amber-50 text-amber-950 dark:border-amber-900/60 dark:bg-amber-950 dark:text-amber-200 [&>svg]:text-amber-600 dark:[&>svg]:text-amber-400">
                <Icon Name="LucideIcon.TriangleAlert"/>
                <AlertTitle>Your subscription will expire in 3 days.</AlertTitle>
                <AlertDescription Class="text-amber-900 dark:text-amber-300">
                    Renew now to avoid service interruption or upgrade to a paid plan to continue using the service.
                </AlertDescription>
            </Alert>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="RTL"
                     Description="Official shadcn RTL example."
                     PreviewDir="rtl"
                     PreviewLang="ar"
                     PreviewClass="preview relative flex w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-auto sm:h-72 p-6"
                     Code="@RtlCode"
                     CodeLanguage="razor">
            <DirectionProvider Dir="rtl">
                <Div Display="Display.Grid" Width="Width.IsFull" MaxWidth="MaxWidth.IsXl" ItemsAlign="Items.Start" Gap="Gap.Is4" TextAlign="TextAlign.End">
                    <Alert>
                        <Icon Name="LucideIcon.CircleCheck"/>
                        <AlertTitle>تم الدفع بنجاح</AlertTitle>
                        <AlertDescription>
                            تمت معالجة دفعتك البالغة 29.99 دولارًا. تم إرسال إيصال إلى عنوان بريدك الإلكتروني.
                        </AlertDescription>
                    </Alert>

                    <Alert>
                        <Icon Name="LucideIcon.Info"/>
                        <AlertTitle>ميزة جديدة متاحة</AlertTitle>
                        <AlertDescription>
                            لقد أضفنا دعم الوضع الداكن. يمكنك تفعيله في إعدادات حسابك.
                        </AlertDescription>
                    </Alert>
                </Div>
            </DirectionProvider>
        </DemoSection>
    </Section>
</Div>

