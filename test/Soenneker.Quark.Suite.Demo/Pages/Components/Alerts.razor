@page "/alerts"

<PageTitle>Alerts - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Stacked alert examples covering the main message patterns."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="grid w-full max-w-xl items-start gap-4">
                    <Alert ShowDefaultIcon="false">
                        <Icon Name="LucideIcon.CircleCheck" Class="size-4 shrink-0 translate-y-0.5" />
                        <AlertMessage>Success! Your changes have been saved</AlertMessage>
                        <AlertDescription>This is an alert with icon, title and description.</AlertDescription>
                    </Alert>
                    <Alert ShowDefaultIcon="false">
                        <Icon Name="LucideIcon.Popcorn" Class="size-4 shrink-0 translate-y-0.5" />
                        <AlertMessage>This alert has a title and an icon. No description.</AlertMessage>
                    </Alert>
                    <Alert Variant="AlertVariant.Danger" ShowDefaultIcon="false">
                        <Icon Name="LucideIcon.CircleAlert" Class="size-4 shrink-0 translate-y-0.5" />
                        <AlertMessage>Unable to process your payment.</AlertMessage>
                        <AlertDescription>
                            <Paragraph Margin="Margin.Is0">Please verify your billing information and try again.</Paragraph>
                            <UnorderedList Class="list-inside list-disc text-sm">
                                <UnorderedListItem>Check your card details</UnorderedListItem>
                                <UnorderedListItem>Ensure sufficient funds</UnorderedListItem>
                                <UnorderedListItem>Verify billing address</UnorderedListItem>
                            </UnorderedList>
                        </AlertDescription>
                    </Alert>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Destructive"
                         Description="Use the destructive variant when the message warns about a problem or irreversible action."
                         Code="@DestructiveCode"
                         CodeLanguage="razor">
                <Alert Variant="AlertVariant.Danger" Class="max-w-md" ShowDefaultIcon="false">
                    <Icon Name="LucideIcon.CircleAlert" Class="size-4 shrink-0 translate-y-0.5" />
                    <AlertMessage>Payment failed</AlertMessage>
                    <AlertDescription>Your payment could not be processed. Please check your payment method and try again.</AlertDescription>
                </Alert>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Action"
                         Description="Use AlertAction to add a button or other control aligned to the alert."
                         Code="@ActionCode"
                         CodeLanguage="razor">
                <Alert Class="max-w-md" ShowDefaultIcon="false">
                    <AlertMessage>Dark mode is now available</AlertMessage>
                    <AlertDescription>Enable it under your profile settings to get started.</AlertDescription>
                    <AlertAction>
                        <Button Size="ButtonSize.Xs" Variant="ButtonVariant.Default">Enable</Button>
                    </AlertAction>
                </Alert>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Colors"
                         Description="Customize emphasis with utility classes on the alert root."
                         Code="@CustomColorsCode"
                         CodeLanguage="razor">
                <Alert Class="max-w-md border-amber-200 bg-amber-50 text-amber-900 dark:border-amber-900 dark:bg-amber-950 dark:text-amber-50"
                       ShowDefaultIcon="false">
                    <Icon Name="LucideIcon.TriangleAlert" Class="size-4 shrink-0 translate-y-0.5" />
                    <AlertMessage>Your subscription will expire in 3 days.</AlertMessage>
                    <AlertDescription>Renew now to avoid service interruption or upgrade to a paid plan to continue using the service.</AlertDescription>
                </Alert>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Alerts stay readable in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="grid w-full max-w-md items-start gap-4">
                        <Alert ShowDefaultIcon="false">
                            <Icon Name="LucideIcon.CircleCheck" Class="size-4 shrink-0 translate-y-0.5" />
                            <AlertMessage>تم تحديث الحساب بنجاح</AlertMessage>
                            <AlertDescription>تم حفظ معلومات ملفك الشخصي. ستظهر التغييرات فوراً.</AlertDescription>
                        </Alert>
                        <Alert ShowDefaultIcon="false">
                            <Icon Name="LucideIcon.Info" Class="size-4 shrink-0 translate-y-0.5" />
                            <AlertMessage>تحديث جديد متاح</AlertMessage>
                            <AlertDescription>يمكنك الآن استخدام الميزات الجديدة من لوحة التحكم.</AlertDescription>
                        </Alert>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Extra semantic variants and dismissible alerts.
                </Paragraph>
            </Div>

            <DemoSection Title="Extended variants"
                         Description="Semantic success, info, and warning variants with default icons."
                         Code="@ExtendedVariantsCode"
                         CodeLanguage="razor">
                <Div Space="Space.Y.Is4">
                    <Alert Variant="AlertVariant.Success">
                        <AlertMessage>Deployment complete</AlertMessage>
                        <AlertDescription>Your latest release is live in production.</AlertDescription>
                    </Alert>
                    <Alert Variant="AlertVariant.Info">
                        <AlertMessage>Heads up</AlertMessage>
                        <AlertDescription>API keys are rotating automatically tonight.</AlertDescription>
                    </Alert>
                    <Alert Variant="AlertVariant.Warning">
                        <AlertMessage>Usage warning</AlertMessage>
                        <AlertDescription>Build minutes are running low for this billing cycle.</AlertDescription>
                    </Alert>
                </Div>
            </DemoSection>

            <DemoSection Title="Dismissible"
                         Description="Optional close control for transient notices."
                         Code="@DismissibleCode"
                         CodeLanguage="razor">
                <Alert Dismissible="true" OnDismiss="HandleDismiss">
                    <AlertMessage>Dismissible alert</AlertMessage>
                    <AlertDescription>Click the close button to dismiss this message.</AlertDescription>
                </Alert>
            </DemoSection>
        </Section>
    </Div>
</Div>

