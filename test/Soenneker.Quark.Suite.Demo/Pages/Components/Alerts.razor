@page "/alerts"

<PageTitle>Alert Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic" Description="A basic alert with icon, title, and supporting description.">
                <Alert>
                    <Icon Name="LucideIcon.Info" Class="size-4 shrink-0 translate-y-0.5" />
                    <AlertMessage>Heads up!</AlertMessage>
                    <AlertDescription>You can add components and dependencies to your app using the CLI.</AlertDescription>
                </Alert>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Destructive" Description="Use the destructive alert when the message warns about irreversible actions.">
                <Alert Variant="AlertVariant.Danger">
                    <AlertMessage>Delete environment</AlertMessage>
                    <AlertDescription>This operation cannot be undone once the environment is deleted.</AlertDescription>
                </Alert>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Action" Description="Alerts now support a dedicated action region instead of forcing buttons into the description block.">
                <Alert>
                    <AlertMessage>Team access</AlertMessage>
                    <AlertDescription>Invite collaborators and grant the right level of access.</AlertDescription>
                    <AlertAction>
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Enable</Button>
                    </AlertAction>
                </Alert>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Colors" Description="Custom utility classes let you tune alert emphasis while keeping the structure intact.">
                <Div Space="Space.Y.Is4">
                    <Alert Class="border-amber-500/30 bg-amber-500/10">
                        <AlertMessage>Billing reminder</AlertMessage>
                        <AlertDescription>Your trial ends in 3 days. Upgrade to keep advanced features enabled.</AlertDescription>
                    </Alert>
                    <Alert Class="border-purple-500/30 bg-gradient-to-r from-purple-500/10 to-pink-500/10">
                        <AlertMessage>Brand alert</AlertMessage>
                        <AlertDescription>Use utility classes when you need product-specific emphasis.</AlertDescription>
                    </Alert>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="Alert composition remains readable in right-to-left layouts.">
                <DirectionProvider Dir="rtl">
                    <Div class="w-full text-right">
                        <Alert>
                            <Icon Name="LucideIcon.Info" Class="size-4 shrink-0 translate-y-0.5" />
                            <AlertMessage>تنبيه</AlertMessage>
                            <AlertDescription>يمكنك إضافة المكونات والاعتمادات إلى تطبيقك باستخدام الأداة.</AlertDescription>
                        </Alert>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show Quark-specific alert behavior beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Extended Variants" Description="Quark ships additional semantic variants for info, success, and warning states.">
                <Div Space="Space.Y.Is4">
                    <Alert Variant="AlertVariant.Success">
                        <AlertMessage>Deployment complete</AlertMessage>
                        <AlertDescription>Your latest release is live in production.</AlertDescription>
                    </Alert>
                    <Alert Variant="AlertVariant.Info">
                        <AlertMessage>Heads up</AlertMessage>
                        <AlertDescription>API keys are rotating automatically tonight.</AlertDescription>
                    </Alert>
                    <Alert Variant="AlertVariant.Warning">
                        <AlertMessage>Usage warning</AlertMessage>
                        <AlertDescription>Build minutes are running low for this billing cycle.</AlertDescription>
                    </Alert>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dismissible" Description="Quark alerts can also be dismissed for app-level notices.">
                <Alert Dismissible="true" OnDismiss="HandleDismiss">
                    <AlertMessage>Dismissible alert</AlertMessage>
                    <AlertDescription>Click the close button to dismiss this message.</AlertDescription>
                </Alert>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private async Task HandleDismiss() => await Task.CompletedTask;
}
