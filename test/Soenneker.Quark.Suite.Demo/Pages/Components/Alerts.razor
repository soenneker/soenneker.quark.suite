@page "/alerts"

<PageTitle>Alert Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Basic" Description="A neutral alert with a title and supporting description." Code="@(@"<Alert>
    <AlertMessage>Heads up!</AlertMessage>
    <AlertDescription>You can add components and dependencies to your app using the CLI.</AlertDescription>
</Alert>")">
            <Alert>
                <AlertMessage>Heads up!</AlertMessage>
                <AlertDescription>You can add components and dependencies to your app using the CLI.</AlertDescription>
            </Alert>
        </DemoSection>
    </Div>

    <Div Space="Space.Y.Is4">
        <DemoSection Title="Destructive" Description="Use the danger variant when the message warns about data loss or irreversible actions." Code="@(@"<Alert Variant=""AlertVariant.Danger"">
    <AlertMessage>Destructive action</AlertMessage>
    <AlertDescription>This operation cannot be undone once the environment is deleted.</AlertDescription>
</Alert>")">
            <Alert Variant="AlertVariant.Danger">
                <AlertMessage>Destructive action</AlertMessage>
                <AlertDescription>This operation cannot be undone once the environment is deleted.</AlertDescription>
            </Alert>
        </DemoSection>
    </Div>

    <Div Space="Space.Y.Is4">
        <DemoSection Title="Action" Description="Quark does not ship a dedicated alert action slot, so the closest equivalent is placing an inline button inside the description area." Code="@(@"<Alert Variant=""AlertVariant.Info"">
    <AlertMessage>Team access</AlertMessage>
    <AlertDescription>
        Invite collaborators and grant the right level of access.
        <Div class=""mt-3"">
            <Button Size=""ButtonSize.Sm"" Variant=""ButtonVariant.Outline"">Enable</Button>
        </Div>
    </AlertDescription>
</Alert>")">
            <Alert Variant="AlertVariant.Info">
                <AlertMessage>Team access</AlertMessage>
                <AlertDescription>
                    Invite collaborators and grant the right level of access.
                    <Div class="mt-3">
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Enable</Button>
                    </Div>
                </AlertDescription>
            </Alert>
        </DemoSection>
    </Div>

    <Div Space="Space.Y.Is4">
        <DemoSection Title="Custom Colors" Description="Custom utility classes let you match shadcn's custom-color examples while still using the Quark alert structure." Code="@(@"<Alert Class=""border-amber-500/30 bg-amber-500/10"">
    <AlertMessage>Billing reminder</AlertMessage>
    <AlertDescription>Your trial ends in 3 days. Upgrade to keep advanced features enabled.</AlertDescription>
</Alert>
<Alert Class=""border-purple-500/30 bg-gradient-to-r from-purple-500/10 to-pink-500/10"">
    <AlertMessage>Brand alert</AlertMessage>
    <AlertDescription>Use utility classes when you need product-specific emphasis.</AlertDescription>
</Alert>")">
            <Div Space="Space.Y.Is4">
                <Alert Class="border-amber-500/30 bg-amber-500/10">
                    <AlertMessage>Billing reminder</AlertMessage>
                    <AlertDescription>Your trial ends in 3 days. Upgrade to keep advanced features enabled.</AlertDescription>
                </Alert>
                <Alert Class="border-purple-500/30 bg-gradient-to-r from-purple-500/10 to-pink-500/10">
                    <AlertMessage>Brand alert</AlertMessage>
                    <AlertDescription>Use utility classes when you need product-specific emphasis.</AlertDescription>
                </Alert>
            </Div>
        </DemoSection>
    </Div>

    <Div Space="Space.Y.Is4">
        <DemoSection Title="Dismissible" Description="Quark also supports dismissible alerts for app-level notices that should be removable." Code="@(@"<Alert Dismissible=""true"" OnDismiss=""HandleDismiss"">
    <AlertMessage>Dismissible alert</AlertMessage>
    <AlertDescription>Click the close button to dismiss this message.</AlertDescription>
</Alert>")">
            <Alert Dismissible="true" OnDismiss="HandleDismiss">
                <AlertMessage>Dismissible alert</AlertMessage>
                <AlertDescription>Click the close button to dismiss this message.</AlertDescription>
            </Alert>
        </DemoSection>
    </Div>
</Div>

@code {
    private async Task HandleDismiss() => await Task.CompletedTask;
}
