    private static int DesktopTotal => _chartData.Sum(item => item.Desktop);
    private static int MobileTotal => _chartData.Sum(item => item.Mobile);

    private void SetActiveSeries(string series)
    {
        _activeSeries = series;
    }

    private const string InteractiveCode =
@"<Card>
    <CardHeader>
        <CardTitle>Bar Chart - Interactive</CardTitle>
        <CardDescription>Showing total visitors for the last 3 months</CardDescription>
    </CardHeader>
    <CardContent>
        <ChartInteractiveBar Data=""@_chartData"" ActiveSeries=""@_activeSeries"" />
    </CardContent>
</Card>";
}
