@page "/components/chart"

<PageTitle>Chart - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <DemoSection Code="@InteractiveCode"
                 CodeLanguage="razor"
                 PreviewClass="preview flex min-h-[480px] w-full items-center justify-center p-0 sm:p-6">
        <Card Class="w-full max-w-[638px] gap-6 border py-0! pb-4! shadow-sm ring-0!">
            <CardHeader Class="flex! flex-col items-stretch border-b p-0! sm:flex-row!">
                <Div Class="flex flex-1 flex-col justify-center gap-1 px-6 pt-4 pb-3 sm:py-0!">
                    <CardTitle Class="text-[16.8px] leading-none font-semibold sm:text-[15px]">Bar Chart - Interactive</CardTitle>
                    <CardDescription>Showing total visitors for the last 3 months</CardDescription>
                </Div>

                <Div Class="flex">
                    <button type="button"
                            data-active="@(_activeSeries == "desktop" ? "true" : "false")"
                            class="relative z-30 flex flex-1 flex-col justify-center gap-1 border-t px-6 py-4 text-left even:border-l data-[active=true]:bg-muted/50 sm:border-t-0 sm:border-l sm:px-8 sm:py-6"
                            @onclick="@(() => SetActiveSeries("desktop"))">
                        <span class="text-xs text-muted-foreground">Desktop</span>
                        <span class="text-lg leading-none font-bold sm:text-3xl">@DesktopTotal.ToString("N0")</span>
                    </button>

                    <button type="button"
                            data-active="@(_activeSeries == "mobile" ? "true" : "false")"
                            class="relative z-30 flex flex-1 flex-col justify-center gap-1 border-t px-6 py-4 text-left even:border-l data-[active=true]:bg-muted/50 sm:border-t-0 sm:border-l sm:px-8 sm:py-6"
                            @onclick="@(() => SetActiveSeries("mobile"))">
                        <span class="text-xs text-muted-foreground">Mobile</span>
                        <span class="text-lg leading-none font-bold sm:text-3xl">@MobileTotal.ToString("N0")</span>
                    </button>
                </Div>
            </CardHeader>

            <CardContent Class="px-2! sm:p-6!">
                <ChartInteractiveBar Data="@_chartData"
                                     ActiveSeries="@_activeSeries"
                                     Title="Bar Chart - Interactive"
                                     Description="Showing total visitors for the last 3 months" />
            </CardContent>
        </Card>
    </DemoSection>
</Div>

@code {
    private string _activeSeries = "desktop";

    private static readonly IReadOnlyList<ChartBarDatum> _chartData =
    [
        new("Apr 1", "Mar 31, 2024", 222, 150),
        new("Apr 2", "Apr 1, 2024", 97, 180),
        new("Apr 3", "Apr 2, 2024", 167, 120),
        new("Apr 4", "Apr 3, 2024", 242, 260),
        new("Apr 5", "Apr 4, 2024", 373, 290),
        new("Apr 6", "Apr 5, 2024", 301, 340),
        new("Apr 7", "Apr 6, 2024", 245, 180),
        new("Apr 8", "Apr 7, 2024", 409, 320),
        new("Apr 9", "Apr 8, 2024", 59, 110),
        new("Apr 10", "Apr 9, 2024", 261, 190),
        new("Apr 11", "Apr 10, 2024", 327, 350),
        new("Apr 12", "Apr 11, 2024", 292, 210),
        new("Apr 13", "Apr 12, 2024", 342, 380),
        new("Apr 14", "Apr 13, 2024", 137, 220),
        new("Apr 15", "Apr 14, 2024", 120, 170),
        new("Apr 16", "Apr 15, 2024", 138, 190),
        new("Apr 17", "Apr 16, 2024", 446, 360),
        new("Apr 18", "Apr 17, 2024", 364, 410),
        new("Apr 19", "Apr 18, 2024", 243, 180),
        new("Apr 20", "Apr 19, 2024", 89, 150),
        new("Apr 21", "Apr 20, 2024", 137, 200),
        new("Apr 22", "Apr 21, 2024", 224, 170),
        new("Apr 23", "Apr 22, 2024", 138, 230),
        new("Apr 24", "Apr 23, 2024", 387, 290),
        new("Apr 25", "Apr 24, 2024", 215, 250),
