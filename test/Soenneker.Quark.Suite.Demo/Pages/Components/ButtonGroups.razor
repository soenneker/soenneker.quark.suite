@page "/button-groups"

<PageTitle>Button Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic" Description="Buttons in a group share borders and sit on one line."
                        Code="@(@"<ButtonGroup>
    <Button BackgroundColor=""BackgroundColor.Primary"">Left</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Middle</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Right</Button>
</ButtonGroup>")">
                <ButtonGroup>
                    <Button Variant="ButtonVariant.Outline">Left</Button>
                    <Button Variant="ButtonVariant.Outline">Middle</Button>
                    <Button Variant="ButtonVariant.Outline">Right</Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Nested" Description="Button groups can mix button treatments when a parent surface needs several related actions." Code="@(@"<ButtonGroup>
    <Button BackgroundColor=""BackgroundColor.Primary"">Primary</Button>
    <Button BackgroundColor=""BackgroundColor.Secondary"">Secondary</Button>
    <Button BackgroundColor=""BackgroundColor.Accent"">Success</Button>
    <Button BackgroundColor=""BackgroundColor.Muted"">Warning</Button>
    <Button BackgroundColor=""BackgroundColor.Destructive"">Danger</Button>
</ButtonGroup>")">
                <ButtonGroup>
                    <Button BackgroundColor="BackgroundColor.Primary">Primary</Button>
                    <Button BackgroundColor="BackgroundColor.Secondary">Secondary</Button>
                    <Button BackgroundColor="BackgroundColor.Accent">Success</Button>
                    <Button BackgroundColor="BackgroundColor.Muted">Warning</Button>
                    <Button BackgroundColor="BackgroundColor.Destructive">Danger</Button>
                </ButtonGroup>
            </DemoSection>
            <DemoSection Title="Separator" Description="Outlined buttons mimic the separated style from the shadcn docs." Code="@(@"<ButtonGroup>
    <Button BackgroundColor=""BackgroundColor.Primary"" Outline=""true"">Left</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"" Outline=""true"">Middle</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"" Outline=""true"">Right</Button>
</ButtonGroup>")">
                <ButtonGroup>
                    <Button BackgroundColor="BackgroundColor.Primary" Outline="true">Left</Button>
                    <Button BackgroundColor="BackgroundColor.Primary" Outline="true">Middle</Button>
                    <Button BackgroundColor="BackgroundColor.Primary" Outline="true">Right</Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical" Description="Set Vertical=true to stack buttons." Code="@(@"<ButtonGroup Vertical=""true"">
    <Button BackgroundColor=""BackgroundColor.Primary"">Button</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Button</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Button</Button>
</ButtonGroup>")">
                <ButtonGroup Vertical="true">
                    <Button BackgroundColor="BackgroundColor.Primary">Button</Button>
                    <Button BackgroundColor="BackgroundColor.Primary">Button</Button>
                    <Button BackgroundColor="BackgroundColor.Primary">Button</Button>
                    <Button BackgroundColor="BackgroundColor.Primary">Button</Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Use Size to control the group and its buttons (Sm, Default, Lg)." Code="@(@"<ButtonGroup Size=""ButtonSize.Sm"">
    <Button BackgroundColor=""BackgroundColor.Primary"">Left</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Middle</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Right</Button>
</ButtonGroup>
<ButtonGroup>
    <Button BackgroundColor=""BackgroundColor.Primary"">Left</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Middle</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Right</Button>
</ButtonGroup>
<ButtonGroup Size=""ButtonSize.Lg"">
    <Button BackgroundColor=""BackgroundColor.Primary"">Left</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Middle</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Right</Button>
</ButtonGroup>")">
                <Div Class="flex flex-wrap gap-6">
                    <Div>
                        <H3 Class="mb-2 text-sm font-medium text-muted-foreground">Small</H3>
                        <ButtonGroup Size="ButtonSize.Sm">
                            <Button BackgroundColor="BackgroundColor.Primary">Left</Button>
                            <Button BackgroundColor="BackgroundColor.Primary">Middle</Button>
                            <Button BackgroundColor="BackgroundColor.Primary">Right</Button>
                        </ButtonGroup>
                    </Div>
                    <Div>
                        <H3 Class="mb-2 text-sm font-medium text-muted-foreground">Default</H3>
                        <ButtonGroup>
                            <Button BackgroundColor="BackgroundColor.Primary">Left</Button>
                            <Button BackgroundColor="BackgroundColor.Primary">Middle</Button>
                            <Button BackgroundColor="BackgroundColor.Primary">Right</Button>
                        </ButtonGroup>
                    </Div>
                    <Div>
                        <H3 Class="mb-2 text-sm font-medium text-muted-foreground">Large</H3>
                        <ButtonGroup Size="ButtonSize.Lg">
                            <Button BackgroundColor="BackgroundColor.Primary">Left</Button>
                            <Button BackgroundColor="BackgroundColor.Primary">Middle</Button>
                            <Button BackgroundColor="BackgroundColor.Primary">Right</Button>
                        </ButtonGroup>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Split" Description="Icon-driven start and end actions are a close match for split-button patterns." Code="@(@"<ButtonGroup>
    <Button BackgroundColor=""BackgroundColor.Primary""><Lucide Name=""LucideIcon.ChevronLeft""/> Previous</Button>
    <Button BackgroundColor=""BackgroundColor.Primary""><Lucide Name=""LucideIcon.House""/> Home</Button>
    <Button BackgroundColor=""BackgroundColor.Primary"">Next <Lucide Name=""LucideIcon.ChevronRight""/></Button>
</ButtonGroup>")">
                <ButtonGroup>
                    <Button BackgroundColor="BackgroundColor.Primary"><Icon Name="LucideIcon.ChevronLeft"/> Previous</Button>
                    <Button BackgroundColor="BackgroundColor.Primary"><Icon Name="LucideIcon.House"/> Home</Button>
                    <Button BackgroundColor="BackgroundColor.Primary">Next <Icon Name="LucideIcon.ChevronRight"/></Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown Menu" Description="Combine a ButtonGroup with a Dropdown for split actions or menus." Code="@(@"<ButtonGroup>
    <Button BackgroundColor=""BackgroundColor.Primary"">Action</Button>
    <Dropdown>
        <DropdownToggle BackgroundColor=""BackgroundColor.Primary"">Dropdown <Lucide Name=""LucideIcon.ChevronDown""/></DropdownToggle>
        <DropdownMenu>
            <DropdownItem>Action</DropdownItem>
            <DropdownItem>Another action</DropdownItem>
            <DropdownDivider/>
            <DropdownItem>Something else</DropdownItem>
        </DropdownMenu>
    </Dropdown>
</ButtonGroup>")">
                <ButtonGroup>
                    <Button BackgroundColor="BackgroundColor.Primary">Action</Button>
                    <Button BackgroundColor="BackgroundColor.Primary">Another action</Button>
                    <Dropdown>
                        <DropdownToggle BackgroundColor="BackgroundColor.Primary">Dropdown <Icon Name="LucideIcon.ChevronDown"/></DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem>Action</DropdownItem>
                            <DropdownItem>Another action</DropdownItem>
                            <DropdownDivider/>
                            <DropdownItem>Something else</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Toolbar" Description="Use multiple groups with role=toolbar for accessibility." Code="@(@"<Div Class=""flex flex-wrap gap-2"" role=""toolbar"" aria-label=""Toolbar"">
    <ButtonGroup role=""group"" aria-label=""First group"">
        <Button BackgroundColor=""BackgroundColor.Primary"">1</Button>
        <Button BackgroundColor=""BackgroundColor.Primary"">2</Button>
        <Button BackgroundColor=""BackgroundColor.Primary"">3</Button>
    </ButtonGroup>
    <ButtonGroup role=""group"" aria-label=""Second group"">
        <Button BackgroundColor=""BackgroundColor.Secondary"">5</Button>
        <Button BackgroundColor=""BackgroundColor.Secondary"">6</Button>
    </ButtonGroup>
</Div>")">
                <Div Class="flex flex-wrap gap-2" role="toolbar" aria-label="Toolbar">
                    <ButtonGroup role="group" aria-label="First group">
                        <Button BackgroundColor="BackgroundColor.Primary">1</Button>
                        <Button BackgroundColor="BackgroundColor.Primary">2</Button>
                        <Button BackgroundColor="BackgroundColor.Primary">3</Button>
                        <Button BackgroundColor="BackgroundColor.Primary">4</Button>
                    </ButtonGroup>
                    <ButtonGroup role="group" aria-label="Second group">
                        <Button BackgroundColor="BackgroundColor.Secondary">5</Button>
                        <Button BackgroundColor="BackgroundColor.Secondary">6</Button>
                        <Button BackgroundColor="BackgroundColor.Secondary">7</Button>
                    </ButtonGroup>
                    <ButtonGroup role="group" aria-label="Third group">
                        <Button BackgroundColor="BackgroundColor.Secondary">8</Button>
                    </ButtonGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input" Description="Pair a grouped action cluster with a compact input for search and filtering workflows." Code="@(@"<Div Class=""flex flex-wrap items-center gap-3"">
    <Input Class=""max-w-xs"" Placeholder=""Search projects"" />
    <ButtonGroup>
        <Button Variant=""ButtonVariant.Outline"">Search</Button>
        <Button Variant=""ButtonVariant.Outline"">Clear</Button>
    </ButtonGroup>
</Div>")">
                <Div Class="flex flex-wrap items-center gap-3">
                    <Input Class="max-w-xs" Placeholder="Search projects" />
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Search</Button>
                        <Button Variant="ButtonVariant.Outline">Clear</Button>
                    </ButtonGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Select" Description="The native select and grouped actions work well together in compact toolbars." Code="@(@"<Div Class=""flex flex-wrap items-center gap-3"">
    <Select TValue=""string"" SelectedValue=""@("All")"">
        <SelectItem TValue=""string"" ItemValue=""@("All")"" Text=""All"" />
        <SelectItem TValue=""string"" ItemValue=""@("Open")"" Text=""Open"" />
    </Select>
    <ButtonGroup>
        <Button Variant=""ButtonVariant.Outline"">Apply</Button>
        <Button Variant=""ButtonVariant.Outline"">Reset</Button>
    </ButtonGroup>
</Div>")">
                <Div Class="flex flex-wrap items-center gap-3">
                    <Select TValue="string" SelectedValue="@("All")">
                        <SelectItem TValue="string" ItemValue="@("All")" Text="All" />
                        <SelectItem TValue="string" ItemValue="@("Open")" Text="Open" />
                        <SelectItem TValue="string" ItemValue="@("Closed")" Text="Closed" />
                    </Select>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Apply</Button>
                        <Button Variant="ButtonVariant.Outline">Reset</Button>
                    </ButtonGroup>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>
