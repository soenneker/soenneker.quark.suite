@page "/button-groups"

<PageTitle>Button Groups - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Toolbar-style groups with outline actions and a split dropdown for overflow."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <ButtonGroup AriaLabel="Message actions">
                    <ButtonGroup Class="hidden sm:flex">
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Go Back">
                            <Icon Name="LucideIcon.ArrowLeft" />
                        </Button>
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Archive</Button>
                        <Button Variant="ButtonVariant.Outline">Report</Button>
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Snooze</Button>
                        <Dropdown>
                            <DropdownToggle IsSplit="true" aria-label="More Options">
                                <Icon Name="LucideIcon.Ellipsis" />
                            </DropdownToggle>
                            <DropdownMenu RightAligned="true" Class="w-40">
                                <DropdownItem>
                                    <Icon Name="LucideIcon.MailCheck" />
                                    Mark as Read
                                </DropdownItem>
                                <DropdownItem>
                                    <Icon Name="LucideIcon.Archive" />
                                    Archive
                                </DropdownItem>
                                <DropdownDivider />
                                <DropdownItem>
                                    <Icon Name="LucideIcon.Clock" />
                                    Snooze
                                </DropdownItem>
                                <DropdownItem>
                                    <Icon Name="LucideIcon.CalendarPlus" />
                                    Add to Calendar
                                </DropdownItem>
                                <DropdownItem>
                                    <Icon Name="LucideIcon.ListFilter" />
                                    Add to List
                                </DropdownItem>
                                <DropdownDivider />
                                <DropdownItem Variant="destructive">
                                    <Icon Name="LucideIcon.Trash2" />
                                    Trash
                                </DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </ButtonGroup>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Orientation"
                         Description="Vertical orientation stacks grouped actions into a compact control."
                         Code="@OrientationCode"
                         CodeLanguage="razor">
                <ButtonGroup Vertical="true" AriaLabel="Media controls" Class="h-fit">
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Increase">
                        <Icon Name="LucideIcon.Plus" />
                    </Button>
                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Decrease">
                        <Icon Name="LucideIcon.Minus" />
                    </Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Control the size of buttons using the size parameter on individual buttons."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Start" Gap='Gap.Token("8")'>
                    <ButtonGroup>
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Small</Button>
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Button</Button>
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">Group</Button>
                        <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Outline" aria-label="Add">
                            <Icon Name="LucideIcon.Plus" />
                        </Button>
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Default</Button>
                        <Button Variant="ButtonVariant.Outline">Button</Button>
                        <Button Variant="ButtonVariant.Outline">Group</Button>
                        <Button Size="ButtonSize.Icon" Variant="ButtonVariant.Outline" aria-label="Add">
                            <Icon Name="LucideIcon.Plus" />
                        </Button>
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Size="ButtonSize.Lg" Variant="ButtonVariant.Outline">Large</Button>
                        <Button Size="ButtonSize.Lg" Variant="ButtonVariant.Outline">Button</Button>
                        <Button Size="ButtonSize.Lg" Variant="ButtonVariant.Outline">Group</Button>
                        <Button Size="ButtonSize.IconLg" Variant="ButtonVariant.Outline" aria-label="Add">
                            <Icon Name="LucideIcon.Plus" />
                        </Button>
                    </ButtonGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Nested"
                         Description="Nested groups now keep their own borders while preserving the outer spacing."
                         Code="@NestedCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Add">
                            <Icon Name="LucideIcon.Plus" />
                        </Button>
                    </ButtonGroup>
                    <ButtonGroup Class="min-w-[20rem]">
                        <InputGroup>
                            <InputGroupInput Placeholder="Send a message..." />
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                                <Icon Name="LucideIcon.MessageSquare" />
                            </InputGroupAddon>
                        </InputGroup>
                    </ButtonGroup>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Separator"
                         Description="Separators now switch orientation with the group instead of relying on ad hoc borders."
                         Code="@SeparatorCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Sm">Copy</Button>
                    <ButtonGroupSeparator />
                    <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Sm">Paste</Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Split"
                         Description="Split groups use a real separator and retain the shared rounded treatment."
                         Code="@SplitCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <Button Variant="ButtonVariant.Secondary">Button</Button>
                    <ButtonGroupSeparator />
                    <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Icon" aria-label="Add">
                        <Icon Name="LucideIcon.Plus" />
                    </Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input"
                         Description="Inputs can sit directly inside the group without breaking the grouped outline."
                         Code="@InputCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <Input Placeholder="Search..." />
                    <Button Variant="ButtonVariant.Outline" aria-label="Search">
                        <Icon Name="LucideIcon.Search" />
                    </Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input Group"
                         Description="Input groups can be nested inside button groups for richer composed forms."
                         Code="@InputGroupCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap="Gap.Is3">
                    <InputGroup>
                        <InputGroupAddon>https://</InputGroupAddon>
                        <InputGroupInput Placeholder="acme.dev" />
                    </InputGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline">Verify</Button>
                        <Button Variant="ButtonVariant.Outline">Copy</Button>
                    </ButtonGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown Menu"
                         Description="Use a split action with a real grouped dropdown trigger."
                         Code="@DropdownMenuCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <Button Variant="ButtonVariant.Outline">Follow</Button>
                    <Dropdown>
                        <DropdownToggle IsSplit="true" Class="pl-2!">
                            <Icon Name="LucideIcon.ChevronDown" />
                        </DropdownToggle>
                        <DropdownMenu RightAligned="true" Class="w-44">
                            <DropdownItem>
                                <Icon Name="LucideIcon.VolumeOff" />
                                Mute Conversation
                            </DropdownItem>
                            <DropdownItem>
                                <Icon Name="LucideIcon.Check" />
                                Mark as Read
                            </DropdownItem>
                            <DropdownItem>
                                <Icon Name="LucideIcon.TriangleAlert" />
                                Report Conversation
                            </DropdownItem>
                            <DropdownItem>
                                <Icon Name="LucideIcon.UserRoundX" />
                                Block User
                            </DropdownItem>
                            <DropdownItem>
                                <Icon Name="LucideIcon.Share" />
                                Share Conversation
                            </DropdownItem>
                            <DropdownItem>
                                <Icon Name="LucideIcon.Copy" />
                                Copy Conversation
                            </DropdownItem>
                            <DropdownDivider />
                            <DropdownItem Variant="destructive">
                                <Icon Name="LucideIcon.Trash" />
                                Delete Conversation
                            </DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Select"
                         Description="Select triggers can now participate in the same grouped surface as inputs and actions."
                         Code="@SelectCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <ButtonGroup>
                        <Select TValue="string" SelectedValue="@("USD")">
                            <SelectTrigger Class="font-mono">
                                <SelectValue Placeholder="USD" />
                            </SelectTrigger>
                            <SelectContent Class="min-w-24">
                                <SelectItem TValue="string" ItemValue="@("USD")" Text="US Dollar" />
                                <SelectItem TValue="string" ItemValue="@("EUR")" Text="Euro" />
                                <SelectItem TValue="string" ItemValue="@("GBP")" Text="British Pound" />
                            </SelectContent>
                        </Select>
                        <Input Placeholder="10.00" />
                    </ButtonGroup>
                    <ButtonGroup>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Send">
                            <Icon Name="LucideIcon.ArrowRight" />
                        </Button>
                    </ButtonGroup>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Popover"
                         Description="Grouped popover triggers use the same shared border and focus treatment as the rest of the surface."
                         Code="@PopoverCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <Button Variant="ButtonVariant.Outline">
                        <Icon Name="LucideIcon.MessageSquare" />
                        Copilot
                    </Button>
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Icon" aria-label="Open popover">
                                <Icon Name="LucideIcon.ChevronDown" />
                            </Button>
                        </PopoverTrigger>
                        <PopoverContent PlacementAlign="end" Class="rounded-xl text-sm">
                            <Div Space="Space.Y.Is3">
                                <PopoverHeader>
                                    <PopoverTitle>Start a new task with Copilot</PopoverTitle>
                                    <PopoverDescription>Describe your task in natural language.</PopoverDescription>
                                </PopoverHeader>
                                <Field>
                                    <Label For="copilot-task" ScreenReader="ScreenReader.Only">Task description</Label>
                                    <TextArea Id="copilot-task" Placeholder="I need to..." Class="resize-none" />
                                    <FieldDescription>Copilot will open a pull request for review.</FieldDescription>
                                </Field>
                            </Div>
                        </PopoverContent>
                    </Popover>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Labeled toolbars and slot-style labels inside the grouped surface.
                </Paragraph>
            </Div>

            <DemoSection Title="Toolbar"
                         Description="Multiple groups can be combined into a toolbar with explicit labels."
                         Code="@ToolbarCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2" role="toolbar" aria-label="Toolbar">
                    <ButtonGroup role="group" aria-label="Primary tools">
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">1</Button>
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">2</Button>
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline">3</Button>
                    </ButtonGroup>
                    <ButtonGroup role="group" aria-label="Secondary tools">
                        <Button Variant="ButtonVariant.Secondary">4</Button>
                        <Button Variant="ButtonVariant.Secondary">5</Button>
                    </ButtonGroup>
                </Div>
            </DemoSection>

            <DemoSection Title="Text"
                         Description="ButtonGroupText also supports slot-style composition, so labels can participate in the grouped surface."
                         Code="@TextCode"
                         CodeLanguage="razor">
                <ButtonGroup>
                    <ButtonGroupText AsChild="true">
                        <Label For="project-name">Project</Label>
                    </ButtonGroupText>
                    <Input Id="project-name" Placeholder="Quark Suite" />
                    <Button Variant="ButtonVariant.Outline">Save</Button>
                </ButtonGroup>
            </DemoSection>
        </Section>
    </Div>
</Div>

