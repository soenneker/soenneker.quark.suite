    <Button Variant=""ButtonVariant.Outline"">...</Button>
    <Popover>...</Popover>
</ButtonGroup>";

    private const string ToolbarCode =
@"<Div role=""toolbar"" aria-label=""Toolbar"">
    <ButtonGroup role=""group"">...</ButtonGroup>
</Div>";

    private const string TextCode =
@"<ButtonGroup>
    <ButtonGroupText AsChild=""true""><Label For=""project-name"">Project</Label></ButtonGroupText>
