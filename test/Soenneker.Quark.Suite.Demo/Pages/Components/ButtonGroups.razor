    <ButtonGroup>
        <Button Variant=""ButtonVariant.Outline"">Snooze</Button>
        <Dropdown>...</Dropdown>
    </ButtonGroup>
</ButtonGroup>";

    private const string OrientationCode =
@"<ButtonGroup Vertical=""true"" AriaLabel=""Media controls"">
    <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Icon"" aria-label=""Increase"">...</Button>
</ButtonGroup>";

    private const string SizeCode =
@"<ButtonGroup>
    <Button Size=""ButtonSize.Sm"" Variant=""ButtonVariant.Outline"">Small</Button>
</ButtonGroup>
<ButtonGroup>...</ButtonGroup>";

    private const string NestedCode =
@"<ButtonGroup>
    <ButtonGroup>...</ButtonGroup>
    <ButtonGroup Class=""min-w-[20rem]"">
        <InputGroup>...</InputGroup>
    </ButtonGroup>
</ButtonGroup>";

    private const string SeparatorCode =
@"<ButtonGroup>
    <Button Variant=""ButtonVariant.Secondary"" Size=""ButtonSize.Sm"">Copy</Button>
    <ButtonGroupSeparator />
    <Button Variant=""ButtonVariant.Secondary"" Size=""ButtonSize.Sm"">Paste</Button>
