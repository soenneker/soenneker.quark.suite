    private const string SplitCode =
@"<ButtonGroup>
    <Button Variant=""ButtonVariant.Secondary"">Button</Button>
    <ButtonGroupSeparator />
    <Button Variant=""ButtonVariant.Secondary"" Size=""ButtonSize.Icon"" aria-label=""Add"">...</Button>
