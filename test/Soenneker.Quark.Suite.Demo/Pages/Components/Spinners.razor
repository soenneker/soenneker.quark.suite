@page "/spinners"

<PageTitle>Spinners - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo" Description="The default spinner covers the minimal loading indicator case."
                        Code="@BasicCode"
                        CodeLanguage="razor">
                <Spinner />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Use Tailwind classes to scale the spinner."
                        CodeLanguage="razor"
                        Code="@(@"<Spinner Class=""size-4"" />
<Spinner Class=""size-6"" />
<Spinner Class=""size-8"" />")">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is4">
                    <Spinner BoxSize="Size.Is4" />
                    <Spinner BoxSize="Size.Is6" />
                    <Spinner Class="size-8" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button" Description="Common loading state inside actions."
                        CodeLanguage="razor"
                        Code="@(@"<Button Variant=""ButtonVariant.Default"">
    <Spinner Class=""mr-2 size-4"" />
    Saving...
</Button>")">
                <Button Variant="ButtonVariant.Default">
                    <Spinner Class="mr-2 size-4" />
                    Saving...
                </Button>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge" Description="Embed a spinner in a badge when the compact status itself is loading."
                        CodeLanguage="razor"
                        Code="@(@"<Badge Variant=""BadgeVariant.Outline"" Class=""inline-flex items-center gap-1.5""><Spinner Class=""size-3"" />Syncing</Badge>")">
                <Badge Variant="BadgeVariant.Outline" Display="Display.InlineFlex" ItemsAlign="Items.Center" Gap='Gap.Token("1.5")'><Spinner BoxSize="Size.Is3" />Syncing</Badge>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input Group" Description="Small spinners work well as trailing status indicators in inputs."
                        CodeLanguage="razor"
                        Code="@(@"<InputGroup>
    <InputGroupInput Placeholder=""Search..."" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd""><Spinner Class=""size-3"" /></InputGroupAddon>
</InputGroup>")">
                <InputGroup>
                    <InputGroupInput Placeholder="Search..." />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd"><Spinner BoxSize="Size.Is3" /></InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Empty" Description="Use a larger spinner inside an empty state while the first dataset is loading."
                        CodeLanguage="razor"
                        Code="@(@"<Div Class=""flex min-h-40 flex-col items-center justify-center gap-3 rounded-xl border border-dashed"">
    <Spinner Class=""size-8"" />
    <Span class=""text-sm text-muted-foreground"">Loading results...</Span>
</Div>")">
                <Div Class="flex min-h-40 flex-col items-center justify-center gap-3 rounded-xl border border-dashed">
                    <Spinner Class="size-8" />
                    <Span TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Loading results...</Span>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="Spinner placements still read correctly in right-to-left layouts."
                        Code="@RtlCode"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is4">
                        <Button Variant="ButtonVariant.Default">
                            جار الحفظ...
                            <Spinner Class="ml-2 size-4" />
                        </Button>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode = @"<Spinner />";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Button Variant=""ButtonVariant.Default"">
        جار الحفظ...
        <Spinner Class=""ml-2 size-4"" />
    </Button>
</DirectionProvider>";
}
