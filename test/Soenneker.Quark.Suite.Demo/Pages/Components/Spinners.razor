@page "/spinners"

<PageTitle>Spinner - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic Spinner" Description="Default shadcn-style loading spinner."
                        Code="@(@"<Spinner />")">
                <Div Class="flex items-center gap-3">
                    <Spinner />
                    <Span Class="text-sm text-muted-foreground">Loading...</Span>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sizes" Description="Use Tailwind classes to scale the spinner."
                        Code="@(@"<Spinner Class=""size-4"" />
<Spinner Class=""size-6"" />
<Spinner Class=""size-8"" />")">
                <Div Class="flex items-center gap-4">
                    <Spinner Class="size-4" />
                    <Spinner Class="size-6" />
                    <Spinner Class="size-8" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Inline in Button" Description="Common loading state inside actions."
                        Code="@(@"<Button Variant=""ButtonVariant.Default"">
    <Spinner Class=""mr-2 size-4"" />
    Saving...
</Button>")">
                <Button Variant="ButtonVariant.Default">
                    <Spinner Class="mr-2 size-4" />
                    Saving...
                </Button>
            </DemoSection>
        </Section>
    </Div>
</Div>
