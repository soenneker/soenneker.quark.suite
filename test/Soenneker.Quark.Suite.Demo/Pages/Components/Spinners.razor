@page "/spinners"

<PageTitle>Spinners - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="An indicator that can be used to show a loading state."
                        Code="@BasicCode"
                        CodeLanguage="razor">
                <Div Class="flex w-full max-w-xs flex-col gap-4 [--radius:1rem]">
                    <Item Variant="ItemVariant.Muted">
                        <ItemMedia>
                            <Spinner />
                        </ItemMedia>
                        <ItemContent>
                            <ItemTitle Class="line-clamp-1">Processing payment...</ItemTitle>
                        </ItemContent>
                        <ItemContent Class="flex-none justify-end">
                            <Span TextSize="TextSize.Sm" Class="tabular-nums">$100.00</Span>
                        </ItemContent>
                    </Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Customization" Description="You can replace the default spinner icon with any other icon by editing the Spinner component."
                        Code="@CustomizationCode"
                        CodeLanguage="razor">
                <Spinner Name="LucideIcon.Loader" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Use the size-* utility class to change the size of the spinner."
                        CodeLanguage="razor"
                        Code="@(@"<Spinner Class=""size-3"" />
<Spinner Class=""size-4"" />
<Spinner Class=""size-6"" />
<Spinner Class=""size-8"" />")">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is4">
                    <Spinner Class="size-3" />
                    <Spinner Class="size-4" />
                    <Spinner BoxSize="Size.Is6" />
                    <Spinner Class="size-8" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button" Description="Add a spinner to a button to indicate a loading state."
                        CodeLanguage="razor"
                        Code="@(@"<Button Variant=""ButtonVariant.Default"">
    <Spinner data-icon=""inline-start"" />
    Loading...
</Button>")">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is2" ItemsAlign="Items.Center">
                    <Button Variant="ButtonVariant.Default"><Spinner data-icon="inline-start" />Loading...</Button>
                    <Button Variant="ButtonVariant.Outline"><Spinner data-icon="inline-start" />Please wait</Button>
                    <Button Variant="ButtonVariant.Secondary">Processing<Spinner data-icon="inline-end" /></Button>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge" Description="Add a spinner to a badge to indicate a loading state."
                        CodeLanguage="razor"
                        Code="@(@"<Badge Variant=""BadgeVariant.Outline""><Spinner data-icon=""inline-start"" />Syncing</Badge>")">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is2" ItemsAlign="Items.Center">
                    <Badge Variant="BadgeVariant.Outline"><Spinner data-icon="inline-start" />Syncing</Badge>
                    <Badge Variant="BadgeVariant.Secondary">Updating<Spinner data-icon="inline-end" /></Badge>
                    <Badge Variant="BadgeVariant.Default"><Spinner data-icon="inline-start" />Processing</Badge>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input Group" Description="Use spinners with input groups for inline validation states."
                        CodeLanguage="razor"
                        Code="@(@"<InputGroup>
    <InputGroupInput Placeholder=""Validating..."" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd""><Spinner /></InputGroupAddon>
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd""><InputGroupButton>Send</InputGroupButton></InputGroupAddon>
</InputGroup>")">
                <InputGroup Class="max-w-sm">
                    <InputGroupInput Placeholder="Validating..." />
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd"><Spinner /></InputGroupAddon>
                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd"><InputGroupButton>Send</InputGroupButton></InputGroupAddon>
                </InputGroup>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Empty" Description="Use a spinner in an empty state while a request is processing."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyMedia Variant=""EmptyMediaVariant.Icon""><Spinner /></EmptyMedia>
        <EmptyTitle>Processing your request</EmptyTitle>
        <EmptyDescription>Please wait while we process your request. Do not refresh the page.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent><Button Variant=""ButtonVariant.Outline"">Cancel</Button></EmptyContent>
</Empty>")">
                <Empty>
                    <EmptyHeader>
                        <EmptyMedia Variant="EmptyMediaVariant.Icon"><Spinner /></EmptyMedia>
                        <EmptyTitle>Processing your request</EmptyTitle>
                        <EmptyDescription>Please wait while we process your request. Do not refresh the page.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent><Button Variant="ButtonVariant.Outline">Cancel</Button></EmptyContent>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                        Code="@RtlCode"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex w-full max-w-xs flex-col gap-4 [--radius:1rem]">
                        <Item Variant="ItemVariant.Muted">
                            <ItemMedia>
                                <Spinner />
                            </ItemMedia>
                            <ItemContent>
                                <ItemTitle Class="line-clamp-1">جاري معالجة الدفع...</ItemTitle>
                            </ItemContent>
                            <ItemContent Class="flex-none justify-end">
                                <Span TextSize="TextSize.Sm" Class="tabular-nums">١٠٠.٠٠ دولار</Span>
                            </ItemContent>
                        </Item>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Div Class=""flex w-full max-w-xs flex-col gap-4 [--radius:1rem]"">
    <Item Variant=""ItemVariant.Muted"">
        <ItemMedia>
            <Spinner />
        </ItemMedia>
        <ItemContent>
            <ItemTitle Class=""line-clamp-1"">Processing payment...</ItemTitle>
        </ItemContent>
        <ItemContent Class=""flex-none justify-end"">
            <Span TextSize=""TextSize.Sm"" Class=""tabular-nums"">$100.00</Span>
        </ItemContent>
    </Item>
</Div>";

    private const string CustomizationCode =
@"<Spinner Name=""LucideIcon.Loader"" />";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Item Variant=""ItemVariant.Muted"">
        <ItemMedia><Spinner /></ItemMedia>
        <ItemContent><ItemTitle>جاري معالجة الدفع...</ItemTitle></ItemContent>
        <ItemContent Class=""flex-none justify-end""><Span>١٠٠.٠٠ دولار</Span></ItemContent>
    </Item>
</DirectionProvider>";
}
