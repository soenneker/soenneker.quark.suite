@page "/selects"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Select Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="The standard grouped fruit select."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Select TValue="string" @bind-SelectedValue="_selectedFruit">
                    <SelectTrigger Class="w-[180px]">
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>Fruits</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" />
                            <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable"
                         Description="Long lists scroll inside the content panel."
                         Code="@ScrollableCode"
                         CodeLanguage="razor">
                <Select TValue="string" @bind-SelectedValue="_selectedTimezone">
                    <SelectTrigger Class="w-[280px]">
                        <SelectValue Placeholder="Select a timezone" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>North America</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("est")" Text="Eastern Standard Time (EST)" />
                            <SelectItem TValue="string" ItemValue="@("cst")" Text="Central Standard Time (CST)" />
                            <SelectItem TValue="string" ItemValue="@("mst")" Text="Mountain Standard Time (MST)" />
                            <SelectItem TValue="string" ItemValue="@("pst")" Text="Pacific Standard Time (PST)" />
                            <SelectItem TValue="string" ItemValue="@("akst")" Text="Alaska Standard Time (AKST)" />
                            <SelectItem TValue="string" ItemValue="@("hst")" Text="Hawaii Standard Time (HST)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Europe &amp; Africa</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("gmt")" Text="Greenwich Mean Time (GMT)" />
                            <SelectItem TValue="string" ItemValue="@("cet")" Text="Central European Time (CET)" />
                            <SelectItem TValue="string" ItemValue="@("eet")" Text="Eastern European Time (EET)" />
                            <SelectItem TValue="string" ItemValue="@("west")" Text="Western European Summer Time (WEST)" />
                            <SelectItem TValue="string" ItemValue="@("cat")" Text="Central Africa Time (CAT)" />
                            <SelectItem TValue="string" ItemValue="@("eat")" Text="East Africa Time (EAT)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Asia</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("msk")" Text="Moscow Time (MSK)" />
                            <SelectItem TValue="string" ItemValue="@("ist")" Text="India Standard Time (IST)" />
                            <SelectItem TValue="string" ItemValue="@("cst_china")" Text="China Standard Time (CST)" />
                            <SelectItem TValue="string" ItemValue="@("jst")" Text="Japan Standard Time (JST)" />
                            <SelectItem TValue="string" ItemValue="@("kst")" Text="Korea Standard Time (KST)" />
                            <SelectItem TValue="string" ItemValue="@("ist_indonesia")" Text="Indonesia Central Standard Time (WITA)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Australia &amp; Pacific</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("awst")" Text="Australian Western Standard Time (AWST)" />
                            <SelectItem TValue="string" ItemValue="@("acst")" Text="Australian Central Standard Time (ACST)" />
                            <SelectItem TValue="string" ItemValue="@("aest")" Text="Australian Eastern Standard Time (AEST)" />
                            <SelectItem TValue="string" ItemValue="@("nzst")" Text="New Zealand Standard Time (NZST)" />
                            <SelectItem TValue="string" ItemValue="@("fjt")" Text="Fiji Time (FJT)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>South America</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("art")" Text="Argentina Time (ART)" />
                            <SelectItem TValue="string" ItemValue="@("bot")" Text="Bolivia Time (BOT)" />
                            <SelectItem TValue="string" ItemValue="@("brt")" Text="Brasilia Time (BRT)" />
                            <SelectItem TValue="string" ItemValue="@("clt")" Text="Chile Standard Time (CLT)" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="Field-backed select with helper text and submitted value preview."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <EditForm Model="_formModel" OnSubmit="@(_ => HandleSubmit())" class="w-2/3 space-y-6">
                    <Field>
                        <FieldLabel>Email</FieldLabel>
                        <Select TValue="string" @bind-SelectedValue="_formModel.Email">
                            <SelectTrigger>
                                <SelectValue Placeholder="Select a verified email to display" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem TValue="string" ItemValue="@("m@example.com")" Text="m@example.com" />
                                <SelectItem TValue="string" ItemValue="@("m@google.com")" Text="m@google.com" />
                                <SelectItem TValue="string" ItemValue="@("m@support.com")" Text="m@support.com" />
                            </SelectContent>
                        </Select>
                        <FieldDescription>
                            You can manage email addresses in your email settings.
                        </FieldDescription>
                        @if (_showFormError)
                        {
                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.Destructive" Margin="Margin.Is0">
                                Please select an email to display.
                            </Paragraph>
                        }
                    </Field>
                    <Button Type="ButtonType.Submit">Submit</Button>
                    @if (!string.IsNullOrEmpty(_formMessage))
                    {
                        <pre class="rounded-lg bg-neutral-950 p-4 text-sm text-white">@_formMessage</pre>
                    }
                </EditForm>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Native Form"
                         Description="Required select participates in native form submission through the hidden select bridge."
                         Code="@NativeFormCode"
                         CodeLanguage="razor">
                <form class="w-2/3 space-y-6" data-testid="select-native-form" @onsubmit="HandleNativeFormSubmit" @onsubmit:preventDefault="true">
                    <Field>
                        <FieldLabel>Framework</FieldLabel>
                        <Select TValue="string"
                                Name="framework"
                                Required="true"
                                @bind-SelectedValue="_nativeFormValue">
                            <SelectTrigger>
                                <SelectValue Placeholder="Select a framework" />
                            </SelectTrigger>
                            <SelectContent ContentPosition="popper">
                                <SelectItem TValue="string" ItemValue="@("astro")" Text="Astro" />
                                <SelectItem TValue="string" ItemValue="@("next")" Text="Next.js" />
                                <SelectItem TValue="string" ItemValue="@("sveltekit")" Text="SvelteKit" />
                            </SelectContent>
                        </Select>
                    </Field>
                    <Button Type="ButtonType.Submit">Submit native form</Button>
                    <pre class="rounded-lg bg-neutral-950 p-4 text-sm text-white" data-testid="select-native-form-result">@_nativeFormSubmission</pre>
                </form>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextColor="TextColor.MutedForeground">
                    Positioning modes, separated groups, disabled items, invalid states, field composition, and RTL.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Align Item With Trigger"
                         Description="Use the default item-aligned mode or switch to popper positioning with shadcn-style trigger sizing and alignment."
                         Code="@AlignItemCode"
                         CodeLanguage="razor">
                <Div Display="Display.Grid" Gap="Gap.Is4" class="md:grid-cols-2">
                    <Select TValue="string" @bind-SelectedValue="_selectedAlignedFruit">
                        <SelectTrigger Width="Width.IsFull">
                            <SelectValue Placeholder="Item aligned" />
                        </SelectTrigger>
                        <SelectContent ContentPosition="item-aligned">
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                                <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                                <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>

                    <Select TValue="string" @bind-SelectedValue="_selectedPopperFruit">
                        <SelectTrigger Width="Width.IsFull">
                            <SelectValue Placeholder="Popper" />
                        </SelectTrigger>
                        <SelectContent ContentPosition="popper">
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                                <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                                <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Groups"
                         Description="Separate options with labels and a separator."
                         Code="@GroupsCode"
                         CodeLanguage="razor">
                <Select TValue="string" @bind-SelectedValue="_selectedProduce">
                    <SelectTrigger Class="w-full max-w-48">
                        <SelectValue Placeholder="Select produce" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>Fruits</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                        </SelectGroup>
                        <SelectSeparator />
                        <SelectGroup>
                            <SelectLabel>Vegetables</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("carrot")" Text="Carrot" Disabled="true" />
                            <SelectItem TValue="string" ItemValue="@("broccoli")" Text="Broccoli" />
                            <SelectItem TValue="string" ItemValue="@("courgette")" Text="Courgette" />
                            <SelectItem TValue="string" ItemValue="@("spinach")" Text="Spinach" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disable the trigger or individual items."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Select TValue="string" Disabled="true">
                    <SelectTrigger Class="w-full max-w-48">
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" Disabled="true" />
                            <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Mark the field invalid when validation fails."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <Field IsInvalid="true" Class="w-full max-w-48">
                    <FieldLabel>Fruit</FieldLabel>
                    <Select TValue="string">
                        <SelectTrigger aria-invalid="true">
                            <SelectValue Placeholder="Select a fruit" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                                <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                                <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                    <FieldError>Please select a fruit.</FieldError>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field"
                         Description="Select inside Field with label and description."
                         Code="@FieldCode"
                         CodeLanguage="razor">
                <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <FieldLabel>Department</FieldLabel>
                    <Select TValue="string" @bind-SelectedValue="_selectedDepartment">
                        <SelectTrigger>
                            <SelectValue Placeholder="Choose department" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("engineering")" Text="Engineering" />
                                <SelectItem TValue="string" ItemValue="@("design")" Text="Design" />
                                <SelectItem TValue="string" ItemValue="@("marketing")" Text="Marketing" />
                                <SelectItem TValue="string" ItemValue="@("sales")" Text="Sales" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                    <FieldDescription>Select your department or area of work.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Select also supports right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Select TValue="string" @bind-SelectedValue="_selectedRtlFruit">
                            <SelectTrigger Class="w-full max-w-48">
                                <SelectValue Placeholder="اختر فاكهة" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectGroup>
                                    <SelectItem TValue="string" ItemValue="@("apple")" Text="تفاح" />
                                    <SelectItem TValue="string" ItemValue="@("banana")" Text="موز" />
                                    <SelectItem TValue="string" ItemValue="@("grapes")" Text="عنب" />
                                </SelectGroup>
                            </SelectContent>
                        </Select>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private sealed class SelectFormModel
    {
        public string? Email { get; set; }
    }

    private string? _selectedFruit;
    private string? _selectedAlignedFruit;
    private string? _selectedPopperFruit;
    private string? _selectedProduce;
    private string? _selectedTimezone;
    private string? _selectedRtlFruit;
    private string? _selectedDepartment;
    private string? _nativeFormValue;
    private readonly SelectFormModel _formModel = new();
    private bool _showFormError;
    private string? _formMessage;
    private string _nativeFormSubmission = "No submission yet.";

    private const string DemoCode =
@"<Select TValue=""string"" @bind-SelectedValue=""_selectedFruit"">
    <SelectTrigger Class=""w-[180px]"">
        <SelectValue Placeholder=""Select a fruit"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectLabel>Fruits</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
            <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
            <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            <SelectItem TValue=""string"" ItemValue=""@(""grapes"")"" Text=""Grapes"" />
            <SelectItem TValue=""string"" ItemValue=""@(""pineapple"")"" Text=""Pineapple"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string ScrollableCode =
@"<Select TValue=""string"" @bind-SelectedValue=""_selectedTimezone"">
    <SelectTrigger Class=""w-[280px]"">
        <SelectValue Placeholder=""Select a timezone"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectLabel>North America</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""est"")"" Text=""Eastern Standard Time (EST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""cst"")"" Text=""Central Standard Time (CST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""mst"")"" Text=""Mountain Standard Time (MST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""pst"")"" Text=""Pacific Standard Time (PST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""akst"")"" Text=""Alaska Standard Time (AKST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""hst"")"" Text=""Hawaii Standard Time (HST)"" />
        </SelectGroup>
        <SelectGroup>
            <SelectLabel>Europe &amp; Africa</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""gmt"")"" Text=""Greenwich Mean Time (GMT)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""cet"")"" Text=""Central European Time (CET)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""eet"")"" Text=""Eastern European Time (EET)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""west"")"" Text=""Western European Summer Time (WEST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""cat"")"" Text=""Central Africa Time (CAT)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""eat"")"" Text=""East Africa Time (EAT)"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnSubmit=""@(_ => HandleSubmit())"" class=""w-2/3 space-y-6"">
    <Field>
        <FieldLabel>Email</FieldLabel>
        <Select TValue=""string"" @bind-SelectedValue=""_formModel.Email"">
            <SelectTrigger>
                <SelectValue Placeholder=""Select a verified email to display"" />
            </SelectTrigger>
            <SelectContent>
                <SelectItem TValue=""string"" ItemValue=""@(""m@example.com"")"" Text=""m@example.com"" />
                <SelectItem TValue=""string"" ItemValue=""@(""m@google.com"")"" Text=""m@google.com"" />
                <SelectItem TValue=""string"" ItemValue=""@(""m@support.com"")"" Text=""m@support.com"" />
            </SelectContent>
        </Select>
        <FieldDescription>
            You can manage email addresses in your email settings.
        </FieldDescription>
    </Field>
    <Button Type=""ButtonType.Submit"">Submit</Button>
</EditForm>";

    private const string NativeFormCode =
@"<form class=""w-2/3 space-y-6"" @onsubmit=""HandleNativeFormSubmit"">
    <Field>
        <FieldLabel>Framework</FieldLabel>
        <Select TValue=""string"" Name=""framework"" Required=""true"" @bind-SelectedValue=""_nativeFormValue"">
            <SelectTrigger>
                <SelectValue Placeholder=""Select a framework"" />
            </SelectTrigger>
            <SelectContent>
                <SelectItem TValue=""string"" ItemValue=""@(""astro"")"" Text=""Astro"" />
                <SelectItem TValue=""string"" ItemValue=""@(""next"")"" Text=""Next.js"" />
                <SelectItem TValue=""string"" ItemValue=""@(""sveltekit"")"" Text=""SvelteKit"" />
            </SelectContent>
        </Select>
    </Field>
    <Button Type=""ButtonType.Submit"">Submit native form</Button>
</form>";

    private const string AlignItemCode =
@"<Div class=""grid gap-4 md:grid-cols-2"">
    <Select TValue=""string"" @bind-SelectedValue=""_selectedAlignedFruit"">
        <SelectTrigger Class=""w-full"">
            <SelectValue Placeholder=""Item aligned"" />
        </SelectTrigger>
        <SelectContent ContentPosition=""item-aligned"">
            <SelectGroup>
                <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
                <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
                <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            </SelectGroup>
        </SelectContent>
    </Select>
    <Select TValue=""string"" @bind-SelectedValue=""_selectedPopperFruit"">
        <SelectTrigger Class=""w-full"">
            <SelectValue Placeholder=""Popper"" />
        </SelectTrigger>
        <SelectContent ContentPosition=""popper"">
            <SelectGroup>
                <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
                <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
                <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            </SelectGroup>
        </SelectContent>
    </Select>
</Div>";

    private const string GroupsCode =
@"<Select TValue=""string"" @bind-SelectedValue=""_selectedProduce"">
    <SelectTrigger Class=""w-full max-w-48"">
        <SelectValue Placeholder=""Select produce"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectLabel>Fruits</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
            <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
            <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
        </SelectGroup>
        <SelectSeparator />
        <SelectGroup>
            <SelectLabel>Vegetables</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""carrot"")"" Text=""Carrot"" Disabled=""true"" />
            <SelectItem TValue=""string"" ItemValue=""@(""broccoli"")"" Text=""Broccoli"" />
            <SelectItem TValue=""string"" ItemValue=""@(""courgette"")"" Text=""Courgette"" />
            <SelectItem TValue=""string"" ItemValue=""@(""spinach"")"" Text=""Spinach"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string DisabledCode =
@"<Select TValue=""string"" Disabled=""true"">
    <SelectTrigger Class=""w-full max-w-48"">
        <SelectValue Placeholder=""Select a fruit"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
            <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
            <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            <SelectItem TValue=""string"" ItemValue=""@(""grapes"")"" Text=""Grapes"" Disabled=""true"" />
            <SelectItem TValue=""string"" ItemValue=""@(""pineapple"")"" Text=""Pineapple"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string InvalidCode =
@"<Field IsInvalid=""true"" Class=""w-full max-w-48"">
    <FieldLabel>Fruit</FieldLabel>
    <Select TValue=""string"">
        <SelectTrigger aria-invalid=""true"">
            <SelectValue Placeholder=""Select a fruit"" />
        </SelectTrigger>
        <SelectContent>
            <SelectGroup>
                <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
                <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
                <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            </SelectGroup>
        </SelectContent>
    </Select>
    <FieldError>Please select a fruit.</FieldError>
</Field>";

    private const string FieldCode =
@"<Field Class=""w-full max-w-xs"">
    <FieldLabel>Department</FieldLabel>
    <Select TValue=""string"" @bind-SelectedValue=""_selectedDepartment"">
        <SelectTrigger>
            <SelectValue Placeholder=""Choose department"" />
        </SelectTrigger>
        <SelectContent>
            <SelectGroup>
                <SelectItem TValue=""string"" ItemValue=""@(""engineering"")"" Text=""Engineering"" />
                <SelectItem TValue=""string"" ItemValue=""@(""design"")"" Text=""Design"" />
                <SelectItem TValue=""string"" ItemValue=""@(""marketing"")"" Text=""Marketing"" />
                <SelectItem TValue=""string"" ItemValue=""@(""sales"")"" Text=""Sales"" />
            </SelectGroup>
        </SelectContent>
    </Select>
    <FieldDescription>Select your department or area of work.</FieldDescription>
</Field>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div class=""w-full text-right"">
        <Select TValue=""string"" @bind-SelectedValue=""_selectedRtlFruit"">
            <SelectTrigger Class=""w-full max-w-48"">
                <SelectValue Placeholder=""اختر فاكهة"" />
            </SelectTrigger>
            <SelectContent>
                <SelectGroup>
                    <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""تفاح"" />
                    <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""موز"" />
                    <SelectItem TValue=""string"" ItemValue=""@(""grapes"")"" Text=""عنب"" />
                </SelectGroup>
            </SelectContent>
        </Select>
    </Div>
</DirectionProvider>";

    private void HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(_formModel.Email))
        {
            _showFormError = true;
            _formMessage = null;
            return;
        }

        _showFormError = false;
        _formMessage = $$"""
                        {
                          "email": "{{_formModel.Email}}"
                        }
                        """;
    }

    private void HandleNativeFormSubmit()
    {
        _nativeFormSubmission = $"framework={_nativeFormValue}";
    }
}
