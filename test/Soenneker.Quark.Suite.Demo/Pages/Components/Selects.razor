        </SelectGroup>
        <SelectGroup>
            <SelectLabel>Asia</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""msk"")"" Text=""Moscow Time"" />
            <SelectItem TValue=""string"" ItemValue=""@(""ist"")"" Text=""India Standard Time"" />
            <SelectItem TValue=""string"" ItemValue=""@(""cst_china"")"" Text=""China Standard Time"" />
            <SelectItem TValue=""string"" ItemValue=""@(""jst"")"" Text=""Japan Standard Time"" />
