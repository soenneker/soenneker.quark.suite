@page "/selects"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Select Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Code="@DemoCode">
                <Select TValue="string" @bind-SelectedValue="_selectedFruit">
                    <SelectTrigger Class="w-full max-w-48">
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>Fruits</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" />
                            <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Code="@DisabledCode">
                <Select TValue="string" Disabled="true">
                    <SelectTrigger Class="w-full max-w-48">
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" Disabled="true" />
                            <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Groups"
                         Code="@GroupsCode">
                <Select TValue="string" @bind-SelectedValue="_selectedProduce">
                    <SelectTrigger Class="w-full max-w-48">
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>Fruits</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                        </SelectGroup>
                        <SelectSeparator />
                        <SelectGroup>
                            <SelectLabel>Vegetables</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("carrot")" Text="Carrot" />
                            <SelectItem TValue="string" ItemValue="@("broccoli")" Text="Broccoli" />
                            <SelectItem TValue="string" ItemValue="@("spinach")" Text="Spinach" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable"
                         Code="@ScrollableCode">
                <Select TValue="string" @bind-SelectedValue="_selectedTimezone">
                    <SelectTrigger Class="w-full max-w-64">
                        <SelectValue Placeholder="Select a timezone" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>North America</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("est")" Text="Eastern Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("cst")" Text="Central Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("mst")" Text="Mountain Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("pst")" Text="Pacific Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("akst")" Text="Alaska Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("hst")" Text="Hawaii Standard Time" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Europe &amp; Africa</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("gmt")" Text="Greenwich Mean Time" />
                            <SelectItem TValue="string" ItemValue="@("cet")" Text="Central European Time" />
                            <SelectItem TValue="string" ItemValue="@("eet")" Text="Eastern European Time" />
                            <SelectItem TValue="string" ItemValue="@("west")" Text="Western European Summer Time" />
                            <SelectItem TValue="string" ItemValue="@("cat")" Text="Central Africa Time" />
                            <SelectItem TValue="string" ItemValue="@("eat")" Text="East Africa Time" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Asia</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("msk")" Text="Moscow Time" />
                            <SelectItem TValue="string" ItemValue="@("ist")" Text="India Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("cst_china")" Text="China Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("jst")" Text="Japan Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("kst")" Text="Korea Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("ist_indonesia")" Text="Indonesia Central Standard Time" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Australia &amp; Pacific</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("awst")" Text="Australian Western Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("acst")" Text="Australian Central Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("aest")" Text="Australian Eastern Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("nzst")" Text="New Zealand Standard Time" />
                            <SelectItem TValue="string" ItemValue="@("fjt")" Text="Fiji Time" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>South America</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("art")" Text="Argentina Time" />
                            <SelectItem TValue="string" ItemValue="@("bot")" Text="Bolivia Time" />
                            <SelectItem TValue="string" ItemValue="@("brt")" Text="Brasilia Time" />
                            <SelectItem TValue="string" ItemValue="@("clt")" Text="Chile Standard Time" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Code="@InvalidCode">
                <Field IsInvalid="true" Class="w-full max-w-48">
                    <FieldLabel>Fruit</FieldLabel>
                    <Select TValue="string">
                        <SelectTrigger aria-invalid="true">
                            <SelectValue Placeholder="Select a fruit" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                                <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                                <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                    <FieldError>Please select a fruit.</FieldError>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field"
                         Code="@FieldCode">
                <Field Class="w-full max-w-xs">
                    <FieldLabel>Department</FieldLabel>
                    <Select TValue="string" @bind-SelectedValue="_selectedDepartment">
                        <SelectTrigger>
                            <SelectValue Placeholder="Choose department" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("engineering")" Text="Engineering" />
                                <SelectItem TValue="string" ItemValue="@("design")" Text="Design" />
                                <SelectItem TValue="string" ItemValue="@("marketing")" Text="Marketing" />
                                <SelectItem TValue="string" ItemValue="@("sales")" Text="Sales" />
                                <SelectItem TValue="string" ItemValue="@("support")" Text="Customer Support" />
                                <SelectItem TValue="string" ItemValue="@("hr")" Text="Human Resources" />
                                <SelectItem TValue="string" ItemValue="@("finance")" Text="Finance" />
                                <SelectItem TValue="string" ItemValue="@("operations")" Text="Operations" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                    <FieldDescription>Select your department or area of work.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show additional select integrations beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form Validation"
                         Description="Select integrates with `EditForm` and validation messaging through two-way selection binding."
                         Code="@FormCode">
                <EditForm Model="_formModel" OnValidSubmit="HandleSubmit" class="max-w-md space-y-4">
                    <DataAnnotationsValidator />
                    <Field>
                        <FieldLabel>Favorite Fruit</FieldLabel>
                        <Select TValue="string" @bind-SelectedValue="_formModel.Fruit">
                            <SelectTrigger>
                                <SelectValue Placeholder="Select a fruit" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                                <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                                <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            </SelectContent>
                        </Select>
                        <ValidationMessage For="@(() => _formModel.Fruit)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                    </Field>
                    <Div Display="Display.Flex" Gap="Gap.Is4">
                        <Button Type="ButtonType.Submit">Submit</Button>
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Reset</Button>
                    </Div>
                    @if (!string.IsNullOrEmpty(_formMessage))
                    {
                        <Div class="p-4 bg-card rounded-lg border">
                            <Paragraph TextSize="TextSize.Sm">@_formMessage</Paragraph>
                        </Div>
                    }
                </EditForm>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _selectedFruit;
    private string? _selectedProduce;
    private string? _selectedTimezone;
    private string? _selectedDepartment;

    private SelectFormModel _formModel = new();
    private string? _formMessage;

    private const string DemoCode =
@"<Select TValue=""string"" @bind-SelectedValue=""_selectedFruit"">
    <SelectTrigger Class=""w-full max-w-48"">
        <SelectValue Placeholder=""Select a fruit"" />
