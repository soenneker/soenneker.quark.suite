@page "/selects"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Select Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection Title="Align Item With Trigger" Description="The new composed select mirrors the shadcn trigger/content/value pattern." Code="@(@"<Select TValue=""string"" @bind-SelectedValue=""_selectedFruit"">
    <SelectTrigger>
        <SelectValue Placeholder=""Select a fruit"" />
    </SelectTrigger>
    <SelectContent>
        <SelectItem TValue=""string"" ItemValue=""apple"" Text=""Apple"" />
        <SelectItem TValue=""string"" ItemValue=""banana"" Text=""Banana"" />
        <SelectItem TValue=""string"" ItemValue=""blueberry"" Text=""Blueberry"" />
    </SelectContent>
</Select>")">
            <Div class="flex items-center gap-4">
                <Div class="w-[220px]">
                    <Select TValue="string" @bind-SelectedValue="_selectedFruit">
                        <SelectTrigger>
                            <SelectValue Placeholder="Select a fruit" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" />
                            <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                        </SelectContent>
                    </Select>
                </Div>
                @if (!string.IsNullOrEmpty(_selectedFruit))
                {
                    <Paragraph class="text-sm">Selected: <strong>@_selectedFruit</strong></Paragraph>
                }
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Groups" Description="Organize related items into labeled groups." Code="@(@"<Select TValue=""string"" @bind-SelectedValue=""_selectedAnimal"">
    <SelectTrigger>
        <SelectValue Placeholder=""Select an animal"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup Label=""Mammals"">
            <SelectItem TValue=""string"" ItemValue=""cat"" Text=""Cat"" />
            <SelectItem TValue=""string"" ItemValue=""dog"" Text=""Dog"" />
        </SelectGroup>
        <SelectSeparator />
        <SelectGroup Label=""Birds"">
            <SelectItem TValue=""string"" ItemValue=""eagle"" Text=""Eagle"" />
            <SelectItem TValue=""string"" ItemValue=""parrot"" Text=""Parrot"" />
        </SelectGroup>
    </SelectContent>
</Select>")">
            <Div class="flex items-center gap-4">
                <Div class="w-[220px]">
                    <Select TValue="string" @bind-SelectedValue="_selectedAnimal">
                        <SelectTrigger>
                            <SelectValue Placeholder="Select an animal" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectGroup Label="Mammals">
                                <SelectItem TValue="string" ItemValue="@("cat")" Text="Cat" />
                                <SelectItem TValue="string" ItemValue="@("dog")" Text="Dog" />
                                <SelectItem TValue="string" ItemValue="@("elephant")" Text="Elephant" />
                            </SelectGroup>
                            <SelectSeparator />
                            <SelectGroup Label="Birds">
                                <SelectItem TValue="string" ItemValue="@("eagle")" Text="Eagle" />
                                <SelectItem TValue="string" ItemValue="@("parrot")" Text="Parrot" />
                                <SelectItem TValue="string" ItemValue="@("penguin")" Text="Penguin" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                </Div>
                @if (!string.IsNullOrEmpty(_selectedAnimal))
                {
                    <Paragraph class="text-sm">Selected: <strong>@_selectedAnimal</strong></Paragraph>
                }
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Scrollable" Description="Use a taller content panel with overflow when the option list is long." Code="@(@"<Select TValue=""string"" @bind-SelectedValue=""_selectedCountry"">
    <SelectTrigger>
        <SelectValue Placeholder=""Select a country"" />
    </SelectTrigger>
    <SelectContent Class=""max-h-60"">
        @foreach (var country in _countries)
        {
            <SelectItem TValue=""string"" ItemValue=""@country"" Text=""@country"" />
        }
    </SelectContent>
</Select>")">
            <Div class="flex items-center gap-4">
                <Div class="w-[220px]">
                    <Select TValue="string" @bind-SelectedValue="_selectedCountry">
                        <SelectTrigger>
                            <SelectValue Placeholder="Select a country" />
                        </SelectTrigger>
                        <SelectContent Class="max-h-60">
                            @foreach (var country in _countries)
                            {
                                <SelectItem TValue="string" ItemValue="@country" Text="@country" />
                            }
                        </SelectContent>
                    </Select>
                </Div>
                @if (!string.IsNullOrEmpty(_selectedCountry))
                {
                    <Paragraph class="text-sm">Selected: <strong>@_selectedCountry</strong></Paragraph>
                }
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Disabled"
                     Description="Disable a select when the user cannot change the value yet or the current step is locked."
                     Code="@(@"<Select TValue=""string"" SelectedValue=""starter"" Disabled=""true"">
    <SelectTrigger>
        <SelectValue Placeholder=""Choose a plan"" />
    </SelectTrigger>
    <SelectContent>
        <SelectItem TValue=""string"" ItemValue=""starter"" Text=""Starter"" />
        <SelectItem TValue=""string"" ItemValue=""pro"" Text=""Pro"" />
        <SelectItem TValue=""string"" ItemValue=""enterprise"" Text=""Enterprise"" />
    </SelectContent>
</Select>")">
            <Div class="flex items-center gap-4">
                <Div class="w-[220px]">
                    <Select TValue="string" SelectedValue="@("starter")" Disabled="true">
                        <SelectTrigger>
                            <SelectValue Placeholder="Choose a plan" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectItem TValue="string" ItemValue="@("starter")" Text="Starter" />
                            <SelectItem TValue="string" ItemValue="@("pro")" Text="Pro" />
                            <SelectItem TValue="string" ItemValue="@("enterprise")" Text="Enterprise" />
                        </SelectContent>
                    </Select>
                </Div>
                <Paragraph class="text-sm text-muted-foreground">The current plan is locked until the billing cycle closes.</Paragraph>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Invalid" Description="Apply invalid treatment on the trigger when the current selection needs correction." Code="@(@"<Select TValue=""string"" SelectedValue="""" >
    <SelectTrigger Class=""border-destructive text-destructive"">
        <SelectValue Placeholder=""Select a value"" />
    </SelectTrigger>
    <SelectContent>
        <SelectItem TValue=""string"" ItemValue=""starter"" Text=""Starter"" />
        <SelectItem TValue=""string"" ItemValue=""pro"" Text=""Pro"" />
    </SelectContent>
</Select>")">
            <Div class="flex items-center gap-4">
                <Div class="w-[220px]">
                    <Select TValue="string" SelectedValue="@("")">
                        <SelectTrigger Class="border-destructive text-destructive">
                            <SelectValue Placeholder="Select a value" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectItem TValue="string" ItemValue="@("starter")" Text="Starter" />
                            <SelectItem TValue="string" ItemValue="@("pro")" Text="Pro" />
                        </SelectContent>
                    </Select>
                </Div>
                <Paragraph class="text-sm text-destructive">Please choose a plan before continuing.</Paragraph>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Form Validation" Description="Select integrates with EditForm and validation messaging through two-way SelectedValue binding." Code="@(@"<EditForm Model=""_formModel"" OnValidSubmit=""HandleSubmit"" class=""max-w-md space-y-4"">
    <DataAnnotationsValidator />
    <Select TValue=""string"" @bind-SelectedValue=""_formModel.Fruit"">
        <SelectTrigger>
            <SelectValue Placeholder=""Select a fruit"" />
        </SelectTrigger>
        <SelectContent>
            <SelectItem TValue=""string"" ItemValue=""apple"" Text=""Apple"" />
            <SelectItem TValue=""string"" ItemValue=""banana"" Text=""Banana"" />
            <SelectItem TValue=""string"" ItemValue=""blueberry"" Text=""Blueberry"" />
        </SelectContent>
    </Select>
</EditForm>")">
            <EditForm Model="_formModel" OnValidSubmit="HandleSubmit" class="max-w-md space-y-4">
                <DataAnnotationsValidator />
                <Div class="space-y-2">
                    <Label class="text-sm font-medium">Favorite Fruit</Label>
                    <Select TValue="string" @bind-SelectedValue="_formModel.Fruit">
                        <SelectTrigger>
                            <SelectValue Placeholder="Select a fruit" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                        </SelectContent>
                    </Select>
                    <ValidationMessage For="@(() => _formModel.Fruit)" class="text-sm text-destructive" />
                </Div>
                <Div class="flex gap-4">
                    <Button Type="@ButtonType.Submit" Variant="ButtonVariant.Default">Submit</Button>
                    <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Reset</Button>
                </Div>
                @if (!string.IsNullOrEmpty(_formMessage))
                {
                    <Div class="p-4 bg-card rounded-lg border">
                        <Paragraph class="text-sm">@_formMessage</Paragraph>
                    </Div>
                }
            </EditForm>
        </DemoSection>
    </Section>
</Div>

@code {
    private string? _selectedFruit;
    private string? _selectedAnimal;
    private string? _selectedCountry;
    private readonly string[] _countries =
    {
        "Afghanistan", "Albania", "Algeria", "Andorra", "Angola",
        "Argentina", "Armenia", "Australia", "Austria", "Azerbaijan",
        "Bahamas", "Bahrain", "Bangladesh", "Barbados", "Belarus",
        "Belgium", "Belize", "Benin", "Bhutan", "Bolivia",
        "Brazil", "Bulgaria", "Canada", "Chile", "China",
        "Colombia", "Croatia", "Czech Republic", "Denmark", "Egypt"
    };

    private SelectFormModel _formModel = new();
    private string? _formMessage;

    private void HandleSubmit()
    {
        _formMessage = $"Submitted! Fruit: {_formModel.Fruit}";
    }

    private void ResetForm()
    {
        _formModel = new();
        _formMessage = null;
    }

    private sealed class SelectFormModel
    {
        [Required(ErrorMessage = "Please select a fruit.")]
        public string? Fruit { get; set; }
    }
}
