@page "/selects"
<PageTitle>Select Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays a list of options for the user to pick from—triggered by a button."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Select TValue="string" @bind-SelectedValue="_selectedFruit">
                    <SelectTrigger Width='Width.Token("[180px]")'>
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>Fruits</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" />
                            <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Align Item With Trigger"
                         Description="Use the position prop on SelectContent to control alignment. When position=&quot;item-aligned&quot; (default), the popup positions so the selected item appears over the trigger. When position=&quot;popper&quot;, the popup aligns to the trigger edge."
                         Code="@AlignItemCode"
                         CodeLanguage="razor">
                <Div Space="Space.Y.Is4" Width='Width.Token("[180px]")'>
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Gap="Gap.Is4">
                        <Div Space="Space.Y.Is1">
                            <Label TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" for="select-align-item">Align Item</Label>
                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                                Toggle to align the item with the trigger.
                            </Paragraph>
                        </Div>
                        <Switch Id="select-align-item" @bind-Checked="_alignItemWithTrigger" />
                    </Div>
                    <Select TValue="string" @bind-SelectedValue="_selectedAlignedFruit">
                        <SelectTrigger Width="Width.IsFull">
                            <SelectValue Placeholder="Select a fruit" />
                        </SelectTrigger>
                        <SelectContent ContentPosition="@(_alignItemWithTrigger ? SelectPosition.ItemAligned : SelectPosition.Popper)">
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                                <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                                <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                                <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" />
                                <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Groups"
                         Description="Use SelectGroup, SelectLabel, and SelectSeparator to organize items."
                         Code="@GroupsCode"
                         CodeLanguage="razor">
                <Select TValue="string" @bind-SelectedValue="_selectedProduce">
                    <SelectTrigger Class="w-full max-w-48">
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>Fruits</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                        </SelectGroup>
                        <SelectSeparator />
                        <SelectGroup>
                            <SelectLabel>Vegetables</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("carrot")" Text="Carrot" Disabled="true" />
                            <SelectItem TValue="string" ItemValue="@("broccoli")" Text="Broccoli" />
                            <SelectItem TValue="string" ItemValue="@("courgette")" Text="Courgette" />
                            <SelectItem TValue="string" ItemValue="@("spinach")" Text="Spinach" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable"
                         Description="A select with many items that scrolls."
                         Code="@ScrollableCode"
                         CodeLanguage="razor">
                <Select TValue="string" @bind-SelectedValue="_selectedTimezone">
                    <SelectTrigger Class="w-[280px]">
                        <SelectValue Placeholder="Select a timezone" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectLabel>North America</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("est")" Text="Eastern Standard Time (EST)" />
                            <SelectItem TValue="string" ItemValue="@("cst")" Text="Central Standard Time (CST)" />
                            <SelectItem TValue="string" ItemValue="@("mst")" Text="Mountain Standard Time (MST)" />
                            <SelectItem TValue="string" ItemValue="@("pst")" Text="Pacific Standard Time (PST)" />
                            <SelectItem TValue="string" ItemValue="@("akst")" Text="Alaska Standard Time (AKST)" />
                            <SelectItem TValue="string" ItemValue="@("hst")" Text="Hawaii Standard Time (HST)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Europe &amp; Africa</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("gmt")" Text="Greenwich Mean Time (GMT)" />
                            <SelectItem TValue="string" ItemValue="@("cet")" Text="Central European Time (CET)" />
                            <SelectItem TValue="string" ItemValue="@("eet")" Text="Eastern European Time (EET)" />
                            <SelectItem TValue="string" ItemValue="@("west")" Text="Western European Summer Time (WEST)" />
                            <SelectItem TValue="string" ItemValue="@("cat")" Text="Central Africa Time (CAT)" />
                            <SelectItem TValue="string" ItemValue="@("eat")" Text="East Africa Time (EAT)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Asia</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("msk")" Text="Moscow Time (MSK)" />
                            <SelectItem TValue="string" ItemValue="@("ist")" Text="India Standard Time (IST)" />
                            <SelectItem TValue="string" ItemValue="@("cst_china")" Text="China Standard Time (CST)" />
                            <SelectItem TValue="string" ItemValue="@("jst")" Text="Japan Standard Time (JST)" />
                            <SelectItem TValue="string" ItemValue="@("kst")" Text="Korea Standard Time (KST)" />
                            <SelectItem TValue="string" ItemValue="@("ist_indonesia")" Text="Indonesia Central Standard Time (WITA)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>Australia &amp; Pacific</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("awst")" Text="Australian Western Standard Time (AWST)" />
                            <SelectItem TValue="string" ItemValue="@("acst")" Text="Australian Central Standard Time (ACST)" />
                            <SelectItem TValue="string" ItemValue="@("aest")" Text="Australian Eastern Standard Time (AEST)" />
                            <SelectItem TValue="string" ItemValue="@("nzst")" Text="New Zealand Standard Time (NZST)" />
                            <SelectItem TValue="string" ItemValue="@("fjt")" Text="Fiji Time (FJT)" />
                        </SelectGroup>
                        <SelectGroup>
                            <SelectLabel>South America</SelectLabel>
                            <SelectItem TValue="string" ItemValue="@("art")" Text="Argentina Time (ART)" />
                            <SelectItem TValue="string" ItemValue="@("bot")" Text="Bolivia Time (BOT)" />
                            <SelectItem TValue="string" ItemValue="@("brt")" Text="Brasilia Time (BRT)" />
                            <SelectItem TValue="string" ItemValue="@("clt")" Text="Chile Standard Time (CLT)" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Select TValue="string" Disabled="true">
                    <SelectTrigger Class="w-full max-w-48">
                        <SelectValue Placeholder="Select a fruit" />
                    </SelectTrigger>
                    <SelectContent>
                        <SelectGroup>
                            <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                            <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                            <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            <SelectItem TValue="string" ItemValue="@("grapes")" Text="Grapes" Disabled="true" />
                            <SelectItem TValue="string" ItemValue="@("pineapple")" Text="Pineapple" />
                        </SelectGroup>
                    </SelectContent>
                </Select>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Add the data-invalid attribute to the Field component and the aria-invalid attribute to the SelectTrigger component to show an error state."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <Field IsInvalid="true" Class="w-full max-w-48">
                    <FieldLabel>Fruit</FieldLabel>
                    <Select TValue="string">
                        <SelectTrigger aria-invalid="true">
                            <SelectValue Placeholder="Select a fruit" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectGroup>
                                <SelectItem TValue="string" ItemValue="@("apple")" Text="Apple" />
                                <SelectItem TValue="string" ItemValue="@("banana")" Text="Banana" />
                                <SelectItem TValue="string" ItemValue="@("blueberry")" Text="Blueberry" />
                            </SelectGroup>
                        </SelectContent>
                    </Select>
                    <FieldError>Please select a fruit.</FieldError>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <Div Space="Space.Y.Is8" Width="Width.IsFull">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Width="Width.IsFull">
                        <Select TValue="string" SelectedValue="@("ar")">
                            <SelectTrigger Class="w-44">
                                <SelectValue />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem TValue="string" ItemValue="@("ar")" Text="Arabic (العربية)" />
                                <SelectItem TValue="string" ItemValue="@("en")" Text="English" />
                            </SelectContent>
                        </Select>
                        <Icon Name="LucideIcon.Info" Class="size-4" TextColor="TextColor.MutedForeground" />
                    </Div>
                    <DirectionProvider Dir="rtl">
                        <Div Width="Width.IsFull" Display="Display.Flex" Justify="Justify.Center">
                        <Select TValue="string" @bind-SelectedValue="_selectedRtlFruit">
                            <SelectTrigger Class="w-full max-w-48">
                                <SelectValue Placeholder="اختر فاكهة" />
                            </SelectTrigger>
                            <SelectContent>
                                <SelectGroup>
                                    <SelectItem TValue="string" ItemValue="@("apple")" Text="تفاح" />
                                    <SelectItem TValue="string" ItemValue="@("banana")" Text="موز" />
                                    <SelectItem TValue="string" ItemValue="@("grapes")" Text="عنب" />
                                </SelectGroup>
                            </SelectContent>
                        </Select>
                        </Div>
                    </DirectionProvider>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _selectedFruit;
    private string? _selectedAlignedFruit = "banana";
    private string? _selectedProduce;
    private string? _selectedTimezone;
    private string? _selectedRtlFruit;
    private bool _alignItemWithTrigger = true;

    private const string DemoCode =
@"<Select TValue=""string"" @bind-SelectedValue=""_selectedFruit"">
    <SelectTrigger Width='Width.Token(""[180px]"")'>
        <SelectValue Placeholder=""Select a fruit"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectLabel>Fruits</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
            <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
            <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            <SelectItem TValue=""string"" ItemValue=""@(""grapes"")"" Text=""Grapes"" />
            <SelectItem TValue=""string"" ItemValue=""@(""pineapple"")"" Text=""Pineapple"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string ScrollableCode =
@"<Select TValue=""string"" @bind-SelectedValue=""_selectedTimezone"">
    <SelectTrigger Class=""w-[280px]"">
        <SelectValue Placeholder=""Select a timezone"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectLabel>North America</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""est"")"" Text=""Eastern Standard Time (EST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""cst"")"" Text=""Central Standard Time (CST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""mst"")"" Text=""Mountain Standard Time (MST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""pst"")"" Text=""Pacific Standard Time (PST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""akst"")"" Text=""Alaska Standard Time (AKST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""hst"")"" Text=""Hawaii Standard Time (HST)"" />
        </SelectGroup>
        <SelectGroup>
            <SelectLabel>Europe &amp; Africa</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""gmt"")"" Text=""Greenwich Mean Time (GMT)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""cet"")"" Text=""Central European Time (CET)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""eet"")"" Text=""Eastern European Time (EET)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""west"")"" Text=""Western European Summer Time (WEST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""cat"")"" Text=""Central Africa Time (CAT)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""eat"")"" Text=""East Africa Time (EAT)"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnSubmit=""@(_ => HandleSubmit())"" class=""w-2/3 space-y-6"">
    <Field>
        <FieldLabel>Email</FieldLabel>
        <Select TValue=""string"" @bind-SelectedValue=""_formModel.Email"">
            <SelectTrigger>
                <SelectValue Placeholder=""Select a verified email to display"" />
            </SelectTrigger>
            <SelectContent>
                <SelectItem TValue=""string"" ItemValue=""@(""m@example.com"")"" Text=""m@example.com"" />
                <SelectItem TValue=""string"" ItemValue=""@(""m@google.com"")"" Text=""m@google.com"" />
                <SelectItem TValue=""string"" ItemValue=""@(""m@support.com"")"" Text=""m@support.com"" />
            </SelectContent>
        </Select>
        <FieldDescription>
            You can manage email addresses in your email settings.
        </FieldDescription>
    </Field>
    <Button Type=""ButtonType.Submit"">Submit</Button>
</EditForm>";

    private const string NativeFormCode =
@"<form class=""w-2/3 space-y-6"" @onsubmit=""HandleNativeFormSubmit"">
    <Field>
        <FieldLabel>Framework</FieldLabel>
        <Select TValue=""string"" Name=""framework"" Required=""true"" @bind-SelectedValue=""_nativeFormValue"">
            <SelectTrigger>
                <SelectValue Placeholder=""Select a framework"" />
            </SelectTrigger>
            <SelectContent>
                <SelectItem TValue=""string"" ItemValue=""@(""astro"")"" Text=""Astro"" />
                <SelectItem TValue=""string"" ItemValue=""@(""next"")"" Text=""Next.js"" />
                <SelectItem TValue=""string"" ItemValue=""@(""sveltekit"")"" Text=""SvelteKit"" />
            </SelectContent>
        </Select>
    </Field>
    <Button Type=""ButtonType.Submit"">Submit native form</Button>
</form>";

    private const string AlignItemCode =
@"<Div Space=""Space.Y.Is4"" Width='Width.Token(""[180px]"")'>
    <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Justify=""Justify.Between"" Gap=""Gap.Is4"">
        <Div Space=""Space.Y.Is1"">
            <Label for=""select-align-item"">Align Item</Label>
            <Paragraph>Toggle to align the item with the trigger.</Paragraph>
        </Div>
        <Switch Id=""select-align-item"" @bind-Checked=""_alignItemWithTrigger"" />
    </Div>
    <Select TValue=""string"" @bind-SelectedValue=""_selectedAlignedFruit"">
        <SelectTrigger Class=""w-full"">
            <SelectValue Placeholder=""Select a fruit"" />
        </SelectTrigger>
        <SelectContent ContentPosition=""@(_alignItemWithTrigger ? SelectPosition.ItemAligned : SelectPosition.Popper)"">
            <SelectGroup>
                <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
                <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
                <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
                <SelectItem TValue=""string"" ItemValue=""@(""grapes"")"" Text=""Grapes"" />
                <SelectItem TValue=""string"" ItemValue=""@(""pineapple"")"" Text=""Pineapple"" />
            </SelectGroup>
        </SelectContent>
    </Select>
</Div>";

    private const string GroupsCode =
@"<Select TValue=""string"" @bind-SelectedValue=""_selectedProduce"">
    <SelectTrigger Class=""w-full max-w-48"">
        <SelectValue Placeholder=""Select a fruit"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectLabel>Fruits</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
            <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
            <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
        </SelectGroup>
        <SelectSeparator />
        <SelectGroup>
            <SelectLabel>Vegetables</SelectLabel>
            <SelectItem TValue=""string"" ItemValue=""@(""carrot"")"" Text=""Carrot"" Disabled=""true"" />
            <SelectItem TValue=""string"" ItemValue=""@(""broccoli"")"" Text=""Broccoli"" />
            <SelectItem TValue=""string"" ItemValue=""@(""courgette"")"" Text=""Courgette"" />
            <SelectItem TValue=""string"" ItemValue=""@(""spinach"")"" Text=""Spinach"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string DisabledCode =
@"<Select TValue=""string"" Disabled=""true"">
    <SelectTrigger Class=""w-full max-w-48"">
        <SelectValue Placeholder=""Select a fruit"" />
    </SelectTrigger>
    <SelectContent>
        <SelectGroup>
            <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
            <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
            <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            <SelectItem TValue=""string"" ItemValue=""@(""grapes"")"" Text=""Grapes"" Disabled=""true"" />
            <SelectItem TValue=""string"" ItemValue=""@(""pineapple"")"" Text=""Pineapple"" />
        </SelectGroup>
    </SelectContent>
</Select>";

    private const string InvalidCode =
@"<Field IsInvalid=""true"" Class=""w-full max-w-48"">
    <FieldLabel>Fruit</FieldLabel>
    <Select TValue=""string"">
        <SelectTrigger aria-invalid=""true"">
            <SelectValue Placeholder=""Select a fruit"" />
        </SelectTrigger>
        <SelectContent>
            <SelectGroup>
                <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""Apple"" />
                <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""Banana"" />
                <SelectItem TValue=""string"" ItemValue=""@(""blueberry"")"" Text=""Blueberry"" />
            </SelectGroup>
        </SelectContent>
    </Select>
    <FieldError>Please select a fruit.</FieldError>
</Field>";

    private const string RtlCode =
@"<Div Space=""Space.Y.Is8"" Width=""Width.IsFull"">
    <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Justify=""Justify.Between"" Width=""Width.IsFull"">
        <Select TValue=""string"" SelectedValue=""@(""ar"")"">
            <SelectTrigger Class=""w-44"">
                <SelectValue />
            </SelectTrigger>
            <SelectContent>
                <SelectItem TValue=""string"" ItemValue=""@(""ar"")"" Text=""Arabic (العربية)"" />
                <SelectItem TValue=""string"" ItemValue=""@(""en"")"" Text=""English"" />
            </SelectContent>
        </Select>
        <Icon Name=""LucideIcon.Info"" Class=""size-4"" />
    </Div>
    <DirectionProvider Dir=""rtl"">
        <Div Width=""Width.IsFull"" Display=""Display.Flex"" Justify=""Justify.Center"">
        <Select TValue=""string"" @bind-SelectedValue=""_selectedRtlFruit"">
            <SelectTrigger Class=""w-full max-w-48"">
                <SelectValue Placeholder=""اختر فاكهة"" />
            </SelectTrigger>
            <SelectContent>
                <SelectGroup>
                    <SelectItem TValue=""string"" ItemValue=""@(""apple"")"" Text=""تفاح"" />
                    <SelectItem TValue=""string"" ItemValue=""@(""banana"")"" Text=""موز"" />
                    <SelectItem TValue=""string"" ItemValue=""@(""grapes"")"" Text=""عنب"" />
                </SelectGroup>
            </SelectContent>
        </Select>
        </Div>
    </DirectionProvider>
</Div>";
}
