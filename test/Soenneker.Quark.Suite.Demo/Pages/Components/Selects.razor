            <SelectItem TValue=""string"" ItemValue=""@(""awst"")"" Text=""Australian Western Standard Time (AWST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""acst"")"" Text=""Australian Central Standard Time (ACST)"" />
            <SelectItem TValue=""string"" ItemValue=""@(""aest"")"" Text=""Australian Eastern Standard Time (AEST)"" />
