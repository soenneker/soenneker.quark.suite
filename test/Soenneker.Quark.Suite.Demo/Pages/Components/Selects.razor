    private const string FormCode =
@"<EditForm Model=""_formModel"" OnSubmit=""@(_ => HandleSubmit())"" class=""w-2/3 space-y-6"">
    <Field>
        <FieldLabel>Email</FieldLabel>
        <Select TValue=""string"" @bind-SelectedValue=""_formModel.Email"">
            <SelectTrigger>
                <SelectValue Placeholder=""Select a verified email to display"" />
            </SelectTrigger>
            <SelectContent>
                <SelectItem TValue=""string"" ItemValue=""@(""m@example.com"")"" Text=""m@example.com"" />
                <SelectItem TValue=""string"" ItemValue=""@(""m@google.com"")"" Text=""m@google.com"" />
                <SelectItem TValue=""string"" ItemValue=""@(""m@support.com"")"" Text=""m@support.com"" />
            </SelectContent>
        </Select>
        <FieldDescription>
            You can manage email addresses in your email settings.
        </FieldDescription>
    </Field>
    <Button Type=""@ButtonType.Submit"">Submit</Button>
</EditForm>";

    private const string NativeFormCode =
@"<form class=""w-2/3 space-y-6"" @onsubmit=""HandleNativeFormSubmit"">
    <Field>
        <FieldLabel>Framework</FieldLabel>
        <Select TValue=""string"" Name=""framework"" Required=""true"" @bind-SelectedValue=""_nativeFormValue"">
            <SelectTrigger>
                <SelectValue Placeholder=""Select a framework"" />
            </SelectTrigger>
            <SelectContent>
                <SelectItem TValue=""string"" ItemValue=""@(""astro"")"" Text=""Astro"" />
                <SelectItem TValue=""string"" ItemValue=""@(""next"")"" Text=""Next.js"" />
                <SelectItem TValue=""string"" ItemValue=""@(""sveltekit"")"" Text=""SvelteKit"" />
            </SelectContent>
        </Select>
    </Field>
    <Button Type=""@ButtonType.Submit"">Submit native form</Button>
</form>";

