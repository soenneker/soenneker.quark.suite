@page "/small-demo"

<PageTitle>Small - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Demo" Code="@(@"<Paragraph>Normal text with <Small>small text inline</Small> in paragraph.</Paragraph>
<Small>Standalone small text.</Small>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Paragraph>Normal text with <Small>small text inline</Small> within the paragraph.</Paragraph>
                <Small>Standalone small text.</Small>
            </Div>
        </DemoSection>

        <DemoSection Title="Colors"
                     Code="@SmallColorsCode"
                     CodeLanguage="razor">
                <Div Space="Space.Y.Is1">
                    <Paragraph>Primary: <Small TextColor="TextColor.Primary">Primary small</Small></Paragraph>
                    <Paragraph>Success: <Small TextColor="TextColor.Accent">Success small</Small></Paragraph>
                    <Paragraph>Warning: <Small TextColor="TextColor.MutedForeground">Warning small</Small></Paragraph>
                    <Paragraph>Danger: <Small TextColor="TextColor.Destructive">Danger small</Small></Paragraph>
                </Div>
        </DemoSection>

        <DemoSection Title="Badges / Labels"
                     Code="@SmallBadgesCode"
                     CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                    <Paragraph>Price: $99.99 <Small Rounded="Rounded.Default" BackgroundColor="BackgroundColor.Secondary" Padding='Padding.Is2.OnX.Token("0.5").OnY' TextColor="TextColor.White">On Sale</Small></Paragraph>
                    <Paragraph>Status: <Small Rounded="Rounded.Default" BackgroundColor='BackgroundColor.Token("green-600")' Padding='Padding.Is2.OnX.Token("0.5").OnY' TextColor="TextColor.White">Verified</Small></Paragraph>
                    <Paragraph>Date: March 15, 2024 <Small TextColor="TextColor.MutedForeground">(Last updated)</Small></Paragraph>
                </Div>
        </DemoSection>

        <DemoSection Title="Forms"
                     Code="@SmallFormsCode"
                     CodeLanguage="razor">
        <Div Display="Display.Grid" Gap="Gap.Is4" Class="md:grid-cols-2">
            <Div Space="Space.Y.Is1">
                <Label Form="true" For="email">Email</Label>
                <Input type="email" id="email" Width="Width.IsFull" placeholder="Enter email"/>
                <Small TextColor="TextColor.MutedForeground">We'll never share your email.</Small>
            </Div>
            <Div Space="Space.Y.Is1">
                <Label Form="true" For="pwd">Password</Label>
                <Input type="password" id="pwd" Width="Width.IsFull" placeholder="Enter password"/>
                <Small TextColor="TextColor.MutedForeground">At least 8 characters.</Small>
            </Div>
        </Div>
        </DemoSection>

        <DemoSection Title="Interactive"
                     Code="@SmallInteractiveCode"
                     CodeLanguage="razor">
            <Paragraph>
                <Small TextColor="TextColor.Primary" Class="cursor-pointer hover:underline" @onclick="HandleClick" Title="Click me!">Click for more info</Small>
            </Paragraph>
            <Small TextColor="TextColor.MutedForeground">Click count: @_clickCount</Small>
        </DemoSection>
    </Div>
</Div>

@code {
    private const string SmallColorsCode =
@"<Paragraph><Small TextColor=""TextColor.Primary"">Primary small</Small></Paragraph>";

    private const string SmallBadgesCode =
@"<Paragraph>Price: $99.99 <Small Rounded=""Rounded.Default"" BackgroundColor=""BackgroundColor.Secondary"" Padding='Padding.Is2.OnX.Token(""0.5"").OnY' TextColor=""TextColor.White"">On Sale</Small></Paragraph>";

    private const string SmallFormsCode =
@"<Label For=""email"">Email</Label>
<Input type=""email"" id=""email"" ... />
<Small TextColor=""TextColor.MutedForeground"">We'll never share your email.</Small>";

    private const string SmallInteractiveCode =
@"<Small TextColor=""TextColor.Primary"" Class=""cursor-pointer hover:underline"" @onclick=""HandleClick"">Click for more info</Small>";

    private int _clickCount;

    private void HandleClick(MouseEventArgs args) { _clickCount++; StateHasChanged(); }
}
