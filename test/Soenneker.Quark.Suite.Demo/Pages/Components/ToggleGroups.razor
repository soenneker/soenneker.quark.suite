@page "/toggle-groups"
@using Soenneker.Bradix

<PageTitle>Toggle Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="A set of two-state buttons that can be toggled on or off."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Multiple" Variant="ToggleVariant.Outline">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Icon Name="LucideIcon.Bold" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Icon Name="LucideIcon.Italic" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="strikethrough" aria-label="Toggle strikethrough">
                        <Icon Name="LucideIcon.Underline" Class="h-4 w-4" />
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                         Description="Use the outline variant for grouped filters."
                         Code="@SingleCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Single"
                             Variant="ToggleVariant.Outline"
                             Value="@_singleFormat"
                             ValueChanged="HandleSingleFormatChanged">
                    <ToggleGroupItem Value="all">All</ToggleGroupItem>
                    <ToggleGroupItem Value="missed">Missed</ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Use the size parameter to scale every item in the group."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Start" Gap="Gap.Is4">
                    <ToggleGroup Type="SelectionMode.Single"
                                 Size="ToggleSize.Sm"
                                 Value="left">
                        <ToggleGroupItem Value="top">Top</ToggleGroupItem>
                        <ToggleGroupItem Value="bottom">Bottom</ToggleGroupItem>
                        <ToggleGroupItem Value="left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="right">Right</ToggleGroupItem>
                    </ToggleGroup>

                    <ToggleGroup Type="SelectionMode.Single"
                                 Size="ToggleSize.Lg"
                                 Value="bottom">
                        <ToggleGroupItem Value="top">Top</ToggleGroupItem>
                        <ToggleGroupItem Value="bottom">Bottom</ToggleGroupItem>
                        <ToggleGroupItem Value="left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="right">Right</ToggleGroupItem>
                    </ToggleGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Spacing"
                         Description="Use spacing to separate grouped actions without changing their shared semantics."
                         Code="@SpacingCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Single"
                             Spacing="2"
                             Value="bottom">
                    <ToggleGroupItem Value="top">Top</ToggleGroupItem>
                    <ToggleGroupItem Value="bottom">Bottom</ToggleGroupItem>
                    <ToggleGroupItem Value="left">Left</ToggleGroupItem>
                    <ToggleGroupItem Value="right">Right</ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use a vertical orientation when grouped actions need to fit into narrow side rails or inspector panels."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Single"
                             Orientation="Orientation.Vertical"
                             Value="@_verticalAlignment"
                             ValueChanged="HandleVerticalAlignmentChanged">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Icon Name="LucideIcon.Bold" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Icon Name="LucideIcon.Italic" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="underline" aria-label="Toggle underline">
                        <Icon Name="LucideIcon.Underline" Class="h-4 w-4" />
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disable the entire group or individual items when a formatting choice is unavailable."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Multiple" Disabled="true">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Icon Name="LucideIcon.Bold" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Icon Name="LucideIcon.Italic" Class="h-4 w-4" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="underline" aria-label="Toggle underline">
                        <Icon Name="LucideIcon.Underline" Class="h-4 w-4" />
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom"
                         Description="A custom toggle group example."
                         Code="@CustomCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel>Font Weight</FieldLabel>
                    <ToggleGroup Type="SelectionMode.Single"
                                 Variant="ToggleVariant.Outline"
                                 Value="@_fontWeight"
                                 ValueChanged="HandleFontWeightChanged">
                        <ToggleGroupItem Value="light">Aa Light</ToggleGroupItem>
                        <ToggleGroupItem Value="normal">Aa Normal</ToggleGroupItem>
                        <ToggleGroupItem Value="medium">Aa Medium</ToggleGroupItem>
                        <ToggleGroupItem Value="bold">Aa Bold</ToggleGroupItem>
                    </ToggleGroup>
                    <FieldDescription>Use `font-normal` to set the font weight.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Toggle groups should preserve selection flow in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <ToggleGroup Type="SelectionMode.Single"
                                 Variant="ToggleVariant.Outline"
                                 Value="@_rtlAlignment"
                                 ValueChanged="HandleRtlAlignmentChanged">
                        <ToggleGroupItem Value="right" aria-label="محاذاة لليمين">يمين</ToggleGroupItem>
                        <ToggleGroupItem Value="center" aria-label="محاذاة للوسط">وسط</ToggleGroupItem>
                        <ToggleGroupItem Value="left" aria-label="محاذاة لليسار">يسار</ToggleGroupItem>
                    </ToggleGroup>
                </DirectionProvider>
            </DemoSection>
        </Section>
</Div>
</Div>

@code {
    private string? _singleFormat = "all";
    private string? _verticalAlignment = "italic";
    private string? _fontWeight = "normal";
    private string? _rtlAlignment = "center";

    private const string DemoCode =
@"<ToggleGroup Type=""SelectionMode.Multiple"" Variant=""ToggleVariant.Outline"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Icon Name=""LucideIcon.Bold"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Icon Name=""LucideIcon.Italic"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""strikethrough"" aria-label=""Toggle strikethrough"">
        <Icon Name=""LucideIcon.Underline"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
</ToggleGroup>";

    private const string SingleCode =
@"<ToggleGroup Type=""SelectionMode.Single""
             Variant=""ToggleVariant.Outline""
             Value=""@_singleFormat""
             ValueChanged=""HandleSingleFormatChanged"">
    <ToggleGroupItem Value=""all"">All</ToggleGroupItem>
    <ToggleGroupItem Value=""missed"">Missed</ToggleGroupItem>
</ToggleGroup>";

    private const string SizeCode =
@"<ToggleGroup Type=""SelectionMode.Single"" Size=""ToggleSize.Sm"" Value=""left"">
    <ToggleGroupItem Value=""top"">Top</ToggleGroupItem>
    <ToggleGroupItem Value=""bottom"">Bottom</ToggleGroupItem>
    <ToggleGroupItem Value=""left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""right"">Right</ToggleGroupItem>
</ToggleGroup>

<ToggleGroup Type=""SelectionMode.Single"" Size=""ToggleSize.Lg"" Value=""bottom"">
    <ToggleGroupItem Value=""top"">Top</ToggleGroupItem>
    <ToggleGroupItem Value=""bottom"">Bottom</ToggleGroupItem>
    <ToggleGroupItem Value=""left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""right"">Right</ToggleGroupItem>
</ToggleGroup>";

    private const string SpacingCode =
@"<ToggleGroup Type=""SelectionMode.Single"" Spacing=""2"" Value=""bottom"">
    <ToggleGroupItem Value=""top"">Top</ToggleGroupItem>
    <ToggleGroupItem Value=""bottom"">Bottom</ToggleGroupItem>
    <ToggleGroupItem Value=""left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""right"">Right</ToggleGroupItem>
</ToggleGroup>";

    private const string VerticalCode =
@"<ToggleGroup Type=""SelectionMode.Single""
             Orientation=""Orientation.Vertical""
             Value=""@_verticalAlignment""
             ValueChanged=""HandleVerticalAlignmentChanged"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Icon Name=""LucideIcon.Bold"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Icon Name=""LucideIcon.Italic"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""underline"" aria-label=""Toggle underline"">
        <Icon Name=""LucideIcon.Underline"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
</ToggleGroup>";

    private const string DisabledCode =
@"<ToggleGroup Type=""SelectionMode.Multiple"" Disabled=""true"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Icon Name=""LucideIcon.Bold"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Icon Name=""LucideIcon.Italic"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""underline"" aria-label=""Toggle underline"">
        <Icon Name=""LucideIcon.Underline"" Class=""h-4 w-4"" />
    </ToggleGroupItem>
</ToggleGroup>";

    private const string CustomCode =
@"<Field>
    <FieldLabel>Font Weight</FieldLabel>
    <ToggleGroup Type=""SelectionMode.Single""
                 Variant=""ToggleVariant.Outline""
                 Value=""@_fontWeight""
                 ValueChanged=""HandleFontWeightChanged"">
        <ToggleGroupItem Value=""light"">Aa Light</ToggleGroupItem>
        <ToggleGroupItem Value=""normal"">Aa Normal</ToggleGroupItem>
        <ToggleGroupItem Value=""medium"">Aa Medium</ToggleGroupItem>
        <ToggleGroupItem Value=""bold"">Aa Bold</ToggleGroupItem>
    </ToggleGroup>
    <FieldDescription>Use `font-normal` to set the font weight.</FieldDescription>
</Field>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <ToggleGroup Type=""SelectionMode.Single""
                 Variant=""ToggleVariant.Outline""
                 Value=""@_rtlAlignment""
                 ValueChanged=""HandleRtlAlignmentChanged"">
        <ToggleGroupItem Value=""right"" aria-label=""محاذاة لليمين"">يمين</ToggleGroupItem>
        <ToggleGroupItem Value=""center"" aria-label=""محاذاة للوسط"">وسط</ToggleGroupItem>
        <ToggleGroupItem Value=""left"" aria-label=""محاذاة لليسار"">يسار</ToggleGroupItem>
    </ToggleGroup>
</DirectionProvider>";

    private Task HandleSingleFormatChanged(string? value)
    {
        _singleFormat = value;
        return Task.CompletedTask;
    }

    private Task HandleVerticalAlignmentChanged(string? value)
    {
        _verticalAlignment = value;
        return Task.CompletedTask;
    }

    private Task HandleFontWeightChanged(string? value)
    {
        _fontWeight = value;
        return Task.CompletedTask;
    }

    private Task HandleRtlAlignmentChanged(string? value)
    {
        _rtlAlignment = value;
        return Task.CompletedTask;
    }
}
