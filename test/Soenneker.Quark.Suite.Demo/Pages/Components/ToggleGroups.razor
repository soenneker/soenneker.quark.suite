@page "/toggle-groups"
@using Soenneker.Bradix

<PageTitle>Toggle Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Outline toggle group with icon-only formatting controls."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Multiple"
                             Variant="ToggleVariant.Outline"
                             Values="@_demoFormats"
                             ValueChangedMultiple="HandleDemoFormatsChanged">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Bold" /></Span>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Italic" /></Span>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="strikethrough" aria-label="Toggle strikethrough">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Underline" /></Span>
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                         Description="Single-selection toggle groups keep one formatting control active at a time."
                         Code="@SingleCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Single"
                             Value="@_singleFormat"
                             ValueChanged="HandleSingleFormatChanged">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Bold" /></Span>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Italic" /></Span>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="strikethrough" aria-label="Toggle strikethrough">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Underline" /></Span>
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Use the outline variant for grouped formatting controls."
                         Code="@OutlineCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Single"
                             Variant="ToggleVariant.Outline"
                             Value="@_outlineAlignment"
                             ValueChanged="HandleOutlineAlignmentChanged">
                    <ToggleGroupItem Value="left" aria-label="Align left">Left</ToggleGroupItem>
                    <ToggleGroupItem Value="center" aria-label="Align center">Center</ToggleGroupItem>
                    <ToggleGroupItem Value="right" aria-label="Align right">Right</ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Spacing"
                         Description="Use the size parameter to scale every item in the group."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Start" Gap="Gap.Is4">
                    <ToggleGroup Type="SelectionMode.Single"
                                 Size="ToggleSize.Sm"
                                 Value="left">
                        <ToggleGroupItem Value="left" aria-label="Align left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="center" aria-label="Align center">Center</ToggleGroupItem>
                        <ToggleGroupItem Value="right" aria-label="Align right">Right</ToggleGroupItem>
                    </ToggleGroup>

                    <ToggleGroup Type="SelectionMode.Single"
                                 Value="center">
                        <ToggleGroupItem Value="left" aria-label="Align left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="center" aria-label="Align center">Center</ToggleGroupItem>
                        <ToggleGroupItem Value="right" aria-label="Align right">Right</ToggleGroupItem>
                    </ToggleGroup>

                    <ToggleGroup Type="SelectionMode.Single"
                                 Size="ToggleSize.Lg"
                                 Value="right">
                        <ToggleGroupItem Value="left" aria-label="Align left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="center" aria-label="Align center">Center</ToggleGroupItem>
                        <ToggleGroupItem Value="right" aria-label="Align right">Right</ToggleGroupItem>
                    </ToggleGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use spacing to separate grouped actions without changing their shared semantics."
                         Code="@SpacingCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Multiple"
                             Variant="ToggleVariant.Outline"
                             Size="ToggleSize.Sm"
                             Spacing="2"
                             Values="@_multipleFormats"
                             ValueChangedMultiple="HandleMultipleFormatsChanged">
                    <ToggleGroupItem Value="star"
                                     aria-label="Toggle star"
                                     Class="data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-yellow-500 data-[state=on]:*:[svg]:stroke-yellow-500">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Star" /></Span>
                        Star
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="heart"
                                     aria-label="Toggle heart"
                                     Class="data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-red-500 data-[state=on]:*:[svg]:stroke-red-500">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Heart" /></Span>
                        Heart
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="bookmark"
                                     aria-label="Toggle bookmark"
                                     Class="data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-blue-500 data-[state=on]:*:[svg]:stroke-blue-500">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Bookmark" /></Span>
                        Bookmark
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Use a vertical orientation when grouped actions need to fit into narrow side rails or inspector panels."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <ToggleGroup Type="SelectionMode.Single"
                             Orientation="Orientation.Vertical"
                             Variant="ToggleVariant.Outline"
                             Value="@_verticalAlignment"
                             ValueChanged="HandleVerticalAlignmentChanged">
                    <ToggleGroupItem Value="top" aria-label="Align top">
                        Top
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="middle" aria-label="Align middle">
                        Middle
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="bottom" aria-label="Align bottom">
                        Bottom
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom"
                         Description="Disable the entire group or individual items when a formatting choice is unavailable."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Start" Gap="Gap.Is4">
                    <ToggleGroup Type="SelectionMode.Single"
                                 Disabled="true"
                                 Value="left">
                        <ToggleGroupItem Value="left" aria-label="Align left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="center" aria-label="Align center">Center</ToggleGroupItem>
                        <ToggleGroupItem Value="right" aria-label="Align right">Right</ToggleGroupItem>
                    </ToggleGroup>

                    <ToggleGroup Type="SelectionMode.Single"
                                 Variant="ToggleVariant.Outline"
                                 Value="center">
                        <ToggleGroupItem Value="left" aria-label="Align left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="center" aria-label="Align center" Disabled="true">Center</ToggleGroupItem>
                        <ToggleGroupItem Value="right" aria-label="Align right">Right</ToggleGroupItem>
                    </ToggleGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Toggle groups should preserve selection flow in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <ToggleGroup Type="SelectionMode.Single"
                                 Variant="ToggleVariant.Outline"
                                 Value="@_rtlAlignment"
                                 ValueChanged="HandleRtlAlignmentChanged">
                        <ToggleGroupItem Value="right" aria-label="محاذاة لليمين">يمين</ToggleGroupItem>
                        <ToggleGroupItem Value="center" aria-label="محاذاة للوسط">وسط</ToggleGroupItem>
                        <ToggleGroupItem Value="left" aria-label="محاذاة لليسار">يسار</ToggleGroupItem>
                    </ToggleGroup>
                </DirectionProvider>
            </DemoSection>
        </Section>
</Div>
</Div>

@code {
    private string[] _demoFormats = ["bold"];
    private string? _singleFormat = "italic";
    private string? _outlineAlignment = "center";
    private string[] _multipleFormats = ["bookmark"];
    private string? _verticalAlignment = "middle";
    private string? _fontWeight = "medium";
    private string? _rtlAlignment = "center";

    private const string DemoCode =
@"<ToggleGroup Type=""SelectionMode.Multiple""
             Variant=""ToggleVariant.Outline""
             Values=""@_demoFormats""
             ValueChangedMultiple=""HandleDemoFormatsChanged"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bold"" /></Span>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Italic"" /></Span>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""strikethrough"" aria-label=""Toggle strikethrough"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Underline"" /></Span>
    </ToggleGroupItem>
</ToggleGroup>";

    private const string SingleCode =
@"<ToggleGroup Type=""SelectionMode.Single""
             Value=""@_singleFormat""
             ValueChanged=""HandleSingleFormatChanged"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bold"" /></Span>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Italic"" /></Span>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""strikethrough"" aria-label=""Toggle strikethrough"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Underline"" /></Span>
    </ToggleGroupItem>
</ToggleGroup>";

    private const string OutlineCode =
@"<ToggleGroup Type=""SelectionMode.Single""
             Variant=""ToggleVariant.Outline""
             Value=""@_outlineAlignment""
             ValueChanged=""HandleOutlineAlignmentChanged"">
    <ToggleGroupItem Value=""left"" aria-label=""Align left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""center"" aria-label=""Align center"">Center</ToggleGroupItem>
    <ToggleGroupItem Value=""right"" aria-label=""Align right"">Right</ToggleGroupItem>
</ToggleGroup>";

    private const string SizeCode =
@"<ToggleGroup Type=""SelectionMode.Single"" Size=""ToggleSize.Sm"" Value=""left"">
    <ToggleGroupItem Value=""left"" aria-label=""Align left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""center"" aria-label=""Align center"">Center</ToggleGroupItem>
    <ToggleGroupItem Value=""right"" aria-label=""Align right"">Right</ToggleGroupItem>
</ToggleGroup>

<ToggleGroup Type=""SelectionMode.Single"" Value=""center"">
    <ToggleGroupItem Value=""left"" aria-label=""Align left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""center"" aria-label=""Align center"">Center</ToggleGroupItem>
    <ToggleGroupItem Value=""right"" aria-label=""Align right"">Right</ToggleGroupItem>
</ToggleGroup>

<ToggleGroup Type=""SelectionMode.Single"" Size=""ToggleSize.Lg"" Value=""right"">
    <ToggleGroupItem Value=""left"" aria-label=""Align left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""center"" aria-label=""Align center"">Center</ToggleGroupItem>
    <ToggleGroupItem Value=""right"" aria-label=""Align right"">Right</ToggleGroupItem>
</ToggleGroup>";

    private const string SpacingCode =
@"<ToggleGroup Type=""SelectionMode.Multiple""
             Variant=""ToggleVariant.Outline""
             Size=""ToggleSize.Sm""
             Spacing=""2""
             Values=""@_multipleFormats""
             ValueChangedMultiple=""HandleMultipleFormatsChanged"">
    <ToggleGroupItem Value=""star""
                     aria-label=""Toggle star""
                     Class=""data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-yellow-500 data-[state=on]:*:[svg]:stroke-yellow-500"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Star"" /></Span>
        Star
    </ToggleGroupItem>
    <ToggleGroupItem Value=""heart""
                     aria-label=""Toggle heart""
                     Class=""data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-red-500 data-[state=on]:*:[svg]:stroke-red-500"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Heart"" /></Span>
        Heart
    </ToggleGroupItem>
    <ToggleGroupItem Value=""bookmark""
                     aria-label=""Toggle bookmark""
                     Class=""data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-blue-500 data-[state=on]:*:[svg]:stroke-blue-500"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bookmark"" /></Span>
        Bookmark
    </ToggleGroupItem>
</ToggleGroup>";

    private const string VerticalCode =
@"<ToggleGroup Type=""SelectionMode.Single""
             Orientation=""Orientation.Vertical""
             Variant=""ToggleVariant.Outline""
             Value=""@_verticalAlignment""
             ValueChanged=""HandleVerticalAlignmentChanged"">
    <ToggleGroupItem Value=""top"" aria-label=""Align top"">
        Top
    </ToggleGroupItem>
    <ToggleGroupItem Value=""middle"" aria-label=""Align middle"">
        Middle
    </ToggleGroupItem>
    <ToggleGroupItem Value=""bottom"" aria-label=""Align bottom"">
        Bottom
    </ToggleGroupItem>
</ToggleGroup>";

    private const string DisabledCode =
@"<ToggleGroup Type=""SelectionMode.Single"" Disabled=""true"" Value=""left"">
    <ToggleGroupItem Value=""left"" aria-label=""Align left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""center"" aria-label=""Align center"">Center</ToggleGroupItem>
    <ToggleGroupItem Value=""right"" aria-label=""Align right"">Right</ToggleGroupItem>
</ToggleGroup>

<ToggleGroup Type=""SelectionMode.Single"" Variant=""ToggleVariant.Outline"" Value=""center"">
    <ToggleGroupItem Value=""left"" aria-label=""Align left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""center"" aria-label=""Align center"" Disabled=""true"">Center</ToggleGroupItem>
    <ToggleGroupItem Value=""right"" aria-label=""Align right"">Right</ToggleGroupItem>
</ToggleGroup>";

    private const string CustomCode =
@"<Field>
    <FieldLabel>Font weight</FieldLabel>
    <FieldDescription>Choose how prominent headings should appear inside this panel.</FieldDescription>
    <ToggleGroup Type=""SelectionMode.Single""
                 Variant=""ToggleVariant.Outline""
                 Value=""@_fontWeight""
                 ValueChanged=""HandleFontWeightChanged""
                 Width=""Width.IsFull"">
        <ToggleGroupItem Value=""regular"">Regular</ToggleGroupItem>
        <ToggleGroupItem Value=""medium"">Medium</ToggleGroupItem>
        <ToggleGroupItem Value=""semibold"">Semibold</ToggleGroupItem>
    </ToggleGroup>
</Field>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <ToggleGroup Type=""SelectionMode.Single""
                 Variant=""ToggleVariant.Outline""
                 Value=""@_rtlAlignment""
                 ValueChanged=""HandleRtlAlignmentChanged"">
        <ToggleGroupItem Value=""right"" aria-label=""محاذاة لليمين"">يمين</ToggleGroupItem>
        <ToggleGroupItem Value=""center"" aria-label=""محاذاة للوسط"">وسط</ToggleGroupItem>
        <ToggleGroupItem Value=""left"" aria-label=""محاذاة لليسار"">يسار</ToggleGroupItem>
    </ToggleGroup>
</DirectionProvider>";

    private Task HandleDemoFormatsChanged(string[] values)
    {
        _demoFormats = values;
        return Task.CompletedTask;
    }

    private Task HandleSingleFormatChanged(string? value)
    {
        _singleFormat = value;
        return Task.CompletedTask;
    }

    private Task HandleOutlineAlignmentChanged(string? value)
    {
        _outlineAlignment = value;
        return Task.CompletedTask;
    }

    private Task HandleMultipleFormatsChanged(string[] values)
    {
        _multipleFormats = values;
        return Task.CompletedTask;
    }

    private Task HandleVerticalAlignmentChanged(string? value)
    {
        _verticalAlignment = value;
        return Task.CompletedTask;
    }

    private Task HandleFontWeightChanged(string? value)
    {
        _fontWeight = value;
        return Task.CompletedTask;
    }

    private Task HandleRtlAlignmentChanged(string? value)
    {
        _rtlAlignment = value;
        return Task.CompletedTask;
    }
}
