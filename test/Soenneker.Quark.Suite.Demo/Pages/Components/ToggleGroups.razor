@page "/components/toggle-groups"

<PageTitle>Toggle Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="A set of two-state buttons that can be toggled on or off." Code="@DemoCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <ToggleGroup Type="SelectionMode.Multiple" Variant="ToggleVariant.Outline">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Icon Name="LucideIcon.Bold" Size="Size.Is4"/>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Icon Name="LucideIcon.Italic" Size="Size.Is4"/>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="strikethrough" aria-label="Toggle strikethrough">
                        <Icon Name="LucideIcon.Underline" Size="Size.Is4"/>
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline" Description="Use the outline variant for grouped filters." Code="@SingleCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <ToggleGroup Type="SelectionMode.Single" Variant="ToggleVariant.Outline" Value="@_singleFormat" ValueChanged="HandleSingleFormatChanged">
                    <ToggleGroupItem Value="all" aria-label="Toggle all">All</ToggleGroupItem>
                    <ToggleGroupItem Value="missed" aria-label="Toggle missed">Missed</ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Use the size parameter to scale every item in the group." Code="@SizeCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Start" Gap="Gap.Is4">
                    <ToggleGroup Type="SelectionMode.Single" Variant="ToggleVariant.Outline" ToggleSize="ToggleSize.Sm" Value="top">
                        <ToggleGroupItem Value="top" aria-label="Toggle top">Top</ToggleGroupItem>
                        <ToggleGroupItem Value="bottom" aria-label="Toggle bottom">Bottom</ToggleGroupItem>
                        <ToggleGroupItem Value="left" aria-label="Toggle left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="right" aria-label="Toggle right">Right</ToggleGroupItem>
                    </ToggleGroup>

                    <ToggleGroup Type="SelectionMode.Single" Variant="ToggleVariant.Outline" Value="top">
                        <ToggleGroupItem Value="top" aria-label="Toggle top">Top</ToggleGroupItem>
                        <ToggleGroupItem Value="bottom" aria-label="Toggle bottom">Bottom</ToggleGroupItem>
                        <ToggleGroupItem Value="left" aria-label="Toggle left">Left</ToggleGroupItem>
                        <ToggleGroupItem Value="right" aria-label="Toggle right">Right</ToggleGroupItem>
                    </ToggleGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Spacing" Description="Use spacing to separate grouped actions without changing their shared semantics." Code="@SpacingCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <ToggleGroup Type="SelectionMode.Single" Variant="ToggleVariant.Outline" ToggleSize="ToggleSize.Sm" Spacing="2" Value="top">
                    <ToggleGroupItem Value="top" aria-label="Toggle top">Top</ToggleGroupItem>
                    <ToggleGroupItem Value="bottom" aria-label="Toggle bottom">Bottom</ToggleGroupItem>
                    <ToggleGroupItem Value="left" aria-label="Toggle left">Left</ToggleGroupItem>
                    <ToggleGroupItem Value="right" aria-label="Toggle right">Right</ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical" Description="Use a vertical orientation when grouped actions need to fit into narrow side rails or inspector panels." Code="@VerticalCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <ToggleGroup Type="SelectionMode.Multiple" Orientation="Orientation.Vertical" Spacing="1" Values="@_verticalValues" ValueChangedMultiple="HandleVerticalAlignmentChanged">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Icon Name="LucideIcon.Bold" Size="Size.Is4"/>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Icon Name="LucideIcon.Italic" Size="Size.Is4"/>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="underline" aria-label="Toggle underline">
                        <Icon Name="LucideIcon.Underline" Size="Size.Is4"/>
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled" Description="Disable the entire group or individual items when a formatting choice is unavailable." Code="@DisabledCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <ToggleGroup Type="SelectionMode.Multiple" Disabled="true">
                    <ToggleGroupItem Value="bold" aria-label="Toggle bold">
                        <Icon Name="LucideIcon.Bold" Size="Size.Is4"/>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="italic" aria-label="Toggle italic">
                        <Icon Name="LucideIcon.Italic" Size="Size.Is4"/>
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="strikethrough" aria-label="Toggle strikethrough">
                        <Icon Name="LucideIcon.Underline" Size="Size.Is4"/>
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom" Description="A custom toggle group example." Code="@CustomCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel>Font Weight</FieldLabel>
                    <ToggleGroup Type="SelectionMode.Single" Variant="ToggleVariant.Outline" ToggleSize="ToggleSize.Lg" Spacing="2" Value="@_fontWeight" ValueChanged="HandleFontWeightChanged">
                        <ToggleGroupItem Value="light" aria-label="Light" Display="Display.Flex" Size="Size.Is16" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Rounded="Rounded.Xl">
                            <Span>Aa</Span>
                            <Span>Light</Span>
                        </ToggleGroupItem>
                        <ToggleGroupItem Value="normal" aria-label="Normal" Display="Display.Flex" Size="Size.Is16" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Rounded="Rounded.Xl">
                            <Span>Aa</Span>
                            <Span>Normal</Span>
                        </ToggleGroupItem>
                        <ToggleGroupItem Value="medium" aria-label="Medium" Display="Display.Flex" Size="Size.Is16" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Rounded="Rounded.Xl">
                            <Span>Aa</Span>
                            <Span>Medium</Span>
                        </ToggleGroupItem>
                        <ToggleGroupItem Value="bold" aria-label="Bold" Display="Display.Flex" Size="Size.Is16" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Rounded="Rounded.Xl">
                            <Span>Aa</Span>
                            <Span>Bold</Span>
                        </ToggleGroupItem>
                    </ToggleGroup>
                    <FieldDescription>Use font-normal to set the font weight.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="Toggle groups should preserve selection flow in right-to-left layouts." Code="@RtlCode" CodeLanguage="razor" PreviewClass="@ToggleGroupPreviewClass">
                <DirectionProvider Dir="rtl">
                    <ToggleGroup Type="SelectionMode.Single" Variant="ToggleVariant.Outline" Value="@_rtlAlignment" ValueChanged="HandleRtlAlignmentChanged">
                        <ToggleGroupItem Value="list" aria-label="قائمة">قائمة</ToggleGroupItem>
                        <ToggleGroupItem Value="grid" aria-label="شبكة">شبكة</ToggleGroupItem>
                        <ToggleGroupItem Value="cards" aria-label="بطاقات">بطاقات</ToggleGroupItem>
                    </ToggleGroup>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _singleFormat = "all";
    private string[] _verticalValues = ["bold", "italic"];
    private string? _fontWeight = "normal";
    private string? _rtlAlignment = "list";

    private const string ToggleGroupPreviewClass = "preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0";

    private const string DemoCode = @"<ToggleGroup Type=""SelectionMode.Multiple"" Variant=""ToggleVariant.Outline"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Icon Name=""LucideIcon.Bold"" Size=""Size.Is4""/>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Icon Name=""LucideIcon.Italic"" Size=""Size.Is4""/>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""strikethrough"" aria-label=""Toggle strikethrough"">
        <Icon Name=""LucideIcon.Underline"" Size=""Size.Is4""/>
    </ToggleGroupItem>
</ToggleGroup>";

    private const string SingleCode = @"<ToggleGroup Type=""SelectionMode.Single"" Variant=""ToggleVariant.Outline"" Value=""@_singleFormat"" ValueChanged=""HandleSingleFormatChanged"">
    <ToggleGroupItem Value=""all"" aria-label=""Toggle all"">All</ToggleGroupItem>
    <ToggleGroupItem Value=""missed"" aria-label=""Toggle missed"">Missed</ToggleGroupItem>
</ToggleGroup>";

    private const string SizeCode = @"<Div Display=""Display.Flex"" FlexDirection=""FlexDirection.Col"" ItemsAlign=""Items.Start"" Gap=""Gap.Is4"">
    <ToggleGroup Type=""SelectionMode.Single"" Variant=""ToggleVariant.Outline"" ToggleSize=""ToggleSize.Sm"" Value=""top"">
        <ToggleGroupItem Value=""top"" aria-label=""Toggle top"">Top</ToggleGroupItem>
        <ToggleGroupItem Value=""bottom"" aria-label=""Toggle bottom"">Bottom</ToggleGroupItem>
        <ToggleGroupItem Value=""left"" aria-label=""Toggle left"">Left</ToggleGroupItem>
        <ToggleGroupItem Value=""right"" aria-label=""Toggle right"">Right</ToggleGroupItem>
    </ToggleGroup>

    <ToggleGroup Type=""SelectionMode.Single"" Variant=""ToggleVariant.Outline"" Value=""top"">
        <ToggleGroupItem Value=""top"" aria-label=""Toggle top"">Top</ToggleGroupItem>
        <ToggleGroupItem Value=""bottom"" aria-label=""Toggle bottom"">Bottom</ToggleGroupItem>
        <ToggleGroupItem Value=""left"" aria-label=""Toggle left"">Left</ToggleGroupItem>
        <ToggleGroupItem Value=""right"" aria-label=""Toggle right"">Right</ToggleGroupItem>
    </ToggleGroup>
</Div>";

    private const string SpacingCode = @"<ToggleGroup Type=""SelectionMode.Single"" Variant=""ToggleVariant.Outline"" ToggleSize=""ToggleSize.Sm"" Spacing=""2"" Value=""top"">
    <ToggleGroupItem Value=""top"" aria-label=""Toggle top"">Top</ToggleGroupItem>
    <ToggleGroupItem Value=""bottom"" aria-label=""Toggle bottom"">Bottom</ToggleGroupItem>
    <ToggleGroupItem Value=""left"" aria-label=""Toggle left"">Left</ToggleGroupItem>
    <ToggleGroupItem Value=""right"" aria-label=""Toggle right"">Right</ToggleGroupItem>
</ToggleGroup>";

    private const string VerticalCode = @"<ToggleGroup Type=""SelectionMode.Multiple"" Orientation=""Orientation.Vertical"" Spacing=""1"" Values=""@_verticalValues"" ValueChangedMultiple=""HandleVerticalAlignmentChanged"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Icon Name=""LucideIcon.Bold"" Size=""Size.Is4""/>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Icon Name=""LucideIcon.Italic"" Size=""Size.Is4""/>
    </ToggleGroupItem>
    <ToggleGroupItem Value=""underline"" aria-label=""Toggle underline"">
        <Icon Name=""LucideIcon.Underline"" Size=""Size.Is4""/>
    </ToggleGroupItem>
</ToggleGroup>";

    private const string DisabledCode = @"<ToggleGroup Type=""SelectionMode.Multiple"" Disabled=""true"">
    <ToggleGroupItem Value=""bold"" aria-label=""Toggle bold"">
        <Icon Name=""LucideIcon.Bold"" Size=""Size.Is4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" aria-label=""Toggle italic"">
        <Icon Name=""LucideIcon.Italic"" Size=""Size.Is4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""strikethrough"" aria-label=""Toggle strikethrough"">
        <Icon Name=""LucideIcon.Underline"" Size=""Size.Is4"" />
    </ToggleGroupItem>
</ToggleGroup>";

    private const string CustomCode = @"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel>Font Weight</FieldLabel>
    <ToggleGroup Type=""SelectionMode.Single"" Variant=""ToggleVariant.Outline"" ToggleSize=""ToggleSize.Lg"" Spacing=""2"" Value=""@_fontWeight"" ValueChanged=""HandleFontWeightChanged"">
        <ToggleGroupItem Value=""light"" aria-label=""Light"" Display=""Display.Flex"" Size=""Size.Is16"" FlexDirection=""FlexDirection.Col"" ItemsAlign=""Items.Center"" Justify=""Justify.Center"" Rounded=""Rounded.Xl"">
            <Span>Aa</Span>
            <Span>Light</Span>
        </ToggleGroupItem>
        <ToggleGroupItem Value=""normal"" aria-label=""Normal"" Display=""Display.Flex"" Size=""Size.Is16"" FlexDirection=""FlexDirection.Col"" ItemsAlign=""Items.Center"" Justify=""Justify.Center"" Rounded=""Rounded.Xl"">
            <Span>Aa</Span>
            <Span>Normal</Span>
        </ToggleGroupItem>
        <ToggleGroupItem Value=""medium"" aria-label=""Medium"" Display=""Display.Flex"" Size=""Size.Is16"" FlexDirection=""FlexDirection.Col"" ItemsAlign=""Items.Center"" Justify=""Justify.Center"" Rounded=""Rounded.Xl"">
            <Span>Aa</Span>
            <Span>Medium</Span>
        </ToggleGroupItem>
        <ToggleGroupItem Value=""bold"" aria-label=""Bold"" Display=""Display.Flex"" Size=""Size.Is16"" FlexDirection=""FlexDirection.Col"" ItemsAlign=""Items.Center"" Justify=""Justify.Center"" Rounded=""Rounded.Xl"">
            <Span>Aa</Span>
            <Span>Bold</Span>
        </ToggleGroupItem>
    </ToggleGroup>
    <FieldDescription>Use font-normal to set the font weight.</FieldDescription>
</Field>";

    private const string RtlCode = @"<DirectionProvider Dir=""rtl"">
    <ToggleGroup Type=""SelectionMode.Single"" Variant=""ToggleVariant.Outline"" Value=""@_rtlAlignment"" ValueChanged=""HandleRtlAlignmentChanged"">
        <ToggleGroupItem Value=""list"" aria-label=""قائمة"">قائمة</ToggleGroupItem>
        <ToggleGroupItem Value=""grid"" aria-label=""شبكة"">شبكة</ToggleGroupItem>
        <ToggleGroupItem Value=""cards"" aria-label=""بطاقات"">بطاقات</ToggleGroupItem>
    </ToggleGroup>
</DirectionProvider>";

    private Task HandleSingleFormatChanged(string? value)
    {
        _singleFormat = value;
        return Task.CompletedTask;
    }

    private Task HandleVerticalAlignmentChanged(string[] values)
    {
        _verticalValues = values;
        return Task.CompletedTask;
    }

    private Task HandleFontWeightChanged(string? value)
    {
        _fontWeight = value;
        return Task.CompletedTask;
    }

    private Task HandleRtlAlignmentChanged(string? value)
    {
        _rtlAlignment = value;
        return Task.CompletedTask;
    }

}
