@page "/sortables"
@using System.Linq

<PageTitle>Sortable - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is6xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic List"
                         Description="Drag entire cards to reorder a backlog. The component raises an event so your page can persist the new order."
                         Code="@(@"<SortableList OnReorder=""HandleBacklogReorder"">
    @foreach (var item in _backlog)
    {
        <SortableItem ItemId=""@item.Id"">
            ...
        </SortableItem>
    }
</SortableList>")"
CodeLanguage="razor">
                <Div Id="sortable-basic-demo" Width="Width.IsFull" MaxWidth="MaxWidth.Is3xl">
                    <SortableList Id="sortable-basic-list" OnReorder="HandleBacklogReorder">
                        @foreach (var card in _backlog)
                        {
                            <SortableItem @key="card.Id" ItemId="@card.Id">
                                <Div Width="Width.IsFull" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" TextColor="TextColor.CardForeground" Class="shadow-sm transition-shadow hover:shadow-md">
                                    <Div Display="Display.Flex" ItemsAlign="Items.Start" Justify="Justify.Between" Gap="Gap.Is4">
                                        <Div Space="Space.Y.Is1">
                                            <Div TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">@card.Title</Div>
                                            <Div TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">@card.Owner</Div>
                                        </Div>
                                        <Span TextSize="TextSize.Xs" FontWeight="FontWeight.Medium" Rounded="Rounded.Full" Padding="Padding.Is1.OnY.Is2.OnX" Class="@($"inline-flex {card.BadgeClass}")">
                                            @card.Status
                                        </Span>
                                    </Div>
                                </Div>
                            </SortableItem>
                        }
                    </SortableList>

                    <Paragraph Id="sortable-basic-order" TextColor="TextColor.MutedForeground" Margin="Margin.Is4.FromTop.Is0.FromBottom">
                        Current order: <Strong>@GetBacklogOrder()</Strong>
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Handle Only"
                         Description="Set HandleOnly to require a dedicated drag affordance instead of making the whole row draggable."
                         Code="@(@"<SortableList HandleOnly=""true"" OnReorder=""HandleReleaseStepReorder"">
    <SortableItem ItemId=""deploy"">
        <SortableHandle>
            <Icon Name=""LucideIcon.GripVertical"" />
        </SortableHandle>
    </SortableItem>
</SortableList>")"
CodeLanguage="razor">
                <Div Id="sortable-handle-demo" Width="Width.IsFull" MaxWidth="MaxWidth.Is3xl">
                    <SortableList Id="sortable-handle-list" HandleOnly="true" OnReorder="HandleReleaseStepReorder">
                        @foreach (var step in _releaseSteps)
                        {
                            <SortableItem @key="step.Id" ItemId="@step.Id">
                                <Div Display="Display.Flex" Width="Width.IsFull" ItemsAlign="Items.Center" Gap="Gap.Is3" Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4" Class="shadow-sm">
                                    <SortableHandle Class="size-9 rounded-lg border border-border bg-muted/40 text-muted-foreground">
                                        <Icon Name="LucideIcon.GripVertical" BoxSize="Size.Is4" />
                                    </SortableHandle>

                                    <Div Width="Width.IsFull" Class="min-w-0 flex-1 text-left">
                                        <Div TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold" Class="truncate">@step.Title</Div>
                                        <Div TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Class="truncate">@step.Detail</Div>
                                    </Div>

                                    <Span Display="Display.InlineFlex" Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is1.OnY.Is2.OnX" TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">
                                        @step.Environment
                                    </Span>
                                </Div>
                            </SortableItem>
                        }
                    </SortableList>

                    <Paragraph Id="sortable-handle-state" TextColor="TextColor.MutedForeground" Margin="Margin.Is4.FromTop.Is0.FromBottom">
                        Last move: <Strong>@_releaseStepMoveSummary</Strong>
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disable the list when the ordering is read-only or controlled elsewhere."
                         Code="@SortableDisabledCode"
CodeLanguage="razor">
                <Div Id="sortable-disabled-demo" Width="Width.IsFull" MaxWidth="MaxWidth.Is3xl">
                    <SortableList Id="sortable-disabled-list" Disabled="true">
                        @foreach (var item in _frozenChecklist)
                        {
                            <SortableItem @key="item.Id" ItemId="@item.Id">
                                <Div Width="Width.IsFull" Rounded="Rounded.Xl" Border="Border.Is1" Class="border-dashed text-left" BackgroundColor='BackgroundColor.Token("muted/20")' Padding="Padding.Is4">
                                    <Div TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">@item.Title</Div>
                                    <Div TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">@item.Detail</Div>
                                </Div>
                            </SortableItem>
                        }
                    </SortableList>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string SortableDisabledCode =
@"<SortableList Disabled=""true"">
    <SortableItem ItemId=""a"">...</SortableItem>
</SortableList>";

    private readonly List<SortableCard> _backlog =
    [
        new("usage-analytics", "Usage analytics dashboard", "Owned by Product", "Ready", "bg-emerald-500/10 text-emerald-700 dark:text-emerald-300"),
        new("billing-export", "Billing export retry policy", "Owned by Platform", "In review", "bg-blue-500/10 text-blue-700 dark:text-blue-300"),
        new("empty-state", "Empty state polish", "Owned by Design", "Todo", "bg-amber-500/10 text-amber-700 dark:text-amber-300"),
        new("audit-log", "Audit log filters", "Owned by Support", "Blocked", "bg-rose-500/10 text-rose-700 dark:text-rose-300")
    ];

    private readonly List<SortableStep> _releaseSteps =
    [
        new("build", "Build artifacts", "Create and sign the release bundle.", "CI"),
        new("smoke", "Run smoke tests", "Verify the preview environment before promote.", "Preview"),
        new("promote", "Promote to production", "Approve the rollout window and push live.", "Prod"),
        new("announce", "Post release note", "Notify support and customer success.", "Ops")
    ];

    private readonly List<SortableStep> _frozenChecklist =
    [
        new("contract", "Contract signed", "Locked after legal review.", "Ready"),
        new("dns", "DNS validated", "Owned by infrastructure automation.", "Ready"),
        new("handoff", "Customer handoff", "Waiting on scheduled launch window.", "Queued")
    ];

    private string _releaseStepMoveSummary = "No changes yet.";

    private Task HandleBacklogReorder(SortableReorderEventArgs args)
    {
        TryMoveItem(_backlog, args);

        return Task.CompletedTask;
    }

    private Task HandleReleaseStepReorder(SortableReorderEventArgs args)
    {
        if (TryMoveItem(_releaseSteps, args))
        {
            _releaseStepMoveSummary = $"{args.ItemId ?? "step"} moved from {args.OldIndex + 1} to {args.NewIndex + 1}.";
        }

        return Task.CompletedTask;
    }

    private string GetBacklogOrder()
    {
        return string.Join(" -> ", _backlog.Select(card => card.Title));
    }

    private static bool TryMoveItem<T>(List<T> items, SortableReorderEventArgs args)
    {
        if (args.OldIndex < 0 || args.NewIndex < 0)
        {
            return false;
        }

        if (args.OldIndex >= items.Count || args.NewIndex >= items.Count)
        {
            return false;
        }

        if (args.OldIndex == args.NewIndex)
        {
            return false;
        }

        var item = items[args.OldIndex];
        items.RemoveAt(args.OldIndex);
        items.Insert(args.NewIndex, item);

        return true;
    }

    private sealed record SortableCard(string Id, string Title, string Owner, string Status, string BadgeClass);

    private sealed record SortableStep(string Id, string Title, string Detail, string Environment);
}
