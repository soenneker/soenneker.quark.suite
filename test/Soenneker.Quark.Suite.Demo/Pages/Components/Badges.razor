@page "/badges"

<PageTitle>Badge Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Variants" Description="Display the full variant set, including quieter ghost and link treatments.">
                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is4">
                    <Badge Variant="BadgeVariant.Default">Default</Badge>
                    <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                    <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                    <Badge Variant="BadgeVariant.Outline">Outline</Badge>
                    <Badge Variant="BadgeVariant.Ghost">Ghost</Badge>
                    <Badge Variant="BadgeVariant.Link">Link</Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icon" Description="Icons inherit compact spacing and alignment automatically.">
                <Div Class="flex flex-wrap gap-3">
                    <Badge Variant="BadgeVariant.Secondary" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'>
                        <Icon Name="LucideIcon.CircleAlert" />
                        Beta
                    </Badge>
                    <Badge Variant="BadgeVariant.Default" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'>
                        <Icon Name="LucideIcon.Check" />
                        Verified
                    </Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Spinner" Description="Spinners can be rendered inline on either edge of the badge content.">
                <Div Display="Display.Flex" Flex="Flex.Wrap" AlignUtility="Align.ItemsCenter" Gap="Gap.Is4">
                    <Badge Variant="BadgeVariant.Outline" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'>
                        <Spinner Class="size-3" />
                        Syncing
                    </Badge>
                    <Badge Variant="BadgeVariant.Secondary" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'>
                        Deploying
                        <Spinner Class="size-3" />
                    </Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link" Description="Badges can pass their styling into a child Quark link.">
                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                    <Badge Variant="BadgeVariant.Outline" AsChild="true">
                        <Anchor To="components">Open docs</Anchor>
                    </Badge>
                    <Badge Variant="BadgeVariant.Secondary" AsChild="true">
                        <Anchor To="buttons">See buttons</Anchor>
                    </Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Colors" Description="Custom classes still work when you need product-specific badge colors.">
                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is4">
                    <Badge Variant="BadgeVariant.Outline" Class="border-green-500/40 bg-green-500/10 text-green-700 dark:text-green-300">Healthy</Badge>
                    <Badge Variant="BadgeVariant.Outline" Class="border-blue-500/40 bg-blue-500/10 text-blue-700 dark:text-blue-300">Preview</Badge>
                    <Badge Variant="BadgeVariant.Outline" Class="border-purple-500/40 bg-gradient-to-r from-purple-500/10 to-pink-500/10 text-purple-700 dark:text-purple-300">Gradient</Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples keep Quark-specific badge compositions separate from the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field" Description="Use badges in labels to call out beta or recommended inputs.">
                <Field>
                    <Div class="mb-2 flex items-center gap-2">
                        <FieldLabel For="webhookUrl">Webhook URL</FieldLabel>
                        <Badge Variant="BadgeVariant.Secondary">Beta</Badge>
                    </Div>
                    <TextInput Id="webhookUrl" Placeholder="https://api.example.com/webhook" Class="w-full" />
                </Field>
            </DemoSection>
        </Section>
    </Div>
</Div>
