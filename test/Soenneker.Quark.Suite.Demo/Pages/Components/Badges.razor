@page "/badges"

<PageTitle>Badge Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Variants" Description="Primary badge variants." Code="@(@"<Badge Variant=""BadgeVariant.Default"">Default</Badge>
<Badge Variant=""BadgeVariant.Secondary"">Secondary</Badge>
<Badge Variant=""BadgeVariant.Destructive"">Destructive</Badge>
<Badge Variant=""BadgeVariant.Outline"">Outline</Badge>")">
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is4">
                <Badge Variant="BadgeVariant.Default">Default</Badge>
                <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                <Badge Variant="BadgeVariant.Outline">Outline</Badge>
            </Div>
        </DemoSection>

        <DemoSection Title="With Icon" Description="Pair an icon with the badge text when the status should scan faster." Code="@(@"<Badge Variant=""BadgeVariant.Secondary"" Class=""inline-flex items-center gap-1.5""><Icon Name=""LucideIcon.CircleAlert"" />Beta</Badge>
<Badge Variant=""BadgeVariant.Default"" Class=""inline-flex items-center gap-1.5""><Icon Name=""LucideIcon.Check"" />Verified</Badge>")">
            <Div class="flex flex-wrap gap-3">
                <Badge Variant="BadgeVariant.Secondary" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'><Icon Name="LucideIcon.CircleAlert" />Beta</Badge>
                <Badge Variant="BadgeVariant.Default" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'><Icon Name="LucideIcon.Check" />Verified</Badge>
                <Badge Variant="BadgeVariant.Destructive" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'><Icon Name="LucideIcon.TriangleAlert" />Blocked</Badge>
            </Div>
        </DemoSection>

        <DemoSection Title="With Spinner" Description="A spinner can communicate background activity inside a compact badge." Code="@(@"<Badge Variant=""BadgeVariant.Outline"" Class=""inline-flex items-center gap-1.5""><Spinner Size=""Size.Small"" />Syncing</Badge>")">
            <Div Display="Display.Flex" Flex="Flex.Wrap" AlignUtility="Align.ItemsCenter" Gap="Gap.Is4">
                <Badge Variant="BadgeVariant.Outline" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'><Spinner Size="Size.Small" />Syncing</Badge>
                <Badge Variant="BadgeVariant.Secondary" Display="Display.InlineFlex" AlignUtility="Align.ItemsCenter" Gap='Gap.Token("1.5")'><Spinner Size="Size.Small" />Deploying</Badge>
            </Div>
        </DemoSection>

        <DemoSection Title="Link" Description="Use a pointer cursor and surrounding link behavior when the badge acts like navigation." Code="@(@"<a href=""/components"" class=""inline-flex""><Badge Variant=""BadgeVariant.Outline"" Class=""cursor-pointer"">Open docs</Badge></a>")">
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                <a href="/components" class="inline-flex"><Badge Variant="BadgeVariant.Outline" Class="cursor-pointer">Open docs</Badge></a>
                <a href="/buttons" class="inline-flex"><Badge Variant="BadgeVariant.Secondary" Class="cursor-pointer">See buttons</Badge></a>
            </Div>
        </DemoSection>

        <DemoSection Title="In Lists" Description="Badges combined with list and card-like rows." Code="@(@"<Div class=""max-w-md border rounded-lg divide-y"">
    <Div class=""p-4 flex items-center justify-between"">
        <Div class=""space-y-1""><Span class=""text-sm font-medium"">Project Alpha</Span><Paragraph class=""text-sm text-muted-foreground"">Active development</Paragraph></Div>
        <Badge Variant=""BadgeVariant.Default"">In Progress</Badge>
    </Div>
    <Div class=""p-4 flex items-center justify-between"">
        <Div class=""space-y-1""><Span class=""text-sm font-medium"">Project Beta</Span><Paragraph class=""text-sm text-muted-foreground"">Under review</Paragraph></Div>
        <Badge Variant=""BadgeVariant.Secondary"">Review</Badge>
    </Div>
</Div>")">
            <Div class="max-w-md border rounded-lg divide-y">
                <Div class="p-4 flex items-center justify-between"><Div Space="Space.Y.Is1"><Span TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Project Alpha</Span><Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Active development</Paragraph></Div><Badge Variant="BadgeVariant.Default">In Progress</Badge></Div>
                <Div class="p-4 flex items-center justify-between"><Div Space="Space.Y.Is1"><Span TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Project Beta</Span><Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Under review</Paragraph></Div><Badge Variant="BadgeVariant.Secondary">Review</Badge></Div>
                <Div class="p-4 flex items-center justify-between"><Div Space="Space.Y.Is1"><Span TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Project Gamma</Span><Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Deployment failed</Paragraph></Div><Badge Variant="BadgeVariant.Destructive">Failed</Badge></Div>
                <Div class="p-4 flex items-center justify-between"><Div Space="Space.Y.Is1"><Span TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Project Delta</Span><Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Planning phase</Paragraph></Div><Badge Variant="BadgeVariant.Outline">Draft</Badge></Div>
            </Div>
        </DemoSection>

        <DemoSection Title="Custom Colors" Description="Override styles with Class when the default badge variants are not enough." Code="@(@"<Badge Variant=""BadgeVariant.Default"" Class=""text-lg px-4 py-1"">Large Badge</Badge>
<Badge Variant=""BadgeVariant.Secondary"" Class=""rounded-sm"">Square Corners</Badge>
<Badge Variant=""BadgeVariant.Outline"" Class=""border-2 border-blue-500 text-blue-500"">Custom Color</Badge>
<Badge Variant=""BadgeVariant.Default"" Class=""bg-gradient-to-r from-purple-500 to-pink-500 border-0"">Gradient</Badge>")">
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is4">
                <Badge Variant="BadgeVariant.Default" Class="text-lg px-4 py-1">Large Badge</Badge>
                <Badge Variant="BadgeVariant.Secondary" Class="rounded-sm">Square Corners</Badge>
                <Badge Variant="BadgeVariant.Outline" Class="border-2 border-blue-500 text-blue-500">Custom Color</Badge>
                <Badge Variant="BadgeVariant.Default" Class="bg-gradient-to-r from-purple-500 to-pink-500 border-0">Gradient</Badge>
            </Div>
        </DemoSection>

        <DemoSection Title="Field" Description="Use badges in labels to highlight recommended or beta fields just like the shadcn input examples." Code="@(@"<Field>
    <Div class=""mb-2 flex items-center gap-2"">
        <FieldLabel For=""webhookUrl"">Webhook URL</FieldLabel>
        <Badge Variant=""BadgeVariant.Secondary"">Beta</Badge>
    </Div>
    <TextInput Id=""webhookUrl"" Placeholder=""https://api.example.com/webhook"" Class=""w-full"" />
</Field>")">
            <Field>
                <Div class="mb-2 flex items-center gap-2">
                    <FieldLabel For="webhookUrl">Webhook URL</FieldLabel>
                    <Badge Variant="BadgeVariant.Secondary">Beta</Badge>
                </Div>
                <TextInput Id="webhookUrl" Placeholder="https://api.example.com/webhook" Class="w-full" />
            </Field>
        </DemoSection>

        <DemoSection Title="Accessibility Notes" Description="Best practices for using badges accessibly." Code="@(@"<Paragraph class=""text-sm""><strong>Keep text concise:</strong> badges are best with short labels.</Paragraph>
<Paragraph class=""text-sm""><strong>Do not rely only on color:</strong> include meaningful text.</Paragraph>
<Paragraph class=""text-sm""><strong>Provide context:</strong> badge purpose should be clear nearby.</Paragraph>")">
            <Div class="border rounded-lg p-6 space-y-3 bg-muted/50">
                <Paragraph TextSize="TextSize.Sm"><strong>Keep text concise:</strong> badges are best with short labels.</Paragraph>
                <Paragraph TextSize="TextSize.Sm"><strong>Do not rely only on color:</strong> include meaningful text.</Paragraph>
                <Paragraph TextSize="TextSize.Sm"><strong>Provide context:</strong> badge purpose should be clear nearby.</Paragraph>
            </Div>
        </DemoSection>
    </Div>
</Div>
