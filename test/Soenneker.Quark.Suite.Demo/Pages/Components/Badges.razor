@page "/badges"

<PageTitle>Badge Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Badge"
                    Code="@(@"<Field>
  <Div class=""flex items-center gap-2 mb-2"">
    <FieldLabel For=""webhookUrl"">Webhook URL</FieldLabel>
    <Badge Variant=""BadgeVariant.Secondary"">Beta</Badge>
  </Div>
  <TextInput Id=""webhookUrl"" Placeholder=""https://api.example.com/webhook"" Class=""w-full"" />
</Field>")">
            <DescriptionContent>Use <Badge Variant="BadgeVariant.Secondary">Badge</Badge> in the label to highlight a recommended field.</DescriptionContent>
            <ChildContent>
                <Field>
                    <Div class="flex items-center gap-2 mb-2">
                        <FieldLabel For="webhookUrl">Webhook URL</FieldLabel>
                        <Badge Variant="BadgeVariant.Secondary">Beta</Badge>
                    </Div>
                    <TextInput Id="webhookUrl" Placeholder="https://api.example.com/webhook" Class="w-full" />
                </Field>
            </ChildContent>
        </DemoSection>

        <DemoSection Title="Variants" Description="Primary badge variants." Code="@(@"<Badge Variant=""BadgeVariant.Default"">Default</Badge>
<Badge Variant=""BadgeVariant.Secondary"">Secondary</Badge>
<Badge Variant=""BadgeVariant.Destructive"">Destructive</Badge>
<Badge Variant=""BadgeVariant.Outline"">Outline</Badge>")">
            <Div class="flex flex-wrap gap-4">
                <Badge Variant="BadgeVariant.Default">Default</Badge>
                <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                <Badge Variant="BadgeVariant.Outline">Outline</Badge>
            </Div>
        </DemoSection>

        <DemoSection Title="Status Indicators" Description="Badges for status display." Code="@(@"<Badge Variant=""BadgeVariant.Default"">Active</Badge>
<Badge Variant=""BadgeVariant.Secondary"">Pending</Badge>")">
            <Div class="flex flex-wrap gap-3">
                <Div class="flex items-center gap-2"><Span class="text-sm">Active:</Span><Badge Variant="BadgeVariant.Default">Active</Badge></Div>
                <Div class="flex items-center gap-2"><Span class="text-sm">Pending:</Span><Badge Variant="BadgeVariant.Secondary">Pending</Badge></Div>
                <Div class="flex items-center gap-2"><Span class="text-sm">Error:</Span><Badge Variant="BadgeVariant.Destructive">Error</Badge></Div>
                <Div class="flex items-center gap-2"><Span class="text-sm">Draft:</Span><Badge Variant="BadgeVariant.Outline">Draft</Badge></Div>
            </Div>
        </DemoSection>

        <DemoSection Title="Notification Counts" Description="Badges for count display." Code="@(@"<Badge Variant=""BadgeVariant.Default"">3</Badge>")">
            <Div class="flex flex-wrap gap-4 items-center">
                <Div class="flex items-center gap-2"><Span class="text-sm">Messages</Span><Badge Variant="BadgeVariant.Default">3</Badge></Div>
                <Div class="flex items-center gap-2"><Span class="text-sm">Unread</Span><Badge Variant="BadgeVariant.Destructive">12</Badge></Div>
                <Div class="flex items-center gap-2"><Span class="text-sm">Completed</Span><Badge Variant="BadgeVariant.Secondary">24</Badge></Div>
            </Div>
        </DemoSection>

        <DemoSection Title="Tags / Labels" Description="Badges as tags." Code="@(@"<Badge Variant=""BadgeVariant.Outline"">Blazor</Badge>")">
            <Div class="flex flex-wrap gap-2">
                <Badge Variant="BadgeVariant.Outline">Blazor</Badge>
                <Badge Variant="BadgeVariant.Outline">C#</Badge>
                <Badge Variant="BadgeVariant.Outline">Tailwind</Badge>
                <Badge Variant="BadgeVariant.Outline">Quark</Badge>
            </Div>
        </DemoSection>

        <DemoSection Title="In Lists" Description="Badges combined with list and card-like rows." Code="@(@"<Div class=""max-w-md border rounded-lg divide-y"">
    <Div class=""p-4 flex items-center justify-between"">
        <Div class=""space-y-1""><Span class=""text-sm font-medium"">Project Alpha</Span><Paragraph class=""text-sm text-muted-foreground"">Active development</Paragraph></Div>
        <Badge Variant=""BadgeVariant.Default"">In Progress</Badge>
    </Div>
    <Div class=""p-4 flex items-center justify-between"">
        <Div class=""space-y-1""><Span class=""text-sm font-medium"">Project Beta</Span><Paragraph class=""text-sm text-muted-foreground"">Under review</Paragraph></Div>
        <Badge Variant=""BadgeVariant.Secondary"">Review</Badge>
    </Div>
</Div>")">
            <Div class="max-w-md border rounded-lg divide-y">
                <Div class="p-4 flex items-center justify-between"><Div class="space-y-1"><Span class="text-sm font-medium">Project Alpha</Span><Paragraph class="text-sm text-muted-foreground">Active development</Paragraph></Div><Badge Variant="BadgeVariant.Default">In Progress</Badge></Div>
                <Div class="p-4 flex items-center justify-between"><Div class="space-y-1"><Span class="text-sm font-medium">Project Beta</Span><Paragraph class="text-sm text-muted-foreground">Under review</Paragraph></Div><Badge Variant="BadgeVariant.Secondary">Review</Badge></Div>
                <Div class="p-4 flex items-center justify-between"><Div class="space-y-1"><Span class="text-sm font-medium">Project Gamma</Span><Paragraph class="text-sm text-muted-foreground">Deployment failed</Paragraph></Div><Badge Variant="BadgeVariant.Destructive">Failed</Badge></Div>
                <Div class="p-4 flex items-center justify-between"><Div class="space-y-1"><Span class="text-sm font-medium">Project Delta</Span><Paragraph class="text-sm text-muted-foreground">Planning phase</Paragraph></Div><Badge Variant="BadgeVariant.Outline">Draft</Badge></Div>
            </Div>
        </DemoSection>

        <DemoSection Title="Custom Styling" Description="Override styles with Class." Code="@(@"<Badge Variant=""BadgeVariant.Default"" Class=""text-lg px-4 py-1"">Large Badge</Badge>
<Badge Variant=""BadgeVariant.Secondary"" Class=""rounded-sm"">Square Corners</Badge>
<Badge Variant=""BadgeVariant.Outline"" Class=""border-2 border-blue-500 text-blue-500"">Custom Color</Badge>
<Badge Variant=""BadgeVariant.Default"" Class=""bg-gradient-to-r from-purple-500 to-pink-500 border-0"">Gradient</Badge>")">
            <Div class="flex flex-wrap gap-4">
                <Badge Variant="BadgeVariant.Default" Class="text-lg px-4 py-1">Large Badge</Badge>
                <Badge Variant="BadgeVariant.Secondary" Class="rounded-sm">Square Corners</Badge>
                <Badge Variant="BadgeVariant.Outline" Class="border-2 border-blue-500 text-blue-500">Custom Color</Badge>
                <Badge Variant="BadgeVariant.Default" Class="bg-gradient-to-r from-purple-500 to-pink-500 border-0">Gradient</Badge>
            </Div>
        </DemoSection>

        <DemoSection Title="Accessibility Notes" Description="Best practices for using badges accessibly." Code="@(@"<Paragraph class=""text-sm""><strong>Keep text concise:</strong> badges are best with short labels.</Paragraph>
<Paragraph class=""text-sm""><strong>Do not rely only on color:</strong> include meaningful text.</Paragraph>
<Paragraph class=""text-sm""><strong>Provide context:</strong> badge purpose should be clear nearby.</Paragraph>")">
            <Div class="border rounded-lg p-6 space-y-3 bg-muted/50">
                <Paragraph class="text-sm"><strong>Keep text concise:</strong> badges are best with short labels.</Paragraph>
                <Paragraph class="text-sm"><strong>Do not rely only on color:</strong> include meaningful text.</Paragraph>
                <Paragraph class="text-sm"><strong>Provide context:</strong> badge purpose should be clear nearby.</Paragraph>
            </Div>
        </DemoSection>
    </Div>
</Div>
