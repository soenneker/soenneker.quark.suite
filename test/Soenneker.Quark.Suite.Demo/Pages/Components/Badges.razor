@page "/badges"

<PageTitle>Badge Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays a badge or a component that looks like a badge."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full flex-wrap justify-center gap-2">
                    <Badge>Badge</Badge>
                    <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                    <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                    <Badge Variant="BadgeVariant.Outline">Outline</Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Variants"
                         Description="Shadcn-aligned Variants example."
                         Code="@VariantsCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full flex-wrap justify-center gap-2">
                    <Badge>Default</Badge>
                    <Badge Variant="BadgeVariant.Secondary">Secondary</Badge>
                    <Badge Variant="BadgeVariant.Destructive">Destructive</Badge>
                    <Badge Variant="BadgeVariant.Outline">Outline</Badge>
                    <Badge Variant="BadgeVariant.Ghost">Ghost</Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icon"
                         Description="Icons align with compact spacing; place icon before or after the label."
                         Code="@WithIconCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                    <Badge Variant="BadgeVariant.Secondary"
                           Display="Display.InlineFlex"
                           ItemsAlign="Items.Center"
                           Gap='Gap.Token("1")'>
                        <Icon Name="LucideIcon.BadgeCheck" data-icon="inline-start" />
                        Verified
                    </Badge>
                    <Badge Variant="BadgeVariant.Outline"
                           Display="Display.InlineFlex"
                           ItemsAlign="Items.Center"
                           Gap='Gap.Token("1")'>
                        Bookmark
                        <Icon Name="LucideIcon.Bookmark" data-icon="inline-end" />
                    </Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Spinner"
                         Description="Spinners can sit at the start or end of the badge content."
                         Code="@WithSpinnerCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                    <Badge Variant="BadgeVariant.Destructive"
                           Display="Display.InlineFlex"
                           ItemsAlign="Items.Center"
                           Gap='Gap.Token("1")'>
                        <Icon Name="LucideIcon.LoaderCircle" Class="size-4 animate-spin" data-icon="inline-start" />
                        Deleting
                    </Badge>
                    <Badge Variant="BadgeVariant.Secondary"
                           Display="Display.InlineFlex"
                           ItemsAlign="Items.Center"
                           Gap='Gap.Token("1")'>
                        Generating
                        <Icon Name="LucideIcon.LoaderCircle" Class="size-4 animate-spin" data-icon="inline-end" />
                    </Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link"
                         Description="Render a badge as a link with AsChild."
                         Code="@LinkCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                    <Badge Variant="BadgeVariant.Default" AsChild="true">
                        <Anchor To="#link">
                            Open Link
                            <Icon Name="LucideIcon.ArrowUpRight" data-icon="inline-end" />
                        </Anchor>
                    </Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Colors"
                         Description="Add utility classes for product-specific emphasis."
                         Code="@CustomColorsCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                    <Badge Variant="BadgeVariant.Default" Class="bg-blue-50 text-blue-700 dark:bg-blue-950 dark:text-blue-300">Blue</Badge>
                    <Badge Variant="BadgeVariant.Default" Class="bg-green-50 text-green-700 dark:bg-green-950 dark:text-green-300">Green</Badge>
                    <Badge Variant="BadgeVariant.Default" Class="bg-sky-50 text-sky-700 dark:bg-sky-950 dark:text-sky-300">Sky</Badge>
                    <Badge Variant="BadgeVariant.Default" Class="bg-purple-50 text-purple-700 dark:bg-purple-950 dark:text-purple-300">Purple</Badge>
                    <Badge Variant="BadgeVariant.Default" Class="bg-red-50 text-red-700 dark:bg-red-950 dark:text-red-300">Red</Badge>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Badges wrap and read naturally in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" Width="Width.IsFull" Flex=@("flex-wrap") Justify="Justify.Center" Gap="Gap.Is2" dir="rtl">
                        <Badge Variant="BadgeVariant.Default">شارة</Badge>
                        <Badge Variant="BadgeVariant.Secondary">ثانوي</Badge>
                        <Badge Variant="BadgeVariant.Destructive">مدمر</Badge>
                        <Badge Variant="BadgeVariant.Outline">مخطط</Badge>
                        <Badge Variant="BadgeVariant.Secondary"
                               Display="Display.InlineFlex"
                               ItemsAlign="Items.Center"
                               Gap='Gap.Token("1")'>
                            <Icon Name="LucideIcon.BadgeCheck" data-icon="inline-start" />
                            متحقق
                        </Badge>
                        <Badge Variant="BadgeVariant.Outline"
                               Display="Display.InlineFlex"
                               ItemsAlign="Items.Center"
                               Gap='Gap.Token("1")'>
                            إشارة مرجعية
                            <Icon Name="LucideIcon.Bookmark" data-icon="inline-end" />
                        </Badge>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

