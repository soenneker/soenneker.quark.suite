@page "/progresses"
@using System.Threading
@implements IAsyncDisposable

<PageTitle>Progress - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="@($"Value animates from 13 to 66 after a short delay. Current: {_demoProgress}.")"
                         Code="@DemoCode">
                <Progress ProgressValue="@_demoProgress" Class="w-[60%]" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A single determinate value."
                         Code="@BasicCode">
                <Progress ProgressValue="33" Class="w-full" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Label"
                         Description="Associate the bar with a label using matching id and for values."
                         Code="@LabelCode">
                <Field Class="w-full max-w-sm">
                    <FieldLabel For="progress-upload" Class="!w-full flex flex-row items-center justify-between gap-2">
                        <Span>Upload progress</Span>
                        <Span Class="text-muted-foreground">66%</Span>
                    </FieldLabel>
                    <Progress Id="progress-upload" ProgressValue="66" Class="w-full" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Controlled"
                         Description="@($"Drag the slider to set the bar. Current: {GetControlledPercent()}%.")"
                         Code="@ControlledCode">
                <Div Class="flex w-full max-w-sm flex-col gap-4">
                    <Progress ProgressValue="@GetControlledPercent()" Class="w-full" />
                    <Slider Min="0"
                            Max="100"
                            Step="1"
                            SliderValue="@_controlledValue"
                            SliderValueChanged="HandleControlledValueChanged"
                            Class="w-full" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Layout and the bar respond to right-to-left direction."
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <Field Class="w-full max-w-sm">
                        <FieldLabel For="progress-upload-rtl" Class="!w-full flex flex-row items-center justify-between gap-2">
                            <Span>تقدم الرفع</Span>
                            <Span Class="text-muted-foreground">66%</Span>
                        </FieldLabel>
                        <Progress Id="progress-upload-rtl" ProgressValue="66" Class="w-full" />
                    </Field>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Indeterminate state when completion is unknown.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Indeterminate"
                         Description="Shows activity without a specific percentage."
                         Code="@IndeterminateCode">
                <Div Class="w-full max-w-md space-y-2">
                    <Div Class="flex items-center justify-between text-sm">
                        <Span>Preparing assets</Span>
                        <Span Class="text-muted-foreground">Loading</Span>
                    </Div>
                    <Progress Indeterminate="true" AriaValueText="Preparing assets" Class="w-full" />
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private CancellationTokenSource? _demoCts;
    private int _demoProgress = 13;
    private double _controlledValue = 50;

    private const string DemoCode =
@"@using System.Threading
@implements IAsyncDisposable

<Progress ProgressValue=""@_demoProgress"" Class=""w-[60%]"" />

@code {
    private CancellationTokenSource? _demoCts;
    private int _demoProgress = 13;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _demoCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(500, _demoCts.Token);
            _demoProgress = 66;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

    public ValueTask DisposeAsync()
    {
        _demoCts?.Cancel();
        _demoCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}";

    private const string BasicCode = @"<Progress ProgressValue=""33"" Class=""w-full"" />";

    private const string LabelCode =
@"<Field Class=""w-full max-w-sm"">
    <FieldLabel For=""progress-upload"" Class=""!w-full flex flex-row items-center justify-between gap-2"">
        <Span>Upload progress</Span>
        <Span Class=""text-muted-foreground"">66%</Span>
    </FieldLabel>
    <Progress Id=""progress-upload"" ProgressValue=""66"" Class=""w-full"" />
</Field>";

    private const string ControlledCode =
@"<Div Class=""flex w-full max-w-sm flex-col gap-4"">
    <Progress ProgressValue=""@GetControlledPercent()"" Class=""w-full"" />
    <Slider Min=""0""
            Max=""100""
            Step=""1""
            SliderValue=""@_controlledValue""
            SliderValueChanged=""HandleControlledValueChanged""
            Class=""w-full"" />
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Field Class=""w-full max-w-sm"">
        <FieldLabel For=""progress-upload-rtl"" Class=""!w-full flex flex-row items-center justify-between gap-2"">
            <Span>تقدم الرفع</Span>
            <Span Class=""text-muted-foreground"">66%</Span>
        </FieldLabel>
        <Progress Id=""progress-upload-rtl"" ProgressValue=""66"" Class=""w-full"" />
    </Field>
</DirectionProvider>";

    private const string IndeterminateCode =
@"<Div Class=""w-full max-w-md space-y-2"">
    <Div Class=""flex items-center justify-between text-sm"">
        <Span>Preparing assets</Span>
        <Span Class=""text-muted-foreground"">Loading</Span>
    </Div>
    <Progress Indeterminate=""true"" AriaValueText=""Preparing assets"" Class=""w-full"" />
</Div>";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _demoCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(500, _demoCts.Token);
            _demoProgress = 66;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException)
        {
        }
    }

    public ValueTask DisposeAsync()
    {
        _demoCts?.Cancel();
        _demoCts?.Dispose();
        return ValueTask.CompletedTask;
    }

    private int GetControlledPercent()
    {
        return (int)Math.Round(_controlledValue, MidpointRounding.AwayFromZero);
    }

    private Task HandleControlledValueChanged(double value)
    {
        _controlledValue = value;
        return Task.CompletedTask;
    }
}
