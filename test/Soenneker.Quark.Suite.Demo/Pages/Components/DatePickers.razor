@page "/datepickers"

<PageTitle>Date Pickers - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="A date picker component with range and presets."
                         Code="@(@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"" Class=""w-[240px] justify-between text-left font-normal"">
            @FormatDate(_dateOnly)
            <Icon Name=""LucideIcon.ChevronDown"" Class=""ml-auto size-4 opacity-50"" />
        </Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"" Align=""Alignment.Start"">
        <Calendar SelectedDate=""_dateOnly"" SelectedDateChanged=""OnBasicDateChanged"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline" Class="@($"w-[240px] justify-between text-left font-normal{(_dateOnly is null ? " text-muted-foreground" : "")}")">
                                @FormatDate(_dateOnly)
                                <Icon Name="LucideIcon.ChevronDown" Class="ml-auto size-4 opacity-50" />
                            </Button>
                        </PopoverTrigger>
                        <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                            <Calendar SelectedDate="_dateOnly" SelectedDateChanged="OnBasicDateChanged" />
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="Shadcn-aligned Basic example."
                         Code="@(@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"" Class=""w-[240px] justify-between text-left font-normal"">
            @FormatDate(_dateOnly)
            <Icon Name=""LucideIcon.ChevronDown"" Class=""ml-auto size-4 opacity-50"" />
        </Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"" Align=""Alignment.Start"">
        <Calendar SelectedDate=""_dateOnly"" SelectedDateChanged=""OnBasicDateChanged"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline" Class="@($"w-[240px] justify-between text-left font-normal{(_dateOnly is null ? " text-muted-foreground" : "")}")">
                                @FormatDate(_dateOnly)
                                <Icon Name="LucideIcon.ChevronDown" Class="ml-auto size-4 opacity-50" />
                            </Button>
                        </PopoverTrigger>
                        <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                            <Calendar SelectedDate="_dateOnly" SelectedDateChanged="OnBasicDateChanged" />
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Range Picker"
                         Description="Use a range calendar inside the popover when users need a start and end date from the same picker."
                         Code="@(@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"" Class=""w-[300px] justify-start text-left font-normal"" Id=""date"">
            @FormatRange(_rangeDate)
            <Icon Name=""LucideIcon.ChevronDown"" Class=""ml-auto size-4 opacity-50"" />
        </Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"" Align=""Alignment.Start"">
        <Calendar Mode=""CalendarSelectionMode.Range"" SelectedRange=""_rangeDate"" SelectedRangeChanged=""OnRangeDateChanged"" NumberOfMonths=""2"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Display="Display.Grid" Gap="Gap.Is2" Justify="Justify.Center">
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Id="date" Variant="ButtonVariant.Outline" Class="@($"w-[300px] justify-between text-left font-normal{(_rangeDate?.From is null ? " text-muted-foreground" : "")}")">
                                @FormatRange(_rangeDate)
                                <Icon Name="LucideIcon.ChevronDown" Class="ml-auto size-4 opacity-50" />
                            </Button>
                        </PopoverTrigger>
                        <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                            <Calendar Mode="CalendarSelectionMode.Range"
                                      SelectedRange="_rangeDate"
                                      SelectedRangeChanged="OnRangeDateChanged"
                                      NumberOfMonths="2" />
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="Date of Birth"
                         Description="Use a supported button trigger styled like an input when you want the field appearance without relying on raw HTML slotting."
                         Code="@(@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"" Class=""w-[240px] justify-start text-left font-normal"">
            @FormatDate(_typedDate)
        </Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"">
        <Calendar SelectedDate=""_typedDate"" SelectedDateChanged=""OnTypedDateChanged"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Display="Display.Flex" MinHeight='Height.Token("[16rem]")' Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is4" TextAlign="TextAlign.Center">
                    <Label Form="true">Type a date</Label>
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline"
                                    Class="@($"w-[240px] justify-start text-left font-normal{(_typedDate is null ? " text-muted-foreground" : "")}")">
                                @FormatDate(_typedDate)
                            </Button>
                        </PopoverTrigger>
                        <PopoverContent Width="Width.Auto" Padding="Padding.Is0">
                            <Calendar SelectedDate="_typedDate" SelectedDateChanged="OnTypedDateChanged" />
                        </PopoverContent>
                    </Popover>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        This stays on the supported trigger path while matching an input-like field surface.
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input"
                         Description="Use the calendar caption dropdown layout when users need direct month and year selection."
                         Code="@(@"<Popover Open=""_dropdownPickerOpen"" OpenChanged=""OnDropdownPickerOpenChanged"">
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"">@FormatDate(_dropdownPickerDate)</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"">
        <Calendar SelectedDate=""_dropdownPickerDate"" SelectedDateChanged=""OnDropdownPickerDateChanged"" CaptionLayout=""dropdown"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Display="Display.Flex" MinHeight='Height.Token("[16rem]")' Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is4" TextAlign="TextAlign.Center">
                    <Label Form="true">Pick a date with dropdowns</Label>
                    <Popover Open="_dropdownPickerOpen" OpenChanged="OnDropdownPickerOpenChanged">
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline" Class="w-[240px] justify-start text-left font-normal">@FormatDate(_dropdownPickerDate)</Button>
                        </PopoverTrigger>
                        <PopoverContent Width="Width.Auto" Padding="Padding.Is0">
                            <Calendar SelectedDate="_dropdownPickerDate"
                                      SelectedDateChanged="OnDropdownPickerDateChanged"
                                      CaptionLayout="dropdown" />
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Time Picker"
                         Description="A bounded `Calendar` keeps date-of-birth selection limited to an allowed historical range."
                         Code="@(@"<Popover Open=""_birthdayCalendarOpen"" OpenChanged=""OnBirthdayCalendarOpenChanged"">
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"">@FormatDate(_deliveryDate)</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"">
        <Calendar SelectedDate=""_deliveryDate"" SelectedDateChanged=""OnBirthdayDateChanged"" Min=""_minDate"" Max=""_maxDate"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Display="Display.Flex" MinHeight='Height.Token("[16rem]")' Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is4" TextAlign="TextAlign.Center">
                    <Label Form="true">Date of birth</Label>
                    <Popover Open="_birthdayCalendarOpen" OpenChanged="OnBirthdayCalendarOpenChanged">
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline" Class="w-[240px] justify-start text-left font-normal">@FormatDate(_deliveryDate)</Button>
                        </PopoverTrigger>
                        <PopoverContent Width="Width.Auto" Padding="Padding.Is0">
                            <Calendar SelectedDate="_deliveryDate"
                                      SelectedDateChanged="OnBirthdayDateChanged"
                                      Min="_minDate"
                                      Max="_maxDate" />
                        </PopoverContent>
                    </Popover>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Choose a date between @_minDate.ToString("yyyy-MM-dd") and @_maxDate.ToString("yyyy-MM-dd")
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Natural Language Picker"
                         Description="Exercise the reusable `DatePicker` trigger directly, including calendar selection and externally controlled state updates."
                         Code="@(@"<DatePicker SelectedDate=""_componentDate"" SelectedDateChanged=""OnComponentDateChanged"" />
<Button OnClick=""SetComponentDateToLaunch"">Set launch date</Button>
<Button OnClick=""ClearComponentDate"">Clear</Button>")"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" MinHeight='Height.Token("[20rem]")' Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is4" TextAlign="TextAlign.Center">
                    <Label Form="true">Reusable date picker</Label>
                    <DatePicker SelectedDate="_componentDate"
                                SelectedDateChanged="OnComponentDateChanged"
                                Placeholder="Pick a date"
                                data-testid="component-date-picker" />
                    <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Justify="Justify.Center" Gap="Gap.Is2">
                        <Button Variant="ButtonVariant.Outline" OnClick="SetComponentDateToLaunch" data-testid="component-date-launch">Set launch date</Button>
                        <Button Variant="ButtonVariant.Outline" OnClick="ClearComponentDate" data-testid="component-date-clear">Clear</Button>
                    </Div>
                    <Div Class="value-chip" Margin="Margin.Is0">
                        <Span Class="dot"></Span><Span>Selected: @_componentDate?.ToString("yyyy-MM-dd")</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="DateTimePicker adds time selection when the exact moment matters."
                         Code="@(@"<Label Form=""true"">Pick a date and time</Label>
<DateTimePicker @bind-SelectedDateTime=""_dateTime""/>")"
CodeLanguage="razor">
                <Div Display="Display.Flex" MinHeight='Height.Token("[16rem]")' Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is4" TextAlign="TextAlign.Center">
                    <Label Form="true">Pick a date and time</Label>
                    <DateTimePicker @bind-SelectedDateTime="_dateTime"/>
                    <Div Class="value-chip" Margin="Margin.Is0">
                        <Span Class="dot"></Span><Span>Value: @_dateTime?.ToString("yyyy-MM-dd HH:mm:ss")</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Natural Language Picker"
                         Description="Pair a natural-language input with the date picker surface when users can type common date phrases."
                         Code="@(@"<Field MaxWidth=""MaxWidth.IsSm"">
    <FieldLabel For=""natural-language-date"">Schedule</FieldLabel>
    <Input Id=""natural-language-date"" Placeholder=""Tomorrow morning"" Value=""Next Friday at 10:00"" />
    <FieldDescription>Resolve the phrase before committing the scheduled date.</FieldDescription>
</Field>")"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="natural-language-date">Schedule</FieldLabel>
                    <Input Id="natural-language-date" Placeholder="Tomorrow morning" Value="Next Friday at 10:00" />
                    <FieldDescription>Resolve the phrase before committing the scheduled date.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scheduled window"
                         Description="Combine date and time with min/max bounds for scheduling flows."
                         Code="@(@"<DateTimePicker @bind-SelectedDateTime=""_deploymentWindow"" Min=""_minDateTime"" Max=""_maxDateTime"" />")"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" MinHeight='Height.Token("[16rem]")' Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" FlexDirection="FlexDirection.Col" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is4" TextAlign="TextAlign.Center">
                    <Label Form="true">Deployment window</Label>
                    <DateTimePicker @bind-SelectedDateTime="_deploymentWindow" Min="_minDateTime" Max="_maxDateTime"/>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Available between @_minDateTime.ToString("MMM dd, yyyy HH:mm") and @_maxDateTime.ToString("MMM dd, yyyy HH:mm")
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code{

    private DateOnly? _dateOnly;
    private readonly DateOnly _minDate = new(1940, 1, 1);
    private readonly DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _deliveryDate = new(1995, 7, 14);
    private DateOnly? _typedDate = DateOnly.FromDateTime(DateTime.Today.AddDays(7));
    private DateOnly? _dropdownPickerDate = DateOnly.FromDateTime(DateTime.Today.AddDays(21));
    private DateOnly? _componentDate = new(2024, 4, 18);
    private bool _dropdownPickerOpen;
    private bool _birthdayCalendarOpen;
    private CalendarDateRange? _rangeDate = new(new DateOnly(2026, 1, 20), new DateOnly(2026, 2, 9));

    private DateTime? _dateTime = DateTime.Now;
    private readonly DateTime _minDateTime = DateTime.Today.AddHours(9);
    private readonly DateTime _maxDateTime = DateTime.Today.AddDays(7).AddHours(18);
    private DateTime? _deploymentWindow = DateTime.Today.AddDays(1).AddHours(14);

    private static string FormatDate(DateOnly? value)
    {
        return value?.ToString("MMM dd, yyyy") ?? "Pick a date";
    }

    private Task OnBirthdayCalendarOpenChanged(bool value)
    {
        _birthdayCalendarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnDropdownPickerOpenChanged(bool value)
    {
        _dropdownPickerOpen = value;
        return Task.CompletedTask;
    }

    private Task OnBasicDateChanged(DateOnly? value)
    {
        _dateOnly = value;
        return Task.CompletedTask;
    }

    private Task OnBirthdayDateChanged(DateOnly? value)
    {
        _deliveryDate = value;
        _birthdayCalendarOpen = false;
        return Task.CompletedTask;
    }

    private Task OnDropdownPickerDateChanged(DateOnly? value)
    {
        _dropdownPickerDate = value;
        _dropdownPickerOpen = false;
        return Task.CompletedTask;
    }

    private Task OnRangeDateChanged(CalendarDateRange? value)
    {
        _rangeDate = value;
        return Task.CompletedTask;
    }

    private Task OnTypedDateChanged(DateOnly? value)
    {
        _typedDate = value;
        return Task.CompletedTask;
    }

    private Task OnComponentDateChanged(DateOnly? value)
    {
        _componentDate = value;
        return Task.CompletedTask;
    }

    private Task SetComponentDateToLaunch()
    {
        _componentDate = new DateOnly(2030, 1, 15);
        return Task.CompletedTask;
    }

    private Task ClearComponentDate()
    {
        _componentDate = null;
        return Task.CompletedTask;
    }

    private static string FormatRange(CalendarDateRange? value)
    {
        if (value?.From is null)
            return "Pick a date range";

        if (value.To is null)
            return value.From.Value.ToString("MMM dd, yyyy");

        return $"{value.From.Value:MMM dd, yyyy} - {value.To.Value:MMM dd, yyyy}";
    }

}
