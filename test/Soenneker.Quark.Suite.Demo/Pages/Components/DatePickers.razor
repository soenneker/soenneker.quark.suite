@page "/datepickers"

<PageTitle>Date Pickers - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Compose a date picker from `Popover` and `Calendar` when you want a trigger-and-panel pattern."
                         Code="@(@"<Popover Open=""_basicCalendarOpen"" OpenChanged=""OnBasicCalendarOpenChanged"">
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"" Class=""w-[240px] justify-start text-left font-normal"">
            <Icon Name=""LucideIcon.Calendar"" />
            @FormatDate(_dateOnly)
        </Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"" Align=""start"">
        <Calendar SelectedDate=""_dateOnly"" SelectedDateChanged=""OnBasicDateChanged"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Class="flex min-h-[16rem] w-full max-w-sm flex-col items-center justify-center gap-4 text-center">
                    <Label Form="true">Pick a date</Label>
                    <Popover Open="_basicCalendarOpen" OpenChanged="OnBasicCalendarOpenChanged">
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline" Class="w-[240px] justify-start text-left font-normal">
                                <Icon Name="LucideIcon.Calendar" />
                                @FormatDate(_dateOnly)
                            </Button>
                        </PopoverTrigger>
                        <PopoverContent Class="w-auto p-0" Align="start">
                            <Calendar SelectedDate="_dateOnly" SelectedDateChanged="OnBasicDateChanged" />
                        </PopoverContent>
                    </Popover>
                    <Div Class="value-chip" Margin="Margin.Is0">
                        <Span Class="dot"></Span><Span>Value: @_dateOnly?.ToString("yyyy-MM-dd")</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Range Picker"
                         Description="Use a range calendar inside the popover when users need a start and end date from the same picker."
                         Code="@(@"<Popover Open=""_rangeCalendarOpen"" OpenChanged=""OnRangeCalendarOpenChanged"">
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"">@FormatRange(_rangeDate)</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"">
        <Calendar Mode=""CalendarSelectionMode.Range"" SelectedRange=""_rangeDate"" SelectedRangeChanged=""OnRangeDateChanged"" NumberOfMonths=""2"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Class="flex min-h-[16rem] w-full max-w-sm flex-col items-center justify-center gap-4 text-center">
                    <Label Form="true">Pick a date range</Label>
                    <Popover Open="_rangeCalendarOpen" OpenChanged="OnRangeCalendarOpenChanged">
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline" Class="w-[280px] justify-start text-left font-normal">@FormatRange(_rangeDate)</Button>
                        </PopoverTrigger>
                        <PopoverContent Class="w-auto p-0">
                            <Calendar Mode="CalendarSelectionMode.Range"
                                      SelectedRange="_rangeDate"
                                      SelectedRangeChanged="OnRangeDateChanged"
                                      NumberOfMonths="2" />
                        </PopoverContent>
                    </Popover>
                    <Div Class="value-chip" Margin="Margin.Is0">
                        <Span Class="dot"></Span><Span>Value: @FormatRange(_rangeDate)</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Dropdowns"
                         Description="Use the calendar caption dropdown layout when users need direct month and year selection."
                         Code="@(@"<Popover Open=""_dropdownPickerOpen"" OpenChanged=""OnDropdownPickerOpenChanged"">
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"">@FormatDate(_dropdownPickerDate)</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"">
        <Calendar SelectedDate=""_dropdownPickerDate"" SelectedDateChanged=""OnDropdownPickerDateChanged"" CaptionLayout=""dropdown"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Class="flex min-h-[16rem] w-full max-w-sm flex-col items-center justify-center gap-4 text-center">
                    <Label Form="true">Pick a date with dropdowns</Label>
                    <Popover Open="_dropdownPickerOpen" OpenChanged="OnDropdownPickerOpenChanged">
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline" Class="w-[240px] justify-start text-left font-normal">@FormatDate(_dropdownPickerDate)</Button>
                        </PopoverTrigger>
                        <PopoverContent Class="w-auto p-0">
                            <Calendar SelectedDate="_dropdownPickerDate"
                                      SelectedDateChanged="OnDropdownPickerDateChanged"
                                      CaptionLayout="dropdown" />
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Date of Birth"
                         Description="A bounded `Calendar` keeps date-of-birth selection limited to an allowed historical range."
                         Code="@(@"<Popover Open=""_birthdayCalendarOpen"" OpenChanged=""OnBirthdayCalendarOpenChanged"">
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"">@FormatDate(_deliveryDate)</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"">
        <Calendar SelectedDate=""_deliveryDate"" SelectedDateChanged=""OnBirthdayDateChanged"" Min=""_minDate"" Max=""_maxDate"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Class="flex min-h-[16rem] w-full max-w-sm flex-col items-center justify-center gap-4 text-center">
                    <Label Form="true">Date of birth</Label>
                    <Popover Open="_birthdayCalendarOpen" OpenChanged="OnBirthdayCalendarOpenChanged">
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline" Class="w-[240px] justify-start text-left font-normal">@FormatDate(_deliveryDate)</Button>
                        </PopoverTrigger>
                        <PopoverContent Class="w-auto p-0">
                            <Calendar SelectedDate="_deliveryDate"
                                      SelectedDateChanged="OnBirthdayDateChanged"
                                      Min="_minDate"
                                      Max="_maxDate" />
                        </PopoverContent>
                    </Popover>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Choose a date between @_minDate.ToString("yyyy-MM-dd") and @_maxDate.ToString("yyyy-MM-dd")
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input"
                         Description="Use `AsChild` on `PopoverTrigger` when the trigger should look like an input instead of a button."
                         Code="@(@"<Popover Open=""_inputCalendarOpen"" OpenChanged=""OnInputCalendarOpenChanged"">
    <PopoverTrigger AsChild=""true"">
        <input readonly value=""@FormatDate(_typedDate)"" />
    </PopoverTrigger>
    <PopoverContent Class=""w-auto p-0"">
        <Calendar SelectedDate=""_typedDate"" SelectedDateChanged=""OnTypedDateChanged"" />
    </PopoverContent>
</Popover>")"
CodeLanguage="razor">
                <Div Class="flex min-h-[16rem] w-full max-w-sm flex-col items-center justify-center gap-4 text-center">
                    <Label Form="true">Type a date</Label>
                    <Popover Open="_inputCalendarOpen" OpenChanged="OnInputCalendarOpenChanged">
                        <PopoverTrigger AsChild="true">
                            <input readonly
                                   value="@FormatDate(_typedDate)"
                                   placeholder="Pick a date"
                                   class="flex h-10 w-[240px] rounded-md border border-input bg-background px-3 py-2 text-sm shadow-xs cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2" />
                        </PopoverTrigger>
                        <PopoverContent Class="w-auto p-0">
                            <Calendar SelectedDate="_typedDate" SelectedDateChanged="OnTypedDateChanged" />
                        </PopoverContent>
                    </Popover>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        The trigger is input-shaped, but the selection still happens through the reusable calendar primitive.
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Date and time"
                         Description="DateTimePicker adds time selection when the exact moment matters."
                         Code="@(@"<Label Form=""true"">Pick a date and time</Label>
<DateTimePicker @bind-SelectedDateTime=""_dateTime""/>")"
CodeLanguage="razor">
                <Div Class="flex min-h-[16rem] w-full max-w-sm flex-col items-center justify-center gap-4 text-center">
                    <Label Form="true">Pick a date and time</Label>
                    <DateTimePicker @bind-SelectedDateTime="_dateTime"/>
                    <Div Class="value-chip" Margin="Margin.Is0">
                        <Span Class="dot"></Span><Span>Value: @_dateTime?.ToString("yyyy-MM-dd HH:mm:ss")</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scheduled window"
                         Description="Combine date and time with min/max bounds for scheduling flows."
                         Code="@(@"<DateTimePicker @bind-SelectedDateTime=""_deploymentWindow"" Min=""_minDateTime"" Max=""_maxDateTime"" />")"
                         CodeLanguage="razor">
                <Div Class="flex min-h-[16rem] w-full max-w-sm flex-col items-center justify-center gap-4 text-center">
                    <Label Form="true">Deployment window</Label>
                    <DateTimePicker @bind-SelectedDateTime="_deploymentWindow" Min="_minDateTime" Max="_maxDateTime"/>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Available between @_minDateTime.ToString("MMM dd, yyyy HH:mm") and @_maxDateTime.ToString("MMM dd, yyyy HH:mm")
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code{

    private DateOnly? _dateOnly = DateOnly.FromDateTime(DateTime.Today);
    private readonly DateOnly _minDate = new(1940, 1, 1);
    private readonly DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _deliveryDate = new(1995, 7, 14);
    private DateOnly? _typedDate = DateOnly.FromDateTime(DateTime.Today.AddDays(7));
    private DateOnly? _dropdownPickerDate = DateOnly.FromDateTime(DateTime.Today.AddDays(21));
    private bool _basicCalendarOpen;
    private bool _dropdownPickerOpen;
    private bool _rangeCalendarOpen;
    private bool _birthdayCalendarOpen;
    private bool _inputCalendarOpen;
    private CalendarDateRange? _rangeDate = new(DateOnly.FromDateTime(DateTime.Today), DateOnly.FromDateTime(DateTime.Today.AddDays(4)));

    private DateTime? _dateTime = DateTime.Now;
    private readonly DateTime _minDateTime = DateTime.Today.AddHours(9);
    private readonly DateTime _maxDateTime = DateTime.Today.AddDays(7).AddHours(18);
    private DateTime? _deploymentWindow = DateTime.Today.AddDays(1).AddHours(14);

    private static string FormatDate(DateOnly? value)
    {
        return value?.ToString("MMM dd, yyyy") ?? "Pick a date";
    }

    private Task OnBasicCalendarOpenChanged(bool value)
    {
        _basicCalendarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnBirthdayCalendarOpenChanged(bool value)
    {
        _birthdayCalendarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnDropdownPickerOpenChanged(bool value)
    {
        _dropdownPickerOpen = value;
        return Task.CompletedTask;
    }

    private Task OnRangeCalendarOpenChanged(bool value)
    {
        _rangeCalendarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnInputCalendarOpenChanged(bool value)
    {
        _inputCalendarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnBasicDateChanged(DateOnly? value)
    {
        _dateOnly = value;
        _basicCalendarOpen = false;
        return Task.CompletedTask;
    }

    private Task OnBirthdayDateChanged(DateOnly? value)
    {
        _deliveryDate = value;
        _birthdayCalendarOpen = false;
        return Task.CompletedTask;
    }

    private Task OnDropdownPickerDateChanged(DateOnly? value)
    {
        _dropdownPickerDate = value;
        _dropdownPickerOpen = false;
        return Task.CompletedTask;
    }

    private Task OnRangeDateChanged(CalendarDateRange? value)
    {
        _rangeDate = value;

        if (value?.From is not null && value.To is not null)
            _rangeCalendarOpen = false;

        return Task.CompletedTask;
    }

    private Task OnTypedDateChanged(DateOnly? value)
    {
        _typedDate = value;
        _inputCalendarOpen = false;
        return Task.CompletedTask;
    }

    private static string FormatRange(CalendarDateRange? value)
    {
        if (value?.From is null)
            return "Pick a date range";

        if (value.To is null)
            return value.From.Value.ToString("MMM dd, yyyy");

        return $"{value.From.Value:MMM dd, yyyy} - {value.To.Value:MMM dd, yyyy}";
    }

}
