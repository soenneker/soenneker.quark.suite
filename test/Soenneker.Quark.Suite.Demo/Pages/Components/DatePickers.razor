@page "/datepickers"
@using System.Globalization

<PageTitle>Date Pickers - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="A date picker component with range and presets."
                         Code="@BasicDatePickerCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex min-h-[350px] w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0">
                @DatePickerOverviewExample
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A basic date picker component."
                         Code="@BasicDatePickerCode"
                         CodeLanguage="razor">
                @DatePickerBasicExample
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Range Picker"
                         Description="A date picker component for selecting a range of dates."
                         Code="@RangePickerCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Div Display="Display.Grid" Gap="Gap.Is2">
                        <FieldLabel For="date-picker-range">Date Picker Range</FieldLabel>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Id="date-picker-range"
                                        Variant="ButtonVariant.Outline"
                                        Class="@DateRangeButtonClass(_rangeDate?.From is not null)">
                                    <Icon Name="LucideIcon.Calendar" Class="size-4" />
                                    @FormatRange(_rangeDate)
                                </Button>
                            </PopoverTrigger>
                            <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                                <Calendar Mode="CalendarSelectionMode.Range"
                                          SelectedRange="_rangeDate"
                                          SelectedRangeChanged="OnRangeDateChanged"
                                          NumberOfMonths="2" />
                            </PopoverContent>
                        </Popover>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Date of Birth"
                         Description="A date picker component for selecting a date of birth. This component includes a dropdown caption layout for date and month selection."
                         Code="@DateOfBirthCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Div Display="Display.Grid" Gap="Gap.Is2">
                        <FieldLabel For="date">Date of birth</FieldLabel>
                        <Popover Open="_dobOpen" OpenChanged="OnDobOpenChanged">
                            <PopoverTrigger AsChild="true">
                                <Button Id="date"
                                        Variant="ButtonVariant.Outline"
                                        Class="@DatePlainButtonClass(_dobDate is not null, "w-[176px]")">
                                    @(_dobDate is null ? "Select date" : FormatDate(_dobDate))
                                </Button>
                            </PopoverTrigger>
                            <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                                <Calendar SelectedDate="_dobDate"
                                          SelectedDateChanged="OnDobDateChanged"
                                          CaptionLayout="dropdown"
                                          Min="_dobMinDate"
                                          Max="_dobMaxDate" />
                            </PopoverContent>
                        </Popover>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input"
                         Description="A date picker component with an input field for selecting a date."
                         Code="@InputPickerCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Div Display="Display.Grid" Gap="Gap.Is2">
                        <FieldLabel For="date-required">Subscription Date</FieldLabel>
                        <Popover Open="_subscriptionOpen" OpenChanged="OnSubscriptionOpenChanged">
                            <Div Class="w-[192px]">
                                <InputGroup>
                                    <InputGroupInput Id="date-required"
                                                     Placeholder="June 01, 2025"
                                                     @bind-Value="_subscriptionDateText" />
                                    <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                                        <PopoverTrigger AsChild="true">
                                            <InputGroupButton Id="date-picker" Size="ButtonSize.IconXs" aria-label="Select date">
                                                <Icon Name="LucideIcon.Calendar" />
                                                <Span Class="sr-only">Select date</Span>
                                            </InputGroupButton>
                                        </PopoverTrigger>
                                    </InputGroupAddon>
                                </InputGroup>
                            </Div>
                            <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                                <Calendar SelectedDate="_subscriptionDate" SelectedDateChanged="OnSubscriptionDateChanged" />
                            </PopoverContent>
                        </Popover>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Time Picker"
                         Description="A date picker component with a time input field for selecting a time."
                         Code="@TimePickerCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Div Display="Display.Flex" Gap="Gap.Is4" AlignItems="AlignItems.End">
                        <Div Display="Display.Grid" Gap="Gap.Is2">
                            <FieldLabel For="date-picker-optional">Date</FieldLabel>
                            <Popover Open="_timePickerOpen" OpenChanged="OnTimePickerOpenChanged">
                                <PopoverTrigger AsChild="true">
                                    <Button Id="date-picker-optional"
                                            Variant="ButtonVariant.Outline"
                                            Class="@DateButtonClass(_timePickerDate is not null, "w-32")">
                                        @(_timePickerDate is null ? "Select date" : FormatDate(_timePickerDate))
                                        <Icon Name="LucideIcon.ChevronDown" Class="ml-auto size-4 opacity-50" />
                                    </Button>
                                </PopoverTrigger>
                                <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                                    <Calendar SelectedDate="_timePickerDate" SelectedDateChanged="OnTimePickerDateChanged" />
                                </PopoverContent>
                            </Popover>
                        </Div>
                        <Div Display="Display.Grid" Gap="Gap.Is2">
                            <FieldLabel For="time-picker-optional">Time</FieldLabel>
                            <Div Class="w-[116px]">
                                <TextInput Id="time-picker-optional" Type="time" Step="1" Class="appearance-none bg-background [&::-webkit-calendar-picker-indicator]:hidden [&::-webkit-calendar-picker-indicator]:appearance-none" @bind-Value="_timeText" />
                            </Div>
                        </Div>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Natural Language Picker"
                         Description="This component uses native C# parsing for common relative date phrases."
                         Code="@NaturalLanguagePickerCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Div Display="Display.Grid" Gap="Gap.Is2" Class="w-[320px]">
                        <FieldLabel For="date-optional">Schedule Date</FieldLabel>
                        <Popover Open="_naturalLanguageOpen" OpenChanged="OnNaturalLanguageOpenChanged">
                            <InputGroup>
                                <InputGroupInput Id="date-optional"
                                                 Placeholder="Tomorrow or next week"
                                                 Value="@_naturalLanguageText"
                                                 ValueChanged="OnNaturalLanguageTextChanged" />
                                <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                                    <PopoverTrigger AsChild="true">
                                        <InputGroupButton Id="date-picker" Size="ButtonSize.IconXs" aria-label="Select date">
                                            <Icon Name="LucideIcon.Calendar" />
                                            <Span Class="sr-only">Select date</Span>
                                        </InputGroupButton>
                                    </PopoverTrigger>
                                </InputGroupAddon>
                            </InputGroup>
                            <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                                <Calendar SelectedDate="NaturalLanguageDate"
                                          SelectedDateChanged="OnNaturalLanguageDateChanged" />
                            </PopoverContent>
                        </Popover>
                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                            Your post will be published on @NaturalLanguageDate.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture).
                        </Paragraph>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Use the document direction to mirror the date picker trigger and calendar surface."
                         Code="@RtlDatePickerCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Div Dir="rtl" Display="Display.Grid" Class="w-fit gap-6">
                        <Div Display="Display.Flex" AlignItems="AlignItems.Center" Gap="Gap.Is2" dir="ltr">
                            <Select TValue="string" Size="SelectSizes.Sm" SelectedValue="@_rtlLocale" SelectedValueChanged="OnRtlLocaleChanged">
                                <SelectTrigger Class="w-36" dir="ltr">
                                    <SelectValue />
                                </SelectTrigger>
                                <SelectContent Class="data-[state=open]:animate-none data-[state=closed]:animate-none" dir="ltr">
                                    <SelectGroup>
                                        <SelectItem TValue="string" ItemValue="@("ar")" Text="Arabic (العربية)" />
                                        <SelectItem TValue="string" ItemValue="@("he")" Text="Hebrew (עברית)" />
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconSm" Class="ml-auto size-7" OnClick="ToggleRtlDate">
                                <Icon Name="LucideIcon.Languages" />
                                <Span Class="sr-only">Toggle</Span>
                            </Button>
                        </Div>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline" Class="@DateButtonClass(_rtlDate is not null, "w-[212px]")">
                                    @FormatRtlDate()
                                    <Icon Name="LucideIcon.ChevronDown" Class="mr-auto size-4 opacity-50" />
                                </Button>
                            </PopoverTrigger>
                            <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                                <Calendar SelectedDate="_rtlDate" SelectedDateChanged="OnRtlDateChanged" />
                            </PopoverContent>
                        </Popover>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private DateOnly? _overviewDate;
    private DateOnly? _basicDate;
    private CalendarDateRange? _rangeDate = new(new DateOnly(2026, 1, 20), new DateOnly(2026, 2, 9));
    private DateOnly? _dobDate;
    private bool _dobOpen;
    private readonly DateOnly _dobMinDate = new(1900, 1, 1);
    private readonly DateOnly _dobMaxDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _subscriptionDate = new(2025, 5, 31);
    private string? _subscriptionDateText = "May 31, 2025";
    private bool _subscriptionOpen;
    private DateOnly? _timePickerDate;
    private bool _timePickerOpen;
    private string? _timeText = "10:30:00";
    private DateOnly? _naturalLanguageDate = DateOnly.FromDateTime(DateTime.Today.AddDays(2));
    private string? _naturalLanguageText = "In 2 days";
    private bool _naturalLanguageOpen;
    private DateOnly? _rtlDate;
    private string? _rtlLocale = "ar";

    private RenderFragment DatePickerOverviewExample => @<Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
        <Popover>
            <PopoverTrigger AsChild="true">
                <Button Variant="ButtonVariant.Outline"
                        Class="@DateButtonClass(_overviewDate is not null, "w-[212px]")">
                    @FormatDate(_overviewDate)
                    <Icon Name="LucideIcon.ChevronDown" Class="ml-auto size-4 opacity-50" />
                </Button>
            </PopoverTrigger>
            <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                <Calendar SelectedDate="_overviewDate" SelectedDateChanged="OnOverviewDateChanged" />
            </PopoverContent>
        </Popover>
    </Div>;

    private RenderFragment DatePickerBasicExample => @<Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
        <Div Display="Display.Grid" Gap="Gap.Is2">
            <FieldLabel For="date-picker-simple">Date</FieldLabel>
            <Popover>
                <PopoverTrigger AsChild="true">
                    <Button Id="date-picker-simple"
                            Variant="ButtonVariant.Outline"
                            Class="@DatePlainButtonClass(_basicDate is not null, "w-[176px]")">
                        @FormatDate(_basicDate)
                        <Icon Name="LucideIcon.ChevronDown" Class="ml-auto size-4 opacity-50" />
                    </Button>
                </PopoverTrigger>
                <PopoverContent Width="Width.Auto" Padding="Padding.Is0" Align="Alignment.Start">
                    <Calendar SelectedDate="_basicDate" SelectedDateChanged="OnBasicDateChanged" />
                </PopoverContent>
            </Popover>
        </Div>
    </Div>;

    private static string DateButtonClass(bool hasValue, string width)
    {
        var muted = hasValue ? string.Empty : " text-muted-foreground";
        return $"{width} justify-between text-left font-normal{muted}";
    }

    private static string DatePlainButtonClass(bool hasValue, string width)
    {
        var muted = hasValue ? string.Empty : " text-muted-foreground";
        return $"{width} justify-start text-left font-normal{muted}";
    }

    private static string DateRangeButtonClass(bool hasValue)
    {
        var muted = hasValue ? string.Empty : " text-muted-foreground";
        return $"w-[240px] justify-start text-left font-normal{muted}";
    }

    private static string FormatDate(DateOnly? value)
    {
        if (value is null)
            return "Pick a date";

        var day = value.Value.Day;

        return value.Value.ToString("MMM ", CultureInfo.InvariantCulture) + day.ToString(CultureInfo.InvariantCulture) + GetOrdinalSuffix(day) + value.Value.ToString(", yyyy", CultureInfo.InvariantCulture);
    }

    private static string GetOrdinalSuffix(int day)
    {
        var lastTwo = day % 100;
        if (lastTwo >= 11 && lastTwo <= 13)
            return "th";

        var last = day % 10;
        if (last == 1)
            return "st";
        if (last == 2)
            return "nd";
        if (last == 3)
            return "rd";

        return "th";
    }

    private static string FormatRange(CalendarDateRange? value)
    {
        if (value?.From is null)
            return "Pick a date range";

        if (value.To is null)
            return value.From.Value.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);

        return $"{value.From.Value:MMM dd, yyyy} - {value.To.Value:MMM dd, yyyy}";
    }

    private DateOnly NaturalLanguageDate => _naturalLanguageDate ?? DateOnly.FromDateTime(DateTime.Today.AddDays(2));

    private string FormatRtlDate()
    {
        if (_rtlDate is null)
            return _rtlLocale == "he" ? "בחר תאריך" : "اختر تاريخًا";

        var culture = new CultureInfo(_rtlLocale == "he" ? "he-IL" : "ar-SA");
        return _rtlDate.Value.ToString("dd MMMM yyyy", culture);
    }

    private Task OnOverviewDateChanged(DateOnly? value)
    {
        _overviewDate = value;
        return Task.CompletedTask;
    }

    private Task OnBasicDateChanged(DateOnly? value)
    {
        _basicDate = value;
        return Task.CompletedTask;
    }

    private Task OnRangeDateChanged(CalendarDateRange? value)
    {
        _rangeDate = value;
        return Task.CompletedTask;
    }

    private Task OnDobOpenChanged(bool value)
    {
        _dobOpen = value;
        return Task.CompletedTask;
    }

    private Task OnDobDateChanged(DateOnly? value)
    {
        _dobDate = value;
        _dobOpen = false;
        return Task.CompletedTask;
    }

    private Task OnSubscriptionOpenChanged(bool value)
    {
        _subscriptionOpen = value;
        return Task.CompletedTask;
    }

    private Task OnSubscriptionDateChanged(DateOnly? value)
    {
        _subscriptionDate = value;
        _subscriptionDateText = value?.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);
        _subscriptionOpen = false;
        return Task.CompletedTask;
    }

    private Task OnTimePickerOpenChanged(bool value)
    {
        _timePickerOpen = value;
        return Task.CompletedTask;
    }

    private Task OnTimePickerDateChanged(DateOnly? value)
    {
        _timePickerDate = value;
        _timePickerOpen = false;
        return Task.CompletedTask;
    }

    private Task OnNaturalLanguageOpenChanged(bool value)
    {
        _naturalLanguageOpen = value;
        return Task.CompletedTask;
    }

    private Task OnNaturalLanguageTextChanged(string? value)
    {
        _naturalLanguageText = value;
        _naturalLanguageDate = ParseNaturalLanguageDate(value);
        return Task.CompletedTask;
    }

    private Task OnNaturalLanguageDateChanged(DateOnly? value)
    {
        _naturalLanguageDate = value;
        _naturalLanguageText = value?.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);
        _naturalLanguageOpen = false;
        return Task.CompletedTask;
    }

    private Task OnRtlDateChanged(DateOnly? value)
    {
        _rtlDate = value;
        return Task.CompletedTask;
    }

    private Task OnRtlLocaleChanged(string? value)
    {
        _rtlLocale = value;
        return Task.CompletedTask;
    }

    private Task ToggleRtlDate()
    {
        _rtlDate = _rtlDate is null ? DateOnly.FromDateTime(DateTime.Today.AddDays(2)) : null;
        return Task.CompletedTask;
    }

    private static DateOnly? ParseNaturalLanguageDate(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var text = value.Trim().ToLowerInvariant();
        var today = DateOnly.FromDateTime(DateTime.Today);

        if (text is "today")
            return today;

        if (text is "tomorrow")
            return today.AddDays(1);

        if (text is "next week")
            return today.AddDays(7);

        if (text.StartsWith("in ", StringComparison.Ordinal) && text.EndsWith(" days", StringComparison.Ordinal))
        {
            var numberText = text[3..^5].Trim();
            if (int.TryParse(numberText, CultureInfo.InvariantCulture, out var days))
                return today.AddDays(days);
        }

        if (DateOnly.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.None, out var parsed))
            return parsed;

        return null;
    }

    private const string BasicDatePickerCode =
@"<FieldLabel For=""date-picker-simple"">Date</FieldLabel>
<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Id=""date-picker-simple"" Variant=""ButtonVariant.Outline"" Class=""w-[176px] justify-start text-left font-normal"">
            @FormatDate(_dateOnly)
            <Icon Name=""LucideIcon.ChevronDown"" Class=""ml-auto size-4 opacity-50"" />
        </Button>
    </PopoverTrigger>
    <PopoverContent Width=""Width.Auto"" Padding=""Padding.Is0"" Align=""Alignment.Start"">
        <Calendar SelectedDate=""_dateOnly"" SelectedDateChanged=""OnBasicDateChanged"" />
    </PopoverContent>
</Popover>";

    private const string RangePickerCode =
@"<FieldLabel For=""date-picker-range"">Date Picker Range</FieldLabel>
<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Id=""date-picker-range"" Variant=""ButtonVariant.Outline"" Class=""w-[240px] justify-start text-left font-normal"">
            <Icon Name=""LucideIcon.Calendar"" Class=""size-4"" />
            @FormatRange(_rangeDate)
        </Button>
    </PopoverTrigger>
    <PopoverContent Width=""Width.Auto"" Padding=""Padding.Is0"" Align=""Alignment.Start"">
        <Calendar Mode=""CalendarSelectionMode.Range"" SelectedRange=""_rangeDate"" SelectedRangeChanged=""OnRangeDateChanged"" NumberOfMonths=""2"" />
    </PopoverContent>
</Popover>";

    private const string DateOfBirthCode =
@"<FieldLabel For=""date"">Date of birth</FieldLabel>
<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Id=""date"" Variant=""ButtonVariant.Outline"" Class=""w-[176px] justify-start text-left font-normal"">
            Select date
        </Button>
    </PopoverTrigger>
    <PopoverContent Width=""Width.Auto"" Padding=""Padding.Is0"" Align=""Alignment.Start"">
        <Calendar CaptionLayout=""dropdown"" Min=""_dobMinDate"" Max=""_dobMaxDate"" />
    </PopoverContent>
</Popover>";

    private const string InputPickerCode =
@"<FieldLabel For=""date-required"">Subscription Date</FieldLabel>
<Popover>
    <Div Class=""w-[192px]"">
        <InputGroup>
            <InputGroupInput Id=""date-required"" Placeholder=""June 01, 2025"" @bind-Value=""_subscriptionDateText"" />
            <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
                <PopoverTrigger AsChild=""true"">
                    <InputGroupButton Id=""date-picker"" Size=""ButtonSize.IconXs"" aria-label=""Select date"">
                        <Icon Name=""LucideIcon.Calendar"" />
                        <Span Class=""sr-only"">Select date</Span>
                    </InputGroupButton>
                </PopoverTrigger>
            </InputGroupAddon>
        </InputGroup>
    </Div>
    <PopoverContent Width=""Width.Auto"" Padding=""Padding.Is0"" Align=""Alignment.Start"">
        <Calendar SelectedDate=""_subscriptionDate"" SelectedDateChanged=""OnSubscriptionDateChanged"" />
    </PopoverContent>
</Popover>";

    private const string TimePickerCode =
@"<Div Display=""Display.Flex"" Gap=""Gap.Is4"" AlignItems=""AlignItems.End"">
    <Div Display=""Display.Grid"" Gap=""Gap.Is2"">
        <FieldLabel For=""date-picker-optional"">Date</FieldLabel>
        <Popover>
            <PopoverTrigger AsChild=""true"">
                <Button Id=""date-picker-optional"" Variant=""ButtonVariant.Outline"" Class=""w-32 justify-between text-left font-normal"">Select date</Button>
            </PopoverTrigger>
            <PopoverContent Width=""Width.Auto"" Padding=""Padding.Is0"" Align=""Alignment.Start"">
                <Calendar SelectedDate=""_timePickerDate"" SelectedDateChanged=""OnTimePickerDateChanged"" />
            </PopoverContent>
        </Popover>
    </Div>
    <Div Display=""Display.Grid"" Gap=""Gap.Is2"">
        <FieldLabel For=""time-picker-optional"">Time</FieldLabel>
        <Div Class=""w-[116px]"">
            <TextInput Id=""time-picker-optional"" Type=""time"" Step=""1"" Class=""appearance-none bg-background [&::-webkit-calendar-picker-indicator]:hidden [&::-webkit-calendar-picker-indicator]:appearance-none"" @bind-Value=""_timeText"" />
        </Div>
    </Div>
</Div>";

    private const string NaturalLanguagePickerCode =
@"<FieldLabel For=""date-optional"">Schedule Date</FieldLabel>
<InputGroup>
    <InputGroupInput Id=""date-optional"" Placeholder=""Tomorrow or next week"" Value=""In 2 days"" />
    <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd"">
        <PopoverTrigger AsChild=""true"">
            <InputGroupButton Id=""date-picker"" Size=""ButtonSize.IconXs"" aria-label=""Select date"">
                <Icon Name=""LucideIcon.Calendar"" />
                <Span Class=""sr-only"">Select date</Span>
            </InputGroupButton>
        </PopoverTrigger>
    </InputGroupAddon>
</InputGroup>";

    private const string RtlDatePickerCode =
@"<Div Dir=""rtl"">
    <Select TValue=""string"" Size=""SelectSizes.Sm"" SelectedValue=""ar"">
        <SelectTrigger Class=""w-36"" dir=""ltr""><SelectValue /></SelectTrigger>
        <SelectContent dir=""ltr""><SelectItem TValue=""string"" ItemValue=""@(""ar"")"" Text=""Arabic (العربية)"" /></SelectContent>
    </Select>
    <Button Variant=""ButtonVariant.Ghost"" Size=""ButtonSize.IconSm"" Class=""ml-auto size-7""><Icon Name=""LucideIcon.Languages"" /><Span Class=""sr-only"">Toggle</Span></Button>
    <Popover>
        <PopoverTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">اختر تاريخًا</Button>
        </PopoverTrigger>
        <PopoverContent Width=""Width.Auto"" Padding=""Padding.Is0"">
            <Calendar SelectedDate=""_rtlDate"" SelectedDateChanged=""OnRtlDateChanged"" />
        </PopoverContent>
    </Popover>
</Div>";
}
