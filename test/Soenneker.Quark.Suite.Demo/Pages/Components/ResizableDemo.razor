@page "/resizable"

<PageTitle>Resizable - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Horizontal panels"
                         Description="Adapted from the shadcn resizable demo with two side-by-side panels and a visible handle."
                         Code="@ResizableCode">
                <Div Class="max-w-3xl">
                    <ResizablePanelGroup Orientation="horizontal" Class="min-h-[220px] rounded-xl border">
                        <ResizablePanel DefaultSize="1">
                            <Div Class="flex h-full items-center justify-center bg-card p-6">
                                <Span Class="font-semibold">One</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle WithHandle="true" />

                        <ResizablePanel DefaultSize="1">
                            <Div Class="flex h-full items-center justify-center bg-muted/30 p-6">
                                <Span Class="font-semibold">Two</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Nested vertical layout"
                         Description="Nest a vertical group inside a panel to mirror the stacked layout from shadcn's example.">
                <Div Class="max-w-4xl">
                    <ResizablePanelGroup Orientation="horizontal" Class="min-h-[260px] rounded-xl border">
                        <ResizablePanel DefaultSize="1">
                            <Div Class="flex h-full items-center justify-center bg-card p-6">
                                <Span Class="font-semibold">Overview</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle WithHandle="true" />

                        <ResizablePanel DefaultSize="2">
                            <ResizablePanelGroup Orientation="vertical" Class="h-full">
                                <ResizablePanel DefaultSize="1">
                                    <Div Class="flex h-full items-center justify-center bg-muted/20 p-6">
                                        <Span Class="font-semibold">Activity</Span>
                                    </Div>
                                </ResizablePanel>

                                <ResizableHandle WithHandle="true" />

                                <ResizablePanel DefaultSize="2">
                                    <Div Class="flex h-full items-center justify-center bg-muted/40 p-6">
                                        <Span Class="font-semibold">Details</Span>
                                    </Div>
                                </ResizablePanel>
                            </ResizablePanelGroup>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string ResizableCode =
@"<ResizablePanelGroup Orientation=""horizontal"">
    <ResizablePanel>One</ResizablePanel>
    <ResizableHandle WithHandle=""true"" />
    <ResizablePanel>Two</ResizablePanel>
</ResizablePanelGroup>";
}
