@page "/resizable"

<PageTitle>Resizable - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Handle"
                         Description="Adapted from the shadcn resizable demo with two side-by-side panels and a visible handle."
                         Code="@ResizableCode">
                <Div Class="max-w-3xl">
                    <ResizablePanelGroup Orientation="horizontal" Class="min-h-[220px] rounded-xl border">
                        <ResizablePanel DefaultSize="1">
                            <Div Class="flex h-full items-center justify-center bg-card p-6">
                                <Span FontWeight="FontWeight.Semibold">One</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle WithHandle="true" />

                        <ResizablePanel DefaultSize="1">
                            <Div Class="flex h-full items-center justify-center bg-muted/30 p-6">
                                <Span FontWeight="FontWeight.Semibold">Two</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="A vertical panel group mirrors the stacked resizable layout from the shadcn docs."
                         Code="@(@"<ResizablePanelGroup Orientation=""vertical"">
    <ResizablePanel>Top</ResizablePanel>
    <ResizableHandle WithHandle=""true"" />
    <ResizablePanel>Bottom</ResizablePanel>
</ResizablePanelGroup>")">
                <Div Class="max-w-3xl">
                    <ResizablePanelGroup Orientation="vertical" Class="min-h-[260px] rounded-xl border">
                        <ResizablePanel DefaultSize="1">
                            <Div Class="flex h-full items-center justify-center bg-card p-6">
                                <Span FontWeight="FontWeight.Semibold">Activity</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle WithHandle="true" />

                        <ResizablePanel DefaultSize="2">
                            <Div Class="flex h-full items-center justify-center bg-muted/30 p-6">
                                <Span FontWeight="FontWeight.Semibold">Details</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string ResizableCode =
@"<ResizablePanelGroup Orientation=""horizontal"">
    <ResizablePanel>One</ResizablePanel>
    <ResizableHandle WithHandle=""true"" />
    <ResizablePanel>Two</ResizablePanel>
</ResizablePanelGroup>";
}
