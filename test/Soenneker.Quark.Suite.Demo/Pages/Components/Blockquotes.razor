@page "/blockquotes"

<PageTitle>Blockquotes - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
        <DemoSection Title="Demo" Code="@(@"<Blockquote Border=""Border.Is4.FromLeft"" BorderColor=""BorderColor.Primary"" Padding=""Padding.Is4.FromStart"" FontStyle=""FontStyle.Italic"">
    <Paragraph>The only way to do great work is to love what you do.</Paragraph>
</Blockquote>")"
CodeLanguage="razor">
            <Blockquote Border="Border.Is4.FromLeft" BorderColor="BorderColor.Primary" Padding="Padding.Is4.FromStart" FontStyle="FontStyle.Italic">
                <Paragraph>The only way to do great work is to love what you do.</Paragraph>
            </Blockquote>
        </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
        <DemoSection Title="With footer" Description="Add a footer element for attribution." Code="@(@"<Blockquote Border=""Border.Is4.FromLeft"" BorderColor=""BorderColor.Primary"" Padding=""Padding.Is4.FromStart"">
    <Paragraph Margin=""Margin.Is0.FromBottom"">Stay hungry. Stay foolish.</Paragraph>
    <footer class=""mt-2 text-sm text-muted-foreground"">Steve Jobs — Stanford Commencement 2005</footer>
</Blockquote>")"
CodeLanguage="razor">
            <Blockquote Border="Border.Is4.FromLeft" BorderColor="BorderColor.Primary" Padding="Padding.Is4.FromStart">
                <Paragraph Margin="Margin.Is0.FromBottom">Stay hungry. Stay foolish.</Paragraph>
                <footer Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Steve Jobs — Stanford Commencement 2005</footer>
            </Blockquote>
        </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
        <DemoSection Title="Styled" Description="Use border, background, and padding for card-style blockquotes." Code="@(@"<Blockquote Rounded=""Rounded.Lg"" Border=""Border.Is4.FromLeft"" BorderColor=""BorderColor.Primary"" BackgroundColor='BackgroundColor.Token(""primary/10"")' Padding=""Padding.Is4"">
    <Paragraph Margin=""Margin.Is0.FromBottom"" TextColor=""TextColor.Primary"">Success is not final, failure is not fatal.</Paragraph>
    <footer class=""mt-2 text-sm text-muted-foreground"">Winston Churchill</footer>
</Blockquote>
<Blockquote Rounded=""Rounded.Lg"" Border=""Border.Is4.FromLeft"" BorderColor='BorderColor.Token(""green-500"")' BackgroundColor='BackgroundColor.Token(""green-500/10"")' Padding=""Padding.Is4"">
    <Paragraph Margin=""Margin.Is0.FromBottom"" TextColor=""TextColor.Accent"">The best time to plant a tree was 20 years ago.</Paragraph>
    <footer class=""mt-2 text-sm text-muted-foreground"">Chinese Proverb</footer>
</Blockquote>")"
CodeLanguage="razor">
            <Div Display="Display.Grid" Gap='Gap.Token("6")' Class="md:grid-cols-2">
            <Blockquote Rounded="Rounded.Lg" Border="Border.Is4.FromLeft" BorderColor="BorderColor.Primary" BackgroundColor='BackgroundColor.Token("primary/10")' Padding="Padding.Is4">
                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Primary">Success is not final, failure is not fatal.</Paragraph>
                <footer Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Winston Churchill</footer>
            </Blockquote>
            <Blockquote Rounded="Rounded.Lg" Border='Border.Is4.FromLeft' BorderColor='BorderColor.Token("green-500")' BackgroundColor='BackgroundColor.Token("green-500/10")' Padding="Padding.Is4">
                <Paragraph Margin="Margin.Is0.FromBottom" TextColor="TextColor.Accent">The best time to plant a tree was 20 years ago.</Paragraph>
                <footer Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Chinese Proverb</footer>
            </Blockquote>
            </Div>
        </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
        <DemoSection Title="Testimonial" Description="Full-width gradient blockquote for testimonials." Code="@(@"<Blockquote Rounded=""Rounded.Xl"" Padding=""Padding.Is6"" TextAlign=""TextAlign.Center"" TextColor=""TextColor.White"" Class=""bg-gradient-to-br from-violet-500 to-purple-700"">
    <Lucide Name=""LucideIcon.Quote"" TextColor=""TextColor.White"" Class=""size-8 opacity-50"" Margin=""Margin.Is3.FromEnd""/>
    <Paragraph Margin=""Margin.Is3.FromBottom"" TextSize=""TextSize.Lg"">This is the best component library I've ever used!</Paragraph>
    <footer><Strong>Jane Developer</Strong>, Senior Engineer</footer>
</Blockquote>")"
CodeLanguage="razor">
            <Blockquote Rounded="Rounded.Xl" Padding="Padding.Is6" TextAlign="TextAlign.Center" TextColor="TextColor.White" Class="bg-gradient-to-br from-violet-500 to-purple-700">
            <Icon Name="LucideIcon.Quote" TextColor="TextColor.White" Class="size-8" Opacity="Opacity.Is50" Margin="Margin.Is3.FromEnd"/>
            <Paragraph Margin="Margin.Is3.FromBottom" TextSize="TextSize.Lg">This is the best component library I've ever used!</Paragraph>
            <footer><Strong>Jane Developer</Strong>, Senior Engineer</footer>
        </Blockquote>
        </DemoSection>
        </Section>
    </Div>
</Div>
