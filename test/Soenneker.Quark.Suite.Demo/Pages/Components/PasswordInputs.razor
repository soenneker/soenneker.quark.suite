@page "/components/password-input"

<PageTitle>Password Input - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
            Description="A password input with a visibility toggle and native browser reveal controls hidden."
            Code="@BasicCode"
            PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel For="password-input-basic">Password</FieldLabel>
                <PasswordInput Id="password-input-basic"
                               Placeholder="Enter your password"
                               @bind-Value="_password" />
                <FieldDescription>Use the eye button to show or hide the value.</FieldDescription>
            </Field>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="New Password"
                     Description="Autocomplete can be adjusted for password creation flows."
                     Code="@NewPasswordCode"
                     PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel For="password-input-new">New password</FieldLabel>
                <PasswordInput Id="password-input-new"
                               Placeholder="Create a password"
                               AutoComplete="new-password"
                               MaxLength="64"
                               @bind-Value="_newPassword" />
            </Field>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Controlled Visibility"
                     Description="Visibility can be controlled from component state."
                     Code="@ControlledCode"
                     PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel For="password-input-controlled">API key</FieldLabel>
                <PasswordInput Id="password-input-controlled"
                               Placeholder="Paste a secret"
                               DisableToggleWhenEmpty="false"
                               @bind-Value="_secret"
                               @bind-ShowPassword="_showSecret" />
            </Field>
        </DemoSection>
    </Section>
</Div>

@code {
    private string? _password = "correct horse battery staple";
    private string? _newPassword;
    private string? _secret;
    private bool _showSecret;

    private const string BasicCode =
        """
        <PasswordInput Placeholder="Enter your password"
                       @bind-Value="_password" />
        """;

    private const string NewPasswordCode =
        """
        <PasswordInput Placeholder="Create a password"
                       AutoComplete="new-password"
                       MaxLength="64"
                       @bind-Value="_newPassword" />
        """;

    private const string ControlledCode =
        """
        <PasswordInput Placeholder="Paste a secret"
                       DisableToggleWhenEmpty="false"
                       @bind-Value="_secret"
                       @bind-ShowPassword="_showSecret" />
        """;
}
