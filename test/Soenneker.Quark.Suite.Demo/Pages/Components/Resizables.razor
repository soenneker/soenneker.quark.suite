@page "/resizables"
@using Soenneker.Bradix

<PageTitle>Resizable - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Accessible resizable panel groups and layouts with keyboard support."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Id="resizable-basic-demo" MaxWidth="MaxWidth.Is3xl">
                    <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="max-w-md rounded-lg border md:min-w-[450px]">
                        <ResizablePanel DefaultSize="50">
                            <Div Display="Display.Flex" Class="h-[200px]" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">One</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle />

                        <ResizablePanel DefaultSize="50">
                            <ResizablePanelGroup Orientation="Orientation.Vertical">
                                <ResizablePanel DefaultSize="25">
                                    <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                        <Span FontWeight="FontWeight.Semibold">Two</Span>
                                    </Div>
                                </ResizablePanel>

                                <ResizableHandle />

                                <ResizablePanel DefaultSize="75">
                                    <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                        <Span FontWeight="FontWeight.Semibold">Three</Span>
                                    </Div>
                                </ResizablePanel>
                            </ResizablePanelGroup>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use vertical orientation to stack the panels and resize them top-to-bottom."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Div Id="resizable-vertical-demo" MaxWidth="MaxWidth.Is3xl">
                    <ResizablePanelGroup Orientation="Orientation.Vertical" Class="min-h-[260px] rounded-xl border">
                        <ResizablePanel DefaultSize="1">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Top</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle />

                        <ResizablePanel DefaultSize="2">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" BackgroundColor='BackgroundColor.Token("muted/30")' Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Bottom</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Handle"
                     Description="Enable the visible grip when you want a stronger affordance for dragging."
                     Code="@HandleCode"
                     CodeLanguage="razor">
                <Div Id="resizable-handle-demo" MaxWidth="MaxWidth.Is3xl">
                    <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="min-h-[220px] rounded-xl border">
                        <ResizablePanel DefaultSize="1">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">One</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle WithHandle="true" />

                        <ResizablePanel DefaultSize="1">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" BackgroundColor='BackgroundColor.Token("muted/30")' Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Two</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Panel dragging follows right-to-left layout flow when rendered inside a direction provider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Id="resizable-rtl-demo" MaxWidth="MaxWidth.Is3xl" TextAlign="TextAlign.End">
                        <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="min-h-[220px] rounded-xl border">
                            <ResizablePanel DefaultSize="1">
                                <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is6">
                                    <Span FontWeight="FontWeight.Semibold">البداية</Span>
                                </Div>
                            </ResizablePanel>

                            <ResizableHandle />

                            <ResizablePanel DefaultSize="1">
                                <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" BackgroundColor='BackgroundColor.Token("muted/30")' Padding="Padding.Is6">
                                    <Span FontWeight="FontWeight.Semibold">النهاية</Span>
                                </Div>
                            </ResizablePanel>
                        </ResizablePanelGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<ResizablePanelGroup Orientation=""Orientation.Horizontal"" Class=""max-w-md rounded-lg border md:min-w-[450px]"">
    <ResizablePanel DefaultSize=""50"">
        <Div Class=""flex h-[200px] items-center justify-center p-6"">
            <Span Class=""font-semibold"">One</Span>
        </Div>
    </ResizablePanel>
    <ResizableHandle />
    <ResizablePanel DefaultSize=""50"">
        <ResizablePanelGroup Orientation=""Orientation.Vertical"">
            <ResizablePanel DefaultSize=""25"">
                <Div Class=""flex h-full items-center justify-center p-6"">
                    <Span Class=""font-semibold"">Two</Span>
                </Div>
            </ResizablePanel>
            <ResizableHandle />
            <ResizablePanel DefaultSize=""75"">
                <Div Class=""flex h-full items-center justify-center p-6"">
                    <Span Class=""font-semibold"">Three</Span>
                </Div>
            </ResizablePanel>
        </ResizablePanelGroup>
    </ResizablePanel>
</ResizablePanelGroup>";

    private const string VerticalCode =
@"<ResizablePanelGroup Orientation=""Orientation.Vertical"">
    <ResizablePanel>Top</ResizablePanel>
    <ResizableHandle />
    <ResizablePanel>Bottom</ResizablePanel>
</ResizablePanelGroup>";

    private const string HandleCode =
@"<ResizablePanelGroup Orientation=""Orientation.Horizontal"">
    <ResizablePanel>One</ResizablePanel>
    <ResizableHandle WithHandle=""true"" />
    <ResizablePanel>Two</ResizablePanel>
</ResizablePanelGroup>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <ResizablePanelGroup Orientation=""Orientation.Horizontal"">
        <ResizablePanel>البداية</ResizablePanel>
        <ResizableHandle />
        <ResizablePanel>النهاية</ResizablePanel>
    </ResizablePanelGroup>
</DirectionProvider>";
}
