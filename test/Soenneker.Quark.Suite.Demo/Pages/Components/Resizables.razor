@page "/resizables"
@using Soenneker.Bradix

<PageTitle>Resizable - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Accessible resizable panel groups and layouts with keyboard support."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Id="resizable-basic-demo" MaxWidth="MaxWidth.Is3xl">
                    <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="max-w-sm rounded-lg border">
                        <ResizablePanel DefaultSize="50">
                            <Div Display="Display.Flex" Class="h-[200px]" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">One</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle />

                        <ResizablePanel DefaultSize="50">
                            <ResizablePanelGroup Orientation="Orientation.Vertical">
                                <ResizablePanel DefaultSize="25">
                                    <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                        <Span FontWeight="FontWeight.Semibold">Two</Span>
                                    </Div>
                                </ResizablePanel>

            <ResizableHandle />

                                <ResizablePanel DefaultSize="75">
                                    <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                        <Span FontWeight="FontWeight.Semibold">Three</Span>
                                    </Div>
                                </ResizablePanel>
                            </ResizablePanelGroup>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use orientation=&quot;vertical&quot; for vertical resizing."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Div Id="resizable-vertical-demo" MaxWidth="MaxWidth.Is3xl">
                    <ResizablePanelGroup Orientation="Orientation.Vertical" Class="min-h-[200px] max-w-sm rounded-lg border">
                        <ResizablePanel DefaultSize="25">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Header</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle />

                        <ResizablePanel DefaultSize="75">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Content</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Handle"
                     Description="Use the withHandle prop on ResizableHandle to show a visible handle."
                     Code="@HandleCode"
                     CodeLanguage="razor">
                <Div Id="resizable-handle-demo" MaxWidth="MaxWidth.Is3xl">
                    <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="min-h-[200px] max-w-md rounded-lg border md:min-w-[450px]">
                        <ResizablePanel DefaultSize="25">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Sidebar</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle WithHandle="true" />

                        <ResizablePanel DefaultSize="75">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Content</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Panel dragging follows right-to-left layout flow when rendered inside a direction provider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Id="resizable-rtl-demo" MaxWidth="MaxWidth.Is3xl">
                        <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="max-w-sm rounded-lg border">
                            <ResizablePanel DefaultSize="50">
                                <Div Display="Display.Flex" Class="h-[200px]" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                    <Span FontWeight="FontWeight.Semibold">واحد</Span>
                                </Div>
                            </ResizablePanel>

                            <ResizableHandle />

                            <ResizablePanel DefaultSize="50">
                                <ResizablePanelGroup Orientation="Orientation.Vertical">
                                    <ResizablePanel DefaultSize="25">
                                        <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                            <Span FontWeight="FontWeight.Semibold">اثنان</Span>
                                        </Div>
                                    </ResizablePanel>

                                    <ResizableHandle />

                                    <ResizablePanel DefaultSize="75">
                                        <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                            <Span FontWeight="FontWeight.Semibold">ثلاثة</Span>
                                        </Div>
                                    </ResizablePanel>
                                </ResizablePanelGroup>
                            </ResizablePanel>
                        </ResizablePanelGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<ResizablePanelGroup Orientation=""Orientation.Horizontal"" Class=""max-w-sm rounded-lg border"">
    <ResizablePanel DefaultSize=""50"">
        <Div Class=""flex h-[200px] items-center justify-center p-6"">
            <Span Class=""font-semibold"">One</Span>
        </Div>
    </ResizablePanel>
    <ResizableHandle />
    <ResizablePanel DefaultSize=""50"">
        <ResizablePanelGroup Orientation=""Orientation.Vertical"">
            <ResizablePanel DefaultSize=""25"">
                <Div Class=""flex h-full items-center justify-center p-6"">
                    <Span Class=""font-semibold"">Two</Span>
                </Div>
            </ResizablePanel>
            <ResizableHandle />
            <ResizablePanel DefaultSize=""75"">
                <Div Class=""flex h-full items-center justify-center p-6"">
                    <Span Class=""font-semibold"">Three</Span>
                </Div>
            </ResizablePanel>
        </ResizablePanelGroup>
    </ResizablePanel>
</ResizablePanelGroup>";

    private const string VerticalCode =
@"<ResizablePanelGroup Orientation=""Orientation.Vertical"" Class=""min-h-[200px] max-w-sm rounded-lg border"">
    <ResizablePanel DefaultSize=""25"">Header</ResizablePanel>
    <ResizableHandle />
    <ResizablePanel DefaultSize=""75"">Content</ResizablePanel>
</ResizablePanelGroup>";

    private const string HandleCode =
@"<ResizablePanelGroup Orientation=""Orientation.Horizontal"" Class=""min-h-[200px] max-w-md rounded-lg border md:min-w-[450px]"">
    <ResizablePanel DefaultSize=""25"">Sidebar</ResizablePanel>
    <ResizableHandle WithHandle=""true"" />
    <ResizablePanel DefaultSize=""75"">Content</ResizablePanel>
</ResizablePanelGroup>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <ResizablePanelGroup Orientation=""Orientation.Horizontal"" Class=""max-w-sm rounded-lg border"">
        <ResizablePanel DefaultSize=""50"">واحد</ResizablePanel>
        <ResizableHandle />
        <ResizablePanel DefaultSize=""50"">
            <ResizablePanelGroup Orientation=""Orientation.Vertical"">
                <ResizablePanel DefaultSize=""25"">اثنان</ResizablePanel>
                <ResizableHandle />
                <ResizablePanel DefaultSize=""75"">ثلاثة</ResizablePanel>
            </ResizablePanelGroup>
        </ResizablePanel>
    </ResizablePanelGroup>
</DirectionProvider>";
}
