@page "/components/resizable"
@using Soenneker.Bradix

<PageTitle>Resizable - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Accessible resizable panel groups and layouts with keyboard support."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Id="resizable-basic-demo" Class="w-full max-w-sm">
                    <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="w-full rounded-lg border">
                        <ResizablePanel DefaultSize="50">
                            <Div Display="Display.Flex" style="height:238px" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">One</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle />

                        <ResizablePanel DefaultSize="50">
                            <ResizablePanelGroup Orientation="Orientation.Vertical">
                                <ResizablePanel DefaultSize="25">
                                    <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                        <Span FontWeight="FontWeight.Semibold">Two</Span>
                                    </Div>
                                </ResizablePanel>

            <ResizableHandle />

                                <ResizablePanel DefaultSize="75">
                                    <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                        <Span FontWeight="FontWeight.Semibold">Three</Span>
                                    </Div>
                                </ResizablePanel>
                            </ResizablePanelGroup>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="Use orientation=&quot;vertical&quot; for vertical resizing."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Div Id="resizable-vertical-demo" Class="h-[208px] w-full max-w-sm">
                    <ResizablePanelGroup Orientation="Orientation.Vertical" Class="min-h-[200px] w-full rounded-lg border">
                        <ResizablePanel DefaultSize="25">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Header</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle />

                        <ResizablePanel DefaultSize="75">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Content</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Handle"
                     Description="Use the withHandle prop on ResizableHandle to show a visible handle."
                     Code="@HandleCode"
                     CodeLanguage="razor">
                <Div Id="resizable-handle-demo" Class="h-[208px] w-full max-w-md md:min-w-[450px]">
                    <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="min-h-[200px] w-full rounded-lg border">
                        <ResizablePanel DefaultSize="25">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Sidebar</Span>
                            </Div>
                        </ResizablePanel>

                        <ResizableHandle WithHandle="true" />

                        <ResizablePanel DefaultSize="75">
                            <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                <Span FontWeight="FontWeight.Semibold">Content</Span>
                            </Div>
                        </ResizablePanel>
                    </ResizablePanelGroup>
                </Div>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Panel dragging follows right-to-left layout flow when rendered inside a direction provider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Id="resizable-rtl-demo" Class="w-full max-w-sm">
                        <ResizablePanelGroup Orientation="Orientation.Horizontal" Class="w-full rounded-lg border">
                            <ResizablePanel DefaultSize="50">
                                <Div Display="Display.Flex" style="height:206px" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                    <Span FontWeight="FontWeight.Semibold">واحد</Span>
                                </Div>
                            </ResizablePanel>

                            <ResizableHandle />

                            <ResizablePanel DefaultSize="50">
                                <ResizablePanelGroup Orientation="Orientation.Vertical">
                                    <ResizablePanel DefaultSize="25">
                                        <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                            <Span FontWeight="FontWeight.Semibold">اثنان</Span>
                                        </Div>
                                    </ResizablePanel>

                                    <ResizableHandle />

                                    <ResizablePanel DefaultSize="75">
                                        <Div Display="Display.Flex" Height="Height.IsFull" ItemsAlign="Items.Center" Justify="Justify.Center" Padding="Padding.Is6">
                                            <Span FontWeight="FontWeight.Semibold">ثلاثة</Span>
                                        </Div>
                                    </ResizablePanel>
                                </ResizablePanelGroup>
                            </ResizablePanel>
                        </ResizablePanelGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

