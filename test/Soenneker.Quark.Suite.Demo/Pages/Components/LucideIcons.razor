@page "/lucide"

<PageTitle>Lucide - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <Paragraph Class="text-sm text-muted-foreground">
            Use the <Code Inline="true">Lucide</Code> primitive to render generated Lucide SVGs with Quark spacing, colors, and standard element attributes.
        </Paragraph>
    </Div>

    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic" Description="Lucide icons rendered with the Lucide primitive. Requires Soenneker.Quark.Gen.Lucide and ILucideIconSvgProvider." Code="@(@"<Lucide Icon=""LucideIcon.Check"" Class=""size-6""/>
<Lucide Icon=""LucideIcon.Heart"" Class=""size-6""/>")">
                <Div Class="flex flex-wrap gap-4 items-center">
                    <Lucide Icon="LucideIcon.AArrowDown" Class="size-6" />
                    <Lucide Icon="LucideIcon.Check" Class="size-6" />
                    <Lucide Icon="LucideIcon.Activity" Class="size-6" />
                    <Lucide Icon="LucideIcon.Heart" Class="size-6" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Text Color" Description="Use TextColor for theming." Code="@(@"<Lucide Icon=""LucideIcon.Check"" TextColor=""TextColor.Primary"" Class=""size-6""/>
<Lucide Icon=""LucideIcon.Heart"" TextColor=""TextColor.Danger"" Class=""size-6""/>")">
                <Div Class="flex flex-wrap gap-4 items-center">
                    <Lucide Icon="LucideIcon.Check" TextColor="TextColor.Primary" Class="size-6" />
                    <Lucide Icon="LucideIcon.Heart" TextColor="TextColor.Danger" Class="size-6" />
                    <Lucide Icon="LucideIcon.Star" TextColor="TextColor.Warning" Class="size-6" />
                    <Lucide Icon="LucideIcon.House" TextColor="TextColor.Success" Class="size-6" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sizes" Description="Use Tailwind size utilities or Class." Code="@(@"<Lucide Icon=""LucideIcon.Star"" Class=""size-4""/>
<Lucide Icon=""LucideIcon.Star"" Class=""size-6""/>
<Lucide Icon=""LucideIcon.Star"" Class=""size-8""/>
<Lucide Icon=""LucideIcon.Star"" Class=""size-12""/>")">
                <Div Class="flex flex-wrap items-center gap-6">
                    <Lucide Icon="LucideIcon.Star" Class="size-4" />
                    <Lucide Icon="LucideIcon.Star" Class="size-6" />
                    <Lucide Icon="LucideIcon.Star" Class="size-8" />
                    <Lucide Icon="LucideIcon.Star" Class="size-12" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Label" Description="ChildContent for accessible labels (e.g. sr-only)." Code="@(@"<Lucide Icon=""LucideIcon.Check"" Class=""size-5 text-green-600"">
    <Span class=""sr-only"">Completed</Span>
</Lucide>
<Span>Task completed</Span>")">
                <Div Class="flex gap-3 items-center">
                    <Lucide Icon="LucideIcon.Check" Class="size-5 text-green-600">
                        <Span class="sr-only">Completed</Span>
                    </Lucide>
                    <Span>Task completed</Span>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="In Buttons" Description="Icons paired with button text." Code="@(@"<Button Variant=""ButtonVariant.Default"">
    <Lucide Icon=""LucideIcon.Plus"" Class=""size-4"" Margin=""Margin.Is2.FromEnd""/>
    Add
</Button>")">
                <Div Class="flex flex-wrap gap-3">
                    <Button Variant="ButtonVariant.Default">
                        <Lucide Icon="LucideIcon.Plus" Class="size-4" Margin="Margin.Is2.FromEnd"/>
                        Add
                    </Button>
                    <Button Variant="ButtonVariant.Outline">
                        <Lucide Icon="LucideIcon.Download" Class="size-4" Margin="Margin.Is2.FromEnd"/>
                        Download
                    </Button>
                    <Button Variant="ButtonVariant.Ghost">
                        <Lucide Icon="LucideIcon.Trash2" Class="size-4" Margin="Margin.Is2.FromEnd"/>
                        Delete
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Common Icons" Description="Frequently used Lucide icons.">
                <Div Class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-4">
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.House" Class="size-6" />
                        <Small Class="text-muted-foreground">Home</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.Settings" Class="size-6" />
                        <Small Class="text-muted-foreground">Settings</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.User" Class="size-6" />
                        <Small Class="text-muted-foreground">User</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.Search" Class="size-6" />
                        <Small Class="text-muted-foreground">Search</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.Mail" Class="size-6" />
                        <Small Class="text-muted-foreground">Mail</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.Bell" Class="size-6" />
                        <Small Class="text-muted-foreground">Bell</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.Calendar" Class="size-6" />
                        <Small Class="text-muted-foreground">Calendar</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Lucide Icon="LucideIcon.Folder" Class="size-6" />
                        <Small Class="text-muted-foreground">Folder</Small>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>
