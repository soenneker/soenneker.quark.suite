@page "/header"
@inject Services.ThemeService ThemeService

<PageTitle>Header - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Section Space="Space.Y.Is3">
        <Div Space="Space.Y.Is2">
            <H1 class="text-3xl font-semibold tracking-tight">Header</H1>
            <Paragraph class="max-w-3xl text-sm text-muted-foreground">
                `Header` gives you a reusable top shell with consistent layout, while `HeaderBrand`, `NavigationLinks`, `HeaderActionLink`, and
                `ThemeToggleButton` keep the common styling out of app layouts.
            </Paragraph>
        </Div>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Composed header"
                     Description="A basic application header built from the suite components."
                     Code="@ComposedHeaderCode"
                     CodeLanguage="razor">
            <Div class="overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
                <Header Class="relative">
                    <BrandContent>
                        <HeaderBrand To=""
                                     AriaLabel="Quark Suite home"
                                     ImageSource="https://user-images.githubusercontent.com/4441470/224455560-91ed3ee7-f510-4041-a8d2-3fc093025112.png"
                                     ImageAlt="Soenneker Quark Suite"
                                     Title="Soenneker Quark Suite"
                                     Subtitle="Reusable app shell pieces" />
                    </BrandContent>
                    <NavigationContent>
                        <NavigationLinks Items="_headerLinks"
                                         Mode="NavigationLinksMode.Header"
                                         IsActive="IsHeaderLinkActive" />
                    </NavigationContent>
                    <ActionsContent>
                        <HeaderActionLink To="https://github.com/soenneker/soenneker.quark.suite"
                                          Target="Target.Blank"
                                          Rel="noreferrer"
                                          Label="GitHub"
                                          AriaLabel="View Soenneker Quark Suite on GitHub">
                            <IconContent>
                                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                    <path d="M12 .5C5.65.5.5 5.65.5 12A11.5 11.5 0 0 0 8.36 22.9c.57.1.78-.25.78-.56 0-.28-.01-1.2-.02-2.18-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.76 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.53-2.55-.29-5.23-1.27-5.23-5.68 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a10.97 10.97 0 0 1 5.77 0c2.2-1.5 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.73.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.67.41.35.78 1.04.78 2.1 0 1.52-.01 2.75-.01 3.12 0 .31.21.67.79.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
                                </svg>
                            </IconContent>
                        </HeaderActionLink>
                        <ThemeToggleButton IsDark="ThemeService.IsDark"
                                           AriaLabel="Toggle dark mode"
                                           OnClick="ToggleTheme" />
                    </ActionsContent>
                </Header>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Header with sidebar shell"
                     Description="The header can sit above a sidebar provider and expose the standard sidebar trigger without each layout restyling it."
                     Code="@ShellHeaderCode"
                     CodeLanguage="razor">
            <Div class="overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
                <SidebarProvider Class="flex h-[360px] flex-col overflow-hidden bg-background text-foreground"
                                 SidebarWidth="calc(var(--spacing) * 64)"
                                 style="--header-height: 3.5rem;">
                    <Header ShowSidebarTrigger="true"
                            Class="relative">
                        <BrandContent>
                            <HeaderBrand To=""
                                         AriaLabel="Acme home"
                                         Title="Acme Control"
                                         Subtitle="Workspace shell" />
                        </BrandContent>
                        <NavigationContent>
                            <NavigationLinks Items="_workspaceLinks"
                                             Mode="NavigationLinksMode.Header"
                                             IsActive="IsWorkspaceLinkActive" />
                        </NavigationContent>
                        <ActionsContent>
                            <Button Variant="ButtonVariant.Outline">Share</Button>
                            <Button>Deploy</Button>
                        </ActionsContent>
                    </Header>

                    <Div class="flex min-h-0 flex-1">
                        <Sidebar>
                            <SidebarHeader>
                                <SidebarInput Placeholder="Search..." Type="search" />
                            </SidebarHeader>
                            <SidebarContent>
                                <NavigationLinks Items="_workspaceSidebarLinks"
                                                 Mode="NavigationLinksMode.Sidebar"
                                                 Title="Workspace"
                                                 GroupClass="pt-2"
                                                 IsActive="IsWorkspaceLinkActive" />
                            </SidebarContent>
                        </Sidebar>

                        <SidebarInset>
                            <Div class="flex h-full items-center justify-center p-6 text-sm text-muted-foreground">
                                Use the trigger in the header to toggle the sidebar.
                            </Div>
                        </SidebarInset>
                    </Div>
                </SidebarProvider>
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private const string ComposedHeaderCode = """
<Header>
    <BrandContent>
        <HeaderBrand Title="Quark Suite" Subtitle="Reusable app shell pieces" />
    </BrandContent>
    <NavigationContent>
        <NavigationLinks Items="_headerLinks" Mode="NavigationLinksMode.Header" IsActive="IsHeaderLinkActive" />
    </NavigationContent>
    <ActionsContent>
        <HeaderActionLink To="https://github.com/soenneker/soenneker.quark.suite" Label="GitHub" />
        <ThemeToggleButton IsDark="ThemeService.IsDark" OnClick="ToggleTheme" />
    </ActionsContent>
</Header>
""";

    private const string ShellHeaderCode = """
<SidebarProvider Class="flex h-[360px] flex-col overflow-hidden">
    <Header ShowSidebarTrigger="true">
        <BrandContent>
            <HeaderBrand Title="Acme Control" Subtitle="Workspace shell" />
        </BrandContent>
        <NavigationContent>
            <NavigationLinks Items="_workspaceLinks" Mode="NavigationLinksMode.Header" IsActive="IsWorkspaceLinkActive" />
        </NavigationContent>
    </Header>

    <Div class="flex min-h-0 flex-1">
        <Sidebar>
            <SidebarContent>
                <NavigationLinks Items="_workspaceSidebarLinks" Mode="NavigationLinksMode.Sidebar" Title="Workspace" />
            </SidebarContent>
        </Sidebar>
        <SidebarInset>...</SidebarInset>
    </Div>
</SidebarProvider>
""";

    private readonly IReadOnlyList<NavigationItem> _headerLinks =
    [
        new("Overview", ExactMatch: true),
        new("Components", "components"),
        new("Header", "header", IsNew: true)
    ];

    private readonly IReadOnlyList<NavigationItem> _workspaceLinks =
    [
        new("Overview", ExactMatch: true),
        new("Projects", "projects"),
        new("Activity", "activity")
    ];

    private readonly IReadOnlyList<NavigationItem> _workspaceSidebarLinks =
    [
        new("Dashboard", ExactMatch: true),
        new("Projects", "projects"),
        new("Activity", "activity"),
        new("Settings", "settings")
    ];

    private bool IsHeaderLinkActive(NavigationItem item)
    {
        return item.Title == "Header";
    }

    private bool IsWorkspaceLinkActive(NavigationItem item)
    {
        return item.Title is "Overview" or "Dashboard";
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleAsync();
    }
}
