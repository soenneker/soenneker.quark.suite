@page "/getting-started"

<PageTitle>Getting Started - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is3">
        <H1 TextSize="TextSize.FourXl" FontWeight="FontWeight.Bold" Tracking="Tracking.Tight">Getting Started</H1>
        <Paragraph TextSize="TextSize.Xl" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
            Learn how to use Surfaces and Components in your Blazor application.
        </Paragraph>
    </Div>

    <Div Space="Space.Y.Is6">
        <Div Space="Space.Y.Is4">
            <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold">Surfaces vs Components</H2>
            <Div Display="Display.Grid" Gap="Gap.Is4" Class="md:grid-cols-2">
                <Div Padding="Padding.Is5" Border="Border.Is1" BorderColor="BorderColor.Border" Rounded="Rounded.Lg" Space="Space.Y.Is3" BackgroundColor="BackgroundColor.Card">
                    <H3 TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold" TextColor="TextColor.Primary">Surfaces</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Pre-styled blocks for layout and feedback: cards, alerts, buttons, accordions.
                    </Paragraph>
                    <Div Space="Space.Y.Is2" TextSize="TextSize.Sm">
                        <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <Span Class="text-green-600 dark:text-green-400 mt-0.5">✓</Span>
                            <Span TextColor="TextColor.MutedForeground">Ready-to-use styling</Span>
                        </Div>
                        <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <Span Class="text-green-600 dark:text-green-400 mt-0.5">✓</Span>
                            <Span TextColor="TextColor.MutedForeground">Consistent design language</Span>
                        </Div>
                        <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <Span Class="text-green-600 dark:text-green-400 mt-0.5">✓</Span>
                            <Span TextColor="TextColor.MutedForeground">Override with Class parameter</Span>
                        </Div>
                    </Div>
                </Div>
                <Div Padding="Padding.Is5" Border="Border.Is1" BorderColor="BorderColor.Border" Rounded="Rounded.Lg" Space="Space.Y.Is3" BackgroundColor="BackgroundColor.Card">
                    <H3 TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold" TextColor="TextColor.Primary">Components</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Full interactive components: forms, inputs, navigation, overlays, data display, layout.
                    </Paragraph>
                    <Div Space="Space.Y.Is2" TextSize="TextSize.Sm">
                        <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <Span Class="text-green-600 dark:text-green-400 mt-0.5">✓</Span>
                            <Span TextColor="TextColor.MutedForeground">Semantic HTML output</Span>
                        </Div>
                        <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <Span Class="text-green-600 dark:text-green-400 mt-0.5">✓</Span>
                            <Span TextColor="TextColor.MutedForeground">Accessibility built-in</Span>
                        </Div>
                        <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is2">
                            <Span Class="text-green-600 dark:text-green-400 mt-0.5">✓</Span>
                            <Span TextColor="TextColor.MutedForeground">Tailwind + Class for customization</Span>
                        </Div>
                    </Div>
                </Div>
            </Div>
        </Div>

        <Div Space="Space.Y.Is4">
            <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold">Usage examples</H2>
            <Div Space="Space.Y.Is6">
                <Div Space="Space.Y.Is3">
                    <H3 TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Forms with Field and Input</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Use Field, FieldLabel, FieldBody, and Input for accessible form fields with optional validation.
                    </Paragraph>
                    <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is4">
                        <PreCode TextSize="TextSize.Sm">@("@using Soenneker.Quark.Suite.Components\n\n<Field>\n    <FieldLabel For=\"email\" RequiredIndicator=\"true\">Email</FieldLabel>\n    <FieldBody>\n        <Validation Action=\"@ValidateEmail\">\n            <Input Id=\"email\" Type=\"email\" Placeholder=\"you@example.com\" @bind-Value=\"email\" />\n            <ValidationError />\n        </Validation>\n    </FieldBody>\n</Field>")</PreCode>
                    </Div>
                </Div>
                <Div Space="Space.Y.Is3">
                    <H3 TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Buttons and variants</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Buttons support variants (Default, Outline, Secondary, Ghost, Link, Destructive) and optional navigation via To.
                    </Paragraph>
                    <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is4">
                        <PreCode TextSize="TextSize.Sm">@("<Button Variant=\"ButtonVariant.Default\" OnClick=\"Save\">Save</Button>\n<Button Variant=\"ButtonVariant.Outline\" Type=\"ButtonType.Link\" To=\"/dashboard\">Dashboard</Button>")</PreCode>
                    </Div>
                </Div>
                <Div Space="Space.Y.Is3">
                    <H3 TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Layout with Div and spacing</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Use Div with Class for layout; use Margin and Padding enums for consistent spacing.
                    </Paragraph>
                    <Div Rounded="Rounded.Lg" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor='BackgroundColor.Token("muted/50")' Padding="Padding.Is4">
                        <PreCode TextSize="TextSize.Sm">@("<Div Display=\"Display.Grid\" Gap=\"Gap.Is4\" Class=\"md:grid-cols-2\">\n    <Div Border=\"Border.Is1\" Rounded=\"Rounded.Lg\" Padding=\"Padding.Is3\">\n        <H3>Card one</H3>\n        <Paragraph Margin=\"Margin.Is0\">Content.</Paragraph>\n    </Div>\n</Div>")</PreCode>
                    </Div>
                </Div>
            </Div>
        </Div>

        <Div Space="Space.Y.Is4">
            <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold">Common patterns</H2>
            <Div Space="Space.Y.Is4">
                <Div Padding="Padding.Is4" Border="Border.Is4.FromLeft" BorderColor="BorderColor.Primary" BackgroundColor='BackgroundColor.Token("primary/5")' Class="rounded-r-lg" Space="Space.Y.Is2">
                    <H4 FontWeight="FontWeight.Medium">Class parameter</H4>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Most components expose <Code TextSize="TextSize.Xs">Class</Code>. Use Tailwind classes to customize; they are merged with default styles.
                    </Paragraph>
                </Div>
                <Div Padding="Padding.Is4" Border="Border.Is4.FromLeft" BorderColor="BorderColor.Primary" BackgroundColor='BackgroundColor.Token("primary/5")' Class="rounded-r-lg" Space="Space.Y.Is2">
                    <H4 FontWeight="FontWeight.Medium">Two-way binding</H4>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Use <Code TextSize="TextSize.Xs">bind-Value</Code> on inputs and form controls. Use <Code TextSize="TextSize.Xs">OnClick</Code>, <Code TextSize="TextSize.Xs">OnChange</Code> and similar for events.
                    </Paragraph>
                </Div>
                <Div Padding="Padding.Is4" Border="Border.Is4.FromLeft" BorderColor="BorderColor.Primary" BackgroundColor='BackgroundColor.Token("primary/5")' Class="rounded-r-lg" Space="Space.Y.Is2">
                    <H4 FontWeight="FontWeight.Medium">Semantic markup</H4>
                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Quark renders semantic HTML (button, input, label, etc.) so accessibility and SEO stay correct. Use Field + FieldLabel + FieldBody for form sections.
                    </Paragraph>
                </Div>
            </Div>
        </Div>

        <Div Space="Space.Y.Is4">
            <H2 TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold">Next steps</H2>
            <Div Display="Display.Grid" Gap="Gap.Is4" Class="sm:grid-cols-2">
                <Anchor To="components" Class="block p-5 border border-border rounded-lg hover:bg-accent transition-colors space-y-2 no-underline text-foreground">
                    <H3 Class="font-semibold text-primary">Explore Components</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Browse the component list and demos.</Paragraph>
                </Anchor>
                <Anchor To="buttons" Class="block p-5 border border-border rounded-lg hover:bg-accent transition-colors space-y-2 no-underline text-foreground">
                    <H3 Class="font-semibold text-primary">Buttons & Surfaces</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Cards, alerts, buttons.</Paragraph>
                </Anchor>
                <Anchor To="input-demo" Class="block p-5 border border-border rounded-lg hover:bg-accent transition-colors space-y-2 no-underline text-foreground">
                    <H3 Class="font-semibold text-primary">Forms & Inputs</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Input, validation, fields, selects.</Paragraph>
                </Anchor>
                <Anchor To="tables-basic" Class="block p-5 border border-border rounded-lg hover:bg-accent transition-colors space-y-2 no-underline text-foreground">
                    <H3 Class="font-semibold text-primary">Data display</H3>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Tables, lists, TreeView.</Paragraph>
                </Anchor>
            </Div>
        </Div>
    </Div>
</Div>
