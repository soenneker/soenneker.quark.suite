@page "/accordions"

<PageTitle>Accordion - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Single (default)" Description="@($"Current open item: {_singleSelectedItem ?? "none"}")" Code="@(@"<Accordion Value=""_singleSelectedItem"" ValueChanged=""HandleSingleAccordionValueChanged"">
    <AccordionItem Value=""item-1"">
        <AccordionTrigger>Is it accessible?</AccordionTrigger>
        <AccordionContent>Yes. Uses semantic button semantics with aria attributes.</AccordionContent>
    </AccordionItem>
</Accordion>")">
            <Div Space="Space.Y.Is3" Width="Width.IsFull">
                <Paragraph Class="text-sm text-muted-foreground" Margin="Margin.Is0">
                    In single mode, clicking the open trigger does not close it unless <code>Collapsible</code> is enabled.
                </Paragraph>
                <Accordion Value="@_singleSelectedItem"
                           ValueChanged="HandleSingleAccordionValueChanged"
                           Collapsible="true"
                           Width="Width.IsFull">
                    <AccordionItem Value="item-1">
                        <AccordionTrigger>Is it accessible?</AccordionTrigger>
                        <AccordionContent>
                            <Paragraph Margin="Margin.Is0">
                                Yes. Quark's Accordion uses semantic triggers with aria attributes and keyboard-focus styles.
                            </Paragraph>
                        </AccordionContent>
                    </AccordionItem>
                    <AccordionItem Value="item-2">
                        <AccordionTrigger>Does it support custom styling?</AccordionTrigger>
                        <AccordionContent>
                            <Paragraph Margin="Margin.Is0">
                                Yes. Add Tailwind utilities through <code>Class</code> on any accordion primitive.
                            </Paragraph>
                        </AccordionContent>
                    </AccordionItem>
                    <AccordionItem Value="item-3">
                        <AccordionTrigger>Can I render complex content?</AccordionTrigger>
                        <AccordionContent>
                            <Div Space="Space.Y.Is2">
                                <Paragraph Margin="Margin.Is0">You can place any Quark components inside accordion content.</Paragraph>
                                <Button Size="ButtonSize.Sm">Example Action</Button>
                            </Div>
                        </AccordionContent>
                    </AccordionItem>
                </Accordion>
            </Div>
        </DemoSection>

        <DemoSection Title="Collapsible single" Description="@($"Current open item: {_collapsibleSelectedItem ?? "none"}")" Code="@(@"<Accordion Value=""_collapsibleSelectedItem"" ValueChanged=""HandleCollapsibleAccordionValueChanged"" Collapsible=""true"">
    <AccordionItem Value=""item-1"">...</AccordionItem>
</Accordion>")">
            <Div Space="Space.Y.Is3" Width="Width.IsFull">
                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                    <Button Size="ButtonSize.Sm" OnClick="OpenCollapsibleFirst">Open first</Button>
                    <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Secondary" OnClick="OpenCollapsibleSecond">Open second</Button>
                    <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline" OnClick="ClearCollapsible">Close all</Button>
                </Div>
                <Accordion Value="@_collapsibleSelectedItem" ValueChanged="HandleCollapsibleAccordionValueChanged" Collapsible="true" Width="Width.IsFull">
                    <AccordionItem Value="collapsible-1">
                        <AccordionTrigger>Can the open item close itself?</AccordionTrigger>
                        <AccordionContent>
                            <Paragraph Margin="Margin.Is0">
                                Yes. In single mode with <code>Collapsible=true</code>, clicking the open trigger collapses the section.
                            </Paragraph>
                        </AccordionContent>
                    </AccordionItem>
                    <AccordionItem Value="collapsible-2">
                        <AccordionTrigger>Can the parent control it too?</AccordionTrigger>
                        <AccordionContent>
                            <Paragraph Margin="Margin.Is0">
                                Yes. The buttons above update the same value used by the accordion.
                            </Paragraph>
                        </AccordionContent>
                    </AccordionItem>
                </Accordion>
            </Div>
        </DemoSection>

        <DemoSection Title="Multiple mode" Description="@($"Open items: {FormatOpenItems(_multipleSelectedItems)}")" Code="@(@"<Accordion Multiple=""true"" Values=""_multipleSelectedItems"" ValuesChanged=""HandleMultipleAccordionValuesChanged"">
    <AccordionItem Value=""a"">...</AccordionItem>
    <AccordionItem Value=""b"">...</AccordionItem>
</Accordion>")">
            <Div Space="Space.Y.Is3" Width="Width.IsFull">
                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                    <Button Size="ButtonSize.Sm" OnClick="OpenAllMultiple">Open first two</Button>
                    <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline" OnClick="ClearMultiple">Close all</Button>
                </Div>
                <Accordion Multiple="true" Values="@_multipleSelectedItems" ValuesChanged="HandleMultipleAccordionValuesChanged" Width="Width.IsFull">
                    <AccordionItem Value="multi-a">
                        <AccordionTrigger>First section</AccordionTrigger>
                        <AccordionContent>
                            <Paragraph Margin="Margin.Is0">This accordion allows multiple expanded items.</Paragraph>
                        </AccordionContent>
                    </AccordionItem>
                    <AccordionItem Value="multi-b">
                        <AccordionTrigger>Second section</AccordionTrigger>
                        <AccordionContent>
                            <Paragraph Margin="Margin.Is0">Open this without closing the first one.</Paragraph>
                        </AccordionContent>
                    </AccordionItem>
                    <AccordionItem Value="multi-c" Disabled="true">
                        <AccordionTrigger>Disabled item</AccordionTrigger>
                        <AccordionContent>
                            <Paragraph Margin="Margin.Is0">Disabled items are non-interactive.</Paragraph>
                        </AccordionContent>
                    </AccordionItem>
                </Accordion>
            </Div>
        </DemoSection>
    </Div>
</Div>

@code {
    private string? _singleSelectedItem = "item-1";
    private string? _collapsibleSelectedItem = "collapsible-1";
    private IReadOnlyCollection<string> _multipleSelectedItems = ["multi-a"];


    private Task HandleSingleAccordionValueChanged(string? value)
    {
        _singleSelectedItem = value;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleCollapsibleAccordionValueChanged(string? value)
    {
        _collapsibleSelectedItem = value;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task HandleMultipleAccordionValuesChanged(IReadOnlyCollection<string> values)
    {
        _multipleSelectedItems = values;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task SetCollapsibleSelected(string? value)
    {
        _collapsibleSelectedItem = value;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task SetMultipleSelected(IReadOnlyCollection<string> values)
    {
        _multipleSelectedItems = values;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static string FormatOpenItems(IReadOnlyCollection<string> values)
    {
        return values.Count == 0 ? "none" : string.Join(", ", values);
    }

    private Task OpenCollapsibleFirst(MouseEventArgs args) => SetCollapsibleSelected("collapsible-1");

    private Task OpenCollapsibleSecond(MouseEventArgs args) => SetCollapsibleSelected("collapsible-2");

    private Task ClearCollapsible(MouseEventArgs args) => SetCollapsibleSelected(null);

    private Task OpenAllMultiple(MouseEventArgs args) => SetMultipleSelected(["multi-a", "multi-b"]);

    private Task ClearMultiple(MouseEventArgs args) => SetMultipleSelected([]);
}
