            Control your privacy settings and security preferences.
        </AccordionContent>
    </AccordionItem>
    <AccordionItem Value=""billing"">
        <AccordionTrigger>Billing &amp; Subscription</AccordionTrigger>
        <AccordionContent>
            View your current plan, payment history, and upcoming invoices.
        </AccordionContent>
