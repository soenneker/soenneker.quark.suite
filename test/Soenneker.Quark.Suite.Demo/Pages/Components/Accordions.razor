            </AccordionContent>
        </AccordionItem>
    </Accordion>
</DirectionProvider>";

    private Task HandleDemoChanged(string? value)
    {
        _demoValue = value;
        return Task.CompletedTask;
    }

    private Task HandleBasicChanged(string? value)
    {
        _basicValue = value;
        return Task.CompletedTask;
    }

    private Task HandleMultipleChanged(IReadOnlyCollection<string> values)
    {
        _multipleValues = values;
        return Task.CompletedTask;
    }

    private Task HandleBordersChanged(string? value)
    {
        _bordersValue = value;
        return Task.CompletedTask;
    }

    private Task HandleCardChanged(string? value)
    {
        _cardValue = value;
        return Task.CompletedTask;
    }

    private Task HandleDisabledChanged(string? value)
    {
        _disabledValue = value;
        return Task.CompletedTask;
    }
}
