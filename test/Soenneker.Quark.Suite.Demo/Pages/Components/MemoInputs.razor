@page "/memoinputs"
@using Microsoft.Extensions.Logging
@using Soenneker.Extensions.String

@inject ILogger<Index> Logger

<PageTitle>MemoInputs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <DemoSection Title="Basic Usage" Description="Default MemoInput with placeholder and binding." Code="@(@"<MemoInput @bind-Value=""_basicValue"" Placeholder=""Enter your text here..."" Rows=""5""/>")"
        CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">Default MemoInput</Paragraph>
            <MemoInput @bind-Value="_basicValue" Placeholder="Enter your text here..."/>
            <Paragraph Margin="Margin.Is0"><Strong>Value:</Strong> @_basicValue</Paragraph>
        </DemoSection>

        <DemoSection Title="Size Variations" Description="InputSizes.Sm and InputSizes.Lg." Code="@(@"<MemoInput @bind-Value=""_smallValue"" Size=""InputSizes.Sm"" Placeholder=""Small...""/>
<MemoInput @bind-Value=""_largeValue"" Size=""InputSizes.Lg"" Placeholder=""Large...""/>")"
CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">Small Size</Paragraph>
            <MemoInput @bind-Value="_smallValue" Size="InputSizes.Sm" Placeholder="Small memo edit..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">Large Size</Paragraph>
            <MemoInput @bind-Value="_largeValue" Size="InputSizes.Lg" Placeholder="Large memo edit..."/>
        </DemoSection>

        <DemoSection Title="Color Variations" Description="primary, success, warning, destructive." Code="@(@"<MemoInput @bind-Value=""_primaryValue"" Color=""primary"" Placeholder=""Primary...""/>
<MemoInput @bind-Value=""_successValue"" Color=""success"" Placeholder=""Success...""/>
<MemoInput @bind-Value=""_dangerValue"" Color=""destructive"" Placeholder=""Danger...""/>")"
CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">Primary Color</Paragraph>
            <MemoInput @bind-Value="_primaryValue" Color="primary" Placeholder="Primary color memo..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">Success Color</Paragraph>
            <MemoInput @bind-Value="_successValue" Color="success" Placeholder="Success color memo..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">Warning Color</Paragraph>
            <MemoInput @bind-Value="_warningValue" Color="warning" Placeholder="Warning color memo..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">Danger Color</Paragraph>
            <MemoInput @bind-Value="_dangerValue" Color="destructive" Placeholder="Danger color memo..."/>
        </DemoSection>

        <DemoSection Title="Row Configuration" Description="Rows attribute for height." Code="@(@"<MemoInput @bind-Value=""_rows2Value"" Rows=""2"" Placeholder=""2 GridRows...""/>
<MemoInput @bind-Value=""_rows5Value"" Rows=""5"" Placeholder=""5 GridRows...""/>
<MemoInput @bind-Value=""_rows8Value"" Rows=""8"" Placeholder=""8 GridRows...""/>")"
CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">2 Rows</Paragraph>
            <MemoInput @bind-Value="_rows2Value" Rows="2" Placeholder="2 rows memo..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">5 Rows</Paragraph>
            <MemoInput @bind-Value="_rows5Value" Rows="5" Placeholder="5 rows memo..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">8 Rows</Paragraph>
            <MemoInput @bind-Value="_rows8Value" Rows="8" Placeholder="8 rows memo..."/>
        </DemoSection>

        <DemoSection Title="Auto Resize" Description="AutoResize=true." Code="@(@"<MemoInput @bind-Value=""_autoResizeValue"" AutoResize=""true"" Placeholder=""Resizes as you type...""/>")"
        CodeLanguage="razor">
            <MemoInput @bind-Value="_autoResizeValue" AutoResize="true" Placeholder="This memo edit will resize as you type..."/>
        </DemoSection>

        <DemoSection Title="Validation Features" Description="Required, MaxLength, MinLength." Code="@(@"<MemoInput @bind-Value=""_requiredValue"" Required=""true"" Placeholder=""Required...""/>
<MemoInput @bind-Value=""_maxLengthValue"" MaxLength=""100"" Placeholder=""Max 100 chars...""/>
<MemoInput @bind-Value=""_minLengthValue"" MinLength=""10"" Placeholder=""Min 10 chars...""/>")"
CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">Required Field</Paragraph>
            <MemoInput @bind-Value="_requiredValue" Required="true" Placeholder="This field is required..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">Max Length (100 characters)</Paragraph>
            <MemoInput @bind-Value="_maxLengthValue" MaxLength="100" Placeholder="Maximum 100 characters allowed..."/>
            <Paragraph Margin="Margin.Is0"><Small>Characters: @(_maxLengthValue?.Length ?? 0)/100</Small></Paragraph>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">Min Length (10 characters)</Paragraph>
            <MemoInput @bind-Value="_minLengthValue" MinLength="10" Placeholder="Minimum 10 characters required..."/>
        </DemoSection>

        <DemoSection Title="State Variations" Description="Disabled and ReadOnly." Code="@(@"<MemoInput @bind-Value=""_disabledValue"" Disabled=""true"" Placeholder=""Disabled...""/>
<MemoInput @bind-Value=""_readOnlyValue"" ReadOnly=""true"" Placeholder=""Read only...""/>")"
CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">Disabled</Paragraph>
            <MemoInput @bind-Value="_disabledValue" Disabled="true" Placeholder="This memo edit is disabled..."/>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">Read Only</Paragraph>
            <MemoInput @bind-Value="_readOnlyValue" ReadOnly="true" Placeholder="This memo edit is read only..."/>
        </DemoSection>

        <DemoSection Title="Event Handling" Description="OnChange and OnInput." Code="@(@"<MemoInput @bind-Value=""_changeValue"" OnChange=""OnChangeHandler"" Placeholder=""Type to see change...""/>
<MemoInput @bind-Value=""_inputValue"" OnInput=""OnInputHandler"" Placeholder=""Type to see input...""/>")"
CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">With Change Event</Paragraph>
            <MemoInput @bind-Value="_changeValue" OnChange="OnChangeHandler" Placeholder="Type to see change events..."/>
            <Paragraph Margin="Margin.Is0"><Strong>Last Change:</Strong> @_lastChangeTime</Paragraph>
            <Paragraph FontWeight="FontWeight.Semibold" Margin="Margin.Is4.FromTop">With Input Event</Paragraph>
            <MemoInput @bind-Value="_inputValue" OnInput="OnInputHandler" Placeholder="Type to see input events..."/>
            <Paragraph Margin="Margin.Is0"><Strong>Last Input:</Strong> @_lastInputTime</Paragraph>
        </DemoSection>

        <DemoSection Title="Form Integration Example" Description="Field, FieldLabel, MemoInput with validation." Code="@(@"<Field>
    <FieldLabel For=""contactMessage"" RequiredIndicator=""true"">Message:</FieldLabel>
    <FieldBody>
        <MemoInput Id=""contactMessage"" @bind-Value=""_contactMessage"" Rows=""4"" Required=""true"" MaxLength=""500"" Placeholder=""Enter message...""/>
    </FieldBody>
</Field>")"
CodeLanguage="razor">
            <Paragraph FontWeight="FontWeight.Semibold">Contact Form</Paragraph>
            <Field>
                <FieldLabel For="contactMessage" RequiredIndicator="true">Message:</FieldLabel>
                <FieldBody>
                    <MemoInput Id="contactMessage" @bind-Value="_contactMessage" Rows="4" Required="true" MaxLength="500" Color="primary" Placeholder="Enter your message here..."/>
                </FieldBody>
            </Field>
            <Field>
                <FieldLabel For="additionalNotes">Additional Notes:</FieldLabel>
                <FieldBody>
                    <MemoInput Id="additionalNotes" @bind-Value="_additionalNotes" Rows="3" AutoResize="true" Color="secondary" Placeholder="Any additional notes..."/>
                </FieldBody>
            </Field>
            <Button Class="btn btn-primary" OnClick="SubmitForm">Submit</Button>
            <Paragraph Margin="Margin.Is0"><Strong>Form Status:</Strong> <Span class="@GetStatusClass()">@_formStatus</Span></Paragraph>
        </DemoSection>

        <DemoSection Title="Character Counter" Description="MaxLength with counter display." Code="@(@"<MemoInput @bind-Value=""_counterValue"" MaxLength=""200"" OnInput=""OnCounterInput"" Placeholder=""Type to see counter...""/>
<Div>@(_counterValue?.Length ?? 0)/200</Div>")"
CodeLanguage="razor">
            <MemoInput @bind-Value="_counterValue" MaxLength="200" OnInput="OnCounterInput" Placeholder="Type to see character counter..."/>
            <Div Class="@($"char-counter {GetCounterClass()}")">@(_counterValue?.Length ?? 0)/200</Div>
        </DemoSection>

        <DemoSection Title="Pre-filled Content" Description="Initial value and Load Sample Content." Code="@(@"<MemoInput @bind-Value=""_prefilledValue"" Rows=""6"" Color=""info"" Placeholder=""Pre-filled...""/>
<Button OnClick=""LoadSampleContent"">Load Sample Content</Button>")"
CodeLanguage="razor">
            <MemoInput @bind-Value="_prefilledValue" Rows="6" Color="info" Placeholder="This has pre-filled content..."/>
            <Button Class="btn btn-primary" OnClick="LoadSampleContent" Style="margin-top: 10px;">Load Sample Content</Button>
        </DemoSection>
    </Div>
</Div>

@code {

    private string? _basicValue;
    private string? _smallValue;
    private string? _largeValue;
    private string? _primaryValue;
    private string? _successValue;
    private string? _warningValue;
    private string? _dangerValue;
    private string? _rows2Value;
    private string? _rows5Value;
    private string? _rows8Value;
    private string? _autoResizeValue;
    private string? _requiredValue;
    private string? _maxLengthValue;
    private string? _minLengthValue;
    private string? _disabledValue = "This is disabled content";
    private string? _readOnlyValue = "This is read-only content";
    private string? _changeValue;
    private string? _inputValue;
    private string? _contactMessage;
    private string? _additionalNotes;
    private string? _counterValue;
    private string? _prefilledValue = "This is some pre-filled content that demonstrates how the MemoInput component can display existing text.";
    private string _formStatus = "Ready to submit";

    private DateTime _lastChangeTime;
    private DateTime _lastInputTime;

    protected override void OnInitialized()
    {
        Logger.LogInformation("MemoInputs demo page initialized");
    }

    private void OnChangeHandler(ChangeEventArgs e)
    {
        _lastChangeTime = DateTime.Now;
        Logger.LogInformation("MemoInput change event fired at {Time}", _lastChangeTime);
    }

    private void OnInputHandler(ChangeEventArgs e)
    {
        _lastInputTime = DateTime.Now;
        Logger.LogInformation("MemoInput input event fired at {Time}", _lastInputTime);
    }

    private void OnCounterInput(ChangeEventArgs e)
    {
        // This could be used for real-time validation or UI updates
        StateHasChanged();
    }

    private void SubmitForm()
    {
        var contactMessage = _contactMessage;

        if (contactMessage.IsNullOrWhiteSpace())
        {
            _formStatus = "Message is required!";
            return;
        }

        if (contactMessage.Length < 10)
        {
            _formStatus = "Message must be at least 10 characters long!";
            return;
        }

        _formStatus = $"Form submitted successfully at {DateTime.Now:HH:mm:ss}! Message: {contactMessage.Substring(0, Math.Min(50, contactMessage.Length))}...";

        // Reset form
        _contactMessage = string.Empty;
        _additionalNotes = string.Empty;
    }

    private void LoadSampleContent()
    {
        _prefilledValue = @"This is a sample of longer content that demonstrates how the MemoInput component handles multi-line text.

It includes:
- Multiple paragraphs
- Line breaks
- Various text formatting

The component automatically handles:
• Resizing
• Scrolling When needed
• Proper text wrapping

You can edit this content to see how the component behaves with different amounts of text.";
    }

    private string GetStatusClass()
    {
        return _formStatus switch
        {
            "Ready to submit" => "status-ready",
            var status when status.Contains("error", StringComparison.OrdinalIgnoreCase) => "status-error",
            var status when status.Contains("success", StringComparison.OrdinalIgnoreCase) => "status-success",
            _ => "status-ready"
        };
    }

    private string GetCounterClass()
    {
        var length = _counterValue?.Length ?? 0;
        return length switch
        {
            var l when l > 180 => "danger",
            var l when l > 160 => "warning",
            _ => ""
        };
    }

}
