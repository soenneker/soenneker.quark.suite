@page "/components/toast"

<PageTitle>Toast - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
            A succinct message that is displayed temporarily.
        </Paragraph>

        <div class="inline-flex w-full items-center gap-6 mb-4">
            <a data-active="true"
               class="relative inline-flex items-center justify-center gap-1 pt-1 pb-0.5 text-base font-medium text-muted-foreground transition-colors after:absolute after:inset-x-0 after:bottom-[-4px] after:h-0.5 after:bg-foreground after:opacity-0 after:transition-opacity hover:text-foreground data-[active=true]:text-foreground data-[active=true]:after:opacity-100"
               href="/components/toast">Radix UI</a>
            <a data-active="false"
               class="relative inline-flex items-center justify-center gap-1 pt-1 pb-0.5 text-base font-medium text-muted-foreground transition-colors after:absolute after:inset-x-0 after:bottom-[-4px] after:h-0.5 after:bg-foreground after:opacity-0 after:transition-opacity hover:text-foreground data-[active=true]:text-foreground data-[active=true]:after:opacity-100"
               href="/components/toast">Base UI</a>
        </div>

        <Paragraph Margin="Margin.Is0">
            The toast component has been deprecated. Use the <Anchor Href="sonner" Class="font-medium underline underline-offset-4">sonner</Anchor> component instead.
        </Paragraph>
    </Section>
</Div>
