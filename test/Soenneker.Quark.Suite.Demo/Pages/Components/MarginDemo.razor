@page "/margin-demo"

<PageTitle>Margin - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <DemoSection Title="Basic Size Examples" Description="Margin.Is0, Is1, Is3 and directional margins." Code="@(@"<Div Margin=""Margin.Is0"">No margin</Div>
<Div Margin=""Margin.Is1"">Small margin</Div>
<Div Margin=""Margin.Is3"">Medium margin</Div>
<Div Margin=""Margin.Is3.FromTop"">Top margin</Div>
<Div Margin=""Margin.Is2.FromBottom.Is4.FromTop"">Multiple margins</Div>")">
        <Row>
            <Column ColumnSize="ColumnSize.Is4.OnMd">
                <H4>S0 (0)</H4>
                <Div Margin="Margin.Is0" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">No margin</Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is4.OnMd">
                <H4>Is1 (0.25rem)</H4>
                <Div Margin="Margin.Is1" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">Small margin</Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is4.OnMd">
                <H4>Is3 (1rem)</H4>
                <Div Margin="Margin.Is3" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">Medium margin</Div>
            </Column>
        </Row>
        </DemoSection>
        <DemoSection Title="Fluent API - Directional Margins" Description="FromTop, FromRight, FromBottom, FromLeft." Code="@(@"<Div Margin=""Margin.Is3.FromTop"">Top</Div>
<Div Margin=""Margin.Is3.FromRight"">Right</Div>
<Div Margin=""Margin.Is3.FromBottom"">Bottom</Div>
<Div Margin=""Margin.Is3.FromLeft"">Left</Div>")">
        <Row>
            <Column ColumnSize="ColumnSize.Is3.OnMd">
                <H4>FromTop</H4>
                <Div Margin="Margin.Is3.FromTop" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Top margin
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is3.OnMd">
                <H4>FromRight</H4>
                <Div Margin="Margin.Is3.FromRight" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Right margin
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is3.OnMd">
                <H4>FromBottom</H4>
                <Div Margin="Margin.Is3.FromBottom" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Bottom margin
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is3.OnMd">
                <H4>FromLeft</H4>
                <Div Margin="Margin.Is3.FromLeft" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Left margin
                </Div>
            </Column>
        </Row>
        </DemoSection>

        <DemoSection Title="Fluent API - Axis Margins" Description="OnX (horizontal), OnY (vertical)." Code="@(@"<Div Margin=""Margin.Is3.OnX"">Horizontal</Div>
<Div Margin=""Margin.Is3.OnY"">Vertical</Div>")">
        <Row>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnX (Horizontal)</H4>
                <Div Margin="Margin.Is3.OnX" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Horizontal margins
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnY (Vertical)</H4>
                <Div Margin="Margin.Is3.OnY" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Vertical margins
                </Div>
            </Column>
        </Row>
        </DemoSection>

        <DemoSection Title="Fluent API - Auto Margins" Description="Auto, Auto.OnX, Auto.OnY." Code="@(@"<Div Margin=""Margin.Auto"">Auto</Div>
<Div Margin=""Margin.Auto.OnX"">Auto horizontal</Div>
<Div Margin=""Margin.Auto.OnY"">Auto vertical</Div>")">
        <Row>
            <Column ColumnSize="ColumnSize.Is4.OnMd">
                <H4>Auto</H4>
                <Div Margin="Margin.Auto" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Auto margin
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is4.OnMd">
                <H4>Auto OnX</H4>
                <Div Margin="Margin.Auto.OnX" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Auto horizontal
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is4.OnMd">
                <H4>Auto OnY</H4>
                <Div Margin="Margin.Auto.OnY" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    Auto vertical
                </Div>
            </Column>
        </Row>
        </DemoSection>

        <DemoSection Title="Fluent API - Chaining Examples" Description="Chain FromTop, FromBottom, OnX, OnY, Auto." Code="@(@"<Div Margin=""Margin.Is1.FromTop.Is3.FromBottom"">mt-1 mb-3</Div>
<Div Margin=""Margin.Is2.OnX.Is4.OnY"">mx-2 my-4</Div>
<Div Margin=""Margin.Auto.FromStart.Is2.FromEnd"">ms-auto me-2</Div>")">
        <Row>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Is1.FromTop.Is3.FromBottom</H4>
                <Div Margin="Margin.Is1.FromTop.Is3.FromBottom" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.Is1.FromTop.Is3.FromBottom</code><br/>
                    <small>mt-1 mb-3</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Is2.OnX.Is4.OnY</H4>
                <Div Margin="Margin.Is2.OnX.Is4.OnY" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.Is2.OnX.Is4.OnY</code><br/>
                    <small>mx-2 my-4</small>
                </Div>
            </Column>
        </Row>
        
        <Row Margin="Margin.Is3.FromTop">
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Is0.FromTop.Is5.FromBottom</H4>
                <Div Margin="Margin.Is0.FromTop.Is5.FromBottom" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.Is0.FromTop.Is5.FromBottom</code><br/>
                    <small>mt-0 mb-5</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Auto.FromStart.Is2.FromEnd</H4>
                <Div Margin="Margin.Auto.FromStart.Is2.FromEnd" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.Auto.FromStart.Is2.FromEnd</code><br/>
                    <small>ms-auto me-2</small>
                </Div>
            </Column>
        </Row>
        </DemoSection>

        <DemoSection Title="Responsive Margins" Description="OnBase, OnMd, OnLg, OnXl, OnXxl." Code="@(@"<Div Margin=""Margin.OnBase.Is1"">m-1</Div>
<Div Margin=""Margin.OnMd.Is3"">sm-m-3</Div>
<Div Margin=""Margin.OnLg.Is4"">lg-m-4</Div>
<Div Margin=""Margin.OnXxl.Is5"">xxl-m-5</Div>")">
        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is4.FromBottom">Apply different margins based on device screen sizes for optimal responsive design.</Paragraph>
        <Row>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnBase</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Portrait phones (&lt; 576px)</Paragraph>
                <Div Margin="Margin.Is0.OnBase.Is1" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnBase.Is1</code><br/>
                    <small>m-1</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnMobile</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Landscape phones (≥ 576px)</Paragraph>
                <Div Margin="Margin.Is0.OnMd.Is3" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnMd.Is3</code><br/>
                    <small>sm-m-3</small>
                </Div>
            </Column>
        </Row>
        
        <Row Margin="Margin.Is3.FromTop">
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnTablet</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Tablets (≥ 768px)</Paragraph>
                <Div Margin="Margin.Is0.OnMd.Is2" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnMd.Is2</code><br/>
                    <small>md-m-2</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnLaptop</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Laptops (≥ 992px)</Paragraph>
                <Div Margin="Margin.Is0.OnLg.Is4" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnLg.Is4</code><br/>
                    <small>lg-m-4</small>
                </Div>
            </Column>
        </Row>
        
        <Row Margin="Margin.Is3.FromTop">
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnDesktop</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Desktops (≥ 1200px)</Paragraph>
                <Div Margin="Margin.Is0.OnXl.Is3" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnXl.Is3</code><br/>
                    <small>xl-m-3</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>OnXxl</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Larger desktops (≥ 1400px)</Paragraph>
                <Div Margin="Margin.Is0.OnXxl.Is5" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnXxl.Is5</code><br/>
                    <small>xxl-m-5</small>
                </Div>
            </Column>
        </Row>
        </DemoSection>

        <DemoSection Title="Responsive Chaining Examples" Description="Chain breakpoints and directions (e.g. OnBase.Is4.OnLg)." Code="@(@"<Div Margin=""Margin.OnBase.Is3.OnLg.Is4"">sm-m-3 lg-m-4</Div>
<Div Margin=""Margin.OnBase.Is2.OnMd.Is3.OnLg.Is4"">Progressive</Div>
<Div Margin=""Margin.OnBase.Is3.FromTop.OnLg.Is4.FromBottom"">Directional responsive</Div>")">
        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is4.FromBottom">Chain different margin sizes for different device types to create adaptive layouts.</Paragraph>
        <Row>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Mobile to Laptop</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Small margin on mobile, larger on laptop</Paragraph>
                <Div Margin="Margin.Is3.OnLg.Is4" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnBase.Is3.OnLg.Is4</code><Br />
                    <small>sm-m-3 lg-m-4</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Progressive Scaling</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Increasing margins across device sizes</Paragraph>
                <Div Margin="Margin.Is2.OnMd.Is3.OnLg.Is4" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnBase.Is2.OnMd.Is3.OnLg.Is4</code><Br />
                    <small>sm-m-2 md-m-3 lg-m-4</small>
                </Div>
            </Column>
        </Row>
        
        <Row Margin="Margin.Is3.FromTop">
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Directional Responsive</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Different margins for different sides on different devices</Paragraph>
                <Div Margin="Margin.Is3.FromTop.OnLg.Is4.FromBottom" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnBase.Is3.FromTop.OnLg.Is4.FromBottom</code><Br />
                    <small>sm-mt-3 lg-mb-4</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Axis Responsive</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Horizontal on mobile, vertical on laptop</Paragraph>
                <Div Margin="Margin.Is2.OnX.OnLg.Is3.OnY" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnBase.Is2.OnX.OnLg.Is3.OnY</code><Br />
                    <small>sm-mx-2 lg-my-3</small>
                </Div>
            </Column>
        </Row>
        
        <Row Margin="Margin.Is3.FromTop">
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Phone to Wide Screen</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Minimal on phone, generous on wide screens</Paragraph>
                <Div Margin="Margin.Is1.OnXxl.Is5" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnBase.Is1.OnXxl.Is5</code><Br />
                    <small>m-1 xxl-m-5</small>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Laptop to Desktop</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Medium on laptop, large on desktop</Paragraph>
                <Div Margin="Margin.Is0.OnLg.Is2.OnXl.Is4" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin.OnLg.Is2.OnXl.Is4</code><br/>
                    <small>lg-m-2 xl-m-4</small>
                </Div>
            </Column>
        </Row>
        </DemoSection>

        <DemoSection Title="Custom CSS and String Usage" Description="Fluent API, CSS string, or class string for Margin." Code="@(@"<Div Margin=""margin-top: 2rem; margin-bottom: 1rem;"">CSS string</Div>
<Div Margin=""mt-4 mb-2"">Class string</Div>
<Div Margin=""Margin.Is3.FromTop.Is2.FromBottom"">Fluent API</Div>")">
        <Paragraph TextColor="TextColor.Muted" Margin="Margin.Is4.FromBottom">You can use both the fluent API and custom strings for maximum flexibility.</Paragraph>
        <Row>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Custom CSS String</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Direct CSS style string</Paragraph>
                <Div Margin="@("margin-top: 2rem; margin-bottom: 1rem;")" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin="@("margin-top: 2rem; margin-bottom: 1rem;")"</code>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Custom CSS Class</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Direct CSS class string</Paragraph>
                <Div Margin="@("mt-4 mb-2")" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin="@("mt-4 mb-2")"</code>
                </Div>
            </Column>
        </Row>
        
        <Row Margin="Margin.Is3.FromTop">
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Fluent API</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Using the fluent API</Paragraph>
                <Div Margin="@("30px")" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light">
                    <code>Margin="Margin.Is3.FromTop.Is2.FromBottom"</code>
                </Div>
            </Column>
            <Column ColumnSize="ColumnSize.Is6.OnMd">
                <H4>Mixed Usage</H4>
                <Paragraph TextColor="TextColor.Muted" Class="small">Fluent API with custom CSS</Paragraph>
                <Div Margin="Margin.Is2" Border="Border.Is1" Padding="Padding.Is2" BackgroundColor="BackgroundColor.Light" Style="margin-top: 3rem;">
                    <code>Margin="Margin.OnBase.Is2" + Style="margin-top: 3rem;"</code>
                </Div>
            </Column>
        </Row>
        </DemoSection>
    </Div>
</Div>

<style>
    .border {
        border: 1px solid #dee2e6;
        border-radius: 0.25rem;
    }
    
    .q-sidebar-bg {
        background-color: var(--muted, #f1f5f9);
    }
    
    .text-center {
        text-align: center;
    }
    
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 15px;
    }
    
    .row {
        display: flex;
        flex-wrap: wrap;
        margin: 0 -15px;
    }
    
    .col-md-2, .col-md-3, .col-md-4, .col-md-6 {
        padding: 0 15px;
        margin-bottom: 1rem;
    }
    
    .col-md-2 { flex: 0 0 16.666667%; max-width: 16.666667%; }
    .col-md-3 { flex: 0 0 25%; max-width: 25%; }
    .col-md-4 { flex: 0 0 33.333333%; max-width: 33.333333%; }
    .col-md-6 { flex: 0 0 50%; max-width: 50%; }
    
    .mt-4 { margin-top: 1.5rem; }
    .mb-4 { margin-bottom: 1.5rem; }
    .p-1 { padding: 0.25rem; }
    .p-2 { padding: 0.5rem; }
    
    pre {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 0.25rem;
        padding: 1rem;
        font-size: 0.875rem;
    }
    
    code {
        color: #e83e8c;
        font-size: 0.875rem;
    }
</style>
