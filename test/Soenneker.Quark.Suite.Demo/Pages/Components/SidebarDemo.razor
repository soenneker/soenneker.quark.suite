@page "/sidebar"

<PageTitle>Sidebar - Quark Suite</PageTitle>

<Div class="mx-auto flex w-full max-w-7xl flex-col gap-10">
    <Section Space="Space.Y.Is3">
        <Div Space="Space.Y.Is2">
            <H1 class="text-3xl font-semibold tracking-tight">Sidebar</H1>
            <Paragraph class="max-w-3xl text-sm text-muted-foreground">
                The sidebar demo now focuses on the reusable shell patterns instead of stacking multiple competing examples. The important knobs are desktop open
                state, separate mobile state, icon collapse, and the new full-screen mobile mode for docs-style navigation.
            </Paragraph>
        </Div>
        <Div class="flex flex-wrap gap-2 text-xs">
            <Span class="rounded-full border border-border bg-background px-3 py-1 text-foreground">Controlled desktop state</Span>
            <Span class="rounded-full border border-border bg-background px-3 py-1 text-foreground">Independent mobile state</Span>
            <Span class="rounded-full border border-border bg-background px-3 py-1 text-foreground">Icon collapse</Span>
            <Span class="rounded-full border border-border bg-background px-3 py-1 text-foreground">Full-screen mobile mode</Span>
        </Div>
    </Section>

    <Section Space="Space.Y.Is4">
        <Div Space="Space.Y.Is1">
            <H2 class="text-xl font-semibold">App Shell</H2>
            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                A single realistic workspace sidebar with nested items, badges, rail collapse, and a content area that stays readable alongside the docs layout.
            </Paragraph>
        </Div>

        <Div class="overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
            <SidebarProvider Open="_appSidebarOpen" OpenChanged="OnAppSidebarOpenChanged" CookieKey="quark-sidebar-demo" Class="h-[680px]">
                <Sidebar Collapsible="SidebarCollapsible.Icon">
                    <SidebarHeader>
                        <Anchor To="" class="flex items-center gap-2 rounded-lg border border-transparent px-2 py-1.5 transition-colors hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
                            <Span class="flex aspect-square size-8 items-center justify-center rounded-lg bg-sidebar-primary text-sidebar-primary-foreground">
                                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M3 11.5 12 4l9 7.5" />
                                    <path d="M5 10.5V20h14v-9.5" />
                                </svg>
                            </Span>
                            <Div class="grid flex-1 text-left text-sm leading-tight group-data-[collapsible=icon]:hidden">
                                <Span class="truncate font-semibold">Acme Control</Span>
                                <Span class="truncate text-xs text-sidebar-foreground/70">Enterprise workspace</Span>
                            </Div>
                        </Anchor>
                        <SidebarInput Placeholder="Search commands..." Type="search" />
                    </SidebarHeader>

                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarGroupLabel>Platform</SidebarGroupLabel>
                            <SidebarGroupAction title="Create workspace">
                                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 5v14" />
                                    <path d="M5 12h14" />
                                </svg>
                            </SidebarGroupAction>
                            <SidebarGroupContent>
                                <SidebarMenu>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton To="" Match="NavLinkMatch.All" Tooltip="Overview">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M3 11.5 12 4l9 7.5" />
                                                <path d="M5 10.5V20h14v-9.5" />
                                            </svg>
                                            <Span>Overview</Span>
                                        </SidebarMenuButton>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton To="components" Tooltip="Components">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="3" width="7" height="7" rx="1.5" />
                                                <rect x="14" y="3" width="7" height="7" rx="1.5" />
                                                <rect x="3" y="14" width="7" height="7" rx="1.5" />
                                                <rect x="14" y="14" width="7" height="7" rx="1.5" />
                                            </svg>
                                            <Span>Components</Span>
                                        </SidebarMenuButton>
                                        <SidebarMenuBadge>84</SidebarMenuBadge>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton Open="_workspaceOpen" OnClick="ToggleWorkspaceMenu" Tooltip="Workspace">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M4 6h16" />
                                                <path d="M4 12h10" />
                                                <path d="M4 18h7" />
                                            </svg>
                                            <Span>Workspace</Span>
                                            <svg class="ml-auto size-4 transition-transform duration-200 @(_workspaceOpen ? "rotate-90" : string.Empty)" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="m9 18 6-6-6-6" />
                                            </svg>
                                        </SidebarMenuButton>
                                        <SidebarMenuAction ShowOnHover="true" title="New workflow">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M12 5v14" />
                                                <path d="M5 12h14" />
                                            </svg>
                                        </SidebarMenuAction>
                                        @if (_workspaceOpen)
                                        {
                                            <SidebarMenuSub>
                                                <SidebarMenuSubItem>
                                                    <SidebarMenuSubButton To="fields">Automation Studio</SidebarMenuSubButton>
                                                </SidebarMenuSubItem>
                                                <SidebarMenuSubItem>
                                                    <SidebarMenuSubButton To="input-demo">Agent Inbox</SidebarMenuSubButton>
                                                </SidebarMenuSubItem>
                                                <SidebarMenuSubItem>
                                                    <SidebarMenuSubButton To="sidebar" Active="true">Sidebar Revamp</SidebarMenuSubButton>
                                                </SidebarMenuSubItem>
                                            </SidebarMenuSub>
                                        }
                                    </SidebarMenuItem>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton To="tables-basic" Tooltip="Analytics">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M4 19h16" />
                                                <path d="M7 16V8" />
                                                <path d="M12 16V5" />
                                                <path d="M17 16v-3" />
                                            </svg>
                                            <Span>Analytics</Span>
                                        </SidebarMenuButton>
                                        <SidebarMenuBadge>12</SidebarMenuBadge>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarGroupContent>
                        </SidebarGroup>

                        <SidebarSeparator />

                        <SidebarGroup>
                            <SidebarGroupLabel>Projects</SidebarGroupLabel>
                            <SidebarGroupContent>
                                <SidebarMenu>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton To="cards" Tooltip="Design system">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M12 3 4 7v10l8 4 8-4V7l-8-4Z" />
                                                <path d="m4 7 8 4 8-4" />
                                                <path d="M12 11v10" />
                                            </svg>
                                            <Span>Design System</Span>
                                        </SidebarMenuButton>
                                        <SidebarMenuAction ShowOnHover="true" title="Share project">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <circle cx="18" cy="5" r="3" />
                                                <circle cx="6" cy="12" r="3" />
                                                <circle cx="18" cy="19" r="3" />
                                                <path d="m8.7 10.7 6.6-3.4" />
                                                <path d="m8.7 13.3 6.6 3.4" />
                                            </svg>
                                        </SidebarMenuAction>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton To="sheets" Tooltip="Release desk">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="5" width="18" height="14" rx="2" />
                                                <path d="M8 3v4" />
                                                <path d="M16 3v4" />
                                                <path d="M3 10h18" />
                                            </svg>
                                            <Span>Release Desk</Span>
                                        </SidebarMenuButton>
                                        <SidebarMenuBadge>3</SidebarMenuBadge>
                                    </SidebarMenuItem>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton To="treeview" Tooltip="Roadmap">
                                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                <path d="M8 6h8" />
                                                <path d="M8 12h10" />
                                                <path d="M8 18h6" />
                                                <path d="M4 6h.01" />
                                                <path d="M4 12h.01" />
                                                <path d="M4 18h.01" />
                                            </svg>
                                            <Span>Roadmap</Span>
                                        </SidebarMenuButton>
                                    </SidebarMenuItem>
                                </SidebarMenu>
                            </SidebarGroupContent>
                        </SidebarGroup>
                    </SidebarContent>

                    <SidebarFooter>
                        <SidebarMenu>
                            <SidebarMenuItem>
                                <SidebarMenuButton Variant="SidebarMenuButtonVariant.Outline" Tooltip="Jake Stevenson">
                                    <Span class="flex size-7 items-center justify-center rounded-lg bg-sidebar-accent text-xs font-semibold text-sidebar-accent-foreground">JS</Span>
                                    <Div class="grid flex-1 text-left text-sm leading-tight group-data-[collapsible=icon]:hidden">
                                        <Span class="truncate font-medium">Jake Stevenson</Span>
                                        <Span class="truncate text-xs text-sidebar-foreground/70">Product Engineering</Span>
                                    </Div>
                                </SidebarMenuButton>
                            </SidebarMenuItem>
                        </SidebarMenu>
                    </SidebarFooter>

                    <SidebarRail />
                </Sidebar>

                <SidebarInset>
                    <Div class="sticky top-0 z-10 flex h-16 shrink-0 items-center gap-3 border-b bg-background/95 px-4 backdrop-blur supports-[backdrop-filter]:bg-background/80">
                        <SidebarTrigger />
                        <Div class="min-w-0">
                            <Paragraph class="truncate text-sm font-medium">Sidebar configuration surface</Paragraph>
                            <Paragraph class="truncate text-xs text-muted-foreground">Use desktop state, mobile state, and collapse mode independently.</Paragraph>
                        </Div>
                        <Div class="ml-auto hidden items-center gap-2 md:flex">
                            <Span class="rounded-full bg-muted px-2.5 py-1 text-xs text-muted-foreground">Cmd/Ctrl + B</Span>
                            <Button Type="ButtonType.Button" class="rounded-md border border-border px-3 py-2 text-sm transition-colors hover:bg-accent">Share</Button>
                            <Button Type="ButtonType.Button" class="rounded-md bg-primary px-3 py-2 text-sm text-primary-foreground transition-colors hover:opacity-90">Deploy</Button>
                        </Div>
                    </Div>

                    <Div class="flex-1 overflow-auto p-6">
                        <Grid Gap="Gap.Is4" Class="xl:grid-cols-[1.3fr_0.9fr]">
                            <Div Space="Space.Y.Is4">
                                <Div class="rounded-xl border border-border bg-card p-6">
                                    <Div Space="Space.Y.Is2">
                                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Reusable shell</Paragraph>
                                        <H3 class="text-2xl font-semibold tracking-tight">One sidebar demo, not four overlapping ones</H3>
                                        <Paragraph class="max-w-2xl text-sm text-muted-foreground">
                                            This preview keeps the canonical app-shell example, while the docs layout itself now demonstrates the static-desktop plus
                                            full-screen-mobile configuration using the same sidebar component.
                                        </Paragraph>
                                    </Div>
                                    <Grid Columns="Columns.Is1.OnSm.Is3" Gap="Gap.Is3" Class="mt-6">
                                        <Div class="rounded-lg border border-border bg-background p-4">
                                            <Paragraph class="text-xs uppercase tracking-wide text-muted-foreground">Desktop mode</Paragraph>
                                            <Paragraph class="mt-2 text-lg font-semibold">Controlled</Paragraph>
                                        </Div>
                                        <Div class="rounded-lg border border-border bg-background p-4">
                                            <Paragraph class="text-xs uppercase tracking-wide text-muted-foreground">Collapse</Paragraph>
                                            <Paragraph class="mt-2 text-lg font-semibold">Icon rail</Paragraph>
                                        </Div>
                                        <Div class="rounded-lg border border-border bg-background p-4">
                                            <Paragraph class="text-xs uppercase tracking-wide text-muted-foreground">Mobile mode</Paragraph>
                                            <Paragraph class="mt-2 text-lg font-semibold">Separate sheet</Paragraph>
                                        </Div>
                                    </Grid>
                                </Div>

                                <Div class="rounded-xl border border-border bg-card p-6">
                                    <H3 class="text-base font-semibold">Why this shape is easier to copy</H3>
                                    <UnorderedList Class="mt-4 space-y-3 text-sm text-muted-foreground">
                                        <UnorderedListItem Display="Display.Flex" Gap="Gap.Is3">
                                            <Span class="mt-1 size-2 rounded-full bg-primary"></Span>
                                            The demo shows one primary application shell instead of introducing extra sidebars that distract from the API.
                                        </UnorderedListItem>
                                        <UnorderedListItem Display="Display.Flex" Gap="Gap.Is3">
                                            <Span class="mt-1 size-2 rounded-full bg-primary"></Span>
                                            Route-aware menu buttons, nested submenus, and the collapse rail are all exercised in one place.
                                        </UnorderedListItem>
                                        <UnorderedListItem Display="Display.Flex" Gap="Gap.Is3">
                                            <Span class="mt-1 size-2 rounded-full bg-primary"></Span>
                                            The docs layout now uses the same component for its mobile navigation, which makes the copy path much clearer.
                                        </UnorderedListItem>
                                    </UnorderedList>
                                </Div>
                            </Div>

                            <Div Space="Space.Y.Is4">
                                <Div class="rounded-xl border border-border bg-card p-6">
                                    <H3 class="text-base font-semibold">Key parameters</H3>
                                    <Div class="mt-4 flex flex-wrap gap-2 text-xs">
                                        <Span class="rounded-full border border-border bg-background px-3 py-1 font-medium">Open / OpenChanged</Span>
                                        <Span class="rounded-full border border-border bg-background px-3 py-1 font-medium">OpenMobile / OpenMobileChanged</Span>
                                        <Span class="rounded-full border border-border bg-background px-3 py-1 font-medium">Collapsible</Span>
                                        <Span class="rounded-full border border-border bg-background px-3 py-1 font-medium">SidebarWidthMobile</Span>
                                        <Span class="rounded-full border border-border bg-background px-3 py-1 font-medium">MobileMode</Span>
                                        <Span class="rounded-full border border-border bg-background px-3 py-1 font-medium">MobileClass</Span>
                                    </Div>
                                </Div>
                            </Div>
                        </Grid>
                    </Div>
                </SidebarInset>
            </SidebarProvider>
        </Div>
    </Section>

    <Section>
        <Grid Gap='Gap.Token("6")' Class="lg:grid-cols-[minmax(0,1fr)_18rem]">
        <Div Space="Space.Y.Is4">
            <Div Space="Space.Y.Is1">
                <H2 class="text-xl font-semibold">Full-Screen Mobile Docs Pattern</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    This preview forces mobile mode and uses `Collapsible.None` plus `MobileMode.FullScreen`, with a mobile-only top slot for the shadcn-style menu shell.
                </Paragraph>
            </Div>

            <Div class="overflow-hidden rounded-2xl border border-border bg-background shadow-sm">
                <SidebarProvider IsMobile="true"
                                 OpenMobile="_mobileSidebarOpen"
                                 OpenMobileChanged="OnMobileSidebarOpenChanged"
                                 SidebarWidthMobile="100vw"
                                 Class="h-[320px]">
                    <Sidebar Collapsible="SidebarCollapsible.None"
                             MobileMode="SidebarMobileMode.FullScreen"
                             MobileShowCloseButton="false"
                             MobileClass="bg-background">
                        <MobileContent>
                            <Div class="flex min-h-0 flex-1 flex-col">
                                <Div class="border-b bg-background px-6 py-4">
                                    <Div class="flex items-center gap-3">
                                        <SidebarTrigger Class="size-8 rounded-md p-0 hover:bg-accent">
                                            <svg class="size-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                                <path d="M18 6 6 18" />
                                                <path d="m6 6 12 12" />
                                            </svg>
                                            <Span class="sr-only">Close menu</Span>
                                        </SidebarTrigger>
                                        <Paragraph class="text-base font-semibold">Menu</Paragraph>
                                    </Div>

                                    <Div class="mt-6">
                                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.MutedForeground">Menu</Paragraph>
                                        <Div class="mt-4 flex flex-col gap-1">
                                            <Anchor To="" class="inline-flex h-12 items-center px-0 text-3xl font-medium text-foreground">Home</Anchor>
                                            <Anchor To="components" class="inline-flex h-12 items-center px-0 text-3xl font-medium text-foreground">Docs</Anchor>
                                            <Anchor To="sidebar" class="inline-flex h-12 items-center px-0 text-3xl font-medium text-foreground">Components</Anchor>
                                        </Div>
                                    </Div>
                                </Div>

                                <Div class="min-h-0 flex-1 overflow-y-auto px-6 py-5">
                                    <Section Space="Space.Y.Is3">
                                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium" TextColor="TextColor.MutedForeground">Sections</Paragraph>
                                        <Div class="flex flex-col gap-1">
                                            <Anchor To="" class="inline-flex items-center rounded-md px-2.5 py-2 text-base font-medium text-foreground">Introduction</Anchor>
                                            <Anchor To="sidebar" class="inline-flex items-center rounded-md bg-accent px-2.5 py-2 text-base font-medium text-foreground">Components</Anchor>
                                            <Anchor To="validation-summary" class="inline-flex items-center rounded-md px-2.5 py-2 text-base font-medium text-foreground">Validation</Anchor>
                                        </Div>
                                    </Section>
                                </Div>
                            </Div>
                        </MobileContent>
                        <ChildContent>
                            <SidebarHeader Class="border-b px-6 py-4">
                                <Div class="pr-10">
                                    <Paragraph class="text-sm font-semibold">Documentation</Paragraph>
                                    <Paragraph class="text-xs text-sidebar-foreground/70">Static on desktop, full-screen on mobile.</Paragraph>
                                </Div>
                            </SidebarHeader>
                            <SidebarContent Class="px-4 pb-6">
                                <SidebarGroup Class="pt-2">
                                    <SidebarGroupLabel>Navigate</SidebarGroupLabel>
                                    <SidebarGroupContent>
                                        <SidebarMenu Class="gap-0.5">
                                            <SidebarMenuItem>
                                                <SidebarMenuButton To="" Match="NavLinkMatch.All">
                                                    <Span>Overview</Span>
                                                </SidebarMenuButton>
                                            </SidebarMenuItem>
                                            <SidebarMenuItem>
                                                <SidebarMenuButton To="sidebar" Active="true">
                                                    <Span>Sidebar</Span>
                                                </SidebarMenuButton>
                                            </SidebarMenuItem>
                                            <SidebarMenuItem>
                                                <SidebarMenuButton To="sheets">
                                                    <Span>Sheets</Span>
                                                </SidebarMenuButton>
                                            </SidebarMenuItem>
                                        </SidebarMenu>
                                    </SidebarGroupContent>
                                </SidebarGroup>
                            </SidebarContent>
                        </ChildContent>
                    </Sidebar>

                    <SidebarInset>
                        <Div class="flex h-14 items-center gap-3 border-b bg-background px-4">
                            <SidebarTrigger />
                            <Div class="min-w-0">
                                <Paragraph class="truncate text-sm font-medium">Launch mobile navigation</Paragraph>
                                <Paragraph class="truncate text-xs text-muted-foreground">This opens a viewport-covering sidebar, not a narrow sheet.</Paragraph>
                            </Div>
                        </Div>
                        <Div class="flex-1 p-6">
                            <Div class="rounded-xl border border-dashed border-border bg-card p-6 text-sm text-muted-foreground">
                                Open the sidebar to see the full-screen mobile presentation that can now be configured directly from `Sidebar`.
                            </Div>
                        </Div>
                    </SidebarInset>
                </SidebarProvider>
            </Div>
        </Div>

        <Div class="rounded-2xl border border-border bg-card p-6">
            <H3 class="text-base font-semibold">Config used here</H3>
            <UnorderedList Class="mt-4 space-y-3 text-sm text-muted-foreground">
                <UnorderedListItem Display="Display.Flex" Gap="Gap.Is3">
                    <Span class="mt-1 size-2 rounded-full bg-primary"></Span>
                    `Collapsible=None` keeps the desktop sidebar fixed.
                </UnorderedListItem>
                <UnorderedListItem Display="Display.Flex" Gap="Gap.Is3">
                    <Span class="mt-1 size-2 rounded-full bg-primary"></Span>
                    `MobileMode=FullScreen` promotes the mobile rendering into a viewport-covering sidebar.
                </UnorderedListItem>
                <UnorderedListItem Display="Display.Flex" Gap="Gap.Is3">
                    <Span class="mt-1 size-2 rounded-full bg-primary"></Span>
                    `SidebarWidthMobile="100vw"` makes the mobile width explicit.
                </UnorderedListItem>
                <UnorderedListItem Display="Display.Flex" Gap="Gap.Is3">
                    <Span class="mt-1 size-2 rounded-full bg-primary"></Span>
                        `MobileTopContent` lets you inject a dedicated shadcn-style mobile menu header and quick links.
                </UnorderedListItem>
            </UnorderedList>
        </Div>
        </Grid>
    </Section>
</Div>

@code {
    private bool _appSidebarOpen = true;
    private bool _workspaceOpen = true;
    private bool _mobileSidebarOpen;

    private Task OnAppSidebarOpenChanged(bool value)
    {
        _appSidebarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnMobileSidebarOpenChanged(bool value)
    {
        _mobileSidebarOpen = value;
        return Task.CompletedTask;
    }

    private Task ToggleWorkspaceMenu(MouseEventArgs _)
    {
        _workspaceOpen = !_workspaceOpen;
        return Task.CompletedTask;
    }
}
