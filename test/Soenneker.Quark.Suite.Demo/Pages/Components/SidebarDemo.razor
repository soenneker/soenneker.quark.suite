@page "/sidebar"

<PageTitle>Sidebar - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Section Space="Space.Y.Is3">
        <H1 TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold" Tracking="Tracking.Tight">Sidebar</H1>
        <Paragraph MaxWidth="MaxWidth.Is3xl" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
            A composable, themeable, and customizable sidebar component. The examples below start with the baseline shell, then cover the core primitives,
            controlled state, and mobile-specific patterns.
        </Paragraph>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Demo"
                     Description="The base provider plus sidebar plus inset shell."
                     Code="@UsageCode"
                     CodeLanguage="razor">
            <Div Width="Width.IsFull" Overflow="Overflow.Hidden" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background">
                <SidebarProvider Open="_usageSidebarOpen" OpenChanged="OnUsageSidebarOpenChanged" Class="h-[24rem]">
                    <Sidebar>
                        <SidebarHeader>
                            <Paragraph Padding="Padding.Is2.OnX" TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Acme Inc.</Paragraph>
                        </SidebarHeader>
                        <SidebarContent>
                            <SidebarGroup>
                                <SidebarGroupLabel>Application</SidebarGroupLabel>
                                <SidebarGroupContent>
                                    <SidebarMenu>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton AsChild="true" Active="true" Tooltip="Home">
                                                <Anchor To="">
                                                    <Icon Name="LucideIcon.House" BoxSize="Size.Is4" />
                                                    <Span>Home</Span>
                                                </Anchor>
                                            </SidebarMenuButton>
                                        </SidebarMenuItem>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton AsChild="true" Tooltip="Messages">
                                                <Anchor To="dropdowns">
                                                    <Icon Name="LucideIcon.Mail" BoxSize="Size.Is4" />
                                                    <Span>Messages</Span>
                                                </Anchor>
                                            </SidebarMenuButton>
                                        </SidebarMenuItem>
                                    </SidebarMenu>
                                </SidebarGroupContent>
                            </SidebarGroup>
                        </SidebarContent>
                        <SidebarFooter>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton AsChild="true" Tooltip="Settings">
                                        <Anchor To="cards">
                                            <Icon Name="LucideIcon.Cog" BoxSize="Size.Is4" />
                                            <Span>Settings</Span>
                                        </Anchor>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarFooter>
                        <SidebarRail />
                    </Sidebar>

                    <SidebarInset>
                        <Div Display="Display.Flex" Height='Height.Token("14")' ItemsAlign="Items.Center" Gap="Gap.Is3" Border="Border.Is1.FromBottom" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4.OnX">
                            <SidebarTrigger />
                            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">SidebarTrigger stays connected to the provider.</Paragraph>
                        </Div>
                        <Div Padding="Padding.Is6" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                            Place your application content inside <Code>SidebarInset</Code> when the layout should flow beside the sidebar.
                        </Div>
                    </SidebarInset>
                </SidebarProvider>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <Div Space="Space.Y.Is2">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Composition</H2>
            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                Use the following structure to build a sidebar layout.
            </Paragraph>
        </Div>

        <CodeEditor ReadOnly="true"
                    Language="text"
                    AutoHeight="true"
                    MinLines="12"
                    Text="@SidebarCompositionCode"
                    Class="w-full rounded-xl border border-border bg-muted/20 text-sm" />

        <UnorderedList Space="Space.Y.Is2" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
            <UnorderedListItem>`SidebarProvider` owns the shared open, mobile, and keyboard-shortcut state.</UnorderedListItem>
            <UnorderedListItem>`Sidebar`, `SidebarHeader`, `SidebarContent`, and `SidebarFooter` form the actual shell.</UnorderedListItem>
            <UnorderedListItem>`SidebarMenuButton`, `SidebarMenuAction`, `SidebarMenuBadge`, and `SidebarMenuSub` cover the menu composition.</UnorderedListItem>
            <UnorderedListItem>`SidebarInset` and `SidebarTrigger` keep the main content area wired to the same provider.</UnorderedListItem>
        </UnorderedList>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Composed Menu"
                     Description="This preview exercises the core menu composition: button-as-child links, group action, menu action, badge, submenu, footer, and rail."
                     Code="@ComposedMenuCode"
                     CodeLanguage="razor">
            <Div Width="Width.IsFull" Overflow="Overflow.Hidden" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background">
                <SidebarProvider Open="_composedSidebarOpen" OpenChanged="OnComposedSidebarOpenChanged" Class="h-[31rem]">
                    <Sidebar Collapsible="SidebarCollapsible.Icon">
                        <SidebarHeader>
                            <Paragraph Padding="Padding.Is2.OnX" TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Workspace</Paragraph>
                            <SidebarInput Placeholder="Search..." Type="search" />
                        </SidebarHeader>

                        <SidebarContent>
                            <SidebarGroup>
                                <SidebarGroupLabel>Platform</SidebarGroupLabel>
                                <SidebarGroupAction AsChild="true">
                                    <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs">
                                        <Icon Name="LucideIcon.Plus" BoxSize="Size.Is4" />
                                        <Span class="sr-only">Add project</Span>
                                    </Button>
                                </SidebarGroupAction>
                                <SidebarGroupContent>
                                    <SidebarMenu>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton AsChild="true" Active="true" Tooltip="Dashboard">
                                                <Anchor To="">
                                                    <Icon Name="LucideIcon.House" BoxSize="Size.Is4" />
                                                    <Span>Dashboard</Span>
                                                </Anchor>
                                            </SidebarMenuButton>
                                        </SidebarMenuItem>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton Open="_workspaceMenuOpen" OnClick="ToggleWorkspaceMenu" Tooltip="Projects">
                                                <Icon Name="LucideIcon.Folder" BoxSize="Size.Is4" />
                                                <Span>Projects</Span>
                                                <Icon Name="LucideIcon.ChevronRight" Class="@($"ml-auto size-4 transition-transform {(_workspaceMenuOpen ? "rotate-90" : string.Empty)}")" />
                                            </SidebarMenuButton>
                                            <SidebarMenuAction AsChild="true" ShowOnHover="true">
                                                <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs">
                                                    <Icon Name="LucideIcon.Plus" BoxSize="Size.Is4" />
                                                    <Span class="sr-only">Create project</Span>
                                                </Button>
                                            </SidebarMenuAction>
                                            @if (_workspaceMenuOpen)
                                            {
                                                <SidebarMenuSub>
                                                    <SidebarMenuSubItem>
                                                        <SidebarMenuSubButton AsChild="true">
                                                            <Anchor To="cards">
                                                                <Span>Design System</Span>
                                                            </Anchor>
                                                        </SidebarMenuSubButton>
                                                    </SidebarMenuSubItem>
                                                    <SidebarMenuSubItem>
                                                        <SidebarMenuSubButton AsChild="true" Active="true">
                                                            <Anchor To="sidebar">
                                                                <Span>Sidebar Refresh</Span>
                                                            </Anchor>
                                                        </SidebarMenuSubButton>
                                                    </SidebarMenuSubItem>
                                                </SidebarMenuSub>
                                            }
                                        </SidebarMenuItem>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton AsChild="true" Tooltip="Inbox">
                                                <Anchor To="input-demo">
                                                    <Icon Name="LucideIcon.Mail" BoxSize="Size.Is4" />
                                                    <Span>Inbox</Span>
                                                </Anchor>
                                            </SidebarMenuButton>
                                            <SidebarMenuBadge>12</SidebarMenuBadge>
                                        </SidebarMenuItem>
                                    </SidebarMenu>
                                </SidebarGroupContent>
                            </SidebarGroup>

                            <SidebarSeparator />

                            <SidebarGroup>
                                <SidebarGroupLabel>Team</SidebarGroupLabel>
                                <SidebarGroupContent>
                                    <SidebarMenu>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton AsChild="true" Tooltip="Members">
                                                <Anchor To="avatars">
                                                    <Icon Name="LucideIcon.User" BoxSize="Size.Is4" />
                                                    <Span>Members</Span>
                                                </Anchor>
                                            </SidebarMenuButton>
                                        </SidebarMenuItem>
                                    </SidebarMenu>
                                </SidebarGroupContent>
                            </SidebarGroup>
                        </SidebarContent>

                        <SidebarFooter>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Variant="SidebarMenuButtonVariant.Outline" Tooltip="Jake Stevenson">
                                        <Span class="flex size-7 items-center justify-center rounded-lg bg-sidebar-accent text-xs font-semibold text-sidebar-accent-foreground">JS</Span>
                                        <Div class="grid flex-1 text-left text-sm leading-tight group-data-[collapsible=icon]:hidden">
                                            <Span class="truncate font-medium">Jake Stevenson</Span>
                                            <Span class="truncate text-xs text-sidebar-foreground/70">Product Engineering</Span>
                                        </Div>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarFooter>

                        <SidebarRail />
                    </Sidebar>

                    <SidebarInset>
                        <Div Display="Display.Flex" Height='Height.Token("14")' ItemsAlign="Items.Center" Gap="Gap.Is3" Border="Border.Is1.FromBottom" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4.OnX">
                            <SidebarTrigger />
                            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Icon collapse, nested submenu, and hover action are all active in this preview.</Paragraph>
                        </Div>
                        <Div class="p-6">
                            <Div class="rounded-xl border border-border bg-card p-6 text-sm text-muted-foreground">
                                Use one composed shell to exercise the sidebar primitives together instead of scattering them across unrelated demos.
                            </Div>
                        </Div>
                    </SidebarInset>
                </SidebarProvider>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Collapsible Group Label"
                     Description="`SidebarGroupLabel AsChild` works with `CollapsibleTrigger` for collapsible group labels."
                     Code="@CollapsibleGroupCode"
                     CodeLanguage="razor">
            <Div Width="Width.IsFull" Overflow="Overflow.Hidden" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background">
                <SidebarProvider DefaultOpen="true" Class="h-[20rem]">
                    <Sidebar Collapsible="SidebarCollapsible.None">
                        <SidebarContent>
                            <Collapsible Open="_resourcesOpen" OpenChanged="OnResourcesOpenChanged" Class="group/collapsible">
                                <SidebarGroup>
                                    <SidebarGroupLabel AsChild="true">
                                        <CollapsibleTrigger>
                                            <Span>Resources</Span>
                                            <Icon Name="LucideIcon.ChevronDown" Class="ml-auto size-4 transition-transform group-data-[state=open]/collapsible:rotate-180" />
                                        </CollapsibleTrigger>
                                    </SidebarGroupLabel>
                                    <CollapsibleContent>
                                        <SidebarGroupContent>
                                            <SidebarMenu>
                                                <SidebarMenuItem>
                                                    <SidebarMenuButton AsChild="true">
                                                        <Anchor To="cards">
                                                            <Icon Name="LucideIcon.File" BoxSize="Size.Is4" />
                                                            <Span>Component inventory</Span>
                                                        </Anchor>
                                                    </SidebarMenuButton>
                                                </SidebarMenuItem>
                                                <SidebarMenuItem>
                                                    <SidebarMenuButton AsChild="true">
                                                        <Anchor To="validation-summary">
                                                            <Icon Name="LucideIcon.Shield" BoxSize="Size.Is4" />
                                                            <Span>Accessibility audit</Span>
                                                        </Anchor>
                                                    </SidebarMenuButton>
                                                </SidebarMenuItem>
                                            </SidebarMenu>
                                        </SidebarGroupContent>
                                    </CollapsibleContent>
                                </SidebarGroup>
                            </Collapsible>
                        </SidebarContent>
                    </Sidebar>
                </SidebarProvider>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Skeleton"
                     Description="`SidebarMenuSkeleton` matches the documented placeholder pattern for loading navigation."
                     Code="@SkeletonCode"
                     CodeLanguage="razor">
            <Div Width="Width.IsFull" Overflow="Overflow.Hidden" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background">
                <SidebarProvider DefaultOpen="true" Class="h-[15rem]">
                    <Sidebar Collapsible="SidebarCollapsible.None">
                        <SidebarContent>
                            <SidebarGroup>
                                <SidebarGroupLabel>Loading</SidebarGroupLabel>
                                <SidebarGroupContent>
                                    <SidebarMenu>
                                        <SidebarMenuItem>
                                            <SidebarMenuSkeleton ShowIcon="true" />
                                        </SidebarMenuItem>
                                        <SidebarMenuItem>
                                            <SidebarMenuSkeleton ShowIcon="true" />
                                        </SidebarMenuItem>
                                        <SidebarMenuItem>
                                            <SidebarMenuSkeleton />
                                        </SidebarMenuItem>
                                    </SidebarMenu>
                                </SidebarGroupContent>
                            </SidebarGroup>
                        </SidebarContent>
                    </Sidebar>
                </SidebarProvider>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Controlled Sidebar"
                     Description="Use `Open` and `OpenChanged` on `SidebarProvider` when the parent owns the expanded state."
                     Code="@ControlledCode"
                     CodeLanguage="razor">
            <Div id="sidebar-controlled-demo" Width="Width.IsFull" Space="Space.Y.Is4">
                <Div class="relative z-10 flex flex-wrap gap-2">
                    <Button id="sidebar-controlled-open" Size="ButtonSize.Sm" OnClick="OpenControlledSidebar">Open</Button>
                    <Button id="sidebar-controlled-close" Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="CloseControlledSidebar">Close</Button>
                </Div>

                <Div Overflow="Overflow.Hidden" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background">
                    <SidebarProvider Open="_controlledSidebarOpen" OpenChanged="OnControlledSidebarOpenChanged" Class="h-[20rem]">
                        <Sidebar>
                            <SidebarContent>
                                <SidebarGroup>
                                    <SidebarGroupLabel>State</SidebarGroupLabel>
                                    <SidebarGroupContent>
                                        <SidebarMenu>
                                            <SidebarMenuItem>
                                                <SidebarMenuButton>
                                                    <Icon Name="LucideIcon.House" BoxSize="Size.Is4" />
                                                    <Span>@(_controlledSidebarOpen ? "Expanded" : "Collapsed")</Span>
                                                </SidebarMenuButton>
                                            </SidebarMenuItem>
                                        </SidebarMenu>
                                    </SidebarGroupContent>
                                </SidebarGroup>
                            </SidebarContent>
                            <SidebarRail />
                        </Sidebar>

                        <SidebarInset>
                            <Div Display="Display.Flex" Height='Height.Token("14")' ItemsAlign="Items.Center" Gap="Gap.Is3" Border="Border.Is1.FromBottom" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4.OnX">
                                <SidebarTrigger id="sidebar-controlled-trigger" />
                                <Paragraph id="sidebar-controlled-state" TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Current state: @(_controlledSidebarOpen ? "open" : "closed")</Paragraph>
                            </Div>
                            <Div Padding="Padding.Is6" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                                This example is controlled entirely by the parent page and mirrors the standard `open` plus `onOpenChange` pattern.
                            </Div>
                        </SidebarInset>
                    </SidebarProvider>
                </Div>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <Div Space="Space.Y.Is2">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                Full-screen mobile sidebar and other advanced shell patterns.
            </Paragraph>
        </Div>

        <DemoSection Title="Full-Screen Mobile"
                     Description="Force mobile mode and render the sidebar as a viewport-covering navigation surface."
                     Code="@FullScreenMobileCode"
                     CodeLanguage="razor">
            <Div id="sidebar-mobile-demo" Width="Width.IsFull" Overflow="Overflow.Hidden" Rounded="Rounded.Xl" Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor="BackgroundColor.Background">
                <SidebarProvider IsMobile="true"
                                 OpenMobile="_mobileSidebarOpen"
                                 OpenMobileChanged="OnMobileSidebarOpenChanged"
                                 SidebarWidthMobile="100vw"
                                 Class="h-[20rem]">
                    <Sidebar Collapsible="SidebarCollapsible.None"
                             MobileMode="SidebarMobileMode.FullScreen"
                             MobileShowCloseButton="false"
                             MobileClass="bg-background">
                        <MobileContent>
                            <Div id="sidebar-mobile-sheet-content" class="flex min-h-0 flex-1 flex-col">
                                <Div class="border-b bg-background px-6 py-4">
                                    <Div class="flex items-center gap-3">
                                        <SidebarTrigger id="sidebar-mobile-close-trigger" Class="size-8 rounded-md p-0 hover:bg-accent">
                                            <Icon Name="LucideIcon.X" BoxSize="Size.Is5" />
                                            <Span class="sr-only">Close menu</Span>
                                        </SidebarTrigger>
                                        <Paragraph class="text-base font-semibold">Menu</Paragraph>
                                    </Div>

                                    <Div class="mt-6 flex flex-col gap-1">
                                        <Anchor To="" Display="Display.InlineFlex" Height='Height.Token("12")' ItemsAlign="Items.Center" Padding="Padding.Is0.OnX" TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground">Home</Anchor>
                                        <Anchor To="components" Display="Display.InlineFlex" Height='Height.Token("12")' ItemsAlign="Items.Center" Padding="Padding.Is0.OnX" TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground">Docs</Anchor>
                                        <Anchor To="sidebar" Display="Display.InlineFlex" Height='Height.Token("12")' ItemsAlign="Items.Center" Padding="Padding.Is0.OnX" TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Medium" TextColor="TextColor.Foreground">Components</Anchor>
                                    </Div>
                                </Div>

                                <Div class="min-h-0 flex-1 overflow-y-auto px-6 py-5">
                                    <SidebarMenu Class="gap-0.5">
                                        <SidebarMenuItem>
                                            <SidebarMenuButton To="" Match="NavLinkMatch.All">
                                                <Span>Introduction</Span>
                                            </SidebarMenuButton>
                                        </SidebarMenuItem>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton To="sidebar" Active="true">
                                                <Span>Sidebar</Span>
                                            </SidebarMenuButton>
                                        </SidebarMenuItem>
                                        <SidebarMenuItem>
                                            <SidebarMenuButton To="validation-summary">
                                                <Span>Validation</Span>
                                            </SidebarMenuButton>
                                        </SidebarMenuItem>
                                    </SidebarMenu>
                                </Div>
                            </Div>
                        </MobileContent>

                        <ChildContent>
                            <SidebarHeader Class="border-b px-6 py-4">
                                <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Documentation</Paragraph>
                                <Paragraph class="text-xs text-sidebar-foreground/70">Static on desktop, full-screen on mobile.</Paragraph>
                            </SidebarHeader>
                            <SidebarContent Class="px-4 pb-6">
                                <SidebarGroup Class="pt-2">
                                    <SidebarGroupLabel>Navigate</SidebarGroupLabel>
                                    <SidebarGroupContent>
                                        <SidebarMenu Class="gap-0.5">
                                            <SidebarMenuItem>
                                                <SidebarMenuButton To="" Match="NavLinkMatch.All">
                                                    <Span>Overview</Span>
                                                </SidebarMenuButton>
                                            </SidebarMenuItem>
                                            <SidebarMenuItem>
                                                <SidebarMenuButton To="sidebar" Active="true">
                                                    <Span>Sidebar</Span>
                                                </SidebarMenuButton>
                                            </SidebarMenuItem>
                                        </SidebarMenu>
                                    </SidebarGroupContent>
                                </SidebarGroup>
                            </SidebarContent>
                        </ChildContent>
                    </Sidebar>

                    <SidebarInset>
                        <Div Display="Display.Flex" Height='Height.Token("14")' ItemsAlign="Items.Center" Gap="Gap.Is3" Border="Border.Is1.FromBottom" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4.OnX" Class="relative z-10">
                            <SidebarTrigger id="sidebar-mobile-open-trigger" />
                            <Paragraph id="sidebar-mobile-state" TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Current state: @(_mobileSidebarOpen ? "open" : "closed")</Paragraph>
                        </Div>
                        <Div Padding="Padding.Is6" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                            Open the sidebar to see the full-screen mobile presentation with the same provider and trigger wiring.
                        </Div>
                    </SidebarInset>
                </SidebarProvider>
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private const string SidebarCompositionCode =
        """
        SidebarProvider
        ├── Sidebar
        │   ├── SidebarHeader
        │   ├── SidebarContent
        │   │   └── SidebarGroup
        │   │       ├── SidebarGroupLabel
        │   │       ├── SidebarGroupAction
        │   │       └── SidebarGroupContent
        │   │           └── SidebarMenu
        │   │               └── SidebarMenuItem
        │   │                   ├── SidebarMenuButton
        │   │                   ├── SidebarMenuAction
        │   │                   ├── SidebarMenuBadge
        │   │                   └── SidebarMenuSub
        │   ├── SidebarFooter
        │   └── SidebarRail
        ├── SidebarInset
        └── SidebarTrigger
        """;

    private const string UsageCode =
        """
        <SidebarProvider Open="_usageSidebarOpen" OpenChanged="OnUsageSidebarOpenChanged">
            <Sidebar>
                <SidebarHeader>
                    <Paragraph Padding="Padding.Is2.OnX" TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Acme Inc.</Paragraph>
                </SidebarHeader>
                <SidebarContent>
                    <SidebarGroup>
                        <SidebarGroupLabel>Application</SidebarGroupLabel>
                        <SidebarGroupContent>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton AsChild="true" Active="true" Tooltip="Home">
                                        <Anchor To="">
                                            <Icon Name="LucideIcon.House" BoxSize="Size.Is4" />
                                            <Span>Home</Span>
                                        </Anchor>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton AsChild="true" Tooltip="Messages">
                                        <Anchor To="dropdowns">
                                            <Icon Name="LucideIcon.Mail" BoxSize="Size.Is4" />
                                            <Span>Messages</Span>
                                        </Anchor>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroupContent>
                    </SidebarGroup>
                </SidebarContent>
                <SidebarFooter>
                    <SidebarMenu>
                        <SidebarMenuItem>
                            <SidebarMenuButton AsChild="true" Tooltip="Settings">
                                <Anchor To="cards">
                                    <Icon Name="LucideIcon.Cog" BoxSize="Size.Is4" />
                                    <Span>Settings</Span>
                                </Anchor>
                            </SidebarMenuButton>
                        </SidebarMenuItem>
                    </SidebarMenu>
                </SidebarFooter>
                <SidebarRail />
            </Sidebar>

            <SidebarInset>
                        <Div Display="Display.Flex" Height='Height.Token("14")' ItemsAlign="Items.Center" Gap="Gap.Is3" Border="Border.Is1.FromBottom" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4.OnX" Class="relative z-10">
                    <SidebarTrigger />
                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">SidebarTrigger stays connected to the provider.</Paragraph>
                </Div>
            </SidebarInset>
        </SidebarProvider>
        """;

    private const string ComposedMenuCode =
        """
        <SidebarProvider Open="_composedSidebarOpen" OpenChanged="OnComposedSidebarOpenChanged">
            <Sidebar Collapsible="SidebarCollapsible.Icon">
                <SidebarHeader>
                    <Paragraph Padding="Padding.Is2.OnX" TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Workspace</Paragraph>
                    <SidebarInput Placeholder="Search..." Type="search" />
                </SidebarHeader>

                <SidebarContent>
                    <SidebarGroup>
                        <SidebarGroupLabel>Platform</SidebarGroupLabel>
                        <SidebarGroupAction AsChild="true">
                            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs">
                                <Icon Name="LucideIcon.Plus" BoxSize="Size.Is4" />
                                <Span class="sr-only">Add project</Span>
                            </Button>
                        </SidebarGroupAction>
                        <SidebarGroupContent>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton AsChild="true" Active="true" Tooltip="Dashboard">
                                        <Anchor To="">
                                            <Icon Name="LucideIcon.House" BoxSize="Size.Is4" />
                                            <Span>Dashboard</Span>
                                        </Anchor>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Open="_workspaceMenuOpen" OnClick="ToggleWorkspaceMenu" Tooltip="Projects">
                                        <Icon Name="LucideIcon.Folder" BoxSize="Size.Is4" />
                                        <Span>Projects</Span>
                                        <Icon Name="LucideIcon.ChevronRight" Class="@($"ml-auto size-4 transition-transform {(_workspaceMenuOpen ? "rotate-90" : string.Empty)}")" />
                                    </SidebarMenuButton>
                                    <SidebarMenuAction AsChild="true" ShowOnHover="true">
                                        <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.IconXs">
                                            <Icon Name="LucideIcon.Plus" BoxSize="Size.Is4" />
                                            <Span class="sr-only">Create project</Span>
                                        </Button>
                                    </SidebarMenuAction>
                                    @if (_workspaceMenuOpen)
                                    {
                                        <SidebarMenuSub>
                                            <SidebarMenuSubItem>
                                                <SidebarMenuSubButton AsChild="true">
                                                    <Anchor To="cards">
                                                        <Span>Design System</Span>
                                                    </Anchor>
                                                </SidebarMenuSubButton>
                                            </SidebarMenuSubItem>
                                            <SidebarMenuSubItem>
                                                <SidebarMenuSubButton AsChild="true" Active="true">
                                                    <Anchor To="sidebar">
                                                        <Span>Sidebar Refresh</Span>
                                                    </Anchor>
                                                </SidebarMenuSubButton>
                                            </SidebarMenuSubItem>
                                        </SidebarMenuSub>
                                    }
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton AsChild="true" Tooltip="Inbox">
                                        <Anchor To="input-demo">
                                            <Icon Name="LucideIcon.Mail" BoxSize="Size.Is4" />
                                            <Span>Inbox</Span>
                                        </Anchor>
                                    </SidebarMenuButton>
                                    <SidebarMenuBadge>12</SidebarMenuBadge>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroupContent>
                    </SidebarGroup>
                </SidebarContent>

                <SidebarFooter>
                    <SidebarMenu>
                        <SidebarMenuItem>
                            <SidebarMenuButton Variant="SidebarMenuButtonVariant.Outline" Tooltip="Jake Stevenson">
                                <Span class="flex size-7 items-center justify-center rounded-lg bg-sidebar-accent text-xs font-semibold text-sidebar-accent-foreground">JS</Span>
                                <Div class="grid flex-1 text-left text-sm leading-tight group-data-[collapsible=icon]:hidden">
                                    <Span class="truncate font-medium">Jake Stevenson</Span>
                                    <Span class="truncate text-xs text-sidebar-foreground/70">Product Engineering</Span>
                                </Div>
                            </SidebarMenuButton>
                        </SidebarMenuItem>
                    </SidebarMenu>
                </SidebarFooter>

                <SidebarRail />
            </Sidebar>
        </SidebarProvider>
        """;

    private const string CollapsibleGroupCode =
