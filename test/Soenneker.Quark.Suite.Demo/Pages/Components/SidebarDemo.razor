    private const string ControlledCode =
        """
        <Button Size="ButtonSize.Sm" OnClick="OpenControlledSidebar">Open</Button>
        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="CloseControlledSidebar">Close</Button>

        <SidebarProvider Open="_controlledSidebarOpen" OpenChanged="OnControlledSidebarOpenChanged">
            <Sidebar>
                <SidebarContent>
                    <SidebarGroup>
                        <SidebarGroupLabel>State</SidebarGroupLabel>
                        <SidebarGroupContent>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton>
                                        <Icon Name="LucideIcon.House" BoxSize="Size.Is4" />
                                        <Span>@(_controlledSidebarOpen ? "Expanded" : "Collapsed")</Span>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroupContent>
                    </SidebarGroup>
                </SidebarContent>
                <SidebarRail />
            </Sidebar>

            <SidebarInset>
                <Div Display="Display.Flex" Height='Height.Token("14")' ItemsAlign="Items.Center" Gap="Gap.Is3" Border="Border.Is1.FromBottom" BackgroundColor="BackgroundColor.Background" Padding="Padding.Is4.OnX">
                    <SidebarTrigger />
                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Current state: @(_controlledSidebarOpen ? "open" : "closed")</Paragraph>
                </Div>
            </SidebarInset>
        </SidebarProvider>
        """;

    private const string FullScreenMobileCode =
        """
        <SidebarProvider IsMobile="true"
                         OpenMobile="_mobileSidebarOpen"
                         OpenMobileChanged="OnMobileSidebarOpenChanged"
                         SidebarWidthMobile="100vw">
            <Sidebar Collapsible="SidebarCollapsible.None"
                     MobileMode="SidebarMobileMode.FullScreen"
                     MobileShowCloseButton="false"
                     MobileClass="bg-background">
                <MobileContent>
                    <Div class="flex min-h-0 flex-1 flex-col">
                        <Div class="border-b bg-background px-6 py-4">
                            <Div class="flex items-center gap-3">
                                <SidebarTrigger Class="size-8 rounded-md p-0 hover:bg-accent">
                                    <Icon Name="LucideIcon.X" BoxSize="Size.Is5" />
                                    <Span class="sr-only">Close menu</Span>
                                </SidebarTrigger>
                                <Paragraph class="text-base font-semibold">Menu</Paragraph>
                            </Div>
                        </Div>
                    </Div>
                </MobileContent>
            </Sidebar>
        </SidebarProvider>
        """;

    private bool _usageSidebarOpen = true;
    private bool _composedSidebarOpen = true;
    private bool _workspaceMenuOpen = true;
    private bool _resourcesOpen = true;
    private bool _controlledSidebarOpen;
    private bool _mobileSidebarOpen;

    private Task OnUsageSidebarOpenChanged(bool value)
    {
        _usageSidebarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnComposedSidebarOpenChanged(bool value)
    {
        _composedSidebarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnResourcesOpenChanged(bool value)
    {
        _resourcesOpen = value;
        return Task.CompletedTask;
    }

    private Task OnControlledSidebarOpenChanged(bool value)
    {
        _controlledSidebarOpen = value;
        return Task.CompletedTask;
    }

    private Task OnMobileSidebarOpenChanged(bool value)
    {
        _mobileSidebarOpen = value;
        return Task.CompletedTask;
    }

    private Task ToggleWorkspaceMenu(MouseEventArgs _)
    {
        _workspaceMenuOpen = !_workspaceMenuOpen;
        return Task.CompletedTask;
    }

    private Task OpenControlledSidebar(MouseEventArgs _)
    {
        _controlledSidebarOpen = true;
        return Task.CompletedTask;
    }

    private Task CloseControlledSidebar(MouseEventArgs _)
    {
        _controlledSidebarOpen = false;
        return Task.CompletedTask;
    }
}
