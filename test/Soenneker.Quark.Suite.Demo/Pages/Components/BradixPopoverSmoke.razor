@page "/bradix-popover-smoke"
@using Soenneker.Bradix

<PageTitle>Bradix Popover Smoke - Quark Suite</PageTitle>

<Div Padding="Padding.Is6">
    <Span Id="playwright-ready" ScreenReader="ScreenReader.Only">ready</Span>

    <BradixPopover DefaultOpen="true">
        <BradixPopoverTrigger>
            Open popover
        </BradixPopoverTrigger>
        <BradixPopoverPortal>
            <BradixPopoverContent Width='Width.Token("40")'>
                Smoke content
            </BradixPopoverContent>
        </BradixPopoverPortal>
    </BradixPopover>
</Div>
