@page "/bradix-popover-smoke"
@using Soenneker.Bradix

<PageTitle>Bradix Popover Smoke - Quark Suite</PageTitle>

<Div Class="p-6">
    <Span Id="playwright-ready" Class="sr-only">ready</Span>

    <BradixPopover DefaultOpen="true">
        <BradixPopoverTrigger>
            Open popover
        </BradixPopoverTrigger>
        <BradixPopoverPortal>
            <BradixPopoverContent Class="w-40">
                Smoke content
            </BradixPopoverContent>
        </BradixPopoverPortal>
    </BradixPopover>
</Div>
