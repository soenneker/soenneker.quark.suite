@page "/popover-smoke"

<PageTitle>Popover Smoke - Quark Suite</PageTitle>

<Div Padding="Padding.Is6">
    <Span Id="playwright-ready" ScreenReader="ScreenReader.Only">ready</Span>

    <Popover DefaultOpen="true">
        <PopoverTrigger AsChild="true">
            <Button Variant="ButtonVariant.Outline">Open popover</Button>
        </PopoverTrigger>
        <PopoverContent Width='Width.Token("40")'>
            Smoke content
        </PopoverContent>
    </Popover>
</Div>
