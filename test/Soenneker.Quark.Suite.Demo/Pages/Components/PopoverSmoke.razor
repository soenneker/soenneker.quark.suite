@page "/popover-smoke"

<PageTitle>Popover Smoke - Quark Suite</PageTitle>

<Div Class="p-6">
    <Span Id="playwright-ready" Class="sr-only">ready</Span>

    <Popover DefaultOpen="true">
        <PopoverTrigger AsChild="true">
            <Button Variant="ButtonVariant.Outline">Open popover</Button>
        </PopoverTrigger>
        <PopoverContent Class="w-40">
            Smoke content
        </PopoverContent>
    </Popover>
</Div>
