@page "/components/chain-of-thought"

<PageTitle>Chain of Thought - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <DemoSection Code="@DefaultCode" CodeLanguage="razor">
        <Div Width="Width.IsFull" MaxWidth='MaxWidth.Token("[594px]")'>
            <ChainOfThought AutoCloseOnAllComplete="false">
                <ChainOfThoughtTrigger>
                    Chain of Thought
                </ChainOfThoughtTrigger>
                <ChainOfThoughtContent>
                    <ChainOfThoughtStep Status="ChainOfThoughtStatus.Completed" HasContent="true">
                        <ChainOfThoughtStepTitle Icon="@YoutubeIcon">Youtube search</ChainOfThoughtStepTitle>
                        <ChainOfThoughtStepContent>
                            <Div Margin="Margin.FromTop.Is1" Space="Space.Y.Is2">
                                <Div Class="no-scrollbar"
                                     Margin="Margin.OnX.Negative1.FromTop.Is1.OnSm.OnX.Is0"
                                     Display="Display.Flex"
                                     FlexWrap='@("sm:flex-wrap")'
                                     Gap="Gap.Is1_5"
                                     OverflowX='CssValue<OverflowBuilder>.For(Overflow.X.Auto, "sm:overflow-x-visible")'
                                     Overscroll="Overscroll.XContain"
                                     Padding="Padding.OnX.Is1.FromBottom.Is0_5.OnSm.OnX.Is0.OnSm.FromBottom.Is0">
                                    @foreach (var query in SearchQueries)
                                    {
                                        <Span Display="Display.InlineFlex"
                                              Height='Height.Token("6.5")'
                                              Shrink="Shrink.Is0"
                                              ItemsAlign="Items.Center"
                                              Gap="Gap.Is1"
                                              Rounded="Rounded.Full"
                                              BackgroundColor="BackgroundColor.Muted"
                                              Padding="Padding.OnX.Is2"
                                              TextSize="TextSize.Xs"
                                              Leading="Leading.Is4_5"
                                              Whitespace="Whitespace.Nowrap.OnSm.Normal"
                                              TextColor="TextColor.MutedForeground"
                                              MaxWidth='@("sm:max-w-[187.8px]")'>
                                            <Icon Name="LucideIcon.Globe" Size="Quark.Size.Is4" Shrink="Quark.Shrink.Is0" TextColor='TextColor.Token("muted-foreground/50")' />
                                            <Span MinWidth="MinWidth.Is0" Truncate='@("sm:truncate")'>@query</Span>
                                        </Span>
                                    }
                                </Div>
                            </Div>
                        </ChainOfThoughtStepContent>
                    </ChainOfThoughtStep>
                    <ChainOfThoughtStep Status="ChainOfThoughtStatus.Completed">
                        <ChainOfThoughtStepTitle Icon="@SourcesIcon">Gathered 8 sources</ChainOfThoughtStepTitle>
                    </ChainOfThoughtStep>
                    <ChainOfThoughtStep Status="ChainOfThoughtStatus.Completed" HasContent="true">
                        <ChainOfThoughtStepTitle Icon="@WebIcon">Web search</ChainOfThoughtStepTitle>
                        <ChainOfThoughtStepContent>
                            <Paragraph TextSize="Quark.TextSize.Sm" TextColor="Quark.TextColor.MutedForeground">
                                Compare source titles, remove duplicates, and preserve the strongest references for the final answer.
                            </Paragraph>
                        </ChainOfThoughtStepContent>
                    </ChainOfThoughtStep>
                    <ChainOfThoughtComplete Label="Task complete" />
                </ChainOfThoughtContent>
            </ChainOfThought>
        </Div>
    </DemoSection>
</Div>

@code {
    private static readonly string[] SearchQueries =
    [
        "trending movies April 2026 box office",
        "popular movies April 2026",
        "highest grossing movies April 2026",
        "box office for April 2026"
    ];

    private static RenderFragment YoutubeIcon => @<Icon Name="LucideIcon.CirclePlay" Size="Quark.Size.Is4" />;
    private static RenderFragment WebIcon => @<Icon Name="LucideIcon.Globe" Size="Quark.Size.Is4" />;
    private static RenderFragment SourcesIcon => @<Icon Name="LucideIcon.Lightbulb" Size="Quark.Size.Is4" />;

    private const string DefaultCode =
@"<Div Width=""Width.IsFull"" MaxWidth='MaxWidth.Token(""[594px]"")'>
    <ChainOfThought AutoCloseOnAllComplete=""false"">
        <ChainOfThoughtTrigger>
            Chain of Thought
        </ChainOfThoughtTrigger>
        <ChainOfThoughtContent>
            <ChainOfThoughtStep Status=""ChainOfThoughtStatus.Completed"" HasContent=""true"">
                <ChainOfThoughtStepTitle Icon=""@YoutubeIcon"">Youtube search</ChainOfThoughtStepTitle>
                <ChainOfThoughtStepContent>
                    <Div Margin=""Margin.FromTop.Is1"" Space=""Space.Y.Is2"">
                        <Div Class=""no-scrollbar""
                             Margin=""Margin.OnX.Negative1.FromTop.Is1.OnSm.OnX.Is0""
                             Display=""Display.Flex""
                             FlexWrap='@(""sm:flex-wrap"")'
                             Gap=""Gap.Is1_5""
                             OverflowX='CssValue<OverflowBuilder>.For(Overflow.X.Auto, ""sm:overflow-x-visible"")'
                             Overscroll=""Overscroll.XContain""
                             Padding=""Padding.OnX.Is1.FromBottom.Is0_5.OnSm.OnX.Is0.OnSm.FromBottom.Is0"">
                            @foreach (var query in SearchQueries)
                            {
                                <Span Display=""Display.InlineFlex""
                                      Height='Height.Token(""6.5"")'
                                      Shrink=""Shrink.Is0""
                                      ItemsAlign=""Items.Center""
                                      Gap=""Gap.Is1""
                                      Rounded=""Rounded.Full""
                                      BackgroundColor=""BackgroundColor.Muted""
                                      Padding=""Padding.OnX.Is2""
                                      TextSize=""TextSize.Xs""
                                      Leading=""Leading.Is4_5""
                                      Whitespace=""Whitespace.Nowrap.OnSm.Normal""
                                      TextColor=""TextColor.MutedForeground""
                                      MaxWidth='@(""sm:max-w-[187.8px]"")'>
                                    <Icon Name=""LucideIcon.Globe"" Size=""Quark.Size.Is4"" Shrink=""Quark.Shrink.Is0"" TextColor='TextColor.Token(""muted-foreground/50"")' />
                                    <Span MinWidth=""MinWidth.Is0"" Truncate='@(""sm:truncate"")'>@query</Span>
                                </Span>
                            }
                        </Div>
                    </Div>
                </ChainOfThoughtStepContent>
            </ChainOfThoughtStep>
            <ChainOfThoughtStep Status=""ChainOfThoughtStatus.Completed"">
                <ChainOfThoughtStepTitle Icon=""@SourcesIcon"">Gathered 8 sources</ChainOfThoughtStepTitle>
            </ChainOfThoughtStep>
            <ChainOfThoughtStep Status=""ChainOfThoughtStatus.Completed"" HasContent=""true"">
                <ChainOfThoughtStepTitle Icon=""@WebIcon"">Web search</ChainOfThoughtStepTitle>
                <ChainOfThoughtStepContent>
                    <Paragraph TextSize=""Quark.TextSize.Sm"" TextColor=""Quark.TextColor.MutedForeground"">
                        Compare source titles, remove duplicates, and preserve the strongest references for the final answer.
                    </Paragraph>
                </ChainOfThoughtStepContent>
            </ChainOfThoughtStep>
            <ChainOfThoughtComplete Label=""Task complete"" />
        </ChainOfThoughtContent>
    </ChainOfThought>
</Div>";
}
