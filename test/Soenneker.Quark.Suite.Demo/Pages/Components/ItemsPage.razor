@page "/items"

<PageTitle>Item - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="A versatile component for displaying content with media, title, description, and actions."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full max-w-md flex-col gap-6">
                    <Item Variant="ItemVariant.Outline">
                        <ItemContent>
                            <ItemTitle>Basic Item</ItemTitle>
                            <ItemDescription>A simple item with title and description.</ItemDescription>
                        </ItemContent>
                        <ItemActions>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Action</Button>
                        </ItemActions>
                    </Item>

                    <Item Variant="ItemVariant.Outline" Size="ItemSize.Small" AsChild="true">
                        <Anchor To="#">
                            <ItemMedia>
                                <Icon Name="LucideIcon.BadgeCheck" class="size-5" />
                            </ItemMedia>
                            <ItemContent>
                                <ItemTitle>Your profile has been verified.</ItemTitle>
                            </ItemContent>
                            <ItemActions>
                                <Icon Name="LucideIcon.ChevronRight" class="size-4" />
                            </ItemActions>
                        </Anchor>
                    </Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Variant"
                         Description="Use the variant prop to change the visual style of the item."
                         Code="@VariantCode"
                         CodeLanguage="razor">
                <Div Class="w-full max-w-md space-y-3">
                    <Item><ItemContent><ItemTitle>Default Variant</ItemTitle><ItemDescription>Transparent background with no border.</ItemDescription></ItemContent></Item>
                    <Item Variant="ItemVariant.Outline"><ItemContent><ItemTitle>Outline Variant</ItemTitle><ItemDescription>Outlined style with a visible border.</ItemDescription></ItemContent></Item>
                    <Item Variant="ItemVariant.Muted"><ItemContent><ItemTitle>Muted Variant</ItemTitle><ItemDescription>Muted background for secondary content.</ItemDescription></ItemContent></Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Use the size prop to change the size of the item. Available sizes are default, sm, and xs."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Class="w-full max-w-md space-y-3">
                    <Item Variant="ItemVariant.Outline"><ItemContent><ItemTitle>Default Size</ItemTitle><ItemDescription>The standard size for most use cases.</ItemDescription></ItemContent></Item>
                    <Item Variant="ItemVariant.Outline" Size="ItemSize.Small"><ItemContent><ItemTitle>Small Size</ItemTitle><ItemDescription>A compact size for dense layouts.</ItemDescription></ItemContent></Item>
                    <Item Variant="ItemVariant.Outline" Size="ItemSize.ExtraSmall"><ItemContent><ItemTitle>Extra Small Size</ItemTitle><ItemDescription>The most compact size available.</ItemDescription></ItemContent></Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icon"
                         Description="Use ItemMedia with variant=&quot;icon&quot; to display an icon."
                         Code="@IconCode"
                         CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline" Class="max-w-md">
                    <ItemMedia Variant="ItemMediaVariant.Icon">
                        <Icon Name="LucideIcon.ShieldAlert" />
                    </ItemMedia>
                    <ItemContent>
                        <ItemTitle>Security Alert</ItemTitle>
                        <ItemDescription>New login detected from unknown device.</ItemDescription>
                    </ItemContent>
                    <ItemActions>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Review</Button>
                    </ItemActions>
                </Item>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Description="You can use ItemMedia with avatar content to display an avatar."
                         Code="@AvatarCode"
                         CodeLanguage="razor">
                <Div Class="flex w-full max-w-md flex-col gap-6">
                    <Item>
                        <ItemMedia>
                            <Avatar>
                                <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" />
                                <AvatarFallback>ER</AvatarFallback>
                            </Avatar>
                        </ItemMedia>
                        <ItemContent>
                            <ItemTitle>Evil Rabbit</ItemTitle>
                            <ItemDescription>Last seen 5 months ago</ItemDescription>
                        </ItemContent>
                        <ItemActions>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Invite</Button>
                        </ItemActions>
                    </Item>

                    <Item Variant="ItemVariant.Outline">
                        <ItemMedia>
                            <AvatarGroup>
                                <Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>CN</AvatarFallback></Avatar>
                                <Avatar><AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")" /><AvatarFallback>LR</AvatarFallback></Avatar>
                                <Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" /><AvatarFallback>ER</AvatarFallback></Avatar>
                            </AvatarGroup>
                        </ItemMedia>
                        <ItemContent>
                            <ItemTitle>No Team Members</ItemTitle>
                            <ItemDescription>Invite your team to collaborate on this project.</ItemDescription>
                        </ItemContent>
                        <ItemActions>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">
                                <Icon Name="LucideIcon.Plus" />
                                Invite
                            </Button>
                        </ItemActions>
                    </Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Image"
                         Description="Use ItemMedia with variant=&quot;image&quot; to display an image."
                         Code="@ImageCode"
                         CodeLanguage="razor">
                <ItemGroup Class="w-full max-w-md">
                    <Item>
                        <ItemMedia Variant="ItemMediaVariant.Image">
                            <Image Source="https://avatar.vercel.sh/Midnight%20City%20Lights" Alt="Midnight City Lights" />
                        </ItemMedia>
                        <ItemContent>
                            <ItemTitle>Midnight City Lights - Electric Nights</ItemTitle>
                            <ItemDescription>Neon Dreams</ItemDescription>
                        </ItemContent>
                        <ItemContent Class="flex-none text-right">
                            <ItemDescription>3:45</ItemDescription>
                        </ItemContent>
                    </Item>
                    <Item>
                        <ItemMedia Variant="ItemMediaVariant.Image">
                            <Image Source="https://avatar.vercel.sh/Coffee%20Shop%20Conversations" Alt="Coffee Shop Conversations" />
                        </ItemMedia>
                        <ItemContent>
                            <ItemTitle>Coffee Shop Conversations - Urban Stories</ItemTitle>
                            <ItemDescription>The Morning Brew</ItemDescription>
                        </ItemContent>
                        <ItemContent Class="flex-none text-right">
                            <ItemDescription>4:05</ItemDescription>
                        </ItemContent>
                    </Item>
                    <Item>
                        <ItemMedia Variant="ItemMediaVariant.Image">
                            <Image Source="https://avatar.vercel.sh/Digital%20Rain" Alt="Digital Rain" />
                        </ItemMedia>
                        <ItemContent>
                            <ItemTitle>Digital Rain - Binary Beats</ItemTitle>
                            <ItemDescription>Cyber Symphony</ItemDescription>
                        </ItemContent>
                        <ItemContent Class="flex-none text-right">
                            <ItemDescription>3:30</ItemDescription>
                        </ItemContent>
                    </Item>
                </ItemGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group"
                         Description="Use ItemGroup to group related items together."
                         Code="@GroupCode"
                         CodeLanguage="razor">
                <ItemGroup Class="w-full max-w-md">
                    <Item>
                        <ItemMedia><Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" /><AvatarFallback>s</AvatarFallback></Avatar></ItemMedia>
                        <ItemContent><ItemTitle>shadcn</ItemTitle><ItemDescription>shadcn@vercel.com</ItemDescription></ItemContent>
                        <ItemActions><Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Invite shadcn"><Icon Name="LucideIcon.Plus" /></Button></ItemActions>
                    </Item>
                    <ItemSeparator />
                    <Item>
                        <ItemMedia><Avatar><AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")" /><AvatarFallback>m</AvatarFallback></Avatar></ItemMedia>
                        <ItemContent><ItemTitle>maxleiter</ItemTitle><ItemDescription>maxleiter@vercel.com</ItemDescription></ItemContent>
                        <ItemActions><Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Invite maxleiter"><Icon Name="LucideIcon.Plus" /></Button></ItemActions>
                    </Item>
                    <ItemSeparator />
                    <Item>
                        <ItemMedia><Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")" /><AvatarFallback>e</AvatarFallback></Avatar></ItemMedia>
                        <ItemContent><ItemTitle>evilrabbit</ItemTitle><ItemDescription>evilrabbit@vercel.com</ItemDescription></ItemContent>
                        <ItemActions><Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" aria-label="Invite evilrabbit"><Icon Name="LucideIcon.Plus" /></Button></ItemActions>
                    </Item>
                </ItemGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Header"
                         Description="Use ItemHeader to add a header above the item content."
                         Code="@HeaderCode"
                         CodeLanguage="razor">
                <ItemGroup Class="w-full max-w-md">
                    <Item Variant="ItemVariant.Muted">
                        <ItemHeader>
                            <ItemMedia Variant="ItemMediaVariant.Image">
                                <Image Source="https://images.unsplash.com/photo-1650804068570-7fb2e3dbf888?q=80&amp;w=640&amp;auto=format&amp;fit=crop" Alt="v0-1.5-sm" />
                            </ItemMedia>
                            <ItemTitle>v0-1.5-sm</ItemTitle>
                        </ItemHeader>
                        <ItemContent><ItemDescription>Everyday tasks and UI generation.</ItemDescription></ItemContent>
                    </Item>
                    <Item Variant="ItemVariant.Muted">
                        <ItemHeader>
                            <ItemMedia Variant="ItemMediaVariant.Image">
                                <Image Source="https://images.unsplash.com/photo-1610280777472-54133d004c8c?q=80&amp;w=640&amp;auto=format&amp;fit=crop" Alt="v0-1.5-lg" />
                            </ItemMedia>
                            <ItemTitle>v0-1.5-lg</ItemTitle>
                        </ItemHeader>
                        <ItemContent><ItemDescription>Advanced thinking or reasoning.</ItemDescription></ItemContent>
                    </Item>
                    <Item Variant="ItemVariant.Muted">
                        <ItemHeader>
                            <ItemMedia Variant="ItemMediaVariant.Image">
                                <Image Source="https://images.unsplash.com/photo-1602146057681-08560aee8cde?q=80&amp;w=640&amp;auto=format&amp;fit=crop" Alt="v0-2.0-mini" />
                            </ItemMedia>
                            <ItemTitle>v0-2.0-mini</ItemTitle>
                        </ItemHeader>
                        <ItemContent><ItemDescription>Open Source model for everyone.</ItemDescription></ItemContent>
                    </Item>
                </ItemGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link"
                         Description="Use the asChild prop to render the item as a link. The hover and focus states will be applied to the anchor element."
                         Code="@LinkCode"
                         CodeLanguage="razor">
                <ItemGroup Class="w-full max-w-md">
                    <Item Variant="ItemVariant.Outline" AsChild="true">
                        <Anchor To="#">
                            <ItemMedia Variant="ItemMediaVariant.Icon"><Icon Name="LucideIcon.BookOpen" /></ItemMedia>
                            <ItemContent>
                                <ItemTitle>Visit our documentation</ItemTitle>
                                <ItemDescription>Learn how to get started with our components.</ItemDescription>
                            </ItemContent>
                            <ItemActions><Icon Name="LucideIcon.ChevronRight" /></ItemActions>
                        </Anchor>
                    </Item>
                    <Item Variant="ItemVariant.Outline" AsChild="true">
                        <Anchor To="#">
                            <ItemMedia Variant="ItemMediaVariant.Icon"><Icon Name="LucideIcon.ExternalLink" /></ItemMedia>
                            <ItemContent>
                                <ItemTitle>External resource</ItemTitle>
                                <ItemDescription>Opens in a new tab with security attributes.</ItemDescription>
                            </ItemContent>
                            <ItemActions><Icon Name="LucideIcon.ChevronRight" /></ItemActions>
                        </Anchor>
                    </Item>
                </ItemGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown"
                         Description="Place a dropdown in the actions area for secondary choices."
                         Code="@DropdownCode"
                         CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline" Class="max-w-md">
                    <ItemContent>
                        <ItemTitle>Notification preferences</ItemTitle>
                        <ItemDescription>Select how you want to receive updates.</ItemDescription>
                    </ItemContent>
                    <ItemActions>
                        <Dropdown>
                            <DropdownToggle AsChild="true">
                                <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">
                                    Select
                                    <Icon Name="LucideIcon.ChevronDown" />
                                </Button>
                            </DropdownToggle>
                            <DropdownMenu>
                                <DropdownItem>Email</DropdownItem>
                                <DropdownItem>Push</DropdownItem>
                                <DropdownItem>None</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </ItemActions>
                </Item>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         ShowPreviewToolbar="true"
                         PreviewLang="ar"
                         PreviewDir="rtl">
                <DirectionProvider Dir="rtl">
                    <Div Class="w-full max-w-md space-y-3">
                        <Item Variant="ItemVariant.Outline">
                            <ItemContent>
                                <ItemTitle>عنصر أساسي</ItemTitle>
                                <ItemDescription>عنصر بسيط يحتوي على عنوان ووصف.</ItemDescription>
                            </ItemContent>
                            <ItemActions><Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">إجراء</Button></ItemActions>
                        </Item>
                        <Item Variant="ItemVariant.Outline" Size="ItemSize.Small" AsChild="true">
                            <Anchor To="#">
                                <ItemMedia><Icon Name="LucideIcon.BadgeCheck" class="size-5" /></ItemMedia>
                                <ItemContent><ItemTitle>تم التحقق من ملفك الشخصي.</ItemTitle></ItemContent>
                            </Anchor>
                        </Item>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
