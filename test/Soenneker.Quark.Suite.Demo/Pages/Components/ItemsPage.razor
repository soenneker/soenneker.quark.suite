@page "/items"

<PageTitle>Item - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="A flexible component for displaying content with optional media, actions, and metadata."
                        Code="@DemoCode"
                        CodeLanguage="razor">
                <Div Class="flex w-full max-w-md flex-col gap-6">
                    <Item Variant="ItemVariant.Outline">
                        <ItemContent>
                            <ItemTitle>Basic Item</ItemTitle>
                            <ItemDescription>A simple item with title and description.</ItemDescription>
                        </ItemContent>
                        <ItemActions>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Action</Button>
                        </ItemActions>
                    </Item>
                    <Item Variant="ItemVariant.Outline" Size="ItemSize.Small" AsChild="true">
                        <Anchor To="#">
                            <ItemMedia>
                                <Icon Name="LucideIcon.BadgeCheck" class="size-5" />
                            </ItemMedia>
                            <ItemContent>
                                <ItemTitle>Your profile has been verified.</ItemTitle>
                            </ItemContent>
                            <ItemActions>
                                <Icon Name="LucideIcon.ChevronRight" class="size-4" />
                            </ItemActions>
                        </Anchor>
                    </Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Variant" Description="Use the variant parameter to shift the emphasis level of the row container."
                        Code="@(@"<Div Class=""space-y-3"">
    <Item Variant=""ItemVariant.Default"">...</Item>
    <Item Variant=""ItemVariant.Outline"">...</Item>
    <Item Variant=""ItemVariant.Muted"">...</Item>
</Div>")"
CodeLanguage="razor">
                <Div Class="w-full max-w-xl space-y-3">
                    <Item>
                        <ItemContent>
                            <ItemTitle>Default item</ItemTitle>
                            <ItemDescription>Use the default surface when the row already sits inside a structured layout.</ItemDescription>
                        </ItemContent>
                    </Item>
                    <Item Variant="ItemVariant.Outline">
                        <ItemContent>
                            <ItemTitle>Outline item</ItemTitle>
                            <ItemDescription>Use the outline variant to separate rows from surrounding content.</ItemDescription>
                        </ItemContent>
                    </Item>
                    <Item Variant="ItemVariant.Muted">
                        <ItemContent>
                            <ItemTitle>Muted item</ItemTitle>
                            <ItemDescription>Use the muted variant for softer supporting content.</ItemDescription>
                        </ItemContent>
                    </Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Use the size parameter to make item rows denser without changing their composition."
                        Code="@(@"<Div Class=""space-y-3"">
    <Item Size=""ItemSize.ExtraSmall"">...</Item>
    <Item Size=""ItemSize.Small"">...</Item>
    <Item>...</Item>
</Div>")"
CodeLanguage="razor">
                <Div Class="w-full max-w-xl space-y-3">
                    <Item Variant="ItemVariant.Outline" Size="ItemSize.ExtraSmall">
                        <ItemContent>
                            <ItemTitle>Extra small item</ItemTitle>
                            <ItemDescription>Useful for compact inspectors and narrow side rails.</ItemDescription>
                        </ItemContent>
                    </Item>
                    <Item Variant="ItemVariant.Outline" Size="ItemSize.Small">
                        <ItemContent>
                            <ItemTitle>Small item</ItemTitle>
                            <ItemDescription>Balances density with comfortable click targets.</ItemDescription>
                        </ItemContent>
                    </Item>
                    <Item Variant="ItemVariant.Outline">
                        <ItemContent>
                            <ItemTitle>Default item</ItemTitle>
                            <ItemDescription>Use the default size for most list and dashboard GridRows.</ItemDescription>
                        </ItemContent>
                    </Item>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icon" Description="Use icon media for the most compact item presentation."
                        Code="@(@"<Item>
    <ItemMedia Variant=""ItemMediaVariant.Icon"">📄</ItemMedia>
    <ItemContent>
        <ItemTitle>Document</ItemTitle>
        <ItemDescription>Quarterly report draft</ItemDescription>
    </ItemContent>
    <ItemActions>
        <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"">Open</Button>
    </ItemActions>
</Item>")"
CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline">
                    <ItemMedia Variant="ItemMediaVariant.Icon">
                        <Span>📄</Span>
                    </ItemMedia>
                    <ItemContent>
                        <ItemTitle>Document</ItemTitle>
                        <ItemDescription>Quarterly report draft</ItemDescription>
                    </ItemContent>
                    <ItemActions>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Open</Button>
                    </ItemActions>
                </Item>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar" Description="Swap icon media for an avatar when the item represents a person or owner."
                        Code="@(@"<Item Variant=""ItemVariant.Outline"">
    <ItemMedia Variant=""ItemMediaVariant.Default""><Avatar><AvatarFallback>CN</AvatarFallback></Avatar></ItemMedia>
    <ItemContent><ItemTitle>Morgan Lee</ItemTitle><ItemDescription>Maintainer</ItemDescription></ItemContent>
</Item>")"
CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline">
                    <ItemMedia Variant="ItemMediaVariant.Default">
                        <Avatar><AvatarFallback>CN</AvatarFallback></Avatar>
                    </ItemMedia>
                    <ItemContent>
                        <ItemTitle>Morgan Lee</ItemTitle>
                        <ItemDescription>Maintainer</ItemDescription>
                    </ItemContent>
                </Item>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Image" Description="Use image media for richer content previews."
                        Code="@(@"<Item Variant=""ItemVariant.Outline"">
    <ItemMedia Variant=""ItemMediaVariant.Image""><Image Source=""https://picsum.photos/80/80"" Alt=""Summer campaign"" Width=""40"" Height=""40"" Rounded=""Rounded.Md"" Class=""object-cover"" /></ItemMedia>
    <ItemContent><ItemTitle>Summer campaign</ItemTitle><ItemDescription>Marketing asset</ItemDescription></ItemContent>
</Item>")"
CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline">
                    <ItemMedia Variant="ItemMediaVariant.Image">
                        <Image Source="https://picsum.photos/80/80" Alt="Summer campaign" Width="40" Height="40" Rounded="Rounded.Md" Class="object-cover" />
                    </ItemMedia>
                    <ItemContent>
                        <ItemTitle>Summer campaign</ItemTitle>
                        <ItemDescription>Marketing asset</ItemDescription>
                    </ItemContent>
                </Item>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group" Description="Grouped items with separators."
                        Code="@(@"<ItemGroup>
    <Item>...</Item>
    <ItemSeparator />
    <Item>...</Item>
</ItemGroup>")"
CodeLanguage="razor">
                <ItemGroup Class="rounded-md border border-border overflow-hidden">
                    <Item Variant="ItemVariant.Default">
                        <ItemContent>
                            <ItemTitle>Profile</ItemTitle>
                            <ItemDescription>Manage your account settings</ItemDescription>
                        </ItemContent>
                    </Item>
                    <ItemSeparator />
                    <Item Variant="ItemVariant.Default">
                        <ItemContent>
                            <ItemTitle>Billing</ItemTitle>
                            <ItemDescription>Update payment details</ItemDescription>
                        </ItemContent>
                    </Item>
                </ItemGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Header" Description="Use header and footer slots to add metadata around the item body."
                        Code="@(@"<Item Variant=""ItemVariant.Muted"">
    <ItemHeader>...</ItemHeader>
    <ItemContent>...</ItemContent>
    <ItemFooter>...</ItemFooter>
</Item>")"
CodeLanguage="razor">
                <Item Variant="ItemVariant.Muted">
                    <ItemHeader>
                        <ItemTitle>Release notes</ItemTitle>
                        <Badge Variant="BadgeVariant.Secondary">New</Badge>
                    </ItemHeader>
                    <ItemContent>
                        <ItemDescription>Version 4.2 is available with performance improvements.</ItemDescription>
                    </ItemContent>
                    <ItemFooter>
                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Updated 2h ago</Span>
                        <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Sm">View</Button>
                    </ItemFooter>
                </Item>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link" Description="Render the item as a link when the whole row should be the interactive target."
                        Code="@(@"<Item Variant=""ItemVariant.Outline"" AsChild=""true"">
    <Anchor To=""buttons"">
        <ItemMedia Variant=""ItemMediaVariant.Icon""><Icon Name=""LucideIcon.BookOpen"" /></ItemMedia>
        <ItemContent>
            <ItemTitle>API Reference</ItemTitle>
            <ItemDescription>Open the related docs page.</ItemDescription>
        </ItemContent>
    </Anchor>
</Item>")"
CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline" AsChild="true">
                    <Anchor To="buttons">
                        <ItemMedia Variant="ItemMediaVariant.Icon">
                            <Icon Name="LucideIcon.BookOpen" />
                        </ItemMedia>
                        <ItemContent>
                            <ItemTitle>API Reference</ItemTitle>
                            <ItemDescription>Open the related docs page.</ItemDescription>
                        </ItemContent>
                    </Anchor>
                </Item>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown" Description="Use a dropdown in the actions area when the row needs secondary actions." 
                        Code="@(@"<Item Variant=""ItemVariant.Outline"">
    <ItemContent><ItemTitle>Release notes</ItemTitle></ItemContent>
    <ItemActions>
        <Dropdown>
            <DropdownToggle>Actions</DropdownToggle>
            <DropdownMenu><DropdownItem>Edit</DropdownItem></DropdownMenu>
        </Dropdown>
    </ItemActions>
</Item>")"
CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline">
                    <ItemContent>
                        <ItemTitle>Release notes</ItemTitle>
                        <ItemDescription>Secondary actions are available from the overflow menu.</ItemDescription>
                    </ItemContent>
                    <ItemActions>
                        <Dropdown>
                            <DropdownToggle>Actions</DropdownToggle>
                            <DropdownMenu>
                                <DropdownItem>Edit</DropdownItem>
                                <DropdownItem>Duplicate</DropdownItem>
                                <DropdownDivider />
                                <DropdownItem>Archive</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </ItemActions>
                </Item>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="Item content, media, and actions align naturally in right-to-left layouts."
                        Code="@(@"<Item Variant=""ItemVariant.Outline"" dir=""rtl"">...</Item>")"
CodeLanguage="razor">
                <Item Variant="ItemVariant.Outline" dir="rtl">
                    <ItemMedia Variant="ItemMediaVariant.Icon">
                        <Icon Name="LucideIcon.Bell" />
                    </ItemMedia>
                    <ItemContent>
                        <ItemTitle>تم تفعيل الاشعارات</ItemTitle>
                        <ItemDescription>ستصلك التنبيهات المهمة على بريدك.</ItemDescription>
                    </ItemContent>
                    <ItemActions>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">ادارة</Button>
                    </ItemActions>
                </Item>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Div Class=""flex w-full max-w-md flex-col gap-6"">
    <Item Variant=""ItemVariant.Outline"">
        <ItemContent>
            <ItemTitle>Basic Item</ItemTitle>
            <ItemDescription>A simple item with title and description.</ItemDescription>
        </ItemContent>
        <ItemActions>
            <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"">Action</Button>
        </ItemActions>
    </Item>
    <Item Variant=""ItemVariant.Outline"" Size=""ItemSize.Small"" AsChild=""true"">
        <Anchor To=""#"">
            <ItemMedia>
                <Icon Name=""LucideIcon.BadgeCheck"" class=""size-5"" />
            </ItemMedia>
            <ItemContent>
                <ItemTitle>Your profile has been verified.</ItemTitle>
            </ItemContent>
            <ItemActions>
                <Icon Name=""LucideIcon.ChevronRight"" class=""size-4"" />
            </ItemActions>
        </Anchor>
    </Item>
</Div>";
}
