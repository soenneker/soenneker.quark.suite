@page "/textareas"

<PageTitle>Textarea - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Displays a form textarea or a component that looks like a textarea."
                         Code="@BasicCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs">
                <TextArea Placeholder="Type your message here." />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field"
                         Description="Textarea composed inside a field."
                         Code="@FieldCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs">
                <Field>
                    <FieldLabel For="textarea-message">Message</FieldLabel>
                    <FieldDescription>Enter your message below.</FieldDescription>
                    <TextArea Id="textarea-message" Placeholder="Type your message here." />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disabled textarea inside a disabled field."
                         Code="@DisabledCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs">
                <Field Disabled="true">
                    <FieldLabel For="textarea-disabled">Message</FieldLabel>
                    <TextArea Id="textarea-disabled" Placeholder="Type your message here." Disabled="true" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Invalid textarea state."
                         Code="@InvalidCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs">
                <Field IsInvalid="true">
                    <FieldLabel For="textarea-invalid">Message</FieldLabel>
                    <TextArea Id="textarea-invalid" Placeholder="Type your message here." />
                    <FieldDescription>Please enter a valid message.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button"
                         Description="Textarea with a submit action."
                         Code="@ButtonCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs">
                <Div Class="grid w-full gap-2">
                    <TextArea Placeholder="Type your message here." />
                    <Button>Send message</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Textarea inside an RTL field."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs">
                <DirectionProvider Dir="rtl">
                    <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                        <FieldLabel For="feedback">التعليقات</FieldLabel>
                        <TextArea Id="feedback" Rows="4" Placeholder="تعليقاتك تساعدنا على التحسين..." />
                        <FieldDescription>شاركنا أفكارك حول خدمتنا.</FieldDescription>
                    </Field>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<TextArea Placeholder=""Type your message here."" />";

    private const string FieldCode =
@"<Field>
    <FieldLabel For=""textarea-message"">Message</FieldLabel>
    <FieldDescription>Enter your message below.</FieldDescription>
    <TextArea Id=""textarea-message"" Placeholder=""Type your message here."" />
</Field>";

    private const string DisabledCode =
@"<Field Disabled=""true"">
    <FieldLabel For=""textarea-disabled"">Message</FieldLabel>
    <TextArea Id=""textarea-disabled"" Placeholder=""Type your message here."" Disabled=""true"" />
</Field>";

    private const string InvalidCode =
@"<Field IsInvalid=""true"">
    <FieldLabel For=""textarea-invalid"">Message</FieldLabel>
    <TextArea Id=""textarea-invalid"" Placeholder=""Type your message here."" />
    <FieldDescription>Please enter a valid message.</FieldDescription>
</Field>";

    private const string ButtonCode =
@"<Div Class=""grid w-full gap-2"">
    <TextArea Placeholder=""Type your message here."" />
    <Button>Send message</Button>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Field Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsXs"">
        <FieldLabel For=""feedback"">التعليقات</FieldLabel>
        <TextArea Id=""feedback"" Rows=""4"" Placeholder=""تعليقاتك تساعدنا على التحسين..."" />
        <FieldDescription>شاركنا أفكارك حول خدمتنا.</FieldDescription>
    </Field>
</DirectionProvider>";
}
