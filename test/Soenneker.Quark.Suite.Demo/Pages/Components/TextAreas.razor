@page "/textareas"

<PageTitle>Textarea - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="A single textarea with the standard message placeholder."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="max-w-xs">
                    <TextArea Placeholder="Type your message here." />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disable the control and set data-disabled on the field."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Field Class="max-w-xs" Disabled="true">
                    <FieldLabel For="textarea-disabled">Message</FieldLabel>
                    <TextArea Id="textarea-disabled" Placeholder="Type your message here." Disabled="true" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Use Field IsInvalid so the textarea gets aria-invalid styling."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <Field Class="max-w-xs" IsInvalid="true">
                    <FieldLabel For="textarea-invalid">Message</FieldLabel>
                    <TextArea Id="textarea-invalid" Placeholder="Type your message here." />
                    <FieldDescription>Please enter a valid message.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button"
                         Description="Stack a primary action under the textarea."
                         Code="@ButtonCode"
                         CodeLanguage="razor">
                <Div Class="grid w-full max-w-xs gap-2">
                    <TextArea Placeholder="Type your message here." />
                    <Button>Send message</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Textareas respect direction from DirectionProvider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Field Class="w-full max-w-xs">
                        <FieldLabel For="feedback">التعليقات</FieldLabel>
                        <TextArea Id="feedback" Rows="4" Placeholder="شاركنا ملاحظاتك حول التجربة..." />
                        <FieldDescription>نقدر وقتك في مشاركة الملاحظات.</FieldDescription>
                    </Field>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Row limits, max length, and two-way binding patterns for longer forms.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field"
                         Description="Compose label, description, and textarea together."
                         Code="@FieldCode"
                         CodeLanguage="razor">
                <Field Class="max-w-xs">
                    <FieldLabel For="textarea-message">Message</FieldLabel>
                    <FieldDescription>Enter your message below.</FieldDescription>
                    <TextArea Id="textarea-message" Placeholder="Type your message here." />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Rows and Max Length"
                         Description="Configure size and content limits for longer multi-line input."
                         Code="@RowsCode"
                         CodeLanguage="razor">
                <TextArea @bind-Value="_notes" Rows="6" MaxLength="200" Placeholder="Up to 200 chars..." />
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Characters: @(_notes?.Length ?? 0)/200</Paragraph>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Bound Value"
                         Description="Bind textarea value when the page needs live state feedback."
                         Code="@BoundValueCode"
                         CodeLanguage="razor">
                <TextArea @bind-Value="_message" Placeholder="Type your message..." />
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Value: @_message</Paragraph>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Div Class=""max-w-xs"">
    <TextArea Placeholder=""Type your message here."" />
</Div>";

    private const string FieldCode =
@"<Field Class=""max-w-xs"">
    <FieldLabel For=""textarea-message"">Message</FieldLabel>
    <FieldDescription>Enter your message below.</FieldDescription>
    <TextArea Id=""textarea-message"" Placeholder=""Type your message here."" />
</Field>";

    private const string DisabledCode =
@"<Field Class=""max-w-xs"" Disabled=""true"">
    <FieldLabel For=""textarea-disabled"">Message</FieldLabel>
    <TextArea Id=""textarea-disabled"" Placeholder=""Type your message here."" Disabled=""true"" />
</Field>";

    private const string InvalidCode =
@"<Field Class=""max-w-xs"" IsInvalid=""true"">
    <FieldLabel For=""textarea-invalid"">Message</FieldLabel>
    <TextArea Id=""textarea-invalid"" Placeholder=""Type your message here."" />
    <FieldDescription>Please enter a valid message.</FieldDescription>
</Field>";

    private const string ButtonCode =
@"<Div Class=""grid w-full max-w-xs gap-2"">
    <TextArea Placeholder=""Type your message here."" />
    <Button>Send message</Button>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Field Class=""w-full max-w-xs"">
        <FieldLabel For=""feedback"">التعليقات</FieldLabel>
        <TextArea Id=""feedback"" Rows=""4"" Placeholder=""شاركنا ملاحظاتك حول التجربة..."" />
        <FieldDescription>نقدر وقتك في مشاركة الملاحظات.</FieldDescription>
    </Field>
</DirectionProvider>";

    private const string RowsCode =
@"<TextArea @bind-Value=""_notes"" Rows=""6"" MaxLength=""200"" Placeholder=""Up to 200 chars..."" />
<Paragraph TextSize=""TextSize.Sm"" TextColor=""TextColor.MutedForeground"" Margin=""Margin.Is0"">
    Characters: @(_notes?.Length ?? 0)/200
</Paragraph>";

    private const string BoundValueCode =
@"<TextArea @bind-Value=""_message"" Placeholder=""Type your message..."" />
<Paragraph TextSize=""TextSize.Sm"" TextColor=""TextColor.MutedForeground"" Margin=""Margin.Is0"">
    Value: @_message
</Paragraph>";

    private string? _message;
    private string? _notes;
}
