@page "/textareas"

<PageTitle>Textarea - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Default" Description="Default shadcn-style textarea with binding."
                        Code="@(@"<TextArea @bind-Value=""_message"" Placeholder=""Type your message..."" />")">
                <TextArea @bind-Value="_message" Placeholder="Type your message..." />
                <Paragraph Class="text-sm text-muted-foreground" Margin="Margin.Is0">Value: @_message</Paragraph>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Rows and max length" Description="Configure size and content limits."
                        Code="@(@"<TextArea @bind-Value=""_notes"" Rows=""6"" MaxLength=""200"" Placeholder=""Up to 200 chars..."" />")">
                <TextArea @bind-Value="_notes" Rows="6" MaxLength="200" Placeholder="Up to 200 chars..."></TextArea>
                <Paragraph Class="text-sm text-muted-foreground" Margin="Margin.Is0">Characters: @(_notes?.Length ?? 0)/200</Paragraph>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled" Description="Common textarea states."
                        Code="@(@"<TextArea Value=""Disabled content"" Disabled=""true"" />
<TextArea Value=""Read-only content"" ReadOnly=""true"" />")">
                <Div class="space-y-3">
                    <TextArea Value="Disabled content" Disabled="true"></TextArea>
                    <TextArea Value="Read-only content" ReadOnly="true"></TextArea>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid" Description="Use destructive border styling or nearby validation copy when the message needs correction."
                        Code="@(@"<TextArea Value=""Please enter at least 20 characters."" Class=""border-destructive focus-visible:ring-destructive"" />
<Paragraph class=""text-sm text-destructive"">Message must be at least 20 characters.</Paragraph>")">
                <Div class="space-y-3">
                    <TextArea Value="Please enter at least 20 characters." Class="border-destructive focus-visible:ring-destructive" />
                    <Paragraph class="text-sm text-destructive">Message must be at least 20 characters.</Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button" Description="Pair the textarea with a submit action for feedback or support forms."
                        Code="@(@"<Div class=""space-y-3"">
    <TextArea @bind-Value=""_message"" Placeholder=""Type your message..."" />
    <Button>Send message</Button>
</Div>")">
                <Div class="space-y-3">
                    <TextArea @bind-Value="_message" Placeholder="Type your message..." />
                    <Div class="flex justify-end">
                        <Button>Send message</Button>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _message;
    private string? _notes;
}
