@page "/components/images"

<PageTitle>Image - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <DemoSection Code="@DefaultCode" CodeLanguage="razor">
        <Div Class="flex min-h-96 items-center justify-center">
            <Image Source="@BallImage" Alt="Picture of a ball" Class="size-72">
                <ImagePreview />
            </Image>
        </Div>
    </DemoSection>

    <DemoSection Title="With Overlay Actions" Code="@OverlayActionsCode" CodeLanguage="razor">
        <Div Class="flex min-h-96 flex-wrap items-center justify-center gap-6">
            <Image Source="@BallImage" Alt="Picture of a ball" Class="size-72">
                <ImagePreview />
                <ImageActions Align="block-start">
                    <ImageActionGroup>
                        <ImageAction>
                            <Icon Name="LucideIcon.Download" />
                            <Span Class="sr-only">Download</Span>
                        </ImageAction>
                        <ImageAction>
                            <Icon Name="LucideIcon.Copy" />
                            <Span Class="sr-only">Copy</Span>
                        </ImageAction>
                    </ImageActionGroup>
                    <ImageActionGroup>
                        <ImageAction ButtonSize="ButtonSize.Sm">
                            Edit
                        </ImageAction>
                    </ImageActionGroup>
                </ImageActions>
            </Image>

            <Image Source="@BallImage" Alt="Picture of a ball" Class="size-72">
                <ImagePreview />
                <ImageActions Align="block-end">
                    <ImageActionGroup>
                        <ImageAction>
                            <Icon Name="LucideIcon.Download" />
                            <Span Class="sr-only">Download</Span>
                        </ImageAction>
                        <ImageAction>
                            <Icon Name="LucideIcon.Copy" />
                            <Span Class="sr-only">Copy</Span>
                        </ImageAction>
                    </ImageActionGroup>
                    <ImageActionGroup>
                        <ImageAction ButtonSize="ButtonSize.Sm">
                            Edit
                        </ImageAction>
                    </ImageActionGroup>
                </ImageActions>
            </Image>
        </Div>
    </DemoSection>

    <DemoSection Title="External URL" Code="@ExternalUrlCode" CodeLanguage="razor">
        <Div Class="flex min-h-96 items-center justify-center">
            <Image Source="https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=512&amp;h=512&amp;fit=crop" Alt="Image loaded from external URL" Class="size-72">
                <ImagePreview />
            </Image>
        </Div>
    </DemoSection>

    <DemoSection Title="No Source Placeholder" Code="@PlaceholderCode" CodeLanguage="razor">
        <Div Class="flex min-h-96 items-center justify-center">
            <Image Alt="Generated image placeholder" Class="size-72">
                <ImagePreview />
            </Image>
        </Div>
    </DemoSection>

    <DemoSection Title="Lightbox Preview" Code="@LightboxCode" CodeLanguage="razor">
        <Div Class="flex min-h-96 items-center justify-center">
            <Image Source="@BallImage" Alt="Preview that opens in a lightbox" Class="size-72">
                <ImagePreview TriggerLightbox="true" />
                <ImageLightbox>
                    <ImageLightboxPreview />
                    <Div Class="absolute top-4 right-4">
                        <ImageLightboxClose />
                    </Div>
                </ImageLightbox>
            </Image>
        </Div>
    </DemoSection>
</Div>

@code {
    private const string BallImage = "data:image/png;base64,";

    private const string DefaultCode =
@"<Image Source=""@BallImage"" Alt=""Picture of a ball"" Class=""size-72"">
    <ImagePreview />
</Image>";

    private const string OverlayActionsCode =
@"<Image Source=""@BallImage"" Alt=""Picture of a ball"" Class=""size-72"">
    <ImagePreview />
    <ImageActions Align=""block-start"">
        <ImageActionGroup>
            <ImageAction><Icon Name=""LucideIcon.Download"" /></ImageAction>
            <ImageAction><Icon Name=""LucideIcon.Copy"" /></ImageAction>
        </ImageActionGroup>
        <ImageActionGroup>
            <ImageAction ButtonSize=""ButtonSize.Sm"">Edit</ImageAction>
        </ImageActionGroup>
    </ImageActions>
</Image>";

    private const string ExternalUrlCode =
@"<Image Source=""https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=512&h=512&fit=crop""
       Alt=""Image loaded from external URL""
       Class=""size-72"">
    <ImagePreview />
</Image>";

    private const string PlaceholderCode =
@"<Image Alt=""Generated image placeholder"" Class=""size-72"">
    <ImagePreview />
</Image>";

    private const string LightboxCode =
@"<Image Source=""@BallImage"" Alt=""Preview that opens in a lightbox"" Class=""size-72"">
    <ImagePreview TriggerLightbox=""true"" />
    <ImageLightbox>
        <ImageLightboxPreview />
        <Div Class=""absolute top-4 right-4"">
            <ImageLightboxClose />
        </Div>
    </ImageLightbox>
</Image>";
}
