@page "/calendars"

<PageTitle>Calendar - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Single-date calendar with the month and year dropdown caption used in shadcn's calendar examples."
                         Code="@(@"<Calendar SelectedDate=""_overviewDate"" SelectedDateChanged=""OnOverviewDateChanged"" CaptionLayout=""dropdown"" Class=""rounded-lg border"" />")"
                         CodeLanguage="razor">
                <Calendar SelectedDate="_overviewDate"
                          SelectedDateChanged="OnOverviewDateChanged"
                          CaptionLayout="dropdown"
                          Class="rounded-lg border" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Persian / Hijri / Jalali Calendar"
                         Description="Calendar supports right-to-left Persian date formatting."
                         Code="@(@"<DirectionProvider Dir=""rtl"">
    <Calendar SelectedDate=""_persianDate"" SelectedDateChanged=""OnPersianDateChanged"" DisplayMonth=""_persianDisplayMonth"" CultureName=""fa-IR"" Class=""rounded-lg border p-3 [--cell-size:--spacing(8)]"" />
</DirectionProvider>")"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Calendar SelectedDate="_persianDate"
                              SelectedDateChanged="OnPersianDateChanged"
                              DisplayMonth="_persianDisplayMonth"
                              CultureName="fa-IR"
                              UseCultureCalendar="true"
                              FixedWeeks="true"
                              Class="rounded-lg border p-3 [--cell-size:--spacing(8)]" />
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A basic calendar component styled with a rounded border."
                         Code="@(@"<Calendar SelectedDate=""_basicDate"" SelectedDateChanged=""OnBasicDateChanged"" DisplayMonth=""_aprilDisplayMonth"" Class=""rounded-lg border"" />")"
                         CodeLanguage="razor">
                <Calendar SelectedDate="_basicDate"
                          SelectedDateChanged="OnBasicDateChanged"
                          DisplayMonth="_aprilDisplayMonth"
                          Class="rounded-lg border" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Range Calendar"
                         Description="Use range mode to enable range selection."
                         Code="@(@"<Card Class=""mx-auto w-fit p-0"">
    <CardBody Class=""p-0"">
        <Calendar Mode=""CalendarSelectionMode.Range"" DisplayMonth=""_rangeDisplayMonth"" SelectedRange=""_selectedRange"" SelectedRangeChanged=""OnSelectedRangeChanged"" NumberOfMonths=""2"" />
    </CardBody>
</Card>")"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFit" Padding="Padding.Is0">
                    <CardBody Padding="Padding.Is0">
                        <Calendar Mode="CalendarSelectionMode.Range"
                                  DisplayMonth="_rangeDisplayMonth"
                                  SelectedRange="_selectedRange"
                                  SelectedRangeChanged="OnSelectedRangeChanged"
                                  NumberOfMonths="2" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Month and Year Selector"
                         Description="Use month and year dropdowns for direct caption navigation."
                         Code="@DropdownCaptionCode"
                         CodeLanguage="razor">
                <Calendar SelectedDate="_dropdownCaptionDate"
                          SelectedDateChanged="OnDropdownCaptionDateChanged"
                          CaptionLayout="dropdown"
                          DisplayMonth="_aprilDisplayMonth"
                          Class="rounded-lg border" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Presets"
                         Description="Preset actions can drive the selected date while keeping the calendar as the source of date selection."
                         Code="@(@"<Div Class=""flex flex-col gap-3"">
    <Div Class=""flex gap-2"">
        <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"" OnClick=""SetCalendarPresetToday"">Today</Button>
        <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"" OnClick=""SetCalendarPresetNextWeek"">Next week</Button>
    </Div>
    <Calendar SelectedDate=""_presetDate"" SelectedDateChanged=""OnPresetDateChanged"" />
</Div>")"
                         CodeLanguage="razor">
                <Card Size="CardSize.Sm" Margin="Margin.Auto.OnX" Width="Width.IsFit" MaxWidth='MaxWidth.Token("[300px]")'>
                    <CardBody>
                        <Calendar SelectedDate="_presetDate"
                                  SelectedDateChanged="OnPresetDateChanged"
                                  DisplayMonth="_aprilDisplayMonth"
                                  FixedWeeks="true"
                                  Class="p-0 [--cell-size:--spacing(9.5)]" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Date and Time Picker"
                         Description="Use the date-time picker when the calendar selection needs a time value as well."
                         Code="@(@"<DateTimePicker @bind-SelectedDateTime=""_calendarDateTime"" />")"
                         CodeLanguage="razor">
                <Card Size="CardSize.Sm" Margin="Margin.Auto.OnX" Width="Width.IsFit">
                    <CardBody>
                        <Calendar SelectedDate="_calendarDate"
                                  SelectedDateChanged="OnCalendarDateChanged"
                                  DisplayMonth="_aprilDisplayMonth"
                                  Class="p-0" />
                    </CardBody>
                    <CardFooter Class="flex flex-col gap-3 border-t px-3! py-3!">
                        <Div Display="Display.Grid" Class="grid-cols-2 gap-3">
                            <Div Class="grid gap-1">
                                <Label for="time-from">Start Time</Label>
                                <Input Type="time" Id="time-from" Value="09:00:00" />
                            </Div>
                            <Div Class="grid gap-1">
                                <Label for="time-to">End Time</Label>
                                <Input Type="time" Id="time-to" Value="12:30:00" />
                            </Div>
                        </Div>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Booked dates"
                         Description="Use modifiers plus disabled dates to style and block already-booked days."
                         Code="@BookedDatesCode"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFit" Padding="Padding.Is0">
                    <CardBody Padding="Padding.Is0">
                        <Calendar SelectedDate="_bookedDate"
                                  SelectedDateChanged="OnBookedDateChanged"
                                  DisplayMonth="_bookedDisplayMonth"
                                  DisabledDates="_bookedDates"
                                  Modifiers="@BookedModifiers"
                                  ModifierClasses="@BookedModifierClasses" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Cell Size"
                         Description="Customize day cells with additional content such as pricing or availability cues."
                         Code="@CustomDaysCode"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFit" Padding="Padding.Is0">
                    <CardBody Padding="Padding.Is0">
                        <Calendar Mode="CalendarSelectionMode.Range"
                                  DisplayMonth="_customDayDisplayMonth"
                                  SelectedRange="_customDayRange"
                                  SelectedRangeChanged="OnCustomDayRangeChanged"
                                  CaptionLayout="dropdown"
                                  UseFullMonthNames="true"
                                  Class="[--cell-size:--spacing(10)] md:[--cell-size:--spacing(12)]"
                                  DayContent="@RenderPricingDay" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Week Numbers"
                         Description="Use week numbers for scheduling and planning workflows."
                         Code="@(@"<Card Class=""mx-auto w-fit p-0"">
    <CardBody Class=""p-0"">
        <Calendar SelectedDate=""_weekNumberDate"" SelectedDateChanged=""OnWeekNumberDateChanged"" ShowWeekNumber=""true"" />
    </CardBody>
</Card>")"
                         CodeLanguage="razor">
                <Card Margin="Margin.Auto.OnX" Width="Width.IsFit" Padding="Padding.Is0">
                    <CardBody Padding="Padding.Is0">
                        <Calendar SelectedDate="_weekNumberDate"
                                  SelectedDateChanged="OnWeekNumberDateChanged"
                                  DisplayMonth="_februaryDisplayMonth"
                                  ShowWeekNumber="true" />
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Calendar supports right-to-left layouts with locale-aware formatting."
                         Code="@(@"<DirectionProvider Dir=""rtl"">
    <Calendar SelectedDate=""_rtlDate"" SelectedDateChanged=""OnRtlDateChanged"" CaptionLayout=""dropdown"" CultureName=""ar-EG"" Class=""rounded-lg border [--cell-size:--spacing(9)]"" />
</DirectionProvider>")"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Calendar SelectedDate="_rtlDate"
                              SelectedDateChanged="OnRtlDateChanged"
                              DisplayMonth="_aprilDisplayMonth"
                              CaptionLayout="dropdown"
                              CultureName="ar-EG"
                              Class="rounded-lg border [--cell-size:--spacing(9)]" />
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private readonly DateOnly _aprilDisplayMonth = new(2026, 4, 1);
    private readonly DateOnly _februaryDisplayMonth = new(2026, 2, 1);
    private readonly DateOnly _customDayDisplayMonth = new(2026, 12, 1);
    private readonly DateOnly _persianDisplayMonth = new(2025, 6, 1);
    private DateOnly? _overviewDate = new(2026, 4, 30);
    private DateOnly? _persianDate = new(2025, 6, 12);
    private DateOnly? _basicDate;
    private CalendarDateRange? _selectedRange = new(new DateOnly(2026, 1, 12), new DateOnly(2026, 2, 11));
    private DateOnly[] _selectedDates =
    [
        DateOnly.FromDateTime(DateTime.Today),
        DateOnly.FromDateTime(DateTime.Today.AddDays(2)),
        DateOnly.FromDateTime(DateTime.Today.AddDays(5))
    ];
    private DateOnly? _weekNumberDate = new(2026, 2, 3);
    private DateOnly? _dropdownCaptionDate;
    private DateOnly? _presetDate;
    private DateOnly? _calendarDate = new(2026, 4, 12);
    private readonly DateOnly _bookedDisplayMonth = new(2026, 2, 1);
    private DateOnly[] _bookedDates =
    [
        new(2026, 2, 12),
        new(2026, 2, 13),
        new(2026, 2, 14),
        new(2026, 2, 15),
        new(2026, 2, 16),
        new(2026, 2, 17),
        new(2026, 2, 18),
        new(2026, 2, 19),
        new(2026, 2, 20),
        new(2026, 2, 21),
        new(2026, 2, 22),
        new(2026, 2, 23),
        new(2026, 2, 24),
        new(2026, 2, 25),
        new(2026, 2, 26)
    ];
    private DateOnly? _bookedDate = new(2026, 2, 3);
    private CalendarDateRange? _customDayRange = new(new DateOnly(2026, 12, 8), new DateOnly(2026, 12, 18));
    private DateOnly? _rtlDate = new(2026, 4, 30);

    private Dictionary<string, Func<DateOnly, bool>> BookedModifiers => new()
    {
        ["booked"] = date => _bookedDates.Contains(date)
    };

    private static Dictionary<string, string> BookedModifierClasses => new()
    {
        ["booked"] = "[&>button]:line-through opacity-100"
    };

    private DateOnly? _rangeDisplayMonth => _selectedRange?.From;

    private Task OnOverviewDateChanged(DateOnly? value)
    {
        _overviewDate = value;
        return Task.CompletedTask;
    }

    private Task OnPersianDateChanged(DateOnly? value)
    {
        _persianDate = value;
        return Task.CompletedTask;
    }

    private Task OnBasicDateChanged(DateOnly? value)
    {
        _basicDate = value;
        return Task.CompletedTask;
    }

    private Task OnSelectedRangeChanged(CalendarDateRange? value)
    {
        _selectedRange = value;
        return Task.CompletedTask;
    }

    private Task OnSelectedDatesChanged(DateOnly[] value)
    {
        _selectedDates = value;
        return Task.CompletedTask;
    }

    private Task OnPresetDateChanged(DateOnly? value)
    {
        _presetDate = value;
        return Task.CompletedTask;
    }

    private void SetCalendarPresetToday()
    {
        _presetDate = new DateOnly(2026, 4, 30);
    }

    private void SetCalendarPresetNextWeek()
    {
        _presetDate = new DateOnly(2026, 5, 7);
    }

    private Task OnWeekNumberDateChanged(DateOnly? value)
    {
        _weekNumberDate = value;
        return Task.CompletedTask;
    }

    private Task OnDropdownCaptionDateChanged(DateOnly? value)
    {
        _dropdownCaptionDate = value;
        return Task.CompletedTask;
    }

    private Task OnCalendarDateChanged(DateOnly? value)
    {
        _calendarDate = value;
        return Task.CompletedTask;
    }

    private Task OnBookedDateChanged(DateOnly? value)
    {
        _bookedDate = value;
        return Task.CompletedTask;
    }

    private Task OnCustomDayRangeChanged(CalendarDateRange? value)
    {
        _customDayRange = value;
        return Task.CompletedTask;
    }

    private Task OnRtlDateChanged(DateOnly? value)
    {
        _rtlDate = value;
        return Task.CompletedTask;
    }

    private static string FormatRange(CalendarDateRange? value)
    {
        if (value?.From is null)
            return "No dates selected";

        if (value.To is null)
            return value.From.Value.ToString("yyyy-MM-dd");

        return $"{value.From.Value:yyyy-MM-dd} to {value.To.Value:yyyy-MM-dd}";
    }

    private static string FormatDates(IEnumerable<DateOnly> values)
    {
        var selected = values.Select(value => value.ToString("yyyy-MM-dd")).ToArray();
        return selected.Length == 0 ? "No dates selected" : string.Join(", ", selected);
    }

    private static bool IsWeekend(DateOnly date)
    {
        return date.DayOfWeek is DayOfWeek.Saturday or DayOfWeek.Sunday;
    }

    private RenderFragment<CalendarDayContext> RenderPricingDay => context => @<Div Display="Display.Flex" Flex=@("flex-col") ItemsAlign="Items.Center" Leading="Leading.None">
        <Span>@context.Date.Day</Span>
        @if (context.InMonth)
        {
            <Span TextSize='TextSize.Token("[10px]")' Class="opacity-70">@(IsWeekend(context.Date) ? "$120" : "$100")</Span>
        }
    </Div>;

    private const string DropdownCaptionCode =
@"<Card Class=""mx-auto w-fit p-0"">
    <CardBody Class=""p-0"">
        <Calendar SelectedDate=""selectedDate"" SelectedDateChanged=""OnDateChanged"" CaptionLayout=""dropdown"" CultureName=""es-ES"" />
    </CardBody>
</Card>";

    private const string BookedDatesCode =
@"<Card Class=""mx-auto w-fit p-0"">
    <CardBody Class=""p-0"">
        <Calendar SelectedDate=""selectedDate""
                  DisplayMonth=""bookedDisplayMonth""
                  DisabledDates=""bookedDates""
                  Modifiers=""BookedModifiers""
                  ModifierClasses=""BookedModifierClasses"" />
    </CardBody>
</Card>";

    private const string CustomDaysCode =
@"<Card Class=""mx-auto w-fit p-0"">
    <CardBody Class=""p-0"">
        <Calendar Mode=""CalendarSelectionMode.Range""
                  SelectedRange=""selectedRange""
                  SelectedRangeChanged=""OnRangeChanged""
                  CaptionLayout=""dropdown""
                  DayContent=""RenderPricingDay"" />
    </CardBody>
</Card>";
}
