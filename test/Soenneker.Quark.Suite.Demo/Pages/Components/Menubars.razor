@page "/menubars"

<PageTitle>Menubar - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="A visually persistent menu common in desktop applications that provides quick access to a consistent set of commands."
                         Code="@MenubarCode"
                         CodeLanguage="razor">
                <Menubar Class="w-72">
                    <MenubarMenu>
                        <MenubarTrigger>File</MenubarTrigger>
                        <MenubarContent>
                            <MenubarItem>New Tab <MenubarShortcut>⌘T</MenubarShortcut></MenubarItem>
                            <MenubarItem>New Window <MenubarShortcut>⌘N</MenubarShortcut></MenubarItem>
                            <MenubarItem Disabled="true">New Incognito Window</MenubarItem>
                            <MenubarSeparator />
                            <MenubarSub>
                                <MenubarSubTrigger>Share</MenubarSubTrigger>
                                <MenubarSubContent>
                                    <MenubarItem>Email link</MenubarItem>
                                    <MenubarItem>Messages</MenubarItem>
                                    <MenubarItem>Notes</MenubarItem>
                                </MenubarSubContent>
                            </MenubarSub>
                            <MenubarSeparator />
                            <MenubarItem>Print... <MenubarShortcut>⌘P</MenubarShortcut></MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                    <MenubarMenu>
                        <MenubarTrigger>Edit</MenubarTrigger>
                        <MenubarContent>
                            <MenubarItem>Undo <MenubarShortcut>⌘Z</MenubarShortcut></MenubarItem>
                            <MenubarItem>Redo <MenubarShortcut>⇧⌘Z</MenubarShortcut></MenubarItem>
                            <MenubarSeparator />
                            <MenubarItem>Cut</MenubarItem>
                            <MenubarItem>Copy</MenubarItem>
                            <MenubarItem>Paste</MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                    <MenubarMenu>
                        <MenubarTrigger>View</MenubarTrigger>
                        <MenubarContent>
                            <MenubarCheckboxItem Checked="true">Always Show Bookmarks Bar</MenubarCheckboxItem>
                            <MenubarCheckboxItem>Always Show Full URLs</MenubarCheckboxItem>
                            <MenubarSeparator />
                            <MenubarItem Indented="true">Reload <MenubarShortcut>⌘R</MenubarShortcut></MenubarItem>
                            <MenubarItem Disabled="true" Indented="true">Force Reload <MenubarShortcut>⇧⌘R</MenubarShortcut></MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                    <MenubarMenu>
                        <MenubarTrigger>Profiles</MenubarTrigger>
                        <MenubarContent>
                            <MenubarRadioGroup Value="@_profile">
                                <MenubarRadioItem Value="andy">Andy</MenubarRadioItem>
                                <MenubarRadioItem Value="benoit">Benoit</MenubarRadioItem>
                                <MenubarRadioItem Value="luis">Luis</MenubarRadioItem>
                            </MenubarRadioGroup>
                            <MenubarSeparator />
                            <MenubarItem Indented="true">Edit...</MenubarItem>
                            <MenubarItem Indented="true">Add Profile...</MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                </Menubar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkbox"
                         Code="@CheckboxCode"
                         CodeLanguage="razor">
                <Menubar Class="w-72">
                    <MenubarMenu>
                        <MenubarTrigger>View</MenubarTrigger>
                        <MenubarContent>
                            <MenubarCheckboxItem @bind-Checked="_showBookmarksBar">Always Show Bookmarks Bar</MenubarCheckboxItem>
                            <MenubarCheckboxItem @bind-Checked="_showFullUrls">Always Show Full URLs</MenubarCheckboxItem>
                            <MenubarSeparator />
                            <MenubarItem Indented="true">Reload <MenubarShortcut>⌘R</MenubarShortcut></MenubarItem>
                            <MenubarItem Disabled="true" Indented="true">Force Reload <MenubarShortcut>⇧⌘R</MenubarShortcut></MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                    <MenubarMenu>
                        <MenubarTrigger>Format</MenubarTrigger>
                        <MenubarContent>
                            <MenubarCheckboxItem Checked="true">Strikethrough</MenubarCheckboxItem>
                            <MenubarCheckboxItem>Code</MenubarCheckboxItem>
                            <MenubarCheckboxItem>Superscript</MenubarCheckboxItem>
                        </MenubarContent>
                    </MenubarMenu>
                </Menubar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio"
                         Code="@RadioCode"
                         CodeLanguage="razor">
                <Menubar Class="w-72">
                    <MenubarMenu>
                        <MenubarTrigger>Profiles</MenubarTrigger>
                        <MenubarContent>
                            <MenubarRadioGroup Value="@_radioProfile" ValueChanged="HandleProfileChanged">
                                <MenubarRadioItem Value="andy">Andy</MenubarRadioItem>
                                <MenubarRadioItem Value="benoit">Benoit</MenubarRadioItem>
                                <MenubarRadioItem Value="luis">Luis</MenubarRadioItem>
                            </MenubarRadioGroup>
                            <MenubarSeparator />
                            <MenubarItem Indented="true">Edit...</MenubarItem>
                            <MenubarItem Indented="true">Add Profile...</MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                    <MenubarMenu>
                        <MenubarTrigger>Theme</MenubarTrigger>
                        <MenubarContent>
                            <MenubarRadioGroup Value="@_theme" ValueChanged="HandleThemeChanged">
                                <MenubarRadioItem Value="light">Light</MenubarRadioItem>
                                <MenubarRadioItem Value="dark">Dark</MenubarRadioItem>
                                <MenubarRadioItem Value="system">System</MenubarRadioItem>
                            </MenubarRadioGroup>
                        </MenubarContent>
                    </MenubarMenu>
                </Menubar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu"
                         Code="@SubmenuCode"
                         CodeLanguage="razor">
                <Menubar Class="w-72">
                    <MenubarMenu>
                        <MenubarTrigger>File</MenubarTrigger>
                        <MenubarContent>
                            <MenubarItem>New Tab <MenubarShortcut>⌘T</MenubarShortcut></MenubarItem>
                            <MenubarItem>New Window <MenubarShortcut>⌘N</MenubarShortcut></MenubarItem>
                            <MenubarSeparator />
                            <MenubarSub>
                                <MenubarSubTrigger>Share</MenubarSubTrigger>
                                <MenubarSubContent>
                                    <MenubarItem>Email link</MenubarItem>
                                    <MenubarItem>Messages</MenubarItem>
                                    <MenubarItem>Notes</MenubarItem>
                                </MenubarSubContent>
                            </MenubarSub>
                            <MenubarSeparator />
                            <MenubarItem>Print... <MenubarShortcut>⌘P</MenubarShortcut></MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                    <MenubarMenu>
                        <MenubarTrigger>Edit</MenubarTrigger>
                        <MenubarContent>
                            <MenubarItem>Undo <MenubarShortcut>⌘Z</MenubarShortcut></MenubarItem>
                            <MenubarItem>Redo <MenubarShortcut>⇧⌘Z</MenubarShortcut></MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                </Menubar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icons"
                         Code="@IconsCode"
                         CodeLanguage="razor">
                <Menubar Class="w-72">
                    <MenubarMenu>
                        <MenubarTrigger>File</MenubarTrigger>
                        <MenubarContent>
                            <MenubarItem><Icon Name="LucideIcon.File" />New File <MenubarShortcut>⌘N</MenubarShortcut></MenubarItem>
                            <MenubarItem><Icon Name="LucideIcon.Folder" />Open Folder</MenubarItem>
                            <MenubarSeparator />
                            <MenubarItem Destructive="true"><Icon Name="LucideIcon.Trash" />Delete File <MenubarShortcut>⌘⌫</MenubarShortcut></MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                    <MenubarMenu>
                        <MenubarTrigger>More</MenubarTrigger>
                        <MenubarContent>
                            <MenubarItem><Icon Name="LucideIcon.User" />Profile</MenubarItem>
                            <MenubarItem><Icon Name="LucideIcon.Settings" />Settings</MenubarItem>
                            <MenubarSeparator />
                            <MenubarItem><Icon Name="LucideIcon.LogOut" />Sign out</MenubarItem>
                        </MenubarContent>
                    </MenubarMenu>
                </Menubar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         ShowPreviewToolbar="true"
                         PreviewLang="ar"
                         PreviewDir="rtl">
                <DirectionProvider Dir="rtl">
                    <Menubar Class="w-72">
                        <MenubarMenu>
                            <MenubarTrigger>ملف</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem>علامة تبويب جديدة</MenubarItem>
                                <MenubarItem>نافذة جديدة</MenubarItem>
                                <MenubarSeparator />
                                <MenubarItem>طباعة...</MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                        <MenubarMenu>
                            <MenubarTrigger>تعديل</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem>تراجع</MenubarItem>
                                <MenubarItem>إعادة</MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                        <MenubarMenu>
                            <MenubarTrigger>عرض</MenubarTrigger>
                            <MenubarContent>
                                <MenubarCheckboxItem Checked="true">إظهار شريط الإشارات</MenubarCheckboxItem>
                                <MenubarCheckboxItem>إظهار عناوين URL كاملة</MenubarCheckboxItem>
                            </MenubarContent>
                        </MenubarMenu>
                        <MenubarMenu>
                            <MenubarTrigger>الملفات الشخصية</MenubarTrigger>
                            <MenubarContent>
                                <MenubarRadioGroup Value="@_profile">
                                    <MenubarRadioItem Value="andy">Andy</MenubarRadioItem>
                                    <MenubarRadioItem Value="benoit">Benoit</MenubarRadioItem>
                                    <MenubarRadioItem Value="luis">Luis</MenubarRadioItem>
                                </MenubarRadioGroup>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string _profile = "benoit";
    private string _radioProfile = "benoit";
    private string _theme = "system";
    private bool _showBookmarksBar = true;
    private bool _showFullUrls;

    private Task HandleProfileChanged(string? value)
    {
        _radioProfile = value ?? _radioProfile;
        return Task.CompletedTask;
    }

    private Task HandleThemeChanged(string? value)
    {
        _theme = value ?? _theme;
        return Task.CompletedTask;
    }

    private const string MenubarCode =
@"<Menubar>
    <MenubarMenu>
        <MenubarTrigger>File</MenubarTrigger>
        <MenubarContent>
            <MenubarItem>New Tab <MenubarShortcut>⌘T</MenubarShortcut></MenubarItem>
            <MenubarItem>New Window <MenubarShortcut>⌘N</MenubarShortcut></MenubarItem>
            <MenubarItem Disabled=""true"">New Incognito Window</MenubarItem>
        </MenubarContent>
    </MenubarMenu>
</Menubar>";

    private const string CheckboxCode =
@"<Menubar>
    <MenubarMenu>
        <MenubarTrigger>View</MenubarTrigger>
        <MenubarContent>
            <MenubarCheckboxItem>Always Show Bookmarks Bar</MenubarCheckboxItem>
            <MenubarCheckboxItem>Always Show Full URLs</MenubarCheckboxItem>
        </MenubarContent>
    </MenubarMenu>
</Menubar>";

    private const string RadioCode =
@"<Menubar>
    <MenubarMenu>
        <MenubarTrigger>Profiles</MenubarTrigger>
        <MenubarContent>
            <MenubarRadioGroup Value=""benoit"">
                <MenubarRadioItem Value=""andy"">Andy</MenubarRadioItem>
                <MenubarRadioItem Value=""benoit"">Benoit</MenubarRadioItem>
                <MenubarRadioItem Value=""luis"">Luis</MenubarRadioItem>
            </MenubarRadioGroup>
        </MenubarContent>
    </MenubarMenu>
</Menubar>";

    private const string SubmenuCode =
@"<Menubar>
    <MenubarMenu>
        <MenubarTrigger>File</MenubarTrigger>
        <MenubarContent>
            <MenubarSub>
                <MenubarSubTrigger>Share</MenubarSubTrigger>
                <MenubarSubContent>
                    <MenubarItem>Email link</MenubarItem>
                    <MenubarItem>Messages</MenubarItem>
                    <MenubarItem>Notes</MenubarItem>
                </MenubarSubContent>
            </MenubarSub>
        </MenubarContent>
    </MenubarMenu>
</Menubar>";

    private const string IconsCode =
@"<Menubar>
    <MenubarMenu>
        <MenubarTrigger>File</MenubarTrigger>
        <MenubarContent>
            <MenubarItem><Icon Name=""LucideIcon.File"" />New File</MenubarItem>
            <MenubarItem><Icon Name=""LucideIcon.Folder"" />Open Folder</MenubarItem>
            <MenubarItem Destructive=""true""><Icon Name=""LucideIcon.Trash"" />Delete File</MenubarItem>
        </MenubarContent>
    </MenubarMenu>
</Menubar>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Menubar>
        <MenubarMenu>
            <MenubarTrigger>ملف</MenubarTrigger>
            <MenubarContent>
                <MenubarItem>علامة تبويب جديدة</MenubarItem>
            </MenubarContent>
        </MenubarMenu>
    </Menubar>
</DirectionProvider>";
}
