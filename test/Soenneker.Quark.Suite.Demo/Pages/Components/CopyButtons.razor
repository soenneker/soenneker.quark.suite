@page "/components/copy-button"

<PageTitle>Copy Button - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                Description="Copy text to clipboard with animated status feedback."
                Code="@BasicCode"
                CodeLanguage="razor"
                PreviewClass="preview flex min-h-[14rem] w-full items-center justify-center"
                PreviewInnerClass="demo-section-preview-inner flex w-full items-center justify-center">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is3">
                    <CopyButton Text="@SampleText" />
                    <CopyButton Text="@SampleText" ButtonSize="ButtonSize.Sm">Copy</CopyButton>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string SampleText = "Text copied from Quark Suite.";

    private const string BasicCode =
@"<Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Justify=""Justify.Center"" Gap=""Gap.Is3"">
    <CopyButton Text=""@SampleText"" />
    <CopyButton Text=""@SampleText"" ButtonSize=""ButtonSize.Sm"">Copy</CopyButton>
</Div>";
}
