@page "/stack"
@page "/stacks"

<PageTitle>Stack - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is6xl">
    <Div Space="Space.Y.Is3">
        <H1>Stack</H1>
        <Paragraph>
            `Stack` is a dedicated flex layout wrapper for one-dimensional flows. It defaults to a vertical stack,
            keeps the API obvious for the common cases, and still lets you layer on the broader Quark element
            and flex utility surface when a layout needs more control.
        </Paragraph>
    </Div>

    <Div Space="Space.Y.Is6">
        <DemoSection Title="Default Vertical Stack"
                     Description="Items flow vertically out of the box."
                     Code="@(@"<Stack Gap=""Gap.Is4"">
    <Div Class=""rounded-lg border p-4"">Profile</Div>
    <Div Class=""rounded-lg border p-4"">Billing</Div>
    <Div Class=""rounded-lg border p-4"">Security</Div>
</Stack>")"
CodeLanguage="razor">
            <Paragraph>
                The default orientation is vertical, which makes `Stack` a good fit for settings sections, forms,
                and any content flow where each child should sit underneath the previous one.
            </Paragraph>
            <Stack Gap="Gap.Is4">
                <Div Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Class="shadow-sm">
                    <H3>Profile</H3>
                    <Paragraph>Personal details and account preferences.</Paragraph>
                </Div>
                <Div Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Class="shadow-sm">
                    <H3>Billing</H3>
                    <Paragraph>Payment methods, invoices, and plan controls.</Paragraph>
                </Div>
                <Div Rounded="Rounded.Xl" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" Class="shadow-sm">
                    <H3>Security</H3>
                    <Paragraph>Sessions, MFA, and access review settings.</Paragraph>
                </Div>
            </Stack>
        </DemoSection>

        <DemoSection Title="Horizontal Stack"
                     Description="Switch to a row-oriented layout for inline groups and toolbars."
                     Code="@(@"<Stack Orientation=""StackOrientation.Horizontal"" Gap=""Gap.Is3"" Class=""flex-wrap"">
    ...
</Stack>")"
CodeLanguage="razor">
            <Paragraph>
                Set `Orientation` to `Horizontal` when you want pills, actions, or summary cards to flow in a row.
            </Paragraph>
            <Stack Orientation="StackOrientation.Horizontal" Gap="Gap.Is3" Class="flex-wrap">
                <Div Rounded="Rounded.Full" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding='Padding.Is4.OnX.Is2.OnY'>All</Div>
                <Div Rounded="Rounded.Full" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding='Padding.Is4.OnX.Is2.OnY'>Open</Div>
                <Div Rounded="Rounded.Full" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding='Padding.Is4.OnX.Is2.OnY'>Assigned</Div>
                <Div Rounded="Rounded.Full" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding='Padding.Is4.OnX.Is2.OnY'>Completed</Div>
            </Stack>
        </DemoSection>

        <DemoSection Title="Responsive Stack"
                     Description="Keep the default vertical flow, then pivot to a row layout at larger breakpoints."
                     Code="@(@"<Stack Gap=""Gap.Is4"" Class=""sm:flex-row sm:items-center sm:justify-between"">
    ...
</Stack>")"
CodeLanguage="razor">
            <Stack Gap="Gap.Is4" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is5" Class="rounded-2xl sm:flex-row sm:items-center sm:justify-between">
                <Div Class="min-w-0">
                    <H3>Deployment summary</H3>
                    <Paragraph>
                        Start stacked for narrow screens, then spread content out horizontally once there is enough room.
                    </Paragraph>
                </Div>
                <Stack Orientation="StackOrientation.Horizontal" Gap="Gap.Is2" Class="flex-wrap">
                    <Span Rounded="Rounded.Full" Border="Border.Is1" Padding='Padding.Is3.OnX.Is1.OnY' TextSize="TextSize.Sm">12 services</Span>
                    <Span Rounded="Rounded.Full" Border="Border.Is1" Padding='Padding.Is3.OnX.Is1.OnY' TextSize="TextSize.Sm">3 regions</Span>
                    <Span Rounded="Rounded.Full" Border="Border.Is1" Padding='Padding.Is3.OnX.Is1.OnY' TextSize="TextSize.Sm">Healthy</Span>
                </Stack>
            </Stack>
        </DemoSection>

        <DemoSection Title="Inherited Element and Flex Features"
                     Description="Use the shared element API and optional flex utilities when the basic stack needs more behavior."
                     Code="@(@"<Stack Gap=""Gap.Is3"" Flex=""flex-wrap"" ItemsAlign=""Items.Center"" Class=""rounded-xl border p-4"">
    ...
</Stack>")"
CodeLanguage="razor">
            <Stack Gap="Gap.Is3" Flex=@("flex-wrap") ItemsAlign="Items.Center" Rounded="Rounded.Xl" Border="Border.Is1" Padding="Padding.Is4">
                <Span Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Muted" Padding='Padding.Is3.OnX.Token("1.5").OnY' TextSize="TextSize.Sm">Shared `Gap` support</Span>
                <Span Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Muted" Padding='Padding.Is3.OnX.Token("1.5").OnY' TextSize="TextSize.Sm">Optional `Flex` helpers</Span>
                <Span Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Muted" Padding='Padding.Is3.OnX.Token("1.5").OnY' TextSize="TextSize.Sm">Standard ids, classes, styles, and spacing</Span>
            </Stack>
        </DemoSection>
    </Div>
</Div>
