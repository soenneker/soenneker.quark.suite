@page "/components/announcement"

<PageTitle>Announcement Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                Description="Pill-shaped announcement badge for product updates, feature releases, or version bumps."
                Code="@DemoCode"
                CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Announcement TagText="New" Href="#announcement">
                        Introducing Quark Suite components
                    </Announcement>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Themed"
                         Description="Use primary themed colors when the announcement needs more emphasis."
                         Code="@ThemedCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Announcement TagText="Beta" Themed="true" Href="#themed">
                        Try the updated component playground
                    </Announcement>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icon"
                         Description="Add an icon before the text while preserving the compact pill layout."
                         Code="@IconCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Announcement TagText="Release" Href="#release">
                        <IconContent>
                            <Icon Name="LucideIcon.Sparkles" Class="size-3.5" aria-hidden="true" />
                        </IconContent>
                        <ChildContent>
                            Version 4.0 is now available
                        </ChildContent>
                    </Announcement>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Long Text"
                         Description="Announcement text truncates inside constrained layouts."
                         Code="@LongTextCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Div Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                        <Announcement TagText="Update" Href="#long-text">
                            This announcement is intentionally long so it truncates cleanly when the available horizontal space is constrained
                        </Announcement>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Without Chevron"
                         Description="Disable the trailing chevron for status-only announcements."
                         Code="@NoChevronCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" Justify="Justify.Center">
                    <Announcement TagText="Stable" ShowChevron="false">
                        All systems operational
                    </Announcement>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Announcement TagText=""New"" Href=""#announcement"">
    Introducing Quark Suite components
</Announcement>";

    private const string ThemedCode =
@"<Announcement TagText=""Beta"" Themed=""true"" Href=""#themed"">
    Try the updated component playground
</Announcement>";

    private const string IconCode =
@"<Announcement TagText=""Release"" Href=""#release"">
    <IconContent>
        <Icon Name=""LucideIcon.Sparkles"" Class=""size-3.5"" aria-hidden=""true"" />
    </IconContent>
    <ChildContent>
        Version 4.0 is now available
    </ChildContent>
</Announcement>";

    private const string LongTextCode =
@"<Div Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsSm"">
    <Announcement TagText=""Update"" Href=""#long-text"">
        This announcement is intentionally long so it truncates cleanly when the available horizontal space is constrained
    </Announcement>
</Div>";

    private const string NoChevronCode =
@"<Announcement TagText=""Stable"" ShowChevron=""false"">
    All systems operational
</Announcement>";
}
