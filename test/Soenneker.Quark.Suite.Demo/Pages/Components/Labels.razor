@page "/labels"
@using Soenneker.Quark.Forms

<PageTitle>Label - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Checkbox"
                         Description="Renders an accessible label associated with a checkbox."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Field Orientation="horizontal">
                    <Check Id="label-demo-terms" />
                    <Label For="label-demo-terms">Accept terms and conditions</Label>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Input"
                         Description="Associate a label with an input by matching For and Id."
                         Code="@InputCode"
                         CodeLanguage="razor">
                <Field>
                    <Label For="label-demo-username">Username</Label>
                    <Input Id="label-demo-username" Placeholder="Username" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disabled fields dim labels through the shared data-disabled contract."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Field Disabled="true">
                    <Label For="label-demo-disabled">Disabled</Label>
                    <Input Id="label-demo-disabled" Placeholder="Disabled" Disabled="true" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Textarea"
                         Description="Labels use the same primitive when paired with textarea controls."
                         Code="@TextareaCode"
                         CodeLanguage="razor">
                <Field>
                    <Label For="label-demo-message">Message</Label>
                    <TextArea Id="label-demo-message" Placeholder="Message" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         PreviewDir="rtl"
                         PreviewLang="ar"
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex gap-2">
                        <Check Id="terms-rtl" />
                        <Label For="terms-rtl">قبول الشروط والأحكام</Label>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Field Orientation=""horizontal"">
    <Check Id=""label-demo-terms"" />
    <Label For=""label-demo-terms"">Accept terms and conditions</Label>
</Field>";

    private const string InputCode =
@"<Field>
    <Label For=""label-demo-username"">Username</Label>
    <Input Id=""label-demo-username"" Placeholder=""Username"" />
</Field>";

    private const string DisabledCode =
@"<Field Disabled=""true"">
    <Label For=""label-demo-disabled"">Disabled</Label>
    <Input Id=""label-demo-disabled"" Placeholder=""Disabled"" Disabled=""true"" />
</Field>";

    private const string TextareaCode =
@"<Field>
    <Label For=""label-demo-message"">Message</Label>
    <TextArea Id=""label-demo-message"" Placeholder=""Message"" />
</Field>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Class=""flex gap-2"">
        <Check Id=""terms-rtl"" />
        <Label For=""terms-rtl"">قبول الشروط والأحكام</Label>
    </Div>
</DirectionProvider>";
}
