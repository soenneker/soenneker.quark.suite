@page "/labels"

<PageTitle>Label - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Official shadcn checkbox and label pairing."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="flex gap-2">
                    <Check Id="terms" />
                    <Label For="terms">Accept terms and conditions</Label>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Standalone labels, grids, and pairing with native controls.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Label in Field"
                         Description="Associate the label with the control using FieldLabel and matching ids."
                         Code="@LabelInFieldCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="label-field-email">Email</FieldLabel>
                    <Input Id="label-field-email" Type="email" Placeholder="name@example.com" />
                    <FieldDescription>We will never share your email.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Form Controls"
                         Description="Two columns of labeled inputs."
                         Code="@FormControlsCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-[44rem]"
                         CodeLanguage="razor">
                <Div Display="Display.Grid" Gap="Gap.Is4" Class="md:grid-cols-2">
                    <Div Space="Space.Y.Is1">
                        <Label Form="true" For="label-username">Username</Label>
                        <Input Id="label-username" Placeholder="Enter username" />
                    </Div>
                    <Div Space="Space.Y.Is1">
                        <Label Form="true" For="label-password">Password</Label>
                        <Input Id="label-password" Type="password" Placeholder="Enter password" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Official shadcn RTL example."
                         PreviewDir="rtl"
                         PreviewLang="ar"
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex gap-2">
                        <Check Id="terms-rtl" />
                        <Label For="terms-rtl">قبول الشروط والأحكام</Label>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Checkbox and Radio"
                         Description="Label as caption for checkbox or radio controls."
                         Code="@CheckboxRadioCode"
                         CodeLanguage="razor">
                <Div Space="Space.Y.Is4">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is2">
                        <Check Id="label-remember-me">Remember me</Check>
                    </Div>
                    <Div>
                        <Label Form="true" Class="mb-2 block">Choose an option:</Label>
                        <Div Class="flex gap-4">
                            <Radio Name="label-option" Value="option1">Option 1</Radio>
                            <Radio Name="label-option" Value="option2">Option 2</Radio>
                        </Div>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Label Features"
                         Description="Common Label properties in Quark."
                         Code="@FeaturesCode"
                         CodeLanguage="razor">
                <Div Rounded="Rounded.Xl" Border="Border.Is1" Padding="Padding.Is6" Class="bg-muted/30">
                    <UnorderedList Class="list-inside list-disc space-y-1 text-sm">
                        <UnorderedListItem><Strong>Id, Class, Style</Strong> — HTML attributes</UnorderedListItem>
                        <UnorderedListItem><Strong>Form, For</Strong> — Form association</UnorderedListItem>
                        <UnorderedListItem><Strong>Margin/Padding</Strong> — Spacing</UnorderedListItem>
                    </UnorderedList>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Div Class=""flex gap-2"">
    <Check Id=""terms"" />
    <Label For=""terms"">Accept terms and conditions</Label>
</Div>";

    private const string LabelInFieldCode =
@"<Field Class=""max-w-xs"">
    <FieldLabel For=""label-field-email"">Email</FieldLabel>
    <Input Id=""label-field-email"" Type=""email"" Placeholder=""name@example.com"" />
    <FieldDescription>We will never share your email.</FieldDescription>
</Field>";

    private const string FormControlsCode =
@"<Div Class=""grid gap-4 md:grid-cols-2"">
    <Div Class=""space-y-1"">
        <Label Form=""true"" For=""label-username"">Username</Label>
        <Input Id=""label-username"" Placeholder=""Enter username"" />
    </Div>
    <Div Class=""space-y-1"">
        <Label Form=""true"" For=""label-password"">Password</Label>
        <Input Id=""label-password"" Type=""password"" Placeholder=""Enter password"" />
    </Div>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Class=""flex gap-2"">
        <Check Id=""terms-rtl"" />
        <Label For=""terms-rtl"">قبول الشروط والأحكام</Label>
    </Div>
</DirectionProvider>";

    private const string CheckboxRadioCode =
@"<Div Class=""space-y-4"">
    <Div Class=""flex items-center gap-2"">
        <Check Id=""label-remember-me"">Remember me</Check>
    </Div>
    <Div>
        <Label Form=""true"" Class=""mb-2 block"">Choose an option:</Label>
        <Div Class=""flex gap-4"">
            <Radio Name=""label-option"" Value=""option1"">Option 1</Radio>
            <Radio Name=""label-option"" Value=""option2"">Option 2</Radio>
        </Div>
    </Div>
</Div>";

    private const string FeaturesCode =
@"<Div Class=""rounded-xl border bg-muted/30 p-6"">
    <UnorderedList Class=""list-inside list-disc space-y-1 text-sm"">
        <UnorderedListItem><Strong>Id, Class, Style</Strong> — HTML attributes</UnorderedListItem>
        <UnorderedListItem><Strong>Form, For</Strong> — Form association</UnorderedListItem>
        <UnorderedListItem><Strong>Margin/Padding</Strong> — Spacing</UnorderedListItem>
    </UnorderedList>
</Div>";
}
