@page "/tabs"

<PageTitle>Tabs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Displays a set of tabs that switch between related panels."
                         Code="@BasicCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-[32rem] w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0">
                <Tabs Composed="true" SelectedTab="overview" Width='Width.Token("[400px]")'>
                    <TabsList>
                        <TabsTrigger Value="overview">Overview</TabsTrigger>
                        <TabsTrigger Value="analytics">Analytics</TabsTrigger>
                        <TabsTrigger Value="reports">Reports</TabsTrigger>
                        <TabsTrigger Value="settings">Settings</TabsTrigger>
                    </TabsList>
                    <TabsContent Value="overview">
                        <Card Margin="Margin.Is4.FromTop">
                            <CardHeader>
                                <CardTitle>Overview</CardTitle>
                                <CardDescription>View your key metrics and recent project activity. Track progress across all your active projects.</CardDescription>
                            </CardHeader>
                            <CardContent>
                                <Paragraph Margin="Margin.Is0">You have 12 active projects and 3 pending tasks.</Paragraph>
                            </CardContent>
                        </Card>
                    </TabsContent>
                    <TabsContent Value="analytics">
                        <Card Margin="Margin.Is4.FromTop">
                            <CardHeader>
                                <CardTitle>Analytics</CardTitle>
                                <CardDescription>Review performance metrics and usage trends.</CardDescription>
                            </CardHeader>
                        </Card>
                    </TabsContent>
                    <TabsContent Value="reports">
                        <Card Margin="Margin.Is4.FromTop">
                            <CardHeader>
                                <CardTitle>Reports</CardTitle>
                                <CardDescription>Download and share reports with your team.</CardDescription>
                            </CardHeader>
                        </Card>
                    </TabsContent>
                    <TabsContent Value="settings">
                        <Card Margin="Margin.Is4.FromTop">
                            <CardHeader>
                                <CardTitle>Settings</CardTitle>
                                <CardDescription>Update workspace preferences.</CardDescription>
                            </CardHeader>
                        </Card>
                    </TabsContent>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Line"
                         Description="A line style tabs list."
                         Code="@LineCode"
                         CodeLanguage="razor">
                <Tabs Composed="true" TabsListVariant="TabsListVariant.Line">
                    <TabsList>
                        <TabsTrigger Value="overview">Overview</TabsTrigger>
                        <TabsTrigger Value="analytics">Analytics</TabsTrigger>
                        <TabsTrigger Value="reports">Reports</TabsTrigger>
                    </TabsList>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="A vertical tabs list."
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Tabs Composed="true" Vertical="true">
                    <TabsList>
                        <TabsTrigger Value="account">Account</TabsTrigger>
                        <TabsTrigger Value="password">Password</TabsTrigger>
                        <TabsTrigger Value="notifications">Notifications</TabsTrigger>
                    </TabsList>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="A disabled tab trigger."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Tabs Composed="true">
                    <TabsList>
                        <TabsTrigger Value="home">Home</TabsTrigger>
                        <TabsTrigger Value="disabled" Disabled="true">Disabled</TabsTrigger>
                    </TabsList>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons"
                         Description="Tabs with icon-only trigger labels."
                         Code="@IconsCode"
                         CodeLanguage="razor">
                <Tabs Composed="true">
                    <TabsList>
                        <TabsTrigger Value="preview">
                            <Span data-icon="inline-start"><Icon Name="LucideIcon.Eye" /></Span>
                            Preview
                        </TabsTrigger>
                        <TabsTrigger Value="code">
                            <Span data-icon="inline-start"><Icon Name="LucideIcon.Code" /></Span>
                            Code
                        </TabsTrigger>
                    </TabsList>
                </Tabs>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Tabs support right-to-left languages."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Tabs Composed="true" SelectedTab="overview" Dir="rtl" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                        <TabsList>
                            <TabsTrigger Value="overview">نظرة عامة</TabsTrigger>
                            <TabsTrigger Value="analytics">التحليلات</TabsTrigger>
                            <TabsTrigger Value="reports">التقارير</TabsTrigger>
                            <TabsTrigger Value="settings">الإعدادات</TabsTrigger>
                        </TabsList>
                        <TabsContent Value="overview">
                            <Card Margin="Margin.Is4.FromTop">
                                <CardHeader>
                                    <CardTitle>نظرة عامة</CardTitle>
                                    <CardDescription>عرض مقاييسك الرئيسية وأنشطة المشروع الأخيرة. تتبع التقدم عبر جميع مشاريعك النشطة.</CardDescription>
                                </CardHeader>
                                <CardContent>
                                    <Paragraph Margin="Margin.Is0">لديك ١٢ مشروعًا نشطًا و٣ مهام معلقة.</Paragraph>
                                </CardContent>
                            </Card>
                        </TabsContent>
                        <TabsContent Value="analytics">
                            <Card Margin="Margin.Is4.FromTop">
                                <CardHeader>
                                    <CardTitle>التحليلات</CardTitle>
                                    <CardDescription>راجع مؤشرات الأداء واتجاهات الاستخدام.</CardDescription>
                                </CardHeader>
                            </Card>
                        </TabsContent>
                        <TabsContent Value="reports">
                            <Card Margin="Margin.Is4.FromTop">
                                <CardHeader>
                                    <CardTitle>التقارير</CardTitle>
                                    <CardDescription>نزّل التقارير وشاركها مع الفريق.</CardDescription>
                                </CardHeader>
                            </Card>
                        </TabsContent>
                        <TabsContent Value="settings">
                            <Card Margin="Margin.Is4.FromTop">
                                <CardHeader>
                                    <CardTitle>الإعدادات</CardTitle>
                                    <CardDescription>حدّث تفضيلات مساحة العمل.</CardDescription>
                                </CardHeader>
                            </Card>
                        </TabsContent>
                    </Tabs>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode = @"<Tabs defaultValue=""overview"">
    <TabsList>
        <TabsTrigger value=""overview"">Overview</TabsTrigger>
        <TabsTrigger value=""analytics"">Analytics</TabsTrigger>
        <TabsTrigger value=""reports"">Reports</TabsTrigger>
        <TabsTrigger value=""settings"">Settings</TabsTrigger>
    </TabsList>
    <TabsContent value=""overview"">Overview content</TabsContent>
</Tabs>";

    private const string LineCode = @"<Tabs TabsListVariant=""TabsListVariant.Line"">
    <TabsList>
        <TabsTrigger Value=""overview"">Overview</TabsTrigger>
        <TabsTrigger Value=""analytics"">Analytics</TabsTrigger>
        <TabsTrigger Value=""reports"">Reports</TabsTrigger>
    </TabsList>
</Tabs>";

    private const string VerticalCode = @"<Tabs Vertical=""true"">
    <TabsList>
        <TabsTrigger Value=""account"">Account</TabsTrigger>
        <TabsTrigger Value=""password"">Password</TabsTrigger>
        <TabsTrigger Value=""notifications"">Notifications</TabsTrigger>
    </TabsList>
</Tabs>";

    private const string DisabledCode = @"<Tabs>
    <TabsList>
        <TabsTrigger Value=""home"">Home</TabsTrigger>
        <TabsTrigger Value=""disabled"" Disabled=""true"">Disabled</TabsTrigger>
    </TabsList>
</Tabs>";

    private const string IconsCode = @"<Tabs>
    <TabsList>
        <TabsTrigger Value=""preview""><Icon Name=""LucideIcon.Eye"" />Preview</TabsTrigger>
        <TabsTrigger Value=""code""><Icon Name=""LucideIcon.Code"" />Code</TabsTrigger>
    </TabsList>
</Tabs>";

    private const string RtlCode = @"<DirectionProvider Dir=""rtl"">
    <Tabs Dir=""rtl"">
        <TabsList>
            <TabsTrigger Value=""overview"">نظرة عامة</TabsTrigger>
            <TabsTrigger Value=""analytics"">التحليلات</TabsTrigger>
            <TabsTrigger Value=""reports"">التقارير</TabsTrigger>
            <TabsTrigger Value=""settings"">الإعدادات</TabsTrigger>
        </TabsList>
    </Tabs>
</DirectionProvider>";
}
