@page "/components/attachments"

<PageTitle>Attachments - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
                     Description="Composable attachment UI for chat and messaging."
                     Code="@BasicCode"
                     CodeLanguage="razor">
            <Div Class="mx-auto flex w-fit flex-col items-center justify-center gap-4">
                <Attachments>
                    <Attachment Name="photo.jpg" Variant="compact" />
                    <Attachment Name="notes.txt" Variant="compact" />
                    <Attachment Name="clip.mp4" Variant="compact" />
                    <Attachment Name="song.mp3" Variant="compact" />
                </Attachments>
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private const string BasicCode =
@"<Div Class=""mx-auto flex w-fit flex-col items-center justify-center gap-4"">
    <Attachments>
        <Attachment Name=""photo.jpg"" Variant=""compact"" />
        <Attachment Name=""notes.txt"" Variant=""compact"" />
        <Attachment Name=""clip.mp4"" Variant=""compact"" />
        <Attachment Name=""song.mp3"" Variant=""compact"" />
    </Attachments>
</Div>";
}
