@page "/components/sonner"
@inject ISonnerUtil Toasts

<PageTitle>Sonner - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="An opinionated toast component for React." Code="@(@"<Button Variant=""ButtonVariant.Outline"" @onclick=""ShowDemoToast"">Show Toast</Button>")"
                         CodeLanguage="razor" PreviewClass="@SonnerPreviewClass">
                <Button Variant="ButtonVariant.Outline" @onclick="ShowDemoToast">Show Toast</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Types" Description="Default and typed Sonner notifications." Code="@(@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is2"">
    <Button Variant=""ButtonVariant.Outline"" @onclick=""ShowBasic"">Default</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""ShowSuccess"">Success</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""ShowInfo"">Info</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""ShowWarning"">Warning</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""ShowError"">Error</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""ShowPromiseSuccess"">Promise</Button>
</Div>")"
                         CodeLanguage="razor" PreviewClass="@SonnerPreviewClass">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is2">
                    <Button Variant="ButtonVariant.Outline" @onclick="ShowBasic">Default</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="ShowSuccess">Success</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="ShowInfo">Info</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="ShowWarning">Warning</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="ShowError">Error</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="ShowPromiseSuccess">Promise</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Description" Description="Toast content can include supporting text and an action." Code="@(@"<Button Variant=""ButtonVariant.Outline"" @onclick=""ShowWithDescription"">Show Toast</Button>")"
                         CodeLanguage="razor" PreviewClass="@SonnerPreviewClass">
                <Button Variant="ButtonVariant.Outline" @onclick="ShowWithDescription">Show Toast</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Position" Description="Top, center, bottom, left, and right placements." Code="@(@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is2"" Class=""justify-center"">
    <Button Variant=""ButtonVariant.Outline"" @onclick=""@(() => ShowPosition(SonnerPosition.TopLeft))"">Top Left</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""@(() => ShowPosition(SonnerPosition.TopCenter))"">Top Center</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""@(() => ShowPosition(SonnerPosition.TopRight))"">Top Right</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""@(() => ShowPosition(SonnerPosition.BottomLeft))"">Bottom Left</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""@(() => ShowPosition(SonnerPosition.BottomCenter))"">Bottom Center</Button>
    <Button Variant=""ButtonVariant.Outline"" @onclick=""@(() => ShowPosition(SonnerPosition.BottomRight))"">Bottom Right</Button>
</Div>")"
                         CodeLanguage="razor" PreviewClass="@SonnerPreviewClass">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is2" Class="justify-center">
                    <Button Variant="ButtonVariant.Outline" @onclick="@(() => ShowPosition(SonnerPosition.TopLeft))">Top Left</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="@(() => ShowPosition(SonnerPosition.TopCenter))">Top Center</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="@(() => ShowPosition(SonnerPosition.TopRight))">Top Right</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="@(() => ShowPosition(SonnerPosition.BottomLeft))">Bottom Left</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="@(() => ShowPosition(SonnerPosition.BottomCenter))">Bottom Center</Button>
                    <Button Variant="ButtonVariant.Outline" @onclick="@(() => ShowPosition(SonnerPosition.BottomRight))">Bottom Right</Button>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string SonnerPreviewClass = "preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start";

    private async Task ShowDemoToast()
    {
        _ = await Toasts.Toast("Event has been created", options =>
        {
            options.Description = "Sunday, December 03, 2023 at 9:00 AM";
            options.ActionLabel = "Undo";
            options.Action = () => ValueTask.CompletedTask;
        });
    }

    private async Task ShowBasic()
    {
        _ = await Toasts.Toast("Event has been created");
    }

    private async Task ShowSuccess()
    {
        _ = await Toasts.Success("Event has been created");
    }

    private async Task ShowInfo()
    {
        _ = await Toasts.Info("Be at the area 10 minutes before the event time");
    }

    private async Task ShowWarning()
    {
        _ = await Toasts.Warning("Event start time cannot be earlier than 8am");
    }

    private async Task ShowError()
    {
        _ = await Toasts.Error("Event has not been created");
    }

    private async Task ShowWithDescription()
    {
        _ = await Toasts.Toast("Event has been created", options =>
        {
            options.Description = "Monday, January 3rd at 6:00pm";
        });
    }

    private async Task ShowPromiseSuccess()
    {
        _ = await Toasts.Promise(SimulateRequest(), new SonnerPromiseOptions
        {
            Loading = "Loading...",
            Success = "Event has been created",
            Error = "Event has not been created"
        });
    }

    private async Task ShowPosition(SonnerPosition position)
    {
        _ = await Toasts.Toast("Event has been created", options =>
        {
            options.Position = position;
        });
    }

    private static async ValueTask SimulateRequest()
    {
        await Task.Delay(1500);
    }
}
