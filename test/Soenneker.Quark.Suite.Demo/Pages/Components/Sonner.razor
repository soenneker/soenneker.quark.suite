@page "/sonner"
@inject ISonnerUtil Toasts

<PageTitle>Sonner - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic toasts" Description="Default and typed Sonner notifications." Code="@(@"@inject ISonnerUtil Toasts
<Sonner />

await Toasts.Toast(""Event has been created"");
await Toasts.Success(""Saved successfully"");
await Toasts.Warning(""Review this change"");
await Toasts.Error(""Unable to continue"");")">
                <Div Class="flex flex-wrap gap-2">
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowBasic">Default</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowSuccess">Success</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowWarning">Warning</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowError">Error</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Descriptions and actions" Description="Mirror the common shadcn Sonner pattern." Code="@(@"await Toasts.Toast(""Your message has been sent"", options =>
{
    options.Description = ""Friday, March 20 at 2:30 PM"";
    options.ActionLabel = ""Undo"";
    options.Action = () => ValueTask.CompletedTask;
});")">
                <Div Class="flex flex-wrap gap-2">
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowWithDescription">With description</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowWithAction">With action</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Promise toast" Description="Loading state that resolves to success or error." Code="@(@"await Toasts.Promise(SimulateRequestAsync(), new SonnerPromiseOptions
{
    Loading = ""Saving changes..."",
    Success = ""Changes saved"",
    Error = ""Save failed""
});")">
                <Div Class="flex flex-wrap gap-2">
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowPromiseSuccess">Promise success</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowPromiseFailure">Promise failure</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Positions" Description="Top, center, bottom, left, and right placements." Code="@(@"await Toasts.Info(""Deployment started"", options =>
{
    options.Position = SonnerPosition.TopRight;
});")">
                <Div Class="grid max-w-md grid-cols-2 gap-2">
                    <Button Class="bg-primary text-primary-foreground" @onclick="@(() => ShowPosition(SonnerPosition.TopLeft))" Size="ButtonSize.Sm">Top Left</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="@(() => ShowPosition(SonnerPosition.TopCenter))" Size="ButtonSize.Sm">Top Center</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="@(() => ShowPosition(SonnerPosition.TopRight))" Size="ButtonSize.Sm">Top Right</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="@(() => ShowPosition(SonnerPosition.BottomLeft))" Size="ButtonSize.Sm">Bottom Left</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="@(() => ShowPosition(SonnerPosition.BottomCenter))" Size="ButtonSize.Sm">Bottom Center</Button>
                    <Button Class="bg-primary text-primary-foreground" @onclick="@(() => ShowPosition(SonnerPosition.BottomRight))" Size="ButtonSize.Sm">Bottom Right</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Rich content" Description="Custom render fragments are supported." Code="@(@"await Toasts.Custom(builder =>
{
    // custom content
}, options => options.Duration = 0);")">
                <Div Class="flex flex-wrap gap-2">
                    <Button Class="bg-primary text-primary-foreground" @onclick="ShowCustomContent">Custom content</Button>
                    <Button Class="bg-secondary text-secondary-foreground" @onclick="DismissAll">Dismiss all</Button>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private async Task ShowBasic()
    {
        _ = await Toasts.Toast("Event has been created");
    }

    private async Task ShowSuccess()
    {
        _ = await Toasts.Success("Saved successfully");
    }

    private async Task ShowWarning()
    {
        _ = await Toasts.Warning("Review this change");
    }

    private async Task ShowError()
    {
        _ = await Toasts.Error("Unable to continue");
    }

    private async Task ShowWithDescription()
    {
        _ = await Toasts.Toast("Your message has been sent", options =>
        {
            options.Description = "Friday, March 20 at 2:30 PM";
        });
    }

    private async Task ShowWithAction()
    {
        _ = await Toasts.Toast("Message archived", options =>
        {
            options.Description = "You can undo this action from the toast.";
            options.ActionLabel = "Undo";
            options.Action = async () =>
            {
                _ = await Toasts.Info("Archive undone");
            };
        });
    }

    private async Task ShowPromiseSuccess()
    {
        _ = await Toasts.Promise(SimulateRequestAsync(false), new SonnerPromiseOptions
        {
            Loading = "Saving changes...",
            Success = "Changes saved",
            Error = "Save failed",
            Description = "This mirrors Sonner's loading to result flow."
        });
    }

    private async Task ShowPromiseFailure()
    {
        _ = await Toasts.Promise(SimulateRequestAsync(true), new SonnerPromiseOptions
        {
            Loading = "Publishing post...",
            Success = "Post published",
            Error = "Publish failed",
            Description = "This request intentionally throws."
        });
    }

    private async Task ShowPosition(SonnerPosition position)
    {
        _ = await Toasts.Info($"Toast at {position}", options =>
        {
            options.Position = position;
            options.Description = "Position can be overridden per toast.";
        });
    }

    private async Task ShowCustomContent()
    {
        _ = await Toasts.Custom(builder =>
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "grid gap-1");
            builder.OpenElement(2, "div");
            builder.AddAttribute(3, "class", "text-sm font-medium");
            builder.AddContent(4, "Deployment complete");
            builder.CloseElement();
            builder.OpenElement(5, "div");
            builder.AddAttribute(6, "class", "text-sm text-muted-foreground");
            builder.AddContent(7, "Production is now serving the latest release.");
            builder.CloseElement();
            builder.CloseElement();
        }, options =>
        {
            options.Position = SonnerPosition.TopRight;
            options.Duration = 0;
            options.ActionLabel = "Dismiss";
            options.Action = async () =>
            {
                await Toasts.Dismiss();
            };
        });
    }

    private async Task DismissAll()
    {
        await Toasts.Dismiss();
    }

    private static async ValueTask SimulateRequestAsync(bool shouldFail)
    {
        await Task.Delay(1500);

        if (shouldFail)
            throw new InvalidOperationException("This request failed.");
    }
}
