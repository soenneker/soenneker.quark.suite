@page "/avatars"

<PageTitle>Avatars - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Code="@BasicCode">
                <Avatar>
                    <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" Class="grayscale" />
                    <AvatarFallback>PR</AvatarFallback>
                </Avatar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge"
                         Description="Add a presence dot using the badge overlay."
                         Code="@BadgeCode">
                <Avatar>
                    <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                    <AvatarFallback>PR</AvatarFallback>
                    <AvatarBadge Class="bg-green-600 dark:bg-green-800" />
                </Avatar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge Icon"
                         Description="Badge icons use the same avatar overlay API as the presence badge."
                         Code="@BadgeIconCode">
                <Avatar Class="grayscale">
                    <AvatarImage Src="https://github.com/pranathip.png" Alt="pranathip" />
                    <AvatarFallback>PP</AvatarFallback>
                    <AvatarBadge>
                        <Icon Name="LucideIcon.Plus" />
                    </AvatarBadge>
                </Avatar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group"
                         Description="Grouped avatars create an overlapping team stack."
                         Code="@GroupCode">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" />
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group Count"
                         Description="Use a trailing count when more people are present than the visible stack can show."
                         Code="@GroupCountCode">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" />
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                    <AvatarGroupCount>+3</AvatarGroupCount>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group Count Icon"
                         Description="The count chip can also render an icon."
                         Code="@GroupCountIconCode">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" />
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                    <AvatarGroupCount>
                        <Icon Name="LucideIcon.Plus" />
                    </AvatarGroupCount>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Small, default, and large avatars share the same component API."
                         Code="@SizeCode">
                <Div Class="flex flex-wrap items-center gap-2 grayscale">
                    <Avatar Size="sm">
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar Size="lg">
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown"
                         Description="Avatars also work as account menu triggers in the same composed dropdown pattern."
                         Code="@DropdownCode">
                <Dropdown>
                    <DropdownToggle Class="size-8 rounded-full p-0 hover:bg-accent">
                        <Avatar>
                            <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                            <AvatarFallback>PR</AvatarFallback>
                        </Avatar>
                    </DropdownToggle>
                    <DropdownMenu Class="w-32">
                        <DropdownItem>Profile</DropdownItem>
                        <DropdownItem>Billing</DropdownItem>
                        <DropdownItem>Settings</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem TextColor="TextColor.Destructive">Log out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples demonstrate extra Quark behavior beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Fallback on Error"
                         Description="Quark avatars now keep the fallback visible until the image loads successfully, including broken-image cases."
                         Code="@ErrorFallbackCode">
                <Div Class="flex flex-wrap items-center gap-4">
                    <Avatar>
                        <AvatarImage Src="https://example.invalid/quark-avatar.png" Alt="Broken avatar example" />
                        <AvatarFallback>QE</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Loaded avatar example" />
                        <AvatarFallback>QL</AvatarFallback>
                    </Avatar>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

