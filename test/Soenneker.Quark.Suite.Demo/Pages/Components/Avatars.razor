@page "/media/avatars"

<PageTitle>Avatars - Quark Suite</PageTitle>

<Div Class="space-y-8 max-w-4xl">
    <Div Class="space-y-6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Latest shadcn v4 avatar demo"
                         Description="Avatar examples aligned to the latest shadcn demo layout."
                         Code="@BasicCode">
                <Div Class="flex flex-row flex-wrap items-center gap-12">
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" />
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>

                    <Avatar Class="rounded-lg">
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>

                    <AvatarGroup Class="*:data-[slot=avatar]:grayscale">
                        <Avatar>
                            <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" />
                            <AvatarFallback>CN</AvatarFallback>
                        </Avatar>
                        <Avatar>
                            <AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" />
                            <AvatarFallback>LR</AvatarFallback>
                        </Avatar>
                        <Avatar>
                            <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                            <AvatarFallback>ER</AvatarFallback>
                        </Avatar>
                    </AvatarGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sizes, badges, and group count"
                         Description="Quark-specific avatar additions using the same shadcn v4 class patterns."
                         Code="@ExtrasCode">
                <Div Class="flex flex-wrap items-center gap-6">
                    <Avatar Size="sm">
                        <AvatarFallback>SM</AvatarFallback>
                        <AvatarBadge />
                    </Avatar>
                    <Avatar>
                        <AvatarFallback>DF</AvatarFallback>
                        <AvatarBadge>
                            <Icon Name="check" Class="size-2" />
                        </AvatarBadge>
                    </Avatar>
                    <Avatar Size="lg">
                        <AvatarFallback>LG</AvatarFallback>
                        <AvatarBadge />
                    </Avatar>
                    <AvatarGroup>
                        <Avatar Size="sm"><AvatarFallback>JD</AvatarFallback></Avatar>
                        <Avatar><AvatarFallback>MP</AvatarFallback></Avatar>
                        <Avatar Size="lg"><AvatarFallback>RL</AvatarFallback></Avatar>
                        <AvatarGroupCount>+5</AvatarGroupCount>
                    </AvatarGroup>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Div Class=""flex flex-row flex-wrap items-center gap-12"">
    <Avatar>
        <AvatarImage Src=""https://github.com/shadcn.png"" Alt=""@shadcn"" />
        <AvatarFallback>CN</AvatarFallback>
    </Avatar>
    <Avatar Class=""rounded-lg"">
        <AvatarImage Src=""https://github.com/evilrabbit.png"" Alt=""@evilrabbit"" />
        <AvatarFallback>ER</AvatarFallback>
    </Avatar>
    <AvatarGroup Class=""*:data-[slot=avatar]:grayscale"">
        <Avatar>...</Avatar>
        <Avatar>...</Avatar>
        <Avatar>...</Avatar>
    </AvatarGroup>
</Div>";

    private const string ExtrasCode =
@"<Avatar Size=""sm"">
    <AvatarFallback>SM</AvatarFallback>
    <AvatarBadge />
</Avatar>

<AvatarGroup>
    <Avatar Size=""sm""><AvatarFallback>JD</AvatarFallback></Avatar>
    <Avatar><AvatarFallback>MP</AvatarFallback></Avatar>
    <Avatar Size=""lg""><AvatarFallback>RL</AvatarFallback></Avatar>
    <AvatarGroupCount>+5</AvatarGroupCount>
</AvatarGroup>";
}
