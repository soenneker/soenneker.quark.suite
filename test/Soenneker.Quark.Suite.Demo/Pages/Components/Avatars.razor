@page "/avatars"

<PageTitle>Avatars - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="An image element with a fallback for representing the user." Code="@BasicCode" CodeLanguage="razor">
                <Div Class="flex flex-row flex-wrap items-center gap-6 md:gap-12">
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" Class="grayscale"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                        <AvatarFallback>ER</AvatarFallback>
                        <AvatarBadge Class="bg-green-600 dark:bg-green-800"/>
                    </Avatar>
                    <AvatarGroup Class="grayscale">
                        <Avatar>
                            <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                            <AvatarFallback>CN</AvatarFallback>
                        </Avatar>
                        <Avatar>
                            <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")"/>
                            <AvatarFallback>LR</AvatarFallback>
                        </Avatar>
                        <Avatar>
                            <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                            <AvatarFallback>ER</AvatarFallback>
                        </Avatar>
                        <AvatarGroupCount>+3</AvatarGroupCount>
                    </AvatarGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic" Description="A basic avatar component with an image and a fallback." Code="@BasicAvatarCode" CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2">
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge" Description="Use the AvatarBadge component to add a badge to the avatar. The badge is positioned at the bottom right of the avatar." Code="@BadgeCode" CodeLanguage="razor">
                <Avatar>
                    <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                    <AvatarFallback>CN</AvatarFallback>
                    <AvatarBadge Class="bg-green-600 dark:bg-green-800"/>
                </Avatar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge with Icon" Description="Badge icons use the same avatar overlay API as the presence badge." Code="@BadgeIconCode" CodeLanguage="razor">
                <Avatar Class="grayscale">
                    <AvatarImage Src="https://github.com/pranathip.png" Alt="@("@pranathip")"/>
                    <AvatarFallback>PP</AvatarFallback>
                    <AvatarBadge>
                        <Icon Name="LucideIcon.Plus"/>
                    </AvatarBadge>
                </Avatar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group" Description="Use the AvatarGroup component to add a group of avatars." Code="@GroupCode" CodeLanguage="razor">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")"/>
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group Count" Description="Use AvatarGroupCount to add a count to the group." Code="@GroupCountCode" CodeLanguage="razor">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")"/>
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                    <AvatarGroupCount>+3</AvatarGroupCount>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group with Icon" Description="You can also use an icon inside AvatarGroupCount." Code="@GroupCountIconCode" CodeLanguage="razor">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")"/>
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                    <AvatarGroupCount>
                        <Icon Name="LucideIcon.Plus"/>
                    </AvatarGroupCount>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sizes" Description="Use the size prop to change the size of the avatar." Code="@SizeCode" CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2 grayscale">
                    <Avatar Size="sm">
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                    <Avatar Size="lg">
                        <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                        <AvatarFallback>CN</AvatarFallback>
                    </Avatar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown" Description="Avatars also work as account menu triggers in the same composed dropdown pattern." Code="@DropdownCode" CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild>
                        <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Rounded="Rounded.Full">
                            <Avatar>
                                <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn"/>
                                <AvatarFallback>CN</AvatarFallback>
                            </Avatar>
                        </Button>
                    </DropdownToggle>
                    <DropdownMenu Width='Width.Token("32")'>
                        <DropdownItem>Profile</DropdownItem>
                        <DropdownItem>Billing</DropdownItem>
                        <DropdownItem>Settings</DropdownItem>
                        <DropdownDivider/>
                        <DropdownItem Variant="destructive">Log out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="Avatars respect direction from DirectionProvider." Code="@RtlCode" CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div dir="rtl" Class="flex flex-row flex-wrap items-center gap-6 md:gap-12">
                        <Avatar>
                            <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" Class="grayscale"/>
                            <AvatarFallback>CN</AvatarFallback>
                        </Avatar>
                        <Avatar>
                            <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                            <AvatarFallback>ER</AvatarFallback>
                            <AvatarBadge Class="end-0 bg-green-600 dark:bg-green-800"/>
                        </Avatar>
                        <AvatarGroup Class="grayscale">
                            <Avatar>
                                <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")"/>
                                <AvatarFallback>CN</AvatarFallback>
                            </Avatar>
                            <Avatar>
                                <AvatarImage Src="https://github.com/maxleiter.png" Alt="@("@maxleiter")"/>
                                <AvatarFallback>LR</AvatarFallback>
                            </Avatar>
                            <Avatar>
                                <AvatarImage Src="https://github.com/evilrabbit.png" Alt="@("@evilrabbit")"/>
                                <AvatarFallback>ER</AvatarFallback>
                            </Avatar>
                            <AvatarGroupCount>+٣</AvatarGroupCount>
                        </AvatarGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

    </Div>
</Div>

