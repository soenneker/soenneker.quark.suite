@page "/avatars"

<PageTitle>Avatars - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Avatar examples covering default, rounded-square, and grouped layouts."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-row flex-wrap items-center gap-12">
                    <Avatar>
                        <AvatarImage Src="https://github.com/vercel.png" Alt="Morgan Lee" />
                        <AvatarFallback>ML</AvatarFallback>
                    </Avatar>
                    <Avatar Class="rounded-lg">
                        <AvatarImage Src="https://github.com/leerob.png" Alt="Casey Park" />
                        <AvatarFallback>CP</AvatarFallback>
                    </Avatar>
                    <AvatarGroup Class="grayscale">
                        <Avatar>
                            <AvatarImage Src="https://github.com/vercel.png" Alt="Morgan Lee" />
                            <AvatarFallback>ML</AvatarFallback>
                        </Avatar>
                        <Avatar>
                            <AvatarImage Src="https://github.com/maxleiter.png" Alt="Jordan Kim" />
                            <AvatarFallback>JK</AvatarFallback>
                        </Avatar>
                        <Avatar>
                            <AvatarImage Src="https://github.com/leerob.png" Alt="Casey Park" />
                            <AvatarFallback>CP</AvatarFallback>
                        </Avatar>
                    </AvatarGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge"
                         Description="Add a presence dot using the badge overlay."
                         Code="@BadgeCode"
                         CodeLanguage="razor">
                <Avatar>
                    <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                    <AvatarFallback>PR</AvatarFallback>
                    <AvatarBadge Class="bg-green-600 dark:bg-green-800" />
                </Avatar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge with Icon"
                         Description="Badge icons use the same avatar overlay API as the presence badge."
                         Code="@BadgeIconCode"
                         CodeLanguage="razor">
                <Avatar Class="grayscale">
                    <AvatarImage Src="https://github.com/pranathip.png" Alt="pranathip" />
                    <AvatarFallback>PP</AvatarFallback>
                    <AvatarBadge>
                        <Icon Name="LucideIcon.Plus" />
                    </AvatarBadge>
                </Avatar>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group"
                         Description="Grouped avatars create an overlapping team stack."
                         Code="@GroupCode"
                         CodeLanguage="razor">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" />
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group Count"
                         Description="Use a trailing count when more people are present than the visible stack can show."
                         Code="@GroupCountCode"
                         CodeLanguage="razor">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" />
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                    <AvatarGroupCount>+3</AvatarGroupCount>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group with Icon"
                         Description="The count chip can also render an icon."
                         Code="@GroupCountIconCode"
                         CodeLanguage="razor">
                <AvatarGroup Class="grayscale">
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" />
                        <AvatarFallback>LR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" />
                        <AvatarFallback>ER</AvatarFallback>
                    </Avatar>
                    <AvatarGroupCount>
                        <Icon Name="LucideIcon.Plus" />
                    </AvatarGroupCount>
                </AvatarGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Small, default, and large avatars share the same component API."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2 grayscale">
                    <Avatar Size="sm">
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                    <Avatar Size="lg">
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                        <AvatarFallback>PR</AvatarFallback>
                    </Avatar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown"
                         Description="Avatars also work as account menu triggers in the same composed dropdown pattern."
                         Code="@DropdownCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle Class="size-8 rounded-full p-0 hover:bg-accent">
                        <Avatar>
                            <AvatarImage Src="https://github.com/maxleiter.png" Alt="Profile image" />
                            <AvatarFallback>PR</AvatarFallback>
                        </Avatar>
                    </DropdownToggle>
                    <DropdownMenu Class="w-32">
                        <DropdownItem>Profile</DropdownItem>
                        <DropdownItem>Billing</DropdownItem>
                        <DropdownItem>Settings</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem TextColor="TextColor.Destructive">Log out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Avatars respect direction from DirectionProvider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex flex-wrap items-center justify-end gap-3 grayscale">
                        <Avatar>
                            <AvatarImage Src="https://github.com/maxleiter.png" Alt="صورة الملف الشخصي" />
                            <AvatarFallback>م</AvatarFallback>
                        </Avatar>
                        <AvatarGroup>
                            <Avatar>
                                <AvatarImage Src="https://github.com/maxleiter.png" Alt="أ" />
                                <AvatarFallback>أ</AvatarFallback>
                            </Avatar>
                            <Avatar>
                                <AvatarImage Src="https://github.com/evilrabbit.png" Alt="ب" />
                                <AvatarFallback>ب</AvatarFallback>
                            </Avatar>
                        </AvatarGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Image load and fallback behavior beyond the reference sections above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Fallback on Error"
                         Description="Quark avatars now keep the fallback visible until the image loads successfully, including broken-image cases."
                         Code="@ErrorFallbackCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-4">
                    <Avatar>
                        <AvatarImage Src="https://example.invalid/quark-avatar.png" Alt="Broken avatar example" />
                        <AvatarFallback>QE</AvatarFallback>
                    </Avatar>
                    <Avatar>
                        <AvatarImage Src="https://github.com/maxleiter.png" Alt="Loaded avatar example" />
                        <AvatarFallback>QL</AvatarFallback>
                    </Avatar>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

