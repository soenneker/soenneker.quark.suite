@page "/navigation-menu"

<PageTitle>Navigation Menu - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                        Description="Navigation menu with grouped content, a direct docs link, shared indicator, and viewport."
                        Code="@BasicCode"
                        CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4">
                    <NavigationMenu Width="Width.IsFull" AlignUtility="Align.JustifyStart">
                        <NavigationMenuList Justify="Justify.Start">
                            <NavigationMenuItem>
                                <NavigationMenuTrigger>Getting started</NavigationMenuTrigger>
                                <NavigationMenuContent Motion="from-start" Class="md:w-[420px] lg:w-[520px]">
                                    <Div Class="grid gap-3 p-2 lg:grid-cols-[1.05fr_1fr]">
                                        <NavigationMenuLink Href="components" Active="true" Class="justify-between rounded-md bg-gradient-to-b from-muted/50 to-muted p-4 no-underline">
                                            <Span FontWeight="FontWeight.Semibold" FontSize="FontSize.IsLg">Quark Suite</Span>
                                            <Span TextColor="TextColor.MutedForeground">Reusable Blazor UI primitives and styled components for app shells, forms, overlays, and layout.</Span>
                                        </NavigationMenuLink>

                                        <Div Display="Display.Grid" Gap="Gap.Is2">
                                            <NavigationMenuLink Href="components">
                                                <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">Introduction</Span>
                                                <Span TextColor="TextColor.MutedForeground">Start with the component catalog, theming, and composition patterns.</Span>
                                            </NavigationMenuLink>
                                            <NavigationMenuLink Href="installation">
                                                <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">Installation</Span>
                                                <Span TextColor="TextColor.MutedForeground">Package references, CSS imports, and required app setup.</Span>
                                            </NavigationMenuLink>
                                            <NavigationMenuLink Href="headings">
                                                <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">Typography</Span>
                                                <Span TextColor="TextColor.MutedForeground">Headings, text, labels, and other content utilities.</Span>
                                            </NavigationMenuLink>
                                        </Div>
                                    </Div>
                                </NavigationMenuContent>
                            </NavigationMenuItem>

                            <NavigationMenuItem>
                                <NavigationMenuTrigger>Guides</NavigationMenuTrigger>
                                <NavigationMenuContent Motion="from-end" Class="md:w-[500px] lg:w-[600px]">
                                    <Div Class="grid gap-2 p-2 md:grid-cols-2">
                                        <NavigationMenuLink Href="accordion">
                                            <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">Accordion</Span>
                                            <Span TextColor="TextColor.MutedForeground">Progressively disclose related sections of content.</Span>
                                        </NavigationMenuLink>
                                        <NavigationMenuLink Href="dialogs">
                                            <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">Dialogs</Span>
                                            <Span TextColor="TextColor.MutedForeground">Modal and non-modal overlays with focus management.</Span>
                                        </NavigationMenuLink>
                                        <NavigationMenuLink Href="progresses">
                                            <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">Progress</Span>
                                            <Span TextColor="TextColor.MutedForeground">Show long-running task completion with determinate feedback.</Span>
                                        </NavigationMenuLink>
                                        <NavigationMenuLink Href="tabs">
                                            <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">Tabs</Span>
                                            <Span TextColor="TextColor.MutedForeground">Switch between layered sections while preserving structure.</Span>
                                        </NavigationMenuLink>
                                    </Div>
                                </NavigationMenuContent>
                            </NavigationMenuItem>

                            <NavigationMenuItem>
                                <NavigationMenuLink Href="components" Class="inline-flex h-9 items-center justify-center rounded-md px-4 py-2 font-medium">
                                    <Span>Docs</Span>
                                </NavigationMenuLink>
                            </NavigationMenuItem>
                        </NavigationMenuList>

                        <NavigationMenuIndicator />
                    </NavigationMenu>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Custom link composition and RTL layout examples below the lead shadcn-equivalent navigation menu.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link Component"
                        Description="Use AsChild to compose a custom Quark link component."
                        Code="@LinkComponentCode"
                        CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4">
                    <NavigationMenu Justify="Justify.Start">
                        <NavigationMenuList Justify="Justify.Start">
                            <NavigationMenuItem>
                                <NavigationMenuLink AsChild="true">
                                    <Anchor To="components">
                                        <Span FontWeight="FontWeight.Medium">Documentation</Span>
                                    </Anchor>
                                </NavigationMenuLink>
                            </NavigationMenuItem>
                        </NavigationMenuList>
                    </NavigationMenu>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                        Description="Navigation menu content and viewport positioning respect right-to-left layouts."
                        Code="@RtlCode"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div class="rounded-xl border border-border p-4 text-right">
                        <NavigationMenu Width="Width.IsFull" AlignUtility="Align.JustifyStart">
                            <NavigationMenuList Justify="Justify.Start">
                                <NavigationMenuItem>
                                    <NavigationMenuTrigger>البدء</NavigationMenuTrigger>
                                    <NavigationMenuContent Motion="from-start">
                                        <Div Class="grid gap-2 p-2 md:w-[420px]">
                                            <NavigationMenuLink Href="components" Active="true">
                                                <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">المكونات</Span>
                                                <Span TextColor="TextColor.MutedForeground">لبنات واجهة قابلة لإعادة الاستخدام.</Span>
                                            </NavigationMenuLink>
                                            <NavigationMenuLink Href="buttons">
                                                <Span FontWeight="FontWeight.Medium" LineHeight="LineHeight.Is1">الأزرار</Span>
                                                <Span TextColor="TextColor.MutedForeground">أنماط متعددة للأسطح التفاعلية.</Span>
                                            </NavigationMenuLink>
                                        </Div>
                                    </NavigationMenuContent>
                                </NavigationMenuItem>
                            </NavigationMenuList>
                        </NavigationMenu>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

