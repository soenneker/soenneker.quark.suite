@page "/navigation-menu"

<PageTitle>Navigation Menu - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                        Description="Navigation menu with grouped list content, a direct docs link, shared indicator, and viewport."
                        Code="@BasicCode"
                        PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                        CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4">
                    <NavigationMenu Width="Width.IsFull" Justify="Justify.Start">
                        <NavigationMenuList Justify="Justify.Start">
                            <NavigationMenuItem>
                                <NavigationMenuTrigger>Getting started</NavigationMenuTrigger>
                                <NavigationMenuContent Motion="from-start">
                                    <UnorderedList Class="w-96">
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="components" Active="true">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Introduction</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">Reusable components built with Tailwind CSS.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="installation">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Installation</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">How to install dependencies and structure your app.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="headings">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Typography</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">Styles for headings, paragraphs, lists...etc</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                    </UnorderedList>
                                </NavigationMenuContent>
                            </NavigationMenuItem>

                            <NavigationMenuItem Class="hidden md:flex">
                                <NavigationMenuTrigger>Components</NavigationMenuTrigger>
                                <NavigationMenuContent Motion="from-end">
                                    <UnorderedList Class="grid w-[400px] gap-2 md:w-[500px] md:grid-cols-2 lg:w-[600px]">
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="alert-dialogs">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Alert Dialog</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">A modal dialog that interrupts the user with important content and expects a response.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="hover-cards">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Hover Card</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">For sighted users to preview content available behind a link.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="progresses">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Progress</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">Displays an indicator showing the completion progress of a task, typically displayed as a progress bar.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="scroll-areas">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Scroll Area</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">Visually or semantically separates content.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="tabs">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Tabs</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">A set of layered sections of content known as tab panels that are displayed one at a time.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="tooltips">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Class="font-medium leading-none">Tooltip</Div>
                                                    <Div Class="line-clamp-2 text-muted-foreground">A popup that displays information related to an element when it receives keyboard focus or the mouse hovers over it.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                    </UnorderedList>
                                </NavigationMenuContent>
                            </NavigationMenuItem>

                            <NavigationMenuItem>
                                <NavigationMenuLink Href="components">
                                    <Span>Docs</Span>
                                </NavigationMenuLink>
                            </NavigationMenuItem>
                        </NavigationMenuList>

                        <NavigationMenuIndicator />
                    </NavigationMenu>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Custom link composition and RTL layout examples below the lead shadcn-equivalent navigation menu.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link Component"
                        Description="Use AsChild to compose a custom Quark link component."
                        Code="@LinkComponentCode"
                        CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4">
                    <NavigationMenu Justify="Justify.Start">
                        <NavigationMenuList Justify="Justify.Start">
                            <NavigationMenuItem>
                                <NavigationMenuLink AsChild="true">
                                    <Anchor To="components">
                                        <Span FontWeight="FontWeight.Medium">Documentation</Span>
                                    </Anchor>
                                </NavigationMenuLink>
                            </NavigationMenuItem>
                        </NavigationMenuList>
                    </NavigationMenu>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                        Description="Navigation menu content and viewport positioning respect right-to-left layouts."
                        Code="@RtlCode"
                        PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div class="rounded-xl border border-border p-4 text-right">
                        <NavigationMenu Width="Width.IsFull" Justify="Justify.Start">
                            <NavigationMenuList Justify="Justify.Start">
                                <NavigationMenuItem>
                                    <NavigationMenuTrigger>البدء</NavigationMenuTrigger>
                                    <NavigationMenuContent Motion="from-start">
                                        <Div Class="grid gap-2 p-2 md:w-[420px]">
                                            <NavigationMenuLink Href="components" Active="true">
                                                <Span FontWeight="FontWeight.Medium" Leading='Leading.Token("1")'>المكونات</Span>
                                                <Span TextColor="TextColor.MutedForeground">لبنات واجهة قابلة لإعادة الاستخدام.</Span>
                                            </NavigationMenuLink>
                                            <NavigationMenuLink Href="buttons">
                                                <Span FontWeight="FontWeight.Medium" Leading='Leading.Token("1")'>الأزرار</Span>
                                                <Span TextColor="TextColor.MutedForeground">أنماط متعددة للأسطح التفاعلية.</Span>
                                            </NavigationMenuLink>
                                        </Div>
                                    </NavigationMenuContent>
                                </NavigationMenuItem>
                            </NavigationMenuList>
                        </NavigationMenu>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

