@page "/empties"

<PageTitle>Empty - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo" Description="The default empty-state composition uses icon media, a title, and follow-up action."
                        Code="@BasicCode"
                        CodeLanguage="razor">
                <Empty Border="Border.Is1" BorderColor="BorderColor.Border">
                    <EmptyHeader>
                        <EmptyMedia Variant="EmptyMediaVariant.Icon">
                            <Icon Name="LucideIcon.Inbox" />
                        </EmptyMedia>
                        <EmptyTitle>No data</EmptyTitle>
                        <EmptyDescription>No data found</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent>
                        <Button>Add data</Button>
                    </EmptyContent>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline" Description="A simple outlined empty state keeps the presentation lightweight."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyTitle>No results found</EmptyTitle>
        <EmptyDescription>Try adjusting your filters.</EmptyDescription>
    </EmptyHeader>
</Empty>")">
                <Empty Border="Border.Is1" BorderColor="BorderColor.Border" Class="border-dashed">
                    <EmptyHeader>
                        <EmptyTitle>No results found</EmptyTitle>
                        <EmptyDescription>Try adjusting your filters or search term.</EmptyDescription>
                    </EmptyHeader>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Background" Description="Muted backgrounds help the empty state feel more like a card or inset panel."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyTitle>No documents yet</EmptyTitle>
        <EmptyDescription>Create your first document to get started.</EmptyDescription>
    </EmptyHeader>
</Empty>")">
                <Empty Border="Border.Is1" BorderColor="BorderColor.Border" BackgroundColor='BackgroundColor.Token("muted/40")'>
                    <EmptyHeader>
                        <EmptyTitle>No documents yet</EmptyTitle>
                        <EmptyDescription>Create your first document to get started.</EmptyDescription>
                    </EmptyHeader>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar" Description="Use avatar media when the empty state refers to people or invitations."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyMedia>
            <Avatar><AvatarFallback>JD</AvatarFallback></Avatar>
        </EmptyMedia>
        <EmptyTitle>No assignee yet</EmptyTitle>
        <EmptyDescription>Invite a teammate to assign ownership.</EmptyDescription>
    </EmptyHeader>
</Empty>")">
                <Empty Border="Border.Is1" BorderColor="BorderColor.Border">
                    <EmptyHeader>
                        <EmptyMedia>
                            <Avatar><AvatarFallback>JD</AvatarFallback></Avatar>
                        </EmptyMedia>
                        <EmptyTitle>No assignee yet</EmptyTitle>
                        <EmptyDescription>Invite a teammate to assign ownership.</EmptyDescription>
                    </EmptyHeader>
                </Empty>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group" Description="Avatar groups work well for empty collaboration and team states."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyMedia>
            <AvatarGroup>
                <Avatar><AvatarFallback>AB</AvatarFallback></Avatar>
                <Avatar><AvatarFallback>CD</AvatarFallback></Avatar>
                <AvatarGroupCount>+2</AvatarGroupCount>
            </AvatarGroup>
        </EmptyMedia>
        <EmptyTitle>No reviewers assigned</EmptyTitle>
        <EmptyDescription>Add reviewers before requesting approval.</EmptyDescription>
    </EmptyHeader>
</Empty>")">
                <Empty Border="Border.Is1" BorderColor="BorderColor.Border">
                    <EmptyHeader>
                        <EmptyMedia>
                            <AvatarGroup>
                                <Avatar><AvatarFallback>AB</AvatarFallback></Avatar>
                                <Avatar><AvatarFallback>CD</AvatarFallback></Avatar>
                                <AvatarGroupCount>+2</AvatarGroupCount>
                            </AvatarGroup>
                        </EmptyMedia>
                        <EmptyTitle>No reviewers assigned</EmptyTitle>
                        <EmptyDescription>Add reviewers before requesting approval.</EmptyDescription>
                    </EmptyHeader>
                </Empty>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="InputGroup" Description="An inline input group is useful when the empty state should immediately collect the next action."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyTitle>No custom domain</EmptyTitle>
        <EmptyDescription>Connect a domain to launch your site.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent>
        <InputGroup>
            <InputGroupAddon>https://</InputGroupAddon>
            <InputGroupInput Placeholder=""acme.dev"" />
        </InputGroup>
    </EmptyContent>
</Empty>")">
                <Empty Border="Border.Is1" BorderColor="BorderColor.Border">
                    <EmptyHeader>
                        <EmptyTitle>No custom domain</EmptyTitle>
                        <EmptyDescription>Connect a domain to launch your site.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent>
                        <Div Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" Space="Space.Y.Is3">
                            <InputGroup>
                                <InputGroupAddon>https://</InputGroupAddon>
                                <InputGroupInput Placeholder="acme.dev" />
                            </InputGroup>
                            <Button Variant="ButtonVariant.Default">Connect domain</Button>
                        </Div>
                    </EmptyContent>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="Empty states also support right-to-left copy and action flow."
                        Code="@RtlCode"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Empty Border="Border.Is1" BorderColor="BorderColor.Border">
                            <EmptyHeader>
                                <EmptyMedia Variant="EmptyMediaVariant.Icon">
                                    <Icon Name="LucideIcon.Inbox" />
                                </EmptyMedia>
                                <EmptyTitle>لا توجد بيانات</EmptyTitle>
                                <EmptyDescription>أضف أول عنصر للبدء.</EmptyDescription>
                            </EmptyHeader>
                            <EmptyContent>
                                <Button>إضافة عنصر</Button>
                            </EmptyContent>
                        </Empty>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Empty>
    <EmptyHeader>
        <EmptyMedia Variant=""EmptyMediaVariant.Icon"">
            <Icon Name=""LucideIcon.Inbox"" />
        </EmptyMedia>
        <EmptyTitle>No data</EmptyTitle>
        <EmptyDescription>No data found</EmptyDescription>
    </EmptyHeader>
    <EmptyContent>
        <Button>Add data</Button>
    </EmptyContent>
</Empty>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Empty>
        <EmptyHeader>
            <EmptyMedia Variant=""EmptyMediaVariant.Icon"">
                <Icon Name=""LucideIcon.Inbox"" />
            </EmptyMedia>
            <EmptyTitle>لا توجد بيانات</EmptyTitle>
            <EmptyDescription>أضف أول عنصر للبدء.</EmptyDescription>
        </EmptyHeader>
        <EmptyContent>
            <Button>إضافة عنصر</Button>
        </EmptyContent>
    </Empty>
</DirectionProvider>";
}
