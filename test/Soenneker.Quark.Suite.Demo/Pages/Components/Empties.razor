@page "/empties"

<PageTitle>Empty - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Use the Empty component to display an empty state."
                        Code="@BasicCode"
                        CodeLanguage="razor">
                <Empty>
                    <EmptyHeader>
                        <EmptyMedia Variant="EmptyMediaVariant.Icon">
                            <Icon Name="LucideIcon.Folder" />
                        </EmptyMedia>
                        <EmptyTitle>No Projects Yet</EmptyTitle>
                        <EmptyDescription>You haven't created any projects yet. Get started by creating your first project.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent Class="flex-row justify-center gap-2">
                        <Button>Create Project</Button>
                        <Button Variant="ButtonVariant.Outline">Import Project</Button>
                    </EmptyContent>
                    <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" To="#" TextColor="TextColor.MutedForeground">
                        Learn More <Icon Name="LucideIcon.ArrowUpRight" data-icon="inline-end" />
                    </Button>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline" Description="Use the border utility class to create an outline empty state."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyMedia Variant=""EmptyMediaVariant.Icon"">
            <Icon Name=""LucideIcon.Cloud"" />
        </EmptyMedia>
        <EmptyTitle>Cloud Storage Empty</EmptyTitle>
        <EmptyDescription>Upload files to your cloud storage to access them anywhere.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent>
        <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"">Upload Files</Button>
    </EmptyContent>
</Empty>")">
                <Empty Border="Border.Is1" BorderColor="BorderColor.Border" Class="border-dashed">
                    <EmptyHeader>
                        <EmptyMedia Variant="EmptyMediaVariant.Icon">
                            <Icon Name="LucideIcon.Cloud" />
                        </EmptyMedia>
                        <EmptyTitle>Cloud Storage Empty</EmptyTitle>
                        <EmptyDescription>Upload files to your cloud storage to access them anywhere.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Upload Files</Button>
                    </EmptyContent>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Background" Description="Use the bg-* and bg-gradient-* utilities to add a background to the empty state."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyMedia Variant=""EmptyMediaVariant.Icon"">
            <Icon Name=""LucideIcon.Bell"" />
        </EmptyMedia>
        <EmptyTitle>No Notifications</EmptyTitle>
        <EmptyDescription>You're all caught up. New notifications will appear here.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent>
        <Button Variant=""ButtonVariant.Outline""><Icon Name=""LucideIcon.RefreshCcw"" data-icon=""inline-start"" /> Refresh</Button>
    </EmptyContent>
</Empty>")">
                <Empty Class="h-full bg-muted/30">
                    <EmptyHeader>
                        <EmptyMedia Variant="EmptyMediaVariant.Icon">
                            <Icon Name="LucideIcon.Bell" />
                        </EmptyMedia>
                        <EmptyTitle>No Notifications</EmptyTitle>
                        <EmptyDescription Class="max-w-xs text-pretty">You're all caught up. New notifications will appear here.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent>
                        <Button Variant="ButtonVariant.Outline"><Icon Name="LucideIcon.RefreshCcw" data-icon="inline-start" /> Refresh</Button>
                    </EmptyContent>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar" Description="Use the EmptyMedia component to display an avatar in the empty state."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyMedia>
            <Avatar Class=""size-12"">
                <AvatarImage Src=""https://github.com/shadcn.png"" Class=""grayscale"" />
                <AvatarFallback>LR</AvatarFallback>
            </Avatar>
        </EmptyMedia>
        <EmptyTitle>User Offline</EmptyTitle>
        <EmptyDescription>This user is currently offline. You can leave a message to notify them or try again later.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent>
        <Button Size=""ButtonSize.Sm"">Leave Message</Button>
    </EmptyContent>
</Empty>")">
                <Empty>
                    <EmptyHeader>
                        <EmptyMedia>
                            <Avatar Class="size-12">
                                <AvatarImage Src="https://github.com/shadcn.png" Class="grayscale" />
                                <AvatarFallback>LR</AvatarFallback>
                            </Avatar>
                        </EmptyMedia>
                        <EmptyTitle>User Offline</EmptyTitle>
                        <EmptyDescription>This user is currently offline. You can leave a message to notify them or try again later.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent>
                        <Button Size="ButtonSize.Sm">Leave Message</Button>
                    </EmptyContent>
                </Empty>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar Group" Description="Use the EmptyMedia component to display an avatar group in the empty state."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyMedia>
            <Div Class=""flex -space-x-2 *:data-[slot=avatar]:size-12 *:data-[slot=avatar]:ring-2 *:data-[slot=avatar]:ring-background *:data-[slot=avatar]:grayscale"">
                <Avatar><AvatarImage Src=""https://github.com/shadcn.png"" Alt=""@shadcn"" /><AvatarFallback>CN</AvatarFallback></Avatar>
                <Avatar><AvatarImage Src=""https://github.com/maxleiter.png"" Alt=""@maxleiter"" /><AvatarFallback>LR</AvatarFallback></Avatar>
                <Avatar><AvatarImage Src=""https://github.com/evilrabbit.png"" Alt=""@evilrabbit"" /><AvatarFallback>ER</AvatarFallback></Avatar>
            </Div>
        </EmptyMedia>
        <EmptyTitle>No Team Members</EmptyTitle>
        <EmptyDescription>Invite your team to collaborate on this project.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent>
        <Button Size=""ButtonSize.Sm""><Icon Name=""LucideIcon.Plus"" /> Invite Members</Button>
    </EmptyContent>
</Empty>")">
                <Empty>
                    <EmptyHeader>
                        <EmptyMedia>
                            <Div Class="flex -space-x-2 *:data-[slot=avatar]:size-12 *:data-[slot=avatar]:ring-2 *:data-[slot=avatar]:ring-background *:data-[slot=avatar]:grayscale">
                                <Avatar><AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" /><AvatarFallback>CN</AvatarFallback></Avatar>
                                <Avatar><AvatarImage Src="https://github.com/maxleiter.png" Alt="maxleiter" /><AvatarFallback>LR</AvatarFallback></Avatar>
                                <Avatar><AvatarImage Src="https://github.com/evilrabbit.png" Alt="evilrabbit" /><AvatarFallback>ER</AvatarFallback></Avatar>
                            </Div>
                        </EmptyMedia>
                        <EmptyTitle>No Team Members</EmptyTitle>
                        <EmptyDescription>Invite your team to collaborate on this project.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent>
                        <Button Size="ButtonSize.Sm"><Icon Name="LucideIcon.Plus" /> Invite Members</Button>
                    </EmptyContent>
                </Empty>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="InputGroup" Description="You can add an InputGroup component to the EmptyContent component."
                        CodeLanguage="razor"
                        Code="@(@"<Empty>
    <EmptyHeader>
        <EmptyTitle>404 - Not Found</EmptyTitle>
        <EmptyDescription>The page you're looking for doesn't exist. Try searching for what you need below.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent>
        <InputGroup Class=""sm:w-3/4"">
            <InputGroupInput Placeholder=""Try searching for pages..."" />
            <InputGroupAddon><Icon Name=""LucideIcon.Search"" /></InputGroupAddon>
            <InputGroupAddon AddonAlign=""InputGroupAddonAlign.InlineEnd""><Kbd>/</Kbd></InputGroupAddon>
        </InputGroup>
        <EmptyDescription>Need help? <a href=""#"">Contact support</a></EmptyDescription>
    </EmptyContent>
</Empty>")">
                <Empty>
                    <EmptyHeader>
                        <EmptyTitle>404 - Not Found</EmptyTitle>
                        <EmptyDescription>The page you're looking for doesn't exist. Try searching for what you need below.</EmptyDescription>
                    </EmptyHeader>
                    <EmptyContent>
                        <InputGroup Class="sm:w-3/4">
                            <InputGroupInput Placeholder="Try searching for pages..." />
                            <InputGroupAddon><Icon Name="LucideIcon.Search" /></InputGroupAddon>
                            <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd"><Kbd>/</Kbd></InputGroupAddon>
                        </InputGroup>
                        <EmptyDescription>Need help? <a href="#">Contact support</a></EmptyDescription>
                    </EmptyContent>
                </Empty>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL" Description="Empty states also support right-to-left copy and action flow."
                        Code="@RtlCode"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull">
                        <Empty>
                            <EmptyHeader>
                                <EmptyMedia Variant="EmptyMediaVariant.Icon">
                                    <Icon Name="LucideIcon.Folder" />
                                </EmptyMedia>
                                <EmptyTitle>لا توجد مشاريع بعد</EmptyTitle>
                                <EmptyDescription>لم تقم بإنشاء أي مشاريع بعد. ابدأ بإنشاء مشروعك الأول.</EmptyDescription>
                            </EmptyHeader>
                            <EmptyContent Class="flex-row justify-center gap-2">
                                <Button>إنشاء مشروع</Button>
                                <Button Variant="ButtonVariant.Outline">استيراد مشروع</Button>
                            </EmptyContent>
                            <Button Variant="ButtonVariant.Link" Size="ButtonSize.Sm" To="#" TextColor="TextColor.MutedForeground">
                                تعرف على المزيد <Icon Name="LucideIcon.ArrowUpRight" data-icon="inline-end" Class="rtl:rotate-270" />
                            </Button>
                        </Empty>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Empty>
    <EmptyHeader>
        <EmptyMedia Variant=""EmptyMediaVariant.Icon"">
            <Icon Name=""LucideIcon.Folder"" />
        </EmptyMedia>
        <EmptyTitle>No Projects Yet</EmptyTitle>
        <EmptyDescription>You haven't created any projects yet. Get started by creating your first project.</EmptyDescription>
    </EmptyHeader>
    <EmptyContent Class=""flex-row justify-center gap-2"">
        <Button>Create Project</Button>
        <Button Variant=""ButtonVariant.Outline"">Import Project</Button>
    </EmptyContent>
    <Button Variant=""ButtonVariant.Link"" Size=""ButtonSize.Sm"" To=""#"" TextColor=""TextColor.MutedForeground"">
        Learn More <Icon Name=""LucideIcon.ArrowUpRight"" data-icon=""inline-end"" />
    </Button>
</Empty>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Empty>
        <EmptyHeader>
            <EmptyMedia Variant=""EmptyMediaVariant.Icon"">
                <Icon Name=""LucideIcon.Folder"" />
            </EmptyMedia>
            <EmptyTitle>لا توجد مشاريع بعد</EmptyTitle>
            <EmptyDescription>لم تقم بإنشاء أي مشاريع بعد. ابدأ بإنشاء مشروعك الأول.</EmptyDescription>
        </EmptyHeader>
        <EmptyContent Class=""flex-row justify-center gap-2"">
            <Button>إنشاء مشروع</Button>
            <Button Variant=""ButtonVariant.Outline"">استيراد مشروع</Button>
        </EmptyContent>
        <Button Variant=""ButtonVariant.Link"" Size=""ButtonSize.Sm"" To=""#"" TextColor=""TextColor.MutedForeground"">
            تعرف على المزيد <Icon Name=""LucideIcon.ArrowUpRight"" data-icon=""inline-end"" Class=""rtl:rotate-270"" />
        </Button>
    </Empty>
</DirectionProvider>";
}
