@page "/components/date-time"
@using System.Globalization
@inject IQuarkBrowserTimeZoneService BrowserTimeZoneService

<PageTitle>Date Time - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <DemoSection Description="Browser-local, culture-aware date/time primitives with semantic time elements and smart automatic updates."
                 Code="@OverviewCode"
                 CodeLanguage="razor"
                 PreviewClass="@PreviewClass">
        <Div Class="grid w-full gap-4 md:grid-cols-2">
            <Card Class="rounded-lg">
                <CardHeader Class="pb-2">
                    <CardTitle Class="text-sm">Current time</CardTitle>
                    <CardDescription>Updates on meaningful display boundaries.</CardDescription>
                </CardHeader>
                <CardBody>
                    <DateNow Class="text-lg font-semibold" data-testid="date-now-basic" />
                </CardBody>
            </Card>
            <Card Class="rounded-lg">
                <CardHeader Class="pb-2">
                    <CardTitle Class="text-sm">Calendar phrase</CardTitle>
                    <CardDescription>Readable labels for nearby dates.</CardDescription>
                </CardHeader>
                <CardBody>
                    <DateCalendar Value="_today" Class="text-lg font-semibold" />
                </CardBody>
            </Card>
            <Card Class="rounded-lg">
                <CardHeader Class="pb-2">
                    <CardTitle Class="text-sm">Relative</CardTitle>
                    <CardDescription>Smart seconds-to-days phrasing.</CardDescription>
                </CardHeader>
                <CardBody>
                    <DateRelative Value="_nearNow" Class="text-lg font-semibold" data-testid="date-relative-live" />
                </CardBody>
            </Card>
            <Card Class="rounded-lg">
                <CardHeader Class="pb-2">
                    <CardTitle Class="text-sm">Countdown</CardTitle>
                    <CardDescription>Stops updating once expired.</CardDescription>
                </CardHeader>
                <CardBody>
                    <DateUntil Value="_countdownTarget" Class="text-lg font-semibold" />
                </CardBody>
            </Card>
        </Div>
    </DemoSection>

    <DemoSection Title="DateNow"
                 Description="Render the current browser-local date/time, with custom formats or manual refresh control."
                 Code="@DateNowCode"
                 CodeLanguage="razor"
                 PreviewClass="@CompactPreviewClass">
        <Div Class="grid w-full gap-3 md:grid-cols-3">
            <DateExample Label="Basic">
                <DateNow Class="font-medium" />
            </DateExample>
            <DateExample Label="Custom format">
                <DateNow Format="HH:mm:ss" Class="font-mono text-sm" data-testid="date-now-seconds" />
            </DateExample>
            <DateExample Label="Auto-update disabled">
                <DateNow AutoUpdate="false" Class="font-medium text-muted-foreground" />
            </DateExample>
        </Div>
    </DemoSection>

    <DemoSection Title="Relative"
                 Description="Past, future, and near-now values use human phrases and switch intervals as the text ages."
                 Code="@RelativeCode"
                 CodeLanguage="razor"
                 PreviewClass="@CompactPreviewClass">
        <Div Class="grid w-full gap-3 md:grid-cols-3">
            <DateExample Label="Past">
                <DateRelative Value="_past" Class="font-medium" />
            </DateExample>
            <DateExample Label="Future">
                <DateRelative Value="_future" Class="font-medium" />
            </DateExample>
            <DateExample Label="Near-now live">
                <DateRelative Value="_nearNow" Class="font-medium" data-testid="date-relative-live-secondary" />
            </DateExample>
        </Div>
    </DemoSection>

    <DemoSection Title="Until"
                 Description="Countdown text renders the largest useful unit and slows or stops when the target is expired."
                 Code="@UntilCode"
                 CodeLanguage="razor"
                 PreviewClass="@CompactPreviewClass">
        <Div Class="grid w-full gap-3 md:grid-cols-2">
            <DateExample Label="Countdown">
                <DateUntil Value="_countdownTarget" Suffix=" remaining" Class="font-medium" />
            </DateExample>
            <DateExample Label="Expired state">
                <DateUntil Value="_expired" ExpiredText="Closed" Class="font-medium text-muted-foreground" />
            </DateExample>
        </Div>
    </DemoSection>

    <DemoSection Title="Calendar"
                 Description="Calendar phrasing keeps nearby dates conversational while falling back to compact localized dates."
                 Code="@CalendarCode"
                 CodeLanguage="razor"
                 PreviewClass="@CalendarPreviewClass">
        <Div Class="grid w-full gap-3 md:grid-cols-2">
            <DateExample Label="Today">
                <DateCalendar Value="_today" Class="font-medium" />
            </DateExample>
            <DateExample Label="Tomorrow">
                <DateCalendar Value="_tomorrow" Class="font-medium" />
            </DateExample>
            <DateExample Label="Yesterday">
                <DateCalendar Value="_yesterday" Class="font-medium" />
            </DateExample>
            <DateExample Label="Last weekday">
                <DateCalendar Value="_lastWeekday" Class="font-medium" />
            </DateExample>
            <DateExample Label="Next weekday">
                <DateCalendar Value="_nextWeekday" Class="font-medium" />
            </DateExample>
            <DateExample Label="Older date">
                <DateCalendar Value="_olderDate" Class="font-medium" />
            </DateExample>
        </Div>
    </DemoSection>

    <DemoSection Title="Time Zones And Culture"
                 Description="When TimeZone is omitted the browser time zone is detected once through Intl and cached for the scope."
                 Code="@TimezoneCode"
                 CodeLanguage="razor"
                 PreviewClass="@CalendarPreviewClass">
        <Div Class="grid w-full gap-3 md:grid-cols-2">
            <DateExample Label="Browser timezone">
                <Div Class="flex flex-col gap-1">
                    <DateTimeText Value="_meetingUtc" Format="f" Class="font-medium" />
                    <Span Class="text-xs text-muted-foreground">Detected: @_browserTimeZone</Span>
                </Div>
            </DateExample>
            <DateExample Label="Explicit timezone">
                <DateTimeText Value="_meetingUtc" TimeZone="UTC" Format="f" Class="font-medium" />
            </DateExample>
            <DateExample Label="Culture and custom format">
                <DateTimeText Value="_meetingUtc"
                              TimeZone="Europe/Paris"
                              Culture="@FrenchCulture"
                              Format="dddd d MMMM yyyy HH:mm"
                              Class="font-medium" />
            </DateExample>
            <DateExample Label="Custom styling">
                <DateCalendar Value="_tomorrow"
                              Class="rounded-md bg-muted px-2 py-1 text-sm font-medium text-foreground" />
            </DateExample>
        </Div>
    </DemoSection>
</Div>

@code {
    private const string PreviewClass = "preview relative flex min-h-[34rem] w-full justify-center p-6 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0";
    private const string CompactPreviewClass = "preview relative flex min-h-56 w-full justify-center p-6 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0";
    private const string CalendarPreviewClass = "preview relative flex min-h-80 w-full justify-center p-6 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0";

    private static readonly CultureInfo FrenchCulture = CultureInfo.GetCultureInfo("fr-FR");
    private readonly DateTimeOffset _createdAt = DateTimeOffset.UtcNow;
    private string _browserTimeZone = "Detecting...";

    private DateTimeOffset _today => _createdAt;
    private DateTimeOffset _past => _createdAt.AddHours(-2);
    private DateTimeOffset _future => _createdAt.AddDays(2);
    private DateTimeOffset _nearNow => _createdAt.AddSeconds(-45);
    private DateTimeOffset _countdownTarget => _createdAt.AddMinutes(3).AddSeconds(30);
    private DateTimeOffset _expired => _createdAt.AddMinutes(-15);
    private DateTimeOffset _tomorrow => _createdAt.AddDays(1).AddHours(2);
    private DateTimeOffset _yesterday => _createdAt.AddDays(-1).AddHours(-1);
    private DateTimeOffset _lastWeekday => _createdAt.AddDays(-5);
    private DateTimeOffset _nextWeekday => _createdAt.AddDays(5);
    private DateTimeOffset _olderDate => new(_createdAt.Year, 1, 12, 16, 0, 0, TimeSpan.Zero);
    private DateTimeOffset _meetingUtc => new(_createdAt.Year, 6, 18, 15, 30, 0, TimeSpan.Zero);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        _browserTimeZone = await BrowserTimeZoneService.GetTimeZoneId() ?? "Unavailable";
        StateHasChanged();
    }

    private const string OverviewCode =
@"<Div Class=""grid w-full gap-4 md:grid-cols-2"">
    <Card Class=""rounded-lg"">
        <CardHeader Class=""pb-2"">
            <CardTitle Class=""text-sm"">Current time</CardTitle>
            <CardDescription>Updates on meaningful display boundaries.</CardDescription>
        </CardHeader>
        <CardBody>
            <DateNow Class=""text-lg font-semibold"" data-testid=""date-now-basic"" />
        </CardBody>
    </Card>
    <Card Class=""rounded-lg"">
        <CardHeader Class=""pb-2"">
            <CardTitle Class=""text-sm"">Calendar phrase</CardTitle>
            <CardDescription>Readable labels for nearby dates.</CardDescription>
        </CardHeader>
        <CardBody>
            <DateCalendar Value=""_today"" Class=""text-lg font-semibold"" />
        </CardBody>
    </Card>
    <Card Class=""rounded-lg"">
        <CardHeader Class=""pb-2"">
            <CardTitle Class=""text-sm"">Relative</CardTitle>
            <CardDescription>Smart seconds-to-days phrasing.</CardDescription>
        </CardHeader>
        <CardBody>
            <DateRelative Value=""_nearNow"" Class=""text-lg font-semibold"" data-testid=""date-relative-live"" />
        </CardBody>
    </Card>
    <Card Class=""rounded-lg"">
        <CardHeader Class=""pb-2"">
            <CardTitle Class=""text-sm"">Countdown</CardTitle>
            <CardDescription>Stops updating once expired.</CardDescription>
        </CardHeader>
        <CardBody>
            <DateUntil Value=""_countdownTarget"" Class=""text-lg font-semibold"" />
        </CardBody>
    </Card>
</Div>";

    private const string DateNowCode =
@"<Div Class=""grid w-full gap-3 md:grid-cols-3"">
    <DateExample Label=""Basic"">
        <DateNow Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Custom format"">
        <DateNow Format=""HH:mm:ss"" Class=""font-mono text-sm"" data-testid=""date-now-seconds"" />
    </DateExample>
    <DateExample Label=""Auto-update disabled"">
        <DateNow AutoUpdate=""false"" Class=""font-medium text-muted-foreground"" />
    </DateExample>
</Div>";

    private const string RelativeCode =
@"<Div Class=""grid w-full gap-3 md:grid-cols-3"">
    <DateExample Label=""Past"">
        <DateRelative Value=""_past"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Future"">
        <DateRelative Value=""_future"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Near-now live"">
        <DateRelative Value=""_nearNow"" Class=""font-medium"" data-testid=""date-relative-live-secondary"" />
    </DateExample>
</Div>";

    private const string UntilCode =
@"<Div Class=""grid w-full gap-3 md:grid-cols-2"">
    <DateExample Label=""Countdown"">
        <DateUntil Value=""_countdownTarget"" Suffix="" remaining"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Expired state"">
        <DateUntil Value=""_expired"" ExpiredText=""Closed"" Class=""font-medium text-muted-foreground"" />
    </DateExample>
</Div>";

    private const string CalendarCode =
@"<Div Class=""grid w-full gap-3 md:grid-cols-2"">
    <DateExample Label=""Today"">
        <DateCalendar Value=""_today"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Tomorrow"">
        <DateCalendar Value=""_tomorrow"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Yesterday"">
        <DateCalendar Value=""_yesterday"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Last weekday"">
        <DateCalendar Value=""_lastWeekday"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Next weekday"">
        <DateCalendar Value=""_nextWeekday"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Older date"">
        <DateCalendar Value=""_olderDate"" Class=""font-medium"" />
    </DateExample>
</Div>";

    private const string TimezoneCode =
@"<Div Class=""grid w-full gap-3 md:grid-cols-2"">
    <DateExample Label=""Browser timezone"">
        <Div Class=""flex flex-col gap-1"">
            <DateTimeText Value=""_meetingUtc"" Format=""f"" Class=""font-medium"" />
            <Span Class=""text-xs text-muted-foreground"">Detected: @_browserTimeZone</Span>
        </Div>
    </DateExample>
    <DateExample Label=""Explicit timezone"">
        <DateTimeText Value=""_meetingUtc"" TimeZone=""UTC"" Format=""f"" Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Culture and custom format"">
        <DateTimeText Value=""_meetingUtc""
                      TimeZone=""Europe/Paris""
                      Culture=""@FrenchCulture""
                      Format=""dddd d MMMM yyyy HH:mm""
                      Class=""font-medium"" />
    </DateExample>
    <DateExample Label=""Custom styling"">
        <DateCalendar Value=""_tomorrow""
                      Class=""rounded-md bg-muted px-2 py-1 text-sm font-medium text-foreground"" />
    </DateExample>
</Div>";
}
