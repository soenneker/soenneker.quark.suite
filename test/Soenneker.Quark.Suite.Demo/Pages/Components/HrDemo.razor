@page "/hr-demo"

<PageTitle>Hr (Horizontal Rule) - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Basic Horizontal Rules" Code="@(@"<Text>Content above</Text>
<Hr/>
<Text>Content below</Text>")"
CodeLanguage="razor">
            <Div>
                <Text>Content above the horizontal rule</Text>
                <Hr/>
                <Text>Content below the horizontal rule</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Styled with Tailwind"
                     Code="@HrStyledCode"
                     CodeLanguage="razor">
            <Div Space="Space.Y.Is4">
                <Div>
                    <Text>Default:</Text>
                    <Hr/>
                </Div>
                <Div>
                    <Text>Primary border:</Text>
                    <Hr Class="border-primary"/>
                </Div>
                <Div>
                    <Text>Custom gradient:</Text>
                    <Hr Style="height: 5px; background: linear-gradient(to right, #007bff, #6f42c1); border: none;"/>
                </Div>
                <Div>
                    <Text>Dashed:</Text>
                    <Hr Style="border: none; border-top: 2px dashed #dc3545;"/>
                </Div>
            </Div>
        </DemoSection>

        <DemoSection Title="In Sections" Description="Hr separates content sections." Code="@(@"<Text>Section 1 content</Text>
<Hr/>
<Text>Section 2 content</Text>")"
CodeLanguage="razor">
            <Div>
                <Div TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Section 1</Div>
                <Text>Content of section 1.</Text>
                <Hr/>
                <Div TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Section 2</Div>
                <Text>Content of section 2.</Text>
                <Hr/>
                <Div TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Section 3</Div>
                <Text>Content of section 3.</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Interactive"
                     Description="Hr supports click events and other interactions."
                     Code="@HrInteractiveCode"
                     CodeLanguage="razor">
            <Div>
                <Text Class="mb-2 block">Hover and click the rule below:</Text>
                <Hr Class="cursor-pointer transition-all duration-300 hover:opacity-50" @onclick="HandleHrClick" Title="Click me!"/>
                <Text Margin="Margin.Is2.FromTop" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Click count: @_clickCount</Text>
            </Div>
        </DemoSection>
    </Div>
</Div>

@code {
    private const string HrStyledCode =
@"<Hr/>
<Hr Class=""border-primary""/>
<Hr Style=""height: 5px; background: linear-gradient(...); border: none;""/>";

    private const string HrInteractiveCode =
@"<Hr Class=""cursor-pointer hover:opacity-50"" @onclick=""HandleHrClick"" Title=""Click me!""/>";

    private int _clickCount;

    private void HandleHrClick(MouseEventArgs args)
    {
        _clickCount++;
        StateHasChanged();
    }
}
