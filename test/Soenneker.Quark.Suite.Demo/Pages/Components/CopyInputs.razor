@page "/components/copy-input"

<PageTitle>Copy Input - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                Description="Display copyable text in a compact input group."
                Code="@BasicCode"
                CodeLanguage="razor"
                PreviewClass="preview flex min-h-[14rem] w-full items-center justify-center p-10"
                PreviewInnerClass="demo-section-preview-inner flex w-full items-center justify-center">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="copy-input-id">ID</FieldLabel>
                    <CopyInput Id="copy-input-id" Value="@SampleId" />
                </Field>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string SampleId = "a8987611-da5e-4db7-9c73-f7509b391b47";

    private const string BasicCode =
@"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel For=""copy-input-id"">ID</FieldLabel>
    <CopyInput Id=""copy-input-id"" Value=""a8987611-da5e-4db7-9c73-f7509b391b47"" />
</Field>";
}
