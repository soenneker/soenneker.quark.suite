@page "/toggles"

<PageTitle>Toggle - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Outline toggle with icon and label."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Toggle aria-label="Toggle bookmark"
                        Size="ToggleSize.Sm"
                        Variant="ToggleVariant.Outline"
                        Class="data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-blue-500 data-[state=on]:*:[svg]:stroke-blue-500">
                    <Span data-icon="inline-start"><Icon Name="LucideIcon.Bookmark" /></Span>
                    Bookmark
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                         Code="@OutlineCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle italic">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Italic" /></Span>
                        Italic
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle bold">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Bold" /></Span>
                        Bold
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Text"
                         Code="@WithTextCode"
                         CodeLanguage="razor">
                <Toggle aria-label="Toggle italic">
                    <Span data-icon="inline-start"><Icon Name="LucideIcon.Italic" /></Span>
                    Italic
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle small" Size="ToggleSize.Sm">
                        Small
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle default" Size="ToggleSize.Default">
                        Default
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle large" Size="ToggleSize.Lg">
                        Large
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Toggle Disabled="true" aria-label="Toggle disabled">
                        Disabled
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" Disabled="true" aria-label="Toggle disabled outline">
                        Disabled
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Toggle aria-label="Toggle bookmark"
                            Size="ToggleSize.Sm"
                            Variant="ToggleVariant.Outline">
                        <Icon Name="LucideIcon.Bookmark" />
                        إشارة مرجعية
                    </Toggle>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Two-way binding and dynamic label text.
                </Paragraph>
            </Div>

            <DemoSection Title="Stateful bookmark"
                         Description="Use two-way binding to reflect pressed state in the label."
                         Code="@StatefulBookmarkCode"
                         CodeLanguage="razor">
                <Toggle @bind-Pressed="_bookmarkPressed"
                        aria-label="Toggle bookmark"
                        Variant="ToggleVariant.Outline"
                        Size="ToggleSize.Sm"
                        Class="data-[state=on]:bg-transparent data-[state=on]:text-blue-600">
                    <Span data-icon="inline-start"><Icon Name="LucideIcon.Bookmark" /></Span>
                    @(_bookmarkPressed ? "Saved" : "Bookmark")
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Controlled state"
                         Description="External controls can drive the same pressed state without drifting out of sync."
                         Code="@ControlledCode"
                         CodeLanguage="razor">
                <Div data-testid="toggle-controlled-demo" Space="Space.Y.Is3">
                    <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                        <Button Id="toggle-controlled-on" Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="@(() => _controlledPressed = true)">Set on</Button>
                        <Button Id="toggle-controlled-off" Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" OnClick="@(() => _controlledPressed = false)">Set off</Button>
                    </Div>
                    <Toggle @bind-Pressed="_controlledPressed"
                            Id="toggle-controlled"
                            aria-label="Toggle notifications"
                            Variant="ToggleVariant.Outline">
                        <Span data-icon="inline-start"><Icon Name="LucideIcon.Bell" /></Span>
                        Notifications
                    </Toggle>
                    <Paragraph Id="toggle-controlled-state" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                        Pressed: @_controlledPressed.ToString().ToLowerInvariant()
                    </Paragraph>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _bookmarkPressed;
    private bool _controlledPressed = true;

    private const string BasicCode =
@"<Toggle aria-label=""Toggle bookmark""
        Size=""ToggleSize.Sm""
        Variant=""ToggleVariant.Outline""
        Class=""data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-blue-500 data-[state=on]:*:[svg]:stroke-blue-500"">
    <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bookmark"" /></Span>
    Bookmark
</Toggle>";

    private const string OutlineCode =
@"<Div Class=""flex flex-wrap items-center gap-2"">
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle italic"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Italic"" /></Span>
        Italic
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle bold"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bold"" /></Span>
        Bold
    </Toggle>
</Div>";

    private const string WithTextCode =
@"<Toggle aria-label=""Toggle italic"">
    <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Italic"" /></Span>
    Italic
</Toggle>";

    private const string SizeCode =
@"<Div Class=""flex flex-wrap items-center gap-2"">
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle small"" Size=""ToggleSize.Sm"">
        Small
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle default"" Size=""ToggleSize.Default"">
        Default
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle large"" Size=""ToggleSize.Lg"">
        Large
    </Toggle>
</Div>";

    private const string DisabledCode =
@"<Div Class=""flex flex-wrap items-center gap-2"">
    <Toggle Disabled=""true"" aria-label=""Toggle disabled"">
        Disabled
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" Disabled=""true"" aria-label=""Toggle disabled outline"">
        Disabled
    </Toggle>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Toggle aria-label=""Toggle bookmark""
            Size=""ToggleSize.Sm""
            Variant=""ToggleVariant.Outline"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bookmark"" /></Span>
        إشارة مرجعية
    </Toggle>
</DirectionProvider>";

    private const string StatefulBookmarkCode =
@"<Toggle @bind-Pressed=""_bookmarkPressed""
        aria-label=""Toggle bookmark""
        Variant=""ToggleVariant.Outline""
        Size=""ToggleSize.Sm""
        Class=""data-[state=on]:bg-transparent data-[state=on]:text-blue-600"">
    <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bookmark"" /></Span>
    @(_bookmarkPressed ? ""Saved"" : ""Bookmark"")
</Toggle>";

    private const string ControlledCode =
@"<Div Space=""Space.Y.Is3"">
    <Div Class=""flex flex-wrap gap-2"">
        <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"" OnClick=""@(() => _controlledPressed = true)"">Set on</Button>
        <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"" OnClick=""@(() => _controlledPressed = false)"">Set off</Button>
    </Div>
    <Toggle @bind-Pressed=""_controlledPressed""
            aria-label=""Toggle notifications""
            Variant=""ToggleVariant.Outline"">
        <Span data-icon=""inline-start""><Icon Name=""LucideIcon.Bell"" /></Span>
        Notifications
    </Toggle>
    <Paragraph TextSize=""TextSize.Sm"" TextColor=""TextColor.MutedForeground"">
        Pressed: @_controlledPressed.ToString().ToLowerInvariant()
    </Paragraph>
</Div>";
}
