@page "/components/toggle"

<PageTitle>Toggle - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="A two-state button that can be either on or off."
                         Code="@BasicCode"
                         CodeLanguage="razor"
                         PreviewClass="@TogglePreviewClass">
                <Toggle Variant="ToggleVariant.Outline"
                        ToggleSize="ToggleSize.Sm"
                        aria-label="Toggle bookmark">
                    <Icon Name="LucideIcon.Bookmark" Class="size-3.5 group-data-[state=on]/toggle:fill-foreground" />
                    Bookmark
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                         Code="@OutlineCode"
                         CodeLanguage="razor"
                         PreviewClass="@TogglePreviewClass">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle italic">
                        <Icon Name="LucideIcon.Italic" />
                        Italic
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle bold">
                        <Icon Name="LucideIcon.Bold" />
                        Bold
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Text"
                         Code="@WithTextCode"
                         CodeLanguage="razor"
                         PreviewClass="@TogglePreviewClass">
                <Toggle aria-label="Toggle italic">
                    <Icon Name="LucideIcon.Italic" />
                    Italic
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Code="@SizeCode"
                         CodeLanguage="razor"
                         PreviewClass="@TogglePreviewClass">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle small" ToggleSize="ToggleSize.Sm">
                        Small
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle default" ToggleSize="ToggleSize.Default">
                        Default
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle large" ToggleSize="ToggleSize.Lg">
                        Large
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Code="@DisabledCode"
                         CodeLanguage="razor"
                         PreviewClass="@TogglePreviewClass">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" ItemsAlign="Items.Center" Gap="Gap.Is2">
                    <Toggle Disabled="true" aria-label="Toggle disabled">
                        Disabled
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" Disabled="true" aria-label="Toggle disabled outline">
                        Disabled
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         PreviewClass="@TogglePreviewClass">
                <DirectionProvider Dir="rtl">
                    <Toggle aria-label="Toggle bookmark"
                            ToggleSize="ToggleSize.Sm"
                            Variant="ToggleVariant.Outline">
                        <Icon Name="LucideIcon.Bookmark" Class="size-3.5" />
                        إشارة مرجعية
                    </Toggle>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string TogglePreviewClass = "preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0";

    private const string BasicCode =
@"<Toggle Variant=""ToggleVariant.Outline""
        ToggleSize=""ToggleSize.Sm""
        aria-label=""Toggle bookmark"">
    <Icon Name=""LucideIcon.Bookmark"" Class=""size-3.5 group-data-[state=on]/toggle:fill-foreground"" />
    Bookmark
</Toggle>";

    private const string OutlineCode =
@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" ItemsAlign=""Items.Center"" Gap=""Gap.Is2"">
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle italic"">
        <Icon Name=""LucideIcon.Italic"" />
        Italic
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle bold"">
        <Icon Name=""LucideIcon.Bold"" />
        Bold
    </Toggle>
</Div>";

    private const string WithTextCode =
@"<Toggle aria-label=""Toggle italic"">
    <Icon Name=""LucideIcon.Italic"" />
    Italic
</Toggle>";

    private const string SizeCode =
@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" ItemsAlign=""Items.Center"" Gap=""Gap.Is2"">
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle small"" ToggleSize=""ToggleSize.Sm"">
        Small
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle default"" ToggleSize=""ToggleSize.Default"">
        Default
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle large"" ToggleSize=""ToggleSize.Lg"">
        Large
    </Toggle>
</Div>";

    private const string DisabledCode =
@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" ItemsAlign=""Items.Center"" Gap=""Gap.Is2"">
    <Toggle Disabled=""true"" aria-label=""Toggle disabled"">
        Disabled
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" Disabled=""true"" aria-label=""Toggle disabled outline"">
        Disabled
    </Toggle>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Toggle aria-label=""Toggle bookmark""
            ToggleSize=""ToggleSize.Sm""
            Variant=""ToggleVariant.Outline"">
        <Icon Name=""LucideIcon.Bookmark"" Class=""size-3.5"" />
        إشارة مرجعية
    </Toggle>
</DirectionProvider>";
}
