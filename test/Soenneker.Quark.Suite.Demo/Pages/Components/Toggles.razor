@page "/toggles"

<PageTitle>Toggle - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                        Code="@DemoCode">
                <Toggle @bind-Pressed="_bookmarkPressed"
                        aria-label="Toggle bookmark"
                        Size="ToggleSize.Small"
                        Variant="ToggleVariant.Outline"
                        Class="data-[state=on]:bg-transparent data-[state=on]:text-blue-600">
                    <Icon Name="LucideIcon.Star" />
                    Bookmark
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                        Code="@OutlineCode">
                <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle featured">
                    <Icon Name="LucideIcon.Star" />
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Toggle Group"
                        Code="@ToggleGroupCode">
                <ToggleGroup Type="ToggleGroupType.Multiple"
                             Variant="ToggleVariant.Outline"
                             Values="@_multipleFormats"
                             ValueChangedMultiple="HandleMultipleFormatsChanged">
                    <ToggleGroupItem Value="featured" aria-label="Toggle featured">
                        <Icon Name="LucideIcon.Star" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="favorite" aria-label="Toggle favorite">
                        <Icon Name="LucideIcon.Heart" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="complete" aria-label="Toggle complete">
                        <Icon Name="LucideIcon.Check" />
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Single"
                        Code="@SingleCode">
                <ToggleGroup Type="ToggleGroupType.Single"
                             Value="@_singleFormat"
                             ValueChanged="HandleSingleFormatChanged">
                    <ToggleGroupItem Value="featured" aria-label="Toggle featured">
                        <Icon Name="LucideIcon.Star" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="favorite" aria-label="Toggle favorite">
                        <Icon Name="LucideIcon.Heart" />
                    </ToggleGroupItem>
                    <ToggleGroupItem Value="complete" aria-label="Toggle complete">
                        <Icon Name="LucideIcon.Check" />
                    </ToggleGroupItem>
                </ToggleGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show additional toggle variants beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                        Description="Use toggle sizing when you need the same interaction in tighter or larger layouts."
                        Code="@SizeCode">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                    <Toggle Size="ToggleSize.Small">Sm</Toggle>
                    <Toggle Size="ToggleSize.Default">Default</Toggle>
                    <Toggle Size="ToggleSize.Large">Lg</Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                        Description="Disabled toggles keep their layout while communicating that an action is unavailable."
                        Code="@DisabledCode">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                    <Toggle Disabled="true">Bold</Toggle>
                    <Toggle Variant="ToggleVariant.Outline" Disabled="true" Pressed="true">Italic</Toggle>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _bookmarkPressed;
    private string[] _multipleFormats = ["featured"];
    private string? _singleFormat = "featured";

    private const string DemoCode =
@"<Toggle @bind-Pressed=""_bookmarkPressed""
        aria-label=""Toggle bookmark""
        Size=""ToggleSize.Small""
        Variant=""ToggleVariant.Outline""
        Class=""data-[state=on]:bg-transparent data-[state=on]:text-blue-600"">
    <Icon Name=""LucideIcon.Star"" />
    Bookmark
</Toggle>";

    private const string OutlineCode =
@"<Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle featured"">
    <Icon Name=""LucideIcon.Star"" />
</Toggle>";

    private const string ToggleGroupCode =
@"<ToggleGroup Type=""ToggleGroupType.Multiple""
             Variant=""ToggleVariant.Outline""
             Values=""@_multipleFormats""
             ValueChangedMultiple=""HandleMultipleFormatsChanged"">
    <ToggleGroupItem Value=""featured"" aria-label=""Toggle featured"">
        <Icon Name=""LucideIcon.Star"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""favorite"" aria-label=""Toggle favorite"">
        <Icon Name=""LucideIcon.Heart"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""complete"" aria-label=""Toggle complete"">
        <Icon Name=""LucideIcon.Check"" />
    </ToggleGroupItem>
</ToggleGroup>";

    private const string SingleCode =
@"<ToggleGroup Type=""ToggleGroupType.Single""
             Value=""@_singleFormat""
             ValueChanged=""HandleSingleFormatChanged"">
    <ToggleGroupItem Value=""featured"" aria-label=""Toggle featured"">
        <Icon Name=""LucideIcon.Star"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""favorite"" aria-label=""Toggle favorite"">
        <Icon Name=""LucideIcon.Heart"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""complete"" aria-label=""Toggle complete"">
        <Icon Name=""LucideIcon.Check"" />
    </ToggleGroupItem>
</ToggleGroup>";

    private const string SizeCode =
@"<Toggle Size=""ToggleSize.Small"">Sm</Toggle>
<Toggle Size=""ToggleSize.Default"">Default</Toggle>
<Toggle Size=""ToggleSize.Large"">Lg</Toggle>";

    private const string DisabledCode =
@"<Toggle Disabled=""true"">Bold</Toggle>
<Toggle Variant=""ToggleVariant.Outline"" Disabled=""true"" Pressed=""true"">Italic</Toggle>";

    private Task HandleMultipleFormatsChanged(string[] values)
    {
        _multipleFormats = values;
        return Task.CompletedTask;
    }

    private Task HandleSingleFormatChanged(string? value)
    {
        _singleFormat = value;
        return Task.CompletedTask;
    }
}
