@page "/toggles"

<PageTitle>Toggle - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Text" Description="The default toggle is most useful when it includes a visible text label."
                        Code="@(@"<Toggle @bind-Pressed=""_pressed"">Bold</Toggle>")">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is4">
                    <Toggle @bind-Pressed="_pressed">Bold</Toggle>
                    <Span TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Pressed: @_pressed</Span>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline" Description="Outline matches the shadcn toggle treatment most closely."
                        Code="@(@"<Toggle Variant=""ToggleVariant.Default"">Default</Toggle>
<Toggle Variant=""ToggleVariant.Outline"">Outline</Toggle>")">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                    <Toggle>Default</Toggle>
                    <Toggle Variant="ToggleVariant.Outline">Outline</Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Small, default, and large toggle sizes."
                        Code="@(@"<Toggle Size=""ToggleSize.Small"">Sm</Toggle>
<Toggle Size=""ToggleSize.Default"">Default</Toggle>
<Toggle Size=""ToggleSize.Large"">Lg</Toggle>")">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                    <Toggle Size="ToggleSize.Small">Sm</Toggle>
                    <Toggle Size="ToggleSize.Default">Default</Toggle>
                    <Toggle Size="ToggleSize.Large">Lg</Toggle>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled" Description="Disabled toggles communicate unavailable formatting or actions without shifting layout."
                        Code="@(@"<Toggle Disabled=""true"">Bold</Toggle>
<Toggle Variant=""ToggleVariant.Outline"" Disabled=""true"" Pressed=""true"">Italic</Toggle>")">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                    <Toggle Disabled="true">Bold</Toggle>
                    <Toggle Variant="ToggleVariant.Outline" Disabled="true" Pressed="true">Italic</Toggle>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _pressed;
}
