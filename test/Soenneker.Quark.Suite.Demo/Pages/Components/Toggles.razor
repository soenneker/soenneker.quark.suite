@page "/toggles"

<PageTitle>Toggle - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Outline toggle with icon and label."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Toggle aria-label="Toggle bookmark"
                        Size="ToggleSize.Small"
                        Variant="ToggleVariant.Outline"
                        Class="data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-blue-500 data-[state=on]:*:[svg]:stroke-blue-500">
                    <span data-icon="inline-start"><Icon Name="LucideIcon.Bookmark" /></span>
                    Bookmark
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                         Code="@OutlineCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2">
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle italic">
                        <span data-icon="inline-start"><Icon Name="LucideIcon.Italic" /></span>
                        Italic
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle bold">
                        <span data-icon="inline-start"><Icon Name="LucideIcon.Bold" /></span>
                        Bold
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Text"
                         Code="@WithTextCode"
                         CodeLanguage="razor">
                <Toggle aria-label="Toggle italic">
                    <span data-icon="inline-start"><Icon Name="LucideIcon.Italic" /></span>
                    Italic
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2">
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle small" Size="ToggleSize.Small">
                        Small
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle default" Size="ToggleSize.Default">
                        Default
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle large" Size="ToggleSize.Large">
                        Large
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-wrap items-center gap-2">
                    <Toggle Disabled="true" aria-label="Toggle disabled">
                        Disabled
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" Disabled="true" aria-label="Toggle disabled outline">
                        Disabled
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Toggle aria-label="Toggle bookmark"
                            Size="ToggleSize.Small"
                            Variant="ToggleVariant.Outline">
                        <Icon Name="LucideIcon.Bookmark" />
                        إشارة مرجعية
                    </Toggle>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Two-way binding and dynamic label text.
                </Paragraph>
            </Div>

            <DemoSection Title="Stateful bookmark"
                         Description="Use two-way binding to reflect pressed state in the label."
                         Code="@StatefulBookmarkCode"
                         CodeLanguage="razor">
                    <Toggle @bind-Pressed="_bookmarkPressed"
                        aria-label="Toggle bookmark"
                        Variant="ToggleVariant.Outline"
                        Size="ToggleSize.Small"
                        Class="data-[state=on]:bg-transparent data-[state=on]:text-blue-600">
                    <span data-icon="inline-start"><Icon Name="LucideIcon.Bookmark" /></span>
                    @(_bookmarkPressed ? "Saved" : "Bookmark")
                </Toggle>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _bookmarkPressed;

    private const string BasicCode =
@"<Toggle aria-label=""Toggle bookmark""
        Size=""ToggleSize.Small""
        Variant=""ToggleVariant.Outline""
        Class=""data-[state=on]:bg-transparent data-[state=on]:*:[svg]:fill-blue-500 data-[state=on]:*:[svg]:stroke-blue-500"">
    <span data-icon=""inline-start""><Icon Name=""LucideIcon.Bookmark"" /></span>
    Bookmark
</Toggle>";

    private const string OutlineCode =
@"<Div Class=""flex flex-wrap items-center gap-2"">
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle italic"">
        <span data-icon=""inline-start""><Icon Name=""LucideIcon.Italic"" /></span>
        Italic
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle bold"">
        <span data-icon=""inline-start""><Icon Name=""LucideIcon.Bold"" /></span>
        Bold
    </Toggle>
</Div>";

    private const string WithTextCode =
@"<Toggle aria-label=""Toggle italic"">
    <span data-icon=""inline-start""><Icon Name=""LucideIcon.Italic"" /></span>
    Italic
</Toggle>";

    private const string SizeCode =
@"<Div Class=""flex flex-wrap items-center gap-2"">
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle small"" Size=""ToggleSize.Small"">
        Small
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle default"" Size=""ToggleSize.Default"">
        Default
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle large"" Size=""ToggleSize.Large"">
        Large
    </Toggle>
</Div>";

    private const string DisabledCode =
@"<Div Class=""flex flex-wrap items-center gap-2"">
    <Toggle Disabled=""true"" aria-label=""Toggle disabled"">
        Disabled
    </Toggle>
    <Toggle Variant=""ToggleVariant.Outline"" Disabled=""true"" aria-label=""Toggle disabled outline"">
        Disabled
    </Toggle>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Toggle aria-label=""Toggle bookmark""
            Size=""ToggleSize.Small""
            Variant=""ToggleVariant.Outline"">
        <span data-icon=""inline-start""><Icon Name=""LucideIcon.Bookmark"" /></span>
        إشارة مرجعية
    </Toggle>
</DirectionProvider>";

    private const string StatefulBookmarkCode =
@"<Toggle @bind-Pressed=""_bookmarkPressed""
        aria-label=""Toggle bookmark""
        Variant=""ToggleVariant.Outline""
        Size=""ToggleSize.Small""
        Class=""data-[state=on]:bg-transparent data-[state=on]:text-blue-600"">
    <span data-icon=""inline-start""><Icon Name=""LucideIcon.Bookmark"" /></span>
    @(_bookmarkPressed ? ""Saved"" : ""Bookmark"")
</Toggle>";
}
