@page "/toggles"

<PageTitle>Toggle - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Default"
                         Description="Use the default toggle when you need a compact two-state action."
                         Code="@DefaultCode">
                <Toggle aria-label="Toggle italic">
                    <Icon Name="LucideIcon.Italic" />
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Outline"
                         Description="Use the outline variant for a quieter treatment that still reads as interactive."
                         Code="@OutlineCode">
                <Toggle Variant="ToggleVariant.Outline" aria-label="Toggle bold">
                    <Icon Name="LucideIcon.Bold" />
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Text"
                         Description="Text labels work alongside icons without changing the toggle interaction model."
                         Code="@WithTextCode">
                <Toggle @bind-Pressed="_bookmarkPressed"
                        aria-label="Toggle bookmark"
                        Variant="ToggleVariant.Outline"
                        Class="data-[state=on]:bg-transparent data-[state=on]:text-blue-600">
                    <Icon Name="LucideIcon.Star" />
                    Bookmark
                </Toggle>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Use the size parameter to scale the toggle for denser or roomier layouts."
                         Code="@SizeCode">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                    <Toggle Size="ToggleSize.Small" aria-label="Small toggle">
                        <Icon Name="LucideIcon.Bold" />
                    </Toggle>
                    <Toggle Size="ToggleSize.Default" aria-label="Default toggle">
                        <Icon Name="LucideIcon.Bold" />
                    </Toggle>
                    <Toggle Size="ToggleSize.Large" aria-label="Large toggle">
                        <Icon Name="LucideIcon.Bold" />
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disabled toggles keep their state styling while clearly communicating that interaction is unavailable."
                         Code="@DisabledCode">
                <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                    <Toggle Disabled="true" aria-label="Disabled bold toggle">
                        <Icon Name="LucideIcon.Bold" />
                    </Toggle>
                    <Toggle Variant="ToggleVariant.Outline" Disabled="true" Pressed="true" aria-label="Disabled italic toggle">
                        <Icon Name="LucideIcon.Italic" />
                    </Toggle>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Toggle interactions should also feel natural in right-to-left interfaces."
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <Toggle @bind-Pressed="_rtlPressed"
                            aria-label="تبديل الإشارة المرجعية"
                            Variant="ToggleVariant.Outline"
                            Class="data-[state=on]:bg-transparent data-[state=on]:text-blue-600">
                        <Icon Name="LucideIcon.Star" />
                        حفظ
                    </Toggle>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show additional toggle behaviors beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Stateful Bookmark"
                         Description="Two-way binding makes it easy to project the pressed state into surrounding UI."
                         Code="@StatefulBookmarkCode">
                <Toggle @bind-Pressed="_bookmarkPressed"
                        aria-label="Toggle bookmark"
                        Variant="ToggleVariant.Outline"
                        Size="ToggleSize.Small"
                        Class="data-[state=on]:bg-transparent data-[state=on]:text-blue-600">
                    <Icon Name="LucideIcon.Star" />
                    @(_bookmarkPressed ? "Saved" : "Bookmark")
                </Toggle>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _bookmarkPressed;

    private const string DefaultCode =
@"<Toggle aria-label=""Toggle italic"">
    <Icon Name=""LucideIcon.Italic"" />
</Toggle>";

    private const string OutlineCode =
@"<Toggle Variant=""ToggleVariant.Outline"" aria-label=""Toggle bold"">
    <Icon Name=""LucideIcon.Bold"" />
</Toggle>";

    private const string WithTextCode =
@"<Toggle @bind-Pressed=""_bookmarkPressed""
        aria-label=""Toggle bookmark""
        Variant=""ToggleVariant.Outline""
        Class=""data-[state=on]:bg-transparent data-[state=on]:text-blue-600"">
    <Icon Name=""LucideIcon.Star"" />
    Bookmark
</Toggle>";

    private const string SizeCode =
@"<Toggle Size=""ToggleSize.Small"" aria-label=""Small toggle"">
    <Icon Name=""LucideIcon.Bold"" />
</Toggle>
<Toggle Size=""ToggleSize.Default"" aria-label=""Default toggle"">
    <Icon Name=""LucideIcon.Bold"" />
</Toggle>
<Toggle Size=""ToggleSize.Large"" aria-label=""Large toggle"">
    <Icon Name=""LucideIcon.Bold"" />
</Toggle>";

    private const string DisabledCode =
@"<Toggle Disabled=""true"" aria-label=""Disabled bold toggle"">
    <Icon Name=""LucideIcon.Bold"" />
</Toggle>
<Toggle Variant=""ToggleVariant.Outline"" Disabled=""true"" Pressed=""true"" aria-label=""Disabled italic toggle"">
    <Icon Name=""LucideIcon.Italic"" />
</Toggle>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Toggle @bind-Pressed=""_rtlPressed""
            aria-label=""تبديل الإشارة المرجعية""
            Variant=""ToggleVariant.Outline""
            Class=""data-[state=on]:bg-transparent data-[state=on]:text-blue-600"">
        <Icon Name=""LucideIcon.Star"" />
        حفظ
    </Toggle>
</DirectionProvider>";

    private const string StatefulBookmarkCode =
@"<Toggle @bind-Pressed=""_bookmarkPressed""
        aria-label=""Toggle bookmark""
        Variant=""ToggleVariant.Outline""
        Size=""ToggleSize.Small""
        Class=""data-[state=on]:bg-transparent data-[state=on]:text-blue-600"">
    <Icon Name=""LucideIcon.Star"" />
    @(_bookmarkPressed ? ""Saved"" : ""Bookmark"")
</Toggle>";

    private bool _rtlPressed = true;
}
