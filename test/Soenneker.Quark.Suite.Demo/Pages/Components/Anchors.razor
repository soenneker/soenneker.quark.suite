@page "/anchors"
@using Target = Soenneker.Quark.Target

<PageTitle>Anchors - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Basic Links" Code="@(@"<Anchor To="""" TextColor=""TextColor.Primary"">NavLink</Anchor>
<Anchor To=""https://example.com"" Target=""Target.Blank"">External</Anchor>")"
CodeLanguage="razor">
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is4">
                <Anchor To="" TextColor="TextColor.Primary">Basic NavLink</Anchor>
                <Anchor To="https://example.com" Target="Target.Blank">External Link</Anchor>
            </Div>
        </DemoSection>

        <DemoSection Title="Navigation" Code="@(@"<Nav Class=""flex gap-4"">
    <Anchor To="""" Class=""text-primary hover:underline"">Home</Anchor>
    <Anchor To=""about"" Class=""text-primary hover:underline"">About</Anchor>
</Nav>")"
CodeLanguage="razor">
            <Nav Display="Display.Flex" Gap="Gap.Is4">
                <Anchor To="" Class="text-primary hover:underline">Home</Anchor>
                <Anchor To="about" Class="text-primary hover:underline">About</Anchor>
                <Anchor To="services" Class="text-primary hover:underline">Services</Anchor>
            </Nav>
        </DemoSection>

        <DemoSection Title="Button-style Links" Code="@(@"<Button Variant=""ButtonVariant.Default"" To="""">Navigate Home</Button>
<Button Variant=""ButtonVariant.Outline"" To=""about"">Navigate About</Button>")"
CodeLanguage="razor">
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                <Button Variant="ButtonVariant.Default" To="">Navigate Home</Button>
                <Button Variant="ButtonVariant.Outline" To="about">Navigate About</Button>
            </Div>
        </DemoSection>

        <DemoSection Title="Styled" Code="@(@"<Anchor To="""" TextDecoration=""TextDecoration.None"" FontWeight=""FontWeight.Bold"" TextColor=""TextColor.Accent"" Class=""hover:underline"">
    Custom Styled Link
</Anchor>")"
CodeLanguage="razor">
            <Anchor To="" TextDecoration="TextDecoration.None" FontWeight="FontWeight.Bold" TextColor="TextColor.Accent" Class="hover:underline">
                Custom Styled Link
            </Anchor>
        </DemoSection>
    </Div>
</Div>
