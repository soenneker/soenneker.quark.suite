@page "/anchors"
@using Target = Soenneker.Quark.Target

<PageTitle>Anchors - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Basic Links" Code="@(@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is4"">
    <Anchor Href="""" TextColor=""TextColor.Primary"">Basic NavLink</Anchor>
    <Anchor Href=""https://example.com"" Target=""Target.Blank"">External Link</Anchor>
</Div>")"
CodeLanguage="razor">
            <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is4">
                <Anchor Href="" TextColor="TextColor.Primary">Basic NavLink</Anchor>
                <Anchor Href="https://example.com" Target="Target.Blank">External Link</Anchor>
            </Div>
        </DemoSection>

        <DemoSection Title="Navigation" Code="@(@"<Div Display=""Display.Flex"" Gap=""Gap.Is4"">
    <Anchor Href="""" TextColor=""TextColor.Primary"">Home</Anchor>
    <Anchor Href=""about"" TextColor=""TextColor.Primary"">About</Anchor>
    <Anchor Href=""services"" TextColor=""TextColor.Primary"">Services</Anchor>
</Div>")"
CodeLanguage="razor">
            <Div Display="Display.Flex" Gap="Gap.Is4">
                <Anchor Href="" TextColor="TextColor.Primary">Home</Anchor>
                <Anchor Href="about" TextColor="TextColor.Primary">About</Anchor>
                <Anchor Href="services" TextColor="TextColor.Primary">Services</Anchor>
            </Div>
        </DemoSection>

        <DemoSection Title="Button-style Links" Code="@(@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is2"">
    <Button Variant=""ButtonVariant.Default"" To="""">Navigate Home</Button>
    <Button Variant=""ButtonVariant.Outline"" To=""about"">Navigate About</Button>
</Div>")"
CodeLanguage="razor">
            <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is2">
                <Button Variant="ButtonVariant.Default" To="">Navigate Home</Button>
                <Button Variant="ButtonVariant.Outline" To="about">Navigate About</Button>
            </Div>
        </DemoSection>

        <DemoSection Title="Styled" Code="@(@"<Anchor Href="""" DecorationLine=""DecorationLine.None"" FontWeight=""FontWeight.Bold"" TextColor=""TextColor.Accent"" Class=""hover:underline"">
    Custom Styled Link
</Anchor>")"
CodeLanguage="razor">
            <Anchor Href="" DecorationLine="DecorationLine.None" FontWeight="FontWeight.Bold" TextColor="TextColor.Accent" Class="hover:underline">
                Custom Styled Link
            </Anchor>
        </DemoSection>
    </Div>
</Div>
