@page "/kbd"

<PageTitle>Kbd - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <TooltipProvider DelayDuration="150">
        <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Used to display textual user input from keyboard."
                         Code="@KbdCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-col items-center gap-4">
                    <KbdGroup>
                        <Kbd>⌘</Kbd>
                        <Kbd>⇧</Kbd>
                        <Kbd>⌥</Kbd>
                        <Kbd>⌃</Kbd>
                    </KbdGroup>
                    <KbdGroup>
                        <Kbd>Ctrl</Kbd>
                        <Span>+</Span>
                        <Kbd>B</Kbd>
                    </KbdGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group"
                         Description="Use the KbdGroup component to group keyboard keys together."
                         Code="@KbdGroupCode"
                         CodeLanguage="razor">
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Use <KbdGroup><Kbd>Ctrl</Kbd><Span>+</Span><Kbd>B</Kbd></KbdGroup>
                    <KbdGroup><Kbd>Ctrl</Kbd><Span>+</Span><Kbd>K</Kbd></KbdGroup>
                    to open the command palette
                </Paragraph>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button"
                         Description="Use the Kbd component inside a Button component to display a keyboard key inside a button."
                         Code="@KbdButtonCode"
                         CodeLanguage="razor">
                <Button Variant="ButtonVariant.Outline">
                    Accept
                    <Kbd>⏎</Kbd>
                </Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Tooltip"
                         Description="You can use the Kbd component inside a Tooltip component to display a tooltip with a keyboard key."
                         Code="@KbdTooltipCode"
                         CodeLanguage="razor">
                <Div Class="flex items-center gap-2">
                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Save</Button>
                            </TooltipTrigger>
                            <TooltipContent Class="pr-1.5">
                                <Div Class="flex items-center gap-2">
                                    Save Changes <Kbd>S</Kbd>
                                </Div>
                            </TooltipContent>
                        </Tooltip>

                        <Tooltip>
                            <TooltipTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Print</Button>
                            </TooltipTrigger>
                            <TooltipContent>
                                <KbdGroup>
                                    <Kbd>Ctrl</Kbd>
                                    <Kbd>P</Kbd>
                                </KbdGroup>
                            </TooltipContent>
                        </Tooltip>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input Group"
                         Description="You can use the Kbd component inside an InputGroupAddon component to display a keyboard key inside an input group."
                         Code="@KbdInputGroupCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsMd" Width="Width.IsFull">
                    <InputGroup>
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineStart">
                            <Icon Name="LucideIcon.Search" />
                        </InputGroupAddon>
                        <InputGroupInput Placeholder="Search..." />
                        <InputGroupAddon AddonAlign="InputGroupAddonAlign.InlineEnd">
                            <KbdGroup>
                                <Kbd>⌘</Kbd>
                                <Kbd>K</Kbd>
                            </KbdGroup>
                        </InputGroupAddon>
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@KbdRtlCode"
                         CodeLanguage="razor"
                         ShowPreviewToolbar="true"
                         PreviewLang="ar"
                         PreviewDir="rtl">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex flex-col items-center gap-4">
                        <KbdGroup>
                            <Kbd>⌘</Kbd>
                            <Kbd>⇧</Kbd>
                            <Kbd>⌥</Kbd>
                            <Kbd>⌃</Kbd>
                        </KbdGroup>
                        <KbdGroup>
                            <Kbd>Ctrl</Kbd>
                            <Span>+</Span>
                            <Kbd>B</Kbd>
                        </KbdGroup>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
        </Div>
    </TooltipProvider>
</Div>

