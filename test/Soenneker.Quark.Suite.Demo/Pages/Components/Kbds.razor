@page "/typography/kbd"

<PageTitle>Kbd - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Common shortcuts"
                         Description="Adapted from the shadcn kbd examples for grouped keyboard shortcuts."
                         Code="@KbdCode">
                <Div Class="flex flex-col items-start gap-4">
                    <Div Class="flex items-center gap-2">
                        <Kbd>Ctrl</Kbd>
                        <Span>+</Span>
                        <Kbd>K</Kbd>
                        <Span Class="text-sm text-muted-foreground">Open command palette</Span>
                    </Div>

                    <Div Class="flex items-center gap-2">
                        <KbdChip>Shift</KbdChip>
                        <Span>+</Span>
                        <KbdChip>Alt</KbdChip>
                        <Span>+</Span>
                        <KbdChip>S</KbdChip>
                        <Span Class="text-sm text-muted-foreground">Save all changes</Span>
                    </Div>

                    <Div Class="flex items-center gap-2">
                        <Kbd>Esc</Kbd>
                        <Span Class="text-sm text-muted-foreground">Close overlays and dialogs</Span>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Buttons and helper text"
                         Description="Keyboard hints can be embedded anywhere you need lightweight affordances.">
                <Div Class="flex flex-col gap-4 md:flex-row md:items-center">
                    <Button Variant="ButtonVariant.Outline">
                        Search docs
                        <Span Class="ml-2 flex items-center gap-1">
                            <KbdChip>Ctrl</KbdChip>
                            <KbdChip>/</KbdChip>
                        </Span>
                    </Button>

                    <Div Class="rounded-lg border border-border bg-muted/40 px-3 py-2 text-sm text-muted-foreground">
                        Press <Kbd>Tab</Kbd> to move focus, then <Kbd>Enter</Kbd> to confirm.
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string KbdCode =
@"<Div Class=""flex items-center gap-2"">
    <Kbd>Ctrl</Kbd>
    <Span>+</Span>
    <Kbd>K</Kbd>
</Div>";
}
