@page "/texts"
@using Microsoft.Extensions.Logging
@inject ILogger<Texts> Logger

<PageTitle>Text - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Colors" Description="TextColor and BackgroundColor for semantic text styling." Code="@(@"<Text TextColor=""TextColor.Primary"">Primary</Text>
<Text TextColor=""TextColor.Accent"">Success</Text>
<Text TextColor=""TextColor.Destructive"">Danger</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Text TextColor="TextColor.Primary">Primary colored text</Text>
                <Text TextColor="TextColor.Secondary">Secondary</Text>
                <Text TextColor="TextColor.Accent">Success</Text>
                <Text TextColor="TextColor.Destructive">Danger</Text>
                <Text TextColor="TextColor.MutedForeground">Warning</Text>
                <Text TextColor="TextColor.SecondaryForeground">Info</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Font Weight" Description="FontWeight.Light, Normal, Bold, Bolder." Code="@(@"<Text FontWeight=""FontWeight.Light"">Light</Text>
<Text FontWeight=""FontWeight.Normal"">Normal</Text>
<Text FontWeight=""FontWeight.Bold"">Bold</Text>
<Text FontWeight=""FontWeight.Extrabold"">Bolder</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Text FontWeight="FontWeight.Light">Light</Text>
                <Text FontWeight="FontWeight.Normal">Normal</Text>
                <Text FontWeight="FontWeight.Bold">Bold</Text>
                <Text FontWeight="FontWeight.Extrabold">Bolder</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Font Style" Description="FontStyle.Normal and Italic." Code="@(@"<Text FontStyle=""FontStyle.Normal"">Normal</Text>
<Text FontStyle=""FontStyle.Italic"">Italic</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Text FontStyle="FontStyle.Normal">Normal</Text>
                <Text FontStyle="FontStyle.Italic">Italic</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Decoration" Description="TextDecoration.None, Underline, LineThrough." Code="@(@"<Text TextDecoration=""TextDecoration.None"">No decoration</Text>
<Text TextDecoration=""TextDecoration.Underline"">Underline</Text>
<Text TextDecoration=""TextDecoration.LineThrough"">Strikethrough</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Text TextDecoration="TextDecoration.None">No decoration</Text>
                <Text TextDecoration="TextDecoration.Underline">Underline</Text>
                <Text TextDecoration="TextDecoration.LineThrough">Strikethrough</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Alignment" Description="TextAlign.Start, Center, End." Code="@(@"<Text TextAlign=""TextAlign.Start"" Class=""block"">Start aligned</Text>
<Text TextAlign=""TextAlign.Center"" Class=""block"">Center aligned</Text>
<Text TextAlign=""TextAlign.End"" Class=""block"">End aligned</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Text TextAlign="TextAlign.Start" Display="Display.Block">Start aligned</Text>
                <Text TextAlign="TextAlign.Center" Display="Display.Block">Center aligned</Text>
                <Text TextAlign="TextAlign.End" Display="Display.Block">End aligned</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Heading-Style Text" Description="Use Class with Tailwind for heading styles (e.g. text-2xl font-bold)." Code="@(@"<Text Class=""text-2xl font-bold"">Heading style</Text>
<Text Class=""text-xl font-semibold"">Subheading</Text>
<Text Class=""text-lg font-medium"">Large text</Text>")"
CodeLanguage="razor">
            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">Use <Code Class="rounded bg-muted px-1.5 py-0.5" Inline="true">Class</Code> with Tailwind for heading styles: <Code Class="rounded bg-muted px-1.5 py-0.5" Inline="true">text-2xl font-bold</Code></Paragraph>
            <Div Space="Space.Y.Is1">
                <Text Class="text-2xl font-bold">Heading 1 style</Text>
                <Text TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Heading 2 style</Text>
                <Text Class="text-lg font-medium">Heading 3 style</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Background Colors" Description="BackgroundColor with TextColor for badges/pills." Code="@(@"<Text BackgroundColor=""BackgroundColor.Primary"" TextColor=""TextColor.White"" Padding=""Padding.Is2"" Class=""rounded"">Primary</Text>
<Text BackgroundColor=""BackgroundColor.Accent"" TextColor=""TextColor.White"" Padding=""Padding.Is2"" Class=""rounded"">Success</Text>")"
CodeLanguage="razor">
            <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                <Text BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is2" Class="rounded">Primary</Text>
                <Text BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is2" Class="rounded">Success</Text>
                <Text BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is2" Class="rounded">Danger</Text>
                <Text BackgroundColor="BackgroundColor.Muted" TextColor="TextColor.Foreground" Padding="Padding.Is2" Class="rounded">Warning</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Features"
                     Description="Id, Class, Style, Margin, Padding, and event handlers."
                     Code="@TextFeaturesCode"
                     CodeLanguage="razor">
        <Div Rounded="Rounded.Xl" Border="Border.Is1" Padding="Padding.Is6" Class="bg-muted/30">
            <Paragraph Class="mb-3 text-sm text-muted-foreground" Margin="Margin.Is0">Text inherits Element properties:</Paragraph>
            <UnorderedList Class="list-inside list-disc space-y-1 text-sm">
                <UnorderedListItem><Strong>Id, Class, Style</Strong> — HTML attributes</UnorderedListItem>
                <UnorderedListItem><Strong>Margin, Padding</Strong> — Spacing utilities</UnorderedListItem>
                <UnorderedListItem><Strong>Event Handlers</Strong> — Click, focus, keyboard</UnorderedListItem>
            </UnorderedList>
        </Div>
        </DemoSection>
    </Div>
</Div>

@code {
    private const string TextFeaturesCode =
@"<Text Id=""my-text"" Class=""font-medium"" Margin=""Margin.Is2"" Padding=""Padding.Is1"">
    Text supports Id, Class, Style, spacing, and event handlers from Element.
</Text>";

    protected override void OnInitialized() => Logger.LogInformation("Text demo page initialized");
}
