@page "/icons"
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

<PageTitle>Lucide - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
            Use the <Code Inline="true">Icon</Code> primitive to render generated Lucide SVGs with Quark spacing, colors, and standard element attributes.
        </Paragraph>
    </Div>

    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Lucide icons rendered with the Lucide primitive. Requires Soenneker.Quark.Gen.Lucide and ILucideIconSvgProvider." Code="@(@"<Icon Name=""LucideIcon.Check"" Class=""size-6""/>
                                                                                                                                                                      <Icon Name=""LucideIcon.Heart"" Class=""size-6""/>")"
                                                                                                                                                                      CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap="Gap.Is4">
                    <Icon Name="LucideIcon.AArrowDown" BoxSize="Size.Is6"/>
                    <Icon Name="LucideIcon.Check" BoxSize="Size.Is6"/>
                    <Icon Name="LucideIcon.Activity" BoxSize="Size.Is6"/>
                    <Icon Name="LucideIcon.Heart" BoxSize="Size.Is6"/>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Text Color" Description="Use Text for theming." Code="@(@"<Icon Name=""LucideIcon.Check"" TextColor=""TextColor.Primary"" Class=""size-6""/>
                                                                                          <Icon Name=""LucideIcon.Heart"" TextColor=""TextColor.Destructive"" Class=""size-6""/>")"
                                                                                          CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap="Gap.Is4">
                    <Icon Name="LucideIcon.Check" BoxSize="Size.Is6"/>
                    <Icon Name="LucideIcon.Heart" BoxSize="Size.Is6"/>
                    <Icon Name="LucideIcon.Star" BoxSize="Size.Is6"/>
                    <Icon Name="LucideIcon.House" BoxSize="Size.Is6"/>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sizes" Description="Use Tailwind size utilities or Class." Code="@(@"<Icon Name=""LucideIcon.Star"" Class=""size-4""/>
                                                                                           <Icon Name=""LucideIcon.Star"" Class=""size-6""/>
                                                                                           <Icon Name=""LucideIcon.Star"" Class=""size-8""/>
                                                                                           <Icon Name=""LucideIcon.Star"" Class=""size-12""/>")"
                                                                                           CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") ItemsAlign="Items.Center" Gap='Gap.Token("6")'>
                    <Icon Name="LucideIcon.Star" BoxSize="Size.Is4"/>
                    <Icon Name="LucideIcon.Star" BoxSize="Size.Is6"/>
                    <Icon Name="LucideIcon.Star" Class="size-8"/>
                    <Icon Name="LucideIcon.Star" Class="size-12"/>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Label" Description="ChildContent for accessible labels (e.g. sr-only)." Code="@(@"<Icon Name=""LucideIcon.Check"" Class=""size-5 text-green-600"">
    <Span class=""sr-only"">Completed</Span>
                                                                                                             </Icon>
<Span>Task completed</Span>")"
CodeLanguage="razor">
                <Div Class="flex gap-3 items-center">
                    <Icon Name="LucideIcon.Check" Class="size-5 text-green-600">
                        <Span class="sr-only">Completed</Span>
                    </Icon>
                    <Span>Task completed</Span>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="In Buttons" Description="Icons paired with button text." Code="@(@"<Button Variant=""ButtonVariant.Default"">
                                                                                             <Icon Name=""LucideIcon.Plus"" Class=""size-4"" Margin=""Margin.Is2.FromEnd""/>
    Add
</Button>")"
CodeLanguage="razor">
                <Div Class="flex flex-wrap gap-3">
                    <Button Variant="ButtonVariant.Default">
                        <Icon Name="LucideIcon.Plus" BoxSize="Size.Is4" Margin="Margin.Is2.FromEnd"/>
                        Add
                    </Button>
                    <Button Variant="ButtonVariant.Outline">
                        <Icon Name="LucideIcon.Download" BoxSize="Size.Is4" Margin="Margin.Is2.FromEnd"/>
                        Download
                    </Button>
                    <Button Variant="ButtonVariant.Ghost">
                        <Icon Name="LucideIcon.Trash2" BoxSize="Size.Is4" Margin="Margin.Is2.FromEnd"/>
                        Delete
                    </Button>
                </Div>
            </DemoSection>
        </Section>

        @if (DeveloperMode)
        {
            <Section Space="Space.Y.Is4">
                <DemoSection Title="Developer Mode: Conditional Name" Description="Verifies that Icon.Name accepts a ternary expression that returns LucideIcon values." Code="@(@"<Icon Name=""@(IsPlaying ? LucideIcon.Pause : LucideIcon.Play)"" Class=""size-6""/>")"
                CodeLanguage="razor">
                    <Div Class="flex flex-wrap items-center gap-4">
                        <Button Variant="ButtonVariant.Outline" @onclick="TogglePlaying">
                            <Icon Name="@(IsPlaying ? LucideIcon.Pause : LucideIcon.Play)" BoxSize="Size.Is4" Margin="Margin.Is2.FromEnd"/>
                            Toggle state
                        </Button>
                        <Icon Name="@(IsPlaying ? LucideIcon.Pause : LucideIcon.Play)" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">IsPlaying: @IsPlaying</Small>
                    </Div>
                </DemoSection>
            </Section>
        }

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Common Icons"
                         Description="Frequently used Lucide icons."
                         Code="@CommonIconsCode"
                         CodeLanguage="razor">
                <Div Class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-4">
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.House" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">Home</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.Settings" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">Settings</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.User" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">User</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.Search" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">Search</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.Mail" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">Mail</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.Bell" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">Bell</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.Calendar" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">Calendar</Small>
                    </Div>
                    <Div Class="flex flex-col items-center gap-2 p-3 rounded-lg border border-border hover:bg-muted/50">
                        <Icon Name="LucideIcon.Folder" BoxSize="Size.Is6"/>
                        <Small TextColor="TextColor.MutedForeground">Folder</Small>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string CommonIconsCode =
@"<Div Class=""grid grid-cols-4 gap-4"">
    <Icon Name=""LucideIcon.House"" Class=""size-6""/>
    <Icon Name=""LucideIcon.Settings"" Class=""size-6""/>
    <Icon Name=""LucideIcon.User"" Class=""size-6""/>
</Div>";

    private bool DeveloperMode => bool.TryParse(Configuration["DeveloperMode"], out var developerMode) && developerMode;

    private bool IsPlaying { get; set; }

    private void TogglePlaying()
    {
        IsPlaying = !IsPlaying;
    }

}
