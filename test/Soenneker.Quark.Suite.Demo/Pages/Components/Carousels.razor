@page "/carousels"
@using Soenneker.Bradix

<PageTitle>Carousel - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
                     Description="A carousel with motion and swipe built using Embla."
                     Code="@BasicCode"
                     CodeLanguage="razor">
            <Div Class="mx-auto w-full max-w-[12rem] sm:max-w-xs">
                <Carousel Width="Width.IsFull" Class="max-w-[12rem] sm:max-w-xs">
                    <CarouselContent>
                        @for (var index = 1; index <= 5; index++)
                        {
                            var slideNumber = index;

                            <CarouselItem>
                                <Div class="p-1">
                                    <Card>
                                        <CardBody Class="flex aspect-square items-center justify-center p-6">
                                            <Span Class="text-4xl font-semibold">@slideNumber</Span>
                                        </CardBody>
                                    </Card>
                                </Div>
                            </CarouselItem>
                        }
                    </CarouselContent>
                    <CarouselPrevious />
                    <CarouselNext />
                </Carousel>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Sizes"
                     Description="To set the size of the items, you can use the basis utility class on CarouselItem."
                     Code="@SizesCode"
                     CodeLanguage="razor">
            <Div Class="mx-auto w-full max-w-[12rem] sm:max-w-xs md:max-w-sm">
                <Carousel Width="Width.IsFull" Class="max-w-[12rem] sm:max-w-xs md:max-w-sm">
                    <CarouselContent>
                        @for (var index = 1; index <= 5; index++)
                        {
                            var slideNumber = index;

                            <CarouselItem Class="basis-1/2 lg:basis-1/3">
                                <Div class="p-1">
                                    <Card>
                                        <CardBody Class="flex aspect-square items-center justify-center p-6">
                                            <Span TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold">@slideNumber</Span>
                                        </CardBody>
                                    </Card>
                                </Div>
                            </CarouselItem>
                        }
                    </CarouselContent>
                    <CarouselPrevious />
                    <CarouselNext />
                </Carousel>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Spacing"
                     Description="To set the spacing between the items, we use a padding utility on CarouselItem and a negative margin on CarouselContent."
                     Code="@SpacingCode"
                     CodeLanguage="razor">
            <Div Class="mx-auto w-full max-w-[12rem] sm:max-w-xs md:max-w-sm">
                <Carousel Align="center" Width="Width.IsFull" Class="max-w-[12rem] sm:max-w-xs md:max-w-sm">
                    <CarouselContent Class="-ml-1">
                        @for (var index = 1; index <= 5; index++)
                        {
                            var slideNumber = index;

                            <CarouselItem Class="basis-1/2 pl-1 lg:basis-1/3">
                                <Div class="p-1">
                                    <Card>
                                        <CardBody Class="flex aspect-square items-center justify-center p-6">
                                            <Span TextSize="TextSize.TwoXl" FontWeight="FontWeight.Semibold">@slideNumber</Span>
                                        </CardBody>
                                    </Card>
                                </Div>
                            </CarouselItem>
                        }
                    </CarouselContent>
                    <CarouselPrevious />
                    <CarouselNext />
                </Carousel>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Orientation"
                     Description="Use the orientation prop to set the orientation of the carousel."
                     Code="@OrientationCode"
                     CodeLanguage="razor">
            <Div Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                <Carousel Orientation="Orientation.Vertical" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <CarouselContent Class="-mt-1 h-[270px]">
                        @for (var index = 1; index <= 5; index++)
                        {
                            var slideNumber = index;

                            <CarouselItem Class="pt-1 basis-1/2">
                                <Div class="p-1">
                                    <Card>
                                        <CardBody Class="flex items-center justify-center p-6">
                                            <Span TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold">@slideNumber</Span>
                                        </CardBody>
                                    </Card>
                                </Div>
                            </CarouselItem>
                        }
                    </CarouselContent>
                    <CarouselPrevious />
                    <CarouselNext />
                </Carousel>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="API"
                     Description="Use a state and the setApi props to get an instance of the carousel API."
                     Code="@ApiCode"
                     CodeLanguage="razor">
            <Div Class="mx-auto max-w-[10rem] sm:max-w-xs">
                <Carousel Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" SelectedIndexChanged="HandleCarouselApiIndexChanged">
                    <CarouselContent>
                        @for (var index = 1; index <= 5; index++)
                        {
                            var slideNumber = index;

                            <CarouselItem>
                                <Div class="p-1">
                                    <Card>
                                        <CardBody Class="flex aspect-square items-center justify-center p-6">
                                            <Span TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold">@slideNumber</Span>
                                        </CardBody>
                                    </Card>
                                </Div>
                            </CarouselItem>
                        }
                    </CarouselContent>
                    <CarouselPrevious />
                    <CarouselNext />
                </Carousel>
                <Div Class="py-2 text-center text-sm text-muted-foreground">
                    Slide @_carouselApiCurrent of 5
                </Div>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Plugins"
                     Description="You can use the plugins prop to add plugins to the carousel."
                     Code="@PluginsCode"
                     CodeLanguage="razor">
            <Div Class="mx-auto w-full max-w-[10rem] sm:max-w-xs">
                <Carousel Autoplay="true" Loop="true" AutoplayDelay="TimeSpan.FromSeconds(2)" Width="Width.IsFull" Class="max-w-[10rem] sm:max-w-xs">
                    <CarouselContent>
                        @for (var index = 1; index <= 5; index++)
                        {
                            var slideNumber = index;

                            <CarouselItem>
                                <Div class="p-1">
                                    <Card>
                                        <CardBody Class="flex aspect-square items-center justify-center p-6">
                                            <Span TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold">@slideNumber</Span>
                                        </CardBody>
                                    </Card>
                                </Div>
                            </CarouselItem>
                        }
                    </CarouselContent>
                    <CarouselPrevious />
                    <CarouselNext />
                </Carousel>
            </Div>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="RTL"
                     Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                     Code="@RtlCode"
                     CodeLanguage="razor">
            <Div Class="flex flex-col items-center gap-6">
                <Select TValue="string" Size="SelectSizes.Sm" SelectedValue="@_carouselRtlLanguage" SelectedValueChanged="HandleCarouselRtlLanguageChanged">
                    <SelectTrigger Class="w-44" dir="ltr">
                        <SelectValue />
                    </SelectTrigger>
                    <SelectContent Class="data-[state=open]:animate-none data-[state=closed]:animate-none" dir="ltr">
                        <SelectGroup>
                            <SelectItem TValue="string" ItemValue="@("ar")" Text="Arabic (العربية)" />
                            <SelectItem TValue="string" ItemValue="@("en")" Text="English" />
                        </SelectGroup>
                    </SelectContent>
                </Select>

                <DirectionProvider Dir="@CarouselRtlDirection">
                    <Div Class="mx-auto w-full max-w-[12rem] sm:max-w-xs">
                        <Carousel Width="Width.IsFull" Class="max-w-[12rem] sm:max-w-xs">
                            <CarouselContent>
                                @foreach (var slideNumber in CarouselRtlSlides)
                                {
                                    <CarouselItem>
                                        <Div class="p-1">
                                            <Card>
                                                <CardBody Class="flex aspect-square items-center justify-center p-6">
                                                    <Span TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold">@slideNumber</Span>
                                                </CardBody>
                                            </Card>
                                        </Div>
                                    </CarouselItem>
                                }
                            </CarouselContent>
                            <CarouselPrevious />
                            <CarouselNext />
                        </Carousel>
                    </Div>
                </DirectionProvider>
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private const string BasicCode =
@"<Carousel Class=""w-full max-w-xs"">
    <CarouselContent>
        @for (var index = 1; index <= 5; index++)
        {
            <CarouselItem>
                <Div class=""p-1"">
                    <Card>
                        <CardBody Class=""flex aspect-square items-center justify-center p-6"">
                            <Span Class=""text-4xl font-semibold"">@slideNumber</Span>
                        </CardBody>
                    </Card>
                </Div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>
<div class=""py-2 text-center text-sm text-muted-foreground"">
    Slide @current of 5
</div>";

    private const string SizesCode =
@"<Carousel Class=""w-full max-w-sm"">
    <CarouselContent>
        @for (var index = 1; index <= 5; index++)
        {
            <CarouselItem Class=""md:basis-1/2 lg:basis-1/3"">
                <Div class=""p-1"">
                    <Card>
                        <CardBody Class=""flex aspect-square items-center justify-center p-6"">
                            <Span Class=""text-3xl font-semibold"">@slideNumber</Span>
                        </CardBody>
                    </Card>
                </Div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>
<div class=""py-2 text-center text-sm text-muted-foreground"">
    Slide @current of 5
</div>";

    private const string SpacingCode =
@"<Carousel Class=""w-full max-w-sm"">
    <CarouselContent Class=""-ml-1"">
        @for (var index = 1; index <= 5; index++)
        {
            <CarouselItem Class=""pl-1 md:basis-1/2 lg:basis-1/3"">
                <Div class=""p-1"">
                    <Card>
                        <CardBody Class=""flex aspect-square items-center justify-center p-6"">
                            <Span Class=""text-2xl font-semibold"">@slideNumber</Span>
                        </CardBody>
                    </Card>
                </Div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private const string OrientationCode =
@"<Carousel Orientation=""Orientation.Vertical"" Class=""w-full max-w-xs"">
    <CarouselContent Class=""-mt-1 h-[200px]"">
        @for (var index = 1; index <= 5; index++)
        {
            <CarouselItem Class=""pt-1 md:basis-1/2"">
                <Div class=""p-1"">
                    <Card>
                        <CardBody Class=""flex items-center justify-center p-6"">
                            <Span Class=""text-3xl font-semibold"">@slideNumber</Span>
                        </CardBody>
                    </Card>
                </Div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private const string ApiCode =
@"<Carousel SelectedIndexChanged=""HandleSelectedIndexChanged"" Class=""w-full max-w-xs"">
    <CarouselContent>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>
<div class=""py-2 text-center text-sm text-muted-foreground"">
    Slide @current of 5
</div>";

    private const string PluginsCode =
@"<Carousel Autoplay=""true"" Loop=""true"" AutoplayDelay=""TimeSpan.FromSeconds(2)"" Class=""w-full max-w-xs"">
    <CarouselContent>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Carousel Class=""w-full max-w-xs"">
        <CarouselContent>
            <CarouselItem>١</CarouselItem>
            <CarouselItem>٢</CarouselItem>
            <CarouselItem>٣</CarouselItem>
        </CarouselContent>
        <CarouselPrevious />
        <CarouselNext />
    </Carousel>
</DirectionProvider>";

    private string _carouselRtlLanguage = "ar";
    private int _carouselApiCurrent = 1;

    private string CarouselRtlDirection => _carouselRtlLanguage == "ar" ? "rtl" : "ltr";

    private IReadOnlyList<string> CarouselRtlSlides => _carouselRtlLanguage == "ar"
        ? ["١", "٢", "٣", "٤", "٥"]
        : ["1", "2", "3", "4", "5"];

    private Task HandleCarouselRtlLanguageChanged(string? value)
    {
        _carouselRtlLanguage = string.IsNullOrWhiteSpace(value) ? "ar" : value;
        return Task.CompletedTask;
    }

    private Task HandleCarouselApiIndexChanged(int index)
    {
        _carouselApiCurrent = index + 1;
        return Task.CompletedTask;
    }
}
