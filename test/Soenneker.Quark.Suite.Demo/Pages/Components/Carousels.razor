@page "/media/carousels"

<PageTitle>Carousel - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Card carousel"
                         Description="Adapted from the shadcn carousel demo with numbered cards inside the carousel shell."
                         Code="@CarouselCode">
                <Div Class="mx-auto w-full max-w-sm px-12">
                    <Carousel>
                        <CarouselContent>
                            @for (int index = 1; index <= 5; index++)
                            {
                                <CarouselItem>
                                    <Card>
                                        <CardBody Class="flex aspect-square items-center justify-center p-6">
                                            <Span Class="text-4xl font-semibold">@index</Span>
                                        </CardBody>
                                    </Card>
                                </CarouselItem>
                            }
                        </CarouselContent>
                        <CarouselPrevious />
                        <CarouselNext />
                    </Carousel>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical orientation"
                         Description="Switch the orientation to vertical for stacked slide layouts.">
                <Div Class="mx-auto h-96 w-full max-w-sm px-12">
                    <Carousel Orientation="vertical" Class="h-full">
                        <CarouselContent Class="h-full">
                            @for (int index = 1; index <= 3; index++)
                            {
                                <CarouselItem>
                                    <Card Class="h-full">
                                        <CardBody Class="flex h-full flex-col justify-between p-6">
                                            <Div Class="space-y-2">
                                                <Paragraph class="text-sm font-medium text-muted-foreground">Slide @index</Paragraph>
                                                <H3 class="text-xl font-semibold">Release checkpoint</H3>
                                                <Paragraph class="text-sm text-muted-foreground">Use vertical carousels for stacked announcements, playlists, or timeline snapshots.</Paragraph>
                                            </Div>
                                            <Button Variant="ButtonVariant.Outline">Review</Button>
                                        </CardBody>
                                    </Card>
                                </CarouselItem>
                            }
                        </CarouselContent>
                        <CarouselPrevious />
                        <CarouselNext />
                    </Carousel>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string CarouselCode =
@"<Carousel>
    <CarouselContent>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
        <CarouselItem>...</CarouselItem>
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";
}
