@page "/asides"

<PageTitle>Aside - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Semantic complementary content."
                         Code="@BasicAsideCode"
                         CodeLanguage="razor">
                <Aside Border="Border.Is1"
                       Rounded="Rounded.Lg"
                       Padding="Padding.Is4"
                       BackgroundColor="BackgroundColor.Muted">
                    <H4>Related reading</H4>
                    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                        Use Aside for content related to the surrounding page, such as notes, references, and supporting links.
                    </Paragraph>
                </Aside>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Article layout"
                         Description="Aside works well beside a primary article."
                         Code="@ArticleAsideCode"
                         CodeLanguage="razor">
                <Div Display="Display.Grid" Gap="Gap.Is4" Class="lg:grid-cols-3">
                    <Article Border="Border.Is1" Rounded="Rounded.Lg" Padding="Padding.Is4" Class="lg:col-span-2">
                        <H4>Release notes</H4>
                        <Paragraph>
                            The main content stays in the article while the supporting summary is kept in a complementary landmark.
                        </Paragraph>
                        <Paragraph Margin="Margin.Is0">
                            This keeps document structure clear for assistive technologies and search engines.
                        </Paragraph>
                    </Article>

                    <Aside AriaLabel="Release summary"
                           Border="Border.Is1"
                           Rounded="Rounded.Lg"
                           Padding="Padding.Is4"
                           BackgroundColor="BackgroundColor.Secondary"
                           BackgroundOpacity="BackgroundOpacity.Is10">
                        <H6>Summary</H6>
                        <UnorderedList Margin="Margin.Is0" Class="list-inside list-disc space-y-1">
                            <UnorderedListItem>3 components updated</UnorderedListItem>
                            <UnorderedListItem>2 new examples added</UnorderedListItem>
                            <UnorderedListItem>No breaking changes</UnorderedListItem>
                        </UnorderedList>
                    </Aside>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Callout aside"
                         Description="Use Quark styling props for compact notes."
                         Code="@CalloutAsideCode"
                         CodeLanguage="razor">
                <Aside Border="Border.Is1"
                       BorderColor="BorderColor.Primary"
                       Rounded="Rounded.Lg"
                       Padding="Padding.Is4"
                       BackgroundColor="BackgroundColor.Primary"
                       BackgroundOpacity="BackgroundOpacity.Is10">
                    <Div Display="Display.Flex" ItemsAlign="Items.Start" Gap="Gap.Is3">
                        <Icon Name="LucideIcon.Info" Size="Quark.Size.Is5" TextColor="TextColor.Primary" />
                        <Div>
                            <Strong>Implementation note</Strong>
                            <Paragraph Margin="Margin.Is1.FromTop.Is0.FromBottom" TextColor="TextColor.MutedForeground">
                                Aside renders a native &lt;aside&gt; element and preserves custom attributes.
                            </Paragraph>
                        </Div>
                    </Div>
                </Aside>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicAsideCode =
@"<Aside Border=""Border.Is1"" Rounded=""Rounded.Lg"" Padding=""Padding.Is4"" BackgroundColor=""BackgroundColor.Muted"">
    <H4>Related reading</H4>
    <Paragraph TextColor=""TextColor.MutedForeground"" Margin=""Margin.Is0"">
        Use Aside for content related to the surrounding page.
    </Paragraph>
</Aside>";

    private const string ArticleAsideCode =
@"<Div Display=""Display.Grid"" Gap=""Gap.Is4"" Class=""lg:grid-cols-3"">
    <Article Border=""Border.Is1"" Rounded=""Rounded.Lg"" Padding=""Padding.Is4"" Class=""lg:col-span-2"">
        <H4>Release notes</H4>
        <Paragraph>The main content stays in the article.</Paragraph>
    </Article>

    <Aside AriaLabel=""Release summary"" Border=""Border.Is1"" Rounded=""Rounded.Lg"" Padding=""Padding.Is4"">
        <H6>Summary</H6>
        <UnorderedList Margin=""Margin.Is0"" Class=""list-inside list-disc space-y-1"">
            <UnorderedListItem>3 components updated</UnorderedListItem>
            <UnorderedListItem>2 new examples added</UnorderedListItem>
        </UnorderedList>
    </Aside>
</Div>";

    private const string CalloutAsideCode =
@"<Aside Border=""Border.Is1"" BorderColor=""BorderColor.Primary"" Rounded=""Rounded.Lg"" Padding=""Padding.Is4"">
    <Div Display=""Display.Flex"" ItemsAlign=""Items.Start"" Gap=""Gap.Is3"">
        <Icon Name=""LucideIcon.Info"" Size=""Quark.Size.Is5"" TextColor=""TextColor.Primary"" />
        <Div>
            <Strong>Implementation note</Strong>
            <Paragraph Margin=""Margin.Is1.FromTop.Is0.FromBottom"">
                Aside renders a native &lt;aside&gt; element.
            </Paragraph>
        </Div>
    </Div>
</Aside>";
}
