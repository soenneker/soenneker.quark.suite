@page "/inputs"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Input Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="A text input component for forms and user data entry with built-in styling and accessibility features."
                         Code="@ApiKeyCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-api-key">API Key</FieldLabel>
                    <Input Id="input-api-key" Type="password" Placeholder="sk-..." />
                    <FieldDescription>Your API key is encrypted and stored securely.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Code="@BasicCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Input Type="email" Placeholder="Email" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field"
                         Description="Use Field, FieldLabel, and FieldDescription to create an input with a label and description."
                         Code="@FieldCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-field-username">Username</FieldLabel>
                    <Input Id="input-field-username" Type="text" Placeholder="Enter your username" />
                    <FieldDescription>Choose a unique username for your account.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field Group"
                         Description="Use FieldGroup to show multiple Field blocks and to build forms."
                         Code="@FieldGroupCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <FieldGroup Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <Field>
                        <FieldLabel For="fieldgroup-name">Name</FieldLabel>
                        <Input Id="fieldgroup-name" Type="text" Placeholder="Jordan Lee" />
                    </Field>
                    <Field>
                        <FieldLabel For="fieldgroup-email">Email</FieldLabel>
                        <Input Id="fieldgroup-email" Type="email" Placeholder="name@example.com" />
                        <FieldDescription>We'll send updates to this address.</FieldDescription>
                    </Field>
                    <Field Horizontal="true">
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Reset</Button>
                        <Button Type="ButtonType.Submit">Submit</Button>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Use the disabled prop to disable the input. To style the disabled state, add the data-disabled attribute to the Field component."
                         Code="@DisabledCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs" Disabled="true">
                    <FieldLabel For="input-disabled">Email</FieldLabel>
                    <Input Id="input-disabled" Type="email" Placeholder="Email" Disabled="true" />
                    <FieldDescription>This field is currently disabled.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Use the aria-invalid prop to mark the input as invalid. To style the invalid state, add the data-invalid attribute to the Field component."
                         Code="@InvalidCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs" IsInvalid="true">
                    <FieldLabel For="input-invalid">Invalid Input</FieldLabel>
                    <Input Id="input-invalid" Placeholder="Error" aria-invalid="true" />
                    <FieldDescription>This field contains validation errors.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="File"
                         Description="Use the type=&quot;file&quot; prop to create a file input."
                         Code="@FileCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="picture">Picture</FieldLabel>
                    <Input Id="picture" Type="file" />
                    <FieldDescription>Select a picture to upload.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Inline"
                         Description="Use Field with orientation=&quot;horizontal&quot; to create an inline input. Pair with Button to create a search input with a button."
                         Code="@InlineCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field Class="max-w-xs w-full" Horizontal="true">
                    <Input Type="search" Placeholder="Search..." />
                    <Button Type="ButtonType.Button" Variant="ButtonVariant.Default">Search</Button>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Grid"
                         Description="Use a grid layout to place multiple inputs side by side."
                         Code="@GridCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <FieldGroup Class="grid w-full max-w-sm grid-cols-2 gap-4">
                    <Field>
                        <FieldLabel For="first-name">First Name</FieldLabel>
                        <Input Id="first-name" Type="text" Placeholder="Jordan" />
                    </Field>
                    <Field>
                        <FieldLabel For="last-name">Last Name</FieldLabel>
                        <Input Id="last-name" Type="text" Placeholder="Lee" />
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Required"
                         Description="Use the required attribute to indicate required inputs."
                         Code="@RequiredCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-required" RequiredIndicator="true">Required Field</FieldLabel>
                    <Input Id="input-required" Placeholder="This field is required" Required="true" />
                    <FieldDescription>This field must be filled out.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge"
                         Description="Use Badge in the label to highlight a recommended field."
                         Code="@BadgeCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-badge" Class="flex w-full items-center gap-2">
                        Webhook URL
                        <Badge Variant="BadgeVariant.Secondary" Class="ml-auto">Beta</Badge>
                    </FieldLabel>
                    <Input Id="input-badge" Type="url" Placeholder="https://api.example.com/webhook" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input Group"
                         Description="To add icons, text, or buttons inside an input, use the InputGroup component. See the Input Group component for more examples."
                         Code="@InputGroupSectionCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 p-6"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-group-url">Website URL</FieldLabel>
                    <InputGroup>
                        <InputGroupAddon>https://</InputGroupAddon>
                        <InputGroupInput Id="input-group-url" Placeholder="example.com" />
                    </InputGroup>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button Group"
                         Description="To add buttons to an input, use the ButtonGroup component. See the Button Group component for more examples."
                         Code="@ButtonGroupCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-button-group">Search</FieldLabel>
                    <ButtonGroup>
                        <Input Id="input-button-group" Type="search" Placeholder="Type to search..." />
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Search</Button>
                    </ButtonGroup>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="A full form example with multiple inputs, a select, and a button."
                         Code="@FormCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-[32rem]"
                         CodeLanguage="razor">
                <EditForm Model="_formModel" OnValidSubmit="HandleValidSubmit" class="w-full max-w-sm space-y-4">
                    <DataAnnotationsValidator />

                    <FieldGroup>
                        <Field>
                            <FieldLabel For="input-form-name">Name</FieldLabel>
                            <Input Id="input-form-name" Type="text" @bind-Value="_formModel.Name" Placeholder="John Doe" />
                            <ValidationMessage For="@(() => _formModel.Name)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                        </Field>

                        <Field>
                            <FieldLabel For="input-form-email">Email</FieldLabel>
                            <Input Id="input-form-email" Type="email" @bind-Value="_formModel.Email" Placeholder="john@example.com" />
                            <FieldDescription>We'll never share your email with anyone.</FieldDescription>
                            <ValidationMessage For="@(() => _formModel.Email)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                        </Field>

                        <Div Class="grid grid-cols-2 gap-4">
                            <Field>
                                <FieldLabel For="input-form-phone">Phone</FieldLabel>
                                <Input Id="input-form-phone" Type="tel" Placeholder="+1 (555) 123-4567" />
                            </Field>
                            <Field>
                                <FieldLabel For="input-form-country">Country</FieldLabel>
                                <Select TValue="string" SelectedValue="@("us")">
                                    <SelectTrigger Id="input-form-country">
                                        <SelectValue />
                                    </SelectTrigger>
                                    <SelectContent>
                                        <SelectItem TValue="string" ItemValue="@("us")" Text="United States" />
                                        <SelectItem TValue="string" ItemValue="@("uk")" Text="United Kingdom" />
                                        <SelectItem TValue="string" ItemValue="@("ca")" Text="Canada" />
                                    </SelectContent>
                                </Select>
                            </Field>
                        </Div>

                        <Field>
                            <FieldLabel For="input-form-address">Address</FieldLabel>
                            <Input Id="input-form-address" Type="text" Placeholder="123 Main St" />
                        </Field>

                        <Field Horizontal="true">
                            <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Cancel</Button>
                            <Button Type="ButtonType.Submit">Submit</Button>
                        </Field>
                    </FieldGroup>

                    @if (!string.IsNullOrEmpty(_formMessage))
                    {
                        <Div class="rounded-lg border bg-card p-4">
                            <Paragraph TextSize="TextSize.Sm">@_formMessage</Paragraph>
                        </Div>
                    }
                </EditForm>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 *:max-w-xs"
                         ShowPreviewToolbar="true"
                         PreviewLang="ar"
                         PreviewDir="rtl"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Field MaxWidth="MaxWidth.IsXs">
                        <FieldLabel For="input-rtl-api-key">مفتاح API</FieldLabel>
                        <Input Id="input-rtl-api-key" Type="password" Placeholder="sk-..." />
                        <FieldDescription>مفتاح API الخاص بك مشفر ومخزن بأمان.</FieldDescription>
                    </Field>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string ApiKeyCode =
@"<Field>
    <FieldLabel For=""input-api-key"">API Key</FieldLabel>
    <Input Id=""input-api-key"" Type=""password"" Placeholder=""sk-..."" />
    <FieldDescription>Your API key is encrypted and stored securely.</FieldDescription>
</Field>";

    private const string BasicCode =
@"<Input Type=""email"" Placeholder=""Email"" />";

    private const string FieldCode =
@"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel For=""input-field-username"">Username</FieldLabel>
    <Input Id=""input-field-username"" Type=""text"" Placeholder=""Enter your username"" />
    <FieldDescription>Choose a unique username for your account.</FieldDescription>
</Field>";

    private const string FieldGroupCode =
@"<FieldGroup Class=""w-full max-w-xs"">
    <Field>
        <FieldLabel For=""fieldgroup-name"">Name</FieldLabel>
        <Input Id=""fieldgroup-name"" Type=""text"" Placeholder=""Jordan Lee"" />
    </Field>
    <Field>
        <FieldLabel For=""fieldgroup-email"">Email</FieldLabel>
        <Input Id=""fieldgroup-email"" Type=""email"" Placeholder=""name@example.com"" />
        <FieldDescription>We'll send updates to this address.</FieldDescription>
    </Field>
    <Field Horizontal=""true"">
        <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Outline"">Reset</Button>
        <Button Type=""ButtonType.Submit"">Submit</Button>
    </Field>
</FieldGroup>";

    private const string DisabledCode =
@"<Field Class=""max-w-xs"" Disabled=""true"">
    <FieldLabel For=""input-disabled"">Email</FieldLabel>
    <Input Id=""input-disabled"" Type=""email"" Placeholder=""Email"" Disabled=""true"" />
    <FieldDescription>This field is currently disabled.</FieldDescription>
</Field>";

    private const string InvalidCode =
@"<Field Class=""max-w-xs"" IsInvalid=""true"">
    <FieldLabel For=""input-invalid"">Invalid Input</FieldLabel>
    <Input Id=""input-invalid"" Placeholder=""Error"" aria-invalid=""true"" />
    <FieldDescription>This field contains validation errors.</FieldDescription>
</Field>";

    private const string FileCode =
@"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel For=""picture"">Picture</FieldLabel>
    <Input Id=""picture"" Type=""file"" />
    <FieldDescription>Select a picture to upload.</FieldDescription>
</Field>";

    private const string InlineCode =
@"<Field Class=""max-w-xs w-full"" Horizontal=""true"">
    <Input Type=""search"" Placeholder=""Search..."" />
    <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Default"">Search</Button>
</Field>";

    private const string GridCode =
@"<FieldGroup Class=""grid w-full max-w-sm grid-cols-2 gap-4"">
    <Field>
        <FieldLabel For=""first-name"">First Name</FieldLabel>
        <Input Id=""first-name"" Type=""text"" Placeholder=""Jordan"" />
    </Field>
    <Field>
        <FieldLabel For=""last-name"">Last Name</FieldLabel>
        <Input Id=""last-name"" Type=""text"" Placeholder=""Lee"" />
    </Field>
</FieldGroup>";

    private const string RequiredCode =
@"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel For=""input-required"" RequiredIndicator=""true"">Required Field</FieldLabel>
    <Input Id=""input-required"" Placeholder=""This field is required"" Required=""true"" />
    <FieldDescription>This field must be filled out.</FieldDescription>
</Field>";

    private const string BadgeCode =
@"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel For=""input-badge"" Class=""flex w-full items-center gap-2"">
        Webhook URL
        <Badge Variant=""BadgeVariant.Secondary"" Class=""ml-auto"">Beta</Badge>
    </FieldLabel>
    <Input Id=""input-badge"" Type=""url"" Placeholder=""https://api.example.com/webhook"" />
</Field>";

    private const string InputGroupSectionCode =
@"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel For=""input-group-url"">Website URL</FieldLabel>
    <InputGroup>
        <InputGroupAddon>https://</InputGroupAddon>
        <InputGroupInput Id=""input-group-url"" Placeholder=""example.com"" />
    </InputGroup>
</Field>";

    private const string ButtonGroupCode =
@"<Field MaxWidth=""MaxWidth.IsXs"">
    <FieldLabel For=""input-button-group"">Search</FieldLabel>
    <ButtonGroup>
        <Input Id=""input-button-group"" Type=""search"" Placeholder=""Type to search..."" />
        <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Outline"">Search</Button>
    </ButtonGroup>
</Field>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnValidSubmit=""HandleValidSubmit"" class=""w-full max-w-sm space-y-4"">
    <DataAnnotationsValidator />
    <FieldGroup>
        <Field>
            <FieldLabel For=""input-form-name"">Name</FieldLabel>
            <Input Id=""input-form-name"" Type=""text"" @bind-Value=""_formModel.Name"" Placeholder=""John Doe"" />
        </Field>
        <Field>
            <FieldLabel For=""input-form-email"">Email</FieldLabel>
            <Input Id=""input-form-email"" Type=""email"" @bind-Value=""_formModel.Email"" Placeholder=""john@example.com"" />
            <FieldDescription>We'll never share your email with anyone.</FieldDescription>
        </Field>
        <Div Class=""grid grid-cols-2 gap-4"">
            <Field>
                <FieldLabel For=""input-form-phone"">Phone</FieldLabel>
                <Input Id=""input-form-phone"" Type=""tel"" Placeholder=""+1 (555) 123-4567"" />
            </Field>
            <Field>
                <FieldLabel For=""input-form-country"">Country</FieldLabel>
                <Select TValue=""string"" SelectedValue=""@(""us"")"">
                    <SelectTrigger Id=""input-form-country""><SelectValue /></SelectTrigger>
                    <SelectContent>
                        <SelectItem TValue=""string"" ItemValue=""@(""us"")"" Text=""United States"" />
                        <SelectItem TValue=""string"" ItemValue=""@(""uk"")"" Text=""United Kingdom"" />
                        <SelectItem TValue=""string"" ItemValue=""@(""ca"")"" Text=""Canada"" />
                    </SelectContent>
                </Select>
            </Field>
        </Div>
        <Field>
            <FieldLabel For=""input-form-address"">Address</FieldLabel>
            <Input Id=""input-form-address"" Type=""text"" Placeholder=""123 Main St"" />
        </Field>
        <Field Horizontal=""true"">
            <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Outline"">Cancel</Button>
            <Button Type=""ButtonType.Submit"">Submit</Button>
        </Field>
    </FieldGroup>
</EditForm>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Field MaxWidth=""MaxWidth.IsXs"">
        <FieldLabel For=""input-rtl-api-key"">مفتاح API</FieldLabel>
        <Input Id=""input-rtl-api-key"" Type=""password"" Placeholder=""sk-..."" />
        <FieldDescription>مفتاح API الخاص بك مشفر ومخزن بأمان.</FieldDescription>
    </Field>
</DirectionProvider>";

    private InputFormModel _formModel = new();
    private string? _formMessage;

    private void HandleValidSubmit()
    {
        _formMessage = $"Form submitted! Name: {_formModel.Name}, Email: {_formModel.Email}";
    }

    private void ResetForm()
    {
        _formModel = new();
        _formMessage = null;
    }

    private sealed class InputFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(50, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 50 characters.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string? Email { get; set; }
    }
}
