@page "/components/cascader"

<PageTitle>Cascader - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
            Description="A shadcn-style cascading dropdown for selecting hierarchical data."
            Code="@BasicCode"
            PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel>Location</FieldLabel>
                <Cascader Options="_locations"
                          Placeholder="Please select"
                          OnChange="OnLocationChanged" />
                <FieldDescription>@LocationSummary</FieldDescription>
            </Field>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Default Value"
                     Description="Seed the selection from a value path."
                     Code="@DefaultValueCode"
                     PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel>Landmark</FieldLabel>
                <Cascader Options="_locations"
                          DefaultValue='new[] { "usa", "new_york", "statue_of_liberty" }'
                          Placeholder="Please select" />
            </Field>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Hover To Expand"
                     Description="Child columns can expand on hover for faster scanning."
                     Code="@HoverCode"
                     PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel>Category</FieldLabel>
                <Cascader Options="_categories"
                          ExpandTrigger="CascaderExpandTrigger.Hover"
                          Placeholder="Select category"
                          TriggerClass="w-full">
                    <OptionTemplate Context="option">
                        <Span Display="Display.InlineFlex" ItemsAlign="Items.Center" Gap="Gap.Is2">
                            @if (option.Value is "electronics" or "computers" or "phones")
                            {
                                <Icon Name="LucideIcon.Smartphone" Class="size-4" aria-hidden="true" />
                            }
                            else if (option.Value is "fashion")
                            {
                                <Icon Name="LucideIcon.Shirt" Class="size-4" aria-hidden="true" />
                            }
                            @option.Label
                        </Span>
                    </OptionTemplate>
                </Cascader>
            </Field>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Disabled Options"
                     Description="Disable specific branches without disabling the whole control."
                     Code="@DisabledOptionsCode"
                     PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel>Restricted location</FieldLabel>
                <Cascader Options="_disabledLocations"
                          Placeholder="Some options disabled" />
            </Field>
        </DemoSection>
    </Section>
</Div>

@code {
