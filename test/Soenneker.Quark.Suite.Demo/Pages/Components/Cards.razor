@page "/cards"

<PageTitle>Card - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Login form with header action, grouped fields, and stacked footer actions."
                         Code="@LoginCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <CardHeader>
                        <CardTitle>Login to your account</CardTitle>
                        <CardDescription>Enter your email below to login to your account</CardDescription>
                        <CardAction>
                            <Button Variant="ButtonVariant.Link">Sign Up</Button>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <form>
                            <Div Class="flex flex-col gap-6">
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Label For="card-email">Email</Label>
                                    <Input Id="card-email" Type="email" Placeholder="m@example.com" required />
                                </Div>
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Div Class="flex items-center">
                                        <Label For="card-password">Password</Label>
                                        <Anchor To="#" Class="ml-auto inline-block text-sm underline-offset-4 hover:underline">Forgot your password?</Anchor>
                                    </Div>
                                    <Input Id="card-password" Type="password" required />
                                </Div>
                            </Div>
                        </form>
                    </CardContent>
                    <CardFooter Class="flex-col gap-2">
                        <Button Width="Width.IsFull">Login</Button>
                        <Button Variant="ButtonVariant.Outline" Width="Width.IsFull">Login with Google</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Form"
                         Description="Project creation card with input and select fields."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <Card Class="w-[350px]">
                    <CardHeader>
                        <CardTitle>Create project</CardTitle>
                        <CardDescription>Deploy your new project in one-click.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <form>
                            <Div Class="grid w-full items-center gap-6">
                                <Div Display="Display.Flex" FlexDirection="FlexDirection.Column" Gap="Gap.Is3">
                                    <Label For="project-name">Name</Label>
                                    <Input Id="project-name" Placeholder="Name of your project" />
                                </Div>
                                <Div Display="Display.Flex" FlexDirection="FlexDirection.Column" Gap="Gap.Is3">
                                    <Label For="project-framework">Framework</Label>
                                    <Select TValue="string">
                                        <SelectTrigger Id="project-framework" Width="Width.IsFull">
                                            <SelectValue Placeholder="Select" />
                                        </SelectTrigger>
                                        <SelectContent ContentPosition="popper">
                                            <SelectItem TValue="string" ItemValue="@("next")" Text="Next.js" />
                                            <SelectItem TValue="string" ItemValue="@("sveltekit")" Text="SvelteKit" />
                                            <SelectItem TValue="string" ItemValue="@("astro")" Text="Astro" />
                                            <SelectItem TValue="string" ItemValue="@("nuxt")" Text="Nuxt.js" />
                                        </SelectContent>
                                    </Select>
                                </Div>
                            </Div>
                        </form>
                    </CardContent>
                    <CardFooter Class="flex justify-between">
                        <Button Variant="ButtonVariant.Outline">Cancel</Button>
                        <Button>Deploy</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>
    </Div>
</Div>

