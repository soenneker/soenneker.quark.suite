@page "/cards"

<PageTitle>Card - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" Class="max-w-4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Account login card with header action, fields, and footer actions."
                         Code="@LoginCode"
                         CodeLanguage="razor">
                <Card Class="w-full max-w-sm">
                    <CardHeader>
                        <CardTitle>Login to your account</CardTitle>
                        <CardDescription>Enter your email below to login to your account.</CardDescription>
                        <CardAction>
                            <Button Variant="ButtonVariant.Link">Sign Up</Button>
                        </CardAction>
                    </CardHeader>
                    <CardBody>
                        <Div Class="flex flex-col gap-6">
                            <Div Class="grid gap-2">
                                <Label For="card-email">Email</Label>
                                <Input Id="card-email" Placeholder="m@example.com" />
                            </Div>
                            <Div Class="grid gap-2">
                                <Div Class="flex items-center">
                                    <Label For="card-password">Password</Label>
                                    <Anchor To="buttons" Class="ml-auto inline-block text-sm underline-offset-4 hover:underline">Forgot your password?</Anchor>
                                </Div>
                                <Input Id="card-password" Type="InputType.Password" />
                            </Div>
                        </Div>
                    </CardBody>
                    <CardFooter Class="flex-col gap-2">
                        <Button Width="Width.IsFull">Login</Button>
                        <Button Variant="ButtonVariant.Outline" Width="Width.IsFull">Login with Google</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Image"
                         Description="Featured cover image with header overlay and actions."
                         Code="@ImageCode"
                         CodeLanguage="razor">
                <Card Class="relative mx-auto w-full max-w-sm pt-0">
                    <Div Class="absolute inset-0 z-30 aspect-video bg-black/35"></Div>
                    <CardImg Top Source="https://picsum.photos/640/360?random=1" alt="Event cover" Class="relative z-20 aspect-video w-full object-cover brightness-60 grayscale dark:brightness-40" />
                    <CardHeader>
                        <CardAction>
                            <Badge Variant="BadgeVariant.Secondary">Featured</Badge>
                        </CardAction>
                        <CardTitle>Design systems meetup</CardTitle>
                        <CardDescription>A practical talk on component APIs, accessibility, and shipping faster.</CardDescription>
                    </CardHeader>
                    <CardFooter>
                        <Button Width="Width.IsFull">View Event</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Card text and actions follow DirectionProvider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Card Class="w-full max-w-sm text-right">
                        <CardHeader>
                            <CardTitle>بطاقة</CardTitle>
                            <CardDescription>وصف قصير بالعربية.</CardDescription>
                        </CardHeader>
                        <CardBody>
                            <Paragraph>محتوى البطاقة يتبع اتجاه النص من اليمين إلى اليسار.</Paragraph>
                        </CardBody>
                        <CardFooter>
                            <Button Width="Width.IsFull">إجراء</Button>
                        </CardFooter>
                    </Card>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Full form and legacy header patterns beyond the reference sections above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Default and compact card spacing for different densities."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Div Class="grid gap-4 md:grid-cols-2">
                    <Card Class="mx-auto w-full max-w-sm">
                        <CardHeader>
                            <CardTitle>Default Card</CardTitle>
                            <CardDescription>Uses the default spacing for the standard card surface.</CardDescription>
                        </CardHeader>
                        <CardBody>
                            <Paragraph>The default size is better for forms, settings panels, and richer content.</Paragraph>
                        </CardBody>
                        <CardFooter>
                            <Button Variant="ButtonVariant.Outline" Width="Width.IsFull">Action</Button>
                        </CardFooter>
                    </Card>
                    <Card Size="CardSize.Sm" Class="mx-auto w-full max-w-sm">
                        <CardHeader>
                            <CardTitle>Small Card</CardTitle>
                            <CardDescription>The small size uses more compact vertical spacing.</CardDescription>
                        </CardHeader>
                        <CardBody>
                            <Paragraph>This variant is useful for denser dashboards and summary surfaces.</Paragraph>
                        </CardBody>
                        <CardFooter>
                            <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" Width="Width.IsFull">Action</Button>
                        </CardFooter>
                    </Card>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Legacy Header and Footer"
                         Description="String header slot with title and text in the body."
                         Code="@LegacyCode"
                         CodeLanguage="razor">
                <Card>
                    <CardHeader>Featured</CardHeader>
                    <CardBody>
                        <CardTitle>Header + footer</CardTitle>
                        <CardText>
                            Add headers and footers to structure content.
                        </CardText>
                    </CardBody>
                    <CardFooter>
                        <Small TextColor="TextColor.MutedForeground">Updated moments ago</Small>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>
    </Div>
</Div>

