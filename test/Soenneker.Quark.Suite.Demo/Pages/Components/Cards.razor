@page "/cards"

<PageTitle>Card - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Login form with header action, grouped fields, and stacked footer actions."
                         Code="@LoginCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <CardHeader>
                        <CardTitle>Login to your account</CardTitle>
                        <CardDescription>Enter your email below to login to your account</CardDescription>
                        <CardAction>
                            <Button Variant="ButtonVariant.Link">Sign Up</Button>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <form>
                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap='Gap.Token("6")'>
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Label For="card-email">Email</Label>
                                    <Input Id="card-email" Type="email" Placeholder="m@example.com" required />
                                </Div>
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Div Display="Display.Flex" ItemsAlign="Items.Center">
                                        <Label For="card-password">Password</Label>
                                        <Anchor To="#" Class="ml-auto inline-block text-sm underline-offset-4 hover:underline">Forgot your password?</Anchor>
                                    </Div>
                                    <Input Id="card-password" Type="password" required />
                                </Div>
                            </Div>
                        </form>
                    </CardContent>
                    <CardFooter FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                        <Button Width="Width.IsFull">Login</Button>
                        <Button Variant="ButtonVariant.Outline" Width="Width.IsFull">Login with Google</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section><Section Space="Space.Y.Is4">
            <DemoSection Title="Image"
                         Description="Use the small card size for denser layouts."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Card Size="CardSize.Sm" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <CardHeader>
                        <CardTitle>Notifications</CardTitle>
                        <CardDescription>Manage your notification preferences.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                            You can configure delivery channels, project subscriptions, and quiet hours.
                        </Paragraph>
                    </CardContent>
                    <CardFooter>
                        <Button Size="ButtonSize.Sm">Save preferences</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Project creation card with input and select fields."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <Card Width='Width.Token("350px")'>
                    <CardHeader>
                        <CardTitle>Create project</CardTitle>
                        <CardDescription>Deploy your new project in one-click.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <form>
                            <Div Display="Display.Grid" Width="Width.IsFull" ItemsAlign="Items.Center" Gap='Gap.Token("6")'>
                                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is3">
                                    <Label For="project-name">Name</Label>
                                    <Input Id="project-name" Placeholder="Name of your project" />
                                </Div>
                                <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is3">
                                    <Label For="project-framework">Framework</Label>
                                    <Select TValue="string">
                                        <SelectTrigger Id="project-framework" Width="Width.IsFull">
                                            <SelectValue Placeholder="Select" />
                                        </SelectTrigger>
                                        <SelectContent ContentPosition="SelectPosition.Popper">
                                            <SelectItem TValue="string" ItemValue="@("next")" Text="Next.js" />
                                            <SelectItem TValue="string" ItemValue="@("sveltekit")" Text="SvelteKit" />
                                            <SelectItem TValue="string" ItemValue="@("astro")" Text="Astro" />
                                            <SelectItem TValue="string" ItemValue="@("nuxt")" Text="Nuxt.js" />
                                        </SelectContent>
                                    </Select>
                                </Div>
                            </Div>
                        </form>
                    </CardContent>
                    <CardFooter Justify="Justify.Between">
                        <Button Variant="ButtonVariant.Outline">Cancel</Button>
                        <Button>Deploy</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Cards can start with an image and keep the media clipped to the card radius."
                         Code="@ImageCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <Image Source="https://images.unsplash.com/photo-1518005020951-eccb494ad742?w=800&amp;dpr=2&amp;q=80"
                           Alt="Geometric architecture"
                           Width="Width.IsFull"
                           Class="aspect-video object-cover" />
                    <CardHeader>
                        <CardTitle>Modern architecture</CardTitle>
                        <CardDescription>Sharp lines, quiet color, and a strong visual anchor.</CardDescription>
                    </CardHeader>
                </Card>
            </DemoSection>
        </Section>
    </Div>
</Div>

