@page "/cards"

<PageTitle>Card - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" Class="max-w-4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Use width utilities to keep cards compact or let them stretch for denser content."
                        Code="@(@"<Div Class=""grid gap-4 md:grid-cols-2"">
    <Card Class=""max-w-sm""><CardBody><CardTitle>Compact</CardTitle></CardBody></Card>
    <Card><CardBody><CardTitle>Default width</CardTitle></CardBody></Card>
</Div>")">
                <Div Class="grid gap-4 md:grid-cols-2">
                    <Card Class="max-w-sm">
                        <CardBody>
                            <CardTitle>Compact card</CardTitle>
                            <CardText>Keep summary cards narrow when they need to share space with sibling cards.</CardText>
                        </CardBody>
                    </Card>
                    <Card>
                        <CardBody>
                            <CardTitle>Default width</CardTitle>
                            <CardText>Let cards grow when they hold forms, metrics, or longer supporting copy.</CardText>
                        </CardBody>
                    </Card>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Image" Description="Use CardImg with Top to place an image above the body."
                        Code="@(@"<Card>
    <CardImg Top Source=""image.jpg"" alt=""Alt""/>
    <CardBody>
        <CardTitle>Title</CardTitle>
        <CardSubtitle>Subtitle</CardSubtitle>
        <CardText>Description.</CardText>
        <Button Variant=""ButtonVariant.Default"">Action</Button>
    </CardBody>
</Card>")">
                <Card>
                    <CardImg Top Source="https://picsum.photos/640/360?random=1" alt="Random"/>
                    <CardBody>
                        <CardTitle>Card with image</CardTitle>
                        <CardSubtitle>A minimal subtitle</CardSubtitle>
                        <CardText>
                            Clean card using Quark components with Tailwind styling.
                        </CardText>
                        <Button Variant="ButtonVariant.Default">Action</Button>
                    </CardBody>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Header and Footer" Description="CardHeader and CardFooter structure content with clear sections."
                        Code="@(@"<Card>
    <CardHeader>Featured</CardHeader>
    <CardBody>
        <CardTitle>Title</CardTitle>
        <CardText>Content.</CardText>
    </CardBody>
    <CardFooter>
        <Small TextColor=""TextColor.MutedForeground"">Footer</Small>
    </CardFooter>
</Card>")">
                <Card>
                    <CardHeader>Featured</CardHeader>
                    <CardBody>
                        <CardTitle>Header + footer</CardTitle>
                        <CardText>
                            Add headers and footers to structure content.
                        </CardText>
                    </CardBody>
                    <CardFooter>
                        <Small TextColor="TextColor.MutedForeground">Updated moments ago</Small>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Simple Layout" Description="A minimal card body works well for compact summaries and side-panel content."
                        Code="@(@"<Card>
    <CardBody>
        <CardTitle>Simple</CardTitle>
        <CardText>Content.</CardText>
    </CardBody>
    <CardImg Bottom Source=""image.jpg"" alt=""Alt""/>
</Card>")">
                <Card>
                    <CardBody>
                        <CardTitle>Simple</CardTitle>
                        <CardText>
                            Use cards for grouping content in a container.
                        </CardText>
                    </CardBody>
                    <CardImg Bottom Source="https://picsum.photos/640/360?random=2" alt="Random"/>
                </Card>
            </DemoSection>
        </Section>
    </Div>
</Div>
