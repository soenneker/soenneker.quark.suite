@page "/cards"

<PageTitle>Card - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays a card with header, content, and footer."
                         Code="@LoginCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <CardHeader>
                        <CardTitle>Login to your account</CardTitle>
                        <CardDescription>Enter your email below to login to your account</CardDescription>
                        <CardAction>
                            <Button Variant="ButtonVariant.Link">Sign Up</Button>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <form>
                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap='Gap.Token("6")'>
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Label For="card-email">Email</Label>
                                    <Input Id="card-email" Type="email" Placeholder="m@example.com" required />
                                </Div>
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Div Display="Display.Flex" ItemsAlign="Items.Center">
                                        <Label For="card-password">Password</Label>
                                        <Anchor To="#" Class="ml-auto inline-block text-sm underline-offset-4 hover:underline">Forgot your password?</Anchor>
                                    </Div>
                                    <Input Id="card-password" Type="password" required />
                                </Div>
                            </Div>
                        </form>
                    </CardContent>
                    <CardFooter FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                        <Button Width="Width.IsFull">Login</Button>
                        <Button Variant="ButtonVariant.Outline" Width="Width.IsFull">Login with Google</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section><Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Use the size=&quot;sm&quot; prop to set the size of the card to small. The small size variant uses smaller spacing."
                         Code="@SizeCode"
                         CodeLanguage="razor">
                <Card Size="CardSize.Sm" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <CardHeader>
                        <CardTitle>Small Card</CardTitle>
                        <CardDescription>This card uses the small size variant.</CardDescription>
                    </CardHeader>
                    <CardContent>
                        <Paragraph Margin="Margin.Is0">
                            The card component supports a size prop that can be set to "sm" for a more compact appearance.
                        </Paragraph>
                    </CardContent>
                    <CardFooter>
                        <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm" Width="Width.IsFull">Action</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Image"
                         Description="Add an image before the card header to create a card with an image."
                         Code="@ImageCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <Image Source="https://images.unsplash.com/photo-1518005020951-eccb494ad742?w=800&amp;dpr=2&amp;q=80"
                           Alt="Event cover"
                           Width="Width.IsFull"
                           Class="aspect-video object-cover" />
                    <CardHeader>
                        <Badge Variant="BadgeVariant.Secondary">Featured</Badge>
                        <CardTitle>Design systems meetup</CardTitle>
                        <CardDescription>A practical talk on component APIs, accessibility, and shipping faster.</CardDescription>
                    </CardHeader>
                    <CardFooter>
                        <Button Width="Width.IsFull">View Event</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <Card Width="Width.IsFull" MaxWidth="MaxWidth.IsSm" dir="rtl">
                    <CardHeader>
                        <CardTitle>تسجيل الدخول إلى حسابك</CardTitle>
                        <CardDescription>أدخل بريدك الإلكتروني أدناه لتسجيل الدخول إلى حسابك</CardDescription>
                        <CardAction>
                            <Button Variant="ButtonVariant.Link">إنشاء حساب</Button>
                        </CardAction>
                    </CardHeader>
                    <CardContent>
                        <form>
                            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap='Gap.Token("6")'>
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Label For="card-email-rtl">البريد الإلكتروني</Label>
                                    <Input Id="card-email-rtl" Type="email" Placeholder="m@example.com" required />
                                </Div>
                                <Div Display="Display.Grid" Gap="Gap.Is2">
                                    <Div Display="Display.Flex" ItemsAlign="Items.Center">
                                        <Label For="card-password-rtl">كلمة المرور</Label>
                                        <Anchor To="#" Class="mr-auto inline-block text-sm underline-offset-4 hover:underline">نسيت كلمة المرور؟</Anchor>
                                    </Div>
                                    <Input Id="card-password-rtl" Type="password" required />
                                </Div>
                            </Div>
                        </form>
                    </CardContent>
                    <CardFooter FlexDirection="FlexDirection.Col" Gap="Gap.Is2">
                        <Button Width="Width.IsFull">تسجيل الدخول</Button>
                        <Button Variant="ButtonVariant.Outline" Width="Width.IsFull">تسجيل الدخول باستخدام Google</Button>
                    </CardFooter>
                </Card>
            </DemoSection>
        </Section>
    </Div>
</Div>

