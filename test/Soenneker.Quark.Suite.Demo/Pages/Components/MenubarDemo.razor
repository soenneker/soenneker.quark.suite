@page "/menubar"

<PageTitle>Menubar - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Multi-menu menubar with shortcuts, submenus, checkbox items, and radio items."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar>
                        <MenubarMenu>
                            <MenubarTrigger>File</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem>
                                    New Tab
                                    <MenubarShortcut>Cmd+T</MenubarShortcut>
                                </MenubarItem>
                                <MenubarItem>
                                    New Window
                                    <MenubarShortcut>Cmd+N</MenubarShortcut>
                                </MenubarItem>
                                <MenubarItem Disabled="true">New Incognito Window</MenubarItem>
                                <MenubarSeparator />
                                <MenubarSub>
                                    <MenubarSubTrigger>Share</MenubarSubTrigger>
                                    <MenubarSubContent>
                                        <MenubarItem>Email link</MenubarItem>
                                        <MenubarItem>Messages</MenubarItem>
                                        <MenubarItem>Notes</MenubarItem>
                                    </MenubarSubContent>
                                </MenubarSub>
                                <MenubarSeparator />
                                <MenubarItem>
                                    Print...
                                    <MenubarShortcut>Cmd+P</MenubarShortcut>
                                </MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                        <MenubarMenu>
                            <MenubarTrigger>Edit</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem>
                                    Undo
                                    <MenubarShortcut>Cmd+Z</MenubarShortcut>
                                </MenubarItem>
                                <MenubarItem>
                                    Redo
                                    <MenubarShortcut>Shift+Cmd+Z</MenubarShortcut>
                                </MenubarItem>
                                <MenubarSeparator />
                                <MenubarSub>
                                    <MenubarSubTrigger>Find</MenubarSubTrigger>
                                    <MenubarSubContent>
                                        <MenubarItem>Search the web</MenubarItem>
                                        <MenubarSeparator />
                                        <MenubarItem>Find...</MenubarItem>
                                        <MenubarItem>Find Next</MenubarItem>
                                        <MenubarItem>Find Previous</MenubarItem>
                                    </MenubarSubContent>
                                </MenubarSub>
                                <MenubarSeparator />
                                <MenubarItem>Cut</MenubarItem>
                                <MenubarItem>Copy</MenubarItem>
                                <MenubarItem>Paste</MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                        <MenubarMenu>
                            <MenubarTrigger>View</MenubarTrigger>
                            <MenubarContent>
                                <MenubarCheckboxItem>Always Show Bookmarks Bar</MenubarCheckboxItem>
                                <MenubarCheckboxItem Checked="true">Always Show Full URLs</MenubarCheckboxItem>
                                <MenubarSeparator />
                                <MenubarItem Inset="true">
                                    Reload
                                    <MenubarShortcut>Cmd+R</MenubarShortcut>
                                </MenubarItem>
                                <MenubarItem Disabled="true" Inset="true">
                                    Force Reload
                                    <MenubarShortcut>Shift+Cmd+R</MenubarShortcut>
                                </MenubarItem>
                                <MenubarSeparator />
                                <MenubarItem Inset="true">Toggle Fullscreen</MenubarItem>
                                <MenubarSeparator />
                                <MenubarItem Inset="true">Hide Sidebar</MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                        <MenubarMenu>
                            <MenubarTrigger>Profiles</MenubarTrigger>
                            <MenubarContent>
                                <MenubarRadioGroup>
                                    <MenubarRadioItem>Andy</MenubarRadioItem>
                                    <MenubarRadioItem Selected="true">Benoit</MenubarRadioItem>
                                    <MenubarRadioItem>Luis</MenubarRadioItem>
                                </MenubarRadioGroup>
                                <MenubarSeparator />
                                <MenubarItem Inset="true">Edit...</MenubarItem>
                                <MenubarSeparator />
                                <MenubarItem Inset="true">Add Profile...</MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Focused radio, checkbox, submenu, icon, and RTL variants beyond the lead shadcn-equivalent menubar.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio"
                         Description="Use radio groups for mutually exclusive choices."
                         Code="@RadioCode"
                         CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>Profiles</MenubarTrigger>
                            <MenubarContent>
                                <MenubarRadioGroup>
                                    <MenubarRadioItem>Andy</MenubarRadioItem>
                                    <MenubarRadioItem Selected="true">Benoit</MenubarRadioItem>
                                    <MenubarRadioItem>Luis</MenubarRadioItem>
                                </MenubarRadioGroup>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkbox"
                         Description="Use checkbox items for toggleable menubar settings."
                         Code="@CheckboxCode"
                         CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>View</MenubarTrigger>
                            <MenubarContent>
                                <MenubarCheckboxItem>Always Show Bookmarks Bar</MenubarCheckboxItem>
                                <MenubarCheckboxItem Checked="true">Always Show Full URLs</MenubarCheckboxItem>
                                <MenubarSeparator />
                                <MenubarItem Inset="true">Reload</MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu"
                         Description="Use nested content for secondary actions."
                         Code="@SubmenuCode"
                         CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>File</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem>
                                    New Tab
                                    <MenubarShortcut>Ctrl+T</MenubarShortcut>
                                </MenubarItem>
                                <MenubarSeparator />
                                <MenubarSub>
                                    <MenubarSubTrigger>Share</MenubarSubTrigger>
                                    <MenubarSubContent>
                                        <MenubarItem>Email link</MenubarItem>
                                        <MenubarItem>Messages</MenubarItem>
                                        <MenubarItem>Notes</MenubarItem>
                                    </MenubarSubContent>
                                </MenubarSub>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icons"
                         Description="Icons can be embedded to add stronger visual hierarchy."
                         Code="@IconsCode"
                         CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>Workspace</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem>
                                    <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                                        <Icon Name="LucideIcon.FolderOpen" />
                                        Open project
                                    </Div>
                                </MenubarItem>
                                <MenubarItem>
                                    <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                                        <Icon Name="LucideIcon.Users" />
                                        Invite teammates
                                    </Div>
                                </MenubarItem>
                                <MenubarItem>
                                    <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                                        <Icon Name="LucideIcon.Settings" />
                                        Settings
                                    </Div>
                                </MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Menus and nested content anchor correctly in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div class="rounded-xl border border-border p-4 overflow-x-auto text-right">
                        <Menubar Class="w-max">
                            <MenubarMenu>
                                <MenubarTrigger>ملف</MenubarTrigger>
                                <MenubarContent>
                                    <MenubarItem>علامة تبويب جديدة</MenubarItem>
                                    <MenubarSeparator />
                                    <MenubarSub>
                                        <MenubarSubTrigger>مشاركة</MenubarSubTrigger>
                                        <MenubarSubContent>
                                            <MenubarItem>رابط بالبريد</MenubarItem>
                                            <MenubarItem>رسائل</MenubarItem>
                                        </MenubarSubContent>
                                    </MenubarSub>
                                </MenubarContent>
                            </MenubarMenu>
                        </Menubar>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

