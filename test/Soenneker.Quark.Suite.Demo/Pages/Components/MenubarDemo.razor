@page "/menubar"

<PageTitle>Menubar - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkbox"
                         Description="Checkbox items are useful for feature toggles and persistent workspace settings."
                         Code="@BasicCode">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>View</MenubarTrigger>
                            <MenubarContent>
                                <MenubarCheckboxItem>Always Show Bookmarks Bar</MenubarCheckboxItem>
                                <MenubarCheckboxItem Checked="true">Always Show Full URLs</MenubarCheckboxItem>
                                <MenubarSeparator />
                                <MenubarItem Inset="true">Reload</MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio"
                         Description="Radio groups work well for mutually exclusive menu choices such as profiles or themes.">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>Profiles</MenubarTrigger>
                            <MenubarContent>
                                <MenubarRadioGroup>
                                    <MenubarRadioItem>Andy</MenubarRadioItem>
                                    <MenubarRadioItem Selected="true">Benoit</MenubarRadioItem>
                                    <MenubarRadioItem>Luis</MenubarRadioItem>
                                </MenubarRadioGroup>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu"
                         Description="Nested menus keep secondary actions available without overcrowding the first level.">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>File</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem>New Tab<MenubarShortcut>Ctrl+T</MenubarShortcut></MenubarItem>
                                <MenubarSeparator />
                                <MenubarSub>
                                    <MenubarSubTrigger>Share</MenubarSubTrigger>
                                    <MenubarSubContent>
                                        <MenubarItem>Email link</MenubarItem>
                                        <MenubarItem>Messages</MenubarItem>
                                        <MenubarItem>Notes</MenubarItem>
                                    </MenubarSubContent>
                                </MenubarSub>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Icons"
                         Description="Icons can be embedded inside item content to give menu actions more visual hierarchy.">
                <Div Class="rounded-xl border border-border p-4 overflow-x-auto">
                    <Menubar Class="w-max">
                        <MenubarMenu>
                            <MenubarTrigger>Workspace</MenubarTrigger>
                            <MenubarContent>
                                <MenubarItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.FolderOpen" />Open project</Div></MenubarItem>
                                <MenubarItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.Users" />Invite teammates</Div></MenubarItem>
                                <MenubarItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.Settings" />Settings</Div></MenubarItem>
                            </MenubarContent>
                        </MenubarMenu>
                    </Menubar>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Menubar>
    <MenubarMenu>
        <MenubarTrigger>File</MenubarTrigger>
        <MenubarContent>
            <MenubarItem>New Tab <MenubarShortcut>Ctrl+T</MenubarShortcut></MenubarItem>
            <MenubarSeparator />
            <MenubarSub>
                <MenubarSubTrigger>Share</MenubarSubTrigger>
                <MenubarSubContent>
                    <MenubarItem>Email link</MenubarItem>
                </MenubarSubContent>
            </MenubarSub>
        </MenubarContent>
    </MenubarMenu>
</Menubar>";
}
