@page "/sliders"
@using System.Globalization
@using System.Linq
@using Soenneker.Bradix

<PageTitle>Sliders - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="An input where the user selects a value from within a given range."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div data-testid="slider-demo-primary" Width="Width.IsFull">
                    <Slider Min="0"
                            Max="100"
                            Step="1"
                            SliderValue="@_demoValue"
                            SliderValueChanged="HandleDemoValueChanged"
                            Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Range"
                         Description="@($"Two-thumb range. Current: {RangeMin} - {RangeMax}.")"
                         Code="@RangeCode"
                         CodeLanguage="razor">
                <Slider Min="0"
                        Max="100"
                        Step="5"
                        Values="@_rangeValues"
                        ValuesChanged="HandleRangeValuesChanged"
                        Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Multiple Thumbs"
                         Description="@($"Several thumbs on one track. Values: {string.Join(", ", _multipleValues.Select(v => v.ToString(CultureInfo.InvariantCulture)))}.")"
                         Code="@MultipleCode"
                         CodeLanguage="razor">
                <Slider Min="0"
                        Max="100"
                        Step="10"
                        Values="@_multipleValues"
                        ValuesChanged="HandleMultipleValuesChanged"
                        Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="@($"Vertical sliders. Left: {_verticalLeft}, right: {_verticalRight}.")"
                         Code="@VerticalCode"
                         CodeLanguage="razor">
                <Div Margin="Margin.Auto.OnX" Display="Display.Flex" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" ItemsAlign="Items.Center" Justify="Justify.Center" Gap='Gap.Token("6")'>
                    <Slider Min="0"
                            Max="100"
                            Step="1"
                            SliderValue="@_verticalLeft"
                            SliderValueChanged="HandleVerticalLeftChanged"
                            Orientation="Orientation.Vertical"
                            Height='Height.Token("40")' />
                    <Slider Min="0"
                            Max="100"
                            Step="1"
                            SliderValue="@_verticalRight"
                            SliderValueChanged="HandleVerticalRightChanged"
                            Orientation="Orientation.Vertical"
                            Height='Height.Token("40")' />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Controlled"
                         Description="@TemperatureDescription"
                         Code="@ControlledCode"
                         CodeLanguage="razor">
                <Div Margin="Margin.Auto.OnX" Display="Display.Grid" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" Gap="Gap.Is3">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Justify="Justify.Between" Gap="Gap.Is2">
                        <Label For="slider-demo-temperature">Temperature</Label>
                        <Span TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">@TemperatureText</Span>
                    </Div>
                    <Slider Id="slider-demo-temperature"
                            Min="0"
                            Max="1"
                            Step="0.1"
                            Values="@_temperatureValues"
                            ValuesChanged="HandleTemperatureValuesChanged"
                            Width="Width.IsFull" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Set Disabled to prevent interaction."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Slider Min="0"
                        Max="100"
                        Step="1"
                        SliderValue="50"
                        Disabled="true"
                        Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" />
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="@($"Slider direction follows DirectionProvider. Value: {_rtlValue}.")"
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Margin="Margin.Auto.OnX" Width="Width.IsFull" MaxWidth="MaxWidth.IsXs" TextAlign="TextAlign.End">
                        <Slider Min="0"
                                Max="100"
                                Step="1"
                                SliderValue="@_rtlValue"
                                SliderValueChanged="HandleRtlValueChanged"
                                Width="Width.IsFull" />
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

    </Div>
</Div>

@code {
    private double _demoValue = 75;
    private double[] _rangeValues = [25, 50];
    private double[] _multipleValues = [10, 20, 70];
    private double _verticalLeft = 50;
    private double _verticalRight = 25;
    private double[] _temperatureValues = [0.3, 0.7];
    private double _rtlValue = 75;

    private double RangeMin => _rangeValues.Length > 0 ? _rangeValues[0] : 0;
    private double RangeMax => _rangeValues.Length > 1 ? _rangeValues[^1] : RangeMin;

    private string TemperatureText =>
        string.Join(", ", _temperatureValues.Select(v => v.ToString("0.0", CultureInfo.InvariantCulture)));

    private string TemperatureDescription =>
        $"Label + live readout. Values: {TemperatureText}.";

    private const string BasicCode = @"<Slider Min=""0""
        Max=""100""
        Step=""1""
        SliderValue=""@_demoValue""
        SliderValueChanged=""HandleDemoValueChanged""
        Margin=""Margin.Auto.OnX""
        Width=""Width.IsFull""
        MaxWidth=""MaxWidth.IsXs"" />";

    private const string RangeCode =
@"<Slider Min=""0""
        Max=""100""
        Step=""5""
        Values=""@_rangeValues""
        ValuesChanged=""HandleRangeValuesChanged""
        Margin=""Margin.Auto.OnX""
        Width=""Width.IsFull""
        MaxWidth=""MaxWidth.IsXs"" />";

    private const string MultipleCode =
@"<Slider Min=""0""
        Max=""100""
        Step=""10""
        Values=""@_multipleValues""
        ValuesChanged=""HandleMultipleValuesChanged""
        Margin=""Margin.Auto.OnX""
        Width=""Width.IsFull""
        MaxWidth=""MaxWidth.IsXs"" />";

    private const string VerticalCode =
@"<Div Margin=""Margin.Auto.OnX"" Display=""Display.Flex"" Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsXs"" ItemsAlign=""Items.Center"" Justify=""Justify.Center"" Gap='Gap.Token(""6"")'>
    <Slider Min=""0""
            Max=""100""
            Step=""1""
            SliderValue=""@_verticalLeft""
            SliderValueChanged=""HandleVerticalLeftChanged""
            Orientation=""Orientation.Vertical""
            Height='Height.Token(""40"")' />
    <Slider Min=""0""
            Max=""100""
            Step=""1""
            SliderValue=""@_verticalRight""
            SliderValueChanged=""HandleVerticalRightChanged""
            Orientation=""Orientation.Vertical""
            Height='Height.Token(""40"")' />
</Div>";

    private const string ControlledCode =
@"<Div Margin=""Margin.Auto.OnX"" Display=""Display.Grid"" Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsXs"" Gap=""Gap.Is3"">
    <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Justify=""Justify.Between"" Gap=""Gap.Is2"">
        <Label For=""slider-demo-temperature"">Temperature</Label>
        <Span TextSize=""TextSize.Sm"" TextColor=""TextColor.MutedForeground"">@TemperatureText</Span>
    </Div>
    <Slider Id=""slider-demo-temperature""
            Min=""0""
            Max=""1""
            Step=""0.1""
            Values=""@_temperatureValues""
            ValuesChanged=""HandleTemperatureValuesChanged""
            Width=""Width.IsFull"" />
</Div>";

    private const string DisabledCode =
@"<Slider Min=""0""
        Max=""100""
        Step=""1""
        SliderValue=""50""
        Disabled=""true""
        Margin=""Margin.Auto.OnX""
        Width=""Width.IsFull""
        MaxWidth=""MaxWidth.IsXs"" />";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Margin=""Margin.Auto.OnX"" Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsXs"" TextAlign=""TextAlign.End"">
        <Slider Min=""0""
                Max=""100""
                Step=""1""
                SliderValue=""@_rtlValue""
                SliderValueChanged=""HandleRtlValueChanged""
                Width=""Width.IsFull"" />
    </Div>
</DirectionProvider>";

    private Task HandleDemoValueChanged(double value)
    {
        _demoValue = value;
        return Task.CompletedTask;
    }

    private Task HandleRangeValuesChanged(double[] values)
    {
        _rangeValues = values;
        return Task.CompletedTask;
    }

    private Task HandleMultipleValuesChanged(double[] values)
    {
        _multipleValues = values;
        return Task.CompletedTask;
    }

    private Task HandleVerticalLeftChanged(double value)
    {
        _verticalLeft = value;
        return Task.CompletedTask;
    }

    private Task HandleVerticalRightChanged(double value)
    {
        _verticalRight = value;
        return Task.CompletedTask;
    }

    private Task HandleTemperatureValuesChanged(double[] values)
    {
        _temperatureValues = values;
        return Task.CompletedTask;
    }

    private Task HandleRtlValueChanged(double value)
    {
        _rtlValue = value;
        return Task.CompletedTask;
    }

}
