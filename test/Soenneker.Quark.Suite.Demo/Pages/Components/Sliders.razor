@page "/sliders"

<PageTitle>Sliders - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="@($"Current value: {_demoValue}.")"
                         Code="@DemoCode">
                <Div Class="mx-auto w-full max-w-xs">
                    <Slider Min="0" Max="100" SliderValue="@_demoValue" SliderValueChanged="HandleDemoValueChanged" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Range"
                         Description="@($"Range: {RangeMin} - {RangeMax}.")"
                         Code="@RangeCode">
                <Div Class="mx-auto w-full max-w-xs">
                    <Slider Min="0" Max="100" Step="5" Values="@_rangeValues" ValuesChanged="HandleRangeValuesChanged" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Multiple Thumbs"
                         Description="@($"Values: {string.Join(", ", _multipleValues)}.")"
                         Code="@MultipleCode">
                <Div Class="mx-auto w-full max-w-xs">
                    <Slider Min="0" Max="100" Step="5" Values="@_multipleValues" ValuesChanged="HandleMultipleValuesChanged" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical"
                         Description="@($"Current value: {_verticalValue}.")"
                         Code="@VerticalCode">
                <Div Class="flex h-64 items-center justify-center">
                    <Slider Min="0" Max="100" SliderValue="@_verticalValue" SliderValueChanged="HandleVerticalValueChanged" Orientation="vertical" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Controlled"
                         Description="@($"Current value: {_controlledValue}.")"
                         Code="@ControlledCode">
                <Div Space="Space.Y.Is4">
                    <Div Class="mx-auto w-full max-w-xs">
                        <Slider Min="0" Max="100" SliderValue="@_controlledValue" SliderValueChanged="HandleControlledValueChanged" />
                    </Div>
                    <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                        <Button Size="ButtonSize.Sm" OnClick="@(() => SetControlledValue(0))">0</Button>
                        <Button Size="ButtonSize.Sm" Variant="ButtonVariant.Outline" OnClick="@(() => SetControlledValue(50))">50</Button>
                        <Button Size="ButtonSize.Sm" OnClick="@(() => SetControlledValue(100))">100</Button>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Use the disabled prop to prevent interaction."
                         Code="@DisabledCode">
                <Div Class="mx-auto w-full max-w-xs">
                    <Slider Min="0" Max="100" SliderValue="50" Disabled="true" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="@($"Current value: {_rtlValue}.")"
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <Div class="mx-auto w-full max-w-xs text-right">
                        <Slider Min="0" Max="100" SliderValue="@_rtlValue" SliderValueChanged="HandleRtlValueChanged" />
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show additional slider variants beyond the core shadcn coverage above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Step"
                         Description="@($"Step 5; current value: {_stepValue}.")"
                         Code="@StepCode">
                <Div Class="mx-auto w-full max-w-xs">
                    <Slider Min="0" Max="100" Step="5" SliderValue="@_stepValue" SliderValueChanged="HandleStepValueChanged" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sizes"
                         Description="Small, default, and large sizing options."
                         Code="@SizesCode">
                <Div Space="Space.Y.Is4">
                    <Slider Min="0" Max="100" SliderValue="@_smallValue" Size="Size.Small" SliderValueChanged="HandleSmallValueChanged" />
                    <Slider Min="0" Max="100" SliderValue="@_defaultValue" Size="Size.Default" SliderValueChanged="HandleDefaultValueChanged" />
                    <Slider Min="0" Max="100" SliderValue="@_largeValue" Size="Size.Large" SliderValueChanged="HandleLargeValueChanged" />
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private double _demoValue = 33;
    private double[] _rangeValues = [20, 80];
    private double[] _multipleValues = [15, 45, 85];
    private double _verticalValue = 60;
    private double _controlledValue = 25;
    private double _rtlValue = 40;
    private double _stepValue = 30;
    private double _smallValue = 35;
    private double _defaultValue = 60;
    private double _largeValue = 80;

    private double RangeMin => _rangeValues.Length > 0 ? _rangeValues[0] : 0;
    private double RangeMax => _rangeValues.Length > 1 ? _rangeValues[^1] : RangeMin;

    private const string DemoCode = @"<Slider Min=""0"" Max=""100"" SliderValue=""33"" />";

    private const string RangeCode =
@"<Slider Min=""0"" Max=""100"" Step=""5"" Values=""@_rangeValues"" ValuesChanged=""HandleRangeValuesChanged"" />";

    private const string MultipleCode =
@"<Slider Min=""0"" Max=""100"" Step=""5"" Values=""@_multipleValues"" ValuesChanged=""HandleMultipleValuesChanged"" />";

    private const string VerticalCode =
@"<Slider Min=""0"" Max=""100"" SliderValue=""@_verticalValue"" SliderValueChanged=""HandleVerticalValueChanged"" Orientation=""vertical"" />";

    private const string ControlledCode =
@"<Slider Min=""0"" Max=""100"" SliderValue=""@_controlledValue"" SliderValueChanged=""HandleControlledValueChanged"" />";

    private const string DisabledCode =
@"<Slider Min=""0"" Max=""100"" SliderValue=""50"" Disabled=""true"" />";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Slider Min=""0"" Max=""100"" SliderValue=""@_rtlValue"" SliderValueChanged=""HandleRtlValueChanged"" />
</DirectionProvider>";

    private const string StepCode =
@"<Slider Min=""0"" Max=""100"" Step=""5"" SliderValue=""@_stepValue"" SliderValueChanged=""HandleStepValueChanged"" />";

    private const string SizesCode =
@"<Slider Min=""0"" Max=""100"" SliderValue=""@_smallValue"" Size=""Size.Small"" SliderValueChanged=""HandleSmallValueChanged"" />
<Slider Min=""0"" Max=""100"" SliderValue=""@_defaultValue"" Size=""Size.Default"" SliderValueChanged=""HandleDefaultValueChanged"" />
<Slider Min=""0"" Max=""100"" SliderValue=""@_largeValue"" Size=""Size.Large"" SliderValueChanged=""HandleLargeValueChanged"" />";

    private Task HandleDemoValueChanged(double value)
    {
        _demoValue = value;
        return Task.CompletedTask;
    }

    private Task HandleRangeValuesChanged(double[] values)
    {
        _rangeValues = values;
        return Task.CompletedTask;
    }

    private Task HandleMultipleValuesChanged(double[] values)
    {
        _multipleValues = values;
        return Task.CompletedTask;
    }

    private Task HandleVerticalValueChanged(double value)
    {
        _verticalValue = value;
        return Task.CompletedTask;
    }

    private Task HandleControlledValueChanged(double value)
    {
        _controlledValue = value;
        return Task.CompletedTask;
    }

    private Task HandleRtlValueChanged(double value)
    {
        _rtlValue = value;
        return Task.CompletedTask;
    }

    private Task HandleStepValueChanged(double value)
    {
        _stepValue = value;
        return Task.CompletedTask;
    }

    private Task HandleSmallValueChanged(double value)
    {
        _smallValue = value;
        return Task.CompletedTask;
    }

    private Task HandleDefaultValueChanged(double value)
    {
        _defaultValue = value;
        return Task.CompletedTask;
    }

    private Task HandleLargeValueChanged(double value)
    {
        _largeValue = value;
        return Task.CompletedTask;
    }

    private Task SetControlledValue(double value)
    {
        _controlledValue = value;
        return Task.CompletedTask;
    }
}
