@page "/components/copyable-text"

<PageTitle>Copyable Text - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <DemoSection
        Description="Reveal a copy action on hover or keyboard focus without sacrificing text truncation."
        Code="@BasicCode"
        CodeLanguage="razor"
        PreviewClass="preview flex min-h-[14rem] w-full items-center justify-center p-10"
        PreviewInnerClass="demo-section-preview-inner flex w-full items-center justify-center">
        <div class="w-64 rounded-lg border p-4">
            <CopyableText Text="@SampleText" Class="w-full" />
        </div>
    </DemoSection>
</Div>

@code {
    private const string SampleText = "a-very-long-resource-identifier-that-will-be-truncated-but-copied-in-full";

    private const string BasicCode =
@"<div class=""w-64"">
    <CopyableText Text=""@SampleText"" Class=""w-full"" />
</div>";
}
