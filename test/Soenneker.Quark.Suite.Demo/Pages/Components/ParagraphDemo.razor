@page "/paragraph-demo"

<PageTitle>Paragraph - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Demo" Code="@(@"<Paragraph>Basic paragraph content.</Paragraph>
<Paragraph TextColor=""TextColor.Primary"">Styled paragraph.</Paragraph>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Paragraph>Creates HTML &lt;p&gt; elements for text blocks.</Paragraph>
                <Paragraph>Each Paragraph creates a separate element with proper spacing.</Paragraph>
            </Div>
        </DemoSection>

        <DemoSection Title="Colors" Description="TextColor for semantic paragraph styling." Code="@(@"<Paragraph TextColor=""TextColor.Primary"">Primary</Paragraph>
<Paragraph TextColor=""TextColor.Accent"">Success</Paragraph>
<Paragraph TextColor=""TextColor.MutedForeground"">Warning</Paragraph>
<Paragraph TextColor=""TextColor.Destructive"">Danger</Paragraph>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Paragraph TextColor="TextColor.Primary">Primary</Paragraph>
                <Paragraph TextColor="TextColor.Accent">Success</Paragraph>
                <Paragraph TextColor="TextColor.MutedForeground">Warning</Paragraph>
                <Paragraph TextColor="TextColor.Destructive">Danger</Paragraph>
            </Div>
        </DemoSection>

        <DemoSection Title="Alignment" Description="TextAlign.Start, Center, End." Code="@(@"<Paragraph TextAlign=""TextAlign.Start"" Class=""block"">Start aligned</Paragraph>
<Paragraph TextAlign=""TextAlign.Center"" Class=""block"">Center aligned</Paragraph>
<Paragraph TextAlign=""TextAlign.End"" Class=""block"">End aligned</Paragraph>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Paragraph TextAlign="TextAlign.Start" Display="Display.Block">Start aligned</Paragraph>
                <Paragraph TextAlign="TextAlign.Center" Display="Display.Block">Center aligned</Paragraph>
                <Paragraph TextAlign="TextAlign.End" Display="Display.Block">End aligned</Paragraph>
            </Div>
        </DemoSection>

        <DemoSection Title="Interactive" Description="Paragraph with onclick and event handling." Code="@(@"<Paragraph TextColor=""TextColor.Primary"" Class=""cursor-pointer hover:underline"" @@onclick=""HandleClick"" Title=""Click me!"">
    Clickable paragraph.
</Paragraph>")"
CodeLanguage="razor">
            <Paragraph TextColor="TextColor.Primary" Class="cursor-pointer hover:underline" @onclick="HandleClick" Title="Click me!">
                Clickable paragraph.
            </Paragraph>
            <Paragraph TextColor="TextColor.MutedForeground">Click count: @_clickCount</Paragraph>
        </DemoSection>
    </Div>
</Div>

@code {
    private int _clickCount;

    private void HandleClick(MouseEventArgs args)
    {
        _clickCount++;
        StateHasChanged();
    }
}
