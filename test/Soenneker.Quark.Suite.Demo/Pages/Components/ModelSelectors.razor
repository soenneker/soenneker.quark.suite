@page "/model-selectors"

<PageTitle>Model Selector - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
                     Description="Dropdown for selecting AI models."
                     Code="@BasicCode"
                     CodeLanguage="razor">
            <Div Display="Display.Flex" FlexDirection="FlexDirection.Col" Gap="Gap.Is3" MaxWidth="MaxWidth.IsSm">
                <ModelSelector @bind-Value="_model" />
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Selected: @_model</Paragraph>
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private string? _model = "gpt-4";

    private const string BasicCode =
@"<ModelSelector @bind-Value=""_model"" />";
}
