@page "/suggestions"

<PageTitle>Suggestions - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection Title="Demo"
                     Description="Clickable prompt suggestion chips that guide users toward common queries."
                     Code="@BasicCode"
                     CodeLanguage="razor">
            <Div Space="Space.Y.Is3">
                <Suggestions OnSelect="Select">
                    <SuggestionList Class="max-w-lg justify-center">
                        <Suggestion Value="What is AI?">What is AI?</Suggestion>
                        <Suggestion Value="Teach me Engineering from scratch">Teach me Engineering from scratch</Suggestion>
                        <Suggestion Value="Design a weekly workout plan">Design a weekly workout plan</Suggestion>
                        <Suggestion Value="Places to visit in France">Places to visit in France</Suggestion>
                        <Suggestion Value="How to learn React?">How to learn React?</Suggestion>
                    </SuggestionList>
                </Suggestions>
                @if (!string.IsNullOrWhiteSpace(_selected))
                {
                    <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Selected: @_selected</Paragraph>
                }
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private string? _selected;

    private void Select(string value)
    {
        _selected = value;
    }

    private const string BasicCode =
@"<Suggestions>
    <SuggestionList Class=""max-w-lg justify-center"">
        <Suggestion>What is AI?</Suggestion>
        <Suggestion>Teach me Engineering from scratch</Suggestion>
        <Suggestion>Design a weekly workout plan</Suggestion>
        <Suggestion>Places to visit in France</Suggestion>
        <Suggestion>How to learn React?</Suggestion>
    </SuggestionList>
</Suggestions>";
}
