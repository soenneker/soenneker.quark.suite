@page "/components/feedback-bar"

<PageTitle>Feedback Bar - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <DemoSection Code="@DefaultCode" CodeLanguage="razor">
        <FeedbackBar>
            <FeedbackBarContent>
                <FeedbackBarPrompt>
                    <Icon Name="LucideIcon.Info" Size="Quark.Size.Is4" Shrink="Quark.Shrink.Is0" />
                    <FeedbackBarLabel>Is this response helpful?</FeedbackBarLabel>
                </FeedbackBarPrompt>
                <FeedbackBarActions>
                    <FeedbackBarAction AsChild="true">
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="cursor-pointer rounded-full bg-transparent transition-all hover:bg-border! active:scale-97" aria-label="Helpful">
                            <Icon Name="LucideIcon.ThumbsUp" Size="Quark.Size.Is4" />
                        </Button>
                    </FeedbackBarAction>
                    <FeedbackBarAction AsChild="true">
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="cursor-pointer rounded-full bg-transparent transition-all hover:bg-border! active:scale-97" aria-label="Not helpful">
                            <Icon Name="LucideIcon.ThumbsDown" Size="Quark.Size.Is4" />
                        </Button>
                    </FeedbackBarAction>
                </FeedbackBarActions>
            </FeedbackBarContent>
            <FeedbackBarClose>
                <Button Type="ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="cursor-pointer rounded-full bg-transparent transition-all hover:bg-border! active:scale-97" aria-label="Close">
                    <Icon Name="LucideIcon.X" Size="Quark.Size.Is4" />
                </Button>
            </FeedbackBarClose>
        </FeedbackBar>
    </DemoSection>

    <DemoSection Title="Compact" Code="@CompactCode" CodeLanguage="razor">
        <FeedbackBar Class="w-auto">
            <FeedbackBarContent>
                <FeedbackBarActions>
                    <FeedbackBarAction AsChild="true" Tooltip="Helpful">
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="cursor-pointer rounded-full bg-transparent transition-all hover:bg-border! active:scale-97" aria-label="Helpful">
                            <Icon Name="LucideIcon.ThumbsUp" Size="Quark.Size.Is4" />
                        </Button>
                    </FeedbackBarAction>
                    <FeedbackBarAction AsChild="true" Tooltip="Not helpful">
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="cursor-pointer rounded-full bg-transparent transition-all hover:bg-border! active:scale-97" aria-label="Not helpful">
                            <Icon Name="LucideIcon.ThumbsDown" Size="Quark.Size.Is4" />
                        </Button>
                    </FeedbackBarAction>
                </FeedbackBarActions>
            </FeedbackBarContent>
            <FeedbackBarClose Tooltip="Close">
                <Button Type="ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="cursor-pointer rounded-full bg-transparent transition-all hover:bg-border! active:scale-97" aria-label="Close">
                    <Icon Name="LucideIcon.X" Size="Quark.Size.Is4" />
                </Button>
            </FeedbackBarClose>
        </FeedbackBar>
    </DemoSection>
</Div>

@code {
    private const string DefaultCode =
@"<FeedbackBar>
    <FeedbackBarContent>
        <FeedbackBarPrompt>
            <Icon Name=""LucideIcon.Info"" />
            <FeedbackBarLabel>Is this response helpful?</FeedbackBarLabel>
        </FeedbackBarPrompt>
        <FeedbackBarActions>
            <FeedbackBarAction AsChild=""true"">
                <Button aria-label=""Helpful"">
                    <Icon Name=""LucideIcon.ThumbsUp"" />
                </Button>
            </FeedbackBarAction>
        </FeedbackBarActions>
    </FeedbackBarContent>
</FeedbackBar>";

    private const string CompactCode =
@"<FeedbackBar Class=""w-auto"">
    <FeedbackBarContent>
        <FeedbackBarActions>
            <FeedbackBarAction AsChild=""true"" Tooltip=""Helpful"">
                <Button aria-label=""Helpful"">
                    <Icon Name=""LucideIcon.ThumbsUp"" />
                </Button>
            </FeedbackBarAction>
        </FeedbackBarActions>
    </FeedbackBarContent>
    <FeedbackBarClose Tooltip=""Close"">
        <Button aria-label=""Close"">
            <Icon Name=""LucideIcon.X"" />
        </Button>
    </FeedbackBarClose>
</FeedbackBar>";
}
