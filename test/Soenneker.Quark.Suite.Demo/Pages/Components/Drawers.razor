                            Rounded=""Rounded.Full""
                            Disabled=""@(_goal <= 200)""
                            OnClick=""DecreaseGoal"">
                        <Icon Name=""LucideIcon.Minus"" />
                        <Span ScreenReader=""ScreenReader.Only"">Decrease</Span>
                    </Button>
                    <Div Flex=""Flex.Is1"" TextAlign=""TextAlign.Center"">
                        <Div TextSize='TextSize.Token(""7xl"")' FontWeight=""FontWeight.Bold"" Tracking=""Tracking.Tighter"">@_goal</Div>
                        <Div TextSize='TextSize.Token(""[0.70rem]"")' TextTransform=""TextTransform.Uppercase"" TextColor=""TextColor.MutedForeground"">Calories/day</Div>
                    </Div>
                    <Button Variant=""ButtonVariant.Outline""
                            ButtonSize=""ButtonSize.Icon""
                            Size=""Quark.Size.Is8""
                            Shrink=""Shrink.Is0""
                            Rounded=""Rounded.Full""
                            Disabled=""@(_goal >= 400)""
                            OnClick=""IncreaseGoal"">
                        <Icon Name=""LucideIcon.Plus"" />
                        <Span ScreenReader=""ScreenReader.Only"">Increase</Span>
                    </Button>
                </Div>
                <Div Margin=""Margin.Is3.FromTop"" Display=""Display.Flex"" Height='Height.Token(""[120px]"")' ItemsAlign=""Items.End"" Gap=""Gap.Is2"">
                    @foreach (var value in _drawerGoals)
                    {
                        <Div MinWidth=""MinWidth.Is0"" Flex=""Flex.Is1""
                             Style=""@($""height: {Math.Max(16, value / 4)}px; background-color: var(--series-1);"")""></Div>
                    }
                </Div>
            </Div>
            <DrawerFooter>
                <Button>Submit</Button>
                <DrawerClose AsChild=""true"">
                    <Button Type=""@ButtonType.Button"" Variant=""ButtonVariant.Outline"">Cancel</Button>
                </DrawerClose>
            </DrawerFooter>
        </Div>
    </DrawerContent>
</Drawer>";

    private const string ScrollableCode =
@"<Drawer Direction=""right"">
    <DrawerTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Scrollable Content</Button>
    </DrawerTrigger>
    <DrawerContent>
        <DrawerHeader>
            <DrawerTitle>Move Goal</DrawerTitle>
            <DrawerDescription>Set your daily activity goal.</DrawerDescription>
        </DrawerHeader>
        <Div OverflowY=""Overflow.Y.Auto"" Padding=""Padding.OnX.Is4"">
            @for (var i = 0; i < 10; i++)
            {
                <Paragraph Margin=""Margin.FromBottom.Is4"" Leading=""Leading.Normal"">
                    @DrawerLorem
                </Paragraph>
            }
        </Div>
        <DrawerFooter>
            <Button>Submit</Button>
            <DrawerClose AsChild=""true"">
                <Button Type=""@ButtonType.Button"" Variant=""ButtonVariant.Outline"">Cancel</Button>
            </DrawerClose>
        </DrawerFooter>
    </DrawerContent>
</Drawer>";

    private const string SidesCode =
@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is2"">
    @foreach (var side in _drawerSides)
    {
        <Div>
            <Drawer @key=""side"" Direction=""@side.Value"">
                <DrawerTrigger AsChild=""true"">
                    <Button Variant=""ButtonVariant.Outline"" TextTransform=""TextTransform.Capitalize"">@side</Button>
                </DrawerTrigger>
                <DrawerContent Class=""data-[vaul-drawer-direction=bottom]:max-h-[50vh] data-[vaul-drawer-direction=top]:max-h-[50vh]"">
                    <DrawerHeader>
                        <DrawerTitle>Move Goal</DrawerTitle>
                        <DrawerDescription>Set your daily activity goal.</DrawerDescription>
                    </DrawerHeader>
                    <Div OverflowY=""Overflow.Y.Auto"" Padding=""Padding.OnX.Is4"">
                        @for (var i = 0; i < 10; i++)
                        {
                            <Paragraph Margin=""Margin.FromBottom.Is4"" Leading=""Leading.Normal"">
                                @DrawerLorem
                            </Paragraph>
                        }
                    </Div>
                    <DrawerFooter>
                        <Button>Submit</Button>
                        <DrawerClose AsChild=""true"">
                            <Button Type=""@ButtonType.Button"" Variant=""ButtonVariant.Outline"">Cancel</Button>
                        </DrawerClose>
                    </DrawerFooter>
                </DrawerContent>
            </Drawer>
        </Div>
    }
</Div>";

    private const string ResponsiveDialogCode =
@"<Div Display=""Display.None.OnMd.Block"">
    <Dialog>
        <DialogTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">Edit Profile</Button>
        </DialogTrigger>
        <DialogContent MaxWidth='MaxWidth.Token(""[425px]"")'>
            <DialogHeader>
                <DialogTitle>Edit profile</DialogTitle>
                <DialogDescription>
                    Make changes to your profile here. Click save when you're done.
                </DialogDescription>
            </DialogHeader>
            <Div Display=""Display.Grid"" ItemsAlign=""Items.Start"" Gap=""Gap.Is6"">
                <Div Display=""Display.Grid"" Gap=""Gap.Is3"">
                    <Label For=""drawer-dialog-email"">Email</Label>
                    <Input Type=""email"" Id=""drawer-dialog-email"" Value=""shadcn@example.com"" />
                </Div>
                <Div Display=""Display.Grid"" Gap=""Gap.Is3"">
                    <Label For=""drawer-dialog-username"">Username</Label>
                    <Input Id=""drawer-dialog-username"" Value=""@(""@shadcn"")"" />
                </Div>
                <Button Type=""@ButtonType.Submit"">Save changes</Button>
            </Div>
        </DialogContent>
    </Dialog>
</Div>
<Div Display=""Display.Block.OnMd.None"">
    <Drawer>
        <DrawerTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">Edit Profile</Button>
        </DrawerTrigger>
        <DrawerContent>
            <Div Margin=""Margin.Auto.OnX"" Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsSm"">
                <DrawerHeader TextAlign=""TextAlign.Left"">
                    <DrawerTitle>Edit profile</DrawerTitle>
                    <DrawerDescription>
                        Make changes to your profile here. Click save when you're done.
                    </DrawerDescription>
                </DrawerHeader>
                <Div Display=""Display.Grid"" ItemsAlign=""Items.Start"" Gap=""Gap.Is6"" Padding=""Padding.OnX.Is4"">
                    <Div Display=""Display.Grid"" Gap=""Gap.Is3"">
                        <Label For=""drawer-mobile-email"">Email</Label>
                        <Input Type=""email"" Id=""drawer-mobile-email"" Value=""shadcn@example.com"" />
                    </Div>
                    <Div Display=""Display.Grid"" Gap=""Gap.Is3"">
                        <Label For=""drawer-mobile-username"">Username</Label>
                        <Input Id=""drawer-mobile-username"" Value=""@(""@shadcn"")"" />
                    </Div>
                    <Button Type=""@ButtonType.Submit"">Save changes</Button>
                </Div>
                <DrawerFooter Padding=""Padding.FromTop.Is2"">
                    <DrawerClose AsChild=""true"">
                        <Button Type=""@ButtonType.Button"" Variant=""ButtonVariant.Outline"">Cancel</Button>
                    </DrawerClose>
                </DrawerFooter>
            </Div>
        </DrawerContent>
    </Drawer>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Width=""Width.IsFull"" TextAlign=""TextAlign.End"">
        <Drawer Direction=""left"">
            <DrawerTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">افتح الدرج</Button>
            </DrawerTrigger>
            <DrawerContent>
                <Div class=""mx-auto"" Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsSm"">
                    <DrawerHeader>
                        <DrawerTitle>تعديل الملف الشخصي</DrawerTitle>
                        <DrawerDescription>
                            حدّث معلوماتك ثم احفظ التغييرات.
                        </DrawerDescription>
                    </DrawerHeader>
                    <DrawerFooter>
                        <Button>حفظ</Button>
                        <DrawerClose AsChild=""true"">
                            <Button Variant=""ButtonVariant.Outline"">إلغاء</Button>
                        </DrawerClose>
                    </DrawerFooter>
                </Div>
            </DrawerContent>
        </Drawer>
    </Div>
</DirectionProvider>";
}
