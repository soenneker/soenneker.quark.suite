    private const string ResponsiveDialogCode =
@"<Div class=""hidden md:block"">
    <Dialog>
        <DialogTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">Edit profile</Button>
        </DialogTrigger>
        <DialogContent class=""sm:max-w-[425px]"">
            <DialogHeader>
