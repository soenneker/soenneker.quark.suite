@page "/drawers"

<PageTitle>Drawer - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Default drawer with header, stepped content, and footer actions."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Drawer>
                    <DrawerTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Drawer</Button>
                    </DrawerTrigger>
                    <DrawerContent>
                        <Div Class="mx-auto" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                            <DrawerHeader>
                                <DrawerTitle>Move Goal</DrawerTitle>
                                <DrawerDescription>Set your daily activity goal.</DrawerDescription>
                            </DrawerHeader>
                            <Div Class="p-4 pb-0">
                                <Div Class="flex items-center justify-center gap-2">
                                    <Button Variant="ButtonVariant.Outline"
                                            Size="ButtonSize.Icon"
                                            Class="h-8 w-8 shrink-0 rounded-full"
                                            Disabled="@(_goal <= 200)"
                                            OnClick="DecreaseGoal">
                                        <Icon Name="LucideIcon.Minus" />
                                        <Span ScreenReader="ScreenReader.Only">Decrease</Span>
                                    </Button>
                                    <Div Class="flex-1 text-center">
                                        <Div Class="text-7xl font-bold tracking-tighter">@_goal</Div>
                                        <Div Class="text-[0.70rem] uppercase text-muted-foreground">Calories/day</Div>
                                    </Div>
                                    <Button Variant="ButtonVariant.Outline"
                                            Size="ButtonSize.Icon"
                                            Class="h-8 w-8 shrink-0 rounded-full"
                                            Disabled="@(_goal >= 400)"
                                            OnClick="IncreaseGoal">
                                        <Icon Name="LucideIcon.Plus" />
                                        <Span ScreenReader="ScreenReader.Only">Increase</Span>
                                    </Button>
                                </Div>
                                <Div Class="mt-3 flex h-[120px] items-end gap-2">
                                    @foreach (var value in _drawerGoals)
                                    {
                                        <Div Class="min-w-0 flex-1"
                                             Style="@($"height: {Math.Max(16, value / 4)}px; background-color: var(--chart-1);")"></Div>
                                    }
                                </Div>
                            </Div>
                            <DrawerFooter>
                                <Button>Submit</Button>
                                <DrawerClose AsChild="true">
                                    <Button Variant="ButtonVariant.Outline">Cancel</Button>
                                </DrawerClose>
                            </DrawerFooter>
                        </Div>
                    </DrawerContent>
                </Drawer>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable Content"
                         Description="Dialog on larger breakpoints, drawer on small screens."
                         Code="@ResponsiveDialogCode"
                         CodeLanguage="razor">
                <Div class="hidden md:block">
                    <Dialog>
                        <DialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Edit profile</Button>
                        </DialogTrigger>
                        <DialogContent class="sm:max-w-[425px]">
                            <DialogHeader>
                                <DialogTitle>Edit profile</DialogTitle>
                                <DialogDescription>
                                    Make changes to your profile here. Click save when you're done.
                                </DialogDescription>
                            </DialogHeader>
                            <Div Display="Display.Grid" Gap="Gap.Is4" Padding="Padding.Is4.OnY">
                                <Div Display="Display.Grid" Gap="Gap.Is3">
                                    <Label For="drawer-dialog-name">Name</Label>
                                    <Input Id="drawer-dialog-name" Value="Pedro Duarte" />
                                </Div>
                                <Div Display="Display.Grid" Gap="Gap.Is3">
                                    <Label For="drawer-dialog-username">Username</Label>
                                    <Input Id="drawer-dialog-username" Value="@("@peduarte")" />
                                </Div>
                            </Div>
                            <DialogFooter>
                                <Button>Save changes</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </Div>
                <Div class="md:hidden">
                    <Drawer>
                        <DrawerTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Edit profile</Button>
                        </DrawerTrigger>
                        <DrawerContent>
                            <Div class="mx-auto" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                                <DrawerHeader>
                                    <DrawerTitle>Edit profile</DrawerTitle>
                                    <DrawerDescription>
                                        Make changes to your profile here. Click save when you're done.
                                    </DrawerDescription>
                                </DrawerHeader>
                                <Div Display="Display.Grid" Gap="Gap.Is4" Padding='Padding.Is4.OnX.Is4.OnY'>
                                    <Div Display="Display.Grid" Gap="Gap.Is3">
                                        <Label For="drawer-mobile-name">Name</Label>
                                        <Input Id="drawer-mobile-name" Value="Pedro Duarte" />
                                    </Div>
                                    <Div Display="Display.Grid" Gap="Gap.Is3">
                                        <Label For="drawer-mobile-username">Username</Label>
                                        <Input Id="drawer-mobile-username" Value="@("@peduarte")" />
                                    </Div>
                                </Div>
                                <DrawerFooter>
                                    <Button>Save changes</Button>
                                    <DrawerClose AsChild="true">
                                        <Button Variant="ButtonVariant.Outline">Cancel</Button>
                                    </DrawerClose>
                                </DrawerFooter>
                            </Div>
                        </DrawerContent>
                    </Drawer>
                </Div>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="Sides"
                         Description="Long body scrolls inside the drawer panel."
                         Code="@ScrollableCode"
                         CodeLanguage="razor">
                <Drawer>
                    <DrawerTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Scrollable Content</Button>
                    </DrawerTrigger>
                    <DrawerContent Side="Side.Right">
                        <DrawerHeader>
                            <DrawerTitle>Move Goal</DrawerTitle>
                            <DrawerDescription>Set your daily activity goal.</DrawerDescription>
                        </DrawerHeader>
                        <Div Class="overflow-y-auto px-4">
                            @for (var i = 0; i < 10; i++)
                            {
                                <Paragraph Class="mb-4 leading-normal">
                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                </Paragraph>
                            }
                        </Div>
                        <DrawerFooter>
                            <Button>Submit</Button>
                            <DrawerClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Cancel</Button>
                            </DrawerClose>
                        </DrawerFooter>
                    </DrawerContent>
                </Drawer>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Responsive Dialog"
                         Description="Drawers can open from any edge via `Side`."
                         Code="@SidesCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                    @foreach (var side in _drawerSides)
                    {
                        <Div>
                            <Drawer @key="side">
                                <DrawerTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline" Class="capitalize">@side</Button>
                                </DrawerTrigger>
                                <DrawerContent Side="@side"
                                               Class="data-[side=bottom]:max-h-[50vh] data-[side=top]:max-h-[50vh]">
                                    <DrawerHeader>
                                        <DrawerTitle>Move Goal</DrawerTitle>
                                        <DrawerDescription>Set your daily activity goal.</DrawerDescription>
                                    </DrawerHeader>
                                    <Div Class="overflow-y-auto px-4">
                                        @for (var i = 0; i < 10; i++)
                                        {
                                            <Paragraph Class="mb-4 leading-normal">
                                                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                            </Paragraph>
                                        }
                                    </Div>
                                    <DrawerFooter>
                                        <Button>Submit</Button>
                                        <DrawerClose AsChild="true">
                                            <Button Variant="ButtonVariant.Outline">Cancel</Button>
                                        </DrawerClose>
                                    </DrawerFooter>
                                </DrawerContent>
                            </Drawer>
                        </Div>
                    }
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Drawer chrome and slide direction in RTL layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Drawer>
                            <DrawerTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">افتح الدرج</Button>
                            </DrawerTrigger>
                            <DrawerContent Side="Side.Left">
                                <Div class="mx-auto" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                                    <DrawerHeader>
                                        <DrawerTitle>تعديل الملف الشخصي</DrawerTitle>
                                        <DrawerDescription>
                                            حدّث معلوماتك ثم احفظ التغييرات.
                                        </DrawerDescription>
                                    </DrawerHeader>
                                    <DrawerFooter>
                                        <Button>حفظ</Button>
                                        <DrawerClose AsChild="true">
                                            <Button Variant="ButtonVariant.Outline">إلغاء</Button>
                                        </DrawerClose>
                                    </DrawerFooter>
                                </Div>
                            </DrawerContent>
                        </Drawer>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private int _goal = 350;
    private readonly int[] _drawerGoals = [400, 300, 200, 300, 200, 278, 189, 239, 300, 200, 278, 189, 349];
    private readonly Side[] _drawerSides =
    [
        Side.Top,
        Side.Right,
        Side.Bottom,
        Side.Left
    ];

    private Task DecreaseGoal()
    {
        _goal = Math.Max(200, _goal - 10);
        return Task.CompletedTask;
    }

    private Task IncreaseGoal()
    {
        _goal = Math.Min(400, _goal + 10);
        return Task.CompletedTask;
    }

