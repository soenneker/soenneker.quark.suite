@page "/hover-cards"

<PageTitle>Hover Cards - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Preview account details behind a lightweight trigger."
                         Code="@HoverCardCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <HoverCard OpenDelay="150" CloseDelay="150">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Link">nextjs</Button>
                        </HoverCardTrigger>

                        <HoverCardContent Class="w-80">
                            <Div Class="flex items-start gap-4">
                                <Avatar>
                                    <AvatarImage Src="https://github.com/vercel.png" Alt="Vercel" />
                                    <AvatarFallback>VC</AvatarFallback>
                                </Avatar>

                                <Div Space="Space.Y.Is1">
                                    <Paragraph class="text-sm font-semibold">nextjs</Paragraph>
                                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">The React framework for production applications.</Paragraph>
                                    <Paragraph class="text-xs text-muted-foreground">Joined December 2021</Paragraph>
                                </Div>
                            </Div>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Extended positioning and right-to-left cases beyond the reference demo above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sides"
                         Description="Change side and alignment to match where the preview should appear."
                         Code="@SidesCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-56 flex-wrap items-center justify-center gap-8">
                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Top start</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="top" Align="start">
                            <Paragraph TextSize="TextSize.Sm">Preview content aligned to the trigger start edge.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Bottom center</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="bottom" Align="center">
                            <Paragraph TextSize="TextSize.Sm">The default placement sits below the trigger.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Right end</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="right" Align="end">
                            <Paragraph TextSize="TextSize.Sm">Use end alignment when a preview needs to anchor to the far edge.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Hover cards should remain readable and aligned in right-to-left contexts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex min-h-48 items-center justify-center text-right">
                        <HoverCard OpenDelay="150" CloseDelay="150">
                            <HoverCardTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Link">واجهة المستخدم</Button>
                            </HoverCardTrigger>

                            <HoverCardContent Class="w-80">
                                <Div Class="flex items-start gap-4">
                                    <Avatar>
                                        <AvatarFallback>QM</AvatarFallback>
                                    </Avatar>

                                    <Div Space="Space.Y.Is1">
                                        <Paragraph class="text-sm font-semibold">واجهة المستخدم</Paragraph>
                                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">نظام مكونات مرن لبناء تطبيقات الإنتاج بسرعة.</Paragraph>
                                        <Paragraph class="text-xs text-muted-foreground">تم التحديث هذا الأسبوع</Paragraph>
                                    </Div>
                                </Div>
                            </HoverCardContent>
                        </HoverCard>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                <code>HoverCardContent</code> exposes a non-modal dialog (<code>role="dialog"</code>, <code>aria-modal="false"</code>).
                When the preview has no visible heading, set the inherited <code>AriaLabel</code> on the content surface.
                With a <code>HoverCardTrigger</code>, content uses the same viewport popper as <code>Popover</code> (flip/clamp, outside dismiss via <code>CloseImmediate</code>).
                Set <code>DisableFloatingPosition</code> to keep the legacy absolute panel under the trigger.
            </Paragraph>
            <DemoSection Title="Accessible name without a heading"
                         Description="Use AriaLabel so the dialog has an accessible name when content is body-only."
                         Code="@AriaLabelCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-32 items-center justify-center">
                    <HoverCard OpenDelay="100" CloseDelay="100">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Preview</Button>
                        </HoverCardTrigger>
                        <HoverCardContent AriaLabel="Account preview" Class="max-w-xs">
                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                                Supplementary text only — the panel name comes from aria-label, not a heading.
                            </Paragraph>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

