@page "/hover-cards"

<PageTitle>Hover Cards - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="For sighted users to preview content available behind a link."
                         Code="@HoverCardCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <HoverCard OpenDelay="10" CloseDelay="100">
                        <HoverCardTrigger Class="!border-transparent !bg-transparent px-0 text-primary shadow-none hover:!bg-transparent hover:underline">Hover Here</HoverCardTrigger>

                        <HoverCardContent Class="flex w-64 flex-col gap-0.5">
                            <Div FontWeight="FontWeight.Semibold">@@nextjs</Div>
                            <Div>The React Framework – created and maintained by @@vercel.</Div>
                            <Div Class="mt-1 text-xs text-muted-foreground">Joined December 2021</Div>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Extended positioning and right-to-left cases beyond the reference demo above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sides"
                         Description="Change side and alignment to match where the preview should appear."
                         Code="@SidesCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-80"
                         CodeLanguage="razor">
                <Div Class="flex min-h-56 flex-wrap items-center justify-center gap-8">
                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger>Top start</HoverCardTrigger>
                        <HoverCardContent Side="Soenneker.Bradix.Side.Top" Align="Alignment.Start">
                            <Paragraph TextSize="TextSize.Sm">Preview content aligned to the trigger start edge.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger>Bottom center</HoverCardTrigger>
                        <HoverCardContent Side="Soenneker.Bradix.Side.Bottom" Align="Alignment.Center">
                            <Paragraph TextSize="TextSize.Sm">The default placement sits below the trigger.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger>Right end</HoverCardTrigger>
                        <HoverCardContent Side="Soenneker.Bradix.Side.Right" Align="Alignment.End">
                            <Paragraph TextSize="TextSize.Sm">Use end alignment when a preview needs to anchor to the far edge.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Hover cards should remain readable and aligned in right-to-left contexts."
                         Code="@RtlCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-[22rem]"
                         PreviewDir="rtl"
                         PreviewLang="ar"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex min-h-48 items-center justify-center text-right">
                        <HoverCard OpenDelay="150" CloseDelay="150">
                            <HoverCardTrigger Class="!border-transparent !bg-transparent px-0 text-primary shadow-none hover:!bg-transparent hover:underline">واجهة المستخدم</HoverCardTrigger>

                            <HoverCardContent Width='Width.Token("80")'>
                                <Div Class="flex items-start gap-4">
                                    <Avatar>
                                        <AvatarFallback>QM</AvatarFallback>
                                    </Avatar>

                                    <Div Space="Space.Y.Is1">
                                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">واجهة المستخدم</Paragraph>
                                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">نظام مكونات مرن لبناء تطبيقات الإنتاج بسرعة.</Paragraph>
                                        <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">تم التحديث هذا الأسبوع</Paragraph>
                                    </Div>
                                </Div>
                            </HoverCardContent>
                        </HoverCard>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Hover Card In Dialog"
                         Description="A hover card opened from within modal dialog content should remain exposed and accessible."
                         Code="@DialogCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-80"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <Dialog>
                        <DialogTrigger>Open hover card dialog</DialogTrigger>

                        <DialogContent Class="sm:max-w-md">
                            <DialogHeader>
                                <DialogTitle>Hover card dialog</DialogTitle>
                                <DialogDescription>
                                    Hover the nested trigger to expose hover card content inside the dialog.
                                </DialogDescription>
                            </DialogHeader>

                            <Div Display="Display.Flex" Justify="Justify.Center">
                                <HoverCard OpenDelay="150" CloseDelay="150">
                                    <HoverCardTrigger AriaLabel="Show nested hover card">Hover for preview</HoverCardTrigger>

                                    <HoverCardContent Width='Width.Token("80")'>
                                        <Div Space="Space.Y.Is1">
                                            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Nested preview</Paragraph>
                                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Hover card content inside dialog</Paragraph>
                                        </Div>
                                    </HoverCardContent>
                                </HoverCard>
                            </Div>
                        </DialogContent>
                    </Dialog>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

