@page "/hover-cards"

<PageTitle>Hover Cards - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Preview account details behind a lightweight trigger."
                         Code="@HoverCardCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <HoverCard OpenDelay="150" CloseDelay="150">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Link">nextjs</Button>
                        </HoverCardTrigger>

                        <HoverCardContent Width='Width.Token("80")'>
                            <Div Class="flex items-start gap-4">
                                <Avatar>
                                    <AvatarImage Src="https://github.com/vercel.png" Alt="Vercel" />
                                    <AvatarFallback>VC</AvatarFallback>
                                </Avatar>

                                <Div Space="Space.Y.Is1">
                                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">nextjs</Paragraph>
                                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">The React framework for production applications.</Paragraph>
                                    <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Joined December 2021</Paragraph>
                                </Div>
                            </Div>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Extended positioning and right-to-left cases beyond the reference demo above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sides"
                         Description="Change side and alignment to match where the preview should appear."
                         Code="@SidesCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-56 flex-wrap items-center justify-center gap-8">
                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Top start</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="top" Align="start">
                            <Paragraph TextSize="TextSize.Sm">Preview content aligned to the trigger start edge.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Bottom center</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="bottom" Align="center">
                            <Paragraph TextSize="TextSize.Sm">The default placement sits below the trigger.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Right end</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="right" Align="end">
                            <Paragraph TextSize="TextSize.Sm">Use end alignment when a preview needs to anchor to the far edge.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Hover cards should remain readable and aligned in right-to-left contexts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex min-h-48 items-center justify-center text-right">
                        <HoverCard OpenDelay="150" CloseDelay="150">
                            <HoverCardTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Link">واجهة المستخدم</Button>
                            </HoverCardTrigger>

                            <HoverCardContent Width='Width.Token("80")'>
                                <Div Class="flex items-start gap-4">
                                    <Avatar>
                                        <AvatarFallback>QM</AvatarFallback>
                                    </Avatar>

                                    <Div Space="Space.Y.Is1">
                                        <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">واجهة المستخدم</Paragraph>
                                        <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">نظام مكونات مرن لبناء تطبيقات الإنتاج بسرعة.</Paragraph>
                                        <Paragraph TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">تم التحديث هذا الأسبوع</Paragraph>
                                    </Div>
                                </Div>
                            </HoverCardContent>
                        </HoverCard>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Hover Card In Dialog"
                         Description="A hover card opened from within modal dialog content should remain exposed and accessible."
                         Code="@DialogCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <Dialog>
                        <DialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Open hover card dialog</Button>
                        </DialogTrigger>

                        <DialogContent Class="sm:max-w-md">
                            <DialogHeader>
                                <DialogTitle>Hover card dialog</DialogTitle>
                                <DialogDescription>
                                    Hover the nested trigger to expose hover card content inside the dialog.
                                </DialogDescription>
                            </DialogHeader>

                            <Div Display="Display.Flex" Justify="Justify.Center">
                                <HoverCard OpenDelay="150" CloseDelay="150">
                                    <HoverCardTrigger AsChild="true">
                                        <Button Variant="ButtonVariant.Outline" AriaLabel="Show nested hover card">Hover for preview</Button>
                                    </HoverCardTrigger>

                                    <HoverCardContent Width='Width.Token("80")'>
                                        <Div Space="Space.Y.Is1">
                                            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Nested preview</Paragraph>
                                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Hover card content inside dialog</Paragraph>
                                        </Div>
                                    </HoverCardContent>
                                </HoverCard>
                            </Div>
                        </DialogContent>
                    </Dialog>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

