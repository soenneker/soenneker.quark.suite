@page "/hovercards"

<PageTitle>Hover Cards - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="For sighted users to preview content available behind a link."
                         Code="@HoverCardCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <HoverCard OpenDelay="10" CloseDelay="100">
                        <HoverCardTrigger AsChild>
                            <Button Variant="ButtonVariant.Link">@@nextjs</Button>
                        </HoverCardTrigger>

                        <HoverCardContent Class="w-80">
                            <Div Class="flex justify-between space-x-4">
                                <Avatar>
                                    <AvatarImage Src="https://github.com/vercel.png" />
                                    <AvatarFallback>VC</AvatarFallback>
                                </Avatar>

                                <Div Class="space-y-1">
                                    <Div Class="text-sm font-semibold">@@nextjs</Div>
                                    <Paragraph TextSize="TextSize.Sm">The React Framework – created and maintained by @@vercel.</Paragraph>
                                    <Div Class="flex items-center pt-2">
                                        <Icon Name="LucideIcon.Calendar" Class="mr-2 h-4 w-4 opacity-70" />
                                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Joined December 2021</Span>
                                    </Div>
                                </Div>
                            </Div>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="Shadcn-aligned Basic example."
                         Code="@HoverCardCode"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <HoverCard OpenDelay="10" CloseDelay="100">
                        <HoverCardTrigger AsChild>
                            <Button Variant="ButtonVariant.Link">@@nextjs</Button>
                        </HoverCardTrigger>

                        <HoverCardContent Class="w-80">
                            <Div Class="flex justify-between space-x-4">
                                <Avatar>
                                    <AvatarImage Src="https://github.com/vercel.png" />
                                    <AvatarFallback>VC</AvatarFallback>
                                </Avatar>

                                <Div Class="space-y-1">
                                    <Div Class="text-sm font-semibold">@@nextjs</Div>
                                    <Paragraph TextSize="TextSize.Sm">The React Framework – created and maintained by @@vercel.</Paragraph>
                                    <Div Class="flex items-center pt-2">
                                        <Icon Name="LucideIcon.Calendar" Class="mr-2 h-4 w-4 opacity-70" />
                                        <Span TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">Joined December 2021</Span>
                                    </Div>
                                </Div>
                            </Div>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sides"
                         Description="Change side and alignment to match where the content should appear."
                         Code="@SidesCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-80"
                         CodeLanguage="razor">
                <Div Class="flex min-h-56 flex-wrap items-center justify-center gap-8">
                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild>
                            <Button Variant="ButtonVariant.Outline">left</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="Side.Left">
                            <Paragraph TextSize="TextSize.Sm">Content shown on the left.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild>
                            <Button Variant="ButtonVariant.Outline">top</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="Side.Top">
                            <Paragraph TextSize="TextSize.Sm">Content shown above.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild>
                            <Button Variant="ButtonVariant.Outline">bottom</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="Side.Bottom">
                            <Paragraph TextSize="TextSize.Sm">Content shown below.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>

                    <HoverCard OpenDelay="100">
                        <HoverCardTrigger AsChild>
                            <Button Variant="ButtonVariant.Outline">right</Button>
                        </HoverCardTrigger>
                        <HoverCardContent Side="Side.Right">
                            <Paragraph TextSize="TextSize.Sm">Content shown on the right.</Paragraph>
                        </HoverCardContent>
                    </HoverCard>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Hover cards should remain readable and aligned in right-to-left contexts."
                         Code="@RtlCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-[22rem]"
                         PreviewDir="rtl"
                         PreviewLang="ar"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Class="flex min-h-48 flex-wrap items-center justify-center gap-8 text-right">
                        <HoverCard OpenDelay="150" CloseDelay="150">
                            <HoverCardTrigger AsChild>
                                <Button Variant="ButtonVariant.Outline">يسار</Button>
                            </HoverCardTrigger>
                            <HoverCardContent Side="Side.Left" Width='Width.Token("80")'>
                                <Paragraph TextSize="TextSize.Sm">المحتوى على اليسار.</Paragraph>
                            </HoverCardContent>
                        </HoverCard>

                        <HoverCard OpenDelay="150" CloseDelay="150">
                            <HoverCardTrigger AsChild>
                                <Button Variant="ButtonVariant.Outline">أعلى</Button>
                            </HoverCardTrigger>
                            <HoverCardContent Side="Side.Top" Width='Width.Token("80")'>
                                <Paragraph TextSize="TextSize.Sm">المحتوى في الأعلى.</Paragraph>
                            </HoverCardContent>
                        </HoverCard>

                        <HoverCard OpenDelay="150" CloseDelay="150">
                            <HoverCardTrigger AsChild>
                                <Button Variant="ButtonVariant.Outline">أسفل</Button>
                            </HoverCardTrigger>
                            <HoverCardContent Side="Side.Bottom" Width='Width.Token("80")'>
                                <Paragraph TextSize="TextSize.Sm">المحتوى في الأسفل.</Paragraph>
                            </HoverCardContent>
                        </HoverCard>

                        <HoverCard OpenDelay="150" CloseDelay="150">
                            <HoverCardTrigger AsChild>
                                <Button Variant="ButtonVariant.Outline">يمين</Button>
                            </HoverCardTrigger>
                            <HoverCardContent Side="Side.Right" Width='Width.Token("80")'>
                                <Paragraph TextSize="TextSize.Sm">المحتوى على اليمين.</Paragraph>
                            </HoverCardContent>
                        </HoverCard>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Hover Card In Dialog"
                         Description="A hover card opened from within modal dialog content should remain exposed and accessible."
                         Code="@DialogCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-80"
                         CodeLanguage="razor">
                <Div Class="flex min-h-48 items-center justify-center">
                    <Dialog>
                        <DialogTrigger>Open hover card dialog</DialogTrigger>

                        <DialogContent Class="sm:max-w-md">
                            <DialogHeader>
                                <DialogTitle>Hover card dialog</DialogTitle>
                                <DialogDescription>
                                    Hover the nested trigger to expose hover card content inside the dialog.
                                </DialogDescription>
                            </DialogHeader>

                            <Div Display="Display.Flex" Justify="Justify.Center">
                                <HoverCard OpenDelay="150" CloseDelay="150">
                                    <HoverCardTrigger AsChild>
                                        <Button AriaLabel="Show nested hover card">Hover for details</Button>
                                    </HoverCardTrigger>

                                    <HoverCardContent Width='Width.Token("80")'>
                                        <Div Space="Space.Y.Is1">
                                            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Nested content</Paragraph>
                                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Hover card content inside dialog</Paragraph>
                                        </Div>
                                    </HoverCardContent>
                                </HoverCard>
                            </Div>
                        </DialogContent>
                    </Dialog>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

