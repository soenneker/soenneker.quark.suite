@page "/dialogs"
@using DialogSize = Soenneker.Quark.DialogSize

<PageTitle>Dialog - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A standard dialog covers the most common confirmation and edit flows."
                         Code="@BasicCode">
                <Button OnClick="@(() => _showBasicDialog = true)">Open dialog</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Large and centered"
                         Description="Scale the dialog up or center it vertically when the content deserves more focus."
                         Code="@LargeCode">
                <Div Class="flex flex-wrap gap-2">
                    <Button Variant="ButtonVariant.Outline" OnClick="@(() => _showLargeDialog = true)">Large dialog</Button>
                    <Button Variant="ButtonVariant.Outline" OnClick="@(() => _showCenteredDialog = true)">Centered dialog</Button>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom close flow"
                         Description="Use footer actions to drive dismissal when you do not want the dialog to close from the backdrop."
                         Code="@StaticCode">
                <Button Variant="ButtonVariant.Outline" OnClick="@(() => _showStaticDialog = true)">Open guarded dialog</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable body"
                         Description="Long content can scroll inside the dialog while keeping the title and footer actions visible."
                         Code="@ScrollableCode">
                <Button Variant="ButtonVariant.Outline" OnClick="@(() => _showScrollableDialog = true)">Open scrollable dialog</Button>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Composable header pieces"
                         Description="DialogTitle and DialogCloseButton can be composed independently when you want more control over the header."
                         Code="@ComposedCode">
                <Button Variant="ButtonVariant.Outline" OnClick="@(() => _showComposedDialog = true)">Open composed dialog</Button>
            </DemoSection>
        </Section>
    </Div>
</Div>

<Dialog @bind-Visible="_showBasicDialog">
    <DialogHeader>
        <DialogTitle Scale="@Scale.Is5">Edit team member</DialogTitle>
        <DialogCloseButton/>
    </DialogHeader>
    <DialogBody>
        <Paragraph>Update the role and contact information for this team member, then save the changes.</Paragraph>
    </DialogBody>
    <DialogFooter>
        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Secondary" OnClick="@(() => _showBasicDialog = false)">Cancel</Button>
        <Button Type="@ButtonType.Button" OnClick="@(() => _showBasicDialog = false)">Save changes</Button>
    </DialogFooter>
</Dialog>

<Dialog @bind-Visible="_showLargeDialog" DialogSize="@DialogSize.Large">
    <DialogHeader>
        <DialogTitle Scale="@Scale.Is4">Invite collaborators</DialogTitle>
        <DialogCloseButton/>
    </DialogHeader>
    <DialogBody>
        <Paragraph>Use a wider dialog when the flow needs richer context or multi-column content.</Paragraph>
        <Div Class="grid gap-4 md:grid-cols-2 mt-4">
            <Div>
                <H5>Workspace access</H5>
                <Paragraph Margin="Margin.Is0">Choose whether invited users can edit settings, deploy changes, or manage billing.</Paragraph>
            </Div>
            <Div>
                <H5>Invite message</H5>
                <Paragraph Margin="Margin.Is0">Add context so collaborators know which project, branch, or milestone they are joining.</Paragraph>
            </Div>
        </Div>
    </DialogBody>
    <DialogFooter>
        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Secondary" OnClick="@(() => _showLargeDialog = false)">Cancel</Button>
        <Button Type="@ButtonType.Button" OnClick="@(() => _showLargeDialog = false)">Send invites</Button>
    </DialogFooter>
</Dialog>

<Dialog @bind-Visible="_showCenteredDialog" Centered="true">
    <DialogHeader>
        <DialogTitle Scale="@Scale.Is5">Publish release</DialogTitle>
        <DialogCloseButton/>
    </DialogHeader>
    <DialogBody>
        <Paragraph>Centered dialogs work well for short, high-importance confirmation steps.</Paragraph>
    </DialogBody>
    <DialogFooter>
        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Secondary" OnClick="@(() => _showCenteredDialog = false)">Not yet</Button>
        <Button Type="@ButtonType.Button" OnClick="@(() => _showCenteredDialog = false)">Publish now</Button>
    </DialogFooter>
</Dialog>

<Dialog @bind-Visible="_showStaticDialog" Static="true">
    <DialogHeader>
        <DialogTitle Scale="@Scale.Is5">Delete environment</DialogTitle>
    </DialogHeader>
    <DialogBody>
        <Paragraph>This dialog ignores backdrop clicks so the user must make an explicit choice before leaving.</Paragraph>
        <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
            Type the environment name in a follow-up step before the destructive action is enabled.
        </Paragraph>
    </DialogBody>
    <DialogFooter>
        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Secondary" OnClick="@(() => _showStaticDialog = false)">Keep environment</Button>
        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Destructive" OnClick="@(() => _showStaticDialog = false)">Delete</Button>
    </DialogFooter>
</Dialog>

<Dialog @bind-Visible="_showScrollableDialog" Scrollable="true">
    <DialogHeader>
        <DialogTitle Scale="@Scale.Is5">Release notes</DialogTitle>
        <DialogCloseButton/>
    </DialogHeader>
    <DialogBody>
        @for (var i = 1; i <= 50; i++)
        {
            <Paragraph>Update @i introduces a focused improvement to the editor, table interactions, and keyboard shortcuts.</Paragraph>
        }
    </DialogBody>
    <DialogFooter>
        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Secondary" OnClick="@(() => _showScrollableDialog = false)">Close</Button>
        <Button Type="@ButtonType.Button" OnClick="@(() => _showScrollableDialog = false)">Acknowledge</Button>
    </DialogFooter>
</Dialog>

<Dialog @bind-Visible="_showComposedDialog" DialogSize="@DialogSize.Large">
    <DialogHeader>
        <DialogTitle Scale="@Scale.Is3">Composable header pieces</DialogTitle>
        <DialogCloseButton/>
    </DialogHeader>
    <DialogBody>
        <Paragraph Margin="Margin.Is0">Compose <Code Inline="true">DialogTitle</Code> and <Code Inline="true">DialogCloseButton</Code> independently when the header needs extra layout freedom.</Paragraph>
        <UnorderedList>
            <UnorderedListItem><Strong>DialogTitle:</Strong> Keep heading scale aligned with the weight of the action.</UnorderedListItem>
            <UnorderedListItem><Strong>DialogCloseButton:</Strong> Drop it where you want a dismiss affordance instead of relying on a monolithic header.</UnorderedListItem>
        </UnorderedList>
    </DialogBody>
    <DialogFooter>
        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Secondary" OnClick="@(() => _showComposedDialog = false)">Close</Button>
        <Button Type="@ButtonType.Button" OnClick="@(() => _showComposedDialog = false)">Got it</Button>
    </DialogFooter>
</Dialog>

@code {
    private bool _showBasicDialog;
    private bool _showLargeDialog;
    private bool _showCenteredDialog;
    private bool _showStaticDialog;
    private bool _showScrollableDialog;
    private bool _showComposedDialog;

    private const string BasicCode =
@"<Button OnClick=""@(() => showDialog = true)"">Open dialog</Button>
<Dialog @bind-Visible=""showDialog"">
    <DialogHeader>
        <DialogTitle>Edit team member</DialogTitle>
        <DialogCloseButton />
    </DialogHeader>
    <DialogBody>
        <Paragraph>Update the role and contact information for this team member.</Paragraph>
    </DialogBody>
    <DialogFooter>
        <Button Variant=""ButtonVariant.Secondary"">Cancel</Button>
        <Button>Save changes</Button>
    </DialogFooter>
</Dialog>";

    private const string LargeCode =
@"<Dialog @bind-Visible=""showLarge"" DialogSize=""DialogSize.Large"">...</Dialog>
<Dialog @bind-Visible=""showCentered"" Centered=""true"">...</Dialog>";

    private const string StaticCode =
@"<Dialog @bind-Visible=""showStatic"" Static=""true"">
    <DialogHeader>
        <DialogTitle>Delete environment</DialogTitle>
    </DialogHeader>
    <DialogBody>
        <Paragraph>This dialog ignores backdrop clicks so the user must choose explicitly.</Paragraph>
    </DialogBody>
    <DialogFooter>
        <Button Variant=""ButtonVariant.Secondary"">Keep environment</Button>
        <Button Variant=""ButtonVariant.Destructive"">Delete</Button>
    </DialogFooter>
</Dialog>";

    private const string ScrollableCode =
@"<Dialog @bind-Visible=""showScrollable"" Scrollable=""true"">
    <DialogHeader>
        <DialogTitle>Release notes</DialogTitle>
        <DialogCloseButton />
    </DialogHeader>
    <DialogBody>
        @for (var i = 1; i <= 50; i++)
        {
            <Paragraph>Update @i introduces a focused improvement...</Paragraph>
        }
    </DialogBody>
    <DialogFooter>
        <Button Variant=""ButtonVariant.Secondary"">Close</Button>
        <Button>Acknowledge</Button>
    </DialogFooter>
</Dialog>";

    private const string ComposedCode =
@"<Dialog @bind-Visible=""showComposed"" DialogSize=""DialogSize.Large"">
    <DialogHeader>
        <DialogTitle Scale=""Scale.Is3"">Composable header pieces</DialogTitle>
        <DialogCloseButton />
    </DialogHeader>
    <DialogBody>...</DialogBody>
</Dialog>";
}