@page "/components/dialog"
@using DialogSize = Soenneker.Quark.DialogSize

<PageTitle>Dialog - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="A window overlaid on either the primary window or another dialog window, rendering the content underneath inert."
                         Code="@BasicCode"
                         CodeLanguage="razor"
                         PreviewClass="@DialogPreviewClass">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Dialog</Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Edit profile</DialogTitle>
                            <DialogDescription>
                                Make changes to your profile here. Click save when you're done.
                            </DialogDescription>
                        </DialogHeader>
                        <FieldGroup Class="gap-5">
                            <Field>
                                <Label For="dialog-name">Name</Label>
                                <Input Id="dialog-name" Value="Pedro Duarte" />
                            </Field>
                            <Field>
                                <Label For="dialog-username">Username</Label>
                                <Input Id="dialog-username" Value="@("@peduarte")" />
                            </Field>
                        </FieldGroup>
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Cancel</Button>
                            </DialogClose>
                            <Button Type="ButtonType.Submit">Save changes</Button>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Close Button"
                         Description="Replace the default close control with your own button."
                         Code="@CustomCloseButtonCode"
                         CodeLanguage="razor"
                         PreviewClass="@DialogPreviewClass">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Share</Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Share link</DialogTitle>
                            <DialogDescription>
                                Anyone who has this link will be able to view this.
                            </DialogDescription>
                        </DialogHeader>
                        <Input Value="https://ui.shadcn.com/docs/installation" />
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Type="ButtonType.Button">Close</Button>
                            </DialogClose>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="No Close Button"
                         Description="Use `showCloseButton={false}` to hide the close button."
                         Code="@NoCloseButtonCode"
                         CodeLanguage="razor"
                         PreviewClass="@DialogPreviewClass">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">No Close Button</Button>
                    </DialogTrigger>
                    <DialogContent ShowCloseButton="false">
                        <DialogHeader>
                            <DialogTitle>No Close Button</DialogTitle>
                            <DialogDescription>
                                This dialog doesn't have a close button in the top-right corner.
                            </DialogDescription>
                        </DialogHeader>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sticky Footer"
                         Description="Keep actions visible while the content scrolls."
                         Code="@StickyFooterCode"
                         CodeLanguage="razor"
                         PreviewClass="@DialogPreviewClass">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Sticky Footer</Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Sticky Footer</DialogTitle>
                            <DialogDescription>
                                This dialog has a sticky footer that stays visible while the content scrolls.
                            </DialogDescription>
                        </DialogHeader>
                        <div class="-mx-4 no-scrollbar max-h-[50vh] overflow-y-auto px-4">
                            @for (var i = 0; i < 10; i++)
                            {
                                <Paragraph class="mb-4 leading-normal">
                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
                                </Paragraph>
                            }
                        </div>
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Close</Button>
                            </DialogClose>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable Content"
                         Description="Long content can scroll while the header stays in view."
                         Code="@ScrollableCode"
                         CodeLanguage="razor"
                         PreviewClass="@DialogPreviewClass">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Scrollable Content</Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Scrollable Content</DialogTitle>
                            <DialogDescription>
                                This is a dialog with scrollable content.
                            </DialogDescription>
                        </DialogHeader>
                        <div class="-mx-4 no-scrollbar max-h-[50vh] overflow-y-auto px-4">
                            @for (var i = 0; i < 10; i++)
                            {
                                <Paragraph class="mb-4 leading-normal">
                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
                                </Paragraph>
                            }
                        </div>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         PreviewClass="@DialogPreviewClass">
                <DirectionProvider Dir="rtl">
                    <Div Class="grid w-full gap-6" dir="rtl">
                        <Div Display="Display.Flex" AlignItems="AlignItems.Center" Gap="Gap.Is2" Class="-mx-6" dir="ltr">
                            <Select TValue="string" SelectSize="SelectSizes.Sm" SelectedValue="@_rtlLocale" SelectedValueChanged="OnRtlLocaleChanged">
                                <SelectTrigger Width="Width.Is36" dir="ltr">
                                    <SelectValue />
                                </SelectTrigger>
                                <SelectContent Class="data-[state=open]:animate-none data-[state=closed]:animate-none" dir="ltr">
                                    <SelectGroup>
                                        <SelectItem TValue="string" ItemValue="@("ar")" Text="Arabic (العربية)" />
                                        <SelectItem TValue="string" ItemValue="@("he")" Text="Hebrew (עברית)" />
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                            <Button Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="ml-auto size-7" OnClick="ToggleRtlLocale">
                                <Icon Name="LucideIcon.Languages" />
                                <Span Class="sr-only">Toggle</Span>
                            </Button>
                        </Div>

                        <Div Class="flex justify-center">
                            <Dialog>
                                <DialogTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline">@RtlDialogTrigger</Button>
                                </DialogTrigger>
                                <DialogContent Class="text-right">
                                    <DialogHeader>
                                        <DialogTitle>@RtlDialogTitle</DialogTitle>
                                        <DialogDescription>@RtlDialogDescription</DialogDescription>
                                    </DialogHeader>
                                    <FieldGroup Class="gap-5">
                                        <Field>
                                            <Label For="dialog-rtl-name">@RtlNameLabel</Label>
                                            <Input Id="dialog-rtl-name" Value="Pedro Duarte" />
                                        </Field>
                                        <Field>
                                            <Label For="dialog-rtl-username">@RtlUsernameLabel</Label>
                                            <Input Id="dialog-rtl-username" Value="@("@peduarte")" />
                                        </Field>
                                    </FieldGroup>
                                    <DialogFooter>
                                        <DialogClose AsChild="true">
                                            <Button Variant="ButtonVariant.Outline">@RtlCancelLabel</Button>
                                        </DialogClose>
                                        <Button>@RtlSaveLabel</Button>
                                    </DialogFooter>
                                </DialogContent>
                            </Dialog>
                        </Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _rtlLocale = "ar";
    private bool IsHebrewRtl => _rtlLocale == "he";
    private string RtlDialogTrigger => IsHebrewRtl ? "פתח דיאלוג" : "فتح الحوار";
    private string RtlDialogTitle => IsHebrewRtl ? "עריכת פרופיל" : "تعديل الملف الشخصي";
    private string RtlDialogDescription => IsHebrewRtl ? "בצע שינויים בפרופיל שלך כאן. לחץ על שמור כשתסיים." : "قم بإجراء تغييرات على ملفك الشخصي هنا. انقر فوق حفظ عند الانتهاء.";
    private string RtlNameLabel => IsHebrewRtl ? "שם" : "الاسم";
    private string RtlUsernameLabel => IsHebrewRtl ? "שם משתמש" : "اسم المستخدم";
    private string RtlCancelLabel => IsHebrewRtl ? "ביטול" : "إلغاء";
    private string RtlSaveLabel => IsHebrewRtl ? "שמור שינויים" : "حفظ التغييرات";

    private Task OnRtlLocaleChanged(string? value)
    {
        _rtlLocale = value;
        return Task.CompletedTask;
    }

    private Task ToggleRtlLocale()
    {
        _rtlLocale = IsHebrewRtl ? "ar" : "he";
        return Task.CompletedTask;
    }

    private const string DialogPreviewClass =
        "preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0";

    private const string BasicCode =
@"<Dialog>
    <DialogTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Dialog</Button>
    </DialogTrigger>
    <DialogContent>
