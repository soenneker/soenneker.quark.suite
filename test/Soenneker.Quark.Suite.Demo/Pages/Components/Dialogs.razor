@page "/dialogs"
@using DialogSize = Soenneker.Quark.DialogSize

<PageTitle>Dialog - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Standard modal with header, form fields, and footer actions."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Dialog</Button>
                    </DialogTrigger>
                    <DialogContent Class="sm:max-w-[425px]">
                        <DialogHeader>
                            <DialogTitle>Edit profile</DialogTitle>
                            <DialogDescription>
                                Make changes to your profile here. Click save when you're done.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogBody>
                            <Div class="grid gap-4">
                                <Div class="grid gap-3">
                                    <Label For="dialog-name">Name</Label>
                                    <Input Id="dialog-name" Value="Pedro Duarte" />
                                </Div>
                                <Div class="grid gap-3">
                                    <Label For="dialog-username">Username</Label>
                                    <Input Id="dialog-username" Value="@("@peduarte")" />
                                </Div>
                            </Div>
                        </DialogBody>
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Cancel</Button>
                            </DialogClose>
                            <Button Type="ButtonType.Button">Save changes</Button>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Scrollable bodies, sticky footers, close-button changes, larger flows, RTL, and guarded dialogs.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Scrollable Content"
                         Description="Long body content scrolls inside the dialog while the chrome stays fixed."
                         Code="@ScrollableCode"
                         CodeLanguage="razor">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Scrollable Content</Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Scrollable Content</DialogTitle>
                            <DialogDescription>
                                This is a dialog with scrollable content.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogBody Class="max-h-[70vh] overflow-y-auto -mx-6 px-6">
                            @for (var i = 0; i < 10; i++)
                            {
                                <Paragraph class="mb-4 leading-normal">
                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                </Paragraph>
                            }
                        </DialogBody>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sticky Footer"
                         Description="Scrollable region with a footer that stays visible at the bottom."
                         Code="@StickyFooterCode"
                         CodeLanguage="razor">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Sticky Footer</Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Scrollable Content</DialogTitle>
                            <DialogDescription>
                                This is a dialog with scrollable content.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogBody Class="max-h-[70vh] overflow-y-auto -mx-6 px-6">
                            @for (var i = 0; i < 10; i++)
                            {
                                <Paragraph class="mb-4 leading-normal">
                                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                                </Paragraph>
                            }
                        </DialogBody>
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Close</Button>
                            </DialogClose>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="No Close Button"
                         Description="Hide the corner close control when dismissal should use explicit actions only."
                         Code="@NoCloseButtonCode"
                         CodeLanguage="razor">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">No Close Button</Button>
                    </DialogTrigger>
                    <DialogContent ShowCloseButton="false">
                        <DialogHeader>
                            <DialogTitle>No Close Button</DialogTitle>
                            <DialogDescription>
                                This dialog does not have a close button in the top-right corner.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Close</Button>
                            </DialogClose>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Chat Settings"
                         Description="Larger dialog with tabbed settings for more advanced configuration flows."
                         Code="@ChatSettingsCode"
                         CodeLanguage="razor">
                <Dialog DialogSize="DialogSize.Large">
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Chat Settings</Button>
                    </DialogTrigger>
                    <DialogContent Class="min-w-md">
                        <DialogHeader>
                            <DialogTitle>Chat Settings</DialogTitle>
                            <DialogDescription>
                                Customize your chat settings: theme, accent color, notifications, and security preferences.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogBody>
                            <Tabs SelectedTab="@_dialogTab"
                                  OnSelectedTabChanged="HandleDialogTabChanged"
                                  Justified="true"
                                  Class="w-full">
                                <Tab Name="general" Title="General">
                                    <Div class="mt-4 rounded-lg border p-4">
                                        <FieldGroup>
                                            <Field Orientation="Orientation.Horizontal">
                                                <FieldLabel For="theme">Theme</FieldLabel>
                                                <Select TValue="string" SelectedValue="@_dialogTheme" SelectedValueChanged="HandleDialogThemeChanged">
                                                    <SelectTrigger Id="theme">
                                                        <SelectValue Placeholder="Select" />
                                                    </SelectTrigger>
                                                    <SelectContent Align="end">
                                                        <SelectGroup>
                                                            <SelectItem TValue="string" ItemValue="@("light")" Text="Light" />
                                                            <SelectItem TValue="string" ItemValue="@("dark")" Text="Dark" />
                                                            <SelectItem TValue="string" ItemValue="@("system")" Text="System" />
                                                        </SelectGroup>
                                                    </SelectContent>
                                                </Select>
                                            </Field>
                                            <Field Orientation="Orientation.Horizontal">
                                                <FieldLabel For="nickname">Nickname</FieldLabel>
                                                <Input Id="nickname" Value="Broski" />
                                            </Field>
                                        </FieldGroup>
                                    </Div>
                                </Tab>
                                <Tab Name="notifications" Title="Notifications">
                                    <Div class="mt-4 rounded-lg border p-4">
                                        <FieldGroup>
                                            <Field Orientation="Orientation.Horizontal">
                                                <Check Id="push-notifications" @bind-Checked="_dialogPushNotifications" />
                                                <FieldLabel For="push-notifications" Class="font-normal">Push notifications</FieldLabel>
                                            </Field>
                                            <Field Orientation="Orientation.Horizontal">
                                                <Check Id="email-notifications" @bind-Checked="_dialogEmailNotifications" />
                                                <FieldLabel For="email-notifications" Class="font-normal">Email notifications</FieldLabel>
                                            </Field>
                                        </FieldGroup>
                                    </Div>
                                </Tab>
                                <Tab Name="security" Title="Security">
                                    <Div class="mt-4 rounded-lg border p-4">
                                        <FieldGroup>
                                            <Field Orientation="Orientation.Horizontal">
                                                <FieldContent>
                                                    <FieldLabel For="dialog-2fa">Multi-factor authentication</FieldLabel>
                                                    <FieldDescription>Enable multi-factor authentication to secure your account.</FieldDescription>
                                                </FieldContent>
                                                <Switch Id="dialog-2fa" Checked="@_dialogTwoFactorEnabled" CheckedChanged="HandleDialogTwoFactorChanged" />
                                            </Field>
                                        </FieldGroup>
                                    </Div>
                                </Tab>
                            </Tabs>
                        </DialogBody>
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Variant="ButtonVariant.Outline">Close</Button>
                            </DialogClose>
                            <Button>Save preferences</Button>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Dialog layout and text align for right-to-left locales."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Dialog>
                        <DialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">افتح الحوار</Button>
                        </DialogTrigger>
                        <DialogContent Class="sm:max-w-[425px] text-right">
                            <DialogHeader>
                                <DialogTitle>تعديل الملف الشخصي</DialogTitle>
                                <DialogDescription>
                                    قم بتحديث معلوماتك هنا، ثم احفظ التغييرات عند الانتهاء.
                                </DialogDescription>
                            </DialogHeader>
                            <DialogBody>
                                <Div class="grid gap-4">
                                    <Div class="grid gap-3">
                                        <Label For="dialog-rtl-name">الاسم</Label>
                                        <Input Id="dialog-rtl-name" Value="بيدرو دوارتي" />
                                    </Div>
                                    <Div class="grid gap-3">
                                        <Label For="dialog-rtl-username">اسم المستخدم</Label>
                                        <Input Id="dialog-rtl-username" Value="@("@peduarte")" />
                                    </Div>
                                </Div>
                            </DialogBody>
                            <DialogFooter>
                                <DialogClose AsChild="true">
                                    <Button Variant="ButtonVariant.Outline">إلغاء</Button>
                                </DialogClose>
                                <Button>حفظ التغييرات</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Static"
                         Description="Use footer actions to drive dismissal when you do not want the dialog to close from the backdrop."
                         Code="@StaticCode"
                         CodeLanguage="razor">
                <Dialog Static="true">
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open guarded dialog</Button>
                    </DialogTrigger>
                    <DialogContent ShowCloseButton="false">
                        <DialogHeader>
                            <DialogTitle>Delete environment</DialogTitle>
                            <DialogDescription>
                                This dialog ignores backdrop clicks so the user must choose explicitly.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogBody>
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
                                Type the environment name in a follow-up step before the destructive action is enabled.
                            </Paragraph>
                        </DialogBody>
                        <DialogFooter>
                            <DialogClose AsChild="true">
                                <Button Variant="ButtonVariant.Secondary">Keep environment</Button>
                            </DialogClose>
                            <DialogClose AsChild="true">
                                <Button Variant="ButtonVariant.Destructive">Delete</Button>
                            </DialogClose>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </DemoSection>

            <DemoSection Title="Size And Position"
                         Description="Scale the dialog up or center it vertically when the content deserves more focus."
                         Code="@SizeAndPositionCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex="Flex.Wrap" Gap="Gap.Is2">
                    <Dialog DialogSize="DialogSize.Large">
                        <DialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Large dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogHeader>
                                <DialogTitle>Invite collaborators</DialogTitle>
                                <DialogDescription>
                                    Use a wider dialog when the flow needs richer context or multi-column content.
                                </DialogDescription>
                            </DialogHeader>
                            <DialogBody>
                                <Div Class="grid gap-4 md:grid-cols-2">
                                    <Div>
                                        <H5>Workspace access</H5>
                                        <Paragraph Margin="Margin.Is0">Choose whether invited users can edit settings, deploy changes, or manage billing.</Paragraph>
                                    </Div>
                                    <Div>
                                        <H5>Invite message</H5>
                                        <Paragraph Margin="Margin.Is0">Add context so collaborators know which project, branch, or milestone they are joining.</Paragraph>
                                    </Div>
                                </Div>
                            </DialogBody>
                        </DialogContent>
                    </Dialog>

                    <Dialog Centered="true">
                        <DialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Centered dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogHeader>
                                <DialogTitle>Publish release</DialogTitle>
                                <DialogDescription>
                                    Centered dialogs work well for short, high-importance confirmation steps.
                                </DialogDescription>
                            </DialogHeader>
                            <DialogFooter>
                                <DialogClose AsChild="true">
                                    <Button Variant="ButtonVariant.Secondary">Not yet</Button>
                                </DialogClose>
                                <DialogClose AsChild="true">
                                    <Button>Publish now</Button>
                                </DialogClose>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

