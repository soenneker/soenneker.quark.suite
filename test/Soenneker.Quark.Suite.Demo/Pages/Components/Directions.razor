@page "/directions"

<PageTitle>Direction - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="LTR and RTL layouts"
                         Description="Adapted from the shadcn direction docs. DirectionProvider lets you preview left-to-right and right-to-left flows side by side."
                         Code="@DirectionCode">
                <Div Class="grid gap-6 md:grid-cols-2">
                    <DirectionProvider Dir="ltr">
                        <Div Class="space-y-4 rounded-xl border bg-card p-5 text-left">
                            <Div Class="flex items-center justify-between">
                                <Paragraph class="text-sm font-semibold">Left to right</Paragraph>
                                <Span class="rounded-full border border-border px-2 py-1 text-xs text-muted-foreground">LTR</Span>
                            </Div>

                            <Paragraph class="text-sm text-muted-foreground">
                                Ship changes, review feedback, and coordinate release work in the default left-to-right flow.
                            </Paragraph>

                            <Div Class="flex flex-wrap gap-2">
                                <Button Variant="ButtonVariant.Default">Deploy</Button>
                                <Button Variant="ButtonVariant.Outline">Preview</Button>
                            </Div>
                        </Div>
                    </DirectionProvider>

                    <DirectionProvider Dir="rtl">
                        <Div Class="space-y-4 rounded-xl border bg-card p-5 text-right">
                            <Div Class="flex items-center justify-between">
                                <Span class="rounded-full border border-border px-2 py-1 text-xs text-muted-foreground">RTL</Span>
                                <Paragraph class="text-sm font-semibold">من اليمين إلى اليسار</Paragraph>
                            </Div>

                            <Paragraph class="text-sm text-muted-foreground">
                                استخدم موفر الاتجاه لمعاينة الواجهات العربية أو العبرية مع نفس مكونات كوارك.
                            </Paragraph>

                            <Div Class="flex flex-wrap justify-end gap-2">
                                <Button Variant="ButtonVariant.Default">نشر</Button>
                                <Button Variant="ButtonVariant.Outline">معاينة</Button>
                            </Div>
                        </Div>
                    </DirectionProvider>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Content blocks"
                         Description="Direction can also scope smaller regions instead of the whole app.">
                <Div Class="grid gap-4">
                    <DirectionProvider Dir="ltr">
                        <Div Class="rounded-xl border border-dashed border-border bg-background p-4">
                            <Paragraph class="text-sm font-medium">Billing summary</Paragraph>
                            <Paragraph class="mt-1 text-sm text-muted-foreground">Direction can be applied to just the components that need it.</Paragraph>
                        </Div>
                    </DirectionProvider>

                    <DirectionProvider Dir="rtl">
                        <Div Class="rounded-xl border border-dashed border-border bg-background p-4 text-right">
                            <Paragraph class="text-sm font-medium">ملخص الفوترة</Paragraph>
                            <Paragraph class="mt-1 text-sm text-muted-foreground">يمكنك تطبيق الاتجاه على قسم واحد فقط دون تغيير بقية الصفحة.</Paragraph>
                        </Div>
                    </DirectionProvider>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DirectionCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Class=""rounded-xl border bg-card p-5 text-right"">
        <Paragraph>RTL content preview</Paragraph>
    </Div>
</DirectionProvider>";
}
