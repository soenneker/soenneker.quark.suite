@page "/directions"

<PageTitle>Direction - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="DirectionProvider lets you preview left-to-right and right-to-left flows side by side."
                         Code="@DirectionCode"
                         CodeLanguage="razor">
                <Div Display="Display.Grid" Gap='Gap.Token("6")' Class="md:grid-cols-2">
                    <DirectionProvider Dir="ltr">
                        <Div Class="space-y-4 rounded-xl border bg-card p-5 text-left">
                            <Div Class="flex items-center justify-between">
                                <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">Left to right</Paragraph>
                                <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Is2.OnX.Is1.OnY' TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">LTR</Span>
                            </Div>

                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                                Ship changes, review feedback, and coordinate release work in the default left-to-right flow.
                            </Paragraph>

                            <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
                                <Button Variant="ButtonVariant.Default">Deploy</Button>
                                <Button Variant="ButtonVariant.Outline">Preview</Button>
                            </Div>
                        </Div>
                    </DirectionProvider>

                    <DirectionProvider Dir="rtl">
                        <Div Class="space-y-4 rounded-xl border bg-card p-5 text-right">
                            <Div Class="flex items-center justify-between">
                                <Span Rounded="Rounded.Full" Border="Border.Is1" BorderColor="BorderColor.Border" Padding='Padding.Is2.OnX.Is1.OnY' TextSize="TextSize.Xs" TextColor="TextColor.MutedForeground">RTL</Span>
                                <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Semibold">من اليمين إلى اليسار</Paragraph>
                            </Div>

                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                                استخدم موفر الاتجاه لمعاينة الواجهات العربية أو العبرية مع نفس مكونات كوارك.
                            </Paragraph>

                            <Div Class="flex flex-wrap justify-end gap-2">
                                <Button Variant="ButtonVariant.Default">نشر</Button>
                                <Button Variant="ButtonVariant.Outline">معاينة</Button>
                            </Div>
                        </Div>
                    </DirectionProvider>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Content blocks"
                         Description="Direction can also scope smaller regions instead of the whole app."
                         Code="@DirectionBlocksCode"
                         CodeLanguage="razor">
                <Div Display="Display.Grid" Gap="Gap.Is4">
                    <DirectionProvider Dir="ltr">
                        <Div Class="rounded-xl border border-dashed border-border bg-background p-4">
                            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Billing summary</Paragraph>
                            <Paragraph class="mt-1 text-sm text-muted-foreground">Direction can be applied to just the components that need it.</Paragraph>
                        </Div>
                    </DirectionProvider>

                    <DirectionProvider Dir="rtl">
                        <Div Class="rounded-xl border border-dashed border-border bg-background p-4 text-right">
                            <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">ملخص الفوترة</Paragraph>
                            <Paragraph class="mt-1 text-sm text-muted-foreground">يمكنك تطبيق الاتجاه على قسم واحد فقط دون تغيير بقية الصفحة.</Paragraph>
                        </Div>
                    </DirectionProvider>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DirectionCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Class=""rounded-xl border bg-card p-5 text-right"">
        <Paragraph>RTL content preview</Paragraph>
    </Div>
</DirectionProvider>";

    private const string DirectionBlocksCode =
@"<DirectionProvider Dir=""ltr""><Div>...</Div></DirectionProvider>
<DirectionProvider Dir=""rtl""><Div Class=""text-right"">...</Div></DirectionProvider>";
}
