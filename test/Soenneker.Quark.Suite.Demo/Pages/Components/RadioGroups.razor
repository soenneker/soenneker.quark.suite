@page "/radiogroups"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Radio Group - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="The standard radio group list with label wiring and roving keyboard navigation."
                         Code="@DemoCode"
                         CodeLanguage="razor">
                <RadioGroup Name="density-demo" Value="@_demoValue" ValueChanged="OnDemoValueChanged" Width="Width.IsFit" AriaLabel="Density options">
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is3">
                        <Radio Id="r1" Value="default" />
                        <Label For="r1">Default</Label>
                    </Div>
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is3">
                        <Radio Id="r2" Value="comfortable" />
                        <Label For="r2">Comfortable</Label>
                    </Div>
                    <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is3">
                        <Radio Id="r3" Value="compact" />
                        <Label For="r3">Compact</Label>
                    </Div>
                </RadioGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="Form-style radio group with validation and submitted value preview."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <EditForm Model="_formModel" OnSubmit="@(_ => HandleFormSubmit())" class="w-2/3 space-y-6">
                    <Field Space="Space.Y.Is3">
                        <FieldLabel>Notify me about...</FieldLabel>
                        <RadioGroup Name="notify-type"
                                    Value="@_formModel.Type"
                                    ValueChanged="OnFormTypeChanged"
                                    AriaLabel="Notification type">
                            <Field Horizontal="true">
                                <Radio Id="notify-all" Value="all" />
                                <FieldLabel For="notify-all" FontWeight="FontWeight.Normal">All new messages</FieldLabel>
                            </Field>
                            <Field Horizontal="true">
                                <Radio Id="notify-mentions" Value="mentions" />
                                <FieldLabel For="notify-mentions" FontWeight="FontWeight.Normal">Direct messages and mentions</FieldLabel>
                            </Field>
                            <Field Horizontal="true">
                                <Radio Id="notify-none" Value="none" />
                                <FieldLabel For="notify-none" FontWeight="FontWeight.Normal">Nothing</FieldLabel>
                            </Field>
                        </RadioGroup>
                        @if (_showFormError)
                        {
                            <Paragraph Class="text-sm text-destructive" Margin="Margin.Is0">
                                You need to select a notification type.
                            </Paragraph>
                        }
                    </Field>

                    <Button Type="ButtonType.Submit">Submit</Button>

                    @if (!string.IsNullOrEmpty(_submittedTypeJson))
                    {
                        <PreCode Class="rounded-lg bg-neutral-950 p-4 text-sm text-white">@_submittedTypeJson</PreCode>
                    }
                </EditForm>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextColor="TextColor.MutedForeground">
                    Descriptions, choice cards, fieldsets, invalid states, RTL, and inline content.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Description"
                         Description="Pair each radio with a label and supporting description."
                         Code="@DescriptionCode"
                         CodeLanguage="razor">
                <RadioGroup Name="density-description" Value="@_descriptionValue" ValueChanged="OnDescriptionValueChanged" Width="Width.IsFit" AriaLabel="Density descriptions">
                    <Field Horizontal="true">
                        <Radio Id="desc-r1" Value="default" />
                        <FieldContent>
                            <FieldLabel For="desc-r1">Default</FieldLabel>
                            <FieldDescription>Standard spacing for most use cases.</FieldDescription>
                        </FieldContent>
                    </Field>
                    <Field Horizontal="true">
                        <Radio Id="desc-r2" Value="comfortable" />
                        <FieldContent>
                            <FieldLabel For="desc-r2">Comfortable</FieldLabel>
                            <FieldDescription>More space between elements.</FieldDescription>
                        </FieldContent>
                    </Field>
                    <Field Horizontal="true">
                        <Radio Id="desc-r3" Value="compact" />
                        <FieldContent>
                            <FieldLabel For="desc-r3">Compact</FieldLabel>
                            <FieldDescription>Minimal spacing for dense layouts.</FieldDescription>
                        </FieldContent>
                    </Field>
                </RadioGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Choice Card"
                         Description="Use card-style rows when options need titles and subtitles."
                         Code="@ChoiceCardCode"
                         CodeLanguage="razor">
                <RadioGroup Name="plan-choice-card" Value="@_choiceCardValue" ValueChanged="OnChoiceCardValueChanged" MaxWidth="MaxWidth.IsSm" AriaLabel="Subscription plans">
                    <FieldLabel For="plus-plan">
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldTitle>Plus</FieldTitle>
                                <FieldDescription>For individuals and small teams.</FieldDescription>
                            </FieldContent>
                            <Radio Id="plus-plan" Value="plus" />
                        </Field>
                    </FieldLabel>
                    <FieldLabel For="pro-plan">
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldTitle>Pro</FieldTitle>
                                <FieldDescription>For growing businesses.</FieldDescription>
                            </FieldContent>
                            <Radio Id="pro-plan" Value="pro" />
                        </Field>
                    </FieldLabel>
                    <FieldLabel For="enterprise-plan">
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldTitle>Enterprise</FieldTitle>
                                <FieldDescription>For large teams and enterprises.</FieldDescription>
                            </FieldContent>
                            <Radio Id="enterprise-plan" Value="enterprise" />
                        </Field>
                    </FieldLabel>
                </RadioGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Fieldset"
                         Description="Group radios with a legend and helper text in a fieldset."
                         Code="@FieldsetCode"
                         CodeLanguage="razor">
                <FieldSet Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <FieldLegend Variant="FieldLegendVariant.Label">Subscription Plan</FieldLegend>
                    <FieldDescription>Yearly and lifetime plans offer significant savings.</FieldDescription>
                    <RadioGroup Name="subscription-plan" Value="@_fieldsetValue" ValueChanged="OnFieldsetValueChanged" AriaLabel="Subscription plans">
                        <Field Horizontal="true">
                            <Radio Id="plan-monthly" Value="monthly" />
                            <FieldLabel For="plan-monthly" FontWeight="FontWeight.Normal">Monthly ($9.99/month)</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Radio Id="plan-yearly" Value="yearly" />
                            <FieldLabel For="plan-yearly" FontWeight="FontWeight.Normal">Yearly ($99.99/year)</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Radio Id="plan-lifetime" Value="lifetime" />
                            <FieldLabel For="plan-lifetime" FontWeight="FontWeight.Normal">Lifetime ($299.99)</FieldLabel>
                        </Field>
                    </RadioGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disable individual radios or the whole field."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <RadioGroup Name="disabled-options" Value="@_disabledValue" ValueChanged="OnDisabledValueChanged" Width="Width.IsFit" AriaLabel="Disabled radio options">
                    <Field Horizontal="true" Disabled="true">
                        <Radio Id="disabled-1" Value="option1" Disabled="true" />
                        <FieldLabel For="disabled-1" FontWeight="FontWeight.Normal">Disabled</FieldLabel>
                    </Field>
                    <Field Horizontal="true">
                        <Radio Id="disabled-2" Value="option2" />
                        <FieldLabel For="disabled-2" FontWeight="FontWeight.Normal">Option 2</FieldLabel>
                    </Field>
                    <Field Horizontal="true">
                        <Radio Id="disabled-3" Value="option3" />
                        <FieldLabel For="disabled-3" FontWeight="FontWeight.Normal">Option 3</FieldLabel>
                    </Field>
                </RadioGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Mark the field invalid when the selection fails validation."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <FieldSet Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <FieldLegend Variant="FieldLegendVariant.Label">Notification Preferences</FieldLegend>
                    <FieldDescription>Choose how you want to receive notifications.</FieldDescription>
                    <RadioGroup Name="invalid-notifications" Value="@_invalidValue" ValueChanged="OnInvalidValueChanged" AriaLabel="Notification preferences">
                        <Field Horizontal="true" IsInvalid="true">
                            <Radio Id="invalid-email" Value="email" aria-invalid="true" />
                            <FieldLabel For="invalid-email" FontWeight="FontWeight.Normal">Email only</FieldLabel>
                        </Field>
                        <Field Horizontal="true" IsInvalid="true">
                            <Radio Id="invalid-sms" Value="sms" aria-invalid="true" />
                            <FieldLabel For="invalid-sms" FontWeight="FontWeight.Normal">SMS only</FieldLabel>
                        </Field>
                        <Field Horizontal="true" IsInvalid="true">
                            <Radio Id="invalid-both" Value="both" aria-invalid="true" />
                            <FieldLabel For="invalid-both" FontWeight="FontWeight.Normal">Both Email &amp; SMS</FieldLabel>
                        </Field>
                    </RadioGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Radio groups respect direction from DirectionProvider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <RadioGroup Name="rtl-density"
                                Value="@_rtlValue"
                                ValueChanged="OnRtlValueChanged"
                                Width="Width.IsFit"
                                TextAlign="TextAlign.End"
                                AriaLabel="خيارات الكثافة">
                        <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is3">
                            <Radio Id="rtl-r1" Value="default" />
                            <Label For="rtl-r1">افتراضي</Label>
                        </Div>
                        <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is3">
                            <Radio Id="rtl-r2" Value="comfortable" />
                            <Label For="rtl-r2">مريح</Label>
                        </Div>
                        <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is3">
                            <Radio Id="rtl-r3" Value="compact" />
                            <Label For="rtl-r3">مضغوط</Label>
                        </Div>
                    </RadioGroup>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Inline Content"
                         Description="Standalone radios can render label text inside the component."
                         Code="@InlineContentCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is4">
                    <Radio Name="rating-inline" Value="excellent" Checked="@(_inlineRating == "excellent")" OnClick="@(() => _inlineRating = "excellent")" Inline="true">Excellent</Radio>
                    <Radio Name="rating-inline" Value="good" Checked="@(_inlineRating == "good")" OnClick="@(() => _inlineRating = "good")" Inline="true">Good</Radio>
                    <Radio Name="rating-inline" Value="fair" Checked="@(_inlineRating == "fair")" OnClick="@(() => _inlineRating = "fair")" Inline="true">Fair</Radio>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private sealed class RadioFormModel
    {
        public string? Type { get; set; }
    }

    private const string DemoCode =
@"<RadioGroup Name=""density-demo"" Value=""@_demoValue"" ValueChanged=""OnDemoValueChanged"" Width=""Width.IsFit"" AriaLabel=""Density options"">
    <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is3"">
        <Radio Id=""r1"" Value=""default"" />
        <Label For=""r1"">Default</Label>
    </Div>
    <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is3"">
        <Radio Id=""r2"" Value=""comfortable"" />
        <Label For=""r2"">Comfortable</Label>
    </Div>
    <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is3"">
        <Radio Id=""r3"" Value=""compact"" />
        <Label For=""r3"">Compact</Label>
    </Div>
</RadioGroup>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnSubmit=""@(_ => HandleFormSubmit())"" class=""w-2/3 space-y-6"">
    <Field Space=""Space.Y.Is3"">
        <FieldLabel>Notify me about...</FieldLabel>
        <RadioGroup Name=""notify-type"" Value=""@_formModel.Type"" ValueChanged=""OnFormTypeChanged"" AriaLabel=""Notification type"">
            <Field Horizontal=""true"">
                <Radio Id=""notify-all"" Value=""all"" />
                <FieldLabel For=""notify-all"" FontWeight=""FontWeight.Normal"">All new messages</FieldLabel>
            </Field>
            <Field Horizontal=""true"">
                <Radio Id=""notify-mentions"" Value=""mentions"" />
                <FieldLabel For=""notify-mentions"" FontWeight=""FontWeight.Normal"">Direct messages and mentions</FieldLabel>
            </Field>
            <Field Horizontal=""true"">
                <Radio Id=""notify-none"" Value=""none"" />
                <FieldLabel For=""notify-none"" FontWeight=""FontWeight.Normal"">Nothing</FieldLabel>
            </Field>
        </RadioGroup>
    </Field>
    <Button Type=""ButtonType.Submit"">Submit</Button>
</EditForm>";

    private const string DescriptionCode =
@"<RadioGroup Name=""density-description"" Value=""@_descriptionValue"" ValueChanged=""OnDescriptionValueChanged"" Width=""Width.IsFit"" AriaLabel=""Density descriptions"">
    <Field Horizontal=""true"">
        <Radio Id=""desc-r1"" Value=""default"" />
        <FieldContent>
            <FieldLabel For=""desc-r1"">Default</FieldLabel>
            <FieldDescription>Standard spacing for most use cases.</FieldDescription>
        </FieldContent>
    </Field>
    <Field Horizontal=""true"">
        <Radio Id=""desc-r2"" Value=""comfortable"" />
        <FieldContent>
            <FieldLabel For=""desc-r2"">Comfortable</FieldLabel>
            <FieldDescription>More space between elements.</FieldDescription>
        </FieldContent>
    </Field>
    <Field Horizontal=""true"">
        <Radio Id=""desc-r3"" Value=""compact"" />
        <FieldContent>
            <FieldLabel For=""desc-r3"">Compact</FieldLabel>
            <FieldDescription>Minimal spacing for dense layouts.</FieldDescription>
        </FieldContent>
    </Field>
</RadioGroup>";

    private const string ChoiceCardCode =
@"<RadioGroup Name=""plan-choice-card"" Value=""@_choiceCardValue"" ValueChanged=""OnChoiceCardValueChanged"" MaxWidth=""MaxWidth.IsSm"" AriaLabel=""Subscription plans"">
    <FieldLabel For=""plus-plan"">
        <Field Horizontal=""true"">
            <FieldContent>
                <FieldTitle>Plus</FieldTitle>
                <FieldDescription>For individuals and small teams.</FieldDescription>
            </FieldContent>
            <Radio Id=""plus-plan"" Value=""plus"" />
        </Field>
    </FieldLabel>
    <FieldLabel For=""pro-plan"">
        <Field Horizontal=""true"">
            <FieldContent>
                <FieldTitle>Pro</FieldTitle>
                <FieldDescription>For growing businesses.</FieldDescription>
            </FieldContent>
            <Radio Id=""pro-plan"" Value=""pro"" />
        </Field>
    </FieldLabel>
</RadioGroup>";

    private const string FieldsetCode =
@"<FieldSet Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsXs"">
    <FieldLegend Variant=""FieldLegendVariant.Label"">Subscription Plan</FieldLegend>
    <FieldDescription>Yearly and lifetime plans offer significant savings.</FieldDescription>
    <RadioGroup Name=""subscription-plan"" Value=""@_fieldsetValue"" ValueChanged=""OnFieldsetValueChanged"" AriaLabel=""Subscription plans"">
        <Field Horizontal=""true"">
            <Radio Id=""plan-monthly"" Value=""monthly"" />
            <FieldLabel For=""plan-monthly"" FontWeight=""FontWeight.Normal"">Monthly ($9.99/month)</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Radio Id=""plan-yearly"" Value=""yearly"" />
            <FieldLabel For=""plan-yearly"" FontWeight=""FontWeight.Normal"">Yearly ($99.99/year)</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Radio Id=""plan-lifetime"" Value=""lifetime"" />
            <FieldLabel For=""plan-lifetime"" FontWeight=""FontWeight.Normal"">Lifetime ($299.99)</FieldLabel>
        </Field>
    </RadioGroup>
</FieldSet>";

    private const string DisabledCode =
@"<RadioGroup Name=""disabled-options"" Value=""@_disabledValue"" ValueChanged=""OnDisabledValueChanged"" Width=""Width.IsFit"" AriaLabel=""Disabled radio options"">
    <Field Horizontal=""true"" Disabled=""true"">
        <Radio Id=""disabled-1"" Value=""option1"" Disabled=""true"" />
        <FieldLabel For=""disabled-1"" FontWeight=""FontWeight.Normal"">Disabled</FieldLabel>
    </Field>
    <Field Horizontal=""true"">
        <Radio Id=""disabled-2"" Value=""option2"" />
        <FieldLabel For=""disabled-2"" FontWeight=""FontWeight.Normal"">Option 2</FieldLabel>
    </Field>
    <Field Horizontal=""true"">
        <Radio Id=""disabled-3"" Value=""option3"" />
        <FieldLabel For=""disabled-3"" FontWeight=""FontWeight.Normal"">Option 3</FieldLabel>
    </Field>
</RadioGroup>";

    private const string InvalidCode =
@"<FieldSet Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsXs"">
    <FieldLegend Variant=""FieldLegendVariant.Label"">Notification Preferences</FieldLegend>
    <FieldDescription>Choose how you want to receive notifications.</FieldDescription>
    <RadioGroup Name=""invalid-notifications"" Value=""@_invalidValue"" ValueChanged=""OnInvalidValueChanged"" AriaLabel=""Notification preferences"">
        <Field Horizontal=""true"" IsInvalid=""true"">
            <Radio Id=""invalid-email"" Value=""email"" aria-invalid=""true"" />
            <FieldLabel For=""invalid-email"" FontWeight=""FontWeight.Normal"">Email only</FieldLabel>
        </Field>
        <Field Horizontal=""true"" IsInvalid=""true"">
            <Radio Id=""invalid-sms"" Value=""sms"" aria-invalid=""true"" />
            <FieldLabel For=""invalid-sms"" FontWeight=""FontWeight.Normal"">SMS only</FieldLabel>
        </Field>
        <Field Horizontal=""true"" IsInvalid=""true"">
            <Radio Id=""invalid-both"" Value=""both"" aria-invalid=""true"" />
            <FieldLabel For=""invalid-both"" FontWeight=""FontWeight.Normal"">Both Email &amp; SMS</FieldLabel>
        </Field>
    </RadioGroup>
</FieldSet>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <RadioGroup Name=""rtl-density"" Value=""@_rtlValue"" ValueChanged=""OnRtlValueChanged"" Width=""Width.IsFit"" TextAlign=""TextAlign.End"" AriaLabel=""خيارات الكثافة"">
        <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is3"">
            <Radio Id=""rtl-r1"" Value=""default"" />
            <Label For=""rtl-r1"">افتراضي</Label>
        </Div>
        <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is3"">
            <Radio Id=""rtl-r2"" Value=""comfortable"" />
            <Label For=""rtl-r2"">مريح</Label>
        </Div>
        <Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is3"">
            <Radio Id=""rtl-r3"" Value=""compact"" />
            <Label For=""rtl-r3"">مضغوط</Label>
        </Div>
    </RadioGroup>
</DirectionProvider>";

    private const string InlineContentCode =
@"<Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is4"">
    <Radio Name=""rating-inline"" Value=""excellent"" Checked=""@(_inlineRating == ""excellent"")"" OnClick=""@(() => _inlineRating = ""excellent"")"" Inline=""true"">Excellent</Radio>
    <Radio Name=""rating-inline"" Value=""good"" Checked=""@(_inlineRating == ""good"")"" OnClick=""@(() => _inlineRating = ""good"")"" Inline=""true"">Good</Radio>
    <Radio Name=""rating-inline"" Value=""fair"" Checked=""@(_inlineRating == ""fair"")"" OnClick=""@(() => _inlineRating = ""fair"")"" Inline=""true"">Fair</Radio>
</Div>";

    private string _demoValue = "comfortable";
    private string _descriptionValue = "comfortable";
    private string _disabledValue = "option2";
    private string _invalidValue = "email";
    private string _choiceCardValue = "plus";
    private string _fieldsetValue = "monthly";
    private string _rtlValue = "comfortable";
    private string _inlineRating = "good";
    private readonly RadioFormModel _formModel = new();
    private bool _showFormError;
    private string? _submittedTypeJson;

    private Task OnDemoValueChanged(string? value)
    {
        _demoValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnDescriptionValueChanged(string? value)
    {
        _descriptionValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnDisabledValueChanged(string? value)
    {
        _disabledValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnInvalidValueChanged(string? value)
    {
        _invalidValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnChoiceCardValueChanged(string? value)
    {
        _choiceCardValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnFieldsetValueChanged(string? value)
    {
        _fieldsetValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnRtlValueChanged(string? value)
    {
        _rtlValue = value ?? string.Empty;
        return Task.CompletedTask;
    }

    private Task OnFormTypeChanged(string? value)
    {
        _formModel.Type = value;
        _showFormError = false;
        return Task.CompletedTask;
    }

    private Task HandleFormSubmit()
    {
        if (string.IsNullOrWhiteSpace(_formModel.Type))
        {
            _showFormError = true;
            _submittedTypeJson = null;
            return Task.CompletedTask;
        }

        _showFormError = false;
        _submittedTypeJson =
            $$"""
              {
                "type": "{{_formModel.Type}}"
              }
              """;

        return Task.CompletedTask;
    }
}
