@page "/fields"
@using Soenneker.Quark.Forms
<PageTitle>Fields - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Multi-section payment form with field sets, selects, and horizontal actions."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="w-full max-w-md">
                    <form>
                        <FieldGroup>
                            <FieldSet>
                                <FieldLegend>Payment Method</FieldLegend>
                                <FieldDescription>All transactions are secure and encrypted</FieldDescription>
                                <FieldGroup>
                                    <Field>
                                        <FieldLabel For="field-card-name">Name on Card</FieldLabel>
                                        <Input Id="field-card-name" Placeholder="Evil Rabbit" Required="true" />
                                    </Field>
                                    <Field>
                                        <FieldLabel For="field-card-number">Card Number</FieldLabel>
                                        <Input Id="field-card-number" Placeholder="1234 5678 9012 3456" Required="true" />
                                        <FieldDescription>Enter your 16-digit card number</FieldDescription>
                                    </Field>
                                    <Div Class="grid grid-cols-3 gap-4">
                                        <Field>
                                            <FieldLabel For="field-exp-month">Month</FieldLabel>
                                            <Select TValue="string" SelectedValue="@("")">
                                                <SelectTrigger Id="field-exp-month">
                                                    <SelectValue Placeholder="MM" />
                                                </SelectTrigger>
                                                <SelectContent>
                                                    <SelectItem TValue="string" ItemValue="@("01")" Text="01" />
                                                    <SelectItem TValue="string" ItemValue="@("02")" Text="02" />
                                                    <SelectItem TValue="string" ItemValue="@("03")" Text="03" />
                                                    <SelectItem TValue="string" ItemValue="@("04")" Text="04" />
                                                </SelectContent>
                                            </Select>
                                        </Field>
                                        <Field>
                                            <FieldLabel For="field-exp-year">Year</FieldLabel>
                                            <Select TValue="string" SelectedValue="@("")">
                                                <SelectTrigger Id="field-exp-year">
                                                    <SelectValue Placeholder="YYYY" />
                                                </SelectTrigger>
                                                <SelectContent>
                                                    <SelectItem TValue="string" ItemValue="@("2026")" Text="2026" />
                                                    <SelectItem TValue="string" ItemValue="@("2027")" Text="2027" />
                                                    <SelectItem TValue="string" ItemValue="@("2028")" Text="2028" />
                                                    <SelectItem TValue="string" ItemValue="@("2029")" Text="2029" />
                                                </SelectContent>
                                            </Select>
                                        </Field>
                                        <Field>
                                            <FieldLabel For="field-cvv">CVV</FieldLabel>
                                            <Input Id="field-cvv" Placeholder="123" Required="true" />
                                        </Field>
                                    </Div>
                                </FieldGroup>
                            </FieldSet>
                            <FieldSeparator />
                            <FieldSet>
                                <FieldLegend>Billing Address</FieldLegend>
                                <FieldDescription>The billing address associated with your payment method</FieldDescription>
                                <FieldGroup>
                                    <Field Horizontal="true">
                                        <Check Id="field-same-as-shipping" Checked="true" />
                                        <FieldLabel For="field-same-as-shipping" FontWeight="FontWeight.Normal">Same as shipping address</FieldLabel>
                                    </Field>
                                </FieldGroup>
                            </FieldSet>
                            <FieldSet>
                                <FieldGroup>
                                    <Field>
                                        <FieldLabel For="field-comments">Comments</FieldLabel>
                                        <TextArea Id="field-comments" Placeholder="Add any additional comments" Class="resize-none" />
                                    </Field>
                                </FieldGroup>
                            </FieldSet>
                            <Field Horizontal="true">
                                <Button Type="ButtonType.Submit">Submit</Button>
                                <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Cancel</Button>
                            </Field>
                        </FieldGroup>
                    </form>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input"
                         Description="A label, control, and description in the standard field layout."
                         Code="@FieldCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="field-email">Email</FieldLabel>
                    <Input Id="field-email" Type="email" Placeholder="m@example.com" />
                    <FieldDescription>We will never share your email address.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Textarea"
                         Description="Label, textarea, and helper text in a small field set."
                         Code="@TextareaCode"
                         CodeLanguage="razor">
                <FieldSet Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <FieldGroup>
                        <Field>
                            <FieldLabel For="feedback">Feedback</FieldLabel>
                            <TextArea Id="feedback" Placeholder="Your feedback helps us improve..." Rows="4" />
                            <FieldDescription>Share your thoughts about our service.</FieldDescription>
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Select"
                         Description="Use Field with Select when the user chooses from a known set of values."
                         Code="@SelectCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="field-role">Role</FieldLabel>
                    <Select TValue="string" SelectedValue="@("viewer")">
                        <SelectTrigger Id="field-role">
                            <SelectValue Placeholder="Select a role" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectItem TValue="string" ItemValue="@("admin")" Text="Admin" />
                            <SelectItem TValue="string" ItemValue="@("editor")" Text="Editor" />
                            <SelectItem TValue="string" ItemValue="@("viewer")" Text="Viewer" />
                        </SelectContent>
                    </Select>
                    <FieldDescription>Roles determine what this member can access.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Slider"
                         Description="Field descriptions can reflect slider values and constraints."
                         Code="@SliderCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsSm">
                    <FieldLabel>Volume</FieldLabel>
                    <Slider Min="0" Max="100" Step="1" SliderValue="40" />
                    <FieldDescription>Set the default playback volume.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Fieldset"
                         Description="Group related controls under a shared legend and description."
                         Code="@FieldsetCode"
                         CodeLanguage="razor">
                <FieldSet MaxWidth="MaxWidth.IsSm">
                    <FieldLegend>Notification preferences</FieldLegend>
                    <FieldGroup>
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldLabel>Email alerts</FieldLabel>
                                <FieldDescription>Receive build and deploy notifications in your inbox.</FieldDescription>
                            </FieldContent>
                            <Switch Label="Enable alerts" />
                        </Field>
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldLabel>SMS alerts</FieldLabel>
                                <FieldDescription>Use SMS only for urgent production incidents.</FieldDescription>
                            </FieldContent>
                            <Switch Label="Enable SMS" />
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkbox"
                         Description="Pair checkbox controls with labels and descriptions in one accessible field."
                         Code="@CheckboxCode"
                         CodeLanguage="razor">
                <Field Horizontal="true">
                    <Check Id="field-marketing" />
                    <FieldContent>
                        <FieldLabel For="field-marketing">Marketing emails</FieldLabel>
                        <FieldDescription>Receive emails about new products and features.</FieldDescription>
                    </FieldContent>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio"
                         Description="Use field rows to label radio choices."
                         Code="@RadioCode"
                         CodeLanguage="razor">
                <RadioGroup Name="field-plan" Value="pro" AriaLabel="Plan">
                    <Field Horizontal="true">
                        <Radio Id="field-plan-free" Value="free" />
                        <FieldLabel For="field-plan-free" FontWeight="FontWeight.Normal">Free</FieldLabel>
                    </Field>
                    <Field Horizontal="true">
                        <Radio Id="field-plan-pro" Value="pro" />
                        <FieldLabel For="field-plan-pro" FontWeight="FontWeight.Normal">Pro</FieldLabel>
                    </Field>
                </RadioGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Switch"
                         Description="Use a horizontal field when the control belongs at the end of the row."
                         Code="@SwitchCode"
                         CodeLanguage="razor">
                <Field Horizontal="true">
                    <FieldContent>
                        <FieldLabel For="field-sync">Sync across devices</FieldLabel>
                        <FieldDescription>Keep this setting consistent on signed-in devices.</FieldDescription>
                    </FieldContent>
                    <Switch Id="field-sync" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Choice Card"
                         Description="Use card-like fields for larger selectable choices."
                         Code="@ChoiceCardCode"
                         CodeLanguage="razor">
                <Field Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" MaxWidth="MaxWidth.IsSm">
                    <Div Display="Display.Flex" ItemsAlign="Items.Start" Justify="Justify.Between" Gap="Gap.Is4">
                        <Div Space="Space.Y.Is1">
                            <FieldLabel>Starter</FieldLabel>
                            <FieldDescription>Good for smaller teams and prototypes.</FieldDescription>
                        </Div>
                        <Radio Name="planChoiceCard" Value="Starter" Checked="true" />
                    </Div>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field Group"
                         Description="Stack related fields with consistent spacing."
                         Code="@FieldGroupCode"
                         CodeLanguage="razor">
                <FieldGroup MaxWidth="MaxWidth.IsSm">
                    <Field>
                        <FieldLabel For="field-group-name">Name</FieldLabel>
                        <Input Id="field-group-name" Placeholder="Ada Lovelace" />
                    </Field>
                    <Field>
                        <FieldLabel For="field-group-email">Email</FieldLabel>
                        <Input Id="field-group-email" Type="email" Placeholder="ada@example.com" />
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Field labels, descriptions, and controls mirror correctly in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <FieldGroup MaxWidth="MaxWidth.IsSm" dir="rtl">
                    <Field>
                        <FieldLabel For="field-rtl-email">البريد الالكتروني</FieldLabel>
                        <Input Id="field-rtl-email" Type="email" Placeholder="name@example.com" />
                        <FieldDescription>سنستخدم هذا البريد للتنبيهات المهمة.</FieldDescription>
                    </Field>
                    <Field Horizontal="true">
                        <Check Id="field-rtl-updates" Checked="true" />
                        <FieldContent>
                            <FieldLabel For="field-rtl-updates">تحديثات المنتج</FieldLabel>
                            <FieldDescription>استلم ملخصا عند توفر ميزات جديدة.</FieldDescription>
                        </FieldContent>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Responsive Layout"
                         Description="Fields can switch from stacked to grid layouts at wider breakpoints."
                         Code="@ResponsiveLayoutCode"
                         CodeLanguage="razor">
                <FieldGroup Class="grid w-full max-w-2xl gap-4 md:grid-cols-2">
                    <Field>
                        <FieldLabel For="field-responsive-first">First name</FieldLabel>
                        <Input Id="field-responsive-first" Placeholder="Ada" />
                    </Field>
                    <Field>
                        <FieldLabel For="field-responsive-last">Last name</FieldLabel>
                        <Input Id="field-responsive-last" Placeholder="Lovelace" />
                    </Field>
                    <Field Class="md:col-span-2">
                        <FieldLabel For="field-responsive-email">Email</FieldLabel>
                        <Input Id="field-responsive-email" Type="email" Placeholder="ada@example.com" />
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>
</Div>
</Div>

