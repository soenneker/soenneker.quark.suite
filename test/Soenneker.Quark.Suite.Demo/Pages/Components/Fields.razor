@page "/fields"
@using Soenneker.Quark.Forms
<PageTitle>Fields - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Combine labels, controls, and help text to compose accessible form fields and grouped inputs."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="w-full max-w-md">
                    <form>
                        <FieldGroup>
                            <FieldSet>
                                <FieldLegend>Payment Method</FieldLegend>
                                <FieldDescription>All transactions are secure and encrypted</FieldDescription>
                                <FieldGroup>
                                    <Field>
                                        <FieldLabel For="field-card-name">Name on Card</FieldLabel>
                                        <Input Id="field-card-name" Placeholder="Evil Rabbit" Required="true" />
                                    </Field>
                                    <Field>
                                        <FieldLabel For="field-card-number">Card Number</FieldLabel>
                                        <Input Id="field-card-number" Placeholder="1234 5678 9012 3456" Required="true" />
                                        <FieldDescription>Enter your 16-digit card number</FieldDescription>
                                    </Field>
                                    <Div Class="grid grid-cols-3 gap-4">
                                        <Field>
                                            <FieldLabel For="field-exp-month">Month</FieldLabel>
                                            <Select TValue="string" SelectedValue="@("")">
                                                <SelectTrigger Id="field-exp-month">
                                                    <SelectValue Placeholder="MM" />
                                                </SelectTrigger>
                                                <SelectContent>
                                                    <SelectItem TValue="string" ItemValue="@("01")" Text="01" />
                                                    <SelectItem TValue="string" ItemValue="@("02")" Text="02" />
                                                    <SelectItem TValue="string" ItemValue="@("03")" Text="03" />
                                                    <SelectItem TValue="string" ItemValue="@("04")" Text="04" />
                                                    <SelectItem TValue="string" ItemValue="@("05")" Text="05" />
                                                    <SelectItem TValue="string" ItemValue="@("06")" Text="06" />
                                                    <SelectItem TValue="string" ItemValue="@("07")" Text="07" />
                                                    <SelectItem TValue="string" ItemValue="@("08")" Text="08" />
                                                    <SelectItem TValue="string" ItemValue="@("09")" Text="09" />
                                                    <SelectItem TValue="string" ItemValue="@("10")" Text="10" />
                                                    <SelectItem TValue="string" ItemValue="@("11")" Text="11" />
                                                    <SelectItem TValue="string" ItemValue="@("12")" Text="12" />
                                                </SelectContent>
                                            </Select>
                                        </Field>
                                        <Field>
                                            <FieldLabel For="field-exp-year">Year</FieldLabel>
                                            <Select TValue="string" SelectedValue="@("")">
                                                <SelectTrigger Id="field-exp-year">
                                                    <SelectValue Placeholder="YYYY" />
                                                </SelectTrigger>
                                                <SelectContent>
                                                    <SelectItem TValue="string" ItemValue="@("2024")" Text="2024" />
                                                    <SelectItem TValue="string" ItemValue="@("2025")" Text="2025" />
                                                    <SelectItem TValue="string" ItemValue="@("2026")" Text="2026" />
                                                    <SelectItem TValue="string" ItemValue="@("2027")" Text="2027" />
                                                    <SelectItem TValue="string" ItemValue="@("2028")" Text="2028" />
                                                    <SelectItem TValue="string" ItemValue="@("2029")" Text="2029" />
                                                </SelectContent>
                                            </Select>
                                        </Field>
                                        <Field>
                                            <FieldLabel For="field-cvv">CVV</FieldLabel>
                                            <Input Id="field-cvv" Placeholder="123" Required="true" />
                                        </Field>
                                    </Div>
                                </FieldGroup>
                            </FieldSet>
                            <FieldSeparator />
                            <FieldSet>
                                <FieldLegend>Billing Address</FieldLegend>
                                <FieldDescription>The billing address associated with your payment method</FieldDescription>
                                <FieldGroup>
                                    <Field Horizontal="true">
                                        <Check Id="field-same-as-shipping" Checked="true" />
                                        <FieldLabel For="field-same-as-shipping" FontWeight="FontWeight.Normal">Same as shipping address</FieldLabel>
                                    </Field>
                                </FieldGroup>
                            </FieldSet>
                            <FieldSet>
                                <FieldGroup>
                                    <Field>
                                        <FieldLabel For="field-comments">Comments</FieldLabel>
                                        <TextArea Id="field-comments" Placeholder="Add any additional comments" Class="resize-none" />
                                    </Field>
                                </FieldGroup>
                            </FieldSet>
                            <Field Horizontal="true">
                                <Button Type="ButtonType.Submit">Submit</Button>
                                <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Cancel</Button>
                            </Field>
                        </FieldGroup>
                    </form>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input"
                         Code="@FieldCode"
                         CodeLanguage="razor">
                <FieldGroup MaxWidth="MaxWidth.IsSm">
                    <Field>
                        <FieldLabel For="field-username">Username</FieldLabel>
                        <Input Id="field-username" Placeholder="shadcn" />
                        <FieldDescription>Choose a unique username for your account.</FieldDescription>
                    </Field>
                    <Field>
                        <FieldLabel For="field-password">Password</FieldLabel>
                        <Input Id="field-password" Type="password" />
                        <FieldDescription>Must be at least 8 characters long.</FieldDescription>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Textarea"
                         Code="@TextareaCode"
                         CodeLanguage="razor">
                <FieldSet Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <FieldGroup>
                        <Field>
                            <FieldLabel For="feedback">Feedback</FieldLabel>
                            <TextArea Id="feedback" Placeholder="Your feedback helps us improve..." Rows="4" />
                            <FieldDescription>Share your thoughts about our service.</FieldDescription>
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Select"
                         Code="@SelectCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="field-department">Department</FieldLabel>
                    <Select TValue="string" SelectedValue="@("")">
                        <SelectTrigger Id="field-department">
                            <SelectValue Placeholder="Choose department" />
                        </SelectTrigger>
                        <SelectContent>
                            <SelectItem TValue="string" ItemValue="@("engineering")" Text="Engineering" />
                            <SelectItem TValue="string" ItemValue="@("marketing")" Text="Marketing" />
                            <SelectItem TValue="string" ItemValue="@("sales")" Text="Sales" />
                            <SelectItem TValue="string" ItemValue="@("support")" Text="Support" />
                        </SelectContent>
                    </Select>
                    <FieldDescription>Select your department or area of work.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Slider"
                         Code="@SliderCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="field-price-range">Price Range</FieldLabel>
                    <Slider Id="field-price-range" Min="0" Max="1000" Step="50" Values="@([200d, 800d])" />
                    <FieldDescription>Set your budget range ($200 - 800).</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Fieldset"
                         Code="@FieldsetCode"
                         CodeLanguage="razor">
                <FieldSet MaxWidth="MaxWidth.IsSm">
                    <FieldLegend>Address Information</FieldLegend>
                    <FieldDescription>We need your address to deliver your order.</FieldDescription>
                    <FieldGroup>
                        <Field>
                            <FieldLabel For="field-street-address">Street Address</FieldLabel>
                            <Input Id="field-street-address" Placeholder="123 Main St" />
                        </Field>
                        <Div Class="grid grid-cols-2 gap-4">
                            <Field>
                                <FieldLabel For="field-city">City</FieldLabel>
                                <Input Id="field-city" Placeholder="New York" />
                            </Field>
                            <Field>
                                <FieldLabel For="field-postal-code">Postal Code</FieldLabel>
                                <Input Id="field-postal-code" Placeholder="10001" />
                            </Field>
                        </Div>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkbox"
                         Code="@CheckboxCode"
                         CodeLanguage="razor">
                <FieldSet MaxWidth="MaxWidth.IsSm">
                    <FieldLegend Variant="label">Show these items on the desktop</FieldLegend>
                    <FieldDescription>Select the items you want to show on the desktop.</FieldDescription>
                    <FieldGroup Slot="checkbox-group">
                        <Field Horizontal="true">
                            <Check Id="field-hard-disks" Checked="true" />
                            <FieldLabel For="field-hard-disks" FontWeight="FontWeight.Normal">Hard disks</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="field-external-disks" />
                            <FieldLabel For="field-external-disks" FontWeight="FontWeight.Normal">External disks</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="field-cds-dvds-ipods" />
                            <FieldLabel For="field-cds-dvds-ipods" FontWeight="FontWeight.Normal">CDs, DVDs, and iPods</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="field-connected-servers" />
                            <FieldLabel For="field-connected-servers" FontWeight="FontWeight.Normal">Connected servers</FieldLabel>
                        </Field>
                    </FieldGroup>
                    <FieldSeparator />
                    <Field Horizontal="true">
                        <Check Id="field-sync-desktop" Checked="true" />
                        <FieldContent>
                            <FieldLabel For="field-sync-desktop">Sync Desktop & Documents folders</FieldLabel>
                            <FieldDescription>Your Desktop & Documents folders are being synced with iCloud Drive. You can access them from other devices.</FieldDescription>
                        </FieldContent>
                    </Field>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio"
                         Code="@RadioCode"
                         CodeLanguage="razor">
                <FieldSet MaxWidth="MaxWidth.IsSm">
                    <FieldLegend Variant="label">Subscription Plan</FieldLegend>
                    <FieldDescription>Yearly and lifetime plans offer significant savings.</FieldDescription>
                    <RadioGroup Name="field-subscription-plan" Value="yearly">
                        <Field Horizontal="true">
                            <Radio Id="field-plan-monthly" Value="monthly" />
                            <FieldLabel For="field-plan-monthly" FontWeight="FontWeight.Normal">Monthly ($9.99/month)</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Radio Id="field-plan-yearly" Value="yearly" />
                            <FieldLabel For="field-plan-yearly" FontWeight="FontWeight.Normal">Yearly ($99.99/year)</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Radio Id="field-plan-lifetime" Value="lifetime" />
                            <FieldLabel For="field-plan-lifetime" FontWeight="FontWeight.Normal">Lifetime ($299.99)</FieldLabel>
                        </Field>
                    </RadioGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Switch"
                         Code="@SwitchCode"
                         CodeLanguage="razor">
                <Field Horizontal="true" MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="field-mfa">Multi-factor authentication</FieldLabel>
                    <Switch Id="field-mfa" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Choice Card"
                         Description="Wrap Field components inside FieldLabel to create selectable field groups. This works with RadioItem, Checkbox and Switch components."
                         Code="@ChoiceCardCode"
                         CodeLanguage="razor">
                <FieldSet MaxWidth="MaxWidth.IsSm">
                    <FieldLegend Variant="label">Compute Environment</FieldLegend>
                    <FieldDescription>Select the compute environment for your cluster.</FieldDescription>
                    <RadioGroup Name="field-compute-environment" Value="kubernetes" Class="grid gap-3">
                        <FieldLabel For="field-compute-kubernetes">
                            <Field Horizontal="true" Selectable="true">
                                <Radio Id="field-compute-kubernetes" Value="kubernetes" />
                                <FieldContent>
                                    <FieldTitle>Kubernetes</FieldTitle>
                                    <FieldDescription>Run GPU workloads on a K8s cluster.</FieldDescription>
                                </FieldContent>
                            </Field>
                        </FieldLabel>
                        <FieldLabel For="field-compute-vm">
                            <Field Horizontal="true" Selectable="true">
                                <Radio Id="field-compute-vm" Value="vm" />
                                <FieldContent>
                                    <FieldTitle>Virtual Machine</FieldTitle>
                                    <FieldDescription>Access a cluster to run GPU workloads.</FieldDescription>
                                </FieldContent>
                            </Field>
                        </FieldLabel>
                    </RadioGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field Group"
                         Description="Stack Field components with FieldGroup. Add FieldSeparator to divide them."
                         Code="@FieldGroupCode"
                         CodeLanguage="razor">
                <FieldGroup MaxWidth="MaxWidth.IsSm">
                    <Field>
                        <FieldContent>
                            <FieldTitle>Responses</FieldTitle>
                            <FieldDescription>Get notified when ChatGPT responds to requests that take time, like research or image generation.</FieldDescription>
                        </FieldContent>
                        <Field Horizontal="true" Disabled="true">
                            <Check Id="field-responses-push" Checked="true" Disabled="true" />
                            <FieldLabel For="field-responses-push" FontWeight="FontWeight.Normal">Push notifications</FieldLabel>
                        </Field>
                    </Field>
                    <FieldSeparator />
                    <Field>
                        <FieldContent>
                            <FieldTitle>Tasks</FieldTitle>
                            <FieldDescription>
                                Get notified when tasks you've created have updates.
                                <Button Type="ButtonType.Link" Variant="ButtonVariant.Link" To="#" Class="h-auto p-0 text-sm">Manage tasks</Button>
                            </FieldDescription>
                        </FieldContent>
                        <Field Horizontal="true">
                            <Check Id="field-tasks-push" />
                            <FieldLabel For="field-tasks-push" FontWeight="FontWeight.Normal">Push notifications</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="field-tasks-email" />
                            <FieldLabel For="field-tasks-email" FontWeight="FontWeight.Normal">Email notifications</FieldLabel>
                        </Field>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         ShowPreviewToolbar="true"
                         PreviewLang="ar"
                         PreviewDir="rtl">
                <FieldGroup MaxWidth="MaxWidth.IsSm" dir="rtl">
                    <FieldSet>
                        <FieldLegend>طريقة الدفع</FieldLegend>
                        <FieldDescription>جميع المعاملات آمنة ومشفرة</FieldDescription>
                        <FieldGroup>
                            <Field>
                                <FieldLabel For="field-rtl-card-name">الاسم على البطاقة</FieldLabel>
                                <Input Id="field-rtl-card-name" Placeholder="أرنب شرير" />
                            </Field>
                            <Field>
                                <FieldLabel For="field-rtl-card-number">رقم البطاقة</FieldLabel>
                                <Input Id="field-rtl-card-number" Placeholder="1234 5678 9012 3456" />
                                <FieldDescription>أدخل رقم البطاقة المكون من 16 رقمًا</FieldDescription>
                            </Field>
                            <Div Class="grid grid-cols-3 gap-4">
                                <Field>
                                    <FieldLabel For="field-rtl-month">الشهر</FieldLabel>
                                    <Select TValue="string" SelectedValue="@("")">
                                        <SelectTrigger Id="field-rtl-month">
                                            <SelectValue Placeholder="ش.ش" />
                                        </SelectTrigger>
                                        <SelectContent>
                                            <SelectItem TValue="string" ItemValue="@("01")" Text="٠١" />
                                            <SelectItem TValue="string" ItemValue="@("02")" Text="٠٢" />
                                            <SelectItem TValue="string" ItemValue="@("03")" Text="٠٣" />
                                            <SelectItem TValue="string" ItemValue="@("04")" Text="٠٤" />
                                            <SelectItem TValue="string" ItemValue="@("05")" Text="٠٥" />
                                            <SelectItem TValue="string" ItemValue="@("06")" Text="٠٦" />
                                            <SelectItem TValue="string" ItemValue="@("07")" Text="٠٧" />
                                            <SelectItem TValue="string" ItemValue="@("08")" Text="٠٨" />
                                            <SelectItem TValue="string" ItemValue="@("09")" Text="٠٩" />
                                            <SelectItem TValue="string" ItemValue="@("10")" Text="١٠" />
                                            <SelectItem TValue="string" ItemValue="@("11")" Text="١١" />
                                            <SelectItem TValue="string" ItemValue="@("12")" Text="١٢" />
                                        </SelectContent>
                                    </Select>
                                </Field>
                                <Field>
                                    <FieldLabel For="field-rtl-year">السنة</FieldLabel>
                                    <Select TValue="string" SelectedValue="@("")">
                                        <SelectTrigger Id="field-rtl-year">
                                            <SelectValue Placeholder="YYYY" />
                                        </SelectTrigger>
                                        <SelectContent>
                                            <SelectItem TValue="string" ItemValue="@("2024")" Text="2024" />
                                            <SelectItem TValue="string" ItemValue="@("2025")" Text="2025" />
                                            <SelectItem TValue="string" ItemValue="@("2026")" Text="2026" />
                                            <SelectItem TValue="string" ItemValue="@("2027")" Text="2027" />
                                            <SelectItem TValue="string" ItemValue="@("2028")" Text="2028" />
                                            <SelectItem TValue="string" ItemValue="@("2029")" Text="2029" />
                                        </SelectContent>
                                    </Select>
                                </Field>
                                <Field>
                                    <FieldLabel For="field-rtl-cvv">CVV</FieldLabel>
                                    <Input Id="field-rtl-cvv" Placeholder="123" />
                                </Field>
                            </Div>
                        </FieldGroup>
                    </FieldSet>
                    <FieldSeparator />
                    <FieldSet>
                        <FieldLegend>عنوان الفوترة</FieldLegend>
                        <FieldDescription>عنوان الفوترة المرتبط بطريقة الدفع الخاصة بك</FieldDescription>
                        <FieldGroup>
                            <Field Horizontal="true">
                                <Check Id="field-rtl-same-as-shipping" Checked="true" />
                                <FieldLabel For="field-rtl-same-as-shipping" FontWeight="FontWeight.Normal">نفس عنوان الشحن</FieldLabel>
                            </Field>
                        </FieldGroup>
                    </FieldSet>
                    <Field>
                        <FieldLabel For="field-rtl-comments">تعليقات</FieldLabel>
                        <TextArea Id="field-rtl-comments" Class="resize-none" />
                    </Field>
                    <Field Horizontal="true">
                        <Button Type="ButtonType.Submit">إرسال</Button>
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">إلغاء</Button>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Responsive Layout"
                         Description="Vertical fields: Default orientation stacks label, control, and helper text—ideal for mobile-first layouts. Horizontal fields: Set orientation=&quot;horizontal&quot; on Field to align the label and control side-by-side. Pair with FieldContent to keep descriptions aligned. Responsive fields: Set orientation=&quot;responsive&quot; for automatic column layouts inside container-aware parents. Apply container-aware classes on FieldGroup to switch orientations at specific breakpoints."
                         Code="@ResponsiveLayoutCode"
                         CodeLanguage="razor">
                <FieldSet MaxWidth="MaxWidth.Is2xl">
                    <FieldLegend>Profile</FieldLegend>
                    <FieldDescription>Fill in your profile information.</FieldDescription>
                    <FieldGroup Class="@("@container/field-group")">
                        <Field Orientation="responsive">
                            <FieldContent>
                                <FieldLabel For="field-responsive-name">Name</FieldLabel>
                                <FieldDescription>Provide your full name for identification</FieldDescription>
                            </FieldContent>
                            <Input Id="field-responsive-name" Placeholder="Evil Rabbit" />
                        </Field>
                        <Field Orientation="responsive">
                            <Button Type="ButtonType.Submit">Submit</Button>
                            <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Cancel</Button>
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Validation and Errors"
                         Description="Invalid fields expose aria-invalid and FieldError content without changing the field structure."
                         Code="@FieldErrorCode"
                         CodeLanguage="razor">
                <Field IsInvalid="true" MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="deploy-branch">Deployment branch</FieldLabel>
                    <Input Id="deploy-branch" Value="main main" aria-invalid="true" />
                    <FieldDescription>Use a single git branch name.</FieldDescription>
                    <FieldError>Branch names cannot contain spaces.</FieldError>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Accessibility"
                         Description="Field descriptions and errors are associated with their controls for assistive technology."
                         Code="@AccessibilityCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="accessibility-email">Email</FieldLabel>
                    <Input Id="accessibility-email"
                           Type="email"
                           Placeholder="m@example.com"
                           aria-describedby="accessibility-email-description" />
                    <FieldDescription Id="accessibility-email-description">
                        We will use this address for account notifications.
                    </FieldDescription>
                </Field>
            </DemoSection>
        </Section>
</Div>
</Div>

