@page "/fields"
@using Microsoft.Extensions.Logging

@inject ILogger<Index> Logger

<PageTitle>Fields - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input" Description="Use the newer `Field` family for the shadcn-style label, control, and description structure." Code="@(@"<Field>
    <FieldLabel For=""textInput"">Text Input</FieldLabel>
    <Input type=""text"" id=""textInput"" placeholder=""Enter text..."" />
    <FieldDescription>This is help text for the text input field.</FieldDescription>
</Field>")">
                <Field>
                    <FieldLabel For="textInput">Text Input</FieldLabel>
                    <Input type="text" id="textInput" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="Enter text..."/>
                    <FieldDescription>This is help text for the text input field.</FieldDescription>
                </Field>

                <Field>
                    <FieldLabel For="emailInput" RequiredIndicator="true">Email Address</FieldLabel>
                    <Input type="email" id="emailInput" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="Enter email..."/>
                    <FieldDescription>We'll never share your email with anyone else.</FieldDescription>
                </Field>

                <Field>
                    <FieldLabel For="passwordInput">Password</FieldLabel>
                    <Input type="password" id="passwordInput" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="Enter password..."/>
                </Field>

                <Field>
                    <FieldLabel For="textareaInput">Comments</FieldLabel>
                    <TextArea id="textareaInput" class="min-h-20 w-full rounded-md border border-input bg-background px-3 py-2 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" rows="3" placeholder="Enter your comments..."></TextArea>
                    <FieldDescription>Please provide any additional feedback.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="FieldSet" Description="`FieldSet` and `FieldLegend` group related fields under one semantic boundary." Code="@(@"<FieldSet>
    <FieldLegend>Notification preferences</FieldLegend>
    <Field>
        <FieldLabel>Email alerts</FieldLabel>
        <Switch Label=""Enable alerts"" />
    </Field>
</FieldSet>")">
                <FieldSet>
                    <FieldLegend>Notification preferences</FieldLegend>
                    <FieldGroup>
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldLabel>Email alerts</FieldLabel>
                                <FieldDescription>Receive build and deploy notifications in your inbox.</FieldDescription>
                            </FieldContent>
                            <Switch Label="Enable alerts" />
                        </Field>
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldLabel>SMS alerts</FieldLabel>
                                <FieldDescription>Use SMS only for urgent production incidents.</FieldDescription>
                            </FieldContent>
                            <Switch Label="Enable SMS" />
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Select" Description="Field rows can host native selects or other controls through `FormControl`." Code="@(@"<FormItem Horizontal=""true"">
    <FormLabel For=""hTextInput"">Text Input</FormLabel>
    <FormControl>
        <Input type=""text"" id=""hTextInput"" class=""..."" placeholder=""Enter text...""/>
        <FormDescription>Help text for horizontal field.</FormDescription>
    </FormControl>
</FormItem>
<FormItem Horizontal=""true"">
    <FormLabel For=""hSelectInput"">Country</FormLabel>
    <FormControl>
        <select id=""hSelectInput"" class=""...""><option value="""">Choose...</option></select>
    </FormControl>
</FormItem>")">
                <FormItem Horizontal="true">
                    <FormLabel For="hTextInput">Text Input</FormLabel>
                    <FormControl>
                        <Input type="text" id="hTextInput" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="Enter text..."/>
                        <FormDescription>This is help text for the horizontal text input.</FormDescription>
                    </FormControl>
                </FormItem>

                <FormItem Horizontal="true">
                    <FormLabel For="hEmailInput" RequiredIndicator="true">Email Address</FormLabel>
                    <FormControl>
                        <Input type="email" id="hEmailInput" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="Enter email..."/>
                        <FormDescription>We'll never share your email with anyone else.</FormDescription>
                    </FormControl>
                </FormItem>

                <FormItem Horizontal="true">
                    <FormLabel For="hSelectInput">Country</FormLabel>
                    <FormControl>
                        <select id="hSelectInput" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-base ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 transition-colors md:text-sm">
                            <option value="">Choose...</option>
                            <option value="us">United States</option>
                            <option value="ca">Canada</option>
                            <option value="uk">United Kingdom</option>
                        </select>
                    </FormControl>
                </FormItem>

                <FormItem Horizontal="true">
                    <FormLabel For="hCheckboxInput">Terms and Conditions</FormLabel>
                    <FormControl>
                        <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                            <Input type="checkbox" id="hCheckboxInput" class="size-4 rounded border border-input"/>
                            <Label for="hCheckboxInput" class="text-sm font-medium leading-none cursor-pointer">I agree to the terms and conditions</Label>
                        </Div>
                    </FormControl>
                </FormItem>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field Group" Description="Group several related fields together when they belong to the same task or submission flow." Code="@(@"<form>
    <FormItem>
        <FormLabel For=""firstName"" RequiredIndicator=""true"">First Name</FormLabel>
        <Input type=""text"" id=""firstName"" placeholder=""Enter your first name""/>
    </FormItem>
    <FormItem>
        <FormLabel For=""lastName"" RequiredIndicator=""true"">Last Name</FormLabel>
        <Input type=""text"" id=""lastName"" placeholder=""Enter your last name""/>
    </FormItem>
    <FormItem Horizontal=""true"">
        <FormLabel For=""newsletter"">Newsletter</FormLabel>
        <FormControl>
            <Input type=""checkbox"" id=""newsletter""/>
            <Label for=""newsletter"">Subscribe to our newsletter</Label>
            <FormDescription>Get updates about new products.</FormDescription>
        </FormControl>
    </FormItem>
    <Button Type=""ButtonType.Submit"">Submit</Button>
</form>")">
                <form>
                    <FormItem>
                        <FormLabel For="firstName" RequiredIndicator="true">First Name</FormLabel>
                        <Input type="text" id="firstName" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="Enter your first name"/>
                    </FormItem>

                    <FormItem>
                        <FormLabel For="lastName" RequiredIndicator="true">Last Name</FormLabel>
                        <Input type="text" id="lastName" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="Enter your last name"/>
                    </FormItem>

                    <FormItem>
                        <FormLabel For="phoneNumber">Phone Number</FormLabel>
                        <Input type="tel" id="phoneNumber" class="h-9 w-full rounded-md border border-input bg-background px-3 py-1 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" placeholder="(555) 123-4567"/>
                        <FormDescription>Optional: We may contact you for order updates.</FormDescription>
                    </FormItem>

                    <FormItem Horizontal="true">
                        <FormLabel For="newsletter">Newsletter</FormLabel>
                        <FormControl>
                            <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                                <Input type="checkbox" id="newsletter" class="size-4 rounded border border-input"/>
                                <Label for="newsletter" class="text-sm font-medium leading-none cursor-pointer">Subscribe to our newsletter</Label>
                            </Div>
                            <FormDescription>Get updates about new products and special offers.</FormDescription>
                        </FormControl>
                    </FormItem>

                    <Div Margin="Margin.Is3.FromTop">
                        <Button Type="ButtonType.Submit" BackgroundColor="BackgroundColor.Primary">Submit</Button>
                        <Button Type="ButtonType.Button" BackgroundColor="BackgroundColor.Secondary" Margin="Margin.Is2.FromStart">Cancel</Button>
                    </Div>
                </form>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Textarea" Description="Textarea fields follow the same label and description pattern." Code="@(@"<FormItem>
    <FormLabel For=""notesField"">Notes</FormLabel>
    <TextArea id=""notesField"" rows=""4""></TextArea>
    <FormDescription>Add any rollout notes for the next deployment.</FormDescription>
</FormItem>")">
                <FormItem>
                    <FormLabel For="notesField">Notes</FormLabel>
                    <TextArea id="notesField" class="min-h-24 w-full rounded-md border border-input bg-background px-3 py-2 text-base shadow-xs focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50" rows="4" placeholder="Add deployment notes"></TextArea>
                    <FormDescription>Add any rollout notes for the next deployment.</FormDescription>
                </FormItem>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkbox" Description="Checkbox rows can also be expressed with `FormItem` and `FormControl`." Code="@(@"<FormItem Horizontal=""true"">
    <FormLabel For=""termsField"">Terms</FormLabel>
    <FormControl>
        <Input type=""checkbox"" id=""termsField"" />
        <Label for=""termsField"">I agree to the terms.</Label>
    </FormControl>
</FormItem>")">
                <FormItem Horizontal="true">
                    <FormLabel For="termsField">Terms</FormLabel>
                    <FormControl>
                        <Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2">
                            <Input type="checkbox" id="termsField" class="size-4 rounded border border-input" />
                            <Label for="termsField" class="text-sm font-medium leading-none cursor-pointer">I agree to the terms and conditions.</Label>
                        </Div>
                    </FormControl>
                </FormItem>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio" Description="Use a labeled field row to group related radio choices." Code="@(@"<FormItem>
    <FormLabel For=""starterPlan"">Plan</FormLabel>
    <Radio Name=""planField"" Value=""Starter"">Starter</Radio>
    <Radio Name=""planField"" Value=""Pro"">Pro</Radio>
</FormItem>")">
                <FormItem>
                    <FormLabel For="starterPlan">Plan</FormLabel>
                    <Radio Name="planField" Value="Starter" id="starterPlan">Starter</Radio>
                    <Radio Name="planField" Value="Pro">Pro</Radio>
                    <FormDescription>Choose the plan that best fits your team.</FormDescription>
                </FormItem>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Switch" Description="Switches pair naturally with field descriptions for settings pages." Code="@(@"<FormItem Horizontal=""true"">
    <FormLabel For=""autoDeploy"">Auto deploy</FormLabel>
    <FormControl>
        <Switch Label=""Enable on merge"" />
    </FormControl>
</FormItem>")">
                <FormItem Horizontal="true">
                    <FormLabel For="autoDeploy">Auto deploy</FormLabel>
                    <FormControl>
                        <Switch Label="Enable on merge" />
                        <FormDescription>Deploy automatically when pull requests land on `main`.</FormDescription>
                    </FormControl>
                </FormItem>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Choice Card" Description="A bordered `FormItem` is the closest Quark equivalent to the shadcn choice-card field pattern." Code="@(@"<FormItem class=""rounded-lg border p-4"">
    <FormLabel>Starter</FormLabel>
    <FormDescription>Good for smaller teams and prototypes.</FormDescription>
</FormItem>")">
                <FormItem Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4">
                    <Div Display="Display.Flex" AlignUtility="Align.ItemsStart.JustifyBetween" Gap="Gap.Is4">
                        <Div Space="Space.Y.Is1">
                            <FormLabel>Starter</FormLabel>
                            <FormDescription>Good for smaller teams and prototypes.</FormDescription>
                        </Div>
                        <Radio Name="planChoiceCard" Value="Starter" Checked="true" />
                    </Div>
                </FormItem>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code{

    protected override void OnInitialized()
    {
    }

}