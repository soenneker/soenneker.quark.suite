@page "/breadcrumbs"

<PageTitle>Breadcrumbs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Collapsed breadcrumb trail with an overflow menu in the middle."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbList>
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Home</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <Dropdown>
                                <DropdownToggle AsChild="true">
                                    <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Ghost">
                                        <BreadcrumbEllipsis />
                                        <Span ScreenReader="ScreenReader.Only">Toggle menu</Span>
                                    </Button>
                                </DropdownToggle>
                                <DropdownMenu>
                                    <DropdownItem>Documentation</DropdownItem>
                                    <DropdownItem>Themes</DropdownItem>
                                    <DropdownItem>GitHub</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Components</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbPage>Breadcrumb</BreadcrumbPage>
                        </BreadcrumbItem>
                    </BreadcrumbList>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="Shadcn-aligned Basic example."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbList>
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Home</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <Dropdown>
                                <DropdownToggle AsChild="true">
                                    <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Ghost">
                                        <BreadcrumbEllipsis />
                                        <Span ScreenReader="ScreenReader.Only">Toggle menu</Span>
                                    </Button>
                                </DropdownToggle>
                                <DropdownMenu>
                                    <DropdownItem>Documentation</DropdownItem>
                                    <DropdownItem>Themes</DropdownItem>
                                    <DropdownItem>GitHub</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Components</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbPage>Breadcrumb</BreadcrumbPage>
                        </BreadcrumbItem>
                    </BreadcrumbList>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Separator"
                         Description="Breadcrumb separators can render custom content instead of only the default chevron."
                         Code="@CustomSeparatorCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbList>
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Home</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator>@DotSeparator</BreadcrumbSeparator>
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Components</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator>@DotSeparator</BreadcrumbSeparator>
                        <BreadcrumbItem>
                            <BreadcrumbPage>Breadcrumb</BreadcrumbPage>
                        </BreadcrumbItem>
                    </BreadcrumbList>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown"
                         Description="A breadcrumb item can host a dropdown when several sibling paths stay collapsed."
                         Code="@DropdownCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbList>
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Home</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator>@DotSeparator</BreadcrumbSeparator>
                        <BreadcrumbItem>
                            <Dropdown>
                                <DropdownToggle Class="flex items-center gap-1">
                                    Components
                                    <Icon Name="LucideIcon.ChevronDown" Class="size-3.5" />
                                </DropdownToggle>
                                <DropdownMenu>
                                    <DropdownItem>Documentation</DropdownItem>
                                    <DropdownItem>Themes</DropdownItem>
                                    <DropdownItem>GitHub</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator>@DotSeparator</BreadcrumbSeparator>
                        <BreadcrumbItem>
                            <BreadcrumbPage>Breadcrumb</BreadcrumbPage>
                        </BreadcrumbItem>
                    </BreadcrumbList>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Collapsed"
                         Description="Use BreadcrumbEllipsis as a dropdown trigger when a long path should collapse in the middle."
                         Code="@CollapsedCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbList>
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Home</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <Dropdown>
                                <DropdownToggle AsChild="true">
                                    <Button Size="ButtonSize.IconSm" Variant="ButtonVariant.Ghost">
                                        <BreadcrumbEllipsis />
                                        <Span ScreenReader="ScreenReader.Only">Toggle menu</Span>
                                    </Button>
                                </DropdownToggle>
                                <DropdownMenu>
                                    <DropdownItem>Documentation</DropdownItem>
                                    <DropdownItem>Themes</DropdownItem>
                                    <DropdownItem>GitHub</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Components</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbPage>Breadcrumb</BreadcrumbPage>
                        </BreadcrumbItem>
                    </BreadcrumbList>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link Component"
                         Description="BreadcrumbLink can pass its styling into a child Quark link with AsChild."
                         Code="@LinkComponentCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbList>
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Home</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbLink AsChild="true">
                                <Anchor To="#">Components</Anchor>
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        <BreadcrumbItem>
                            <BreadcrumbPage>Breadcrumb</BreadcrumbPage>
                        </BreadcrumbItem>
                    </BreadcrumbList>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Breadcrumb separators and item flow render correctly in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Breadcrumb Dir="rtl">
                            <BreadcrumbList>
                                <BreadcrumbItem>
                                    <BreadcrumbLink AsChild="true">
                                        <Anchor To="#">الرئيسية</Anchor>
                                    </BreadcrumbLink>
                                </BreadcrumbItem>
                                <BreadcrumbSeparator />
                                <BreadcrumbItem>
                                    <BreadcrumbLink AsChild="true">
                                        <Anchor To="#">المكونات</Anchor>
                                    </BreadcrumbLink>
                                </BreadcrumbItem>
                                <BreadcrumbSeparator />
                                <BreadcrumbItem>
                                    <BreadcrumbPage>Breadcrumb</BreadcrumbPage>
                                </BreadcrumbItem>
                            </BreadcrumbList>
                        </Breadcrumb>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

