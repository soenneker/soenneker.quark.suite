@page "/breadcrumbs"

<PageTitle>Breadcrumbs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A basic breadcrumb with a home link, a components link, and the current page."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="">Home</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="components">Components</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem Active="true">Breadcrumb</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Ellipsis"
                         Description="Collapsed middle segment opens a menu from an ellipsis trigger, matching the shadcn overflow pattern."
                         Code="@EllipsisCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="">Home</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem>
                        <Dropdown>
                            <DropdownToggle Class="flex items-center gap-1 bg-transparent px-2 py-1 text-sm font-normal text-muted-foreground shadow-none hover:bg-accent hover:text-foreground">
                                <BreadcrumbEllipsis />
                                <Span Class="sr-only">Toggle menu</Span>
                            </DropdownToggle>
                            <DropdownMenu>
                                <DropdownItem>Documentation</DropdownItem>
                                <DropdownItem>Themes</DropdownItem>
                                <DropdownItem>GitHub</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </BreadcrumbItem>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="components">Components</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem Active="true">Breadcrumb</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Separator"
                         Description="Breadcrumb separators can render custom content instead of only plain text."
                         Code="@CustomSeparatorCode"
                         CodeLanguage="razor">
                <Breadcrumb SeparatorContent="@DotSeparator">
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="">Home</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="components">Components</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem Active="true">Breadcrumb</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown"
                         Description="A breadcrumb item can host a dropdown when several sibling paths need to stay collapsed."
                         Code="@DropdownCode"
                         CodeLanguage="razor">
                <Breadcrumb SeparatorContent="@DotSeparator">
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="">Home</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem>
                        <Dropdown>
                            <DropdownToggle Class="flex items-center gap-1 bg-transparent px-2 py-1 text-sm font-normal text-muted-foreground shadow-none hover:bg-accent hover:text-foreground">
                                Components
                                <Icon Name="LucideIcon.ChevronDown" Class="size-3.5" />
                            </DropdownToggle>
                            <DropdownMenu>
                                <DropdownItem>Documentation</DropdownItem>
                                <DropdownItem>Themes</DropdownItem>
                                <DropdownItem>GitHub</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </BreadcrumbItem>
                    <BreadcrumbItem Active="true">Breadcrumb</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Collapsed"
                         Description="Use BreadcrumbEllipsis when a long path should collapse in the middle."
                         Code="@CollapsedCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="">Home</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem>
                        <BreadcrumbEllipsis />
                    </BreadcrumbItem>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="components">Components</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem Active="true">Breadcrumb</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link Component"
                         Description="Breadcrumb items can pass breadcrumb-link styling into a child Quark link."
                         Code="@LinkComponentCode"
                         CodeLanguage="razor">
                <Breadcrumb>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="">Home</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="components">Components</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem Active="true">Breadcrumb</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Breadcrumb separators and item flow now render correctly in right-to-left layouts."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div class="w-full text-right">
                        <Breadcrumb>
                            <BreadcrumbItem AsChild="true">
                                <Anchor To="">الرئيسية</Anchor>
                            </BreadcrumbItem>
                            <BreadcrumbItem AsChild="true">
                                <Anchor To="components">المكونات</Anchor>
                            </BreadcrumbItem>
                            <BreadcrumbItem Active="true">Breadcrumb</BreadcrumbItem>
                        </Breadcrumb>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Text-based separators when you want a minimal trail without icon separators.
                </Paragraph>
            </Div>

            <DemoSection Title="Text Divider"
                         Description="Quark still supports a simple text divider for lightweight breadcrumb trails."
                         Code="@TextDividerCode"
                         CodeLanguage="razor">
                <Breadcrumb DividerText="•">
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="">Home</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem AsChild="true">
                        <Anchor To="products">Products</Anchor>
                    </BreadcrumbItem>
                    <BreadcrumbItem Active="true">Phones</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>
    </Div>
</Div>

