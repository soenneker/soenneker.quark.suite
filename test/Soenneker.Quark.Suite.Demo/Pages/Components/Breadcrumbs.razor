@page "/breadcrumbs"
@using Microsoft.Extensions.Logging
@inject ILogger<Breadcrumbs> Logger

<PageTitle>Breadcrumbs - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic" Description="Simple breadcrumb trail with Home, Library, and current page."
                        Code="@(@"<Breadcrumb>
    <BreadcrumbItem To="""">Home</BreadcrumbItem>
    <BreadcrumbItem To=""library"">Library</BreadcrumbItem>
    <BreadcrumbItem Active=""true"">Data</BreadcrumbItem>
</Breadcrumb>")">
                <Breadcrumb>
                    <BreadcrumbItem To="">Home</BreadcrumbItem>
                    <BreadcrumbItem To="library">Library</BreadcrumbItem>
                    <BreadcrumbItem Active="true">Data</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Separator" Description="Use text dividers when the path benefits from a stronger visual separator." Code="@(@"<Breadcrumb DividerText=""•"">
    <BreadcrumbItem To="""">Home</BreadcrumbItem>
    <BreadcrumbItem To=""products"">Products</BreadcrumbItem>
    <BreadcrumbItem Active=""true"">Phones</BreadcrumbItem>
</Breadcrumb>")">
                <Breadcrumb DividerText="•">
                    <BreadcrumbItem To="">Home</BreadcrumbItem>
                    <BreadcrumbItem To="products">Products</BreadcrumbItem>
                    <BreadcrumbItem Active="true">Phones</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dropdown" Description="Use a dropdown in the middle of a breadcrumb trail when several sibling paths need to stay collapsed." Code="@(@"<Div Class=""flex items-center gap-2 text-sm"">
    <Breadcrumb>
        <BreadcrumbItem To="""">Home</BreadcrumbItem>
    </Breadcrumb>
    <Dropdown>
        <DropdownToggle Class=""bg-transparent px-2 py-1 text-sm hover:bg-accent"">Sections</DropdownToggle>
        <DropdownMenu>
            <DropdownItem>Design</DropdownItem>
            <DropdownItem>Engineering</DropdownItem>
        </DropdownMenu>
    </Dropdown>
    <Breadcrumb>
        <BreadcrumbItem Active=""true"">Profile</BreadcrumbItem>
    </Breadcrumb>
</Div>")">
                <Div Class="flex items-center gap-2 text-sm">
                    <Breadcrumb>
                        <BreadcrumbItem To="">Home</BreadcrumbItem>
                    </Breadcrumb>
                    <Dropdown>
                        <DropdownToggle Class="bg-transparent px-2 py-1 text-sm hover:bg-accent">Sections</DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem>Design</DropdownItem>
                            <DropdownItem>Engineering</DropdownItem>
                            <DropdownItem>Support</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                    <Breadcrumb>
                        <BreadcrumbItem Active="true">Profile</BreadcrumbItem>
                    </Breadcrumb>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Collapsed" Description="Use a simplified middle section when the full hierarchy would be too long to show at once." Code="@(@"<Breadcrumb>
    <BreadcrumbItem To="""">Home</BreadcrumbItem>
    <BreadcrumbItem To=""products"">Products</BreadcrumbItem>
    <BreadcrumbItem Active=""true"">...</BreadcrumbItem>
</Breadcrumb>")">
                <Breadcrumb>
                    <BreadcrumbItem To="">Home</BreadcrumbItem>
                    <BreadcrumbItem To="products">Products</BreadcrumbItem>
                    <BreadcrumbItem Active="true">...</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link Component" Description="Quark breadcrumb items already render as links when a `To` value is supplied." Code="@(@"<Breadcrumb>
    <BreadcrumbItem To=""docs"">Documentation</BreadcrumbItem>
    <BreadcrumbItem To=""docs/api"">API Reference</BreadcrumbItem>
    <BreadcrumbItem Active=""true"">OAuth 2.0</BreadcrumbItem>
</Breadcrumb>")">
                <Breadcrumb>
                    <BreadcrumbItem To="docs">Documentation</BreadcrumbItem>
                    <BreadcrumbItem To="docs/api">API Reference</BreadcrumbItem>
                    <BreadcrumbItem Active="true">OAuth 2.0</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With aria label" Description="Set AriaLabel on Breadcrumb for accessibility." Code="@(@"<Breadcrumb AriaLabel=""Product navigation breadcrumb"">
    <BreadcrumbItem To="""">Store</BreadcrumbItem>
    <BreadcrumbItem To=""category/electronics"">Electronics</BreadcrumbItem>
    <BreadcrumbItem To=""category/electronics/computers"">Computers</BreadcrumbItem>
    <BreadcrumbItem Active=""true"">Laptops</BreadcrumbItem>
</Breadcrumb>")">
                <Breadcrumb AriaLabel="Product navigation breadcrumb">
                    <BreadcrumbItem To="">Store</BreadcrumbItem>
                    <BreadcrumbItem To="category/electronics">Electronics</BreadcrumbItem>
                    <BreadcrumbItem To="category/electronics/computers">Computers</BreadcrumbItem>
                    <BreadcrumbItem Active="true">Laptops</BreadcrumbItem>
                </Breadcrumb>
            </DemoSection>
        </Section>

    </Div>
</Div>

@code {
    protected override void OnInitialized()
    {
        Logger.LogInformation("Breadcrumbs demo page initialized");
    }
}
