@page "/input-demo"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Input Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Code="@DemoCode">
                <Field Class="max-w-md">
                    <FieldLabel For="input-demo-api-key">API Key</FieldLabel>
                    <Input Id="input-demo-api-key" Type="password" Placeholder="sk-..." />
                    <FieldDescription>Your API key is encrypted and stored securely.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disabled fields propagate state through the field wrapper."
                         Code="@DisabledCode">
                <Field Class="max-w-md" Disabled="true">
                    <FieldLabel For="input-demo-disabled">Email</FieldLabel>
                    <Input Id="input-demo-disabled" Type="email" Placeholder="Email" Disabled="true" />
                    <FieldDescription>This field is currently disabled.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="File"
                         Description="File inputs use the same base component and field composition as other text fields."
                         Code="@FileCode">
                <Field Class="max-w-md">
                    <FieldLabel For="picture">Picture</FieldLabel>
                    <Input Id="picture" Type="file" />
                    <FieldDescription>Select a picture to upload.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show broader Quark form compositions beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input Group"
                         Description="Use an input group when the field needs affixes or inline helpers."
                         Code="@InputGroupCode">
                <Div class="max-w-md">
                    <InputGroup>
                        <InputGroupAddon>https://</InputGroupAddon>
                        <InputGroupInput Placeholder="acme.dev" />
                    </InputGroup>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button Group"
                         Description="Pair inputs with adjacent actions when search or command entry needs immediate follow-up buttons."
                         Code="@ButtonGroupCode">
                <ButtonGroup>
                    <Input Type="search" Placeholder="Search docs" Class="min-w-64" />
                    <Button Variant="ButtonVariant.Outline">Clear</Button>
                    <Button>Search</Button>
                </ButtonGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="Quark inputs also bind directly into `EditForm` validation workflows."
                         Code="@FormCode">
                <EditForm Model="_formModel" OnValidSubmit="HandleValidSubmit" class="max-w-md space-y-4">
                    <DataAnnotationsValidator />

                    <Field>
                        <FieldLabel For="input-form-name">Name</FieldLabel>
                        <Input Id="input-form-name" Type="text" @bind-Value="_formModel.Name" Placeholder="Enter your name" />
                        <ValidationMessage For="@(() => _formModel.Name)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                    </Field>

                    <Field>
                        <FieldLabel For="input-form-email">Email</FieldLabel>
                        <Input Id="input-form-email" Type="email" @bind-Value="_formModel.Email" Placeholder="Enter your email" />
                        <ValidationMessage For="@(() => _formModel.Email)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                    </Field>

                    <Div Display="Display.Flex" Gap="Gap.Is4">
                        <Button Type="ButtonType.Submit">Submit</Button>
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Reset</Button>
                    </Div>

                    @if (!string.IsNullOrEmpty(_formMessage))
                    {
                        <Div class="rounded-lg border bg-card p-4">
                            <Paragraph TextSize="TextSize.Sm">@_formMessage</Paragraph>
                        </Div>
                    }
                </EditForm>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Field>
    <FieldLabel For=""input-demo-api-key"">API Key</FieldLabel>
    <Input Id=""input-demo-api-key"" Type=""password"" Placeholder=""sk-..."" />
    <FieldDescription>Your API key is encrypted and stored securely.</FieldDescription>
</Field>";

    private const string DisabledCode =
@"<Field Disabled=""true"">
    <FieldLabel For=""input-demo-disabled"">Email</FieldLabel>
    <Input Id=""input-demo-disabled"" Type=""email"" Placeholder=""Email"" Disabled=""true"" />
    <FieldDescription>This field is currently disabled.</FieldDescription>
</Field>";

    private const string FileCode =
@"<Field>
    <FieldLabel For=""picture"">Picture</FieldLabel>
    <Input Id=""picture"" Type=""file"" />
    <FieldDescription>Select a picture to upload.</FieldDescription>
</Field>";

    private const string InputGroupCode =
@"<InputGroup>
    <InputGroupAddon>https://</InputGroupAddon>
    <InputGroupInput Placeholder=""acme.dev"" />
</InputGroup>";

    private const string ButtonGroupCode =
@"<ButtonGroup>
    <Input Type=""search"" Placeholder=""Search docs"" Class=""min-w-64"" />
    <Button Variant=""ButtonVariant.Outline"">Clear</Button>
    <Button>Search</Button>
</ButtonGroup>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnValidSubmit=""HandleValidSubmit"" class=""max-w-md space-y-4"">
    <DataAnnotationsValidator />
    <Field>
        <FieldLabel For=""input-form-name"">Name</FieldLabel>
        <Input Id=""input-form-name"" Type=""text"" @bind-Value=""_formModel.Name"" Placeholder=""Enter your name"" />
        <ValidationMessage For=""@(() => _formModel.Name)"" TextSize=""TextSize.Sm"" TextColor=""TextColor.Destructive"" />
    </Field>
    <Field>
        <FieldLabel For=""input-form-email"">Email</FieldLabel>
        <Input Id=""input-form-email"" Type=""email"" @bind-Value=""_formModel.Email"" Placeholder=""Enter your email"" />
        <ValidationMessage For=""@(() => _formModel.Email)"" TextSize=""TextSize.Sm"" TextColor=""TextColor.Destructive"" />
    </Field>
    <Div Display=""Display.Flex"" Gap=""Gap.Is4"">
        <Button Type=""ButtonType.Submit"">Submit</Button>
        <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Outline"">Reset</Button>
    </Div>
</EditForm>";

    private InputFormModel _formModel = new();
    private string? _formMessage;

    private void HandleValidSubmit()
    {
        _formMessage = $"Form submitted! Name: {_formModel.Name}, Email: {_formModel.Email}";
    }

    private void ResetForm()
    {
        _formModel = new();
        _formMessage = null;
    }

    private sealed class InputFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(50, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 50 characters.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string? Email { get; set; }
    }
}
