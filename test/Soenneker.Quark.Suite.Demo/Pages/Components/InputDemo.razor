@page "/input-demo"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Input Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="A single input with the standard email placeholder."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div MaxWidth="MaxWidth.IsXs">
                    <Input Type="email" Placeholder="Email" />
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Fields, validation, layout, and grouped input patterns beyond the core example.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field"
                         Description="Compose label, control, and description with Field."
                         Code="@FieldCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-field-username">Username</FieldLabel>
                    <Input Id="input-field-username" Type="text" Placeholder="Enter your username" />
                    <FieldDescription>Choose a unique username for your account.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Field Group"
                         Description="Stack multiple fields for simple forms."
                         Code="@FieldGroupCode"
                         CodeLanguage="razor">
                <FieldGroup Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <Field>
                        <FieldLabel For="fieldgroup-name">Name</FieldLabel>
                        <Input Id="fieldgroup-name" Type="text" Placeholder="Jordan Lee" />
                    </Field>
                    <Field>
                        <FieldLabel For="fieldgroup-email">Email</FieldLabel>
                        <Input Id="fieldgroup-email" Type="email" Placeholder="name@example.com" />
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disable the input and set data-disabled on the field."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs" Disabled="true">
                    <FieldLabel For="input-demo-disabled">Email</FieldLabel>
                    <Input Id="input-demo-disabled" Type="email" Placeholder="Email" Disabled="true" />
                    <FieldDescription>This field is currently disabled.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Mark the field invalid for error styling and aria-invalid on the control."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs" IsInvalid="true">
                    <FieldLabel For="input-invalid">Invalid Input</FieldLabel>
                    <Input Id="input-invalid" Placeholder="Error" />
                    <FieldDescription>This field contains validation errors.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="File"
                         Description="Use type file for uploads."
                         Code="@FileCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="picture">Picture</FieldLabel>
                    <Input Id="picture" Type="file" />
                    <FieldDescription>Select a picture to upload.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Inline"
                         Description="Horizontal field layout with a search control and button."
                         Code="@InlineCode"
                         CodeLanguage="razor">
                <Field Class="max-w-xs w-full" Horizontal="true">
                    <Input Type="search" Placeholder="Search..." />
                    <Button Type="ButtonType.Button" Variant="ButtonVariant.Default">Search</Button>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Grid"
                         Description="Place inputs side by side with a grid on the field group."
                         Code="@GridCode"
                         CodeLanguage="razor">
                <FieldGroup Class="grid w-full max-w-sm grid-cols-2 gap-4">
                    <Field>
                        <FieldLabel For="first-name">First Name</FieldLabel>
                        <Input Id="first-name" Type="text" Placeholder="Jordan" />
                    </Field>
                    <Field>
                        <FieldLabel For="last-name">Last Name</FieldLabel>
                        <Input Id="last-name" Type="text" Placeholder="Lee" />
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Required"
                         Description="Use the required attribute for mandatory fields."
                         Code="@RequiredCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-required" RequiredIndicator="true">Required Field</FieldLabel>
                    <Input Id="input-required" Placeholder="This field is required" Required="true" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Badge"
                         Description="Add a badge in the label row for beta or recommended fields."
                         Code="@BadgeCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-badge" Class="flex w-full items-center gap-2">
                        Webhook URL
                        <Badge Variant="BadgeVariant.Secondary" Class="ml-auto">Beta</Badge>
                    </FieldLabel>
                    <Input Id="input-badge" Type="url" Placeholder="https://api.example.com/webhook" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Input Group"
                         Description="Prefix or suffix content with InputGroup."
                         Code="@InputGroupSectionCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-group-url">Website URL</FieldLabel>
                    <InputGroup>
                        <InputGroupAddon>https://</InputGroupAddon>
                        <InputGroupInput Id="input-group-url" Placeholder="example.com" />
                    </InputGroup>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Button Group"
                         Description="Attach actions to an input with ButtonGroup."
                         Code="@ButtonGroupCode"
                         CodeLanguage="razor">
                <Field MaxWidth="MaxWidth.IsXs">
                    <FieldLabel For="input-button-group">Search</FieldLabel>
                    <ButtonGroup>
                        <Input Id="input-button-group" Type="search" Placeholder="Type to search..." />
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline">Search</Button>
                    </ButtonGroup>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="Inputs inside EditForm with validation messages."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <EditForm Model="_formModel" OnValidSubmit="HandleValidSubmit" class="max-w-sm space-y-4">
                    <DataAnnotationsValidator />

                    <Field>
                        <FieldLabel For="input-form-name">Name</FieldLabel>
                        <Input Id="input-form-name" Type="text" @bind-Value="_formModel.Name" Placeholder="Evil Rabbit" />
                        <ValidationMessage For="@(() => _formModel.Name)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                    </Field>

                    <Field>
                        <FieldLabel For="input-form-email">Email</FieldLabel>
                        <Input Id="input-form-email" Type="email" @bind-Value="_formModel.Email" Placeholder="name@example.com" />
                        <ValidationMessage For="@(() => _formModel.Email)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                    </Field>

                    <Div Display="Display.Flex" Gap="Gap.Is4">
                        <Button Type="ButtonType.Submit">Submit</Button>
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Reset</Button>
                    </Div>

                    @if (!string.IsNullOrEmpty(_formMessage))
                    {
                        <Div class="rounded-lg border bg-card p-4">
                            <Paragraph TextSize="TextSize.Sm">@_formMessage</Paragraph>
                        </Div>
                    }
                </EditForm>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Fields and inputs respect direction from DirectionProvider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Field MaxWidth="MaxWidth.IsXs">
                        <FieldLabel For="input-rtl-api-key">مفتاح API</FieldLabel>
                        <Input Id="input-rtl-api-key" Type="password" Placeholder="sk-..." />
                        <FieldDescription>مفتاح API الخاص بك مشفر ويتم تخزينه بأمان.</FieldDescription>
                    </Field>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string BasicCode =
@"<Div Class=""max-w-xs"">
    <Input Type=""email"" Placeholder=""Email"" />
</Div>";

    private const string FieldCode =
@"<Field Class=""max-w-xs"">
    <FieldLabel For=""input-field-username"">Username</FieldLabel>
    <Input Id=""input-field-username"" Type=""text"" Placeholder=""Enter your username"" />
    <FieldDescription>Choose a unique username for your account.</FieldDescription>
</Field>";

    private const string FieldGroupCode =
@"<FieldGroup Class=""w-full max-w-xs"">
    <Field>
        <FieldLabel For=""fieldgroup-name"">Name</FieldLabel>
        <Input Id=""fieldgroup-name"" Type=""text"" Placeholder=""Jordan Lee"" />
    </Field>
    <Field>
        <FieldLabel For=""fieldgroup-email"">Email</FieldLabel>
        <Input Id=""fieldgroup-email"" Type=""email"" Placeholder=""name@example.com"" />
    </Field>
</FieldGroup>";

    private const string DisabledCode =
@"<Field Class=""max-w-xs"" Disabled=""true"">
    <FieldLabel For=""input-demo-disabled"">Email</FieldLabel>
    <Input Id=""input-demo-disabled"" Type=""email"" Placeholder=""Email"" Disabled=""true"" />
    <FieldDescription>This field is currently disabled.</FieldDescription>
</Field>";

    private const string InvalidCode =
@"<Field Class=""max-w-xs"" IsInvalid=""true"">
    <FieldLabel For=""input-invalid"">Invalid Input</FieldLabel>
    <Input Id=""input-invalid"" Placeholder=""Error"" />
    <FieldDescription>This field contains validation errors.</FieldDescription>
</Field>";

    private const string FileCode =
@"<Field Class=""max-w-xs"">
    <FieldLabel For=""picture"">Picture</FieldLabel>
    <Input Id=""picture"" Type=""file"" />
    <FieldDescription>Select a picture to upload.</FieldDescription>
</Field>";

    private const string InlineCode =
@"<Field Class=""max-w-xs w-full"" Horizontal=""true"">
    <Input Type=""search"" Placeholder=""Search..."" />
    <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Default"">Search</Button>
</Field>";

    private const string GridCode =
@"<FieldGroup Class=""grid w-full max-w-sm grid-cols-2 gap-4"">
    <Field>
        <FieldLabel For=""first-name"">First Name</FieldLabel>
        <Input Id=""first-name"" Type=""text"" Placeholder=""Jordan"" />
    </Field>
    <Field>
        <FieldLabel For=""last-name"">Last Name</FieldLabel>
        <Input Id=""last-name"" Type=""text"" Placeholder=""Lee"" />
