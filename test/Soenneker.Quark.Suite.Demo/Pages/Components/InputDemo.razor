@page "/input-demo"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Input Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div class="space-y-4">
        <DemoSection Title="Field" Description="Use Input for straightforward string-based text fields and pair it with labels or descriptions when needed." Code="@(@"<Div class=""space-y-2"">
    <Label class=""text-sm font-medium"">Email</Label>
    <Input Type=""email"" Placeholder=""you@example.com"" />
</Div>")">
            <Div class="rounded-lg border bg-card p-6 space-y-4">
                <Div class="space-y-2 max-w-md">
                    <Label class="text-sm font-medium">Email</Label>
                    <Input Type="email" Placeholder="you@example.com" />
                    <Paragraph class="text-sm text-muted-foreground">Use the thin input component when you only need the field itself.</Paragraph>
                </Div>
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Basic" Description="A simple text input with placeholder." Code="@(@"<Input Type=""text"" Placeholder=""Enter your text..."" />")">
            <Div class="max-w-md">
                <Input Type="text" Placeholder="Enter your text..." />
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Field Group" Description="Stack related inputs under one bordered group when they belong to the same task." Code="@(@"<Div class=""rounded-lg border p-4 space-y-3"">
    <Input Type=""text"" Placeholder=""First name"" />
    <Input Type=""text"" Placeholder=""Last name"" />
</Div>")">
            <Div class="rounded-lg border bg-card p-4 space-y-3 max-w-md">
                <Input Type="text" Placeholder="First name" />
                <Input Type="text" Placeholder="Last name" />
                <Input Type="email" Placeholder="Email address" />
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Input Types" Description="Different HTML input types." Code="@(@"<Input Type=""text"" Placeholder=""Text"" />
<Input Type=""email"" Placeholder=""you@example.com"" />
<Input Type=""password"" Placeholder=""Password"" />
<Input Type=""number"" Placeholder=""123"" />
<Input Type=""search"" Placeholder=""Search..."" />
<Input Type=""date"" />
<Input Type=""time"" />
<Input Type=""file"" />")">
            <Div class="space-y-4 max-w-md">
                <Div class="space-y-2"><Label class="text-sm font-medium">Text</Label><Input Type="text" Placeholder="Text" /></Div>
                <Div class="space-y-2"><Label class="text-sm font-medium">Email</Label><Input Type="email" Placeholder="you@example.com" /></Div>
                <Div class="space-y-2"><Label class="text-sm font-medium">Password</Label><Input Type="password" Placeholder="Password" /></Div>
                <Div class="space-y-2"><Label class="text-sm font-medium">Number</Label><Input Type="number" Placeholder="123" /></Div>
                <Div class="space-y-2"><Label class="text-sm font-medium">Search</Label><Input Type="search" Placeholder="Search..." /></Div>
                <Div class="space-y-2"><Label class="text-sm font-medium">Date</Label><Input Type="date" /></Div>
                <Div class="space-y-2"><Label class="text-sm font-medium">Time</Label><Input Type="time" /></Div>
                <Div class="space-y-2"><Label class="text-sm font-medium">File</Label><Input Type="file" /></Div>
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Inline" Description="Inline inputs work well when the field needs to live beside a label or action." Code="@(@"<Div class=""flex items-center gap-3"">
    <Label class=""min-w-24 text-sm font-medium"">Domain</Label>
    <Input Type=""text"" Value=""acme"" />
</Div>")">
            <Div class="flex flex-wrap items-center gap-3 max-w-xl">
                <Label class="min-w-24 text-sm font-medium">Domain</Label>
                <Input Type="text" Value="acme" Class="max-w-xs" />
                <Paragraph class="text-sm text-muted-foreground">.quark.dev</Paragraph>
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Grid" Description="Use grid layouts for multi-column input forms." Code="@(@"<Div class=""grid gap-4 md:grid-cols-2"">
    <Input Type=""text"" Placeholder=""City"" />
    <Input Type=""text"" Placeholder=""State"" />
</Div>")">
            <Div class="grid gap-4 max-w-2xl md:grid-cols-2">
                <Input Type="text" Placeholder="City" />
                <Input Type="text" Placeholder="State" />
                <Input Type="text" Placeholder="Postal code" />
                <Input Type="text" Placeholder="Country" />
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Disabled" Description="Input states for disabled and required forms." Code="@(@"<Input Type=""text"" Placeholder=""Disabled input"" Disabled=""true"" Value=""Cannot edit this"" />
<Input Type=""text"" Placeholder=""Required input"" Required=""true"" />")">
            <Div class="max-w-md space-y-4">
                <Input Type="text" Placeholder="Disabled input" Disabled="true" Value="Cannot edit this" />
                <Input Type="text" Placeholder="Required input" Required="true" />
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Required" Description="Required indicators are often paired with the input rather than baked into the control itself." Code="@(@"<Div class=""space-y-2"">
    <Label class=""text-sm font-medium"">Project name *</Label>
    <Input Type=""text"" Required=""true"" Placeholder=""Acme redesign"" />
</Div>")">
            <Div class="space-y-2 max-w-md">
                <Label class="text-sm font-medium">Project name *</Label>
                <Input Type="text" Required="true" Placeholder="Acme redesign" />
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Invalid" Description="Inputs with ARIA labels and invalid state." Code="@(@"<Input Type=""text"" Placeholder=""Full name"" aria-label=""User full name"" />
<Input Type=""text"" Placeholder=""Username"" aria-describedby=""username-help"" />
<Paragraph id=""username-help"" class=""text-sm text-muted-foreground"">Username must be unique.</Paragraph>
<Input Type=""email"" Value=""invalid-email"" aria-invalid=""true"" />")">
            <Div class="max-w-md space-y-4">
                <Input Type="text" Placeholder="Full name" aria-label="User full name" />
                <Input Type="text" Placeholder="Username" aria-describedby="username-help" />
                <Paragraph id="username-help" class="text-sm text-muted-foreground">Username must be unique.</Paragraph>
                <Input Type="email" Value="invalid-email" aria-invalid="true" />
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Badge" Description="Pair compact status badges with inputs when the field has async validation or environment context." Code="@(@"<Div class=""flex items-center gap-3"">
    <Input Type=""text"" Value=""main"" />
    <Badge Variant=""BadgeVariant.Outline"">Active</Badge>
</Div>")">
            <Div class="flex flex-wrap items-center gap-3 max-w-md">
                <Input Type="text" Value="main" Class="max-w-xs" />
                <Badge Variant="BadgeVariant.Outline">Active</Badge>
                <Badge>Production</Badge>
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Input Group" Description="Use an input group when the field needs affixes or inline helpers." Code="@(@"<InputGroup>
    <InputGroupAddon>https://</InputGroupAddon>
    <InputGroupInput Placeholder=""acme.dev"" />
</InputGroup>")">
            <Div class="max-w-md">
                <InputGroup>
                    <InputGroupAddon>https://</InputGroupAddon>
                    <InputGroupInput Placeholder="acme.dev" />
                </InputGroup>
            </Div>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Button Group" Description="Use button groups when the input needs primary and secondary adjacent actions." Code="@(@"<ButtonGroup>
    <Input Type=""search"" Placeholder=""Search docs"" Class=""min-w-64"" />
    <Button Variant=""ButtonVariant.Outline"">Clear</Button>
    <Button>Search</Button>
</ButtonGroup>")">
            <ButtonGroup>
                <Input Type="search" Placeholder="Search docs" Class="min-w-64" />
                <Button Variant="ButtonVariant.Outline">Clear</Button>
                <Button>Search</Button>
            </ButtonGroup>
        </DemoSection>
    </Div>

    <Div class="space-y-4">
        <DemoSection Title="Form" Description="Input integrated with EditForm validation." Code="@(@"<EditForm Model=""_formModel"" OnValidSubmit=""HandleValidSubmit"" class=""max-w-md space-y-4"">
    <DataAnnotationsValidator />
    <Label class=""text-sm font-medium"">Name</Label>
    <Input Type=""text"" @bind-Value=""_formModel.Name"" Placeholder=""Enter your name"" />
    <ValidationMessage For=""@(() => _formModel.Name)"" class=""text-sm text-destructive"" />
    <Label class=""text-sm font-medium"">Email</Label>
    <Input Type=""email"" @bind-Value=""_formModel.Email"" Placeholder=""Enter your email"" />
    <ValidationMessage For=""@(() => _formModel.Email)"" class=""text-sm text-destructive"" />
    <Button Type=""ButtonType.Submit"" Variant=""ButtonVariant.Default"">Submit</Button>
</EditForm>")">
        <EditForm Model="_formModel" OnValidSubmit="HandleValidSubmit" class="max-w-md space-y-4">
            <DataAnnotationsValidator />

            <Div class="space-y-2">
                <Label class="text-sm font-medium">Name</Label>
                <Input Type="text" @bind-Value="_formModel.Name" Placeholder="Enter your name" />
                <ValidationMessage For="@(() => _formModel.Name)" class="text-sm text-destructive" />
            </Div>

            <Div class="space-y-2">
                <Label class="text-sm font-medium">Email</Label>
                <Input Type="email" @bind-Value="_formModel.Email" Placeholder="Enter your email" />
                <ValidationMessage For="@(() => _formModel.Email)" class="text-sm text-destructive" />
            </Div>

            <Div class="flex gap-4">
                <Button Type="@ButtonType.Submit" Variant="ButtonVariant.Default">Submit</Button>
                <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Reset</Button>
            </Div>

            @if (!string.IsNullOrEmpty(_formMessage))
            {
                <Div class="p-4 bg-card rounded-lg border">
                    <Paragraph class="text-sm">@_formMessage</Paragraph>
                </Div>
            }
        </EditForm>
        </DemoSection>
    </Div>
</Div>

@code {
    private InputFormModel _formModel = new();
    private string? _formMessage;

    private void HandleValidSubmit()
    {
        _formMessage = $"Form submitted! Name: {_formModel.Name}, Email: {_formModel.Email}";
    }

    private void ResetForm()
    {
        _formModel = new();
        _formMessage = null;
    }

    private sealed class InputFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(50, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 50 characters.")]
        public string? Name { get; set; }

        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string? Email { get; set; }
    }
}
