@page "/position-offset"

<PageTitle>Position Offset - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
<Div Space="Space.Y.Is6">
<DemoSection Title="Basic Position Offset Values" Description="Top, bottom with 0, 50%, 100%." Code="@(@"<Div Position=""Position.Relative"" MinHeight=""150px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top0"">Top 0</Div>
</Div>
<Div Position=""Position.Relative"" MinHeight=""150px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top50"">Top 50%</Div>
</Div>
<Div Position=""Position.Relative"" MinHeight=""150px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Bottom0"">Bottom 0</Div>
</Div>")">
    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is3.FromBottom">
        Position offset utilities allow you to position elements using top, bottom, start, and end properties with values of 0, 50%, or 100%.
    </Paragraph>
    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4">
        <Div>
            <H4>Top Values</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top0" BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Top 0
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top50" BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Top 50%
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top100" BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Top 100%
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Bottom Values</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Bottom0" BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Bottom 0
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Bottom50" BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Bottom 50%
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Bottom100" BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Bottom 100%
                </Div>
            </Div>
        </Div>
    </Grid>
</DemoSection>

<DemoSection Title="Start and End Values" Description="Start/End for LTR/RTL; 0, 50%, 100%." Code="@(@"<Div Position=""Position.Relative"" MinHeight=""150px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Start0"">Start 0</Div>
</Div>
<Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.End0"">End 0</Div>")">
    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is3.FromBottom">
        Start and end values use logical properties that adapt to text direction (LTR/RTL).
    </Paragraph>
    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4">
        <Div>
            <H4>Start Values</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Start0" BackgroundColor="BackgroundColor.Secondary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Start 0
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Start50" BackgroundColor="BackgroundColor.Secondary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Start 50%
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Start100" BackgroundColor="BackgroundColor.Secondary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Start 100%
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>End Values</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.End0" BackgroundColor="BackgroundColor.Muted" TextColor="TextColor.Foreground" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    End 0
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Margin="Margin.Is2.FromBottom">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.End50" BackgroundColor="BackgroundColor.Muted" TextColor="TextColor.Foreground" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    End 50%
                </Div>
            </Div>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.End100" BackgroundColor="BackgroundColor.Muted" TextColor="TextColor.Foreground" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    End 100%
                </Div>
            </Div>
        </Div>
    </Grid>
</DemoSection>

<DemoSection Title="Combining Multiple Offsets" Description="Chain Top, Bottom, Start, End." Code="@(@"<Div Position=""Position.Relative"" MinHeight=""150px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top0.Start0"">Top 0, Start 0</Div>
</Div>
<Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top50.Start50"">Top 50%, Start 50%</Div>
<Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Bottom0.End0"">Bottom 0, End 0</Div>")">
    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is3.FromBottom">
        You can chain multiple offset values together to position elements precisely.
    </Paragraph>

    <Grid Columns="Columns.Is1.OnMd.Is3" Gap="Gap.Is4">
        <Div>
            <H4>Top + Start</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top0.Start0" BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Top 0, Start 0
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Top + End</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top0.End0" BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Top 0, End 0
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Bottom + Start</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Bottom0.Start0" BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Bottom 0, Start 0
                </Div>
            </Div>
        </Div>
    </Grid>

    <Grid Columns="Columns.Is1.OnMd.Is3" Gap="Gap.Is4" Margin="Margin.Is3.FromTop">
        <Div>
            <H4>Bottom + End</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Bottom0.End0" BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Bottom 0, End 0
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Top 50% + Start 50%</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top50.Start50" BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Top 50%, Start 50%
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>All Corners</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top0.Start0.Bottom0.End0" BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm" Opacity="Opacity.Is75">
                    All 0 (Full Coverage)
                </Div>
            </Div>
        </Div>
    </Grid>
</DemoSection>

<DemoSection Title="Translate Middle Utilities" Description="TranslateMiddle, TranslateMiddleX, TranslateMiddleY for centering." Code="@(@"<Div Position=""Position.Relative"" MinHeight=""150px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top50.Start50.TranslateMiddle"">Centered</Div>
</Div>
<Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top0.Start50.TranslateMiddleX"">Centered X</Div>
<Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top50.Start0.TranslateMiddleY"">Centered Y</Div>")">
    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is3.FromBottom">
        Translate middle utilities are perfect for centering absolutely positioned elements.
    </Paragraph>

    <Grid Columns="Columns.Is1.OnMd.Is3" Gap="Gap.Is4">
        <Div>
            <H4>Translate Middle</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top50.Start50.TranslateMiddle" BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Centered
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Translate Middle X</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top0.Start50.TranslateMiddleX" BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Centered X
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Translate Middle Y</H4>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top50.Start0.TranslateMiddleY" BackgroundColor="BackgroundColor.Secondary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
