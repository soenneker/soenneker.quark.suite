                </Div>
            </Div>
        </Div>
    </Grid>
</DemoSection>

<DemoSection Title="Responsive Position Offsets" Description="OnBase, OnMd, OnLg for breakpoint-specific offsets." Code="@(@"<Div Position=""Position.Relative"" MinHeight=""150px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top0.OnBase.Top50.OnMd"">Responsive</Div>
</Div>
<Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Start0.OnBase.Start50.OnLg"">Responsive</Div>")">
    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is3.FromBottom">
        Apply different position offsets based on device screen sizes for responsive positioning.
    </Paragraph>

    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4">
        <Div>
            <H4>Responsive Top</H4>
            <Paragraph TextColor="TextColor.MutedForeground" Class="small">Top 0 on phone, Top 50% on tablet</Paragraph>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top0.OnBase.Top50.OnMd" BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Responsive
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Responsive Start</H4>
            <Paragraph TextColor="TextColor.MutedForeground" Class="small">Start 0 on phone, Start 50% on laptop</Paragraph>
            <Div Position="Position.Relative" MinHeight="@("150px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Start0.OnBase.Start50.OnLg" BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm">
                    Responsive
                </Div>
            </Div>
        </Div>
    </Grid>
</DemoSection>

<DemoSection Title="Real-World Examples" Description="Badge overlay, centered dialog, tooltip, fixed footer." Code="@(@"<Div Position=""Position.Relative"">
    <Div>Notification</Div>
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top0.End0"">3</Div>
</Div>
<Div Position=""Position.Relative"" MinHeight=""200px"">
    <Div Position=""Position.Absolute"" PositionOffset=""PositionOffset.Top50.Start50.TranslateMiddle"">Dialog content</Div>
</Div>")">
    <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is3.FromBottom">
        Common use cases for position offsets in real applications.
    </Paragraph>

    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4">
        <Div>
            <H4>Badge Overlay</H4>
            <Div Position="Position.Relative" Display="Display.InlineBlock" Margin="Margin.Is3.FromBottom">
                <Div BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White" Padding="Padding.Is3" Rounded="Rounded.Sm">
                    Notification
                </Div>
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top0.End0" BackgroundColor="BackgroundColor.Destructive" TextColor="TextColor.White" Padding="Padding.Is1" MinWidth="@("20px")" MinHeight="@("20px")" Display="Display.Flex" Flex="Flex.Column.AlignCenter.JustifyCenter" Style="transform: translate(50%, -50%);">
                    3
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Centered Dialog Content</H4>
            <Div Position="Position.Relative" MinHeight="@("200px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Top50.Start50.TranslateMiddle" BackgroundColor="BackgroundColor.White" Border="Border.Is1" Rounded="Rounded.Sm" Padding="Padding.Is4" BoxShadow="BoxShadow.Base" MinWidth="@("300px")" TextAlignment="TextAlignment.Center">
                    <H4>Dialog Title</H4>
                    <Paragraph>This is centered content</Paragraph>
                </Div>
            </Div>
        </Div>
    </Grid>

    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4" Margin="Margin.Is3.FromTop">
        <Div>
            <H4>Tooltip Position</H4>
            <Div Position="Position.Relative" Display="Display.InlineBlock" Margin="Margin.Is3.FromBottom">
                <Button BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.White">
                    Hover Me
                </Button>
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Bottom100.Start50.TranslateMiddleX" BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is2" Rounded="Rounded.Sm" Margin="Margin.Is2.FromBottom" Display="Display.None" Style="white-space: nowrap;">
                    Tooltip text here
                </Div>
            </Div>
        </Div>
        <Div>
            <H4>Fixed Footer</H4>
            <Div Position="Position.Relative" MinHeight="@("200px")" Border="Border.Is1" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2">
                <Div Position="Position.Absolute" PositionOffset="PositionOffset.Bottom0.Start0.End0" BackgroundColor="BackgroundColor.Accent" TextColor="TextColor.White" Padding="Padding.Is3" TextAlignment="TextAlignment.Center">
                    Fixed Footer Content
                </Div>
            </Div>
        </Div>
    </Grid>
</DemoSection>
</Div>
</Div>

