@page "/components/timelines"

<PageTitle>Timeline - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is6xl">
    <Section Space="Space.Y.Is4">
        <DemoSection Title="Timeline"
                     Description="A vertical ReUI timeline with dates, titles, indicators, separators, and content."
                     Code="@TimelineBasicCode"
                     CodeLanguage="razor">
            <Timeline Value="2">
                <TimelineItem Step="1">
                    <TimelineHeader>
                        <TimelineDate>March 2024</TimelineDate>
                        <TimelineTitle>Project Initialized</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator />
                    <TimelineSeparator />
                    <TimelineContent>Successfully set up the project repository and initial architecture.</TimelineContent>
                </TimelineItem>

                <TimelineItem Step="2">
                    <TimelineHeader>
                        <TimelineDate>April 2024</TimelineDate>
                        <TimelineTitle>Beta Release</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator />
                    <TimelineSeparator />
                    <TimelineContent>Launched the beta version for early testers and feedback.</TimelineContent>
                </TimelineItem>

                <TimelineItem Step="3">
                    <TimelineHeader>
                        <TimelineDate>June 2024</TimelineDate>
                        <TimelineTitle>Official Launch</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator />
                    <TimelineSeparator />
                    <TimelineContent>The platform is now live for all users worldwide.</TimelineContent>
                </TimelineItem>
            </Timeline>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Custom Indicators"
                     Description="Indicators can contain normal Quark content while keeping the ReUI timeline structure."
                     Code="@TimelineIndicatorsCode"
                     CodeLanguage="razor">
            <Timeline Value="3">
                <TimelineItem Step="1">
                    <TimelineHeader>
                        <TimelineDate>Mar 15, 2024</TimelineDate>
                        <TimelineTitle>Order Placed</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator Class="bg-background text-primary">
                        <Icon Name="LucideIcon.ShoppingCart" Size="Quark.Size.Is3" />
                    </TimelineIndicator>
                    <TimelineSeparator />
                    <TimelineContent>Your order has been received and is being processed.</TimelineContent>
                </TimelineItem>

                <TimelineItem Step="2">
                    <TimelineHeader>
                        <TimelineDate>Mar 16, 2024</TimelineDate>
                        <TimelineTitle>Payment Confirmed</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator Class="bg-background text-primary">
                        <Icon Name="LucideIcon.CreditCard" Size="Quark.Size.Is3" />
                    </TimelineIndicator>
                    <TimelineSeparator />
                    <TimelineContent>Transaction successful. Preparing for shipment.</TimelineContent>
                </TimelineItem>

                <TimelineItem Step="3">
                    <TimelineHeader>
                        <TimelineDate>Mar 18, 2024</TimelineDate>
                        <TimelineTitle>Shipped</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator Class="bg-background text-primary">
                        <Icon Name="LucideIcon.PackageCheck" Size="Quark.Size.Is3" />
                    </TimelineIndicator>
                    <TimelineSeparator />
                    <TimelineContent>Your package is on its way. Track your delivery.</TimelineContent>
                </TimelineItem>
            </Timeline>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Horizontal Orientation"
                     Description="The same primitives switch layout through the ReUI orientation attribute."
                     Code="@TimelineHorizontalCode"
                     CodeLanguage="razor">
            <Timeline Orientation="horizontal" Value="2" Class="max-w-3xl">
                <TimelineItem Step="1">
                    <TimelineHeader>
                        <TimelineDate>Week 1</TimelineDate>
                        <TimelineTitle>Planning</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator />
                    <TimelineSeparator />
                    <TimelineContent>Scope definition and resource planning.</TimelineContent>
                </TimelineItem>

                <TimelineItem Step="2">
                    <TimelineHeader>
                        <TimelineDate>Week 2</TimelineDate>
                        <TimelineTitle>Design</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator />
                    <TimelineSeparator />
                    <TimelineContent>UI/UX design and prototyping.</TimelineContent>
                </TimelineItem>

                <TimelineItem Step="3">
                    <TimelineHeader>
                        <TimelineDate>Week 4</TimelineDate>
                        <TimelineTitle>Development</TimelineTitle>
                    </TimelineHeader>
                    <TimelineIndicator />
                    <TimelineSeparator />
                    <TimelineContent>Core features implementation.</TimelineContent>
                </TimelineItem>
            </Timeline>
        </DemoSection>
    </Section>
</Div>

