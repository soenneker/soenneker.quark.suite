@page "/components/color-picker"

<PageTitle>Color Picker - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
            Description="A shadcn-style color picker with a saturation/lightness canvas, hue and alpha controls, a working browser eyedropper, and multiple output formats."
            Code="@BasicCode"
            PreviewClass="preview relative flex min-h-96 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel>Accent color</FieldLabel>
                <ColorPicker Inline="true"
                             @bind-Value="_accentColor"
                             @bind-Format="_format" />
                <FieldDescription>Current value: @_accentColor</FieldDescription>
            </Field>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Popover"
                     Description="Use the compact trigger when the picker belongs inside a form."
                     Code="@PopoverCode"
                     PreviewClass="preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel>Brand color</FieldLabel>
                <ColorPicker @bind-Value="_brandColor"
                             Format="ColorPickerFormat.Css"
                             TriggerClass="w-full" />
            </Field>
        </DemoSection>
    </Section>

    <Section Space="Space.Y.Is4">
        <DemoSection Title="Configurable controls"
                     Description="Every part of the picker can be hidden independently. This opaque-only variant removes the eyedropper and alpha controls, limits the formats, and adds a custom preset palette."
                     Code="@NoAlphaCode"
                     PreviewClass="preview relative flex min-h-96 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0">
            <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                <FieldLabel>Solid color</FieldLabel>
                <ColorPicker Inline="true"
                             ShowAlpha="false"
                             ShowEyedropper="false"
                             ShowPresets="true"
                             Formats="_opaqueFormats"
                             PresetColors="_brandPresets"
                             @bind-Value="_solidColor" />
            </Field>
        </DemoSection>
    </Section>
</Div>

@code {
    private string? _accentColor = "#8b5cf6";
    private string? _brandColor = "rgba(59, 130, 246, 0.85)";
    private string? _solidColor = "#22c55e";
    private ColorPickerFormat _format = ColorPickerFormat.Hex;
    private readonly ColorPickerFormat[] _opaqueFormats = [ColorPickerFormat.Hex, ColorPickerFormat.Rgb, ColorPickerFormat.Hsl];
    private readonly string[] _brandPresets = ["#ef4444", "#f97316", "#eab308", "#22c55e", "#06b6d4", "#3b82f6", "#8b5cf6", "#ec4899"];

    private const string BasicCode ="""
        <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
            <FieldLabel>Accent color</FieldLabel>
            <ColorPicker Inline="true"
                         @bind-Value="_accentColor"
                         @bind-Format="_format" />
            <FieldDescription>Current value: @_accentColor</FieldDescription>
        </Field>
        """;

    private const string PopoverCode ="""
        <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
            <FieldLabel>Brand color</FieldLabel>
            <ColorPicker @bind-Value="_brandColor"
                         Format="ColorPickerFormat.Css"
                         TriggerClass="w-full" />
        </Field>
        """;

    private const string NoAlphaCode ="""
        <Field Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
            <FieldLabel>Solid color</FieldLabel>
        <ColorPicker Inline="true"
                     ShowAlpha="false"
                     ShowEyedropper="false"
                     ShowPresets="true"
                     Formats="_opaqueFormats"
                     PresetColors="_brandPresets"
                     @bind-Value="_solidColor" />
        </Field>
        """;
}
