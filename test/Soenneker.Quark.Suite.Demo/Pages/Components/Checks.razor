@page "/checks"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Checkbox Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Code="@DemoCode">
                <Div class="flex flex-col gap-6">
                    <Field Orientation="Orientation.Horizontal">
                        <Check Id="terms-checkbox-demo" />
                        <FieldLabel For="terms-checkbox-demo">Accept terms and conditions</FieldLabel>
                    </Field>

                    <Field Orientation="Orientation.Horizontal">
                        <Check Id="terms-checkbox-demo-2" Checked="true" />
                        <FieldContent>
                            <FieldLabel For="terms-checkbox-demo-2">Accept terms and conditions</FieldLabel>
                            <FieldDescription>By clicking this checkbox, you agree to the terms and conditions.</FieldDescription>
                        </FieldContent>
                    </Field>

                    <Field Orientation="Orientation.Horizontal">
                        <Check Id="notifications-checkbox-disabled" Disabled="true" />
                        <FieldLabel For="notifications-checkbox-disabled">Enable notifications</FieldLabel>
                    </Field>

                    <Label class="flex items-start gap-3 rounded-lg border p-3 hover:bg-accent/50 has-[[aria-checked=true]]:border-blue-600 has-[[aria-checked=true]]:bg-blue-50 dark:has-[[aria-checked=true]]:border-blue-900 dark:has-[[aria-checked=true]]:bg-blue-950">
                        <Check Id="notifications-checkbox-card"
                               Checked="true"
                               class="data-[state=checked]:border-blue-600 data-[state=checked]:bg-blue-600 data-[state=checked]:text-white dark:data-[state=checked]:border-blue-700 dark:data-[state=checked]:bg-blue-700" />
                        <Div class="grid gap-1.5 font-normal">
                            <Paragraph class="text-sm leading-none font-medium">Enable notifications</Paragraph>
                            <Paragraph class="text-sm text-muted-foreground">You can enable or disable notifications at any time.</Paragraph>
                        </Div>
                    </Label>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Code="@DisabledCode">
                <Field Orientation="Orientation.Horizontal">
                    <Check Id="terms-checkbox-disabled" Disabled="true" />
                    <FieldLabel For="terms-checkbox-disabled">Accept terms and conditions</FieldLabel>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group"
                         Code="@GroupCode">
                <FieldSet>
                    <FieldLegend Variant="FieldLegendVariant.Label">Show these items on the desktop:</FieldLegend>
                    <FieldDescription>Select the items you want to show on the desktop.</FieldDescription>
                    <FieldGroup Class="gap-3">
                        <Field Orientation="Orientation.Horizontal">
                            <Check Id="desktop-hard-disks" @bind-Checked="_showHardDisks" />
                            <FieldLabel For="desktop-hard-disks" Class="font-normal">Hard disks</FieldLabel>
                        </Field>
                        <Field Orientation="Orientation.Horizontal">
                            <Check Id="desktop-external-disks" @bind-Checked="_showExternalDisks" />
                            <FieldLabel For="desktop-external-disks" Class="font-normal">External disks</FieldLabel>
                        </Field>
                        <Field Orientation="Orientation.Horizontal">
                            <Check Id="desktop-cds" @bind-Checked="_showCds" />
                            <FieldLabel For="desktop-cds" Class="font-normal">CDs, DVDs, and iPods</FieldLabel>
                        </Field>
                        <Field Orientation="Orientation.Horizontal">
                            <Check Id="desktop-servers" @bind-Checked="_showServers" />
                            <FieldLabel For="desktop-servers" Class="font-normal">Connected servers</FieldLabel>
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Code="@InvalidCode">
                <Field Orientation="Orientation.Horizontal" IsInvalid="true">
                    <Check Id="terms-checkbox-invalid" aria-invalid="true" />
                    <FieldLabel For="terms-checkbox-invalid">Accept terms and conditions</FieldLabel>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Quark-only examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                These examples show additional checkbox patterns that go beyond the core examples above.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Indeterminate"
                         Description="Use an indeterminate parent checkbox to reflect a partial selection state."
                         Code="@IndeterminateCode">
                <Div Space="Space.Y.Is3">
                    <Check Checked="@_selectAllChecked" CheckedChanged="HandleSelectAllChanged" Indeterminate="@_selectAllIndeterminate" Id="select-all">
                        Select all
                    </Check>
                    <Div class="ml-6 space-y-3">
                        <Check Checked="@_itemRead" CheckedChanged="@(v => HandlePermissionChanged(nameof(_itemRead), v))" Id="item-read">Read</Check>
                        <Check Checked="@_itemWrite" CheckedChanged="@(v => HandlePermissionChanged(nameof(_itemWrite), v))" Id="item-write">Write</Check>
                        <Check Checked="@_itemExecute" CheckedChanged="@(v => HandlePermissionChanged(nameof(_itemExecute), v))" Id="item-execute">Execute</Check>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form Validation"
                         Description="Checkbox integrates with `EditForm` and validation messaging through two-way checked binding."
                         Code="@FormCode">
                <EditForm Model="_formModel" OnValidSubmit="HandleValidSubmit" class="space-y-4">
                    <DataAnnotationsValidator />
                    <Field>
                        <Check @bind-Checked="_formModel.AcceptTerms" Id="terms">I accept the terms and conditions</Check>
                        <ValidationMessage For="@(() => _formModel.AcceptTerms)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                    </Field>
                    <Field>
                        <Check @bind-Checked="_formModel.Subscribe" Id="subscribe">Subscribe to newsletter (optional)</Check>
                    </Field>
                    <Div Display="Display.Flex" Gap="Gap.Is4">
                        <Button Type="ButtonType.Submit">Submit</Button>
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Reset</Button>
                    </Div>
                    @if (!string.IsNullOrEmpty(_formMessage))
                    {
                        <Div class="p-4 bg-card rounded-lg border">
                            <Paragraph TextSize="TextSize.Sm">@_formMessage</Paragraph>
                        </Div>
                    }
                </EditForm>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _showHardDisks = true;
    private bool _showExternalDisks = true;
    private bool _showCds;
    private bool _showServers;

    private bool _selectAllChecked;
    private bool _selectAllIndeterminate;
    private bool _itemRead = true;
    private bool _itemWrite;
    private bool _itemExecute;

    private FormModel _formModel = new();
    private string _formMessage = "";

    private const string DemoCode =
@"<div class=""flex flex-col gap-6"">
    <Field Orientation=""Orientation.Horizontal"">
        <Check Id=""terms-checkbox-demo"" />
        <FieldLabel For=""terms-checkbox-demo"">Accept terms and conditions</FieldLabel>
    </Field>

    <Field Orientation=""Orientation.Horizontal"">
        <Check Id=""terms-checkbox-demo-2"" Checked=""true"" />
        <FieldContent>
            <FieldLabel For=""terms-checkbox-demo-2"">Accept terms and conditions</FieldLabel>
            <FieldDescription>By clicking this checkbox, you agree to the terms and conditions.</FieldDescription>
        </FieldContent>
    </Field>

    <Field Orientation=""Orientation.Horizontal"">
        <Check Id=""notifications-checkbox-disabled"" Disabled=""true"" />
        <FieldLabel For=""notifications-checkbox-disabled"">Enable notifications</FieldLabel>
    </Field>

    <Label class=""flex items-start gap-3 rounded-lg border p-3 hover:bg-accent/50 has-[[aria-checked=true]]:border-blue-600 has-[[aria-checked=true]]:bg-blue-50 dark:has-[[aria-checked=true]]:border-blue-900 dark:has-[[aria-checked=true]]:bg-blue-950"">
        <Check Id=""notifications-checkbox-card""
               Checked=""true""
               class=""data-[state=checked]:border-blue-600 data-[state=checked]:bg-blue-600 data-[state=checked]:text-white dark:data-[state=checked]:border-blue-700 dark:data-[state=checked]:bg-blue-700"" />
        <Div class=""grid gap-1.5 font-normal"">
            <Paragraph class=""text-sm leading-none font-medium"">Enable notifications</Paragraph>
            <Paragraph class=""text-sm text-muted-foreground"">You can enable or disable notifications at any time.</Paragraph>
        </Div>
    </Label>
</div>";

    private const string DisabledCode =
@"<Field Orientation=""Orientation.Horizontal"">
    <Check Id=""terms-checkbox-disabled"" Disabled=""true"" />
    <FieldLabel For=""terms-checkbox-disabled"">Accept terms and conditions</FieldLabel>
</Field>";

    private const string GroupCode =
@"<FieldSet>
    <FieldLegend Variant=""FieldLegendVariant.Label"">Show these items on the desktop:</FieldLegend>
    <FieldDescription>Select the items you want to show on the desktop.</FieldDescription>
    <FieldGroup Class=""gap-3"">
        <Field Orientation=""Orientation.Horizontal"">
            <Check Id=""desktop-hard-disks"" @bind-Checked=""_showHardDisks"" />
            <FieldLabel For=""desktop-hard-disks"" Class=""font-normal"">Hard disks</FieldLabel>
        </Field>
        <Field Orientation=""Orientation.Horizontal"">
            <Check Id=""desktop-external-disks"" @bind-Checked=""_showExternalDisks"" />
            <FieldLabel For=""desktop-external-disks"" Class=""font-normal"">External disks</FieldLabel>
        </Field>
        <Field Orientation=""Orientation.Horizontal"">
            <Check Id=""desktop-cds"" @bind-Checked=""_showCds"" />
            <FieldLabel For=""desktop-cds"" Class=""font-normal"">CDs, DVDs, and iPods</FieldLabel>
        </Field>
        <Field Orientation=""Orientation.Horizontal"">
            <Check Id=""desktop-servers"" @bind-Checked=""_showServers"" />
            <FieldLabel For=""desktop-servers"" Class=""font-normal"">Connected servers</FieldLabel>
        </Field>
    </FieldGroup>
</FieldSet>";

    private const string InvalidCode =
@"<Field Orientation=""Orientation.Horizontal"" IsInvalid=""true"">
    <Check Id=""terms-checkbox-invalid"" aria-invalid=""true"" />
    <FieldLabel For=""terms-checkbox-invalid"">Accept terms and conditions</FieldLabel>
</Field>";

    private const string IndeterminateCode =
@"<Check Checked=""_selectAllChecked"" CheckedChanged=""HandleSelectAllChanged"" Indeterminate=""_selectAllIndeterminate"" Id=""select-all"">
    Select all
</Check>
<Div class=""ml-6 space-y-3"">
    <Check Checked=""_itemRead"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemRead), v))"" Id=""item-read"">Read</Check>
    <Check Checked=""_itemWrite"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemWrite), v))"" Id=""item-write"">Write</Check>
    <Check Checked=""_itemExecute"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemExecute), v))"" Id=""item-execute"">Execute</Check>
</Div>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnValidSubmit=""HandleValidSubmit"" class=""space-y-4"">
    <DataAnnotationsValidator />
    <Field>
        <Check @bind-Checked=""_formModel.AcceptTerms"" Id=""terms"">I accept the terms and conditions</Check>
        <ValidationMessage For=""@(() => _formModel.AcceptTerms)"" TextSize=""TextSize.Sm"" TextColor=""TextColor.Destructive"" />
    </Field>
    <Field>
        <Check @bind-Checked=""_formModel.Subscribe"" Id=""subscribe"">Subscribe to newsletter (optional)</Check>
    </Field>
    <Div Display=""Display.Flex"" Gap=""Gap.Is4"">
        <Button Type=""ButtonType.Submit"">Submit</Button>
        <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Outline"">Reset</Button>
    </Div>
</EditForm>";

    protected override void OnInitialized()
    {
        UpdateSelectAll();
    }

    private void HandleSelectAllChanged(bool value)
    {
        _selectAllChecked = value;
        _selectAllIndeterminate = false;
        _itemRead = value;
        _itemWrite = value;
        _itemExecute = value;
    }

    private void HandlePermissionChanged(string permission, bool value)
    {
        switch (permission)
        {
            case nameof(_itemRead):
                _itemRead = value;
                break;
            case nameof(_itemWrite):
                _itemWrite = value;
                break;
            case nameof(_itemExecute):
                _itemExecute = value;
                break;
        }

        UpdateSelectAll();
    }

    private void UpdateSelectAll()
    {
        var all = _itemRead && _itemWrite && _itemExecute;
        var none = !_itemRead && !_itemWrite && !_itemExecute;
        _selectAllChecked = all;
        _selectAllIndeterminate = !all && !none;
    }

    private void HandleValidSubmit()
    {
        _formMessage = $"Submitted at {DateTime.Now:HH:mm:ss}. Terms: {_formModel.AcceptTerms}, Subscribe: {_formModel.Subscribe}";
    }

    private void ResetForm()
    {
        _formModel = new FormModel();
        _formMessage = "";
    }

    private sealed class FormModel
    {
        [Required(ErrorMessage = "You must accept terms.")]
        [Range(typeof(bool), "true", "true", ErrorMessage = "You must accept terms.")]
        public bool AcceptTerms { get; set; }

        public bool Subscribe { get; set; }
    }
}
