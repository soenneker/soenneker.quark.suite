@page "/checks"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Checkbox Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Code="@DemoCode">
                <FieldGroup Class="max-w-sm">
                    <Field Horizontal="true">
                        <Check Id="terms-checkbox" Name="terms-checkbox" />
                        <Label For="terms-checkbox">Accept terms and conditions</Label>
                    </Field>
                    <Field Horizontal="true">
                        <Check Id="terms-checkbox-2" Name="terms-checkbox-2" Checked="true" />
                        <FieldContent>
                            <FieldLabel For="terms-checkbox-2">Accept terms and conditions</FieldLabel>
                            <FieldDescription>By clicking this checkbox, you agree to the terms.</FieldDescription>
                        </FieldContent>
                    </Field>
                    <Field Horizontal="true" Disabled="true">
                        <Check Id="toggle-checkbox" Name="toggle-checkbox" Disabled="true" />
                        <FieldLabel For="toggle-checkbox">Enable notifications</FieldLabel>
                    </Field>
                    <Field Horizontal="true">
                        <Check Id="toggle-checkbox-2" Name="toggle-checkbox-2" />
                        <FieldContent>
                            <FieldTitle>Enable notifications</FieldTitle>
                            <FieldDescription>You can enable or disable notifications at any time.</FieldDescription>
                        </FieldContent>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Code="@BasicCode">
                <FieldGroup Class="mx-auto w-56">
                    <Field Horizontal="true">
                        <Check Id="terms-checkbox-basic" Name="terms-checkbox-basic" />
                        <FieldLabel For="terms-checkbox-basic">Accept terms and conditions</FieldLabel>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Description"
                         Code="@DescriptionCode">
                <FieldGroup Class="mx-auto w-72">
                    <Field Horizontal="true">
                        <Check Id="terms-checkbox-desc" Name="terms-checkbox-desc" Checked="true" />
                        <FieldContent>
                            <FieldLabel For="terms-checkbox-desc">Accept terms and conditions</FieldLabel>
                            <FieldDescription>By clicking this checkbox, you agree to the terms and conditions.</FieldDescription>
                        </FieldContent>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Code="@DisabledCode">
                <FieldGroup Class="mx-auto w-56">
                    <Field Horizontal="true" Disabled="true">
                        <Check Id="toggle-checkbox-disabled" Name="toggle-checkbox-disabled" Disabled="true" />
                        <FieldLabel For="toggle-checkbox-disabled">Enable notifications</FieldLabel>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Code="@InvalidCode">
                <FieldGroup Class="mx-auto w-56">
                    <Field Horizontal="true" IsInvalid="true">
                        <Check Id="terms-checkbox-invalid" Name="terms-checkbox-invalid" aria-invalid="true" />
                        <FieldLabel For="terms-checkbox-invalid">Accept terms and conditions</FieldLabel>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group"
                         Code="@GroupCode">
                <FieldSet>
                    <FieldLegend Variant="FieldLegendVariant.Label">Show these items on the desktop:</FieldLegend>
                    <FieldDescription>Select the items you want to show on the desktop.</FieldDescription>
                    <FieldGroup Class="gap-3">
                        <Field Horizontal="true">
                            <Check Id="finder-pref-9k2-hard-disks-ljj-checkbox" Name="finder-pref-9k2-hard-disks-ljj-checkbox" Checked="true" />
                            <FieldLabel For="finder-pref-9k2-hard-disks-ljj-checkbox" Class="font-normal">Hard disks</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="finder-pref-9k2-external-disks-1yg-checkbox" Name="finder-pref-9k2-external-disks-1yg-checkbox" Checked="true" />
                            <FieldLabel For="finder-pref-9k2-external-disks-1yg-checkbox" Class="font-normal">External disks</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="finder-pref-9k2-cds-dvds-fzt-checkbox" Name="finder-pref-9k2-cds-dvds-fzt-checkbox" />
                            <FieldLabel For="finder-pref-9k2-cds-dvds-fzt-checkbox" Class="font-normal">CDs, DVDs, and iPods</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="finder-pref-9k2-connected-servers-6l2-checkbox" Name="finder-pref-9k2-connected-servers-6l2-checkbox" />
                            <FieldLabel For="finder-pref-9k2-connected-servers-6l2-checkbox" Class="font-normal">Connected servers</FieldLabel>
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Table"
                         Code="@TableCode">
                <TableElement>
                    <Thead>
                        <Tr>
                            <Th Class="w-8">
                                <Check Id="select-all-checkbox"
                                       Name="select-all-checkbox"
                                       Checked="@_tableSelectAll"
                                       Indeterminate="@_tableSelectIndeterminate"
                                       CheckedChanged="HandleTableSelectAllChanged" />
                            </Th>
                            <Th>Name</Th>
                            <Th>Email</Th>
                            <Th>Role</Th>
                        </Tr>
                    </Thead>
                    <Tbody>
                        @foreach (var row in _tablePeople)
                        {
                            <Tr Attributes="@GetTableRowAttributes(row.Id)">
                                <Td>
                                    <Check Id="@($"row-{row.Id}-checkbox")"
                                           Name="@($"row-{row.Id}-checkbox")"
                                           Checked="@GetRowSelected(row.Id)"
                                           CheckedChanged="@(v => HandleTableRowChanged(row.Id, v))" />
                                </Td>
                                <Td Class="font-medium">@row.Name</Td>
                                <Td>@row.Email</Td>
                                <Td>@row.Role</Td>
                            </Tr>
                        }
                    </Tbody>
                </TableElement>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Code="@RtlCode">
                <DirectionProvider Dir="rtl">
                    <FieldGroup Class="max-w-sm">
                        <Field Horizontal="true">
                            <Check Id="terms-checkbox-rtl" Name="terms-checkbox" />
                            <Label For="terms-checkbox-rtl">قبول الشروط والأحكام</Label>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="terms-checkbox-2-rtl" Name="terms-checkbox-2" Checked="true" />
                            <FieldContent>
                                <FieldLabel For="terms-checkbox-2-rtl">قبول الشروط والأحكام</FieldLabel>
                                <FieldDescription>بالنقر على هذا المربع، فإنك توافق على الشروط.</FieldDescription>
                            </FieldContent>
                        </Field>
                        <Field Horizontal="true" Disabled="true">
                            <Check Id="toggle-checkbox-rtl" Name="toggle-checkbox" Disabled="true" />
                            <FieldLabel For="toggle-checkbox-rtl">تفعيل الإشعارات</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="toggle-checkbox-2-rtl-inner" Name="toggle-checkbox-2" />
                            <FieldContent>
                                <FieldTitle>تفعيل الإشعارات</FieldTitle>
                                <FieldDescription>يمكنك تفعيل أو إلغاء تفعيل الإشعارات في أي وقت.</FieldDescription>
                            </FieldContent>
                        </Field>
                    </FieldGroup>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
            <Paragraph TextColor="TextColor.MutedForeground">
                Indeterminate parent state, EditForm validation, and other patterns.
            </Paragraph>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Indeterminate"
                         Description="Use an indeterminate parent checkbox to reflect a partial selection state."
                         Code="@IndeterminateCode">
                <Div Space="Space.Y.Is3">
                    <Check Checked="@_selectAllChecked" CheckedChanged="HandleSelectAllChanged" Indeterminate="@_selectAllIndeterminate" Id="select-all">
                        Select all
                    </Check>
                    <Div class="ml-6 space-y-3">
                        <Check Checked="@_itemRead" CheckedChanged="@(v => HandlePermissionChanged(nameof(_itemRead), v))" Id="item-read">Read</Check>
                        <Check Checked="@_itemWrite" CheckedChanged="@(v => HandlePermissionChanged(nameof(_itemWrite), v))" Id="item-write">Write</Check>
                        <Check Checked="@_itemExecute" CheckedChanged="@(v => HandlePermissionChanged(nameof(_itemExecute), v))" Id="item-execute">Execute</Check>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form Validation"
                         Description="Checkbox integrates with EditForm and validation messaging through two-way checked binding."
                         Code="@FormCode">
                <EditForm Model="_formModel" OnValidSubmit="HandleValidSubmit" class="space-y-4">
                    <DataAnnotationsValidator />
                    <Field>
                        <Check @bind-Checked="_formModel.AcceptTerms" Id="terms">I accept the terms and conditions</Check>
                        <ValidationMessage For="@(() => _formModel.AcceptTerms)" TextSize="TextSize.Sm" TextColor="TextColor.Destructive" />
                    </Field>
                    <Field>
                        <Check @bind-Checked="_formModel.Subscribe" Id="subscribe">Subscribe to newsletter (optional)</Check>
                    </Field>
                    <Div Display="Display.Flex" Gap="Gap.Is4">
                        <Button Type="ButtonType.Submit">Submit</Button>
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Outline" OnClick="@(_ => ResetForm())">Reset</Button>
                    </Div>
                    @if (!string.IsNullOrEmpty(_formMessage))
                    {
                        <Div class="p-4 bg-card rounded-lg border">
                            <Paragraph TextSize="TextSize.Sm">@_formMessage</Paragraph>
                        </Div>
                    }
                </EditForm>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private sealed record TablePerson(string Id, string Name, string Email, string Role);

    private static readonly TablePerson[] _tablePeople =
    [
        new("1", "Sarah Chen", "sarah.chen@example.com", "Admin"),
        new("2", "Marcus Rodriguez", "marcus.rodriguez@example.com", "User"),
        new("3", "Priya Patel", "priya.patel@example.com", "User"),
        new("4", "David Kim", "david.kim@example.com", "Editor")
    ];

    private readonly HashSet<string> _selectedTableRows = ["1"];

    private bool _tableSelectAll;
    private bool _tableSelectIndeterminate = true;

    private bool _selectAllChecked;
    private bool _selectAllIndeterminate;
    private bool _itemRead = true;
    private bool _itemWrite;
    private bool _itemExecute;

    private FormModel _formModel = new();
    private string _formMessage = "";

    private const string DemoCode =
@"<FieldGroup Class=""max-w-sm"">
    <Field Horizontal=""true"">
        <Check Id=""terms-checkbox"" Name=""terms-checkbox"" />
        <Label For=""terms-checkbox"">Accept terms and conditions</Label>
    </Field>
    <Field Horizontal=""true"">
        <Check Id=""terms-checkbox-2"" Name=""terms-checkbox-2"" Checked=""true"" />
        <FieldContent>
            <FieldLabel For=""terms-checkbox-2"">Accept terms and conditions</FieldLabel>
            <FieldDescription>By clicking this checkbox, you agree to the terms.</FieldDescription>
        </FieldContent>
    </Field>
    <Field Horizontal=""true"" Disabled=""true"">
        <Check Id=""toggle-checkbox"" Name=""toggle-checkbox"" Disabled=""true"" />
        <FieldLabel For=""toggle-checkbox"">Enable notifications</FieldLabel>
    </Field>
    <Field Horizontal=""true"">
        <Check Id=""toggle-checkbox-2"" Name=""toggle-checkbox-2"" />
        <FieldContent>
            <FieldTitle>Enable notifications</FieldTitle>
            <FieldDescription>You can enable or disable notifications at any time.</FieldDescription>
        </FieldContent>
    </Field>
</FieldGroup>";

    private const string BasicCode =
@"<FieldGroup Class=""mx-auto w-56"">
    <Field Horizontal=""true"">
        <Check Id=""terms-checkbox-basic"" Name=""terms-checkbox-basic"" />
        <FieldLabel For=""terms-checkbox-basic"">Accept terms and conditions</FieldLabel>
    </Field>
</FieldGroup>";

    private const string DescriptionCode =
@"<FieldGroup Class=""mx-auto w-72"">
    <Field Horizontal=""true"">
        <Check Id=""terms-checkbox-desc"" Name=""terms-checkbox-desc"" Checked=""true"" />
        <FieldContent>
            <FieldLabel For=""terms-checkbox-desc"">Accept terms and conditions</FieldLabel>
            <FieldDescription>By clicking this checkbox, you agree to the terms and conditions.</FieldDescription>
        </FieldContent>
    </Field>
</FieldGroup>";

    private const string DisabledCode =
@"<FieldGroup Class=""mx-auto w-56"">
    <Field Horizontal=""true"" Disabled=""true"">
        <Check Id=""toggle-checkbox-disabled"" Name=""toggle-checkbox-disabled"" Disabled=""true"" />
        <FieldLabel For=""toggle-checkbox-disabled"">Enable notifications</FieldLabel>
    </Field>
</FieldGroup>";

    private const string InvalidCode =
@"<FieldGroup Class=""mx-auto w-56"">
    <Field Horizontal=""true"" IsInvalid=""true"">
        <Check Id=""terms-checkbox-invalid"" Name=""terms-checkbox-invalid"" aria-invalid=""true"" />
        <FieldLabel For=""terms-checkbox-invalid"">Accept terms and conditions</FieldLabel>
    </Field>
</FieldGroup>";

    private const string GroupCode =
@"<FieldSet>
    <FieldLegend Variant=""FieldLegendVariant.Label"">Show these items on the desktop:</FieldLegend>
    <FieldDescription>Select the items you want to show on the desktop.</FieldDescription>
    <FieldGroup Class=""gap-3"">
        <Field Horizontal=""true"">
            <Check Id=""finder-pref-9k2-hard-disks-ljj-checkbox"" Name=""finder-pref-9k2-hard-disks-ljj-checkbox"" Checked=""true"" />
            <FieldLabel For=""finder-pref-9k2-hard-disks-ljj-checkbox"" Class=""font-normal"">Hard disks</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""finder-pref-9k2-external-disks-1yg-checkbox"" Name=""finder-pref-9k2-external-disks-1yg-checkbox"" Checked=""true"" />
            <FieldLabel For=""finder-pref-9k2-external-disks-1yg-checkbox"" Class=""font-normal"">External disks</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""finder-pref-9k2-cds-dvds-fzt-checkbox"" Name=""finder-pref-9k2-cds-dvds-fzt-checkbox"" />
            <FieldLabel For=""finder-pref-9k2-cds-dvds-fzt-checkbox"" Class=""font-normal"">CDs, DVDs, and iPods</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""finder-pref-9k2-connected-servers-6l2-checkbox"" Name=""finder-pref-9k2-connected-servers-6l2-checkbox"" />
            <FieldLabel For=""finder-pref-9k2-connected-servers-6l2-checkbox"" Class=""font-normal"">Connected servers</FieldLabel>
        </Field>
    </FieldGroup>
</FieldSet>";

    private const string TableCode =
@"<TableElement>
    <Thead>
        <Tr>
            <Th Class=""w-8"">
                <Check Id=""select-all-checkbox"" Name=""select-all-checkbox"" Checked=""@_tableSelectAll"" Indeterminate=""@_tableSelectIndeterminate"" CheckedChanged=""HandleTableSelectAllChanged"" />
            </Th>
            <Th>Name</Th>
            <Th>Email</Th>
            <Th>Role</Th>
        </Tr>
    </Thead>
    <Tbody>
        @foreach (var row in _tablePeople)
        {
            <Tr Attributes=""@GetTableRowAttributes(row.Id)"">
                <Td>
                    <Check Id=""@($""row-{row.Id}-checkbox"")"" Name=""@($""row-{row.Id}-checkbox"")"" Checked=""@GetRowSelected(row.Id)"" CheckedChanged=""@((bool v) => HandleTableRowChanged(row.Id, v))"" />
                </Td>
                <Td Class=""font-medium"">@row.Name</Td>
                <Td>@row.Email</Td>
                <Td>@row.Role</Td>
            </Tr>
        }
    </Tbody>
</TableElement>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <FieldGroup Class=""max-w-sm"">
        <Field Horizontal=""true"">
            <Check Id=""terms-checkbox-rtl"" Name=""terms-checkbox"" />
            <Label For=""terms-checkbox-rtl"">قبول الشروط والأحكام</Label>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""terms-checkbox-2-rtl"" Name=""terms-checkbox-2"" Checked=""true"" />
            <FieldContent>
                <FieldLabel For=""terms-checkbox-2-rtl"">قبول الشروط والأحكام</FieldLabel>
                <FieldDescription>بالنقر على هذا المربع، فإنك توافق على الشروط.</FieldDescription>
            </FieldContent>
        </Field>
        <Field Horizontal=""true"" Disabled=""true"">
            <Check Id=""toggle-checkbox-rtl"" Name=""toggle-checkbox"" Disabled=""true"" />
            <FieldLabel For=""toggle-checkbox-rtl"">تفعيل الإشعارات</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""toggle-checkbox-2-rtl-inner"" Name=""toggle-checkbox-2"" />
            <FieldContent>
                <FieldTitle>تفعيل الإشعارات</FieldTitle>
                <FieldDescription>يمكنك تفعيل أو إلغاء تفعيل الإشعارات في أي وقت.</FieldDescription>
            </FieldContent>
        </Field>
    </FieldGroup>
</DirectionProvider>";

    private const string IndeterminateCode =
@"<Check Checked=""_selectAllChecked"" CheckedChanged=""HandleSelectAllChanged"" Indeterminate=""_selectAllIndeterminate"" Id=""select-all"">
    Select all
</Check>
<Div class=""ml-6 space-y-3"">
    <Check Checked=""_itemRead"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemRead), v))"" Id=""item-read"">Read</Check>
    <Check Checked=""_itemWrite"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemWrite), v))"" Id=""item-write"">Write</Check>
    <Check Checked=""_itemExecute"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemExecute), v))"" Id=""item-execute"">Execute</Check>
</Div>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnValidSubmit=""HandleValidSubmit"" class=""space-y-4"">
    <DataAnnotationsValidator />
    <Field>
        <Check @bind-Checked=""_formModel.AcceptTerms"" Id=""terms"">I accept the terms and conditions</Check>
        <ValidationMessage For=""@(() => _formModel.AcceptTerms)"" TextSize=""TextSize.Sm"" TextColor=""TextColor.Destructive"" />
    </Field>
    <Field>
        <Check @bind-Checked=""_formModel.Subscribe"" Id=""subscribe"">Subscribe to newsletter (optional)</Check>
    </Field>
    <Div Display=""Display.Flex"" Gap=""Gap.Is4"">
        <Button Type=""ButtonType.Submit"">Submit</Button>
        <Button Type=""ButtonType.Button"" Variant=""ButtonVariant.Outline"" OnClick=""@(_ => ResetForm())"">Reset</Button>
    </Div>
</EditForm>";

    protected override void OnInitialized()
    {
        UpdateSelectAll();
        UpdateTableSelectAll();
    }

    private IReadOnlyDictionary<string, object>? GetTableRowAttributes(string id)
    {
        if (!_selectedTableRows.Contains(id))
            return null;

        return new Dictionary<string, object> { ["data-state"] = "selected" };
    }

    private bool GetRowSelected(string id) => _selectedTableRows.Contains(id);

    private void HandleSelectAllChanged(bool value)
    {
        _selectAllChecked = value;
        _selectAllIndeterminate = false;
        _itemRead = value;
        _itemWrite = value;
        _itemExecute = value;
    }

    private Task HandleTableSelectAllChanged(bool value)
    {
        if (value)
        {
            _selectedTableRows.Clear();
            foreach (var p in _tablePeople)
                _selectedTableRows.Add(p.Id);
        }
        else
        {
            _selectedTableRows.Clear();
        }

        UpdateTableSelectAll();
        return Task.CompletedTask;
    }

    private void HandlePermissionChanged(string permission, bool value)
    {
        switch (permission)
        {
            case nameof(_itemRead):
                _itemRead = value;
                break;
            case nameof(_itemWrite):
                _itemWrite = value;
                break;
            case nameof(_itemExecute):
                _itemExecute = value;
                break;
        }

        UpdateSelectAll();
    }

    private Task HandleTableRowChanged(string id, bool value)
    {
        if (value)
            _selectedTableRows.Add(id);
        else
            _selectedTableRows.Remove(id);

        UpdateTableSelectAll();
        return Task.CompletedTask;
    }

    private void UpdateSelectAll()
    {
        var all = _itemRead && _itemWrite && _itemExecute;
        var none = !_itemRead && !_itemWrite && !_itemExecute;
        _selectAllChecked = all;
        _selectAllIndeterminate = !all && !none;
    }

    private void UpdateTableSelectAll()
    {
        var all = _selectedTableRows.Count == _tablePeople.Length;
        var none = _selectedTableRows.Count == 0;
        _tableSelectAll = all;
        _tableSelectIndeterminate = !all && !none;
    }

    private void HandleValidSubmit()
    {
        _formMessage = $"Submitted at {DateTime.Now:HH:mm:ss}. Terms: {_formModel.AcceptTerms}, Subscribe: {_formModel.Subscribe}";
    }

    private void ResetForm()
    {
        _formModel = new FormModel();
        _formMessage = "";
    }

    private sealed class FormModel
    {
        [Required(ErrorMessage = "You must accept terms.")]
        [Range(typeof(bool), "true", "true", ErrorMessage = "You must accept terms.")]
        public bool AcceptTerms { get; set; }

        public bool Subscribe { get; set; }
    }
}
