@page "/checks"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Checkbox Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="A control that allows the user to toggle between checked and not checked."
                         Code="@DemoCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-80"
                         CodeLanguage="razor">
                <FieldGroup MaxWidth="MaxWidth.IsSm">
                    <Field Horizontal="true">
                        <Check Id="terms-checkbox" Name="terms-checkbox" />
                        <Label For="terms-checkbox">Accept terms and conditions</Label>
                    </Field>

                    <Field Horizontal="true">
                        <Check Id="terms-checkbox-2" Name="terms-checkbox-2" Checked="true" />
                        <FieldContent>
                            <FieldLabel For="terms-checkbox-2">Accept terms and conditions</FieldLabel>
                            <FieldDescription>
                                By clicking this checkbox, you agree to the terms.
                            </FieldDescription>
                        </FieldContent>
                    </Field>

                    <Field Horizontal="true" Disabled="true">
                        <Check Id="toggle-checkbox" Name="toggle-checkbox" Disabled="true" />
                        <FieldLabel For="toggle-checkbox">Enable notifications</FieldLabel>
                    </Field>

                    <FieldLabel>
                        <Field Horizontal="true">
                            <Check Id="toggle-checkbox-2" Name="toggle-checkbox-2" />
                            <FieldContent>
                                <FieldTitle>Enable notifications</FieldTitle>
                                <FieldDescription>
                                    You can enable or disable notifications at any time.
                                </FieldDescription>
                            </FieldContent>
                        </Field>
                    </FieldLabel>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid State"
                         Description="Set aria-invalid on the checkbox and data-invalid on the field wrapper to show the invalid styles."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <FieldGroup Margin="Margin.Auto.OnX" Width='Width.Token("56")'>
                    <Field Horizontal="true" IsInvalid="true">
                        <Check Id="terms-checkbox-invalid" aria-invalid="true" />
                        <FieldLabel For="terms-checkbox-invalid">Accept terms and conditions</FieldLabel>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="Pair the checkbox with Field and FieldLabel for proper layout and labeling."
                         Code="@(@"<Field Horizontal=""true"">
    <Check Id=""checkbox-basic"" />
    <Label For=""checkbox-basic"">Accept terms and conditions</Label>
</Field>")"
                         CodeLanguage="razor">
                <Field Horizontal="true">
                    <Check Id="checkbox-basic" />
                    <Label For="checkbox-basic">Accept terms and conditions</Label>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Description"
                         Description="Use FieldContent and FieldDescription for helper text."
                         Code="@(@"<Field Horizontal=""true"">
    <Check Id=""checkbox-description"" Checked=""true"" />
    <FieldContent>
        <FieldLabel For=""checkbox-description"">Accept terms and conditions</FieldLabel>
        <FieldDescription>By clicking this checkbox, you agree to the terms.</FieldDescription>
    </FieldContent>
</Field>")"
                         CodeLanguage="razor">
                <Field Horizontal="true" MaxWidth="MaxWidth.IsSm">
                    <Check Id="checkbox-description" Checked="true" />
                    <FieldContent>
                        <FieldLabel For="checkbox-description">Accept terms and conditions</FieldLabel>
                        <FieldDescription>By clicking this checkbox, you agree to the terms and conditions.</FieldDescription>
                    </FieldContent>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Use the disabled prop to prevent interaction and add the data-disabled attribute to the Field component for disabled styles."
                         Code="@(@"<Field Horizontal=""true"" Disabled=""true"">
    <Check Id=""checkbox-disabled"" Disabled=""true"" />
    <FieldLabel For=""checkbox-disabled"">Enable notifications</FieldLabel>
</Field>")"
                         CodeLanguage="razor">
                <Field Horizontal="true" Disabled="true">
                    <Check Id="checkbox-disabled" Disabled="true" />
                    <FieldLabel For="checkbox-disabled">Enable notifications</FieldLabel>
                </Field>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Group"
                         Description="Use multiple fields to create a checkbox list."
                         Code="@GroupCode"
                         CodeLanguage="razor">
                <FieldSet>
                    <FieldLegend Variant="FieldLegendVariant.Label">Show these items on the desktop:</FieldLegend>
                    <FieldDescription>Select the items you want to show on the desktop.</FieldDescription>
                    <FieldGroup Class="gap-3">
                        <Field Horizontal="true">
                            <Check Id="finder-pref-hard-disks" Checked="true" />
                            <FieldLabel For="finder-pref-hard-disks" FontWeight="FontWeight.Normal">Hard disks</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="finder-pref-external-disks" Checked="true" />
                            <FieldLabel For="finder-pref-external-disks" FontWeight="FontWeight.Normal">External disks</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="finder-pref-cds" />
                            <FieldLabel For="finder-pref-cds" FontWeight="FontWeight.Normal">CDs, DVDs, and iPods</FieldLabel>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="finder-pref-connected-servers" />
                            <FieldLabel For="finder-pref-connected-servers" FontWeight="FontWeight.Normal">Connected servers</FieldLabel>
                        </Field>
                    </FieldGroup>
                </FieldSet>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Table"
                         Description="Header checkbox for select-all with row checkboxes."
                         Code="@TableCode"
                         PreviewClass="preview relative flex h-72 w-full justify-center data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 p-4 md:p-8"
                         CodeLanguage="razor">
                <TableElement>
                    <Thead>
                        <Tr>
                            <Th Class="w-8">
                                <Check Id="select-all-checkbox"
                                       Name="select-all-checkbox"
                                       Checked="@_tableSelectAll"
                                       Indeterminate="@_tableSelectIndeterminate"
                                       CheckedChanged="HandleTableSelectAllChanged" />
                            </Th>
                            <Th>Name</Th>
                            <Th>Email</Th>
                            <Th>Role</Th>
                        </Tr>
                    </Thead>
                    <Tbody>
                        @foreach (var row in _tablePeople)
                        {
                            <Tr Attributes="@GetTableRowAttributes(row.Id)">
                                <Td>
                                    <Check Id="@($"row-{row.Id}-checkbox")"
                                           Name="@($"row-{row.Id}-checkbox")"
                                           Checked="@GetRowSelected(row.Id)"
                                           CheckedChanged="@(v => HandleTableRowChanged(row.Id, v))" />
                                </Td>
                                <Td FontWeight="FontWeight.Medium">@row.Name</Td>
                                <Td>@row.Email</Td>
                                <Td>@row.Role</Td>
                            </Tr>
                        }
                    </Tbody>
                </TableElement>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Checkboxes align correctly in right-to-left layouts."
                         Code="@RtlCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-80"
                         PreviewDir="rtl"
                         PreviewLang="ar"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <FieldGroup MaxWidth="MaxWidth.IsSm">
                        <Field Horizontal="true">
                            <Check Id="terms-checkbox-rtl" />
                            <Label For="terms-checkbox-rtl">قبول الشروط والأحكام</Label>
                        </Field>
                        <Field Horizontal="true">
                            <Check Id="terms-checkbox-2-rtl" Checked="true" />
                            <FieldContent>
                                <FieldLabel For="terms-checkbox-2-rtl">قبول الشروط والأحكام</FieldLabel>
                                <FieldDescription>بالنقر على هذا المربع، فإنك توافق على الشروط والأحكام.</FieldDescription>
                            </FieldContent>
                        </Field>
                        <Field Horizontal="true" Disabled="true">
                            <Check Id="toggle-checkbox-rtl" Disabled="true" />
                            <FieldLabel For="toggle-checkbox-rtl">تفعيل الإشعارات</FieldLabel>
                        </Field>
                        <FieldLabel>
                            <Field Horizontal="true">
                                <Check Id="toggle-checkbox-2-rtl" />
                                <FieldContent>
                                    <FieldTitle>تفعيل الإشعارات</FieldTitle>
                                    <FieldDescription>يمكنك تفعيل أو إلغاء تفعيل الإشعارات في أي وقت.</FieldDescription>
                                </FieldContent>
                            </Field>
                        </FieldLabel>
                    </FieldGroup>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private sealed record TablePerson(string Id, string Name, string Email, string Role);
    private sealed record SidebarItem(string Id, string Label);
    private sealed class SingleCheckboxForm
    {
        public bool Mobile { get; set; } = true;
    }

    private sealed class MultipleCheckboxForm
    {
        public HashSet<string> Items { get; } = ["recents", "home"];
    }

    private static readonly TablePerson[] _tablePeople =
    [
        new("1", "Sarah Chen", "sarah.chen@example.com", "Admin"),
        new("2", "Marcus Rodriguez", "marcus.rodriguez@example.com", "User"),
        new("3", "Priya Patel", "priya.patel@example.com", "User"),
        new("4", "David Kim", "david.kim@example.com", "Editor")
    ];

    private static readonly SidebarItem[] _sidebarItems =
    [
        new("recents", "Recents"),
        new("home", "Home"),
        new("applications", "Applications"),
        new("desktop", "Desktop"),
        new("downloads", "Downloads"),
        new("documents", "Documents")
    ];

    private readonly HashSet<string> _selectedTableRows = ["1"];
    private readonly SingleCheckboxForm _singleForm = new();
    private readonly MultipleCheckboxForm _multipleForm = new();

    private bool _tableSelectAll;
    private bool _tableSelectIndeterminate;
    private bool _selectAllChecked;
    private bool _selectAllIndeterminate;
    private bool _itemRead = true;
    private bool _itemWrite;
    private bool _itemExecute;
    private bool _showMultipleError;
    private string? _singleSubmitJson;
    private string? _multipleSubmitJson;

    private const string DemoCode =
@"<FieldGroup Class=""max-w-sm"">
    <Field Horizontal=""true"">
        <Check Id=""terms-checkbox"" Name=""terms-checkbox"" />
        <Label For=""terms-checkbox"">Accept terms and conditions</Label>
    </Field>
    <Field Horizontal=""true"">
        <Check Id=""terms-checkbox-2"" Name=""terms-checkbox-2"" Checked=""true"" />
        <FieldContent>
            <FieldLabel For=""terms-checkbox-2"">Accept terms and conditions</FieldLabel>
            <FieldDescription>
                By clicking this checkbox, you agree to the terms.
            </FieldDescription>
        </FieldContent>
    </Field>
    <Field Horizontal=""true"" Disabled=""true"">
        <Check Id=""toggle-checkbox"" Name=""toggle-checkbox"" Disabled=""true"" />
        <FieldLabel For=""toggle-checkbox"">Enable notifications</FieldLabel>
    </Field>
    <FieldLabel>
        <Field Horizontal=""true"">
            <Check Id=""toggle-checkbox-2"" Name=""toggle-checkbox-2"" />
            <FieldContent>
                <FieldTitle>Enable notifications</FieldTitle>
                <FieldDescription>
                    You can enable or disable notifications at any time.
                </FieldDescription>
            </FieldContent>
        </Field>
    </FieldLabel>
</FieldGroup>";

    private const string FormSingleCode =
@"<EditForm Model=""_singleForm"" OnSubmit=""@(_ => HandleSingleSubmit())"" class=""flex max-w-md flex-col items-start gap-4"">
    <Field Horizontal=""true"" Class=""items-start gap-2 rounded-md border p-4 shadow-sm"">
        <Check Id=""mobile""
               Checked=""@_singleForm.Mobile""
               CheckedChanged=""HandleMobileChanged"" />
        <Div Class=""space-y-1 leading-none"">
            <FieldLabel For=""mobile"">Use different settings for my mobile devices</FieldLabel>
            <FieldDescription>
                You can manage your mobile notifications in the mobile settings page.
            </FieldDescription>
        </Div>
    </Field>
    <Button Type=""ButtonType.Submit"">Submit</Button>
</EditForm>";

    private const string FormMultipleCode =
@"<EditForm Model=""_multipleForm"" OnSubmit=""@(_ => HandleMultipleSubmit())"" class=""space-y-8"">
    <Field>
        <Div Class=""mb-4"">
            <FieldLabel Class=""text-base"">Sidebar</FieldLabel>
            <FieldDescription>
                Select the items you want to display in the sidebar.
            </FieldDescription>
        </Div>
        <FieldGroup Class=""gap-3"">
            @foreach (var item in _sidebarItems)
            {
                <Field Horizontal=""true"" Class=""items-center gap-2"">
                    <Check Id=""@item.Id""
                           Checked=""@_multipleForm.Items.Contains(item.Id)""
                           CheckedChanged=""@(checkedValue => HandleSidebarItemChanged(item.Id, checkedValue))"" />
                    <FieldLabel For=""@item.Id"" Class=""text-sm font-normal"">@item.Label</FieldLabel>
                </Field>
            }
        </FieldGroup>
    </Field>
    <Button Type=""ButtonType.Submit"">Submit</Button>
</EditForm>";

    private const string InvalidCode =
@"<FieldGroup Class=""mx-auto w-56"">
    <Field Horizontal=""true"" IsInvalid=""true"">
        <Check Id=""terms-checkbox-invalid"" Name=""terms-checkbox-invalid"" aria-invalid=""true"" />
        <FieldLabel For=""terms-checkbox-invalid"">Accept terms and conditions</FieldLabel>
    </Field>
</FieldGroup>";

    private const string IndeterminateCode =
@"<Check Checked=""_selectAllChecked"" CheckedChanged=""HandleSelectAllChanged"" Indeterminate=""_selectAllIndeterminate"" Id=""select-all"">
    Select all
</Check>
<Div class=""ml-6 space-y-3"">
    <Check Checked=""_itemRead"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemRead), v))"" Id=""item-read"">Read</Check>
    <Check Checked=""_itemWrite"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemWrite), v))"" Id=""item-write"">Write</Check>
    <Check Checked=""_itemExecute"" CheckedChanged=""@(v => HandlePermissionChanged(nameof(_itemExecute), v))"" Id=""item-execute"">Execute</Check>
</Div>";

    private const string GroupCode =
@"<FieldSet>
    <FieldLegend Variant=""FieldLegendVariant.Label"">Show these items on the desktop:</FieldLegend>
    <FieldDescription>Select the items you want to show on the desktop.</FieldDescription>
    <FieldGroup Class=""gap-3"">
        <Field Horizontal=""true"">
            <Check Id=""finder-pref-hard-disks"" Checked=""true"" />
            <FieldLabel For=""finder-pref-hard-disks"" Class=""font-normal"">Hard disks</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""finder-pref-external-disks"" Checked=""true"" />
            <FieldLabel For=""finder-pref-external-disks"" Class=""font-normal"">External disks</FieldLabel>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""finder-pref-cds"" />
            <FieldLabel For=""finder-pref-cds"" Class=""font-normal"">CDs, DVDs, and iPods</FieldLabel>
        </Field>
    </FieldGroup>
</FieldSet>";

    private const string TableCode =
@"<TableElement>
    <Thead>
        <Tr>
            <Th Class=""w-8"">
                <Check Id=""select-all-checkbox"" Name=""select-all-checkbox"" Checked=""@_tableSelectAll"" Indeterminate=""@_tableSelectIndeterminate"" CheckedChanged=""HandleTableSelectAllChanged"" />
            </Th>
            <Th>Name</Th>
            <Th>Email</Th>
            <Th>Role</Th>
        </Tr>
    </Thead>
    <Tbody>
        @foreach (var row in _tablePeople)
        {
            <Tr Attributes=""@GetTableRowAttributes(row.Id)"">
                <Td>
                    <Check Id=""@($""row-{row.Id}-checkbox"")"" Name=""@($""row-{row.Id}-checkbox"")"" Checked=""@GetRowSelected(row.Id)"" CheckedChanged=""@((bool v) => HandleTableRowChanged(row.Id, v))"" />
                </Td>
                <Td FontWeight=""FontWeight.Medium"">@row.Name</Td>
                <Td>@row.Email</Td>
                <Td>@row.Role</Td>
            </Tr>
        }
    </Tbody>
</TableElement>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <FieldGroup Class=""max-w-sm"">
        <Field Horizontal=""true"">
            <Check Id=""terms-checkbox-rtl"" />
            <Label For=""terms-checkbox-rtl"">قبول الشروط والأحكام</Label>
        </Field>
        <Field Horizontal=""true"">
            <Check Id=""terms-checkbox-2-rtl"" Checked=""true"" />
            <FieldContent>
                <FieldLabel For=""terms-checkbox-2-rtl"">قبول الشروط والأحكام</FieldLabel>
                <FieldDescription>بالنقر على هذا المربع، فإنك توافق على الشروط والأحكام.</FieldDescription>
            </FieldContent>
        </Field>
        <Field Horizontal=""true"" Disabled=""true"">
            <Check Id=""toggle-checkbox-rtl"" Disabled=""true"" />
            <FieldLabel For=""toggle-checkbox-rtl"">تفعيل الإشعارات</FieldLabel>
        </Field>
        <FieldLabel>
            <Field Horizontal=""true"">
                <Check Id=""toggle-checkbox-2-rtl"" />
                <FieldContent>
                    <FieldTitle>تفعيل الإشعارات</FieldTitle>
                    <FieldDescription>يمكنك تفعيل أو إلغاء تفعيل الإشعارات في أي وقت.</FieldDescription>
                </FieldContent>
            </Field>
        </FieldLabel>
    </FieldGroup>
</DirectionProvider>";

    protected override void OnInitialized()
    {
        UpdateSelectAll();
        UpdateTableSelectAll();
    }

    private IReadOnlyDictionary<string, object>? GetTableRowAttributes(string id)
    {
        if (!_selectedTableRows.Contains(id))
            return null;

        return new Dictionary<string, object> { ["data-state"] = "selected" };
    }

    private bool GetRowSelected(string id) => _selectedTableRows.Contains(id);

    private Task HandleMobileChanged(bool value)
    {
        _singleForm.Mobile = value;
        return Task.CompletedTask;
    }

    private Task HandleSidebarItemChanged(string id, bool value)
    {
        if (value)
            _multipleForm.Items.Add(id);
        else
            _multipleForm.Items.Remove(id);

        _showMultipleError = false;
        return Task.CompletedTask;
    }

    private Task HandleSingleSubmit()
    {
        _singleSubmitJson =
            $$"""
              {
                "mobile": {{_singleForm.Mobile.ToString().ToLowerInvariant()}}
              }
              """;

        return Task.CompletedTask;
    }

    private Task HandleMultipleSubmit()
    {
        if (_multipleForm.Items.Count == 0)
        {
            _showMultipleError = true;
            _multipleSubmitJson = null;
            return Task.CompletedTask;
        }

        _showMultipleError = false;
        _multipleSubmitJson =
            $$"""
              {
                "items": [{{string.Join(", ", _multipleForm.Items.Select(item => $"\"{item}\""))}}]
              }
              """;

        return Task.CompletedTask;
    }

    private void HandleSelectAllChanged(bool value)
    {
        _selectAllChecked = value;
        _selectAllIndeterminate = false;
        _itemRead = value;
        _itemWrite = value;
        _itemExecute = value;
    }

    private Task HandleTableSelectAllChanged(bool value)
    {
        if (value)
        {
            _selectedTableRows.Clear();
            foreach (var p in _tablePeople)
                _selectedTableRows.Add(p.Id);
        }
        else
        {
            _selectedTableRows.Clear();
        }

        UpdateTableSelectAll();
        return Task.CompletedTask;
    }

    private void HandlePermissionChanged(string permission, bool value)
    {
        switch (permission)
        {
            case nameof(_itemRead):
                _itemRead = value;
                break;
            case nameof(_itemWrite):
                _itemWrite = value;
                break;
            case nameof(_itemExecute):
                _itemExecute = value;
                break;
        }

        UpdateSelectAll();
    }

    private Task HandleTableRowChanged(string id, bool value)
    {
        if (value)
            _selectedTableRows.Add(id);
        else
            _selectedTableRows.Remove(id);

        UpdateTableSelectAll();
        return Task.CompletedTask;
    }

    private void UpdateSelectAll()
    {
        var all = _itemRead && _itemWrite && _itemExecute;
        var none = !_itemRead && !_itemWrite && !_itemExecute;
        _selectAllChecked = all;
        _selectAllIndeterminate = !all && !none;
    }

    private void UpdateTableSelectAll()
    {
        var all = _selectedTableRows.Count == _tablePeople.Length;
        _tableSelectAll = all;
        _tableSelectIndeterminate = false;
    }
}
