@page "/container"
@page "/containers"
@using Microsoft.Extensions.Logging

@inject ILogger<Containers> Logger

<PageTitle>Container - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is6xl">
    <Div Space="Space.Y.Is3">
        <H1>Container</H1>
        <Paragraph>
            `Container` gives you the common shadcn-style centered content wrapper by default:
            full width, a shared max width, auto horizontal margins, and responsive horizontal padding.
        </Paragraph>
    </Div>

    <Div Space="Space.Y.Is6">
        <DemoSection Title="Default Container"
                     Description="Centered content wrapper with responsive gutters out of the box."
                     Code="@(@"<Container Class=""rounded-xl border border-dashed border-border py-6"">
    <H3>Default container</H3>
    <Paragraph>Centered content with shadcn-style width and padding defaults.</Paragraph>
</Container>")"
CodeLanguage="razor">
            <Paragraph>
                Use `Container` when you want the standard centered docs or app-shell width without repeating
                `mx-auto w-full max-w-7xl px-4 md:px-6 lg:px-8`.
            </Paragraph>
            <Container Class="rounded-xl border border-dashed border-border py-6" Margin="Margin.Is3.FromBottom">
                <H3>Default container</H3>
                <Paragraph>Centered content with shadcn-style width and padding defaults.</Paragraph>
                <Paragraph>The built-in layout is ideal for docs pages, settings screens, and general content surfaces.</Paragraph>
            </Container>
        </DemoSection>

        <DemoSection Title="Override the Width"
                     Description="Bring your own max-width utilities while keeping the base centering behavior."
                     Code="@(@"<Container Class=""max-w-4xl rounded-xl border bg-card py-6"">
    <H3>Narrower container</H3>
    <Paragraph>Custom width override for tighter reading layouts.</Paragraph>
</Container>")"
CodeLanguage="razor">
            <Paragraph>
                Your custom `Class` value is appended after the default container classes, so width or padding overrides can intentionally win when needed.
            </Paragraph>
            <Container Class="max-w-4xl rounded-xl border bg-card py-6" Margin="Margin.Is3.FromBottom">
                <H3>Narrower container</H3>
                <Paragraph>This example trims the reading width for dense prose or form-heavy screens.</Paragraph>
                <UnorderedList>
                    <UnorderedListItem>The default centering still applies.</UnorderedListItem>
                    <UnorderedListItem>`max-w-4xl` overrides the wider default.</UnorderedListItem>
                    <UnorderedListItem>The component still keeps your content full width inside that cap.</UnorderedListItem>
                </UnorderedList>
            </Container>

            <Container Class="max-w-2xl rounded-xl border bg-muted/30 py-6">
                <H3>Even tighter layout</H3>
                <Paragraph>Useful for narrow content flows like auth, onboarding, or confirmation states.</Paragraph>
            </Container>
        </DemoSection>

        <DemoSection Title="Container + Surface Styling"
                     Description="Layer layout behavior with your own visual treatment."
                     Code="@(@"<Container Class=""rounded-2xl border bg-card px-6 py-8 shadow-sm"">
    <H3>Card-like section</H3>
    <Paragraph>Layout and surface styling can live together.</Paragraph>
</Container>")"
CodeLanguage="razor">
            <Container Class="rounded-2xl border bg-card px-6 py-8 shadow-sm">
                <H3>Card-like section</H3>
                <Paragraph>
                    `Container` handles the outer layout, while your utility classes shape the visual surface.
                    This is a common pattern for docs callouts, settings groups, and marketing sections.
                </Paragraph>
                <UnorderedList>
                    <UnorderedListItem>Rounded corners and borders create the surface.</UnorderedListItem>
                    <UnorderedListItem>Extra `px-6 py-8` can override the default gutter when desired.</UnorderedListItem>
                    <UnorderedListItem>The centered width behavior still comes from `Container` itself.</UnorderedListItem>
                </UnorderedList>
            </Container>
        </DemoSection>

        <DemoSection Title="Inherited Element Features"
                     Description="Id, Class, Style, Margin, Padding, events, and other Element features still apply."
                     Code="@(@"<Container Id=""details"" Class=""rounded-xl border"" Margin=""Margin.Is4.FromBottom"">
    <H3>Inherited element API</H3>
    <Paragraph>Container still exposes the shared Element surface.</Paragraph>
</Container>")"
CodeLanguage="razor">
            <Container Id="details" Class="rounded-xl border" Margin="Margin.Is4.FromBottom">
                <H3>Inherited element API</H3>
                <Paragraph>`Container` still inherits the shared `Element` surface.</Paragraph>
                <UnorderedList>
                    <UnorderedListItem><Strong>Id:</Strong> adds a standard HTML id.</UnorderedListItem>
                    <UnorderedListItem><Strong>Class / Style:</Strong> lets you layer custom utilities or inline styles.</UnorderedListItem>
                    <UnorderedListItem><Strong>Margin / Padding:</Strong> works alongside the default container layout.</UnorderedListItem>
                    <UnorderedListItem><Strong>Events:</Strong> click, focus, and keyboard handlers are still available.</UnorderedListItem>
                </UnorderedList>
            </Container>
        </DemoSection>
    </Div>
</Div>

@code{

    protected override void OnInitialized()
    {
        Logger.LogInformation("Container demo page initialized");
    }

}