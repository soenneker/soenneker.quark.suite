@page "/components/popover"

<PageTitle>Popover - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Displays rich content in a portal, triggered by a button."
                         Code="@BasicCode"
                         CodeLanguage="razor"
                         PreviewClass="@PopoverPreviewClass">
                @BasicPopover("Open popover", "popover")
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A simple popover with a header, title, and description."
                         Code="@BasicPreview2Code"
                         CodeLanguage="razor"
                         PreviewClass="@PopoverPreviewClass">
                @HeaderPopover()
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Align"
                         Description="Use the align prop on PopoverContent to control the horizontal alignment."
                         Code="@AlignmentsCode"
                         CodeLanguage="razor"
                         PreviewClass="@PopoverPreviewClass">
                        <Div Display="Display.Flex" Flex="@Flex.Wrap" ItemsAlign="Items.Start" Gap="Gap.Is6">
                            <Popover>
                                <PopoverTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Sm">Start</Button>
                                </PopoverTrigger>
                                <PopoverContent Align="Alignment.Start" Width='Width.Token("40")'>
                                    Aligned to start
                                </PopoverContent>
                            </Popover>
                            <Popover>
                                <PopoverTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Sm">Center</Button>
                                </PopoverTrigger>
                                <PopoverContent Align="Alignment.Center" Width='Width.Token("40")'>
                                    Aligned to center
                                </PopoverContent>
                            </Popover>
                            <Popover>
                                <PopoverTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Sm">End</Button>
                                </PopoverTrigger>
                                <PopoverContent Align="Alignment.End" Width='Width.Token("40")'>
                                    Aligned to end
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Form"
                         Description="A popover with form fields inside."
                         Code="@WithFormCode"
                         CodeLanguage="razor"
                         PreviewClass="@PopoverPreviewClass">
                <Popover>
                    <PopoverTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Popover</Button>
                    </PopoverTrigger>
                    <PopoverContent Width='Width.Token("64")' Align="Alignment.Start">
                        <PopoverHeader>
                            <PopoverTitle>Dimensions</PopoverTitle>
                            <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
                        </PopoverHeader>
                        <FieldGroup Gap="Gap.Is4">
                            <Field Orientation="@Orientation.Horizontal">
                                <FieldLabel For="form-width" Width="Width.Is1of2">Width</FieldLabel>
                                <Input Id="form-width" Value="100%" />
                            </Field>
                            <Field Orientation="@Orientation.Horizontal">
                                <FieldLabel For="form-height" Width="Width.Is1of2">Height</FieldLabel>
                                <Input Id="form-height" Value="25px" />
                            </Field>
                        </FieldGroup>
                    </PopoverContent>
                </Popover>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Popover respects right-to-left direction."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         PreviewClass="@PopoverPreviewClass">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" Flex="@Flex.Wrap" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is3" Width="Width.IsFull" TextAlign="TextAlign.End" dir="rtl">
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">يسار</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Left" dir="rtl">
                                <PopoverHeader>
                                    <PopoverTitle>الأبعاد</PopoverTitle>
                                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                                </PopoverHeader>
                            </PopoverContent>
                        </Popover>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">أعلى</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Top" dir="rtl">
                                <PopoverHeader>
                                    <PopoverTitle>الأبعاد</PopoverTitle>
                                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                                </PopoverHeader>
                            </PopoverContent>
                        </Popover>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">أسفل</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Bottom" dir="rtl">
                                <PopoverHeader>
                                    <PopoverTitle>الأبعاد</PopoverTitle>
                                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                                </PopoverHeader>
                            </PopoverContent>
                        </Popover>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">يمين</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Right" dir="rtl">
                                <PopoverHeader>
                                    <PopoverTitle>الأبعاد</PopoverTitle>
                                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                                </PopoverHeader>
                            </PopoverContent>
                        </Popover>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string PopoverPreviewClass = "preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start";

    private RenderFragment BasicPopover(string text, string idPrefix) => @<Popover>
        <PopoverTrigger AsChild="true">
            <Button Variant="ButtonVariant.Outline">@text</Button>
        </PopoverTrigger>
        <PopoverContent Width='Width.Token("80")'>
            <Div Display="Display.Grid" Gap="Gap.Is4">
                <PopoverHeader>
                    <PopoverTitle>Dimensions</PopoverTitle>
                    <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
                </PopoverHeader>
                <Div Display="Display.Grid" Gap="Gap.Is2">
                    <Div Display="Display.Grid" ItemsAlign="Items.Center" Gap="Gap.Is4" Class="grid-cols-3">
                        <Label For="@($"{idPrefix}-width")">Width</Label>
                        <Input Id="@($"{idPrefix}-width")" Value="100%" Height="Height.Is8" Class="col-span-2" />
                    </Div>
                    <Div Display="Display.Grid" ItemsAlign="Items.Center" Gap="Gap.Is4" Class="grid-cols-3">
                        <Label For="@($"{idPrefix}-max-width")">Max. width</Label>
                        <Input Id="@($"{idPrefix}-max-width")" Value="300px" Height="Height.Is8" Class="col-span-2" />
                    </Div>
                    <Div Display="Display.Grid" ItemsAlign="Items.Center" Gap="Gap.Is4" Class="grid-cols-3">
                        <Label For="@($"{idPrefix}-height")">Height</Label>
                        <Input Id="@($"{idPrefix}-height")" Value="25px" Height="Height.Is8" Class="col-span-2" />
                    </Div>
                    <Div Display="Display.Grid" ItemsAlign="Items.Center" Gap="Gap.Is4" Class="grid-cols-3">
                        <Label For="@($"{idPrefix}-max-height")">Max. height</Label>
                        <Input Id="@($"{idPrefix}-max-height")" Value="none" Height="Height.Is8" Class="col-span-2" />
                    </Div>
                </Div>
            </Div>
        </PopoverContent>
    </Popover>;

    private RenderFragment HeaderPopover() => @<Popover>
        <PopoverTrigger AsChild="true">
            <Button Variant="ButtonVariant.Outline">Open Popover</Button>
        </PopoverTrigger>
        <PopoverContent Align="Alignment.Start">
            <PopoverHeader>
                <PopoverTitle>Dimensions</PopoverTitle>
                <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
            </PopoverHeader>
        </PopoverContent>
    </Popover>;

    private const string BasicCode =
@"@BasicPopover(""Open popover"", ""popover"")";

    private const string BasicPreview2Code =
@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Popover</Button>
    </PopoverTrigger>
    <PopoverContent Align=""Alignment.Start"">
        <PopoverHeader>
            <PopoverTitle>Dimensions</PopoverTitle>
            <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
        </PopoverHeader>
    </PopoverContent>
</Popover>";

    private const string AlignmentsCode =
@"<Div Display=""Display.Flex"" Flex=""@Flex.Wrap"" ItemsAlign=""Items.Start"" Gap=""Gap.Is6"">
    <Popover>
        <PopoverTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"" ButtonSize=""ButtonSize.Sm"">Start</Button>
        </PopoverTrigger>
        <PopoverContent Align=""Alignment.Start"" Width='Width.Token(""40"")'>
            Aligned to start
        </PopoverContent>
    </Popover>
    <Popover>
        <PopoverTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"" ButtonSize=""ButtonSize.Sm"">Center</Button>
        </PopoverTrigger>
        <PopoverContent Align=""Alignment.Center"" Width='Width.Token(""40"")'>
            Aligned to center
        </PopoverContent>
    </Popover>
    <Popover>
        <PopoverTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"" ButtonSize=""ButtonSize.Sm"">End</Button>
        </PopoverTrigger>
        <PopoverContent Align=""Alignment.End"" Width='Width.Token(""40"")'>
            Aligned to end
        </PopoverContent>
    </Popover>
</Div>";

    private const string WithFormCode =
@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Popover</Button>
    </PopoverTrigger>
    <PopoverContent Width='Width.Token(""64"")' Align=""Alignment.Start"">
        <PopoverHeader>
            <PopoverTitle>Dimensions</PopoverTitle>
            <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
        </PopoverHeader>
        <FieldGroup Gap=""Gap.Is4"">
            <Field Orientation=""horizontal"">
                <FieldLabel For=""form-width"" Width=""Width.Is1of2"">Width</FieldLabel>
                <Input Id=""form-width"" Value=""100%"" />
            </Field>
            <Field Orientation=""horizontal"">
                <FieldLabel For=""form-height"" Width=""Width.Is1of2"">Height</FieldLabel>
                <Input Id=""form-height"" Value=""25px"" />
            </Field>
        </FieldGroup>
    </PopoverContent>
</Popover>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Div Display=""Display.Flex"" Flex=""@Flex.Wrap"" ItemsAlign=""Items.Center"" Justify=""Justify.Center"" Gap=""Gap.Is3"" Width=""Width.IsFull"" TextAlign=""TextAlign.End"" dir=""rtl"">
        <Popover>
            <PopoverTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">يسار</Button>
            </PopoverTrigger>
            <PopoverContent Side=""Side.Left"" dir=""rtl"">
                <PopoverHeader>
                    <PopoverTitle>الأبعاد</PopoverTitle>
                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                </PopoverHeader>
            </PopoverContent>
        </Popover>
        <Popover>
            <PopoverTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">أعلى</Button>
            </PopoverTrigger>
            <PopoverContent Side=""Side.Top"" dir=""rtl"">
                <PopoverHeader>
                    <PopoverTitle>الأبعاد</PopoverTitle>
                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                </PopoverHeader>
            </PopoverContent>
        </Popover>
        <Popover>
            <PopoverTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">أسفل</Button>
            </PopoverTrigger>
            <PopoverContent Side=""Side.Bottom"" dir=""rtl"">
                <PopoverHeader>
                    <PopoverTitle>الأبعاد</PopoverTitle>
                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                </PopoverHeader>
            </PopoverContent>
        </Popover>
        <Popover>
            <PopoverTrigger AsChild=""true"">
                <Button Variant=""ButtonVariant.Outline"">يمين</Button>
            </PopoverTrigger>
            <PopoverContent Side=""Side.Right"" dir=""rtl"">
                <PopoverHeader>
                    <PopoverTitle>الأبعاد</PopoverTitle>
                    <PopoverDescription>تعيين الأبعاد للطبقة.</PopoverDescription>
                </PopoverHeader>
            </PopoverContent>
        </Popover>
    </Div>
</DirectionProvider>";
}
