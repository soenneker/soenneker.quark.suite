@page "/popovers"

<PageTitle>Popovers - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="shadcn-style popover with trigger and content."
                         Code="@BasicCode">
                <Popover>
                    <PopoverTrigger>
                        <Button Variant="ButtonVariant.Outline">Open popover</Button>
                    </PopoverTrigger>
                    <PopoverContent Class="w-80">
                        <Div Class="grid gap-4">
                            <PopoverHeader>
                                <PopoverTitle>Dimensions</PopoverTitle>
                                <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
                            </PopoverHeader>
                            <Div Class="grid gap-2">
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label Form="true">Width</Label>
                                    <Div Class="col-span-2 h-8 rounded-md border px-3 py-1 text-sm text-muted-foreground">100%</Div>
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label Form="true">Max. width</Label>
                                    <Div Class="col-span-2 h-8 rounded-md border px-3 py-1 text-sm text-muted-foreground">300px</Div>
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label Form="true">Height</Label>
                                    <Div Class="col-span-2 h-8 rounded-md border px-3 py-1 text-sm text-muted-foreground">25px</Div>
                                </Div>
                            </Div>
                        </Div>
                    </PopoverContent>
                </Popover>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Align"
                         Description="Change alignment to anchor the content start, center, or end relative to the trigger."
                         Code="@AlignCode">
                <Div Class="flex flex-wrap items-start gap-3">
                    <Popover>
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline">Start</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="start">
                            <PopoverHeader>
                                <PopoverTitle>Start aligned</PopoverTitle>
                                <PopoverDescription>
                                    Anchor to the start edge when the trigger is part of a left-aligned layout.
                                </PopoverDescription>
                            </PopoverHeader>
                        </PopoverContent>
                    </Popover>
                    <Popover>
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline">Center</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="center">
                            <PopoverHeader>
                                <PopoverTitle>Center aligned</PopoverTitle>
                                <PopoverDescription>
                                    Center alignment matches the most common popover presentation.
                                </PopoverDescription>
                            </PopoverHeader>
                        </PopoverContent>
                    </Popover>
                    <Popover>
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline">End</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="end">
                            <PopoverHeader>
                                <PopoverTitle>End aligned</PopoverTitle>
                                <PopoverDescription>
                                    Use end alignment when the trigger sits near the edge of a card or panel.
                                </PopoverDescription>
                            </PopoverHeader>
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>
        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Form"
                         Description="@($"Open: {_open}. Use DisableAutoOpen for explicit visibility control or keep it self-managed for small forms.")"
                         Code="@WithFormCode">
                <Div Class="flex flex-wrap items-start gap-3">
                    <Button BackgroundColor="BackgroundColor.Primary" TextColor="TextColor.PrimaryForeground" OnClick="TogglePopover">
                        Toggle popover
                    </Button>

                    <Popover>
                        <PopoverTrigger>
                            <Button Variant="ButtonVariant.Outline">Edit dimensions</Button>
                        </PopoverTrigger>
                        <PopoverContent Open="_open" DisableAutoOpen="true" Class="w-80">
                            <Div Class="grid gap-4">
                                <PopoverHeader>
                                    <PopoverTitle>Dimensions</PopoverTitle>
                                    <PopoverDescription>
                                        Update the values below and save them back to the current layer.
                                    </PopoverDescription>
                                </PopoverHeader>
                                <Div Class="grid gap-3">
                                    <Div Class="grid grid-cols-3 items-center gap-4">
                                        <Label Form="true">Width</Label>
                                        <Input Type="text" Class="col-span-2" Value="100%" />
                                    </Div>
                                    <Div Class="grid grid-cols-3 items-center gap-4">
                                        <Label Form="true">Max width</Label>
                                        <Input Type="text" Class="col-span-2" Value="300px" />
                                    </Div>
                                    <Div Class="grid grid-cols-3 items-center gap-4">
                                        <Label Form="true">Height</Label>
                                        <Input Type="text" Class="col-span-2" Value="25px" />
                                    </Div>
                                </Div>
                                <Div Class="flex justify-end gap-2">
                                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Cancel</Button>
                                    <Button Size="ButtonSize.Sm">Save</Button>
                                </Div>
                            </Div>
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _open;

    private Task TogglePopover()
    {
        _open = !_open;
        return Task.CompletedTask;
    }

    private const string BasicCode =
@"<Popover>
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"">Open popover</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-80"">
        <PopoverHeader>
            <PopoverTitle>Dimensions</PopoverTitle>
            <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
        </PopoverHeader>
    </PopoverContent>
</Popover>";

    private const string AlignCode =
@"<Popover><PopoverTrigger><Button Variant=""ButtonVariant.Outline"">Start</Button></PopoverTrigger><PopoverContent Align=""start"">...</PopoverContent></Popover>
<Popover><PopoverTrigger><Button Variant=""ButtonVariant.Outline"">Center</Button></PopoverTrigger><PopoverContent Align=""center"">...</PopoverContent></Popover>
<Popover><PopoverTrigger><Button Variant=""ButtonVariant.Outline"">End</Button></PopoverTrigger><PopoverContent Align=""end"">...</PopoverContent></Popover>";

    private const string WithFormCode =
@"<Popover>
    <PopoverTrigger>
        <Button Variant=""ButtonVariant.Outline"">Edit dimensions</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-80"">
        <Input Type=""text"" Value=""100%"" />
        <Input Type=""text"" Value=""300px"" />
        <Input Type=""text"" Value=""25px"" />
    </PopoverContent>
</Popover>";
}
