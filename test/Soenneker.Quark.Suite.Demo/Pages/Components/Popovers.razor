@page "/popovers"

<PageTitle>Popover - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Displays rich content in a portal, triggered by a button."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                @BasicPopover("Open popover", "popover")
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A simple popover with a header, title, and description."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                @BasicPopover("Open Popover", "basic")
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Align"
                         Description="Use the align prop on PopoverContent to control the horizontal alignment."
                         Code="@AlignmentsCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex="@Flex.Wrap" ItemsAlign="Items.Start" Gap="Gap.Is3">
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Start</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="Alignment.Start" Width='Width.Token("40")'>
                            Aligned to start
                        </PopoverContent>
                    </Popover>
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Center</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="Alignment.Center" Width='Width.Token("40")'>
                            Aligned to center
                        </PopoverContent>
                    </Popover>
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">End</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="Alignment.End" Width='Width.Token("40")'>
                            Aligned to end
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Form"
                         Description="A popover with form fields inside."
                         Code="@WithFormCode"
                         CodeLanguage="razor">
                <Popover>
                    <PopoverTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Popover</Button>
                    </PopoverTrigger>
                    <PopoverContent Width='Width.Token("64")' Align="Alignment.Start">
                        <PopoverHeader>
                            <PopoverTitle>Dimensions</PopoverTitle>
                            <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
                        </PopoverHeader>
                        <FieldGroup Class="gap-4">
                            <Field Orientation="Orientation.Horizontal">
                                <FieldLabel For="form-width" Class="w-1/2">Width</FieldLabel>
                                <Input Id="form-width" Value="100%" />
                            </Field>
                            <Field Orientation="Orientation.Horizontal">
                                <FieldLabel For="form-height" Class="w-1/2">Height</FieldLabel>
                                <Input Id="form-height" Value="25px" />
                            </Field>
                        </FieldGroup>
                    </PopoverContent>
                </Popover>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Popover respects right-to-left direction."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Display="Display.Flex" Flex="@Flex.Wrap" ItemsAlign="Items.Center" Justify="Justify.Center" Gap="Gap.Is3" Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">يسار</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Left" Width='Width.Token("56")'>
                                تظهر النافذة يسار الزر.
                            </PopoverContent>
                        </Popover>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">أعلى</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Top" Width='Width.Token("56")'>
                                تظهر النافذة أعلى الزر.
                            </PopoverContent>
                        </Popover>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">أسفل</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Bottom" Width='Width.Token("56")'>
                                تظهر النافذة أسفل الزر.
                            </PopoverContent>
                        </Popover>
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">يمين</Button>
                            </PopoverTrigger>
                            <PopoverContent Side="Side.Right" Width='Width.Token("56")'>
                                تظهر النافذة يمين الزر.
                            </PopoverContent>
                        </Popover>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private RenderFragment BasicPopover(string text, string idPrefix) => @<Popover>
        <PopoverTrigger AsChild="true">
            <Button Variant="ButtonVariant.Outline">@text</Button>
        </PopoverTrigger>
        <PopoverContent Width='Width.Token("80")'>
            <Div Display="Display.Grid" Gap="Gap.Is4">
                <PopoverHeader>
                    <PopoverTitle>Dimensions</PopoverTitle>
                    <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
                </PopoverHeader>
                <Div Display="Display.Grid" Gap="Gap.Is2">
                    <Div Class="grid grid-cols-3 items-center gap-4">
                        <Label For="@($"{idPrefix}-width")">Width</Label>
                        <Input Id="@($"{idPrefix}-width")" Value="100%" Class="col-span-2 h-8" />
                    </Div>
                    <Div Class="grid grid-cols-3 items-center gap-4">
                        <Label For="@($"{idPrefix}-max-width")">Max. width</Label>
                        <Input Id="@($"{idPrefix}-max-width")" Value="300px" Class="col-span-2 h-8" />
                    </Div>
                    <Div Class="grid grid-cols-3 items-center gap-4">
                        <Label For="@($"{idPrefix}-height")">Height</Label>
                        <Input Id="@($"{idPrefix}-height")" Value="25px" Class="col-span-2 h-8" />
                    </Div>
                    <Div Class="grid grid-cols-3 items-center gap-4">
                        <Label For="@($"{idPrefix}-max-height")">Max. height</Label>
                        <Input Id="@($"{idPrefix}-max-height")" Value="none" Class="col-span-2 h-8" />
                    </Div>
                </Div>
            </Div>
        </PopoverContent>
    </Popover>;

    private const string BasicCode =
@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open popover</Button>
    </PopoverTrigger>
    <PopoverContent Width='Width.Token(""80"")'>
        ...
    </PopoverContent>
</Popover>";

    private const string AlignmentsCode =
@"<Popover>
    <PopoverTrigger AsChild=""true""><Button Variant=""ButtonVariant.Outline"">Start</Button></PopoverTrigger>
    <PopoverContent Align=""Alignment.Start"">Aligned to start</PopoverContent>
</Popover>";

    private const string WithFormCode =
@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Popover</Button>
    </PopoverTrigger>
    <PopoverContent Width='Width.Token(""64"")' Align=""Alignment.Start"">
        <PopoverHeader>
            <PopoverTitle>Dimensions</PopoverTitle>
            <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
        </PopoverHeader>
        <FieldGroup Class=""gap-4"">...</FieldGroup>
    </PopoverContent>
</Popover>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Popover>
        <PopoverTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">يسار</Button>
        </PopoverTrigger>
        <PopoverContent Side=""Side.Left"">تظهر النافذة يسار الزر.</PopoverContent>
    </Popover>
</DirectionProvider>";
}
