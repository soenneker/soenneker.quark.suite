@page "/popovers"

<PageTitle>Popovers - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Displays rich content in a portal, triggered by a button."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Popover>
                    <PopoverTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open popover</Button>
                    </PopoverTrigger>
                    <PopoverContent Width='Width.Token("80")'>
                        <Div Display="Display.Grid" Gap="Gap.Is4">
                            <PopoverHeader>
                                <PopoverTitle>Dimensions</PopoverTitle>
                                <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
                            </PopoverHeader>
                            <Div Display="Display.Grid" Gap="Gap.Is2">
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-width">Width</Label>
                                    <Input Id="popover-width" Value="100%" Class="col-span-2 h-8" />
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-max-width">Max. width</Label>
                                    <Input Id="popover-max-width" Value="300px" Class="col-span-2 h-8" />
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-height">Height</Label>
                                    <Input Id="popover-height" Value="25px" Class="col-span-2 h-8" />
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-max-height">Max. height</Label>
                                    <Input Id="popover-max-height" Value="none" Class="col-span-2 h-8" />
                                </Div>
                            </Div>
                        </Div>
                    </PopoverContent>
                </Popover>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="Shadcn-aligned Basic example."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Popover>
                    <PopoverTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open popover</Button>
                    </PopoverTrigger>
                    <PopoverContent Width='Width.Token("80")'>
                        <Div Display="Display.Grid" Gap="Gap.Is4">
                            <PopoverHeader>
                                <PopoverTitle>Dimensions</PopoverTitle>
                                <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
                            </PopoverHeader>
                            <Div Display="Display.Grid" Gap="Gap.Is2">
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-width">Width</Label>
                                    <Input Id="popover-width" Value="100%" Class="col-span-2 h-8" />
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-max-width">Max. width</Label>
                                    <Input Id="popover-max-width" Value="300px" Class="col-span-2 h-8" />
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-height">Height</Label>
                                    <Input Id="popover-height" Value="25px" Class="col-span-2 h-8" />
                                </Div>
                                <Div Class="grid grid-cols-3 items-center gap-4">
                                    <Label For="popover-max-height">Max. height</Label>
                                    <Input Id="popover-max-height" Value="none" Class="col-span-2 h-8" />
                                </Div>
                            </Div>
                        </Div>
                    </PopoverContent>
                </Popover>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="Align"
                         Description="Use `Align` on the content to anchor the panel to start, center, or end."
                         Code="@AlignmentsCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex="@Flex.Wrap" ItemsAlign="Items.Start" Gap="Gap.Is3">
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Start</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="Alignment.Start" Width='Width.Token("40")'>
                            Aligned to start
                        </PopoverContent>
                    </Popover>
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Center</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="Alignment.Center" Width='Width.Token("40")'>
                            Aligned to center
                        </PopoverContent>
                    </Popover>
                    <Popover>
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">End</Button>
                        </PopoverTrigger>
                        <PopoverContent Align="Alignment.End" Width='Width.Token("40")'>
                            Aligned to end
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Form"
                         Description="Compact fields inside the popover using horizontal field layout."
                         Code="@WithFormCode"
                         CodeLanguage="razor">
                <Popover>
                    <PopoverTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Popover</Button>
                    </PopoverTrigger>
                    <PopoverContent Width='Width.Token("64")' Align="Alignment.Start">
                        <PopoverHeader>
                            <PopoverTitle>Dimensions</PopoverTitle>
                            <PopoverDescription>
                                Set the dimensions for the layer.
                            </PopoverDescription>
                        </PopoverHeader>
                        <FieldGroup Class="gap-4">
                            <Field Orientation="Orientation.Horizontal">
                                <FieldLabel For="form-width" Class="w-1/2">Width</FieldLabel>
                                <Input Id="form-width" Value="100%" />
                            </Field>
                            <Field Orientation="Orientation.Horizontal">
                                <FieldLabel For="form-height" Class="w-1/2">Height</FieldLabel>
                                <Input Id="form-height" Value="25px" />
                            </Field>
                        </FieldGroup>
                    </PopoverContent>
                </Popover>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Popover respects right-to-left direction when wrapped in `DirectionProvider`."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div Width="Width.IsFull" TextAlign="TextAlign.End">
                        <Popover>
                            <PopoverTrigger AsChild="true">
                                <Button Variant="ButtonVariant.Outline">افتح النافذة</Button>
                            </PopoverTrigger>
                            <PopoverContent Width='Width.Token("72")' Align="Alignment.Start">
                                <PopoverHeader>
                                    <PopoverTitle>الإعدادات</PopoverTitle>
                                    <PopoverDescription>
                                        تظهر المحاذاة والرسوم بشكل صحيح في الاتجاه من اليمين إلى اليسار.
                                    </PopoverDescription>
                                </PopoverHeader>
                            </PopoverContent>
                        </Popover>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Custom Role"
                         Description="Popover content can expose a non-dialog role when the surface behaves like a picker or listbox."
                         Code="@CustomRoleCode"
                         CodeLanguage="razor">
                <Popover DefaultOpen="true">
                    <PopoverTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open custom listbox</Button>
                    </PopoverTrigger>
                    <PopoverContent Width='Width.Token("56")' role="listbox" aria-label="Framework choices">
                        <Div role="option" aria-selected="false">Remix</Div>
                        <Div role="option" aria-selected="true">Astro</Div>
                    </PopoverContent>
                </Popover>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="In Dialog"
                         Description="A popover opened from content inside a modal dialog."
                         Code="@InDialogCode"
                         CodeLanguage="razor">
                <Dialog>
                    <DialogTrigger AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open Dialog</Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Popover Example</DialogTitle>
                            <DialogDescription>
                                Click the button below to see the popover.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogBody>
                            <Popover>
                                <PopoverTrigger AsChild="true">
                                    <Button Variant="ButtonVariant.Outline" Width="Width.IsFit">
                                        Open Popover
                                    </Button>
                                </PopoverTrigger>
                                <PopoverContent Align="Alignment.Start">
                                    <PopoverHeader>
                                        <PopoverTitle>Popover in Dialog</PopoverTitle>
                                        <PopoverDescription>
                                            This popover appears inside a dialog.
                                        </PopoverDescription>
                                    </PopoverHeader>
                                </PopoverContent>
                            </Popover>
                        </DialogBody>
                    </DialogContent>
                </Dialog>
            </DemoSection>

            <DemoSection Title="Controlled Open State"
                         Description="Drive visibility with `Open` and `OpenChanged` for external toggles."
                         Code="@ControlledCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Flex="@Flex.Wrap" ItemsAlign="Items.Start" Gap="Gap.Is3">
                    <Button Id="popover-controlled-toggle" Variant="ButtonVariant.Outline" OnClick="TogglePopover">
                        Toggle popover
                    </Button>
                    <Span Id="popover-controlled-state" data-slot="controlled-open-state" Class="self-center text-sm text-muted-foreground">
                        Open: @(_open ? "true" : "false")
                    </Span>
                    <Popover Open="_open" OpenChanged="OnOpenChanged">
                        <PopoverTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Edit dimensions</Button>
                        </PopoverTrigger>
                        <PopoverContent Width='Width.Token("80")'>
                            <Div Display="Display.Grid" Gap="Gap.Is4">
                                <PopoverHeader>
                                    <PopoverTitle>Dimensions</PopoverTitle>
                                    <PopoverDescription>
                                        Update the values below and save them back to the current layer.
                                    </PopoverDescription>
                                </PopoverHeader>
                                <Div Display="Display.Grid" Gap="Gap.Is3">
                                    <Div Class="grid grid-cols-3 items-center gap-4">
                                        <Label For="controlled-width">Width</Label>
                                        <Input Id="controlled-width" Type="text" Class="col-span-2" Value="100%" />
                                    </Div>
                                    <Div Class="grid grid-cols-3 items-center gap-4">
                                        <Label For="controlled-max-width">Max width</Label>
                                        <Input Id="controlled-max-width" Type="text" Class="col-span-2" Value="300px" />
                                    </Div>
                                    <Div Class="grid grid-cols-3 items-center gap-4">
                                        <Label For="controlled-height">Height</Label>
                                        <Input Id="controlled-height" Type="text" Class="col-span-2" Value="25px" />
                                    </Div>
                                </Div>
                                <Div Class="flex justify-end gap-2">
                                    <Button Variant="ButtonVariant.Outline" Size="ButtonSize.Sm">Cancel</Button>
                                    <Button Size="ButtonSize.Sm">Save</Button>
                                </Div>
                            </Div>
                        </PopoverContent>
                    </Popover>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _open;

    private Task TogglePopover(MouseEventArgs _)
    {
        _open = !_open;
        return Task.CompletedTask;
    }

    private const string BasicCode =
@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open popover</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-80"">
        <Div Class=""grid gap-4"">
            <PopoverHeader>
                <PopoverTitle>Dimensions</PopoverTitle>
                <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
            </PopoverHeader>
            <Div Class=""grid gap-2"">
                <Div Class=""grid grid-cols-3 items-center gap-4"">
                    <Label For=""popover-width"">Width</Label>
                    <Input Id=""popover-width"" Value=""100%"" Class=""col-span-2 h-8"" />
                </Div>
                <Div Class=""grid grid-cols-3 items-center gap-4"">
                    <Label For=""popover-max-width"">Max. width</Label>
                    <Input Id=""popover-max-width"" Value=""300px"" Class=""col-span-2 h-8"" />
                </Div>
                <Div Class=""grid grid-cols-3 items-center gap-4"">
                    <Label For=""popover-height"">Height</Label>
                    <Input Id=""popover-height"" Value=""25px"" Class=""col-span-2 h-8"" />
                </Div>
                <Div Class=""grid grid-cols-3 items-center gap-4"">
                    <Label For=""popover-max-height"">Max. height</Label>
                    <Input Id=""popover-max-height"" Value=""none"" Class=""col-span-2 h-8"" />
                </Div>
            </Div>
        </Div>
    </PopoverContent>
</Popover>";

    private const string WithFormCode =
@"<Popover>
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Popover</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-64"" Align=""Alignment.Start"">
        <PopoverHeader>
            <PopoverTitle>Dimensions</PopoverTitle>
            <PopoverDescription>Set the dimensions for the layer.</PopoverDescription>
        </PopoverHeader>
        <FieldGroup Class=""gap-4"">
            <Field Orientation=""Orientation.Horizontal"">
                <FieldLabel For=""form-width"" Class=""w-1/2"">Width</FieldLabel>
                <Input Id=""form-width"" Value=""100%"" />
            </Field>
            <Field Orientation=""Orientation.Horizontal"">
                <FieldLabel For=""form-height"" Class=""w-1/2"">Height</FieldLabel>
                <Input Id=""form-height"" Value=""25px"" />
            </Field>
        </FieldGroup>
    </PopoverContent>
</Popover>";

    private const string CustomRoleCode =
@"<Popover DefaultOpen=""true"">
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open custom listbox</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-56"" role=""listbox"" aria-label=""Framework choices"">
        <Div role=""option"" aria-selected=""false"">Remix</Div>
        <Div role=""option"" aria-selected=""true"">Astro</Div>
    </PopoverContent>
</Popover>";

    private const string AlignmentsCode =
@"<Popover><PopoverTrigger AsChild=""true""><Button Variant=""ButtonVariant.Outline"">Start</Button></PopoverTrigger><PopoverContent Align=""Alignment.Start"" Class=""w-40"">Aligned to start</PopoverContent></Popover>
<Popover><PopoverTrigger AsChild=""true""><Button Variant=""ButtonVariant.Outline"">Center</Button></PopoverTrigger><PopoverContent Align=""Alignment.Center"" Class=""w-40"">Aligned to center</PopoverContent></Popover>
<Popover><PopoverTrigger AsChild=""true""><Button Variant=""ButtonVariant.Outline"">End</Button></PopoverTrigger><PopoverContent Align=""Alignment.End"" Class=""w-40"">Aligned to end</PopoverContent></Popover>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Popover>
        <PopoverTrigger AsChild=""true"">
            <Button Variant=""ButtonVariant.Outline"">افتح النافذة</Button>
        </PopoverTrigger>
        <PopoverContent Class=""w-72"" Align=""Alignment.Start"">
            <PopoverHeader>
                <PopoverTitle>الإعدادات</PopoverTitle>
                <PopoverDescription>
                    تظهر المحاذاة والرسوم بشكل صحيح في الاتجاه من اليمين إلى اليسار.
                </PopoverDescription>
            </PopoverHeader>
        </PopoverContent>
    </Popover>
</DirectionProvider>";

    private const string InDialogCode =
@"<Dialog>
    <DialogTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open Dialog</Button>
    </DialogTrigger>
    <DialogContent>
        <DialogHeader>
            <DialogTitle>Popover Example</DialogTitle>
            <DialogDescription>Click the button below to see the popover.</DialogDescription>
        </DialogHeader>
        <DialogBody>
            <Popover>
                <PopoverTrigger AsChild=""true"">
                    <Button Variant=""ButtonVariant.Outline"" Class=""w-fit"">Open Popover</Button>
                </PopoverTrigger>
                <PopoverContent Align=""Alignment.Start"">
                    <PopoverHeader>
                        <PopoverTitle>Popover in Dialog</PopoverTitle>
                        <PopoverDescription>
                            This popover appears inside a dialog.
                        </PopoverDescription>
                    </PopoverHeader>
                </PopoverContent>
            </Popover>
        </DialogBody>
    </DialogContent>
</Dialog>";

    private const string ControlledCode =
@"<Button Variant=""ButtonVariant.Outline"" OnClick=""TogglePopover"">Toggle popover</Button>
<Popover Open=""_open"" OpenChanged=""OnOpenChanged"">
    <PopoverTrigger AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Edit dimensions</Button>
    </PopoverTrigger>
    <PopoverContent Class=""w-80"">
        <Div Class=""grid gap-4"">
            <PopoverHeader>
                <PopoverTitle>Dimensions</PopoverTitle>
                <PopoverDescription>
                    Update the values below and save them back to the current layer.
                </PopoverDescription>
            </PopoverHeader>
            <Div Class=""grid gap-3"">
                <Div Class=""grid grid-cols-3 items-center gap-4"">
                    <Label For=""controlled-width"">Width</Label>
                    <Input Id=""controlled-width"" Type=""text"" Class=""col-span-2"" Value=""100%"" />
                </Div>
                <Div Class=""grid grid-cols-3 items-center gap-4"">
                    <Label For=""controlled-max-width"">Max width</Label>
                    <Input Id=""controlled-max-width"" Type=""text"" Class=""col-span-2"" Value=""300px"" />
                </Div>
                <Div Class=""grid grid-cols-3 items-center gap-4"">
                    <Label For=""controlled-height"">Height</Label>
                    <Input Id=""controlled-height"" Type=""text"" Class=""col-span-2"" Value=""25px"" />
                </Div>
            </Div>
            <Div Class=""flex justify-end gap-2"">
                <Button Variant=""ButtonVariant.Outline"" Size=""ButtonSize.Sm"">Cancel</Button>
                <Button Size=""ButtonSize.Sm"">Save</Button>
            </Div>
        </Div>
    </PopoverContent>
</Popover>";

    private Task OnOpenChanged(bool value)
    {
        _open = value;
        return Task.CompletedTask;
    }
}
