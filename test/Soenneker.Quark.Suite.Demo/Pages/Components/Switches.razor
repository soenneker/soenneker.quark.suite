@page "/switches"
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Switches - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="The standard switch and label pairing."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Div Class="flex items-center space-x-2">
                    <Switch Id="airplane-mode" />
                    <Label For="airplane-mode">Airplane Mode</Label>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextColor="TextColor.MutedForeground">
                    Form rows, descriptions, cards, validation states, sizing, RTL, and Quark-specific inline label patterns.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Description="Settings-style rows with descriptions and a submitted value preview."
                         Code="@FormCode"
                         CodeLanguage="razor">
                <EditForm Model="_formModel" OnSubmit="@(_ => HandleFormSubmit())" class="w-full max-w-xl space-y-6">
                    <Div>
                        <H3 Class="mb-4 text-lg font-medium">Email Notifications</H3>
                        <Div Space="Space.Y.Is4">
                            <Field Horizontal="true" Class="items-center justify-between rounded-lg border p-3 shadow-sm">
                                <FieldContent>
                                    <FieldLabel For="marketing-emails">Marketing emails</FieldLabel>
                                    <FieldDescription>
                                        Receive emails about new products, features, and more.
                                    </FieldDescription>
                                </FieldContent>
                                <Switch Id="marketing-emails"
                                        Checked="@_formModel.MarketingEmails"
                                        CheckedChanged="HandleMarketingEmailsChanged" />
                            </Field>

                            <Field Horizontal="true" Class="items-center justify-between rounded-lg border p-3 shadow-sm">
                                <FieldContent>
                                    <FieldLabel For="security-emails">Security emails</FieldLabel>
                                    <FieldDescription>
                                        Receive emails about your account security.
                                    </FieldDescription>
                                </FieldContent>
                                <Switch Id="security-emails"
                                        Checked="@_formModel.SecurityEmails"
                                        CheckedChanged="HandleSecurityEmailsChanged"
                                        Disabled="true"
                                        aria-readonly="true" />
                            </Field>
                        </Div>
                    </Div>

                    <Button Type="ButtonType.Submit">Submit</Button>

                    @if (!string.IsNullOrEmpty(_submittedSwitchJson))
                    {
                        <PreCode Class="rounded-lg bg-neutral-950 p-4 text-sm text-white">@_submittedSwitchJson</PreCode>
                    }
                </EditForm>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Description"
                         Description="Label and supporting text beside the switch."
                         Code="@DescriptionCode"
                         CodeLanguage="razor">
                <Field Horizontal="true" MaxWidth="MaxWidth.IsSm">
                    <FieldContent>
                        <FieldLabel For="switch-focus-mode">Share across devices</FieldLabel>
                        <FieldDescription>Focus is shared across devices, and turns off when you leave the app.</FieldDescription>
                    </FieldContent>
                    <Switch Id="switch-focus-mode" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Choice Card"
                         Description="Card-style rows with title, description, and switch."
                         Code="@ChoiceCardCode"
                         CodeLanguage="razor">
                <FieldGroup Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <FieldLabel For="switch-share">
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldTitle>Share across devices</FieldTitle>
                                <FieldDescription>Focus is shared across devices, and turns off when you leave the app.</FieldDescription>
                            </FieldContent>
                            <Switch Id="switch-share" />
                        </Field>
                    </FieldLabel>
                    <FieldLabel For="switch-notifications">
                        <Field Horizontal="true">
                            <FieldContent>
                                <FieldTitle>Enable notifications</FieldTitle>
                                <FieldDescription>Receive notifications when focus mode is enabled or disabled.</FieldDescription>
                            </FieldContent>
                            <Switch Id="switch-notifications" Checked="true" />
                        </Field>
                    </FieldLabel>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disable the switch to block interaction."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <Field Horizontal="true" Disabled="true" Width="Width.IsFit">
                    <Switch Id="switch-disabled-unchecked" Disabled="true" />
                    <FieldLabel For="switch-disabled-unchecked">Disabled</FieldLabel>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Mark the field invalid when validation fails."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <Field Horizontal="true" IsInvalid="true" MaxWidth="MaxWidth.IsSm">
                    <FieldContent>
                        <FieldLabel For="switch-terms">Accept terms and conditions</FieldLabel>
                        <FieldDescription>You must accept the terms and conditions to continue.</FieldDescription>
                    </FieldContent>
                    <Switch Id="switch-terms" aria-invalid="true" />
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size"
                         Description="Small and default switch sizes."
                         Code="@SizesCode"
                         CodeLanguage="razor">
                <FieldGroup Class="w-full max-w-[10rem]">
                    <Field Horizontal="true">
                        <Switch Id="switch-size-sm" Size="SwitchSizes.Sm" />
                        <FieldLabel For="switch-size-sm">Small</FieldLabel>
                    </Field>
                    <Field Horizontal="true">
                        <Switch Id="switch-size-default" />
                        <FieldLabel For="switch-size-default">Default</FieldLabel>
                    </Field>
                </FieldGroup>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Switch and field content respect DirectionProvider."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Field Horizontal="true" MaxWidth="MaxWidth.IsSm">
                        <FieldContent>
                            <FieldLabel For="switch-focus-mode-rtl">المشاركة عبر الأجهزة</FieldLabel>
                            <FieldDescription>يتم مشاركة التركيز عبر الأجهزة، ويتم إيقاف تشغيله عند مغادرة التطبيق.</FieldDescription>
                        </FieldContent>
                        <Switch Id="switch-focus-mode-rtl" Checked="@_rtlSwitchChecked" CheckedChanged="HandleRtlSwitchChanged" />
                    </Field>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Inline Content"
                         Description="Switches can render label content as child content or via the Label parameter."
                         Code="@InlineContentCode"
                         CodeLanguage="razor">
                <Div Space="Space.Y.Is3">
                    <Switch @bind-Checked="_inlineContentChecked">
                        Enable notifications
                    </Switch>
                    <Switch @bind-Checked="_legacyLabelChecked" Label="Dark mode" />
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private sealed class SwitchFormModel
    {
        public bool MarketingEmails { get; set; }
        public bool SecurityEmails { get; set; } = true;
    }

    private const string BasicCode =
@"<Div Class=""flex items-center space-x-2"">
    <Switch Id=""airplane-mode"" />
    <Label For=""airplane-mode"">Airplane Mode</Label>
</Div>";

    private const string FormCode =
@"<EditForm Model=""_formModel"" OnSubmit=""@(_ => HandleFormSubmit())"" class=""w-full max-w-xl space-y-6"">
    <Div>
        <H3 Class=""mb-4 text-lg font-medium"">Email Notifications</H3>
        <Div Class=""space-y-4"">
            <Field Horizontal=""true"" Class=""items-center justify-between rounded-lg border p-3 shadow-sm"">
                <FieldContent>
                    <FieldLabel For=""marketing-emails"">Marketing emails</FieldLabel>
                    <FieldDescription>
                        Receive emails about new products, features, and more.
                    </FieldDescription>
                </FieldContent>
                <Switch Id=""marketing-emails""
                        Checked=""@_formModel.MarketingEmails""
                        CheckedChanged=""HandleMarketingEmailsChanged"" />
            </Field>
            <Field Horizontal=""true"" Class=""items-center justify-between rounded-lg border p-3 shadow-sm"">
                <FieldContent>
                    <FieldLabel For=""security-emails"">Security emails</FieldLabel>
                    <FieldDescription>
                        Receive emails about your account security.
                    </FieldDescription>
                </FieldContent>
                <Switch Id=""security-emails""
                        Checked=""@_formModel.SecurityEmails""
                        CheckedChanged=""HandleSecurityEmailsChanged""
                        Disabled=""true""
                        aria-readonly=""true"" />
            </Field>
        </Div>
    </Div>
    <Button Type=""ButtonType.Submit"">Submit</Button>
</EditForm>";

    private const string DescriptionCode =
@"<Field Horizontal=""true"" Class=""max-w-sm"">
    <FieldContent>
        <FieldLabel For=""switch-focus-mode"">Share across devices</FieldLabel>
        <FieldDescription>Focus is shared across devices, and turns off when you leave the app.</FieldDescription>
    </FieldContent>
    <Switch Id=""switch-focus-mode"" />
</Field>";

    private const string ChoiceCardCode =
@"<FieldGroup Class=""w-full max-w-sm"">
    <FieldLabel For=""switch-share"">
        <Field Horizontal=""true"">
            <FieldContent>
                <FieldTitle>Share across devices</FieldTitle>
                <FieldDescription>Focus is shared across devices, and turns off when you leave the app.</FieldDescription>
            </FieldContent>
            <Switch Id=""switch-share"" />
        </Field>
    </FieldLabel>
    <FieldLabel For=""switch-notifications"">
        <Field Horizontal=""true"">
            <FieldContent>
                <FieldTitle>Enable notifications</FieldTitle>
                <FieldDescription>Receive notifications when focus mode is enabled or disabled.</FieldDescription>
            </FieldContent>
            <Switch Id=""switch-notifications"" Checked=""true"" />
        </Field>
    </FieldLabel>
</FieldGroup>";

    private const string DisabledCode =
@"<Field Horizontal=""true"" Disabled=""true"" Class=""w-fit"">
    <Switch Id=""switch-disabled-unchecked"" Disabled=""true"" />
    <FieldLabel For=""switch-disabled-unchecked"">Disabled</FieldLabel>
</Field>";

    private const string InvalidCode =
@"<Field Horizontal=""true"" IsInvalid=""true"" Class=""max-w-sm"">
    <FieldContent>
        <FieldLabel For=""switch-terms"">Accept terms and conditions</FieldLabel>
        <FieldDescription>You must accept the terms and conditions to continue.</FieldDescription>
    </FieldContent>
    <Switch Id=""switch-terms"" aria-invalid=""true"" />
</Field>";

    private const string SizesCode =
@"<FieldGroup Class=""w-full max-w-[10rem]"">
    <Field Horizontal=""true"">
        <Switch Id=""switch-size-sm"" Size=""SwitchSizes.Sm"" />
        <FieldLabel For=""switch-size-sm"">Small</FieldLabel>
    </Field>
    <Field Horizontal=""true"">
        <Switch Id=""switch-size-default"" />
        <FieldLabel For=""switch-size-default"">Default</FieldLabel>
    </Field>
</FieldGroup>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Field Horizontal=""true"" Class=""max-w-sm"">
        <FieldContent>
            <FieldLabel For=""switch-focus-mode-rtl"">المشاركة عبر الأجهزة</FieldLabel>
            <FieldDescription>يتم مشاركة التركيز عبر الأجهزة، ويتم إيقاف تشغيله عند مغادرة التطبيق.</FieldDescription>
        </FieldContent>
        <Switch Id=""switch-focus-mode-rtl"" Checked=""@_rtlSwitchChecked"" CheckedChanged=""HandleRtlSwitchChanged"" />
    </Field>
</DirectionProvider>";

    private const string InlineContentCode =
@"<Div Space=""Space.Y.Is3"">
    <Switch @bind-Checked=""_inlineContentChecked"">
        Enable notifications
    </Switch>
    <Switch @bind-Checked=""_legacyLabelChecked"" Label=""Dark mode"" />
</Div>";

    private readonly SwitchFormModel _formModel = new();
    private string? _submittedSwitchJson;
    private bool _inlineContentChecked;
    private bool _legacyLabelChecked;
    private bool _rtlSwitchChecked = true;

    private Task HandleMarketingEmailsChanged(bool value)
    {
        _formModel.MarketingEmails = value;
        return Task.CompletedTask;
    }

    private Task HandleSecurityEmailsChanged(bool value)
    {
        _formModel.SecurityEmails = value;
        return Task.CompletedTask;
    }

    private Task HandleRtlSwitchChanged(bool value)
    {
        _rtlSwitchChecked = value;
        return Task.CompletedTask;
    }

    private Task HandleFormSubmit()
    {
        _submittedSwitchJson =
            $$"""
              {
                "marketing_emails": {{_formModel.MarketingEmails.ToString().ToLowerInvariant()}},
                "security_emails": {{_formModel.SecurityEmails.ToString().ToLowerInvariant()}}
              }
              """;

        return Task.CompletedTask;
    }
}
