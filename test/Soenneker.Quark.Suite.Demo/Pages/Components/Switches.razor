@page "/switches"

<PageTitle>Switches - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Description" Description="Use ChildContent for richer labels and supporting text around the switch." Code="@(@"<Switch @bind-Checked=""isEnabled"">
    Enable notifications
</Switch>
<Switch @bind-Checked=""isEnabled"">
    Dark mode with <Strong>bold text</Strong>
</Switch>")">
                    <Grid Columns="Columns.Is1.OnXl.Is2" Gap="Gap.Is4">
                        <Div>
                            <H5>Using ChildContent</H5>
                            <Switch @bind-Checked="_childContentChecked">
                                Enable notifications
                            </Switch>
                            <Switch @bind-Checked="_childContentChecked2">
                                Dark mode with <Strong>bold text</Strong>
                            </Switch>
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is2.FromTop">ChildContent allows rich content inside switches</Paragraph>
                        </Div>
                        <Div>
                            <H5>Using Label (Legacy)</H5>
                            <Switch Label="Enable notifications" @bind-Checked="_labelChecked" />
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is2.FromTop">The Label property is still supported for backward compatibility</Paragraph>
                        </Div>
                    </Grid>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic" Description="Simple switch with ChildContent or without a label." Code="@(@"<Switch @bind-Checked=""isEnabled"">Enable notifications</Switch>
<Switch @bind-Checked=""noLabel"" />")">
                    <Grid Columns="Columns.Is1.OnXl.Is2" Gap="Gap.Is4">
                        <Div>
                            <H5>Simple Switch</H5>
                            <Switch @bind-Checked="_basicChecked">
                                Enable notifications
                            </Switch>
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is2.FromTop">Status: @(_basicChecked ? "Enabled" : "Disabled")</Paragraph>
                        </Div>
                        <Div>
                            <H5>Switch without Label</H5>
                            <Switch @bind-Checked="_noLabelChecked" />
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is2.FromTop">Status: @(_noLabelChecked ? "On" : "Off")</Paragraph>
                        </Div>
                    </Grid>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Choice Card" Description="A bordered row is the closest Quark equivalent to the shadcn choice-card switch pattern." Code="@(@"<Div class=""rounded-lg border p-4"">
    <Switch @bind-Checked=""marketing"">Marketing emails</Switch>
</Div>")">
                <Div Rounded="Rounded.Lg" Border="Border.Is1" BackgroundColor="BackgroundColor.Card" Padding="Padding.Is4" MaxWidth="MaxWidth.IsXl">
                    <Div Display="Display.Flex" AlignUtility="Align.ItemsStart.JustifyBetween" Gap="Gap.Is4">
                        <Div Space="Space.Y.Is1">
                            <Label TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Marketing emails</Label>
                            <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Receive launch announcements and feature updates.</Paragraph>
                        </Div>
                        <Switch @bind-Checked="_marketingChecked" />
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Color Variants" Description="BackgroundColor for semantic switch styling." Code="@(@"<Switch BackgroundColor=""BackgroundColor.Primary"" @bind-Checked=""value"">Primary</Switch>
<Switch BackgroundColor=""BackgroundColor.Accent"" @bind-Checked=""value"">Success</Switch>
<Switch BackgroundColor=""BackgroundColor.Destructive"" @bind-Checked=""value"">Danger</Switch>")">
                    <Grid Columns="Columns.Is1.OnXl.Is3" Gap="Gap.Is4">
                        <Div>
                            <H6>Primary</H6>
                            <Switch BackgroundColor="BackgroundColor.Primary" @bind-Checked="_primaryChecked">
                                Primary Switch
                            </Switch>
                        </Div>
                        <Div>
                            <H6>Secondary</H6>
                            <Switch BackgroundColor="BackgroundColor.Secondary" @bind-Checked="_secondaryChecked">
                                Secondary Switch
                            </Switch>
                        </Div>
                        <Div>
                            <H6>Success</H6>
                            <Switch BackgroundColor="BackgroundColor.Accent" @bind-Checked="_successChecked">
                                Success Switch
                            </Switch>
                        </Div>
                    </Grid>
                    <Grid Columns="Columns.Is1.OnXl.Is3" Gap="Gap.Is4" Margin="Margin.Is3.FromTop">
                        <Div>
                            <H6>Danger</H6>
                            <Switch BackgroundColor="BackgroundColor.Destructive" @bind-Checked="_dangerChecked">
                                Danger Switch
                            </Switch>
                        </Div>
                        <Div>
                            <H6>Warning</H6>
                            <Switch BackgroundColor="BackgroundColor.Muted" @bind-Checked="_warningChecked">
                                Warning Switch
                            </Switch>
                        </Div>
                        <Div>
                            <H6>Info</H6>
                            <Switch BackgroundColor="BackgroundColor.Secondary" @bind-Checked="_infoChecked">
                                Info Switch
                            </Switch>
                        </Div>
                    </Grid>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Size" Description="Size.Small, Default, Large." Code="@(@"<Switch Label=""Small Switch"" Size=""Size.Small"" @bind-Checked=""value""/>
<Switch Label=""Default Switch"" Size=""Size.Default"" @bind-Checked=""value""/>
<Switch Label=""Large Switch"" Size=""Size.Large"" @bind-Checked=""value""/>")">
                    <Grid Columns="Columns.Is1.OnXl.Is3" Gap="Gap.Is4">
                        <Div>
                            <H6>Small</H6>
                            <Switch Label="Small Switch" Size="Size.Small" @bind-Checked="_smallChecked" />
                        </Div>
                        <Div>
                            <H6>Default</H6>
                            <Switch Label="Default Switch" Size="Size.Default" @bind-Checked="_defaultChecked" />
                        </Div>
                        <Div>
                            <H6>Large</H6>
                            <Switch Label="Large Switch" Size="Size.Large" @bind-Checked="_largeChecked" />
                        </Div>
                    </Grid>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled" Description="Disabled switches (checked or unchecked)." Code="@(@"<Switch Label=""Disabled unchecked"" Disabled=""true"" Checked=""false""/>
<Switch Label=""Disabled checked"" Disabled=""true"" Checked=""true""/>")">
                    <Grid Columns="Columns.Is1.OnXl.Is2" Gap="Gap.Is4">
                        <Div>
                            <H6>Disabled (Unchecked)</H6>
                            <Switch Label="This switch is disabled" Disabled="true" Checked="false" />
                        </Div>
                        <Div>
                            <H6>Disabled (Checked)</H6>
                            <Switch Label="This switch is disabled and checked" Disabled="true" Checked="true" />
                        </Div>
                    </Grid>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid" Description="Pair the switch with destructive helper text when the selection is required before continuing." Code="@(@"<Div class=""space-y-2"">
    <Switch Checked=""false"">Accept the security policy</Switch>
    <Paragraph class=""text-sm text-destructive"">You must accept this policy before saving.</Paragraph>
</Div>")">
                <Div Space="Space.Y.Is2" MaxWidth="MaxWidth.IsXl" Rounded="Rounded.Lg" Border="Border.Is1" BorderColor='BorderColor.Token("destructive/40")' BackgroundColor='BackgroundColor.Token("destructive/5")' Padding="Padding.Is4">
                    <Switch Checked="false">
                        Accept the security policy
                    </Switch>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.Destructive">You must accept this policy before saving.</Paragraph>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Event Handling" Description="OnClick and OnChange event handlers." Code="@(@"<Switch Label=""Click me"" @bind-Checked=""value"" OnClick=""OnSwitchClick""/>
<Switch Label=""Change me"" @bind-Checked=""value"" OnChange=""OnSwitchChange""/>")">
                    <Grid Columns="Columns.Is1.OnXl.Is2" Gap="Gap.Is4">
                        <Div>
                            <H6>Click Events</H6>
                            <Switch Label="Click me to see events" @bind-Checked="_eventChecked" OnClick="OnSwitchClick" />
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is2.FromTop">Click count: @_clickCount</Paragraph>
                        </Div>
                        <Div>
                            <H6>Change Events</H6>
                            <Switch Label="Change me to see events" @bind-Checked="_changeChecked" OnChange="OnSwitchChange" />
                            <Paragraph TextColor="TextColor.MutedForeground" Margin="Margin.Is2.FromTop">Last change: @_lastChangeEvent</Paragraph>
                        </Div>
                    </Grid>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form Integration" Description="Switches in forms with bind-Checked." Code="@(@"<form>
    <Switch Label=""Email notifications"" @bind-Checked=""data.EmailNotifications""/>
    <Switch Label=""SMS notifications"" @bind-Checked=""data.SmsNotifications""/>
    <Button OnClick=""SubmitForm"">Submit</Button>
</form>")">
                    <form>
                        <Div Margin="Margin.Is3.FromBottom">
                            <H6>User Preferences</H6>
                            <Switch Label="Email notifications" @bind-Checked="_formData.EmailNotifications" />
                            <Switch Label="SMS notifications" @bind-Checked="_formData.SmsNotifications" />
                            <Switch Label="Marketing emails" @bind-Checked="_formData.MarketingEmails" />
                        </Div>
                        <Button BackgroundColor="BackgroundColor.Primary" OnClick="SubmitForm">Submit Preferences</Button>
                    </form>
                    <Div Margin="Margin.Is3.FromTop">
                        <H6>Form Data:</H6>
                        <Div ElementType="ElementType.Pre" BackgroundColor="BackgroundColor.Muted" Padding="Padding.Is2" Rounded="Rounded.Default">@GetFormDataJson()</Div>
                    </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Interactive Demo" Description="Master switch controlling disabled child switches." Code="@(@"<Switch Label=""Toggle all"" @bind-Checked=""_masterSwitch""/>
<Switch Label=""Option 1"" Checked=""_masterSwitch"" Disabled=""true""/>")">
                    <Grid Columns="Columns.Is1.OnXl.Is2" Gap="Gap.Is4">
                        <Div>
                            <H6>Master Switch</H6>
                            <Switch Label="Toggle all switches" @bind-Checked="_masterSwitch" />
                        </Div>
                        <Div>
                            <H6>Controlled Switches</H6>
                            <Switch Label="Option 1" Checked="_masterSwitch" Disabled="true" />
                            <Switch Label="Option 2" Checked="_masterSwitch" Disabled="true" />
                            <Switch Label="Option 3" Checked="_masterSwitch" Disabled="true" />
                        </Div>
                    </Grid>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    // ChildContent examples
    private bool _childContentChecked;
    private bool _childContentChecked2 = true;
    private bool _labelChecked;

    // Basic switches
    private bool _basicChecked;
    private bool _noLabelChecked = true;
    private bool _marketingChecked = true;

    // Color variants
    private bool _primaryChecked;
    private bool _secondaryChecked = true;
    private bool _successChecked;
    private bool _dangerChecked = true;
    private bool _warningChecked;
    private bool _infoChecked = true;

    // Size variants
    private bool _smallChecked;
    private bool _defaultChecked = true;
    private bool _largeChecked;

    // Event handling
    private bool _eventChecked;
    private bool _changeChecked;
    private int _clickCount;
    private string _lastChangeEvent = "No changes yet";

    // Form data
    private UserPreferences _formData = new();

    // Interactive demo
    private bool _masterSwitch;

    private void OnSwitchClick(MouseEventArgs e)
    {
        _clickCount++;
        StateHasChanged();
    }

    private void OnSwitchChange(ChangeEventArgs e)
    {
        _lastChangeEvent = $"Changed to: {e.Value} at {DateTime.Now:HH:mm:ss}";
        StateHasChanged();
    }

    private void SubmitForm()
    {
        // In a real application, you would submit the form data to a server
        Console.WriteLine("Form submitted with data: " + GetFormDataJson());
    }

    private string GetFormDataJson()
    {
        return System.Text.Json.JsonSerializer.Serialize(_formData, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    public class UserPreferences
    {
        public bool EmailNotifications { get; set; } = true;
        public bool SmsNotifications { get; set; }
        public bool MarketingEmails { get; set; }
    }
}
