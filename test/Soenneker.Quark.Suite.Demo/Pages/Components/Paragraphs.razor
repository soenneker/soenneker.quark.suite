@page "/paragraphs"

<PageTitle>Paragraph - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection Code="@ParagraphCode"
                     CodeLanguage="razor">
            <Paragraph>
                The king, seeing how much happier his subjects were, realized the error of his ways and repealed the joke tax.
            </Paragraph>
        </DemoSection>
    </Section>
</Div>

@code {
    private const string ParagraphCode =
@"<Paragraph>
    The king, seeing how much happier his subjects were, realized the error of his ways and repealed the joke tax.
</Paragraph>";
}
