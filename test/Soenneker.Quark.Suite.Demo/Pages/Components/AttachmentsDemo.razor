@page "/attachments"

<PageTitle>Attachments - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection Title="Demo"
                     Description="File-attachment UI for compact, inline, detailed, and pasted states."
                     Code="@BasicCode"
                     CodeLanguage="razor">
            <Attachments MaxWidth="MaxWidth.IsLg">
                <Attachment Name="quarterly-report.pdf" Description="842 KB PDF" />
                <Attachment Name="screenshot.png" Description="Uploading" Progress="64" />
                <Attachment Name="notes.md" Description="Ready" Variant="inline" />
                <Attachment Name="pasted-image.png" Description="Pasted from clipboard" Variant="pasted">
                    <AttachmentRemove>Remove</AttachmentRemove>
                </Attachment>
            </Attachments>
        </DemoSection>
    </Section>
</Div>

@code {
    private const string BasicCode =
@"<Attachments>
    <Attachment Name=""quarterly-report.pdf"" Description=""842 KB PDF"" />
    <Attachment Name=""screenshot.png"" Description=""Uploading"" Progress=""64"" />
    <Attachment Name=""notes.md"" Description=""Ready"" Variant=""inline"" />
    <Attachment Name=""pasted-image.png"" Description=""Pasted from clipboard"" Variant=""pasted"">
        <AttachmentRemove>Remove</AttachmentRemove>
    </Attachment>
</Attachments>";
}
