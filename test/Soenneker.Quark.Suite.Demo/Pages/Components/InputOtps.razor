@page "/components/input-otp"

<PageTitle>Input OTP - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Accessible one-time password component with copy-paste functionality."
                         Code="@DemoCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <InputOtp DefaultOtpValue="123456" Length="6">
                    <InputOtpInput />
                    <InputOtpGroup>
                        <InputOtpSlot Index="0" />
                        <InputOtpSlot Index="1" />
                        <InputOtpSlot Index="2" />
                        <InputOtpSlot Index="3" />
                        <InputOtpSlot Index="4" />
                        <InputOtpSlot Index="5" />
                    </InputOtpGroup>
                </InputOtp>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Pattern"
                         Description="Use the pattern prop to define a custom pattern for the input."
                         Code="@DigitsOnlyCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <Field>
                    <FieldLabel For="digits-only-otp">Digits Only</FieldLabel>
                    <InputOtp Id="digits-only-otp" Length="6" Pattern="@DigitsOnlyPattern">
                        <InputOtpInput />
                        <InputOtpGroup>
                            <InputOtpSlot Index="0" />
                            <InputOtpSlot Index="1" />
                            <InputOtpSlot Index="2" />
                            <InputOtpSlot Index="3" />
                            <InputOtpSlot Index="4" />
                            <InputOtpSlot Index="5" />
                        </InputOtpGroup>
                    </InputOtp>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Separator"
                         Description="Use the <InputOTPSeparator /> component to add a separator between input groups."
                         Code="@WithSeparatorCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <Field>
                    <FieldLabel For="separator-otp">Separator</FieldLabel>
                    <InputOtp Id="separator-otp" OtpValue="@_separatorValue" OtpValueChanged="OnSeparatorChanged" Length="6" Pattern="@DigitsOnlyPattern" InputMode="numeric">
                        <InputOtpInput />
                        <InputOtpGroup>
                            <InputOtpSlot Index="0" />
                            <InputOtpSlot Index="1" />
                        </InputOtpGroup>
                        <InputOtpSeparator />
                        <InputOtpGroup>
                            <InputOtpSlot Index="2" />
                            <InputOtpSlot Index="3" />
                        </InputOtpGroup>
                        <InputOtpSeparator />
                        <InputOtpGroup>
                            <InputOtpSlot Index="4" />
                            <InputOtpSlot Index="5" />
                        </InputOtpGroup>
                    </InputOtp>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Use the disabled prop to disable the input."
                         Code="@DisabledCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <Field Disabled="true">
                    <FieldLabel For="disabled-otp">Disabled</FieldLabel>
                    <InputOtp Id="disabled-otp" OtpValue="123456" Length="6" Disabled="true" Pattern="@DigitsOnlyPattern" InputMode="numeric">
                        <InputOtpInput />
                        <InputOtpGroup>
                            <InputOtpSlot Index="0" />
                            <InputOtpSlot Index="1" />
                            <InputOtpSlot Index="2" />
                        </InputOtpGroup>
                        <InputOtpSeparator />
                        <InputOtpGroup>
                            <InputOtpSlot Index="3" />
                            <InputOtpSlot Index="4" />
                            <InputOtpSlot Index="5" />
                        </InputOtpGroup>
                    </InputOtp>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Controlled"
                         Description="Use the value and onChange props to control the input value."
                         Code="@ControlledCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <Field>
                    <InputOtp OtpValue="@_controlledValue" OtpValueChanged="OnControlledChanged" Length="6" Pattern="@DigitsOnlyPattern" InputMode="numeric">
                        <InputOtpInput />
                        <InputOtpGroup>
                            <InputOtpSlot Index="0" />
                            <InputOtpSlot Index="1" />
                            <InputOtpSlot Index="2" />
                            <InputOtpSlot Index="3" />
                            <InputOtpSlot Index="4" />
                            <InputOtpSlot Index="5" />
                        </InputOtpGroup>
                    </InputOtp>
                    <FieldDescription>Enter your one-time password.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>
    <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Use aria-invalid on the slots to show an error state."
                         Code="@InvalidCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <Field IsInvalid="true">
                    <FieldLabel For="invalid-otp">Invalid</FieldLabel>
                    <FieldDescription>Example showing the invalid error state.</FieldDescription>
                    <InputOtp Id="invalid-otp" OtpValue="@_invalidValue" OtpValueChanged="OnInvalidChanged" Length="6" Pattern="@DigitsOnlyPattern" InputMode="numeric">
                        <InputOtpInput />
                        <InputOtpGroup>
                            <InputOtpSlot Index="0" aria-invalid="true" />
                            <InputOtpSlot Index="1" aria-invalid="true" />
                        </InputOtpGroup>
                        <InputOtpSeparator />
                        <InputOtpGroup>
                            <InputOtpSlot Index="2" aria-invalid="true" />
                            <InputOtpSlot Index="3" aria-invalid="true" />
                        </InputOtpGroup>
                        <InputOtpSeparator />
                        <InputOtpGroup>
                            <InputOtpSlot Index="4" aria-invalid="true" />
                            <InputOtpSlot Index="5" aria-invalid="true" />
                        </InputOtpGroup>
                    </InputOtp>
                    <FieldError>Invalid code. Please try again.</FieldError>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Four Digits"
                         Description="A common pattern for PIN codes. This uses the pattern={REGEXP_ONLY_DIGITS} prop."
                         Code="@FourDigitsCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <Field>
                    <FieldLabel For="four-digit-otp">Four Digits</FieldLabel>
                    <FieldDescription>Common pattern for PIN codes.</FieldDescription>
                    <InputOtp Id="four-digit-otp" OtpValue="@_pinValue" OtpValueChanged="OnPinChanged" Length="4" Pattern="@DigitsOnlyPattern" InputMode="numeric">
                        <InputOtpInput />
                        <InputOtpGroup>
                            <InputOtpSlot Index="0" />
                            <InputOtpSlot Index="1" />
                            <InputOtpSlot Index="2" />
                            <InputOtpSlot Index="3" />
                        </InputOtpGroup>
                    </InputOtp>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Alphanumeric"
                         Description="Use REGEXP_ONLY_DIGITS_AND_CHARS to accept both letters and numbers."
                         Code="@AlphanumericCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpPreviewClass">
                <Field>
                    <FieldLabel For="alphanumeric-otp">Alphanumeric</FieldLabel>
                    <FieldDescription>Accepts both letters and numbers.</FieldDescription>
                    <InputOtp Id="alphanumeric-otp" OtpValue="@_alphaNumericValue" OtpValueChanged="OnAlphaNumericChanged" Length="6" Pattern="@AlphaNumericPattern">
                        <InputOtpInput />
                        <InputOtpGroup>
                            <InputOtpSlot Index="0" />
                            <InputOtpSlot Index="1" />
                            <InputOtpSlot Index="2" />
                        </InputOtpGroup>
                        <InputOtpSeparator />
                        <InputOtpGroup>
                            <InputOtpSlot Index="3" />
                            <InputOtpSlot Index="4" />
                            <InputOtpSlot Index="5" />
                        </InputOtpGroup>
                    </InputOtp>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Form"
                         Code="@FormCode"
                         CodeLanguage="razor"
                         PreviewClass="@InputOtpFormPreviewClass">
                <form>
                    <Card Class="mx-auto max-w-md">
                        <CardHeader>
                            <CardTitle>Verify your login</CardTitle>
                            <CardDescription>
                                Enter the verification code we sent to your email address:
                                <Span FontWeight="FontWeight.Medium">m@example.com</Span>.
                            </CardDescription>
                        </CardHeader>
                        <CardBody>
                            <Field>
                                <Div Class="flex items-center justify-between">
                                    <FieldLabel For="otp-verification">Verification code</FieldLabel>
                                    <Button Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Sm">
                                        <Icon Name="LucideIcon.RefreshCw" />
                                        Resend Code
                                    </Button>
                                </Div>
                                <InputOtp Id="otp-verification" OtpValue="@_formOtpValue" OtpValueChanged="OnFormOtpChanged" Length="6" Pattern="@DigitsOnlyPattern" InputMode="numeric" Required="true" RootHeight="48px">
                                    <InputOtpInput />
                                    <InputOtpGroup Class="*:data-[slot=input-otp-slot]:h-12 *:data-[slot=input-otp-slot]:w-11 *:data-[slot=input-otp-slot]:text-xl">
                                        <InputOtpSlot Index="0" />
                                        <InputOtpSlot Index="1" />
                                        <InputOtpSlot Index="2" />
                                    </InputOtpGroup>
                                    <InputOtpSeparator Class="mx-3" />
                                    <InputOtpGroup Class="*:data-[slot=input-otp-slot]:h-12 *:data-[slot=input-otp-slot]:w-11 *:data-[slot=input-otp-slot]:text-xl">
                                        <InputOtpSlot Index="3" />
                                        <InputOtpSlot Index="4" />
                                        <InputOtpSlot Index="5" />
                                    </InputOtpGroup>
                                </InputOtp>
                                <FieldDescription>
                                    <Anchor Href="#">I no longer have access to this email address.</Anchor>
                                </FieldDescription>
                            </Field>
                        </CardBody>
                        <CardFooter Class="flex-col gap-2">
                            <Button Type="ButtonType.Submit" Width="Width.IsFull">Verify</Button>
                            <Paragraph Class="text-center text-sm text-muted-foreground">
                                Having trouble signing in?
                                <Anchor Href="#" Class="underline underline-offset-4">Contact support</Anchor>
                            </Paragraph>
                        </CardFooter>
                    </Card>
                </form>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         ShowPreviewToolbar="true"
                         PreviewLang="ar"
                         PreviewDir="rtl"
                         PreviewClass="@InputOtpPreviewClass">
                <DirectionProvider Dir="rtl">
                    <Field>
                        <FieldLabel For="rtl-otp">رمز التحقق</FieldLabel>
                        <InputOtp Id="rtl-otp" OtpValue="@_rtlValue" OtpValueChanged="OnRtlChanged" Length="6" Pattern="@DigitsOnlyPattern" InputMode="numeric">
                            <InputOtpInput />
                            <InputOtpGroup>
                                <InputOtpSlot Index="0" />
                                <InputOtpSlot Index="1" />
                                <InputOtpSlot Index="2" />
                                <InputOtpSlot Index="3" />
                                <InputOtpSlot Index="4" />
                                <InputOtpSlot Index="5" />
                            </InputOtpGroup>
                        </InputOtp>
                    </Field>
                </DirectionProvider>
            </DemoSection>
        </Section>

        </Div>
</Div>

@code {
    private const string InputOtpPreviewClass = "preview relative flex h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0";
    private const string InputOtpFormPreviewClass = "preview relative flex h-[480px] w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0";

    private const string DigitsOnlyPattern = "^[0-9]$";
    private const string AlphaNumericPattern = "^[0-9A-Za-z]$";

    private string _formOtpValue = "";
    private string _separatorValue = "";
    private string _alphaNumericValue = "";
    private string _pinValue = "";
    private string _invalidValue = "000000";
    private string _controlledValue = "";
    private string _rtlValue = "123456";

    private Task OnFormOtpChanged(string value)
    {
        _formOtpValue = value;
        return Task.CompletedTask;
    }

    private Task OnSeparatorChanged(string value)
    {
        _separatorValue = value;
        return Task.CompletedTask;
    }

    private Task OnAlphaNumericChanged(string value)
    {
        _alphaNumericValue = value.ToUpperInvariant();
        return Task.CompletedTask;
    }

    private Task OnPinChanged(string value)
    {
        _pinValue = value;
        return Task.CompletedTask;
    }

    private Task OnInvalidChanged(string value)
    {
        _invalidValue = value;
        return Task.CompletedTask;
    }

    private Task OnControlledChanged(string value)
    {
        _controlledValue = value;
        return Task.CompletedTask;
    }

    private Task OnRtlChanged(string value)
    {
        _rtlValue = value;
        return Task.CompletedTask;
    }

    private const string DemoCode =
@"<InputOtp DefaultOtpValue=""123456"" Length=""6"">
    <InputOtpInput />
    <InputOtpGroup>
        <InputOtpSlot Index=""0"" />
        <InputOtpSlot Index=""1"" />
        <InputOtpSlot Index=""2"" />
        <InputOtpSlot Index=""3"" />
        <InputOtpSlot Index=""4"" />
        <InputOtpSlot Index=""5"" />
    </InputOtpGroup>
</InputOtp>";

    private const string FormCode =
@"<form>
    <Card Class=""mx-auto max-w-md"">
        <CardHeader>
            <CardTitle>Verify your login</CardTitle>
            <CardDescription>
                Enter the verification code we sent to your email address:
                <Span FontWeight=""FontWeight.Medium"">m@example.com</Span>.
            </CardDescription>
        </CardHeader>
        <CardBody>
            <Field>
                <Div Class=""flex items-center justify-between"">
                    <FieldLabel For=""otp-verification"">Verification code</FieldLabel>
                    <Button Variant=""ButtonVariant.Outline"" ButtonSize=""ButtonSize.Sm"">
                        <Icon Name=""LucideIcon.RefreshCw"" />
                        Resend Code
                    </Button>
                </Div>
                <InputOtp Id=""otp-verification"" OtpValue=""@_formOtpValue"" OtpValueChanged=""OnFormOtpChanged"" Length=""6"" Pattern=""@DigitsOnlyPattern"" InputMode=""numeric"" Required=""true"" RootHeight=""48px"">
                    <InputOtpInput />
                    <InputOtpGroup Class=""*:data-[slot=input-otp-slot]:h-12 *:data-[slot=input-otp-slot]:w-11 *:data-[slot=input-otp-slot]:text-xl"">
                        <InputOtpSlot Index=""0"" />
                        <InputOtpSlot Index=""1"" />
                        <InputOtpSlot Index=""2"" />
                    </InputOtpGroup>
                    <InputOtpSeparator Class=""mx-3"" />
                    <InputOtpGroup Class=""*:data-[slot=input-otp-slot]:h-12 *:data-[slot=input-otp-slot]:w-11 *:data-[slot=input-otp-slot]:text-xl"">
                        <InputOtpSlot Index=""3"" />
                        <InputOtpSlot Index=""4"" />
                        <InputOtpSlot Index=""5"" />
                    </InputOtpGroup>
                </InputOtp>
                <FieldDescription>
                    <Anchor Href=""#"">I no longer have access to this email address.</Anchor>
                </FieldDescription>
            </Field>
        </CardBody>
        <CardFooter Class=""flex-col gap-2"">
            <Button Type=""ButtonType.Submit"" Width=""Width.IsFull"">Verify</Button>
            <Paragraph Class=""text-center text-sm text-muted-foreground"">
                Having trouble signing in?
                <Anchor Href=""#"" Class=""underline underline-offset-4"">Contact support</Anchor>
            </Paragraph>
        </CardFooter>
    </Card>
</form>";

    private const string SimpleCode =
@"<Field>
    <FieldLabel For=""simple-otp"">Simple</FieldLabel>
    <InputOtp Id=""simple-otp"" Length=""6"">
        <InputOtpInput />
        <InputOtpGroup>
            <InputOtpSlot Index=""0"" />
            <InputOtpSlot Index=""1"" />
            <InputOtpSlot Index=""2"" />
        </InputOtpGroup>
