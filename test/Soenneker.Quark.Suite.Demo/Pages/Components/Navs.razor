@page "/navs"

<PageTitle>Nav - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="Semantic navigation landmark." Code="@BasicNavCode" CodeLanguage="razor">
                <Nav AriaLabel="Primary demo navigation" Border="Border.Is1" Rounded="Rounded.Lg" Padding="Padding.Is3">
                    <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is3">
                        <Anchor Href="#overview" FontWeight="FontWeight.Medium">Overview</Anchor>
                        <Anchor Href="#usage" FontWeight="FontWeight.Medium">Usage</Anchor>
                        <Anchor Href="#api" FontWeight="FontWeight.Medium">API</Anchor>
                    </Div>
                </Nav>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Vertical" Description="A secondary navigation list." Code="@VerticalNavCode" CodeLanguage="razor">
                <Nav AriaLabel="Documentation sections" Width="@("min(100%, 18rem)")" Border="Border.Is1" Rounded="Rounded.Lg" Padding="Padding.Is2">
                    <UnorderedList Margin="Margin.Is0" Space="Space.Y.Is1">
                        @foreach (var item in _sections)
                        {
                            <UnorderedListItem>
                                <Anchor Href="@item.To" Display="Display.Block" Rounded="Rounded.Md" Padding="Padding.Is2.OnX.Is1.OnY" BackgroundColor="BackgroundColor.Muted.Hover">
                                    @item.Label
                                </Anchor>
                            </UnorderedListItem>
                        }
                    </UnorderedList>
                </Nav>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With current page" Description="Use aria-current for the active link." Code="@CurrentPageNavCode" CodeLanguage="razor">
                <Nav AriaLabel="Settings" Border="Border.Is1" Rounded="Rounded.Lg" Padding="Padding.Is3" BackgroundColor="BackgroundColor.Muted">
                    <Div Display="Display.Flex" FlexWrap="FlexWrap.Wrap" Gap="Gap.Is2">
                        <Anchor Href="#profile" AriaCurrent="page" Rounded="Rounded.Md" BackgroundColor="BackgroundColor.Background" Padding='Padding.Is3.OnX.Token("1.5").OnY' FontWeight="FontWeight.Medium" Shadow="Shadow.Sm">Profile</Anchor>
                        <Anchor Href="#team" Rounded="Rounded.Md" Padding='Padding.Is3.OnX.Token("1.5").OnY' FontWeight="FontWeight.Medium" BackgroundColor="BackgroundColor.Background.Hover">Team</Anchor>
                        <Anchor Href="#billing" Rounded="Rounded.Md" Padding='Padding.Is3.OnX.Token("1.5").OnY' FontWeight="FontWeight.Medium" BackgroundColor="BackgroundColor.Background.Hover">Billing</Anchor>
                    </Div>
                </Nav>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {

    private static readonly NavDemoLink[] _sections =
    [
        new("Getting started", "#getting-started"),
        new("Components", "#components"),
        new("Primitives", "#primitives"),
        new("Theming", "#theming")
    ];

    private const string BasicNavCode = @"<Nav AriaLabel=""Primary demo navigation"" Border=""Border.Is1"" Rounded=""Rounded.Lg"" Padding=""Padding.Is3"">
    <Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is3"">
        <Anchor Href=""#overview"">Overview</Anchor>
        <Anchor Href=""#usage"">Usage</Anchor>
        <Anchor Href=""#api"">API</Anchor>
    </Div>
</Nav>";

    private const string VerticalNavCode = @"<Nav AriaLabel=""Documentation sections"" Border=""Border.Is1"" Rounded=""Rounded.Lg"" Padding=""Padding.Is2"">
    <UnorderedList Margin=""Margin.Is0"" Space=""Space.Y.Is1"">
        <UnorderedListItem>
            <Anchor Href=""#getting-started"" Display=""Display.Block"" Rounded=""Rounded.Md"" Padding=""Padding.Is2.OnX.Is1.OnY"" BackgroundColor=""BackgroundColor.Muted.Hover"">
                Getting started
            </Anchor>
        </UnorderedListItem>
    </UnorderedList>
</Nav>";

    private const string CurrentPageNavCode = @"<Nav AriaLabel=""Settings"" Border=""Border.Is1"" Rounded=""Rounded.Lg"" Padding=""Padding.Is3"" BackgroundColor=""BackgroundColor.Muted"">
    <Div Display=""Display.Flex"" FlexWrap=""FlexWrap.Wrap"" Gap=""Gap.Is2"">
        <Anchor Href=""#profile"" AriaCurrent=""page"" Rounded=""Rounded.Md"" BackgroundColor=""BackgroundColor.Background"" Padding='Padding.Is3.OnX.Token(""1.5"").OnY' FontWeight=""FontWeight.Medium"" Shadow=""Shadow.Sm"">Profile</Anchor>
        <Anchor Href=""#team"" Rounded=""Rounded.Md"" Padding='Padding.Is3.OnX.Token(""1.5"").OnY' FontWeight=""FontWeight.Medium"" BackgroundColor=""BackgroundColor.Background.Hover"">Team</Anchor>
    </Div>
</Nav>";

    private sealed record NavDemoLink(string Label, string To);

}
