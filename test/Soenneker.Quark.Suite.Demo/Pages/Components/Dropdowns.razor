@page "/dropdowns"

<PageTitle>Dropdowns - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A basic dropdown menu with groups, labels, and separators."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle>Open</DropdownToggle>
                    <DropdownMenu>
                        <DropdownGroup>
                            <DropdownLabel>My Account</DropdownLabel>
                            <DropdownItem>Profile</DropdownItem>
                            <DropdownItem>Billing</DropdownItem>
                        </DropdownGroup>
                        <DropdownDivider />
                        <DropdownGroup>
                            <DropdownItem>Team</DropdownItem>
                            <DropdownItem>Subscription</DropdownItem>
                        </DropdownGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu"
                         Description="Use nested dropdown submenu primitives to expose secondary actions."
                         Code="@SubmenuCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle>Invite users</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Email</DropdownItem>
                        <DropdownItem>Message</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger>More...</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownItem>Calendar</DropdownItem>
                                <DropdownItem>Slack</DropdownItem>
                            </DropdownSubContent>
                        </DropdownSub>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Class="flex flex-wrap gap-6">
                <DemoSection Title="Shortcuts"
                             Description="Add `DropdownShortcut` for keyboard hints."
                             Code="@ShortcutsCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>Open shortcuts</DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem>
                                New tab
                                <DropdownShortcut>Ctrl+T</DropdownShortcut>
                            </DropdownItem>
                            <DropdownItem>
                                Share
                                <DropdownShortcut>Ctrl+S</DropdownShortcut>
                            </DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>

                <DemoSection Title="Icons"
                             Description="Combine icons with labels for faster scanning."
                             Code="@IconsCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>With icons</DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem><Icon Name="LucideIcon.User" />Profile</DropdownItem>
                            <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
                            <DropdownItem><Icon Name="LucideIcon.Settings" />Settings</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Class="flex flex-wrap gap-6">
                <DemoSection Title="Checkboxes"
                             Description="Use checkbox items for independent menu toggles."
                             Code="@CheckboxesCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>Preferences</DropdownToggle>
                        <DropdownMenu>
                            <DropdownCheckboxItem Checked="@_showStatusBar" CheckedChanged="HandleShowStatusBarChanged">Status bar</DropdownCheckboxItem>
                            <DropdownCheckboxItem Checked="@_showActivityBar" CheckedChanged="HandleShowActivityBarChanged">Activity bar</DropdownCheckboxItem>
                            <DropdownCheckboxItem Checked="@_showPanel" CheckedChanged="HandleShowPanelChanged">Panel</DropdownCheckboxItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>

                <DemoSection Title="Radio Group"
                             Description="Use radio items for exclusive choices."
                             Code="@RadioGroupCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>Sort by</DropdownToggle>
                        <DropdownMenu>
                            <DropdownLabel>Sort by</DropdownLabel>
                            <DropdownDivider />
                            <DropdownRadioGroup>
                                <DropdownRadioItem Selected="@(_sortBy == "name")" SelectedChanged="HandleSortByNameChanged">Name</DropdownRadioItem>
                                <DropdownRadioItem Selected="@(_sortBy == "date-modified")" SelectedChanged="HandleSortByDateModifiedChanged">Date modified</DropdownRadioItem>
                                <DropdownRadioItem Selected="@(_sortBy == "created-date")" SelectedChanged="HandleSortByCreatedDateChanged">Created date</DropdownRadioItem>
                            </DropdownRadioGroup>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Class="flex flex-wrap gap-6">
                <DemoSection Title="Destructive"
                             Description="Use the destructive variant for irreversible actions."
                             Code="@DestructiveCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>Project actions</DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem>Rename</DropdownItem>
                            <DropdownItem>Duplicate</DropdownItem>
                            <DropdownDivider />
                            <DropdownItem Variant="destructive">Delete project</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>

                <DemoSection Title="Avatar"
                             Description="An account-style dropdown triggered by profile content."
                             Code="@AvatarCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>Account</DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem>
                                <Avatar Size="sm"><AvatarFallback>CN</AvatarFallback></Avatar>
                                <Div Class="grid gap-0.5">
                                    <Span class="text-sm font-medium">shadcn</Span>
                                    <Span class="text-xs text-muted-foreground">@("@")shadcn</Span>
                                </Div>
                            </DropdownItem>
                            <DropdownDivider />
                            <DropdownItem>Settings</DropdownItem>
                            <DropdownItem>Log out</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Complex"
                         Description="Combine groups, shortcuts, checkboxes, radio items, and a submenu in one richer menu."
                         Code="@ComplexCode"
                         CodeLanguage="razor">
                <Dropdown RightAligned="true">
                    <DropdownToggle>Open menu</DropdownToggle>
                    <DropdownMenu>
                        <DropdownGroup>
                            <DropdownLabel>Workspace</DropdownLabel>
                            <DropdownItem>
                                <Icon Name="LucideIcon.LayoutDashboard" />
                                Overview
                                <DropdownShortcut>G O</DropdownShortcut>
                            </DropdownItem>
                            <DropdownItem>
                                <Icon Name="LucideIcon.Settings" />
                                Settings
                                <DropdownShortcut>G S</DropdownShortcut>
                            </DropdownItem>
                        </DropdownGroup>
                        <DropdownDivider />
                        <DropdownCheckboxItem Checked="@_showSidebar" CheckedChanged="HandleShowSidebarChanged">Show sidebar</DropdownCheckboxItem>
                        <DropdownCheckboxItem Checked="@_showNotifications" CheckedChanged="HandleShowNotificationsChanged">Show notifications</DropdownCheckboxItem>
                        <DropdownDivider />
                        <DropdownRadioGroup>
                            <DropdownRadioItem Selected="@(_teamRole == "viewer")" SelectedChanged="HandleViewerRoleChanged">Viewer</DropdownRadioItem>
                            <DropdownRadioItem Selected="@(_teamRole == "editor")" SelectedChanged="HandleEditorRoleChanged">Editor</DropdownRadioItem>
                        </DropdownRadioGroup>
                        <DropdownDivider />
                        <DropdownSub>
                            <DropdownSubTrigger>Invite</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownItem>Email</DropdownItem>
                                <DropdownItem>Slack</DropdownItem>
                            </DropdownSubContent>
                        </DropdownSub>
                        <DropdownDivider />
                        <DropdownItem Variant="destructive">Remove member</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Class="flex flex-wrap gap-6">
                <DemoSection Title="In Dialog"
                             Description="Nested overlays should still work when the dropdown is opened from inside a dialog."
                             Code="@InDialogCode"
                             CodeLanguage="razor">
                    <Dialog>
                        <DialogTrigger AsChild="true">
                            <Button Variant="ButtonVariant.Outline">Open dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogHeader>
                                <DialogTitle>Workspace actions</DialogTitle>
                                <DialogDescription>Open the dropdown from within the dialog content.</DialogDescription>
                            </DialogHeader>

                            <Dropdown>
                                <DropdownToggle>Open menu</DropdownToggle>
                                <DropdownMenu>
                                    <DropdownItem><Icon Name="LucideIcon.Copy" />Copy</DropdownItem>
                                    <DropdownItem><Icon Name="LucideIcon.Scissors" />Cut</DropdownItem>
                                    <DropdownSub>
                                        <DropdownSubTrigger>More options</DropdownSubTrigger>
                                        <DropdownSubContent>
                                            <DropdownItem>Save page</DropdownItem>
                                            <DropdownItem>Create shortcut</DropdownItem>
                                        </DropdownSubContent>
                                    </DropdownSub>
                                    <DropdownDivider />
                                    <DropdownItem Variant="destructive"><Icon Name="LucideIcon.Trash2" />Delete</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </DialogContent>
                    </Dialog>
                </DemoSection>

                <DemoSection Title="Inset"
                             Description="Inset labels, items, checkboxes, radios, and sub-triggers match the indented shadcn menu layout."
                             Code="@InsetCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>Inset menu</DropdownToggle>
                        <DropdownMenu Class="w-52">
                            <DropdownGroup>
                                <DropdownLabel>Actions</DropdownLabel>
                                <DropdownItem><Icon Name="LucideIcon.Copy" />Copy</DropdownItem>
                                <DropdownItem><Icon Name="LucideIcon.Scissors" />Cut</DropdownItem>
                                <DropdownItem Inset="true">Paste</DropdownItem>
                            </DropdownGroup>
                            <DropdownDivider />
                            <DropdownGroup>
                                <DropdownLabel Inset="true">Appearance</DropdownLabel>
                                <DropdownCheckboxItem Inset="true" Checked="@_showBookmarks" CheckedChanged="HandleShowBookmarksChanged">Bookmarks</DropdownCheckboxItem>
                                <DropdownCheckboxItem Inset="true" Checked="@_showFullUrls" CheckedChanged="HandleShowFullUrlsChanged">Full URLs</DropdownCheckboxItem>
                            </DropdownGroup>
                            <DropdownDivider />
                            <DropdownGroup>
                                <DropdownLabel Inset="true">Theme</DropdownLabel>
                                <DropdownRadioGroup>
                                    <DropdownRadioItem Inset="true" Selected="@(_theme == "light")" SelectedChanged="HandleThemeLightChanged">Light</DropdownRadioItem>
                                    <DropdownRadioItem Inset="true" Selected="@(_theme == "dark")" SelectedChanged="HandleThemeDarkChanged">Dark</DropdownRadioItem>
                                    <DropdownRadioItem Inset="true" Selected="@(_theme == "system")" SelectedChanged="HandleThemeSystemChanged">System</DropdownRadioItem>
                                </DropdownRadioGroup>
                            </DropdownGroup>
                            <DropdownDivider />
                            <DropdownSub>
                                <DropdownSubTrigger Inset="true">More options</DropdownSubTrigger>
                                <DropdownSubContent>
                                    <DropdownItem>Save page</DropdownItem>
                                    <DropdownItem>Create shortcut</DropdownItem>
                                </DropdownSubContent>
                            </DropdownSub>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Dropdown menus should mirror naturally in right-to-left interfaces."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div class="text-right">
                        <Dropdown>
                            <DropdownToggle>افتح القائمة</DropdownToggle>
                            <DropdownMenu>
                                <DropdownGroup>
                                    <DropdownLabel>حسابي</DropdownLabel>
                                    <DropdownItem>الملف الشخصي</DropdownItem>
                                    <DropdownItem>الفواتير</DropdownItem>
                                </DropdownGroup>
                                <DropdownDivider />
                                <DropdownGroup>
                                    <DropdownItem>الفريق</DropdownItem>
                                    <DropdownItem>الاشتراك</DropdownItem>
                                </DropdownGroup>
                            </DropdownMenu>
                        </Dropdown>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Navigation links, split actions, and explicit click handlers.
                </Paragraph>
            </Div>

            <Div Class="flex flex-wrap gap-6">
                <DemoSection Title="Links"
                             Description="Render menu items as anchors when the action is true navigation."
                             Code="@LinksCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle>Docs links</DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem IsLink="true" Href="#buttons">Buttons</DropdownItem>
                            <DropdownItem IsLink="true" Href="#cards">Cards</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>

                <DemoSection Title="Split Button"
                             Description="Use a grouped action plus a split toggle when one action should stay primary."
                             Code="@SplitButtonCode"
                             CodeLanguage="razor">
                    <Dropdown IsGroup="true">
                        <Button Type="ButtonType.Button" Variant="ButtonVariant.Default">Deploy</Button>
                        <DropdownToggle IsSplit="true">
                            <Span Class="sr-only">Open deploy options</Span>
                        </DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem>Deploy now</DropdownItem>
                            <DropdownItem>Schedule</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>

                <DemoSection Title="Click Events"
                             Description="@($"Last clicked: {_lastClicked}")"
                             Code="@ClickEventsCode"
                             CodeLanguage="razor">
                    <Dropdown>
                        <DropdownToggle Clicked="OnDropdownToggleClicked">Clickable dropdown</DropdownToggle>
                        <DropdownMenu>
                            <DropdownItem Clicked="OnItemClicked">Click me</DropdownItem>
                            <DropdownItem Clicked="OnItemClicked">Click me too</DropdownItem>
                        </DropdownMenu>
                    </Dropdown>
                </DemoSection>
            </Div>
        </Section>
    </Div>
</Div>

@code {
    private bool _showStatusBar = true;
    private bool _showActivityBar;
    private bool _showPanel = true;
    private string _sortBy = "date-modified";
    private bool _showSidebar = true;
    private bool _showNotifications = true;
    private string _teamRole = "editor";
    private bool _showBookmarks = true;
    private bool _showFullUrls;
    private string _theme = "system";
    private string _lastClicked = "None";

