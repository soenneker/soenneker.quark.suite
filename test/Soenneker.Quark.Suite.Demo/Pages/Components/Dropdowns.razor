@page "/dropdowns"

<PageTitle>Dropdowns - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays a menu to the user — such as a set of actions or functions — triggered by a button."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                @AccountMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="The standard shadcn dropdown menu pattern."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                @AccountMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu"
                         Description="Use a submenu when an item opens a secondary list of actions."
                         Code="@SubmenuCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Email</DropdownItem>
                        <DropdownItem>Message</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger>More...</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownItem>Calendar</DropdownItem>
                                <DropdownItem>Slack</DropdownItem>
                            </DropdownSubContent>
                        </DropdownSub>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Shortcuts"
                         Description="Keyboard shortcuts sit at the trailing edge of menu items."
                         Code="@ShortcutsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>
                            New Tab
                            <DropdownShortcut>⌘T</DropdownShortcut>
                        </DropdownItem>
                        <DropdownItem>
                            New Window
                            <DropdownShortcut>⌘N</DropdownShortcut>
                        </DropdownItem>
                        <DropdownItem>
                            Share
                            <DropdownShortcut>⇧⌘S</DropdownShortcut>
                        </DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons"
                         Description="Icons make menu actions faster to scan."
                         Code="@IconsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Icon Name="LucideIcon.User" />Profile</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.Settings" />Settings</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkboxes"
                         Description="Checkbox menu items support independent toggles."
                         Code="@CheckboxesCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownLabel>Appearance</DropdownLabel>
                        <DropdownDivider />
                        <DropdownCheckboxItem Checked="true">Status Bar</DropdownCheckboxItem>
                        <DropdownCheckboxItem Checked="false" Disabled="true">Activity Bar</DropdownCheckboxItem>
                        <DropdownCheckboxItem Checked="true">Panel</DropdownCheckboxItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkboxes Icons"
                         Description="Checkbox menu items can include icons while preserving checked state."
                         Code="@CheckboxesIconsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownCheckboxItem Checked="true"><Icon Name="LucideIcon.PanelLeft" />Sidebar</DropdownCheckboxItem>
                        <DropdownCheckboxItem Checked="false"><Icon Name="LucideIcon.Bell" />Notifications</DropdownCheckboxItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio Group"
                         Description="Radio groups support mutually exclusive choices."
                         Code="@RadioGroupCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownLabel>Panel Position</DropdownLabel>
                        <DropdownDivider />
                        <DropdownRadioGroup>
                            <DropdownRadioItem Selected="true">Top</DropdownRadioItem>
                            <DropdownRadioItem>Bottom</DropdownRadioItem>
                            <DropdownRadioItem>Right</DropdownRadioItem>
                        </DropdownRadioGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio Icons"
                         Description="Radio items can pair choices with icons for faster scanning."
                         Code="@RadioIconsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownRadioGroup>
                            <DropdownRadioItem Selected="true"><Icon Name="LucideIcon.ArrowLeft" />Left</DropdownRadioItem>
                            <DropdownRadioItem><Icon Name="LucideIcon.ArrowUp" />Center</DropdownRadioItem>
                            <DropdownRadioItem><Icon Name="LucideIcon.ArrowRight" />Right</DropdownRadioItem>
                        </DropdownRadioGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Destructive"
                         Description="Use the destructive variant for dangerous actions."
                         Code="@DestructiveCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Project actions</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Rename</DropdownItem>
                        <DropdownItem>Duplicate</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem Variant="destructive">Delete project</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Description="Use an avatar dropdown for account menus."
                         Code="@AvatarCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" aria-label="Open account menu">
                            <Avatar><AvatarFallback>CN</AvatarFallback></Avatar>
                        </Button>
                    </DropdownToggle>
                    <DropdownMenu RightAligned="true" Class="w-56">
                        <DropdownItem>
                            <Avatar><AvatarFallback>CN</AvatarFallback></Avatar>
                            <Div Class="grid gap-0.5">
                                <Span Class="text-sm font-medium">Casey Nguyen</Span>
                                <Span Class="text-xs text-muted-foreground">casey@example.com</Span>
                            </Div>
                        </DropdownItem>
                        <DropdownDivider />
                        <DropdownItem>Settings</DropdownItem>
                        <DropdownItem>Log out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Complex"
                         Description="Combine groups, shortcuts, checkboxes, radio items, submenu, and destructive actions."
                         Code="@ComplexCode"
                         CodeLanguage="razor">
                @AccountMenu
            </DemoSection>
        </Section><Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Dropdown menus mirror naturally in right-to-left interfaces."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div TextAlign="TextAlign.End">
                        <Dropdown>
                            <DropdownToggle AsChild="true">
                                <Button Variant="ButtonVariant.Outline">افتح القائمة</Button>
                            </DropdownToggle>
                            <DropdownMenu>
                                <DropdownGroup>
                                    <DropdownLabel>حسابي</DropdownLabel>
                                    <DropdownItem>الملف الشخصي</DropdownItem>
                                    <DropdownItem>الفواتير</DropdownItem>
                                </DropdownGroup>
                                <DropdownDivider />
                                <DropdownItem Variant="destructive">تسجيل الخروج</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private RenderFragment AccountMenu =>
@<Dropdown>
    <DropdownToggle AsChild="true">
        <Button Variant="ButtonVariant.Outline">Open</Button>
    </DropdownToggle>
    <DropdownMenu Class="w-40">
        <DropdownLabel>My Account</DropdownLabel>
        <DropdownGroup>
            <DropdownItem>
                Profile
                <DropdownShortcut>⇧⌘P</DropdownShortcut>
            </DropdownItem>
            <DropdownItem>
                Billing
                <DropdownShortcut>⌘B</DropdownShortcut>
            </DropdownItem>
            <DropdownItem>
                Settings
                <DropdownShortcut>⌘S</DropdownShortcut>
            </DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>Team</DropdownItem>
            <DropdownSub>
                <DropdownSubTrigger>Invite users</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownItem>Email</DropdownItem>
                    <DropdownItem>Message</DropdownItem>
                    <DropdownDivider />
                    <DropdownItem>More...</DropdownItem>
                </DropdownSubContent>
            </DropdownSub>
            <DropdownItem>
                New Team
                <DropdownShortcut>⌘+T</DropdownShortcut>
            </DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownItem>GitHub</DropdownItem>
        <DropdownItem>Support</DropdownItem>
        <DropdownItem Disabled="true">API</DropdownItem>
        <DropdownDivider />
        <DropdownItem>
            Log out
            <DropdownShortcut>⇧⌘Q</DropdownShortcut>
        </DropdownItem>
    </DropdownMenu>
</Dropdown>;

    private const string BasicCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open</Button>
    </DropdownToggle>
    <DropdownMenu Class=""w-40"">
        <DropdownLabel>My Account</DropdownLabel>
