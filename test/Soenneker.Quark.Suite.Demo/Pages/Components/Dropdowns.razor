</Dropdown>";

    private const string ClickEventsCode =
@"<Dropdown>
    <DropdownToggle Clicked=""OnDropdownToggleClicked"">Clickable dropdown</DropdownToggle>
    <DropdownMenu>
        <DropdownItem Clicked=""OnItemClicked"">Click me</DropdownItem>
        <DropdownItem Clicked=""OnItemClicked"">Click me too</DropdownItem>
    </DropdownMenu>
</Dropdown>";

    private Task HandleShowStatusBarChanged(bool value)
    {
        _showStatusBar = value;
        return Task.CompletedTask;
    }

    private Task HandleShowActivityBarChanged(bool value)
    {
        _showActivityBar = value;
        return Task.CompletedTask;
    }

    private Task HandleShowPanelChanged(bool value)
    {
        _showPanel = value;
        return Task.CompletedTask;
    }

    private Task HandleSortByNameChanged(bool selected)
    {
        if (selected)
            _sortBy = "name";

        return Task.CompletedTask;
    }

    private Task HandleSortByDateModifiedChanged(bool selected)
    {
        if (selected)
            _sortBy = "date-modified";

        return Task.CompletedTask;
    }

    private Task HandleSortByCreatedDateChanged(bool selected)
    {
        if (selected)
            _sortBy = "created-date";

        return Task.CompletedTask;
    }

    private Task HandleShowSidebarChanged(bool value)
    {
        _showSidebar = value;
        return Task.CompletedTask;
    }

    private Task HandleShowNotificationsChanged(bool value)
    {
        _showNotifications = value;
        return Task.CompletedTask;
    }

    private Task HandleShowBookmarksChanged(bool value)
    {
        _showBookmarks = value;
        return Task.CompletedTask;
    }

    private Task HandleShowFullUrlsChanged(bool value)
    {
        _showFullUrls = value;
        return Task.CompletedTask;
    }

    private Task HandleViewerRoleChanged(bool selected)
    {
        if (selected)
            _teamRole = "viewer";

        return Task.CompletedTask;
    }

    private Task HandleEditorRoleChanged(bool selected)
    {
        if (selected)
            _teamRole = "editor";

        return Task.CompletedTask;
    }

    private Task HandleThemeLightChanged(bool selected)
    {
        if (selected)
            _theme = "light";

        return Task.CompletedTask;
    }

    private Task HandleThemeDarkChanged(bool selected)
    {
        if (selected)
            _theme = "dark";

        return Task.CompletedTask;
    }

    private Task HandleThemeSystemChanged(bool selected)
    {
        if (selected)
            _theme = "system";

        return Task.CompletedTask;
    }

    private void OnDropdownToggleClicked(MouseEventArgs _)
    {
        _lastClicked = "Toggle clicked";
        StateHasChanged();
    }

    private void OnItemClicked(MouseEventArgs _)
    {
        _lastClicked = DateTime.Now.ToString("HH:mm:ss");
        StateHasChanged();
    }
}
