@page "/components/dropdown-menu"

<PageTitle>Dropdowns - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays a menu to the user — such as a set of actions or functions — triggered by a button."
                         Code="@BasicCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                @AccountMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A basic dropdown menu with labels and separators."
                         Code="@BasicPreview2Code"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                @BasicMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu"
                         Description="Use DropdownMenuSub to nest secondary actions."
                         Code="@SubmenuCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Team</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger>Invite users</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownItem>Email</DropdownItem>
                                <DropdownItem>Message</DropdownItem>
                                <DropdownDivider />
                                <DropdownItem>More...</DropdownItem>
                            </DropdownSubContent>
                        </DropdownSub>
                        <DropdownItem>
                            New Team
                            <DropdownShortcut>⌘+T</DropdownShortcut>
                        </DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Shortcuts"
                         Description="Add DropdownMenuShortcut to show keyboard hints."
                         Code="@ShortcutsCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownGroup>
                            <DropdownLabel>My Account</DropdownLabel>
                            <DropdownItem>
                                Profile
                                <DropdownShortcut>⇧⌘P</DropdownShortcut>
                            </DropdownItem>
                            <DropdownItem>
                                Billing
                                <DropdownShortcut>⌘B</DropdownShortcut>
                            </DropdownItem>
                            <DropdownItem>
                                Settings
                                <DropdownShortcut>⌘S</DropdownShortcut>
                            </DropdownItem>
                        </DropdownGroup>
                        <DropdownDivider />
                        <DropdownItem>
                            Log out
                            <DropdownShortcut>⇧⌘Q</DropdownShortcut>
                        </DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons"
                         Description="Combine icons with labels for quick scanning."
                         Code="@IconsCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Icon Name="LucideIcon.User" />Profile</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.Settings" />Settings</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem><Icon Name="LucideIcon.LogOut" />Log out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkboxes"
                         Description="Use DropdownMenuCheckboxItem for toggles."
                         Code="@CheckboxesCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu Width="Width.Is40">
                        <DropdownLabel>Appearance</DropdownLabel>
                        <DropdownDivider />
                        <DropdownCheckboxItem @bind-Checked="_dropdownStatusBar">Status Bar</DropdownCheckboxItem>
                        <DropdownCheckboxItem Checked="false" Disabled="true">Activity Bar</DropdownCheckboxItem>
                        <DropdownCheckboxItem @bind-Checked="_dropdownPanel">Panel</DropdownCheckboxItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkboxes Icons"
                         Description="Add icons to checkbox items."
                         Code="@CheckboxesIconsCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Notifications</Button>
                    </DropdownToggle>
                    <DropdownMenu Width="Width.Is48">
                        <DropdownGroup>
                            <DropdownLabel>Notification Preferences</DropdownLabel>
                            <DropdownCheckboxItem @bind-Checked="_dropdownEmailNotifications"><Icon Name="LucideIcon.Mail" />Email notifications</DropdownCheckboxItem>
                            <DropdownCheckboxItem @bind-Checked="_dropdownSmsNotifications"><Icon Name="LucideIcon.MessageSquare" />SMS notifications</DropdownCheckboxItem>
                            <DropdownCheckboxItem @bind-Checked="_dropdownPushNotifications"><Icon Name="LucideIcon.Bell" />Push notifications</DropdownCheckboxItem>
                        </DropdownGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio Group"
                         Description="Use DropdownMenuRadioGroup for exclusive choices."
                         Code="@RadioGroupCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownGroup>
                            <DropdownLabel>Panel Position</DropdownLabel>
                            <DropdownRadioGroup @bind-Value="_dropdownPanelPosition">
                                <DropdownRadioItem Value="top">Top</DropdownRadioItem>
                                <DropdownRadioItem Value="bottom">Bottom</DropdownRadioItem>
                                <DropdownRadioItem Value="right">Right</DropdownRadioItem>
                            </DropdownRadioGroup>
                        </DropdownGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio Icons"
                         Description="Show radio options with icons."
                         Code="@RadioIconsCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Payment Method</Button>
                    </DropdownToggle>
                    <DropdownMenu MinWidth="MinWidth.Is56">
                        <DropdownGroup>
                            <DropdownLabel>Select Payment Method</DropdownLabel>
                            <DropdownRadioGroup @bind-Value="_dropdownPaymentMethod">
                                <DropdownRadioItem Value="card"><Icon Name="LucideIcon.CreditCard" />Credit Card</DropdownRadioItem>
                                <DropdownRadioItem Value="paypal"><Icon Name="LucideIcon.Wallet" />PayPal</DropdownRadioItem>
                                <DropdownRadioItem Value="bank"><Icon Name="LucideIcon.Building2" />Bank Transfer</DropdownRadioItem>
                            </DropdownRadioGroup>
                        </DropdownGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Destructive"
                         Description="Use variant=&quot;destructive&quot; for irreversible actions."
                         Code="@DestructiveCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Actions</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Icon Name="LucideIcon.Pencil" />Edit</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.Share" />Share</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem Variant="destructive"><Icon Name="LucideIcon.Trash" />Delete</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>



        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Description="An account switcher dropdown triggered by an avatar."
                         Code="@AvatarCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.Icon" Class="rounded-full">
                            <Avatar>
                                <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" />
                                <AvatarFallback>LR</AvatarFallback>
                            </Avatar>
                        </Button>
                    </DropdownToggle>
                    <DropdownMenu Align="Alignment.End">
                        <DropdownGroup>
                            <DropdownItem><Icon Name="LucideIcon.BadgeCheck" />Account</DropdownItem>
                            <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
                            <DropdownItem><Icon Name="LucideIcon.Bell" />Notifications</DropdownItem>
                        </DropdownGroup>
                        <DropdownDivider />
                        <DropdownItem><Icon Name="LucideIcon.LogOut" />Sign Out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Complex"
                         Description="A richer example combining groups, icons, and submenus."
                         Code="@ComplexCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                @ComplexMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor"
                         PreviewClass="@DropdownPreviewClass">
                <DirectionProvider Dir="rtl">
                    <Div dir="rtl" Class="grid w-full gap-6">
                        <Div Display="Display.Flex" AlignItems="AlignItems.Center" Gap="Gap.Is2" dir="ltr">
                            <Select TValue="string" SelectSize="SelectSizes.Sm" SelectedValue="@_dropdownRtlLocale" SelectedValueChanged="OnDropdownRtlLocaleChanged">
                                <SelectTrigger Width="Width.Is36" dir="ltr">
                                    <SelectValue />
                                </SelectTrigger>
                                <SelectContent Class="data-[state=open]:animate-none data-[state=closed]:animate-none" dir="ltr">
                                    <SelectGroup>
                                        <SelectItem TValue="string" ItemValue="@("ar")" Text="Arabic (العربية)" />
                                        <SelectItem TValue="string" ItemValue="@("he")" Text="Hebrew (עברית)" />
                                    </SelectGroup>
                                </SelectContent>
                            </Select>
                            <Button Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconSm" Class="ml-auto size-7" OnClick="ToggleDropdownRtlLocale">
                                <Icon Name="LucideIcon.Languages" />
                                <Span Class="sr-only">Toggle</Span>
                            </Button>
                        </Div>
                        <Div Class="flex justify-center">
                            <Dropdown>
                                <DropdownToggle AsChild="true">
                                    <Button Variant="ButtonVariant.Outline">@DropdownRtlOpenLabel</Button>
                                </DropdownToggle>
                                <DropdownMenu>
                                    <DropdownLabel>@DropdownRtlAccountLabel</DropdownLabel>
                                    <DropdownGroup>
                                        <DropdownItem>@DropdownRtlTeamLabel</DropdownItem>
                                        <DropdownSub>
                                            <DropdownSubTrigger>@DropdownRtlTeamLabel</DropdownSubTrigger>
                                            <DropdownSubContent>
                                                <DropdownItem>@DropdownRtlInviteUsersLabel</DropdownItem>
                                                <DropdownDivider />
                                                <DropdownItem>@DropdownRtlMoreLabel</DropdownItem>
                                            </DropdownSubContent>
                                        </DropdownSub>
                                        <DropdownItem>
                                            @DropdownRtlNewTeamLabel
                                            <DropdownShortcut>⌘+T</DropdownShortcut>
                                        </DropdownItem>
                                    </DropdownGroup>
                                    <DropdownDivider />
                                    <DropdownLabel>@DropdownRtlViewLabel</DropdownLabel>
                                    <DropdownGroup>
                                        <DropdownCheckboxItem @bind-Checked="_dropdownStatusBar">@DropdownRtlStatusBarLabel</DropdownCheckboxItem>
                                        <DropdownCheckboxItem Checked="false">@DropdownRtlActivityBarLabel</DropdownCheckboxItem>
                                        <DropdownCheckboxItem @bind-Checked="_dropdownPanel">@DropdownRtlPanelLabel</DropdownCheckboxItem>
                                    </DropdownGroup>
                                    <DropdownDivider />
                                    <DropdownLabel>@DropdownRtlPositionLabel</DropdownLabel>
                                    <DropdownRadioGroup @bind-Value="_dropdownPanelPosition">
                                        <DropdownRadioItem Value="top">@DropdownRtlTopLabel</DropdownRadioItem>
                                        <DropdownRadioItem Value="bottom">@DropdownRtlBottomLabel</DropdownRadioItem>
                                        <DropdownRadioItem Value="right">@DropdownRtlRightLabel</DropdownRadioItem>
                                        <DropdownRadioItem Value="left">@DropdownRtlLeftLabel</DropdownRadioItem>
                                    </DropdownRadioGroup>
                                    <DropdownDivider />
                                    <DropdownItem Variant="destructive">@DropdownRtlLogoutLabel</DropdownItem>
                                </DropdownMenu>
                            </Dropdown>
                        </Div>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DropdownPreviewClass =
        "preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0";

    private bool _dropdownStatusBar = true;
    private bool _dropdownPanel;
    private bool _dropdownEmailNotifications = true;
    private bool _dropdownSmsNotifications;
    private bool _dropdownPushNotifications = true;
    private string? _dropdownPanelPosition = "bottom";
    private string? _dropdownPaymentMethod = "card";
    private string? _dropdownTheme = "light";
    private string? _dropdownRtlLocale = "ar";
    private bool IsDropdownRtlHebrew => _dropdownRtlLocale == "he";
    private string DropdownRtlOpenLabel => IsDropdownRtlHebrew ? "פתח תפריט" : "افتح القائمة";
    private string DropdownRtlAccountLabel => IsDropdownRtlHebrew ? "חשבון" : "الحساب";
    private string DropdownRtlTeamLabel => IsDropdownRtlHebrew ? "צוות" : "الفريق";
    private string DropdownRtlInviteUsersLabel => IsDropdownRtlHebrew ? "הזמן משתמשים" : "دعوة المستخدمين";
    private string DropdownRtlMoreLabel => IsDropdownRtlHebrew ? "עוד..." : "المزيد...";
    private string DropdownRtlNewTeamLabel => IsDropdownRtlHebrew ? "צוות חדש" : "فريق جديد";
    private string DropdownRtlViewLabel => IsDropdownRtlHebrew ? "תצוגה" : "عرض";
    private string DropdownRtlStatusBarLabel => IsDropdownRtlHebrew ? "שורת מצב" : "شريط الحالة";
    private string DropdownRtlActivityBarLabel => IsDropdownRtlHebrew ? "סרגל פעילות" : "شريط النشاط";
    private string DropdownRtlPanelLabel => IsDropdownRtlHebrew ? "לוח" : "اللوحة";
    private string DropdownRtlPositionLabel => IsDropdownRtlHebrew ? "מיקום" : "الموضع";
    private string DropdownRtlTopLabel => IsDropdownRtlHebrew ? "למעלה" : "أعلى";
    private string DropdownRtlBottomLabel => IsDropdownRtlHebrew ? "למטה" : "أسفل";
    private string DropdownRtlRightLabel => IsDropdownRtlHebrew ? "ימין" : "يمين";
    private string DropdownRtlLeftLabel => IsDropdownRtlHebrew ? "שמאל" : "يسار";
    private string DropdownRtlLogoutLabel => IsDropdownRtlHebrew ? "התנתק" : "تسجيل الخروج";

    private RenderFragment BasicMenu =>
@<Dropdown>
    <DropdownToggle AsChild="true">
        <Button Variant="ButtonVariant.Outline">Open</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownGroup>
            <DropdownLabel>My Account</DropdownLabel>
            <DropdownItem>Profile</DropdownItem>
            <DropdownItem>Billing</DropdownItem>
            <DropdownItem>Settings</DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>GitHub</DropdownItem>
            <DropdownItem>Support</DropdownItem>
            <DropdownItem Disabled="true">API</DropdownItem>
        </DropdownGroup>
    </DropdownMenu>
</Dropdown>;

    private RenderFragment AccountMenu =>
@<Dropdown>
    <DropdownToggle AsChild="true">
        <Button Variant="ButtonVariant.Outline">Open</Button>
    </DropdownToggle>
    <DropdownMenu Width="Width.Is40">
        <DropdownLabel>My Account</DropdownLabel>
        <DropdownGroup>
            <DropdownItem>
                Profile
                <DropdownShortcut>⇧⌘P</DropdownShortcut>
            </DropdownItem>
            <DropdownItem>
                Billing
                <DropdownShortcut>⌘B</DropdownShortcut>
            </DropdownItem>
            <DropdownItem>
                Settings
                <DropdownShortcut>⌘S</DropdownShortcut>
            </DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>Team</DropdownItem>
            <DropdownSub>
                <DropdownSubTrigger>Invite users</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownItem>Email</DropdownItem>
                    <DropdownItem>Message</DropdownItem>
                    <DropdownDivider />
                    <DropdownItem>More...</DropdownItem>
                </DropdownSubContent>
            </DropdownSub>
            <DropdownItem>
                New Team
                <DropdownShortcut>⌘+T</DropdownShortcut>
            </DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>GitHub</DropdownItem>
            <DropdownItem>Support</DropdownItem>
            <DropdownItem Disabled="true">API</DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>
                Log out
                <DropdownShortcut>⇧⌘Q</DropdownShortcut>
            </DropdownItem>
        </DropdownGroup>
    </DropdownMenu>
</Dropdown>;

    private RenderFragment ComplexMenu =>
@<Dropdown>
    <DropdownToggle AsChild="true">
        <Button Variant="ButtonVariant.Outline">Complex Menu</Button>
    </DropdownToggle>
    <DropdownMenu Width="Width.Is44">
        <DropdownGroup>
            <DropdownLabel>File</DropdownLabel>
            <DropdownItem><Icon Name="LucideIcon.File" />New File<DropdownShortcut>⌘N</DropdownShortcut></DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.Folder" />New Folder<DropdownShortcut>⇧⌘N</DropdownShortcut></DropdownItem>
            <DropdownSub>
                <DropdownSubTrigger><Icon Name="LucideIcon.FolderOpen" />Open Recent</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownGroup>
                        <DropdownLabel>Recent Projects</DropdownLabel>
                        <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Alpha</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Beta</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger><Icon Name="LucideIcon.Ellipsis" />More Projects</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Gamma</DropdownItem>
                                <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Delta</DropdownItem>
                            </DropdownSubContent>
                        </DropdownSub>
                    </DropdownGroup>
                    <DropdownDivider />
                    <DropdownGroup>
                        <DropdownItem><Icon Name="LucideIcon.FolderSearch" />Browse...</DropdownItem>
                    </DropdownGroup>
                </DropdownSubContent>
            </DropdownSub>
            <DropdownDivider />
            <DropdownItem><Icon Name="LucideIcon.Save" />Save<DropdownShortcut>⌘S</DropdownShortcut></DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.Download" />Export<DropdownShortcut>⇧⌘E</DropdownShortcut></DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownLabel>View</DropdownLabel>
            <DropdownCheckboxItem @bind-Checked="_dropdownEmailNotifications"><Icon Name="LucideIcon.Eye" />Show Sidebar</DropdownCheckboxItem>
            <DropdownCheckboxItem @bind-Checked="_dropdownSmsNotifications"><Icon Name="LucideIcon.LayoutPanelLeft" />Show Status Bar</DropdownCheckboxItem>
            <DropdownSub>
                <DropdownSubTrigger><Icon Name="LucideIcon.Palette" />Theme</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownGroup>
                        <DropdownLabel>Appearance</DropdownLabel>
                        <DropdownRadioGroup @bind-Value="_dropdownTheme">
                            <DropdownRadioItem Value="light"><Icon Name="LucideIcon.Sun" />Light</DropdownRadioItem>
                            <DropdownRadioItem Value="dark"><Icon Name="LucideIcon.Moon" />Dark</DropdownRadioItem>
                            <DropdownRadioItem Value="system"><Icon Name="LucideIcon.Monitor" />System</DropdownRadioItem>
                        </DropdownRadioGroup>
                    </DropdownGroup>
                </DropdownSubContent>
            </DropdownSub>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownLabel>Account</DropdownLabel>
            <DropdownItem><Icon Name="LucideIcon.User" />Profile<DropdownShortcut>⇧⌘P</DropdownShortcut></DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
            <DropdownSub>
                <DropdownSubTrigger><Icon Name="LucideIcon.Settings" />Settings</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownGroup>
                        <DropdownLabel>Preferences</DropdownLabel>
                        <DropdownItem><Icon Name="LucideIcon.Keyboard" />Keyboard Shortcuts</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.Languages" />Language</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger><Icon Name="LucideIcon.Bell" />Notifications</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownGroup>
                                    <DropdownLabel>Notification Types</DropdownLabel>
                                    <DropdownCheckboxItem @bind-Checked="_dropdownPushNotifications"><Icon Name="LucideIcon.Bell" />Push Notifications</DropdownCheckboxItem>
                                    <DropdownCheckboxItem @bind-Checked="_dropdownEmailNotifications"><Icon Name="LucideIcon.Mail" />Email Notifications</DropdownCheckboxItem>
                                </DropdownGroup>
                            </DropdownSubContent>
                        </DropdownSub>
                    </DropdownGroup>
                    <DropdownDivider />
                    <DropdownGroup>
                        <DropdownItem><Icon Name="LucideIcon.Shield" />Privacy &amp; Security</DropdownItem>
                    </DropdownGroup>
                </DropdownSubContent>
            </DropdownSub>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem><Icon Name="LucideIcon.CircleQuestionMark" />Help &amp; Support</DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.FileText" />Documentation</DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem Variant="destructive"><Icon Name="LucideIcon.LogOut" />Sign Out<DropdownShortcut>⇧⌘Q</DropdownShortcut></DropdownItem>
        </DropdownGroup>
    </DropdownMenu>
</Dropdown>;

    private Task OnDropdownRtlLocaleChanged(string? value)
    {
        _dropdownRtlLocale = value;
        return Task.CompletedTask;
    }

    private Task ToggleDropdownRtlLocale()
    {
        _dropdownRtlLocale = IsDropdownRtlHebrew ? "ar" : "he";
        return Task.CompletedTask;
    }

    private const string BasicCode =
@"@AccountMenu";

    private const string BasicPreview2Code = @"@BasicMenu";

    private const string SubmenuCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownItem>Email</DropdownItem>
        <DropdownItem>Message</DropdownItem>
        <DropdownSub>
            <DropdownSubTrigger>More...</DropdownSubTrigger>
            <DropdownSubContent>
                <DropdownItem>Calendar</DropdownItem>
                <DropdownItem>Slack</DropdownItem>
            </DropdownSubContent>
        </DropdownSub>
    </DropdownMenu>
</Dropdown>";

    private const string ShortcutsCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownItem>
            New Tab
            <DropdownShortcut>⌘T</DropdownShortcut>
        </DropdownItem>
        <DropdownItem>
            New Window
            <DropdownShortcut>⌘N</DropdownShortcut>
        </DropdownItem>
        <DropdownItem>
            Share
            <DropdownShortcut>⇧⌘S</DropdownShortcut>
        </DropdownItem>
    </DropdownMenu>
</Dropdown>";

    private const string IconsCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownItem><Icon Name=""LucideIcon.User"" />Profile</DropdownItem>
        <DropdownItem><Icon Name=""LucideIcon.CreditCard"" />Billing</DropdownItem>
        <DropdownItem><Icon Name=""LucideIcon.Settings"" />Settings</DropdownItem>
    </DropdownMenu>
</Dropdown>";

    private const string CheckboxesCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownLabel>Appearance</DropdownLabel>
