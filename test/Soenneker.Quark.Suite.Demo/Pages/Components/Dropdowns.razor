@page "/dropdowns"

<PageTitle>Dropdowns - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays a menu to the user — such as a set of actions or functions — triggered by a button."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                @AccountMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A basic dropdown menu with labels and separators."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                @BasicMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Submenu"
                         Description="Use `DropdownMenuSub` to nest secondary actions."
                         Code="@SubmenuCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Email</DropdownItem>
                        <DropdownItem>Message</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger>More...</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownItem>Calendar</DropdownItem>
                                <DropdownItem>Slack</DropdownItem>
                            </DropdownSubContent>
                        </DropdownSub>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Shortcuts"
                         Description="Add `DropdownMenuShortcut` to show keyboard hints."
                         Code="@ShortcutsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>
                            New Tab
                            <DropdownShortcut>⌘T</DropdownShortcut>
                        </DropdownItem>
                        <DropdownItem>
                            New Window
                            <DropdownShortcut>⌘N</DropdownShortcut>
                        </DropdownItem>
                        <DropdownItem>
                            Share
                            <DropdownShortcut>⇧⌘S</DropdownShortcut>
                        </DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Icons"
                         Description="Combine icons with labels for quick scanning."
                         Code="@IconsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Icon Name="LucideIcon.User" />Profile</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.Settings" />Settings</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkboxes"
                         Description="Use `DropdownMenuCheckboxItem` for toggles."
                         Code="@CheckboxesCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownLabel>Appearance</DropdownLabel>
                        <DropdownDivider />
                        <DropdownCheckboxItem @bind-Checked="_dropdownStatusBar">Status Bar</DropdownCheckboxItem>
                        <DropdownCheckboxItem Checked="false" Disabled="true">Activity Bar</DropdownCheckboxItem>
                        <DropdownCheckboxItem @bind-Checked="_dropdownPanel">Panel</DropdownCheckboxItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Checkboxes Icons"
                         Description="Add icons to checkbox items."
                         Code="@CheckboxesIconsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Notifications</Button>
                    </DropdownToggle>
                    <DropdownMenu Class="w-48">
                        <DropdownGroup>
                            <DropdownLabel>Notification Preferences</DropdownLabel>
                            <DropdownCheckboxItem @bind-Checked="_dropdownEmailNotifications"><Icon Name="LucideIcon.Mail" />Email notifications</DropdownCheckboxItem>
                            <DropdownCheckboxItem @bind-Checked="_dropdownSmsNotifications"><Icon Name="LucideIcon.MessageSquare" />SMS notifications</DropdownCheckboxItem>
                            <DropdownCheckboxItem @bind-Checked="_dropdownPushNotifications"><Icon Name="LucideIcon.Bell" />Push notifications</DropdownCheckboxItem>
                        </DropdownGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio Group"
                         Description="Use `DropdownMenuRadioGroup` for exclusive choices."
                         Code="@RadioGroupCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Open</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownLabel>Panel Position</DropdownLabel>
                        <DropdownDivider />
                        <DropdownRadioGroup @bind-Value="_dropdownPanelPosition">
                            <DropdownRadioItem Value="top">Top</DropdownRadioItem>
                            <DropdownRadioItem Value="bottom">Bottom</DropdownRadioItem>
                            <DropdownRadioItem Value="right">Right</DropdownRadioItem>
                        </DropdownRadioGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Radio Icons"
                         Description="Show radio options with icons."
                         Code="@RadioIconsCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Payment Method</Button>
                    </DropdownToggle>
                    <DropdownMenu Class="min-w-56">
                        <DropdownGroup>
                            <DropdownLabel>Select Payment Method</DropdownLabel>
                            <DropdownRadioGroup @bind-Value="_dropdownPaymentMethod">
                                <DropdownRadioItem Value="card"><Icon Name="LucideIcon.CreditCard" />Credit Card</DropdownRadioItem>
                                <DropdownRadioItem Value="paypal"><Icon Name="LucideIcon.Wallet" />PayPal</DropdownRadioItem>
                                <DropdownRadioItem Value="bank"><Icon Name="LucideIcon.Building2" />Bank Transfer</DropdownRadioItem>
                            </DropdownRadioGroup>
                        </DropdownGroup>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Destructive"
                         Description="Use `variant=&quot;destructive&quot;` for irreversible actions."
                         Code="@DestructiveCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Outline">Actions</Button>
                    </DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Icon Name="LucideIcon.Pencil" />Edit project</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.Share" />Share project</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem Variant="destructive"><Icon Name="LucideIcon.Trash" />Delete project</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Description="An account switcher dropdown triggered by an avatar."
                         Code="@AvatarCode"
                         CodeLanguage="razor">
                <Dropdown>
                    <DropdownToggle AsChild="true">
                        <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" Class="rounded-full">
                            <Avatar>
                                <AvatarImage Src="https://github.com/shadcn.png" Alt="shadcn" />
                                <AvatarFallback>LR</AvatarFallback>
                            </Avatar>
                        </Button>
                    </DropdownToggle>
                    <DropdownMenu Align="Alignment.End">
                        <DropdownGroup>
                            <DropdownItem><Icon Name="LucideIcon.BadgeCheck" />Account</DropdownItem>
                            <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
                            <DropdownItem><Icon Name="LucideIcon.Bell" />Notifications</DropdownItem>
                        </DropdownGroup>
                        <DropdownDivider />
                        <DropdownItem><Icon Name="LucideIcon.LogOut" />Sign Out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Complex"
                         Description="A richer example combining groups, icons, and submenus."
                         Code="@ComplexCode"
                         CodeLanguage="razor">
                @ComplexMenu
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="To enable RTL support in shadcn/ui, see the RTL configuration guide."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div TextAlign="TextAlign.End">
                        <Dropdown>
                            <DropdownToggle AsChild="true">
                                <Button Variant="ButtonVariant.Outline">افتح القائمة</Button>
                            </DropdownToggle>
                            <DropdownMenu>
                                <DropdownGroup>
                                    <DropdownLabel>حسابي</DropdownLabel>
                                    <DropdownItem>الملف الشخصي</DropdownItem>
                                    <DropdownItem>الفواتير</DropdownItem>
                                </DropdownGroup>
                                <DropdownDivider />
                                <DropdownItem Variant="destructive">تسجيل الخروج</DropdownItem>
                            </DropdownMenu>
                        </Dropdown>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private bool _dropdownStatusBar = true;
    private bool _dropdownPanel;
    private bool _dropdownEmailNotifications = true;
    private bool _dropdownSmsNotifications;
    private bool _dropdownPushNotifications = true;
    private string? _dropdownPanelPosition = "bottom";
    private string? _dropdownPaymentMethod = "card";
    private string? _dropdownTheme = "light";

    private RenderFragment BasicMenu =>
@<Dropdown>
    <DropdownToggle AsChild="true">
        <Button Variant="ButtonVariant.Outline">Open</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownGroup>
            <DropdownLabel>My Account</DropdownLabel>
            <DropdownItem>Profile</DropdownItem>
            <DropdownItem>Billing</DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>Team</DropdownItem>
            <DropdownItem>Subscription</DropdownItem>
        </DropdownGroup>
    </DropdownMenu>
</Dropdown>;

    private RenderFragment AccountMenu =>
@<Dropdown>
    <DropdownToggle AsChild="true">
        <Button Variant="ButtonVariant.Outline">Open</Button>
    </DropdownToggle>
    <DropdownMenu Class="w-56">
        <DropdownLabel>My Account</DropdownLabel>
        <DropdownGroup>
            <DropdownItem>
                Profile
                <DropdownShortcut>⇧⌘P</DropdownShortcut>
            </DropdownItem>
            <DropdownItem>
                Billing
                <DropdownShortcut>⌘B</DropdownShortcut>
            </DropdownItem>
            <DropdownItem>
                Settings
                <DropdownShortcut>⌘S</DropdownShortcut>
            </DropdownItem>
            <DropdownItem>
                Keyboard shortcuts
                <DropdownShortcut>⌘K</DropdownShortcut>
            </DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>Team</DropdownItem>
            <DropdownSub>
                <DropdownSubTrigger>Invite users</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownItem>Email</DropdownItem>
                    <DropdownItem>Message</DropdownItem>
                    <DropdownDivider />
                    <DropdownItem>More...</DropdownItem>
                </DropdownSubContent>
            </DropdownSub>
            <DropdownItem>
                New Team
                <DropdownShortcut>⌘+T</DropdownShortcut>
            </DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownItem>GitHub</DropdownItem>
        <DropdownItem>Support</DropdownItem>
        <DropdownItem Disabled="true">API</DropdownItem>
        <DropdownDivider />
        <DropdownItem>
            Log out
            <DropdownShortcut>⇧⌘Q</DropdownShortcut>
        </DropdownItem>
    </DropdownMenu>
</Dropdown>;

    private RenderFragment ComplexMenu =>
@<Dropdown>
    <DropdownToggle AsChild="true">
        <Button Variant="ButtonVariant.Outline">Complex Menu</Button>
    </DropdownToggle>
    <DropdownMenu Class="w-44">
        <DropdownGroup>
            <DropdownLabel>File</DropdownLabel>
            <DropdownItem><Icon Name="LucideIcon.File" />New File<DropdownShortcut>⌘N</DropdownShortcut></DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.Folder" />New Folder<DropdownShortcut>⇧⌘N</DropdownShortcut></DropdownItem>
            <DropdownSub>
                <DropdownSubTrigger><Icon Name="LucideIcon.FolderOpen" />Open Recent</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownGroup>
                        <DropdownLabel>Recent Projects</DropdownLabel>
                        <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Alpha</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Beta</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger><Icon Name="LucideIcon.Ellipsis" />More Projects</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Gamma</DropdownItem>
                                <DropdownItem><Icon Name="LucideIcon.FileCode" />Project Delta</DropdownItem>
                            </DropdownSubContent>
                        </DropdownSub>
                    </DropdownGroup>
                    <DropdownDivider />
                    <DropdownGroup>
                        <DropdownItem><Icon Name="LucideIcon.FolderSearch" />Browse...</DropdownItem>
                    </DropdownGroup>
                </DropdownSubContent>
            </DropdownSub>
            <DropdownDivider />
            <DropdownItem><Icon Name="LucideIcon.Save" />Save<DropdownShortcut>⌘S</DropdownShortcut></DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.Download" />Export<DropdownShortcut>⇧⌘E</DropdownShortcut></DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownLabel>View</DropdownLabel>
            <DropdownCheckboxItem @bind-Checked="_dropdownEmailNotifications"><Icon Name="LucideIcon.Eye" />Show Sidebar</DropdownCheckboxItem>
            <DropdownCheckboxItem @bind-Checked="_dropdownSmsNotifications"><Icon Name="LucideIcon.LayoutPanelLeft" />Show Status Bar</DropdownCheckboxItem>
            <DropdownSub>
                <DropdownSubTrigger><Icon Name="LucideIcon.Palette" />Theme</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownGroup>
                        <DropdownLabel>Appearance</DropdownLabel>
                        <DropdownRadioGroup @bind-Value="_dropdownTheme">
                            <DropdownRadioItem Value="light"><Icon Name="LucideIcon.Sun" />Light</DropdownRadioItem>
                            <DropdownRadioItem Value="dark"><Icon Name="LucideIcon.Moon" />Dark</DropdownRadioItem>
                            <DropdownRadioItem Value="system"><Icon Name="LucideIcon.Monitor" />System</DropdownRadioItem>
                        </DropdownRadioGroup>
                    </DropdownGroup>
                </DropdownSubContent>
            </DropdownSub>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownLabel>Account</DropdownLabel>
            <DropdownItem><Icon Name="LucideIcon.User" />Profile<DropdownShortcut>⇧⌘P</DropdownShortcut></DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.CreditCard" />Billing</DropdownItem>
            <DropdownSub>
                <DropdownSubTrigger><Icon Name="LucideIcon.Settings" />Settings</DropdownSubTrigger>
                <DropdownSubContent>
                    <DropdownGroup>
                        <DropdownLabel>Preferences</DropdownLabel>
                        <DropdownItem><Icon Name="LucideIcon.Keyboard" />Keyboard Shortcuts</DropdownItem>
                        <DropdownItem><Icon Name="LucideIcon.Languages" />Language</DropdownItem>
                        <DropdownSub>
                            <DropdownSubTrigger><Icon Name="LucideIcon.Bell" />Notifications</DropdownSubTrigger>
                            <DropdownSubContent>
                                <DropdownGroup>
                                    <DropdownLabel>Notification Types</DropdownLabel>
                                    <DropdownCheckboxItem @bind-Checked="_dropdownPushNotifications"><Icon Name="LucideIcon.Bell" />Push Notifications</DropdownCheckboxItem>
                                    <DropdownCheckboxItem @bind-Checked="_dropdownEmailNotifications"><Icon Name="LucideIcon.Mail" />Email Notifications</DropdownCheckboxItem>
                                </DropdownGroup>
                            </DropdownSubContent>
                        </DropdownSub>
                    </DropdownGroup>
                    <DropdownDivider />
                    <DropdownGroup>
                        <DropdownItem><Icon Name="LucideIcon.Shield" />Privacy &amp; Security</DropdownItem>
                    </DropdownGroup>
                </DropdownSubContent>
            </DropdownSub>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem><Icon Name="LucideIcon.CircleQuestionMark" />Help &amp; Support</DropdownItem>
            <DropdownItem><Icon Name="LucideIcon.FileText" />Documentation</DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem Variant="destructive"><Icon Name="LucideIcon.LogOut" />Sign Out<DropdownShortcut>⇧⌘Q</DropdownShortcut></DropdownItem>
        </DropdownGroup>
    </DropdownMenu>
</Dropdown>;

    private const string BasicCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Open</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownGroup>
            <DropdownLabel>My Account</DropdownLabel>
            <DropdownItem>Profile</DropdownItem>
            <DropdownItem>Billing</DropdownItem>
        </DropdownGroup>
        <DropdownDivider />
        <DropdownGroup>
            <DropdownItem>Team</DropdownItem>
            <DropdownItem>Subscription</DropdownItem>
        </DropdownGroup>
    </DropdownMenu>
</Dropdown>";

    private const string SubmenuCode =
@"<DropdownSub>
    <DropdownSubTrigger>More...</DropdownSubTrigger>
    <DropdownSubContent>
        <DropdownItem>Calendar</DropdownItem>
        <DropdownItem>Slack</DropdownItem>
    </DropdownSubContent>
</DropdownSub>";

    private const string ShortcutsCode =
@"<DropdownItem>
    New Tab
    <DropdownShortcut>⌘T</DropdownShortcut>
</DropdownItem>";

    private const string IconsCode =
@"<DropdownItem><Icon Name=""LucideIcon.User"" />Profile</DropdownItem>";

    private const string CheckboxesCode =
@"<DropdownCheckboxItem Checked=""true"">Status Bar</DropdownCheckboxItem>";

    private const string CheckboxesIconsCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Notifications</Button>
    </DropdownToggle>
    <DropdownMenu Class=""w-48"">
        <DropdownGroup>
            <DropdownLabel>Notification Preferences</DropdownLabel>
            <DropdownCheckboxItem @bind-Checked=""_dropdownEmailNotifications""><Icon Name=""LucideIcon.Mail"" />Email notifications</DropdownCheckboxItem>
            <DropdownCheckboxItem @bind-Checked=""_dropdownSmsNotifications""><Icon Name=""LucideIcon.MessageSquare"" />SMS notifications</DropdownCheckboxItem>
            <DropdownCheckboxItem @bind-Checked=""_dropdownPushNotifications""><Icon Name=""LucideIcon.Bell"" />Push notifications</DropdownCheckboxItem>
        </DropdownGroup>
    </DropdownMenu>
</Dropdown>";

    private const string RadioGroupCode =
@"<DropdownRadioGroup @bind-Value=""_dropdownPanelPosition"">
    <DropdownRadioItem Value=""top"">Top</DropdownRadioItem>
    <DropdownRadioItem Value=""bottom"">Bottom</DropdownRadioItem>
</DropdownRadioGroup>";

    private const string RadioIconsCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Payment Method</Button>
    </DropdownToggle>
    <DropdownMenu Class=""min-w-56"">
        <DropdownLabel>Select Payment Method</DropdownLabel>
        <DropdownRadioGroup @bind-Value=""_dropdownPaymentMethod"">
            <DropdownRadioItem Value=""card""><Icon Name=""LucideIcon.CreditCard"" />Credit Card</DropdownRadioItem>
            <DropdownRadioItem Value=""paypal""><Icon Name=""LucideIcon.Wallet"" />PayPal</DropdownRadioItem>
            <DropdownRadioItem Value=""bank""><Icon Name=""LucideIcon.Building2"" />Bank Transfer</DropdownRadioItem>
        </DropdownRadioGroup>
    </DropdownMenu>
</Dropdown>";

    private const string DestructiveCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Actions</Button>
    </DropdownToggle>
    <DropdownMenu>
        <DropdownItem><Icon Name=""LucideIcon.Pencil"" />Edit project</DropdownItem>
        <DropdownItem><Icon Name=""LucideIcon.Share"" />Share project</DropdownItem>
        <DropdownDivider />
        <DropdownItem Variant=""destructive""><Icon Name=""LucideIcon.Trash"" />Delete project</DropdownItem>
    </DropdownMenu>
</Dropdown>";

    private const string AvatarCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Ghost"" Size=""ButtonSize.Icon"" Class=""rounded-full"">
            <Avatar>
                <AvatarImage Src=""https://github.com/shadcn.png"" Alt=""shadcn"" />
                <AvatarFallback>LR</AvatarFallback>
            </Avatar>
        </Button>
    </DropdownToggle>
    <DropdownMenu Align=""Alignment.End"">...</DropdownMenu>
</Dropdown>";

    private const string ComplexCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Outline"">Complex Menu</Button>
    </DropdownToggle>
    <DropdownMenu Class=""w-44"">...</DropdownMenu>
</Dropdown>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Dropdown>
        <DropdownToggle AsChild=""true""><Button Variant=""ButtonVariant.Outline"">افتح القائمة</Button></DropdownToggle>
        <DropdownMenu>
            <DropdownItem>الملف الشخصي</DropdownItem>
            <DropdownItem Variant=""destructive"">تسجيل الخروج</DropdownItem>
        </DropdownMenu>
    </Dropdown>
</DirectionProvider>";
}
