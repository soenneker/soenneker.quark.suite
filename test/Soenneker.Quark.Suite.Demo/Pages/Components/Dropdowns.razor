        <DropdownItem>Support</DropdownItem>
        <DropdownItem Disabled=""true"">API</DropdownItem>
        <DropdownDivider />
        <DropdownItem>Log out<DropdownShortcut>⇧⌘Q</DropdownShortcut></DropdownItem>
    </DropdownMenu>
</Dropdown>";

    private const string SubmenuCode =
@"<DropdownSub>
    <DropdownSubTrigger>More...</DropdownSubTrigger>
    <DropdownSubContent>
        <DropdownItem>Calendar</DropdownItem>
        <DropdownItem>Slack</DropdownItem>
    </DropdownSubContent>
</DropdownSub>";

    private const string ShortcutsCode =
@"<DropdownItem>
    New Tab
    <DropdownShortcut>⌘T</DropdownShortcut>
</DropdownItem>";

    private const string IconsCode =
@"<DropdownItem><Icon Name=""LucideIcon.User"" />Profile</DropdownItem>";

    private const string CheckboxesCode =
@"<DropdownCheckboxItem Checked=""true"">Status Bar</DropdownCheckboxItem>";

    private const string CheckboxesIconsCode =
@"<DropdownCheckboxItem Checked=""true"">
    <Icon Name=""LucideIcon.PanelLeft"" />
    Sidebar
</DropdownCheckboxItem>";

    private const string RadioGroupCode =
@"<DropdownRadioGroup>
    <DropdownRadioItem Selected=""true"">Top</DropdownRadioItem>
    <DropdownRadioItem>Bottom</DropdownRadioItem>
</DropdownRadioGroup>";

    private const string RadioIconsCode =
@"<DropdownRadioItem Selected=""true"">
    <Icon Name=""LucideIcon.ArrowLeft"" />
    Left
</DropdownRadioItem>";

    private const string DestructiveCode =
@"<DropdownItem Variant=""destructive"">Delete project</DropdownItem>";

    private const string AvatarCode =
@"<Dropdown>
    <DropdownToggle AsChild=""true"">
        <Button Variant=""ButtonVariant.Ghost""><Avatar><AvatarFallback>CN</AvatarFallback></Avatar></Button>
    </DropdownToggle>
    <DropdownMenu>...</DropdownMenu>
</Dropdown>";

    private const string ComplexCode = BasicCode;

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Dropdown>
        <DropdownToggle AsChild=""true""><Button Variant=""ButtonVariant.Outline"">افتح القائمة</Button></DropdownToggle>
        <DropdownMenu>
            <DropdownItem>الملف الشخصي</DropdownItem>
            <DropdownItem Variant=""destructive"">تسجيل الخروج</DropdownItem>
        </DropdownMenu>
    </Dropdown>
</DirectionProvider>";
}
