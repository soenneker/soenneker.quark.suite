@page "/dropdowns"

<PageTitle>Dropdowns - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
        <DemoSection Title="Basic" Description="DropdownToggle opens DropdownMenu with DropdownItem entries." Code="@(@"<Dropdown>
    <DropdownToggle>Dropdown button</DropdownToggle>
    <DropdownMenu>
        <DropdownItem>Action</DropdownItem>
        <DropdownItem>Another action</DropdownItem>
    </DropdownMenu>
</Dropdown>")">
            <Dropdown>
                <DropdownToggle>Dropdown button</DropdownToggle>
                <DropdownMenu>
                    <DropdownItem>Action</DropdownItem>
                    <DropdownItem>Another action</DropdownItem>
                    <DropdownItem>Something else here</DropdownItem>
                </DropdownMenu>
            </Dropdown>
        </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
        <Div Class="flex flex-wrap gap-6">
            <DemoSection Title="Shortcuts" Description="Render shortcut hints inline within the item content to mirror the shadcn shortcut pattern.">
                <Dropdown>
                    <DropdownToggle>Open shortcuts</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Div Class="flex w-48 items-center justify-between"><Span>New tab</Span><Kbd>Ctrl+T</Kbd></Div></DropdownItem>
                        <DropdownItem><Div Class="flex w-48 items-center justify-between"><Span>Share</Span><Kbd>Ctrl+S</Kbd></Div></DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Icons" Description="Icons can be embedded directly in dropdown item content.">
                <Dropdown>
                    <DropdownToggle>With icons</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.User" />Profile</Div></DropdownItem>
                        <DropdownItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.CreditCard" />Billing</Div></DropdownItem>
                        <DropdownItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.Settings" />Settings</Div></DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Links" Description="Use IsLink=true and Href for anchor items.">
                <Dropdown>
                    <DropdownToggle>Dropdown with Links</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem Href="#" IsLink="true">Action</DropdownItem>
                        <DropdownItem Href="#" IsLink="true">Another action</DropdownItem>
                        <DropdownDivider/>
                        <DropdownItem Href="#" IsLink="true">Separated link</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Right-aligned" Description="Set RightAligned=true to align menu to the right edge.">
                <Dropdown RightAligned="true">
                    <DropdownToggle>Right-aligned</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Action</DropdownItem>
                        <DropdownItem>Another action</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Div>
        </Section>

        <Section Space="Space.Y.Is4">
        <DemoSection Title="Split button" Description="Use IsGroup=true with a Button and DropdownToggle IsSplit=true.">
            <Dropdown IsGroup="true">
                <Button Type="ButtonType.Button" Variant="ButtonVariant.Default">Split button</Button>
                <DropdownToggle IsSplit="true">
                    <Span Class="sr-only">Toggle Dropdown</Span>
                </DropdownToggle>
                <DropdownMenu>
                    <DropdownItem>Action</DropdownItem>
                    <DropdownItem>Another action</DropdownItem>
                    <DropdownDivider/>
                    <DropdownItem>Separated link</DropdownItem>
                </DropdownMenu>
            </Dropdown>
        </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
        <Div Class="flex flex-wrap gap-6">
            <DemoSection Title="Checkboxes" Description="Quark does not ship checkbox menu items, so the closest equivalent is active rows with check icons.">
                <Dropdown>
                    <DropdownToggle>Preferences</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem Active="true"><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.Check" />Status bar</Div></DropdownItem>
                        <DropdownItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Span class="size-4"></Span>Activity feed</Div></DropdownItem>
                        <DropdownItem Active="true"><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.Check" />Sidebar</Div></DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Radio Group" Description="Active styling can also represent the single selected choice in a dropdown list.">
                <Dropdown>
                    <DropdownToggle>Sort by</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Span class="size-4"></Span>Name</Div></DropdownItem>
                        <DropdownItem Active="true"><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Icon Name="LucideIcon.CircleCheck" />Date modified</Div></DropdownItem>
                        <DropdownItem><Div Display="Display.Flex" AlignUtility="Align.ItemsCenter" Gap="Gap.Is2"><Span class="size-4"></Span>Created date</Div></DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Active item" Description="Set Active=true on the selected DropdownItem.">
                <Dropdown>
                    <DropdownToggle>With Active</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Regular</DropdownItem>
                        <DropdownItem Active="true">Active item</DropdownItem>
                        <DropdownItem>Another</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Disabled" Description="Set Disabled=true on Dropdown and DropdownToggle to disable opening.">
                <Dropdown Disabled="true">
                    <DropdownToggle Disabled="true">Disabled dropdown</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Won't show</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Div>
        </Section>

        <Section Space="Space.Y.Is4">
        <Div Class="flex flex-wrap gap-6">
            <DemoSection Title="Destructive" Description="Use destructive text utilities for irreversible actions.">
                <Dropdown>
                    <DropdownToggle>Project actions</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>Rename</DropdownItem>
                        <DropdownItem>Duplicate</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem><Span Class="text-destructive">Delete project</Span></DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Avatar" Description="Use richer content inside items for profile-style dropdown rows.">
                <Dropdown>
                    <DropdownToggle>Account</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>
                            <Div Class="flex items-center gap-3">
                                <Avatar Size="sm"><AvatarFallback>CN</AvatarFallback></Avatar>
                                <Div Class="space-y-0.5">
                                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">shadcn</Paragraph>
                                    <Paragraph Class="text-xs text-muted-foreground">@("@")shadcn</Paragraph>
                                </Div>
                            </Div>
                        </DropdownItem>
                        <DropdownDivider />
                        <DropdownItem>Settings</DropdownItem>
                        <DropdownItem>Log out</DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
            <DemoSection Title="Complex" Description="Combine avatars, shortcuts, active rows, and destructive actions in a single overflow menu.">
                <Dropdown RightAligned="true">
                    <DropdownToggle>Open menu</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>
                            <Div Class="flex items-center gap-3">
                                <Avatar Size="sm"><AvatarFallback>JD</AvatarFallback></Avatar>
                                <Div>
                                    <Paragraph TextSize="TextSize.Sm" FontWeight="FontWeight.Medium">Jane Doe</Paragraph>
                                    <Paragraph Class="text-xs text-muted-foreground">jane@acme.dev</Paragraph>
                                </Div>
                            </Div>
                        </DropdownItem>
                        <DropdownDivider />
                        <DropdownItem Active="true"><Div Class="flex w-56 items-center justify-between"><Span>Overview</Span><Kbd>G O</Kbd></Div></DropdownItem>
                        <DropdownItem><Div Class="flex w-56 items-center justify-between"><Span>Settings</Span><Kbd>G S</Kbd></Div></DropdownItem>
                        <DropdownDivider />
                        <DropdownItem><Span Class="text-destructive">Remove member</Span></DropdownItem>
                    </DropdownMenu>
                </Dropdown>
            </DemoSection>
        </Div>
        </Section>

        <Section Space="Space.Y.Is4">
        <DemoSection Title="Click events" Description="@($"Last clicked: {_lastClicked}")">
            <Dropdown>
                <DropdownToggle Clicked="OnDropdownToggleClicked">Clickable Dropdown</DropdownToggle>
                <DropdownMenu>
                    <DropdownItem Clicked="OnItemClicked">Click me!</DropdownItem>
                    <DropdownItem Clicked="OnItemClicked">Click me too!</DropdownItem>
                </DropdownMenu>
            </Dropdown>
        </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string _lastClicked = "None";

    private void OnDropdownToggleClicked(MouseEventArgs _) { _lastClicked = "Toggle clicked"; StateHasChanged(); }
    private void OnItemClicked(MouseEventArgs _) { _lastClicked = DateTime.Now.ToString("HH:mm:ss"); StateHasChanged(); }
}
