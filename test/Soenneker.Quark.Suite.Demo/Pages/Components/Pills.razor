@page "/components/pill"

<PageTitle>Pill Component - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                Description="Composable pill badge for dense status, ownership, and metric labels."
                Code="@DemoCode"
                CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" FlexWrap="FlexWrap.Wrap" Justify="Justify.Center" Gap="Gap.Is2">
                    <Pill>
                        <PillIndicator Variant="PillIndicatorVariant.Success" Pulse="true" />
                        Online
                    </Pill>
                    <Pill>
                        <Icon Name="LucideIcon.CircleCheck" />
                        Verified
                    </Pill>
                    <Pill>
                        Revenue
                        <PillDelta>12%</PillDelta>
                    </Pill>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Indicators"
                         Description="Indicator variants cover success, error, warning, info, and neutral states."
                         Code="@IndicatorsCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" FlexWrap="FlexWrap.Wrap" Justify="Justify.Center" Gap="Gap.Is2">
                    <Pill><PillIndicator Variant="PillIndicatorVariant.Success" /> Success</Pill>
                    <Pill><PillIndicator Variant="PillIndicatorVariant.Error" /> Error</Pill>
                    <Pill><PillIndicator Variant="PillIndicatorVariant.Warning" /> Warning</Pill>
                    <Pill><PillIndicator Variant="PillIndicatorVariant.Info" /> Info</Pill>
                    <Pill><PillIndicator Variant="PillIndicatorVariant.Neutral" /> Neutral</Pill>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Avatar"
                         Description="Compose small avatars directly inside the pill."
                         Code="@AvatarCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" FlexWrap="FlexWrap.Wrap" Justify="Justify.Center" Gap="Gap.Is2">
                    <Pill>
                        <Avatar AvatarSize="sm" Class="-ms-1">
                            <AvatarImage Src="https://github.com/shadcn.png" Alt="@("@shadcn")" />
                            <AvatarFallback>CN</AvatarFallback>
                        </Avatar>
                        shadcn
                    </Pill>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Dismissible"
                         Description="Use PillClose when a pill represents a removable assignment or filter."
                         Code="@DismissibleCode"
                         CodeLanguage="razor">
                <Div Display="Display.Flex" Width="Width.IsFull" FlexWrap="FlexWrap.Wrap" Justify="Justify.Center" Gap="Gap.Is2">
                    <Pill>
                        <PillIndicator Variant="PillIndicatorVariant.Info" />
                        Assigned
                        <PillClose Label="Remove assigned filter" />
                    </Pill>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string DemoCode =
@"<Pill>
    <PillIndicator Variant=""PillIndicatorVariant.Success"" Pulse=""true"" />
    Online
</Pill>
<Pill>
    <Icon Name=""LucideIcon.CircleCheck"" />
    Verified
</Pill>
<Pill>
    Revenue
    <PillDelta>12%</PillDelta>
</Pill>";

    private const string IndicatorsCode =
@"<Pill><PillIndicator Variant=""PillIndicatorVariant.Success"" /> Success</Pill>
<Pill><PillIndicator Variant=""PillIndicatorVariant.Error"" /> Error</Pill>
<Pill><PillIndicator Variant=""PillIndicatorVariant.Warning"" /> Warning</Pill>
<Pill><PillIndicator Variant=""PillIndicatorVariant.Info"" /> Info</Pill>
<Pill><PillIndicator Variant=""PillIndicatorVariant.Neutral"" /> Neutral</Pill>";

    private const string AvatarCode =
@"<Pill>
    <Avatar AvatarSize=""sm"" Class=""-ms-1"">
        <AvatarImage Src=""https://github.com/shadcn.png"" Alt=""@@shadcn"" />
        <AvatarFallback>CN</AvatarFallback>
    </Avatar>
    shadcn
</Pill>";

    private const string DismissibleCode =
@"<Pill>
    <PillIndicator Variant=""PillIndicatorVariant.Info"" />
    Assigned
    <PillClose Label=""Remove assigned filter"" />
</Pill>";
}
