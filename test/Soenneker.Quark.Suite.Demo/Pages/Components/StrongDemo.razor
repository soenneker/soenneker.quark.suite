@page "/strong-demo"

<PageTitle>Strong - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Basic" Code="@(@"<Paragraph>Normal text with <Strong>strong text</Strong> inline.</Paragraph>")"
        CodeLanguage="razor">
            <Paragraph>Normal text with <Strong>strong text inline</Strong> within the paragraph.</Paragraph>
        </DemoSection>

        <DemoSection Title="Colors & Context"
                     Code="@ColorsContextCode"
                     CodeLanguage="razor">
            <Div Space="Space.Y.Is1">
                <Paragraph>Colored: <Strong TextColor="TextColor.Primary">Primary</Strong> <Strong TextColor="TextColor.Accent">Success</Strong> <Strong TextColor="TextColor.Destructive">Danger</Strong></Paragraph>
                <Paragraph>Important: <Strong>Please read the terms carefully.</Strong></Paragraph>
                <Paragraph>Success: <Strong TextColor="TextColor.Accent">Action completed successfully!</Strong></Paragraph>
            </Div>
        </DemoSection>

        <DemoSection Title="Product Info" Code="@(@"<Paragraph>Name: <Strong>Premium Widget Pro</Strong></Paragraph>")"
        CodeLanguage="razor">
            <Div>
                <Paragraph>Name: <Strong>Premium Widget Pro</Strong></Paragraph>
                <Paragraph>Price: <Strong TextColor="TextColor.Accent">$99.99</Strong></Paragraph>
                <Paragraph>Status: <Strong TextColor="TextColor.Primary">In Stock</Strong></Paragraph>
            </Div>
        </DemoSection>

        <DemoSection Title="Key Features" Code="@(@"<UnorderedListItem><Strong>High Performance:</Strong> Optimized for speed</UnorderedListItem>")"
        CodeLanguage="razor">
            <UnorderedList>
                <UnorderedListItem><Strong>High Performance:</Strong> Optimized for speed</UnorderedListItem>
                <UnorderedListItem><Strong>Secure:</Strong> Enterprise-grade security</UnorderedListItem>
                <UnorderedListItem><Strong>Support:</Strong> 24/7 customer support</UnorderedListItem>
            </UnorderedList>
        </DemoSection>

        <DemoSection Title="Strong vs Bold"
                     Code="@StrongVsBoldCode"
                     CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Paragraph><Strong>Strong (semantic):</Strong> Used for importance and emphasis.</Paragraph>
                <Paragraph><Span FontWeight="FontWeight.Bold">Bold (visual):</Span> Used for visual emphasis only.</Paragraph>
                <Paragraph TextColor="TextColor.MutedForeground">Strong is semantically meaningful for screen readers.</Paragraph>
            </Div>
        </DemoSection>
    </Div>
</Div>

@code {
    private const string ColorsContextCode =
@"<Paragraph>
    <Strong TextColor=""TextColor.Primary"">Primary</Strong>
    <Strong TextColor=""TextColor.Accent"">Success</Strong>
    <Strong TextColor=""TextColor.Destructive"">Danger</Strong>
</Paragraph>";

    private const string StrongVsBoldCode =
@"<Paragraph><Strong>Strong (semantic)</Strong> vs <Span FontWeight=""FontWeight.Bold"">Bold (visual)</Span></Paragraph>";
}
