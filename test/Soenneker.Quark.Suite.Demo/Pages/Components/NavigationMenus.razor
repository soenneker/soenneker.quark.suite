@page "/navigationmenus"

<PageTitle>Navigation Menu - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                        Description="A collection of links for navigating websites."
                        Code="@BasicCode"
                        PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                        CodeLanguage="razor">
                <NavigationMenu>
                    <NavigationMenuList Class="flex-nowrap gap-0">
                        <NavigationMenuItem>
                            <NavigationMenuTrigger>Getting started</NavigationMenuTrigger>
                            <NavigationMenuContent Motion="from-start">
                                <UnorderedList Class="w-96 list-none p-0">
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="components" Active="true">
                                            <Div Class="text-sm leading-none font-medium">Introduction</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">Re-usable components built with Tailwind CSS.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="installation">
                                            <Div Class="text-sm leading-none font-medium">Installation</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">How to install dependencies and structure your app.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="headings">
                                            <Div Class="text-sm leading-none font-medium">Typography</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">Styles for headings, paragraphs, lists...etc</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                </UnorderedList>
                            </NavigationMenuContent>
                        </NavigationMenuItem>

                        <NavigationMenuItem Class="hidden md:flex">
                            <NavigationMenuTrigger>Components</NavigationMenuTrigger>
                            <NavigationMenuContent Motion="from-end">
                                <UnorderedList Class="grid w-[500px] grid-cols-2 list-none p-0">
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="alert-dialogs">
                                            <Div Class="text-sm leading-none font-medium">Alert Dialog</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">A modal dialog that interrupts the user with important content and expects a response.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="hover-cards">
                                            <Div Class="text-sm leading-none font-medium">Hover Card</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">For sighted users to preview content available behind a link.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="progress">
                                            <Div Class="text-sm leading-none font-medium">Progress</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">Displays an indicator showing the completion progress of a task.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="scroll-areas">
                                            <Div Class="text-sm leading-none font-medium">Scroll-area</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">Visually or semantically separates content.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="tabs">
                                            <Div Class="text-sm leading-none font-medium">Tabs</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">A set of layered sections of content that are displayed one at a time.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="tooltips">
                                            <Div Class="text-sm leading-none font-medium">Tooltip</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">A popup that displays information related to an element.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                </UnorderedList>
                            </NavigationMenuContent>
                        </NavigationMenuItem>

                        <NavigationMenuItem>
                            <NavigationMenuLink Href="components" Class="@NavigationMenuTriggerLinkClass">
                                Docs
                            </NavigationMenuLink>
                        </NavigationMenuItem>
                    </NavigationMenuList>
                </NavigationMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Link Component"
                        Description="Use AsChild to compose a custom Quark link component."
                        Code="@LinkComponentCode"
                        CodeLanguage="razor">
                <Div Class="rounded-xl border border-border p-4">
                    <NavigationMenu Justify="Justify.Start">
                        <NavigationMenuList Justify="Justify.Start" Class="gap-0">
                            <NavigationMenuItem>
                                <NavigationMenuLink AsChild="true" Class="@NavigationMenuTriggerLinkClass">
                                    <Anchor To="components">
                                        <Span FontWeight="FontWeight.Medium">Documentation</Span>
                                    </Anchor>
                                </NavigationMenuLink>
                            </NavigationMenuItem>
                        </NavigationMenuList>
                    </NavigationMenu>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                        Description="Navigation menu content and viewport positioning respect right-to-left layouts."
                        Code="@RtlCode"
                        PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                        CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Div class="rounded-xl border border-border p-4 text-right">
                        <NavigationMenu Width="Width.IsFull" Justify="Justify.Start">
                            <NavigationMenuList Justify="Justify.Start" Class="gap-0">
                                <NavigationMenuItem>
                                    <NavigationMenuTrigger>البدء</NavigationMenuTrigger>
                                    <NavigationMenuContent Motion="from-start">
                                        <Div Class="grid w-96 gap-0">
                                            <NavigationMenuLink Href="components" Active="true">
                                                <Span FontWeight="FontWeight.Medium" Leading='Leading.Token("1")'>المكونات</Span>
                                                <Span TextColor="TextColor.MutedForeground">لبنات واجهة قابلة لإعادة الاستخدام.</Span>
                                            </NavigationMenuLink>
                                            <NavigationMenuLink Href="buttons">
                                                <Span FontWeight="FontWeight.Medium" Leading='Leading.Token("1")'>الأزرار</Span>
                                                <Span TextColor="TextColor.MutedForeground">أنماط متعددة للأسطح التفاعلية.</Span>
                                            </NavigationMenuLink>
                                        </Div>
                                    </NavigationMenuContent>
                                </NavigationMenuItem>
                                <NavigationMenuItem Class="hidden md:flex">
                                    <NavigationMenuTrigger>المكونات</NavigationMenuTrigger>
                                    <NavigationMenuContent Motion="from-end">
                                        <Div Class="grid w-[500px] grid-cols-2 gap-0">
                                            <NavigationMenuLink Href="alert-dialogs">
                                                <Span FontWeight="FontWeight.Medium" Leading='Leading.Token("1")'>مربع التنبيه</Span>
                                                <Span TextColor="TextColor.MutedForeground">مربع حوار مهم يتطلب استجابة من المستخدم.</Span>
                                            </NavigationMenuLink>
                                            <NavigationMenuLink Href="tabs">
                                                <Span FontWeight="FontWeight.Medium" Leading='Leading.Token("1")'>التبويبات</Span>
                                                <Span TextColor="TextColor.MutedForeground">أقسام طبقية تعرض محتوى واحدا في كل مرة.</Span>
                                            </NavigationMenuLink>
                                        </Div>
                                    </NavigationMenuContent>
                                </NavigationMenuItem>
                                <NavigationMenuItem>
                                    <NavigationMenuLink Href="components" Class="@NavigationMenuTriggerLinkClass">الوثائق</NavigationMenuLink>
                                </NavigationMenuItem>
                            </NavigationMenuList>
                        </NavigationMenu>
                    </Div>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string NavigationMenuTriggerLinkClass =
        "group inline-flex h-9 w-max flex-row items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium transition-[color,box-shadow] outline-none hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 data-[state=open]:bg-accent/50 data-[state=open]:text-accent-foreground data-[state=open]:hover:bg-accent data-[state=open]:focus:bg-accent";

