@page "/navigationmenus"

<PageTitle>Navigation Menu - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Navigation Menu"
                         Description="A collection of links for navigating websites."
                         Code="@BasicCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                         CodeLanguage="razor">
                <NavigationMenu>
                    <NavigationMenuList>
                        <NavigationMenuItem>
                            <NavigationMenuTrigger>Getting started</NavigationMenuTrigger>
                            <NavigationMenuContent>
                                <UnorderedList Class="grid w-full list-none gap-0 p-0 md:w-96">
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/docs" Active="true">
                                            <Div Class="text-sm leading-none font-medium">Introduction</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">Re-usable components built with Tailwind CSS.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/docs/installation">
                                            <Div Class="text-sm leading-none font-medium">Installation</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">How to install dependencies and structure your app.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/docs/primitives/typography">
                                            <Div Class="text-sm leading-none font-medium">Typography</Div>
                                            <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">Styles for headings, paragraphs, lists...etc</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                </UnorderedList>
                            </NavigationMenuContent>
                        </NavigationMenuItem>
                        <NavigationMenuItem>
                            <NavigationMenuLink Href="/docs" Class="@NavigationMenuTriggerLinkClass">
                                Docs
                            </NavigationMenuLink>
                        </NavigationMenuItem>
                    </NavigationMenuList>
                </NavigationMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Navigation menu content and viewport positioning respect right-to-left layouts."
                         Code="@RtlCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <NavigationMenu>
                        <NavigationMenuList>
                            <NavigationMenuItem>
                                <NavigationMenuTrigger>البدء</NavigationMenuTrigger>
                                <NavigationMenuContent>
                                    <UnorderedList Class="grid w-full list-none gap-0 p-0 md:w-96">
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="/docs" Active="true">
                                                <Div Class="text-sm leading-none font-medium">المقدمة</Div>
                                                <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">مكونات قابلة لإعادة الاستخدام مبنية باستخدام Tailwind CSS.</Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="/docs/installation">
                                                <Div Class="text-sm leading-none font-medium">التثبيت</Div>
                                                <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">كيفية تثبيت التبعيات وتنظيم التطبيق.</Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="/docs/primitives/typography">
                                                <Div Class="text-sm leading-none font-medium">الطباعة</Div>
                                                <Div Class="line-clamp-2 text-sm leading-snug text-muted-foreground">أنماط للعناوين والفقرات والقوائم.</Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                    </UnorderedList>
                                </NavigationMenuContent>
                            </NavigationMenuItem>
                            <NavigationMenuItem>
                                <NavigationMenuLink Href="/docs" Class="@NavigationMenuTriggerLinkClass">الوثائق</NavigationMenuLink>
                            </NavigationMenuItem>
                        </NavigationMenuList>
                    </NavigationMenu>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string NavigationMenuTriggerLinkClass =
        "gap-2 p-2 in-data-[slot=navigation-menu-content]:rounded-md data-active:bg-muted/50 data-active:hover:bg-muted data-active:focus:bg-muted [&_svg:not([class*='size-'])]:size-4 group/navigation-menu-trigger inline-flex h-9 w-max items-center justify-center rounded-lg px-2.5 py-1.5 text-sm font-medium transition-all outline-none hover:bg-muted focus:bg-muted focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 data-popup-open:bg-muted/50 data-popup-open:hover:bg-muted data-open:bg-muted/50 data-open:hover:bg-muted data-open:focus:bg-muted";

    private const string BasicCode =
@"<NavigationMenu>
