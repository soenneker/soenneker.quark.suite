@page "/components/navigation-menu"

<PageTitle>Navigation Menu - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Navigation Menu"
                         Description="A collection of links for navigating websites."
                         Code="@BasicCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                         CodeLanguage="razor">
                <NavigationMenu>
                    <NavigationMenuList>
                        <NavigationMenuItem>
                            <NavigationMenuTrigger>Getting started</NavigationMenuTrigger>
                            <NavigationMenuContent>
                                <ul class="grid w-full list-none gap-0 p-0 md:w-96">
                                    <li>
                                        <NavigationMenuLink Href="/docs">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Introduction</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">Re-usable components built with Tailwind CSS.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                    <li>
                                        <NavigationMenuLink Href="/docs/installation">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Installation</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">How to install dependencies and structure your app.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                    <li>
                                        <NavigationMenuLink Href="/docs/primitives/typography">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Typography</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">Styles for headings, paragraphs, lists...etc</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                </ul>
                            </NavigationMenuContent>
                        </NavigationMenuItem>
                        <NavigationMenuItem Class="hidden md:flex">
                            <NavigationMenuTrigger>Components</NavigationMenuTrigger>
                            <NavigationMenuContent>
                                <ul class="grid w-[400px] list-none gap-2 p-0 md:w-[500px] md:grid-cols-2 lg:w-[600px]">
                                    <li>
                                        <NavigationMenuLink Href="/docs/primitives/alert-dialog">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Alert Dialog</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">A modal dialog that interrupts the user with important content and expects a response.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                    <li>
                                        <NavigationMenuLink Href="/docs/primitives/hover-card">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Hover Card</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">For sighted users to preview content available behind a link.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                    <li>
                                        <NavigationMenuLink Href="/docs/primitives/progress">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Progress</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">Displays an indicator showing the completion progress of a task, typically displayed as a progress bar.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                    <li>
                                        <NavigationMenuLink Href="/docs/primitives/scroll-area">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Scroll-area</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">Visually or semantically separates content.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                    <li>
                                        <NavigationMenuLink Href="/docs/primitives/tabs">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Tabs</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">A set of layered sections of content—known as tab panels—that are displayed one at a time.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                    <li>
                                        <NavigationMenuLink Href="/docs/primitives/tooltip">
                                            <Div Class="flex flex-col gap-1 text-sm">
                                                <Div Leading="Leading.None" FontWeight="FontWeight.Medium">Tooltip</Div>
                                                <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">A popup that displays information related to an element when the element receives keyboard focus or the mouse hovers over it.</Div>
                                            </Div>
                                        </NavigationMenuLink>
                                    </li>
                                </ul>
                            </NavigationMenuContent>
                        </NavigationMenuItem>
                        <NavigationMenuItem>
                            <Anchor Href="/docs" data-slot="navigation-menu-link" Class="@NavigationMenuTriggerLinkClass">
                                Docs
                            </Anchor>
                        </NavigationMenuItem>
                    </NavigationMenuList>
                </NavigationMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Navigation menu content and viewport positioning respect right-to-left layouts."
                         Code="@RtlCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <NavigationMenu>
                        <NavigationMenuList>
                            <NavigationMenuItem>
                                <NavigationMenuTrigger>البدء</NavigationMenuTrigger>
                                <NavigationMenuContent>
                                    <ul class="grid w-full list-none gap-0 p-0 md:w-96">
                                        <li>
                                            <NavigationMenuLink Href="/docs">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">مقدمة</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">مكونات قابلة لإعادة الاستخدام مبنية باستخدام Tailwind CSS.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                        <li>
                                            <NavigationMenuLink Href="/docs/installation">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">التثبيت</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">كيفية تثبيت التبعيات وتنظيم تطبيقك.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                        <li>
                                            <NavigationMenuLink Href="/docs/primitives/typography">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">الطباعة</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">أنماط للعناوين والفقرات والقوائم...إلخ</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                    </ul>
                                </NavigationMenuContent>
                            </NavigationMenuItem>
                            <NavigationMenuItem Class="hidden md:flex">
                                <NavigationMenuTrigger>المكونات</NavigationMenuTrigger>
                                <NavigationMenuContent>
                                    <ul class="grid w-[400px] list-none gap-2 p-0 md:w-[500px] md:grid-cols-2 lg:w-[600px]">
                                        <li>
                                            <NavigationMenuLink Href="/docs/primitives/alert-dialog">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">حوار التنبيه</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">حوار نافذة يقطع المستخدم بمحتوى مهم ويتوقع استجابة.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                        <li>
                                            <NavigationMenuLink Href="/docs/primitives/hover-card">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">بطاقة التحويم</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">للمستخدمين المبصرين لمعاينة المحتوى المتاح خلف الرابط.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                        <li>
                                            <NavigationMenuLink Href="/docs/primitives/progress">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">التقدم</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">يعرض مؤشرًا يوضح تقدم إتمام المهمة، عادةً يتم عرضه كشريط تقدم.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                        <li>
                                            <NavigationMenuLink Href="/docs/primitives/scroll-area">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">منطقة التمرير</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">يفصل المحتوى بصريًا أو دلاليًا.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                        <li>
                                            <NavigationMenuLink Href="/docs/primitives/tabs">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">التبويبات</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">مجموعة من أقسام المحتوى المتعددة الطبقات—المعروفة بألواح التبويب—التي يتم عرضها واحدة في كل مرة.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                        <li>
                                            <NavigationMenuLink Href="/docs/primitives/tooltip">
                                                <Div Class="flex flex-col gap-1 text-sm">
                                                    <Div Leading="Leading.None" FontWeight="FontWeight.Medium">تلميح</Div>
                                                    <Div LineClamp="LineClamp.Two" TextColor="TextColor.MutedForeground">نافذة منبثقة تعرض معلومات متعلقة بعنصر عندما يتلقى العنصر التركيز على لوحة المفاتيح أو عند تحويم الماوس فوقه.</Div>
                                                </Div>
                                            </NavigationMenuLink>
                                        </li>
                                    </ul>
                                </NavigationMenuContent>
                            </NavigationMenuItem>
                            <NavigationMenuItem>
                                <Anchor Href="/docs" data-slot="navigation-menu-link" Class="@NavigationMenuTriggerLinkClass">الوثائق</Anchor>
                            </NavigationMenuItem>
                        </NavigationMenuList>
                    </NavigationMenu>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
