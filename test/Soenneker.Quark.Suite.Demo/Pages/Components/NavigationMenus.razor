                </ul>
            </NavigationMenuContent>
        </NavigationMenuItem>
        <NavigationMenuItem>
            <Anchor Href=""/docs"" data-slot=""navigation-menu-link"" Class=""@NavigationMenuTriggerLinkClass"">Docs</Anchor>
        </NavigationMenuItem>
    </NavigationMenuList>
</NavigationMenu>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
