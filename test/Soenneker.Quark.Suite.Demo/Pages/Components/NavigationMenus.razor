@page "/components/navigation-menu"

<PageTitle>Navigation Menu - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is5xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Navigation Menu"
                         Description="A collection of links for navigating websites."
                         Code="@BasicCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                         CodeLanguage="razor">
                <NavigationMenu>
                    <NavigationMenuList>
                        <NavigationMenuItem>
                            <NavigationMenuTrigger>Getting started</NavigationMenuTrigger>
                            <NavigationMenuContent>
                                <UnorderedList Class="grid w-full list-none gap-0 p-0 md:w-96">
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/docs" Active="true">
                                            <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">Introduction</Div>
                                            <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">Re-usable components built with Tailwind CSS.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/docs/installation">
                                            <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">Installation</Div>
                                            <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">How to install dependencies and structure your app.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/docs/primitives/typography">
                                            <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">Typography</Div>
                                            <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">Styles for headings, paragraphs, lists...etc</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                </UnorderedList>
                            </NavigationMenuContent>
                        </NavigationMenuItem>
                        <NavigationMenuItem>
                            <NavigationMenuTrigger>Components</NavigationMenuTrigger>
                            <NavigationMenuContent>
                                <UnorderedList Class="grid w-full list-none gap-0 p-0 md:w-96 md:grid-cols-2">
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/components/button">
                                            <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">Button</Div>
                                            <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">Displays a button or a component that looks like a button.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/dialog">
                                            <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">Dialog</Div>
                                            <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">A window overlaid on either the primary window or another dialog.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                    <UnorderedListItem>
                                        <NavigationMenuLink Href="/components/accordion">
                                            <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">Accordion</Div>
                                            <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">A vertically stacked set of interactive headings.</Div>
                                        </NavigationMenuLink>
                                    </UnorderedListItem>
                                </UnorderedList>
                            </NavigationMenuContent>
                        </NavigationMenuItem>
                        <NavigationMenuItem>
                            <NavigationMenuLink Href="/docs" Class="@NavigationMenuTriggerLinkClass">
                                Docs
                            </NavigationMenuLink>
                        </NavigationMenuItem>
                    </NavigationMenuList>
                </NavigationMenu>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Navigation menu content and viewport positioning respect right-to-left layouts."
                         Code="@RtlCode"
                         PreviewClass="preview relative flex w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0 h-96"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <NavigationMenu>
                        <NavigationMenuList>
                            <NavigationMenuItem>
                                <NavigationMenuTrigger>البدء</NavigationMenuTrigger>
                                <NavigationMenuContent>
                                    <UnorderedList Class="grid w-full list-none gap-0 p-0 md:w-96">
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="/docs" Active="true">
                                                <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">المقدمة</Div>
                                                <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">مكونات قابلة لإعادة الاستخدام مبنية باستخدام Tailwind CSS.</Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="/docs/installation">
                                                <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">التثبيت</Div>
                                                <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">كيفية تثبيت التبعيات وتنظيم التطبيق.</Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                        <UnorderedListItem>
                                            <NavigationMenuLink Href="/docs/primitives/typography">
                                                <Div TextSize="TextSize.Sm" Leading="Leading.None" FontWeight="FontWeight.Medium">الطباعة</Div>
                                                <Div LineClamp="LineClamp.Two" TextSize="TextSize.Sm" Leading="Leading.Snug" TextColor="TextColor.MutedForeground">أنماط للعناوين والفقرات والقوائم.</Div>
                                            </NavigationMenuLink>
                                        </UnorderedListItem>
                                    </UnorderedList>
                                </NavigationMenuContent>
                            </NavigationMenuItem>
                            <NavigationMenuItem>
                                <NavigationMenuLink Href="/docs" Class="@NavigationMenuTriggerLinkClass">الوثائق</NavigationMenuLink>
                            </NavigationMenuItem>
                        </NavigationMenuList>
                    </NavigationMenu>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string NavigationMenuTriggerLinkClass =
        "gap-2 p-2 in-data-[slot=navigation-menu-content]:rounded-md data-active:bg-muted/50 data-active:hover:bg-muted data-active:focus:bg-muted [&_svg:not([class*='size-'])]:size-4 group/navigation-menu-trigger inline-flex h-9 w-max items-center justify-center rounded-lg px-2.5 py-1.5 text-sm font-medium transition-all outline-none hover:bg-muted focus:bg-muted focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-1 disabled:pointer-events-none disabled:opacity-50 data-popup-open:bg-muted/50 data-popup-open:hover:bg-muted data-open:bg-muted/50 data-open:hover:bg-muted data-open:focus:bg-muted";

