@page "/native-selects"

<PageTitle>Native Select - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Basic"
                         Description="A styled native HTML select element with browser-native option behavior."
                         Code="@BasicCode"
                         CodeLanguage="razor">
                <NativeSelect data-testid="native-select-basic">
                    <NativeSelectOption Value="">Select a fruit</NativeSelectOption>
                    <NativeSelectOption Value="apple">Apple</NativeSelectOption>
                    <NativeSelectOption Value="banana">Banana</NativeSelectOption>
                    <NativeSelectOption Value="blueberry">Blueberry</NativeSelectOption>
                    <NativeSelectOption Value="grapes" Disabled="true">Grapes</NativeSelectOption>
                    <NativeSelectOption Value="pineapple">Pineapple</NativeSelectOption>
                </NativeSelect>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Groups"
                         Description="Use native option groups to organize related choices."
                         Code="@GroupsCode"
                         CodeLanguage="razor">
                <NativeSelect @bind-Value="_food" data-testid="native-select-groups">
                    <NativeSelectOption Value="">Select a food</NativeSelectOption>
                    <NativeSelectOptGroup Label="Fruits">
                        <NativeSelectOption Value="apple">Apple</NativeSelectOption>
                        <NativeSelectOption Value="banana">Banana</NativeSelectOption>
                        <NativeSelectOption Value="blueberry">Blueberry</NativeSelectOption>
                    </NativeSelectOptGroup>
                    <NativeSelectOptGroup Label="Vegetables">
                        <NativeSelectOption Value="carrot">Carrot</NativeSelectOption>
                        <NativeSelectOption Value="broccoli">Broccoli</NativeSelectOption>
                        <NativeSelectOption Value="spinach">Spinach</NativeSelectOption>
                    </NativeSelectOptGroup>
                </NativeSelect>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Sizes"
                         Description="Use the size option for compact or default height controls."
                         Code="@SizesCode"
                         CodeLanguage="razor">
                <Div Class="flex flex-col gap-4">
                    <NativeSelect Size="NativeSelectSize.Sm" data-testid="native-select-size-sm">
                        <NativeSelectOption Value="">Select a fruit</NativeSelectOption>
                        <NativeSelectOption Value="apple">Apple</NativeSelectOption>
                        <NativeSelectOption Value="banana">Banana</NativeSelectOption>
                        <NativeSelectOption Value="blueberry">Blueberry</NativeSelectOption>
                    </NativeSelect>
                    <NativeSelect Size="NativeSelectSize.Default" data-testid="native-select-size-default">
                        <NativeSelectOption Value="">Select a fruit</NativeSelectOption>
                        <NativeSelectOption Value="apple">Apple</NativeSelectOption>
                        <NativeSelectOption Value="banana">Banana</NativeSelectOption>
                        <NativeSelectOption Value="blueberry">Blueberry</NativeSelectOption>
                    </NativeSelect>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="With Field"
                         Description="Compose NativeSelect with Field for labels and descriptions."
                         Code="@FieldCode"
                         CodeLanguage="razor">
                <Field>
                    <FieldLabel For="native-select-country">Country</FieldLabel>
                    <NativeSelect Id="native-select-country" data-testid="native-select-country">
                        <NativeSelectOption Value="">Select a country</NativeSelectOption>
                        <NativeSelectOption Value="us">United States</NativeSelectOption>
                        <NativeSelectOption Value="uk">United Kingdom</NativeSelectOption>
                        <NativeSelectOption Value="ca">Canada</NativeSelectOption>
                        <NativeSelectOption Value="au">Australia</NativeSelectOption>
                    </NativeSelect>
                    <FieldDescription>Select your country of residence.</FieldDescription>
                </Field>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled"
                         Description="Disabled selects keep the value visible without allowing changes."
                         Code="@DisabledCode"
                         CodeLanguage="razor">
                <NativeSelect Disabled="true" data-testid="native-select-disabled">
                    <NativeSelectOption Value="">Disabled</NativeSelectOption>
                    <NativeSelectOption Value="apple">Apple</NativeSelectOption>
                    <NativeSelectOption Value="banana">Banana</NativeSelectOption>
                    <NativeSelectOption Value="blueberry">Blueberry</NativeSelectOption>
                </NativeSelect>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid"
                         Description="Use the invalid state when the current selection needs correction."
                         Code="@InvalidCode"
                         CodeLanguage="razor">
                <NativeSelect aria-invalid="true" data-testid="native-select-invalid">
                    <NativeSelectOption Value="">Error state</NativeSelectOption>
                    <NativeSelectOption Value="apple">Apple</NativeSelectOption>
                    <NativeSelectOption Value="banana">Banana</NativeSelectOption>
                    <NativeSelectOption Value="blueberry">Blueberry</NativeSelectOption>
                </NativeSelect>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Native selects inherit direction from the surrounding container."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <Div dir="rtl" MaxWidth="MaxWidth.IsSm">
                    <NativeSelect data-testid="native-select-rtl">
                        <NativeSelectOption Value="">اختر الفاكهة</NativeSelectOption>
                        <NativeSelectOption Value="apple">تفاح</NativeSelectOption>
                        <NativeSelectOption Value="banana">موز</NativeSelectOption>
                        <NativeSelectOption Value="blueberry">توت</NativeSelectOption>
                    </NativeSelect>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _food;

    private const string BasicCode =
@"<NativeSelect>
    <NativeSelectOption Value="""">Select a fruit</NativeSelectOption>
    <NativeSelectOption Value=""apple"">Apple</NativeSelectOption>
    <NativeSelectOption Value=""banana"">Banana</NativeSelectOption>
    <NativeSelectOption Value=""blueberry"">Blueberry</NativeSelectOption>
    <NativeSelectOption Value=""grapes"" Disabled=""true"">Grapes</NativeSelectOption>
    <NativeSelectOption Value=""pineapple"">Pineapple</NativeSelectOption>
</NativeSelect>";

    private const string GroupsCode =
