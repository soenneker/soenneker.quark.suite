@page "/native-selects"

<PageTitle>Native Select - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo" Description="Simple native select control with binding."
                        Code="@BasicCode"
CodeLanguage="razor">
                <Div Display="Display.Flex" ItemsAlign="Items.Center" Gap="Gap.Is4">
                    <NativeSelect @bind-Value="_fruit">
                        <NativeSelectOption Value="">Select a fruit...</NativeSelectOption>
                        <NativeSelectOption Value="apple">Apple</NativeSelectOption>
                        <NativeSelectOption Value="banana">Banana</NativeSelectOption>
                        <NativeSelectOption Value="blueberry">Blueberry</NativeSelectOption>
                    </NativeSelect>
                    <Span TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">Selected: @(_fruit ?? "(none)")</Span>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Groups" Description="Use option groups to organize long lists."
                        Code="@GroupsCode"
CodeLanguage="razor">
                <NativeSelect @bind-Value="_animal">
                    <NativeSelectOption Value="">Select an animal...</NativeSelectOption>
                    <NativeSelectOptGroup Label="Mammals">
                        <NativeSelectOption Value="cat">Cat</NativeSelectOption>
                        <NativeSelectOption Value="dog">Dog</NativeSelectOption>
                    </NativeSelectOptGroup>
                    <NativeSelectOptGroup Label="Birds">
                        <NativeSelectOption Value="eagle">Eagle</NativeSelectOption>
                        <NativeSelectOption Value="parrot">Parrot</NativeSelectOption>
                    </NativeSelectOptGroup>
                </NativeSelect>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Disabled" Description="Small size and disabled state."
                        Code="@DisabledCode"
CodeLanguage="razor">
                <Div Space="Space.Y.Is3">
                    <NativeSelect Size="NativeSelectSize.Sm" @bind-Value="_sizeDemo">
                        <NativeSelectOption Value="">Small size</NativeSelectOption>
                        <NativeSelectOption Value="one">Option one</NativeSelectOption>
                    </NativeSelect>
                    <NativeSelect Disabled="true" Value="">
                        <NativeSelectOption Value="">Disabled select</NativeSelectOption>
                    </NativeSelect>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Invalid" Description="Use a destructive border and supporting copy when the current selection needs correction."
                        Code="@InvalidCode"
CodeLanguage="razor">
                <Div Space="Space.Y.Is2">
                    <NativeSelect Value="" aria-invalid="true">
                        <NativeSelectOption Value="">Select a plan...</NativeSelectOption>
                        <NativeSelectOption Value="starter">Starter</NativeSelectOption>
                        <NativeSelectOption Value="pro">Pro</NativeSelectOption>
                    </NativeSelect>
                    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.Destructive">Please choose a plan before continuing.</Paragraph>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string? _fruit;
    private string? _animal;
    private string? _sizeDemo;

    private const string BasicCode =
@"<Div Display=""Display.Flex"" ItemsAlign=""Items.Center"" Gap=""Gap.Is4"">
    <NativeSelect @bind-Value=""_fruit"">
        <NativeSelectOption Value="""">Select a fruit...</NativeSelectOption>
        <NativeSelectOption Value=""apple"">Apple</NativeSelectOption>
        <NativeSelectOption Value=""banana"">Banana</NativeSelectOption>
        <NativeSelectOption Value=""blueberry"">Blueberry</NativeSelectOption>
    </NativeSelect>
    <Span TextSize=""TextSize.Sm"" TextColor=""TextColor.MutedForeground"">Selected: @(_fruit ?? ""(none)"")</Span>
</Div>";

    private const string GroupsCode =
@"<NativeSelect @bind-Value=""_animal"">
    <NativeSelectOption Value="""">Select an animal...</NativeSelectOption>
    <NativeSelectOptGroup Label=""Mammals"">
        <NativeSelectOption Value=""cat"">Cat</NativeSelectOption>
        <NativeSelectOption Value=""dog"">Dog</NativeSelectOption>
    </NativeSelectOptGroup>
    <NativeSelectOptGroup Label=""Birds"">
        <NativeSelectOption Value=""eagle"">Eagle</NativeSelectOption>
        <NativeSelectOption Value=""parrot"">Parrot</NativeSelectOption>
    </NativeSelectOptGroup>
</NativeSelect>";

    private const string DisabledCode =
@"<Div Space=""Space.Y.Is3"">
    <NativeSelect Size=""NativeSelectSize.Sm"" @bind-Value=""_sizeDemo"">
        <NativeSelectOption Value="""">Small size</NativeSelectOption>
        <NativeSelectOption Value=""one"">Option one</NativeSelectOption>
    </NativeSelect>
    <NativeSelect Disabled=""true"" Value="""">
        <NativeSelectOption Value="""">Disabled select</NativeSelectOption>
    </NativeSelect>
</Div>";

private const string InvalidCode =
@"<Div Space=""Space.Y.Is2"">
    <NativeSelect Value="""" aria-invalid=""true"">
        <NativeSelectOption Value="""">Select a plan...</NativeSelectOption>
        <NativeSelectOption Value=""starter"">Starter</NativeSelectOption>
        <NativeSelectOption Value=""pro"">Pro</NativeSelectOption>
    </NativeSelect>
    <Paragraph TextSize=""TextSize.Sm"" TextColor=""TextColor.Destructive"">Please choose a plan before continuing.</Paragraph>
</Div>";
}
