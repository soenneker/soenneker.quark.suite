@page "/prompt-inputs"

<PageTitle>Prompt Input - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Section Space="Space.Y.Is4">
        <DemoSection
                     Description="A flexible, composable input component for building chat interfaces. Includes an auto-resizing textarea with scroll support and customizable action slots for buttons like send, attach, and more."
                     Code="@BasicCode"
                     CodeLanguage="razor"
                     PreviewClass="preview relative flex min-h-[28rem] w-full justify-center p-10 data-[align=center]:items-start">
            <Div>
                <PromptInput OnSubmit="SubmitPrompt" style="width: 226px;">
                    <PromptInputTextarea @bind-Value="_prompt" Disabled="@_isLoading" />
                    <PromptInputFooter>
                        <PromptInputTools>
                            <PromptInputButton>
                                <Button Type="ButtonType.Button" Size="ButtonSize.IconSm" Variant="ButtonVariant.Ghost" Class="cursor-pointer rounded-full text-secondary-foreground active:scale-97 disabled:opacity-70 hover:dark:bg-secondary" aria-label="Add attachment">
                                    <Icon Name="LucideIcon.Plus" />
                                </Button>
                            </PromptInputButton>
                        </PromptInputTools>
                        <PromptInputTools>
                            <PromptInputSubmit Disabled="@(!_isLoading && string.IsNullOrWhiteSpace(_prompt))"
                                               Loading="@_isLoading"
                                               Class="cursor-pointer rounded-full active:scale-97 disabled:opacity-70" />
                        </PromptInputTools>
                    </PromptInputFooter>
                </PromptInput>
            </Div>
        </DemoSection>
    </Section>
</Div>

@code {
    private string? _prompt;
    private bool _isLoading;

    private async Task SubmitPrompt(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        _prompt = null;
        _isLoading = true;
        await Task.Delay(2500);
        _isLoading = false;
    }

    private const string BasicCode =
@"<PromptInput OnSubmit=""SubmitPrompt"" style=""width: 226px;"">
    <PromptInputTextarea @bind-Value=""_prompt"" Disabled=""@_isLoading"" />
    <PromptInputFooter>
        <PromptInputTools>
            <PromptInputButton>
                <Button Type=""ButtonType.Button"" Size=""ButtonSize.IconSm"" Variant=""ButtonVariant.Ghost"" Class=""cursor-pointer rounded-full text-secondary-foreground active:scale-97 disabled:opacity-70 hover:dark:bg-secondary"" aria-label=""Add attachment"">
                    <Icon Name=""LucideIcon.Plus"" />
                </Button>
            </PromptInputButton>
        </PromptInputTools>
        <PromptInputTools>
            <PromptInputSubmit Disabled=""@(!_isLoading && string.IsNullOrWhiteSpace(_prompt))"" Loading=""@_isLoading"" Class=""cursor-pointer rounded-full active:scale-97 disabled:opacity-70"" />
        </PromptInputTools>
    </PromptInputFooter>
</PromptInput>";
}
