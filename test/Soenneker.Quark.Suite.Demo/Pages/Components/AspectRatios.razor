@page "/aspect-ratios"

<PageTitle>Aspect Ratio - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Landscape media"
                         Description="Adapted from the shadcn aspect-ratio demo using a 16:9 frame for wide content."
                         Code="@LandscapeCode">
                <AspectRatioBox Ratio="16.0 / 9.0" Class="overflow-hidden rounded-xl border bg-muted">
                    <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=1200&amp;q=80"
                         alt="Landscape sample"
                         class="h-full w-full object-cover dark:brightness-[0.65] dark:grayscale" />
                </AspectRatioBox>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Square thumbnail" Description="Use a 1:1 ratio for avatars, cards, and gallery thumbnails.">
                <Div Class="max-w-xs">
                    <AspectRatioBox Ratio="1" Class="overflow-hidden rounded-xl border bg-muted">
                        <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=800&amp;q=80"
                             alt="Square sample"
                             class="h-full w-full object-cover" />
                    </AspectRatioBox>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Portrait frame" Description="Portrait ratios work well for mobile previews and editorial imagery.">
                <Div Class="max-w-[18rem]">
                    <AspectRatioBox Ratio="9.0 / 16.0" Class="overflow-hidden rounded-xl border bg-muted">
                        <img src="https://images.unsplash.com/photo-1494526585095-c41746248156?w=900&amp;q=80"
                             alt="Portrait sample"
                             class="h-full w-full object-cover" />
                    </AspectRatioBox>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string LandscapeCode =
@"<AspectRatioBox Ratio=""16.0 / 9.0"" Class=""overflow-hidden rounded-xl border bg-muted"">
    <img src=""https://images.unsplash.com/..."" alt=""Landscape sample"" class=""h-full w-full object-cover"" />
</AspectRatioBox>";
}
