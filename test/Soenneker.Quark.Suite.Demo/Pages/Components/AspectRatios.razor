@page "/aspect-ratios"

<PageTitle>Aspect Ratio - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection
                         Description="Displays content within a desired ratio."
                         Code="@LandscapeCode"
                         CodeLanguage="razor">
                <Div Id="aspect-ratio-landscape-demo" Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                    <Soenneker.Quark.Components.Layout.AspectRatio Ratio="16.0 / 9.0" Class="rounded-lg bg-muted">
                        <Image Source="https://avatar.vercel.sh/shadcn1"
                               Alt="Photo"
                               Width="Width.IsFull"
                               Height="Height.IsFull"
                               Rounded="Rounded.Lg"
                               Class="object-cover grayscale dark:brightness-20" />
                    </Soenneker.Quark.Components.Layout.AspectRatio>
                </Div>
            </DemoSection>
        </Section>
<Section Space="Space.Y.Is4">
            <DemoSection Title="Square"
                         Description="A square aspect ratio component using the ratio={1 / 1} prop. This is useful for displaying images in a square format."
                         Code="@SquareCode"
                         CodeLanguage="razor">
                <Div Width="Width.IsFull" MaxWidth='MaxWidth.Token("[12rem]")'>
                    <Div Id="aspect-ratio-square-demo" Width="Width.IsFull">
                        <Soenneker.Quark.Components.Layout.AspectRatio Ratio="1" Class="rounded-lg bg-muted">
                            <Image Source="https://avatar.vercel.sh/shadcn1"
                                   Alt="Photo"
                                   Width="Width.IsFull"
                                   Height="Height.IsFull"
                                   Rounded="Rounded.Lg"
                                   Class="object-cover grayscale dark:brightness-20" />
                        </Soenneker.Quark.Components.Layout.AspectRatio>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Portrait"
                         Description="A portrait aspect ratio component using the ratio={9 / 16} prop. This is useful for displaying images in a portrait format."
                         Code="@PortraitCode"
                         CodeLanguage="razor">
                <Div Width="Width.IsFull" MaxWidth='MaxWidth.Token("[10rem]")'>
                    <Div Id="aspect-ratio-portrait-demo" Width="Width.IsFull">
                        <Soenneker.Quark.Components.Layout.AspectRatio Ratio="9.0 / 16.0" Class="rounded-lg bg-muted">
                            <Image Source="https://avatar.vercel.sh/shadcn1"
                                   Alt="Photo"
                                   Width="Width.IsFull"
                                   Height="Height.IsFull"
                                   Rounded="Rounded.Lg"
                                   Class="object-cover grayscale dark:brightness-20" />
                        </Soenneker.Quark.Components.Layout.AspectRatio>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Aspect ratio preserves layout in right-to-left direction."
                         Code="@RtlCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <Figure Width="Width.IsFull" MaxWidth="MaxWidth.IsSm">
                        <Soenneker.Quark.Components.Layout.AspectRatio Ratio="16.0 / 9.0" Class="rounded-lg bg-muted">
                            <Image Source="https://avatar.vercel.sh/shadcn1"
                                   Alt="Photo"
                                   Width="Width.IsFull"
                                   Height="Height.IsFull"
                                   Rounded="Rounded.Lg"
                                   Class="object-cover grayscale dark:brightness-20" />
                        </Soenneker.Quark.Components.Layout.AspectRatio>
                        <Figcaption Margin="Margin.Is2.FromTop" TextAlign="TextAlign.Center" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                            منظر طبيعي جميل
                        </Figcaption>
                    </Figure>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string LandscapeCode =
@"<Soenneker.Quark.Components.Layout.AspectRatio Ratio=""16.0 / 9.0"" Class=""rounded-lg bg-muted"">
    <Image Source=""https://avatar.vercel.sh/shadcn1"" Alt=""Photo"" Width=""Width.IsFull"" Height=""Height.IsFull"" Rounded=""Rounded.Lg"" Class=""object-cover grayscale dark:brightness-20"" />
</Soenneker.Quark.Components.Layout.AspectRatio>";

    private const string SquareCode =
@"<Div Width=""Width.IsFull"" MaxWidth='MaxWidth.Token(""[12rem]"")'>
    <Soenneker.Quark.Components.Layout.AspectRatio Ratio=""1"" Class=""rounded-lg bg-muted"">
        <Image Source=""https://avatar.vercel.sh/shadcn1"" Alt=""Photo"" Width=""Width.IsFull"" Height=""Height.IsFull"" Rounded=""Rounded.Lg"" Class=""object-cover grayscale dark:brightness-20"" />
    </Soenneker.Quark.Components.Layout.AspectRatio>
</Div>";

    private const string PortraitCode =
@"<Div Width=""Width.IsFull"" MaxWidth='MaxWidth.Token(""[10rem]"")'>
    <Soenneker.Quark.Components.Layout.AspectRatio Ratio=""9.0 / 16.0"" Class=""rounded-lg bg-muted"">
        <Image Source=""https://avatar.vercel.sh/shadcn1"" Alt=""Photo"" Width=""Width.IsFull"" Height=""Height.IsFull"" Rounded=""Rounded.Lg"" Class=""object-cover grayscale dark:brightness-20"" />
    </Soenneker.Quark.Components.Layout.AspectRatio>
</Div>";

    private const string RtlCode =
@"<DirectionProvider Dir=""rtl"">
    <Figure Width=""Width.IsFull"" MaxWidth=""MaxWidth.IsSm"">
        <Soenneker.Quark.Components.Layout.AspectRatio Ratio=""16.0 / 9.0"" Class=""rounded-lg bg-muted"">
            <Image Source=""https://avatar.vercel.sh/shadcn1"" Alt=""Photo"" Width=""Width.IsFull"" Height=""Height.IsFull"" Rounded=""Rounded.Lg"" Class=""object-cover grayscale dark:brightness-20"" />
        </Soenneker.Quark.Components.Layout.AspectRatio>
        <Figcaption Margin=""Margin.Is2.FromTop"" TextAlign=""TextAlign.Center"" TextSize=""TextSize.Sm"" TextColor=""TextColor.MutedForeground"">
            منظر طبيعي جميل
        </Figcaption>
    </Figure>
</DirectionProvider>";
}
