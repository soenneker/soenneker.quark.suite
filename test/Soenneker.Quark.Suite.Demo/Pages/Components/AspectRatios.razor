@page "/aspect-ratios"

<PageTitle>Aspect Ratio - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Use a 16:9 frame for wide content."
                         Code="@LandscapeCode"
                         CodeLanguage="razor">
                <Div Id="aspect-ratio-landscape-demo" Width="Width.IsFull" MaxWidth="MaxWidth.Is3xl">
                    <Soenneker.Quark.Components.Layout.AspectRatio Ratio="16.0 / 9.0" Class="rounded-lg bg-muted">
                        <Image Source="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=1200&amp;q=80"
                               Alt="Photo by Drew Beamer"
                               Width="Width.IsFull"
                               Height="Height.IsFull"
                               Rounded="Rounded.Lg"
                               Class="object-cover dark:brightness-[0.2] dark:grayscale" />
                    </Soenneker.Quark.Components.Layout.AspectRatio>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Alternative square and portrait ratios beyond the shadcn-equivalent reference demo.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Square"
                         Description="Use a 1:1 ratio for avatars, cards, and gallery thumbnails."
                         Code="@SquareCode"
                         CodeLanguage="razor">
                <Div Width="Width.IsFull" MaxWidth="MaxWidth.IsXs">
                    <Div Id="aspect-ratio-square-demo" Width="Width.IsFull">
                        <Soenneker.Quark.Components.Layout.AspectRatio Ratio="1" Class="overflow-hidden rounded-xl border bg-muted">
                            <Image Source="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=800&amp;q=80"
                                   Alt="Square sample"
                                   Width="Width.IsFull"
                                   Height="Height.IsFull"
                                   Class="object-cover" />
                        </Soenneker.Quark.Components.Layout.AspectRatio>
                    </Div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Portrait"
                         Description="Portrait ratios work well for mobile previews and editorial imagery."
                         Code="@PortraitCode"
                         CodeLanguage="razor">
                <Div Width="Width.IsFull" MaxWidth='MaxWidth.Token("[18rem]")'>
                    <Div Id="aspect-ratio-portrait-demo" Width="Width.IsFull">
                        <Soenneker.Quark.Components.Layout.AspectRatio Ratio="9.0 / 16.0" Class="overflow-hidden rounded-xl border bg-muted">
                            <Image Source="https://images.unsplash.com/photo-1494526585095-c41746248156?w=900&amp;q=80"
                                   Alt="Portrait sample"
                                   Width="Width.IsFull"
                                   Height="Height.IsFull"
                                   Class="object-cover" />
                        </Soenneker.Quark.Components.Layout.AspectRatio>
                    </Div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string LandscapeCode =
@"<Soenneker.Quark.Components.Layout.AspectRatio Ratio=""16.0 / 9.0"" Class=""rounded-lg bg-muted"">
    <Image Source=""https://images.unsplash.com/..."" Alt=""Photo by Drew Beamer"" Width=""Width.IsFull"" Height=""Height.IsFull"" Rounded=""Rounded.Lg"" Class=""object-cover dark:brightness-[0.2] dark:grayscale"" />
</Soenneker.Quark.Components.Layout.AspectRatio>";

    private const string SquareCode =
@"<Soenneker.Quark.Components.Layout.AspectRatio Ratio=""1"" Class=""overflow-hidden rounded-xl border bg-muted"">
    <Image Source=""..."" Alt=""Square"" Width=""Width.IsFull"" Height=""Height.IsFull"" Class=""object-cover"" />
</Soenneker.Quark.Components.Layout.AspectRatio>";

    private const string PortraitCode =
@"<Soenneker.Quark.Components.Layout.AspectRatio Ratio=""9.0 / 16.0"" Class=""overflow-hidden rounded-xl border bg-muted"">
    <Image Source=""..."" Alt=""Portrait"" Width=""Width.IsFull"" Height=""Height.IsFull"" Class=""object-cover"" />
</Soenneker.Quark.Components.Layout.AspectRatio>";
}
