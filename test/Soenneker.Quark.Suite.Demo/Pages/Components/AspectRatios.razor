@page "/aspect-ratios"

<PageTitle>Aspect Ratio - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Title="Demo"
                         Description="Use a 16:9 frame for wide content."
                         Code="@LandscapeCode"
                         CodeLanguage="razor">
                <div id="aspect-ratio-landscape-demo" style="width:min(100%,48rem);">
                    <Soenneker.Quark.Components.Layout.AspectRatio Ratio="16.0 / 9.0" Class="rounded-lg bg-muted">
                        <img src="https://images.unsplash.com/photo-1588345921523-c2dcdb7f1dcd?w=1200&amp;q=80"
                             alt="Photo by Drew Beamer"
                             class="h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale" />
                    </Soenneker.Quark.Components.Layout.AspectRatio>
                </div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <Div Space="Space.Y.Is2">
                <H2 TextSize="TextSize.Xl" FontWeight="FontWeight.Semibold">Additional examples</H2>
                <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    Alternative square and portrait ratios beyond the shadcn-equivalent reference demo.
                </Paragraph>
            </Div>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Square"
                         Description="Use a 1:1 ratio for avatars, cards, and gallery thumbnails."
                         Code="@SquareCode"
                         CodeLanguage="razor">
                <Div Class="w-full max-w-xs">
                    <div id="aspect-ratio-square-demo" style="width:100%;">
                        <Soenneker.Quark.Components.Layout.AspectRatio Ratio="1" Class="overflow-hidden rounded-xl border bg-muted">
                            <img src="https://images.unsplash.com/photo-1519389950473-47ba0277781c?w=800&amp;q=80"
                                 alt="Square sample"
                                 class="h-full w-full object-cover" />
                        </Soenneker.Quark.Components.Layout.AspectRatio>
                    </div>
                </Div>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Portrait"
                         Description="Portrait ratios work well for mobile previews and editorial imagery."
                         Code="@PortraitCode"
                         CodeLanguage="razor">
                <Div Class="w-full max-w-[18rem]">
                    <div id="aspect-ratio-portrait-demo" style="width:100%;">
                        <Soenneker.Quark.Components.Layout.AspectRatio Ratio="9.0 / 16.0" Class="overflow-hidden rounded-xl border bg-muted">
                            <img src="https://images.unsplash.com/photo-1494526585095-c41746248156?w=900&amp;q=80"
                                 alt="Portrait sample"
                                 class="h-full w-full object-cover" />
                        </Soenneker.Quark.Components.Layout.AspectRatio>
                    </div>
                </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private const string LandscapeCode =
@"<Soenneker.Quark.Components.Layout.AspectRatio Ratio=""16.0 / 9.0"" Class=""rounded-lg bg-muted"">
    <img src=""https://images.unsplash.com/..."" alt=""Photo by Drew Beamer"" class=""h-full w-full rounded-lg object-cover dark:brightness-[0.2] dark:grayscale"" />
</Soenneker.Quark.Components.Layout.AspectRatio>";

    private const string SquareCode =
@"<Soenneker.Quark.Components.Layout.AspectRatio Ratio=""1"" Class=""overflow-hidden rounded-xl border bg-muted"">
    <img src=""..."" alt=""Square"" class=""h-full w-full object-cover"" />
</Soenneker.Quark.Components.Layout.AspectRatio>";

    private const string PortraitCode =
@"<Soenneker.Quark.Components.Layout.AspectRatio Ratio=""9.0 / 16.0"" Class=""overflow-hidden rounded-xl border bg-muted"">
    <img src=""..."" alt=""Portrait"" class=""h-full w-full object-cover"" />
</Soenneker.Quark.Components.Layout.AspectRatio>";
}
