    private const string ColumnDefinitionsCode =
@"private static readonly ColumnDefinitionRow[] ColumnDefinitions =
[
    new(""Name"", ""Name"", true, true),
    new(""Department"", ""Department"", true, true),
    new(""Email"", ""Email"", true, true),
