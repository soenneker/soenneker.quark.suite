        new("HireDate", "Hire Date", true, true),
        new("Status", "Status", true, true)
    ];

    private sealed record ColumnDefinitionRow(string Key, string Label, bool Sortable, bool Searchable);

    private Table? _basicTable;
    private List<Employee> _currentEmployees = [];

    private readonly TableOptions _basicTableOptions = new()
    {
