    private void TogglePaymentEmailSort()
    {
        _paymentSortAscending = _paymentSortAscending is null || !_paymentSortAscending.Value;
        _paymentPageIndex = 0;
    }

    private void PreviousPaymentPage()
    {
        if (CanPreviousPaymentPage)
            _paymentPageIndex--;
    }

    private void NextPaymentPage()
    {
        if (CanNextPaymentPage)
            _paymentPageIndex++;
    }

    private void SetPaymentStatusVisible(bool visible)
    {
        _showPaymentStatus = visible;
    }

    private void SetPaymentEmailVisible(bool visible)
    {
        _showPaymentEmail = visible;
    }

    private void SetPaymentAmountVisible(bool visible)
    {
        _showPaymentAmount = visible;
    }

    private void SetPaymentSelected(string id, bool selected)
    {
        if (selected)
            _selectedPaymentIds.Add(id);
        else
            _selectedPaymentIds.Remove(id);
    }

    private void SetPaymentPageSelected(bool selected)
    {
        foreach (var payment in VisiblePayments)
        {
            if (selected)
                _selectedPaymentIds.Add(payment.Id);
            else
                _selectedPaymentIds.Remove(payment.Id);
        }
    }

    private Dictionary<string, object>? GetPaymentRowAttributes(string id)
    {
        return _selectedPaymentIds.Contains(id)
            ? new Dictionary<string, object> { ["data-state"] = "selected" }
            : null;
    }

    private void SelectPaymentAction(string id)
    {
        _lastPaymentActionId = id;
    }

    private static string FormatPaymentAmount(decimal amount)
    {
        return $"${amount:N2}";
    }

    protected override async Task OnInitializedAsync()
    {
        // Initialize total records from the service
        _totalRecords = EmployeeService.GetTotalCount();
        Logger.LogInformation("TablesBasic: OnInitializedAsync - Initialized with {TotalRecords} total records", _totalRecords);

        // Test the service directly
        var testEmployees = EmployeeService.GetAllEmployees();
        Logger.LogInformation("TablesBasic: OnInitializedAsync - EmployeeService.GetAllEmployees() returned {Count} employees", testEmployees.Count);
    }

    private async Task OnInteraction(DataTableServerSideRequest serverSideRequest)
    {
        Logger.LogInformation("TablesBasic: OnInteraction called: basicTable is {IsNull}, Request: Start={Start}, Length={Length}", _basicTable == null ? "null" : "not null", serverSideRequest.Start, serverSideRequest.Length);
        
        // Log columns information if available
        if (serverSideRequest.Columns != null && serverSideRequest.Columns.Count > 0)
        {
            Logger.LogInformation("TablesBasic: Request includes {ColumnCount} columns:", serverSideRequest.Columns.Count);
            foreach (var column in serverSideRequest.Columns)
            {
                Logger.LogInformation("  Column: Data='{Data}', Name='{Name}', Searchable={Searchable}, Orderable={Orderable}", 
                    column.Data ?? "null", column.Name ?? "null", column.Searchable, column.Orderable);
            }
        }
        else
        {
            Logger.LogInformation("TablesBasic: Request has no columns information");
        }

        try
        {
            // Get filtered employees using the service
            var employees = await EmployeeService.GetFilteredEmployees(serverSideRequest);

            Logger.LogInformation("TablesBasic: EmployeeService returned {Count} employees", employees.Count);

            // Update the current employees list
            _currentEmployees = employees;

            _totalRecords = EmployeeService.GetFilteredCount(serverSideRequest);

            // Trigger UI update
            StateHasChanged();

            Logger.LogInformation("TablesBasic: Updated currentEmployees with {Count} records, totalRecords={TotalRecords}", _currentEmployees.Count, _totalRecords);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "TablesBasic: Error handling manual request: {Message}", ex.Message);
        }
    }

    private async Task HandleOrder(TableOrderEventArgs args)
    {
        Logger.LogInformation("Column '{Column}' sorted {Direction}", args.Column, args.Direction);
    }

    private async Task HandleInitialize()
    {
        Logger.LogInformation("Basic table initialized");
    }

