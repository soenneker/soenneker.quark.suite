    private const string ActionsTableCode =
@"<TableElement>
    <Thead>
        <Tr>
            <Th>Project</Th>
            <Th>Status</Th>
            <Th>Owner</Th>
            <Th TextAlign=""TextAlign.End"">Actions</Th>
        </Tr>
    </Thead>
    <Tbody>
        <Tr>
            <Td FontWeight=""FontWeight.Medium"">Design system</Td>
            <Td>Active</Td>
            <Td>Casey</Td>
            <Td TextAlign=""TextAlign.End"">
                <Dropdown RightAligned=""true"">
                    <DropdownToggle>Open</DropdownToggle>
                    <DropdownMenu>
                        <DropdownItem>View details</DropdownItem>
                        <DropdownItem>Edit</DropdownItem>
                        <DropdownDivider />
                        <DropdownItem Variant=""destructive"">Archive</DropdownItem>
                    </DropdownMenu>
