@page "/tablesbasic"

<PageTitle>Table - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is6">
        <Section Space="Space.Y.Is4">
            <DemoSection Description="A responsive table component."
                         Code="@BasicTableCode"
                         CodeLanguage="razor"
                         PreviewClass="preview relative flex h-[28rem] w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0"
                         PreviewInnerClass="mx-auto flex w-full max-w-full flex-col items-center justify-center [&_img]:mx-auto [&_img]:block [&_img]:max-h-72 [&_img]:max-w-full [&_img]:object-contain">
                @InvoiceTable
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Footer"
                         Description="Use a footer row to summarize table data."
                         Code="@FooterTableCode"
                         CodeLanguage="razor">
                <TableElement>
                    <TableCaption>A list of your recent invoices.</TableCaption>
                    <Thead>
                        <Tr>
                            <Th Width='Width.Token("[100px]")'>Invoice</Th>
                            <Th>Status</Th>
                            <Th>Method</Th>
                            <Th TextAlign='TextAlign.Token("right")'>Amount</Th>
                        </Tr>
                    </Thead>
                    <Tbody>
                        <Tr>
                            <Td FontWeight="FontWeight.Medium">INV001</Td>
                            <Td>Paid</Td>
                            <Td>Credit Card</Td>
                            <Td TextAlign='TextAlign.Token("right")'>$250.00</Td>
                        </Tr>
                        <Tr>
                            <Td FontWeight="FontWeight.Medium">INV002</Td>
                            <Td>Pending</Td>
                            <Td>PayPal</Td>
                            <Td TextAlign='TextAlign.Token("right")'>$150.00</Td>
                        </Tr>
                        <Tr>
                            <Td FontWeight="FontWeight.Medium">INV003</Td>
                            <Td>Unpaid</Td>
                            <Td>Bank Transfer</Td>
                            <Td TextAlign='TextAlign.Token("right")'>$350.00</Td>
                        </Tr>
                    </Tbody>
                    <TableFooter>
                        <Tr>
                            <Td Colspan="3">Total</Td>
                            <Td TextAlign='TextAlign.Token("right")'>$2,500.00</Td>
                        </Tr>
                    </TableFooter>
                </TableElement>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Actions"
                         Description="Add actions to a table row."
                         Code="@ActionsTableCode"
                         CodeLanguage="razor">
                <TableElement>
                    <Thead>
                        <Tr>
                            <Th>Product</Th>
                            <Th>Price</Th>
                            <Th TextAlign='TextAlign.Token("right")'>Actions</Th>
                        </Tr>
                    </Thead>
                    <Tbody>
                        @foreach (var product in Products)
                        {
                            <Tr>
                                <Td FontWeight="FontWeight.Medium">@product.Name</Td>
                                <Td>@product.Price</Td>
                                <Td TextAlign='TextAlign.Token("right")'>
                                    <Dropdown RightAligned="true">
                                        <DropdownToggle AsChild="true">
                                            <Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon">
                                                <Icon Name="LucideIcon.Ellipsis" />
                                                <Span Class="sr-only">Open menu</Span>
                                            </Button>
                                        </DropdownToggle>
                                        <DropdownMenu Class="min-w-32">
                                            <DropdownItem>Edit</DropdownItem>
                                            <DropdownItem>Duplicate</DropdownItem>
                                            <DropdownDivider />
                                            <DropdownItem Variant="destructive">Delete</DropdownItem>
                                        </DropdownMenu>
                                    </Dropdown>
                                </Td>
                            </Tr>
                        }
                    </Tbody>
                </TableElement>
            </DemoSection>
        </Section>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="RTL"
                         Description="Tables support right-to-left direction."
                         Code="@RtlTableCode"
                         CodeLanguage="razor">
                <DirectionProvider Dir="rtl">
                    <TableElement>
                        <TableCaption>قائمة بفواتيرك الأخيرة.</TableCaption>
                        <Thead>
                            <Tr>
                                <Th Width='Width.Token("[100px]")' TextAlign='TextAlign.Token("start")'>الفاتورة</Th>
                                <Th TextAlign='TextAlign.Token("start")'>الحالة</Th>
                                <Th TextAlign='TextAlign.Token("start")'>الطريقة</Th>
                                <Th TextAlign='TextAlign.Token("right")'>المبلغ</Th>
                            </Tr>
                        </Thead>
                        <Tbody>
                            @foreach (var invoice in ArabicInvoices)
                            {
                                <Tr>
                                    <Td FontWeight="FontWeight.Medium">@invoice.Id</Td>
                                    <Td>@invoice.Status</Td>
                                    <Td>@invoice.Method</Td>
                                    <Td TextAlign='TextAlign.Token("right")'>@invoice.Amount</Td>
                                </Tr>
                            }
                        </Tbody>
                        <TableFooter>
                            <Tr>
                                <Td Colspan="3">المجموع</Td>
                                <Td TextAlign='TextAlign.Token("right")'>$2,500.00</Td>
                            </Tr>
                        </TableFooter>
                    </TableElement>
                </DirectionProvider>
            </DemoSection>
        </Section>
    </Div>
</Div>

