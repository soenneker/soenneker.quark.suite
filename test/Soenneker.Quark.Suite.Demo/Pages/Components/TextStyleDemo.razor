@page "/textstyle-demo"

<PageTitle>Text Style - Quark Suite</PageTitle>

<Div Space="Space.Y.Is8" MaxWidth="MaxWidth.Is4xl">
    <Div Space="Space.Y.Is4">
        <DemoSection Title="Text Alignment" Description="TextAlign and inline style examples." Code="@(@"<Text TextAlign=""TextAlign.Start"" Display=""Display.Block"" Class=""rounded border p-2"">TextAlign.Start</Text>
<Text TextAlign=""TextAlign.Center"" Display=""Display.Block"" Class=""rounded border p-2"">TextAlign.Center</Text>
<Text TextAlign=""TextAlign.End"" Display=""Display.Block"" Class=""rounded border p-2"">TextAlign.End</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Div Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2" style="text-align: start;"><Text>Left aligned</Text></Div>
                <Div Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2" style="text-align: center;"><Text>Center aligned</Text></Div>
                <Div Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2" style="text-align: end;"><Text>Right aligned</Text></Div>
            </Div>
            <Div Margin="Margin.Is4.FromTop" Space="Space.Y.Is2">
                <Text TextAlign="TextAlign.Start" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">TextAlign.Start</Text>
                <Text TextAlign="TextAlign.Center" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">TextAlign.Center</Text>
                <Text TextAlign="TextAlign.End" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">TextAlign.End</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Transformation" Description="TextTransform.Lowercase, Uppercase, Capitalize." Code="@(@"<Text TextTransform=""TextTransform.Lowercase"" Display=""Display.Block"" Class=""rounded border p-2"">LOWERCASE TEXT</Text>
<Text TextTransform=""TextTransform.Uppercase"" Display=""Display.Block"" Class=""rounded border p-2"">uppercase text</Text>
<Text TextTransform=""TextTransform.Capitalize"" Display=""Display.Block"" Class=""rounded border p-2"">capitalize this text</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Text TextTransform="TextTransform.Lowercase" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">LOWERCASE TEXT</Text>
                <Text TextTransform="TextTransform.Uppercase" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">uppercase text</Text>
                <Text TextTransform="TextTransform.Capitalize" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">capitalize this text</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Styling & Wrapping" Description="MutedForeground, Semibold, Wrap, Truncate." Code="@(@"<Text TextColor=""TextColor.MutedForeground"" Display=""Display.Block"" Class=""rounded border p-2"">Muted text</Text>
<Text FontWeight=""FontWeight.Semibold"" Display=""Display.Block"" Class=""rounded border p-2"">Semibold text</Text>
<Text TextWrap=""TextWrap.Wrap"" Display=""Display.Block"" Class=""max-w-[200px] rounded border p-2"">Wrapping text...</Text>
<Text Truncate=""Truncate.Default"" Display=""Display.Block"" Class=""max-w-[200px] rounded border p-2"">Truncated text...</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Text TextColor="TextColor.MutedForeground" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">Muted text</Text>
                <Text FontWeight="FontWeight.Semibold" Display="Display.Block" Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">Semibold text</Text>
                <Text TextWrap="TextWrap.Wrap" Display="Display.Block" MaxWidth='MaxWidth.Token("[200px]")' Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">This text will wrap When it reaches the container width.</Text>
                <Text Truncate="Truncate.Default" Display="Display.Block" MaxWidth='MaxWidth.Token("[200px]")' Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">This text will truncate with ellipsis When it overflows.</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Combined with Components" Description="TextTransform on Button and Text in containers." Code="@(@"<Button TextTransform=""TextTransform.Uppercase"" Variant=""ButtonVariant.Default"">Uppercase Button</Button>
<Div Class=""rounded-lg border border-primary/30 bg-primary/10 p-4 text-center"">
    <Text TextAlign=""TextAlign.Center"">Centered text in styled container</Text>
</Div>")"
CodeLanguage="razor">
            <Button TextTransform="TextTransform.Uppercase" Variant="ButtonVariant.Default">Uppercase Button</Button>
            <Div Margin="Margin.Is4.FromTop" Rounded="Rounded.Lg" Border="Border.Is1" BorderColor='BorderColor.Token("primary/30")' BackgroundColor='BackgroundColor.Token("primary/10")' Padding="Padding.Is4" TextAlign="TextAlign.Center">
                <Text TextAlign="TextAlign.Center">Centered text in styled container</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Responsive & Fluent API" Description="Responsive alignment via Tailwind and split text utility groups." Code="@(@"<Text TextAlign=""TextAlign.Start"" Display=""Display.Block"" Class=""rounded border p-2 md:text-center"">Start on mobile, Center on tablet+</Text>
<Text TextColor=""TextColor.MutedForeground"" Truncate=""Truncate.Default"" Display=""Display.Block"" Class=""max-w-[200px] rounded border p-2"">Muted + Truncate</Text>")"
CodeLanguage="razor">
            <Div Space="Space.Y.Is2">
                <Text TextAlign="TextAlign.Start" Display="Display.Block" Class="rounded border p-2 md:text-center">Start on mobile, Center on tablet+</Text>
                <Text TextColor="TextColor.MutedForeground" Truncate="Truncate.Default" Display="Display.Block" MaxWidth='MaxWidth.Token("[200px]")' Rounded="Rounded.Default" Border="Border.Is1" Padding="Padding.Is2">Muted + Truncate</Text>
            </Div>
        </DemoSection>
    </Div>
</Div>
