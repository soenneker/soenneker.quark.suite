@page "/textstyle-demo"

<PageTitle>Text Style - Quark Suite</PageTitle>

<Div class="space-y-8 max-w-4xl">
    <Div class="space-y-4">
        <DemoSection Title="Text Alignment" Description="TextAlignment and inline style examples." Code="@(@"<Text TextAlignment=""TextAlignment.Start"" Display=""Display.Block"" Class=""rounded border p-2"">TextAlignment.Start</Text>
<Text TextAlignment=""TextAlignment.Center"" Display=""Display.Block"" Class=""rounded border p-2"">TextAlignment.Center</Text>
<Text TextAlignment=""TextAlignment.End"" Display=""Display.Block"" Class=""rounded border p-2"">TextAlignment.End</Text>")">
            <Div Class="space-y-2">
                <Div Class="rounded border p-2" style="text-align: start;"><Text>Left aligned</Text></Div>
                <Div Class="rounded border p-2" style="text-align: center;"><Text>Center aligned</Text></Div>
                <Div Class="rounded border p-2" style="text-align: end;"><Text>Right aligned</Text></Div>
            </Div>
            <Div Class="mt-4 space-y-2">
                <Text TextAlignment="TextAlignment.Start" Display="Display.Block" Class="rounded border p-2">TextAlignment.Start</Text>
                <Text TextAlignment="TextAlignment.Center" Display="Display.Block" Class="rounded border p-2">TextAlignment.Center</Text>
                <Text TextAlignment="TextAlignment.End" Display="Display.Block" Class="rounded border p-2">TextAlignment.End</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Transformation" Description="TextTransform.Lowercase, Uppercase, Capitalize." Code="@(@"<Text TextTransform=""TextTransform.Lowercase"" Display=""Display.Block"" Class=""rounded border p-2"">LOWERCASE TEXT</Text>
<Text TextTransform=""TextTransform.Uppercase"" Display=""Display.Block"" Class=""rounded border p-2"">uppercase text</Text>
<Text TextTransform=""TextTransform.Capitalize"" Display=""Display.Block"" Class=""rounded border p-2"">capitalize this text</Text>")">
            <Div Class="space-y-2">
                <Text TextTransform="TextTransform.Lowercase" Display="Display.Block" Class="rounded border p-2">LOWERCASE TEXT</Text>
                <Text TextTransform="TextTransform.Uppercase" Display="Display.Block" Class="rounded border p-2">uppercase text</Text>
                <Text TextTransform="TextTransform.Capitalize" Display="Display.Block" Class="rounded border p-2">capitalize this text</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Text Styling & Wrapping" Description="MutedForeground, Semibold, Wrap, Truncate." Code="@(@"<Text TextColor=""TextColor.MutedForeground"" Display=""Display.Block"" Class=""rounded border p-2"">Muted text</Text>
<Text FontWeight=""FontWeight.Semibold"" Display=""Display.Block"" Class=""rounded border p-2"">Semibold text</Text>
<Text TextWrap=""TextWrap.Wrap"" Display=""Display.Block"" Class=""max-w-[200px] rounded border p-2"">Wrapping text...</Text>
<Text Truncate=""Truncate.Default"" Display=""Display.Block"" Class=""max-w-[200px] rounded border p-2"">Truncated text...</Text>")">
            <Div Class="space-y-2">
                <Text TextColor="TextColor.MutedForeground" Display="Display.Block" Class="rounded border p-2">Muted text</Text>
                <Text FontWeight="FontWeight.Semibold" Display="Display.Block" Class="rounded border p-2">Semibold text</Text>
                <Text TextWrap="TextWrap.Wrap" Display="Display.Block" Class="max-w-[200px] rounded border p-2">This text will wrap When it reaches the container width.</Text>
                <Text Truncate="Truncate.Default" Display="Display.Block" Class="max-w-[200px] rounded border p-2">This text will truncate with ellipsis When it overflows.</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Combined with Components" Description="TextTransform on Button and Text in containers." Code="@(@"<Button TextTransform=""TextTransform.Uppercase"" Variant=""ButtonVariant.Default"">Uppercase Button</Button>
<Div Class=""rounded-lg border border-primary/30 bg-primary/10 p-4 text-center"">
    <Text TextAlignment=""TextAlignment.Center"">Centered text in styled container</Text>
</Div>")">
            <Button TextTransform="TextTransform.Uppercase" Variant="ButtonVariant.Default">Uppercase Button</Button>
            <Div Class="mt-4 rounded-lg border border-primary/30 bg-primary/10 p-4 text-center">
                <Text TextAlignment="TextAlignment.Center">Centered text in styled container</Text>
            </Div>
        </DemoSection>

        <DemoSection Title="Responsive & Fluent API" Description="Responsive alignment via Tailwind and split text utility groups." Code="@(@"<Text TextAlignment=""TextAlignment.Start"" Display=""Display.Block"" Class=""rounded border p-2 md:text-center"">Start on mobile, Center on tablet+</Text>
<Text TextColor=""TextColor.MutedForeground"" Truncate=""Truncate.Default"" Display=""Display.Block"" Class=""max-w-[200px] rounded border p-2"">Muted + Truncate</Text>")">
            <Div Class="space-y-2">
                <Text TextAlignment="TextAlignment.Start" Display="Display.Block" Class="rounded border p-2 md:text-center">Start on mobile, Center on tablet+</Text>
                <Text TextColor="TextColor.MutedForeground" Truncate="Truncate.Default" Display="Display.Block" Class="max-w-[200px] rounded border p-2">Muted + Truncate</Text>
            </Div>
        </DemoSection>
    </Div>
</Div>
