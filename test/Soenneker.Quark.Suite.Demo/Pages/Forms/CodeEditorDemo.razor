@page "/forms/code-editor"

<PageTitle>Code Editor - Quark Suite</PageTitle>

<Div Class="space-y-8 max-w-4xl">
    <Div Class="space-y-6">
        <DemoSection Title="CodeEditor" Description="Monaco-based editor with Language, Theme, WordWrap, Minimap, AutoHeight." Code="@(@"<CodeEditor @bind-Text=""_text""
    Language=""@_language""
    Theme=""@_theme""
    WordWrap=""@_wordWrap""
    Minimap=""@_minimap""
    AutoHeight=""@_autoHeight""/>")">
        <Div Class="grid gap-6 lg:grid-cols-[1fr_3fr]">
        <Div>
            <Card>
                <CardBody>
                    <H4>Options</H4>
                    <Div Margin="Margin.Is2.FromBottom">
                        <Label Form="true">Language</Label>
                        <Select TValue="string" SelectedValue="_language" SelectedValueChanged="v => _language = v">
                            <SelectItem ItemValue="@("csharp")">CSharp</SelectItem>
                            <SelectItem ItemValue="@("json")">JSON</SelectItem>
                            <SelectItem ItemValue="@("xml")">XML</SelectItem>
                            <SelectItem ItemValue="@("javascript")">JavaScript</SelectItem>
                            <SelectItem ItemValue="@("typescript")">TypeScript</SelectItem>
                            <SelectItem ItemValue="@("html")">HTML</SelectItem>
                            <SelectItem ItemValue="@("css")">CSS</SelectItem>
                            <SelectItem ItemValue="@("sql")">SQL</SelectItem>
                            <SelectItem ItemValue="@("yaml")">YAML</SelectItem>
                            <SelectItem ItemValue="@("markdown")">Markdown</SelectItem>
                        </Select>
                    </Div>

                    <Div Margin="Margin.Is2.FromBottom">
                        <Label Form="true">Theme</Label>
                        <Select TValue="string" SelectedValue="_theme" SelectedValueChanged="v => _theme = v">
                            <SelectItem ItemValue="@("auto")">auto (follow app)</SelectItem>
                            <SelectItem ItemValue="@("vs")">vs (light)</SelectItem>
                            <SelectItem ItemValue="@("vs-dark")">vs-dark</SelectItem>
                            <SelectItem ItemValue="@("hc-black")">hc-black</SelectItem>
                        </Select>
                    </Div>

                    <Div Margin="Margin.Is2.FromBottom">
                        <Check Checked="_wordWrap" CheckedChanged="v => _wordWrap = v">Word Wrap</Check>
                    </Div>
                    <Div Margin="Margin.Is2.FromBottom">
                        <Check Checked="_minimap" CheckedChanged="v => _minimap = v">Minimap</Check>
                    </Div>
                    <Div Margin="Margin.Is2.FromBottom">
                        <Check Checked="_autoHeight" CheckedChanged="v => _autoHeight = v">Auto Height</Check>
                    </Div>
                    @if (!_autoHeight)
                    {
                        <Div Margin="Margin.Is2.FromBottom">
                            <Label Form="true">Height (px)</Label>
                            <NumericEdit NumericValue="@((decimal)_editorHeight)" NumericValueChanged="v => _editorHeight = (int)v.GetValueOrDefault(300)" />
                        </Div>
                    }
                    else
                    {
                        <Div Margin="Margin.Is2.FromBottom">
                            <Label Form="true">Min Lines</Label>
                            <NumericEdit NumericValue="@((decimal?)_minLines)" NumericValueChanged="v => _minLines = (int?)v" />
                        </Div>
                        <Div Margin="Margin.Is2.FromBottom">
                            <Label Form="true">Max Lines</Label>
                            <NumericEdit NumericValue="@((decimal?)_maxLines)" NumericValueChanged="v => _maxLines = (int?)v" />
                        </Div>
                    }
                </CardBody>
            </Card>
        </Div>
        <Div Class="min-w-0">
            <CodeEditor @bind-Text="_text"
                        Language="@_language"
                        Theme="@_theme"
                        WordWrap="@_wordWrap"
                        Minimap="@_minimap"
                        AutoHeight="@_autoHeight"
                        MinLines="@_minLines"
                        MaxLines="@_maxLines"
                        Style="@(!_autoHeight ? $"height: {_editorHeight}px" : null)" />
            <Div Margin="Margin.Is3.FromTop">
                <H5>Value</H5>
                <Pre>@_text</Pre>
            </Div>
        </Div>
        </Div>
        </DemoSection>

        <Section Space="Space.Y.Is4">
            <DemoSection Title="Auto height examples" Description="Editors that adjust height by content." Code="@(@"<CodeEditor @bind-Text=""_text"" Language=""javascript"" AutoHeight=""true"" MinLines=""3"" MaxLines=""10""/>
<CodeEditor @bind-Text=""_text2"" Language=""json"" AutoHeight=""true"" MinLines=""5""/>")">
            <Div Class="grid gap-6 lg:grid-cols-2">
        <Div>
            <Card>
                <CardBody>
                    <H5 Margin="Margin.Is3.FromBottom">Min 3 lines, Max 10 lines</H5>
                    <CodeEditor @bind-Text="_autoHeightText1"
                                Language="javascript"
                                Theme="@_theme"
                                AutoHeight="true"
                                MinLines="3"
                                MaxLines="10" />
                </CardBody>
            </Card>
        </Div>
        <Div>
            <Card>
                <CardBody>
                    <H5 Margin="Margin.Is3.FromBottom">Min 5 lines, No Max</H5>
                    <CodeEditor @bind-Text="_autoHeightText2"
                                Language="json"
                                Theme="@_theme"
                                AutoHeight="true"
                                MinLines="5"
                                MaxLines="null" />
                </CardBody>
            </Card>
        </Div>
            </Div>
            </DemoSection>
        </Section>
    </Div>
</Div>

@code {
    private string _language = "csharp";
    private string _theme = "auto";
    private bool _wordWrap = false;
    private bool _minimap = true;
    private bool _autoHeight = true;
    private int _editorHeight = 300;
    private int? _minLines = 3;
    private int? _maxLines = 30;
    private string _text = "// Hello, Monaco!\npublic class Demo { }";
    
    private string _autoHeightText1 = @"// Try adding more lines!
console.log('Hello');";
    
    private string _autoHeightText2 = @"{
  ""name"": ""example"",
  ""value"": ""test""
}";
}


