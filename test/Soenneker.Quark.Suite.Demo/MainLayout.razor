@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject Soenneker.Quark.Suite.Demo.Services.ThemeService ThemeService
@implements IDisposable

<PageTitle>Quark Suite Demo</PageTitle>

<CascadingValue Value="ThemeService">
    <div class="min-h-svh bg-background text-foreground">
        <header class="sticky top-0 z-40 border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/80">
            <div class="mx-auto flex h-14 w-full max-w-[1400px] items-center gap-3 px-4 md:px-6">
                <a href="/" class="flex size-8 items-center justify-center rounded-md hover:bg-accent" aria-label="Quark Suite">
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 7h10" />
                        <path d="M4 12h16" />
                        <path d="M4 17h12" />
                    </svg>
                </a>

                <nav class="hidden items-center gap-1 md:flex">
                    @foreach (DocsNavLink item in DocsNavigation.TopLinks)
                    {
                        @if (item.Href is not null)
                        {
                            <a href="@item.Href" class="@GetTopNavClass(item)">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <span class="size-2 rounded-full bg-blue-500"></span>
                                }
                            </a>
                        }
                        else
                        {
                            <span class="@($"{GetTopNavClass(item)} opacity-75")">
                                @item.Title
                            </span>
                        }
                    }
                </nav>

                <div class="ml-auto flex items-center gap-2">
                    <div class="relative hidden items-center md:flex">
                        <svg class="pointer-events-none absolute left-2.5 size-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="11" cy="11" r="8" />
                            <path d="m21 21-4.35-4.35" />
                        </svg>
                        <Input Type="search" Placeholder="Search documentation..." Class="h-8 w-64 pl-8 text-sm" />
                    </div>
                    <button type="button" @onclick="ToggleTheme" class="rounded-md p-2 transition-colors hover:bg-accent" aria-label="Toggle dark mode">
                        @if (ThemeService.IsDark)
                        {
                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M12 3a6 6 0 1 0 9 9 9 9 0 1 1-9-9z" />
                            </svg>
                        }
                        else
                        {
                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <circle cx="12" cy="12" r="4" />
                                <path d="M12 2v2" />
                                <path d="M12 20v2" />
                                <path d="m4.93 4.93 1.41 1.41" />
                                <path d="m17.66 17.66 1.41 1.41" />
                                <path d="M2 12h2" />
                                <path d="M20 12h2" />
                                <path d="m6.34 17.66-1.41 1.41" />
                                <path d="m19.07 4.93-1.41 1.41" />
                            </svg>
                        }
                    </button>
                </div>
            </div>
        </header>

        <div class="mx-auto flex w-full max-w-[1400px] items-start">
            @if (ShowDocsSidebar)
            {
                <Sidebar Collapsible="SidebarCollapsible.None" Class="sticky top-14 hidden h-[calc(100svh-3.5rem)] border-r bg-background lg:flex lg:flex-col" Style="--sidebar-width: 14.5rem;">
                    <SidebarContent Class="gap-5 px-3 py-6">
                        <SidebarGroup Class="gap-1.5">
                            <SidebarGroupLabel Class="h-auto px-1 text-[0.65rem] font-medium tracking-wide text-muted-foreground">
                                Sections
                            </SidebarGroupLabel>
                            <SidebarGroupContent>
                                <SidebarMenu Class="gap-0.5">
                                    @foreach (DocsNavLink item in DocsNavigation.SectionLinks)
                                    {
                                        <SidebarMenuItem>
                                            @if (item.Href is not null)
                                            {
                                                <a href="@item.Href" class="@GetSidebarItemClass(IsSectionActive(item))">
                                                    <span>@item.Title</span>
                                                    @if (item.IsNew)
                                                    {
                                                        <span class="size-2 rounded-full bg-blue-500"></span>
                                                    }
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="@($"{GetSidebarItemClass(false)} opacity-80")">
                                                    <span>@item.Title</span>
                                                    @if (item.IsNew)
                                                    {
                                                        <span class="size-2 rounded-full bg-blue-500"></span>
                                                    }
                                                </span>
                                            }
                                        </SidebarMenuItem>
                                    }
                                </SidebarMenu>
                            </SidebarGroupContent>
                        </SidebarGroup>

                        <SidebarGroup Class="gap-1.5 border-t pt-4">
                            <SidebarGroupLabel Class="h-auto px-1 text-[0.65rem] font-medium tracking-wide text-muted-foreground">
                                Components
                            </SidebarGroupLabel>
                            <SidebarGroupContent>
                                <SidebarMenu Class="gap-0.5">
                                    @foreach (DocsNavLink item in DocsNavigation.ComponentLinks)
                                    {
                                        <SidebarMenuItem>
                                            @if (item.Href is not null)
                                            {
                                                <a href="@item.Href" class="@GetSidebarItemClass(IsCurrentPath(item.Href, false))">
                                                    @item.Title
                                                </a>
                                            }
                                            else
                                            {
                                                <span class="@($"{GetSidebarItemClass(false)} opacity-70")">@item.Title</span>
                                            }
                                        </SidebarMenuItem>
                                    }
                                </SidebarMenu>
                            </SidebarGroupContent>
                        </SidebarGroup>
                    </SidebarContent>
                </Sidebar>
            }

            <main class="@MainClass">
                @Body
            </main>
        </div>
    </div>
</CascadingValue>

@code {
    private string CurrentPath
    {
        get
        {
            string path = Navigation.ToBaseRelativePath(Navigation.Uri);
            int separatorIndex = path.IndexOfAny(['?', '#']);

            if (separatorIndex >= 0)
                path = path[..separatorIndex];

            return string.IsNullOrWhiteSpace(path) ? "/" : $"/{path.Trim('/')}";
        }
    }

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
    }

    private bool ShowDocsSidebar => CurrentPath != "/";

    private string MainClass => ShowDocsSidebar
        ? "min-w-0 flex-1 px-4 py-8 md:px-8 lg:px-12"
        : "min-w-0 flex-1";

    private string GetTopNavClass(DocsNavLink item)
    {
        const string baseClass = "inline-flex h-8 items-center gap-2 rounded-md px-2.5 text-sm transition-colors";

        return IsTopNavActive(item)
            ? $"{baseClass} font-semibold text-foreground"
            : $"{baseClass} text-foreground/70 hover:text-foreground";
    }

    private string GetSidebarItemClass(bool active)
    {
        const string baseClass = "inline-flex h-[28px] w-full items-center gap-2 rounded-md border border-transparent px-2 text-[0.78rem] font-medium transition-colors";

        return active
            ? $"{baseClass} bg-accent/70 text-foreground"
            : $"{baseClass} text-foreground/75 hover:bg-accent/40 hover:text-foreground";
    }

    private bool IsTopNavActive(DocsNavLink item)
    {
        return item.Href switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsSectionActive(DocsNavLink item)
    {
        return item.Href switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsCurrentPath(string href, bool exactMatch)
    {
        string normalized = href == "/" ? "/" : $"/{href.Trim('/')}";

        return exactMatch ? CurrentPath == normalized : CurrentPath == normalized;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await ThemeService.InitializeAsync();
        StateHasChanged();
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleAsync();
    }

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
    }
}
