@code {
    private ElementReference _scrollContainerRef;
    private string? _lastScrolledPath;
    private bool _docsLayoutExpanded;

    private static readonly IReadOnlyList<QuarkPresetToken> ContainerWrapperPresets = [QuarkPresets.ContainerWrapper];

    private readonly IReadOnlyList<NavigationItem> _headerLinks =
    [
        new("Docs", "", ExactMatch: true),
        new("Components", "components"),
    ];

    private string CurrentPath
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            var separatorIndex = path.IndexOfAny(['?', '#']);

            if (separatorIndex >= 0)
                path = path[..separatorIndex];

            return string.IsNullOrWhiteSpace(path) ? "/" : $"/{path.Trim('/')}";
        }
    }

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private bool IsDocsPage => CurrentPath != "/";
    private bool IsComponentsIndexPage => CurrentPath == "/components";
    private bool ShouldRenderLayoutPageTitle => !IsComponentsIndexPage;
    private bool IsLandingPage => CurrentPath == "/";
    private bool ShowSidebarTrigger => true;
    private bool IsHeaderNavActive(NavigationItem item) => false;

    private string? CurrentPageTitle
    {
        get
        {
            if (!IsDocsPage)
                return null;

            NavigationItem[] groups =
            [
                ..DocsNavigation.ComponentLinks,
                ..DocsNavigation.PrimitiveLinks,
                ..DocsNavigation.SectionLinks
            ];

            foreach (var item in groups)
            {
                if (IsCurrentPath(item))
                    return item.Title;
            }

            return null;
        }
    }

    private IReadOnlyList<QuarkPresetToken>? HeaderContainerPresets => _docsLayoutExpanded ? null : ContainerWrapperPresets;

    private string HeaderContainerClass => _docsLayoutExpanded
        ? "px-6"
        : "px-6 group-has-data-[slot=designer]/layout:max-w-none 3xl:fixed:px-0";

    private IReadOnlyList<QuarkPresetToken>? DocsContainerPresets => _docsLayoutExpanded ? null : ContainerWrapperPresets;

    private IReadOnlyList<QuarkPresetToken>? NavigationShellContainerPresets => IsLandingPage ? ContainerWrapperPresets : DocsContainerPresets;

    private string MainClass => IsLandingPage ? string.Empty : "max-w-6xl px-4 py-6 md:px-6 lg:px-8 lg:py-8";

    private Task ToggleDocsLayout(MouseEventArgs _)
    {
        _docsLayoutExpanded = !_docsLayoutExpanded;
        return Task.CompletedTask;
    }

    private static string LandingNavLinkClass(bool active = false)
    {
        const string baseClass = "inline-flex h-8 shrink-0 items-center justify-center rounded-md border border-transparent bg-clip-padding px-2.5 text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50";
        return active ? $"{baseClass} text-foreground bg-accent dark:bg-accent/50" : $"{baseClass} text-muted-foreground hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50";
    }

    private bool IsTopNavActive(NavigationItem item)
    {
        return NormalizeRoute(item.Href) switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsSectionActive(NavigationItem item)
    {
        return NormalizeRoute(item.Href) switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsCurrentPath(NavigationItem item)
    {
        return IsCurrentPath(item.Href, item.ExactMatch);
    }

    private bool IsCurrentPath(string? href, bool exactMatch)
    {
        var normalized = NormalizeRoute(href);

        return exactMatch ? CurrentPath == normalized : CurrentPath == normalized;
    }

    private static string NormalizeRoute(string? href)
    {
        return string.IsNullOrWhiteSpace(href) ? "/" : $"/{href.Trim('/')}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.Initialize();
            StateHasChanged();
        }

        if (_lastScrolledPath != CurrentPath)
        {
            _lastScrolledPath = CurrentPath;
            await JSRuntime.InvokeVoidAsync("quarkDemo.scrollElementToTop", _scrollContainerRef);
        }
    }

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ToggleTheme()
    {
        await ThemeService.Toggle();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }

}
