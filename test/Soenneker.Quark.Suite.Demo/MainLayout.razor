@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Routing
@inject NavigationManager Navigation
@inject Services.ThemeService ThemeService
@implements IDisposable

<PageTitle>Quark Suite Demo</PageTitle>

<CascadingValue Value="ThemeService">
    <div class="min-h-svh bg-background text-foreground" style="--header-height: 3.5rem;">
        <header class="sticky top-0 z-50 w-full border-b bg-background">
            <div class="container-wrapper px-6">
                <div class="flex h-(--header-height) items-center gap-4">
                    <button type="button"
                            @onclick="ToggleDocsSidebar"
                            class="inline-flex size-8 items-center justify-center rounded-md transition-colors hover:bg-accent hover:text-accent-foreground md:hidden"
                            aria-label="@(_docsSidebarOpenMobile ? "Close navigation menu" : "Open navigation menu")"
                            aria-expanded="@_docsSidebarOpenMobile"
                            aria-controls="mobile-docs-navigation">
                        <span class="relative block size-4" aria-hidden="true">
                            <span class="@GetMobileMenuLineOneClass()"></span>
                            <span class="@GetMobileMenuLineTwoClass()"></span>
                        </span>
                    </button>

                    <a href="/" class="inline-flex items-center gap-3 rounded-md px-2 py-1.5 transition-colors hover:bg-accent" aria-label="Quark Suite home">
                        <img src="https://user-images.githubusercontent.com/4441470/224455560-91ed3ee7-f510-4041-a8d2-3fc093025112.png"
                             alt="Soenneker Quark Suite"
                             class="hidden h-7 w-7 rounded-sm object-contain md:block" />
                        <div class="flex min-w-0 flex-col">
                            <span class="truncate text-sm font-semibold leading-none">Soenneker Quark Suite</span>
                            <span class="hidden truncate text-xs text-muted-foreground sm:block">Blazor components for .NET</span>
                        </div>
                    </a>

                    <nav class="hidden items-center gap-1 lg:flex">
                    @foreach (DocsNavLink item in DocsNavigation.TopLinks)
                    {
                        @if (item.Href is not null)
                        {
                            <a href="@item.Href" class="@GetTopNavClass(item)">
                                @item.Title
                                @if (item.IsNew)
                                {
                                    <span class="size-2 rounded-full bg-blue-500"></span>
                                }
                            </a>
                        }
                        else
                        {
                            <span class="@($"{GetTopNavClass(item)} opacity-75")">
                                @item.Title
                            </span>
                        }
                    }

                    </nav>

                    <div class="ml-auto flex items-center gap-2 md:flex-1 md:justify-end">
                        <a href="https://github.com/soenneker/soenneker.quark.suite"
                           target="_blank"
                           rel="noreferrer"
                           class="inline-flex h-8 items-center gap-2 rounded-md px-2.5 text-sm text-foreground/70 transition-colors hover:bg-accent hover:text-foreground"
                           aria-label="View Soenneker Quark Suite on GitHub">
                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 .5C5.65.5.5 5.65.5 12A11.5 11.5 0 0 0 8.36 22.9c.57.1.78-.25.78-.56 0-.28-.01-1.2-.02-2.18-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.76 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.53-2.55-.29-5.23-1.27-5.23-5.68 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a10.97 10.97 0 0 1 5.77 0c2.2-1.5 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.73.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.67.41.35.78 1.04.78 2.1 0 1.52-.01 2.75-.01 3.12 0 .31.21.67.79.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
                            </svg>
                            <span class="hidden sm:inline">GitHub</span>
                        </a>
                        <button type="button"
                                @onclick="ToggleTheme"
                                class="inline-flex size-8 items-center justify-center rounded-md transition-colors hover:bg-accent hover:text-accent-foreground"
                                aria-label="Toggle dark mode">
                            @if (ThemeService.IsDark)
                            {
                                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M12 3a6 6 0 1 0 9 9 9 9 0 1 1-9-9z" />
                                </svg>
                            }
                            else
                            {
                                <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <circle cx="12" cy="12" r="4" />
                                    <path d="M12 2v2" />
                                    <path d="M12 20v2" />
                                    <path d="m4.93 4.93 1.41 1.41" />
                                    <path d="m17.66 17.66 1.41 1.41" />
                                    <path d="M2 12h2" />
                                    <path d="M20 12h2" />
                                    <path d="m6.34 17.66-1.41 1.41" />
                                    <path d="m19.07 4.93-1.41 1.41" />
                                </svg>
                            }
                        </button>
                    </div>
                </div>
            </div>
        </header>

        @if (ShowDocsSidebar)
        {
            <div class="container-wrapper flex flex-1 flex-col px-2">
                <SidebarProvider Class="min-h-min flex-1 items-start px-0 [--top-spacing:0] lg:grid lg:grid-cols-[var(--sidebar-width)_minmax(0,1fr)] lg:[--top-spacing:calc(var(--spacing)*4)] 3xl:fixed:container 3xl:fixed:px-3"
                                 SidebarWidth="calc(var(--spacing) * 72)">
                    <Sidebar Collapsible="SidebarCollapsible.None"
                             Class="sticky top-[calc(var(--header-height)+0.6rem)] z-30 h-[calc(100svh-10rem)] overscroll-none bg-transparent [--sidebar-menu-width:--spacing(56)]">
                        <div class="h-9"></div>
                        <div class="absolute top-8 z-10 h-8 w-(--sidebar-menu-width) shrink-0 bg-linear-to-b from-background via-background/80 to-background/50 blur-xs"></div>
                        <div class="absolute top-12 right-2 bottom-0 hidden h-full w-px bg-linear-to-b from-transparent via-border to-transparent lg:flex"></div>

                        <SidebarContent Class="mx-auto no-scrollbar w-(--sidebar-menu-width) overflow-x-hidden px-2">
                            <SidebarGroup Class="pt-6">
                                <SidebarGroupLabel Class="font-medium text-muted-foreground">
                                    Sections
                                </SidebarGroupLabel>
                                <SidebarGroupContent>
                                    <SidebarMenu>
                                        @foreach (DocsNavLink item in DocsNavigation.SectionLinks)
                                        {
                                            <SidebarMenuItem>
                                                @if (item.Href is not null)
                                                {
                                                    <SidebarMenuButton To="@item.Href"
                                                                       Active="@(IsSectionActive(item))"
                                                                       Class="@SidebarDocsMenuButtonClass">
                                                        <span class="absolute inset-0 flex w-(--sidebar-menu-width) bg-transparent"></span>
                                                        @item.Title
                                                        @if (item.IsNew)
                                                        {
                                                            <span class="flex size-2 rounded-full bg-blue-500" title="New"></span>
                                                        }
                                                    </SidebarMenuButton>
                                                }
                                                else
                                                {
                                                    <span class="@($"{SidebarDocsMenuButtonClass} inline-flex opacity-80")">
                                                        @item.Title
                                                        @if (item.IsNew)
                                                        {
                                                            <span class="flex size-2 rounded-full bg-blue-500" title="New"></span>
                                                        }
                                                    </span>
                                                }
                                            </SidebarMenuItem>
                                        }
                                    </SidebarMenu>
                                </SidebarGroupContent>
                            </SidebarGroup>

                            <SidebarGroup>
                                <SidebarGroupLabel Class="font-medium text-muted-foreground">
                                    Components
                                </SidebarGroupLabel>
                                <SidebarGroupContent>
                                    <SidebarMenu Class="gap-0.5">
                                        @foreach (DocsNavLink item in DocsNavigation.ComponentLinks)
                                        {
                                            <SidebarMenuItem>
                                                @if (item.Href is not null)
                                                {
                                                    <SidebarMenuButton To="@item.Href"
                                                                       Active="@(IsCurrentPath(item.Href, false))"
                                                                       Class="@SidebarDocsMenuButtonClass">
                                                        <span class="absolute inset-0 flex w-(--sidebar-menu-width) bg-transparent"></span>
                                                        @item.Title
                                                        @if (item.IsNew)
                                                        {
                                                            <span class="flex size-2 rounded-full bg-blue-500" title="New"></span>
                                                        }
                                                    </SidebarMenuButton>
                                                }
                                                else
                                                {
                                                    <span class="@($"{SidebarDocsMenuButtonClass} inline-flex opacity-70")">
                                                        @item.Title
                                                    </span>
                                                }
                                            </SidebarMenuItem>
                                        }
                                    </SidebarMenu>
                                </SidebarGroupContent>
                            </SidebarGroup>

                            <div class="sticky -bottom-1 z-10 h-16 shrink-0 bg-linear-to-t from-background via-background/80 to-background/50 blur-xs"></div>
                        </SidebarContent>
                    </Sidebar>

                    <div class="h-full w-full">
                        <main class="@MainClass">
                            @Body
                        </main>
                    </div>
                </SidebarProvider>
            </div>
        }
        else
        {
            <main class="@MainClass">
                @Body
            </main>
        }

        @if (_docsSidebarOpenMobile)
        {
            <div id="mobile-docs-navigation"
                 class="fixed inset-x-0 bottom-0 z-40 overflow-y-auto border-t bg-background md:hidden"
                 style="top: var(--header-height);">
                <div class="px-6 py-5">
                    <div class="space-y-8">
                        <section>
                            <p class="text-sm font-medium text-muted-foreground">Sections</p>
                            <div class="mt-3 flex flex-col gap-1">
                                @foreach (DocsNavLink item in DocsNavigation.SectionLinks)
                                {
                                    @if (item.Href is not null)
                                    {
                                        <a href="@item.Href"
                                           @onclick="CloseDocsSidebar"
                                           class="@GetMobileOverlayLinkClass(IsSectionActive(item))">
                                            @item.Title
                                            @if (item.IsNew)
                                            {
                                                <span class="flex size-2 rounded-full bg-blue-500" title="New"></span>
                                            }
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="@($"{GetMobileOverlayLinkClass(false)} opacity-70")">
                                            @item.Title
                                            @if (item.IsNew)
                                            {
                                                <span class="flex size-2 rounded-full bg-blue-500" title="New"></span>
                                            }
                                        </span>
                                    }
                                }
                            </div>
                        </section>

                        <section>
                            <p class="text-sm font-medium text-muted-foreground">Components</p>
                            <div class="mt-3 flex flex-col gap-1">
                                @foreach (DocsNavLink item in DocsNavigation.ComponentLinks)
                                {
                                    @if (item.Href is not null)
                                    {
                                        <a href="@item.Href"
                                           @onclick="CloseDocsSidebar"
                                           class="@GetMobileOverlayLinkClass(IsCurrentPath(item.Href, false))">
                                            @item.Title
                                            @if (item.IsNew)
                                            {
                                                <span class="flex size-2 rounded-full bg-blue-500" title="New"></span>
                                            }
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="@($"{GetMobileOverlayLinkClass(false)} opacity-70")">
                                            @item.Title
                                        </span>
                                    }
                                }
                            </div>
                        </section>
                    </div>
                </div>
            </div>
        }
    </div>

    <Sonner Theme="@(ThemeService.IsDark ? "dark" : "light")" />
</CascadingValue>

@code {
    private const string SidebarDocsMenuButtonClass = "relative h-[30px] w-fit overflow-visible border border-transparent text-[0.8rem] font-medium after:absolute after:inset-x-0 after:-inset-y-1 after:z-0 after:rounded-md data-[active=true]:border-accent data-[active=true]:bg-accent 3xl:fixed:w-full 3xl:fixed:max-w-48";
    private bool _docsSidebarOpenMobile;

    private string CurrentPath
    {
        get
        {
            string path = Navigation.ToBaseRelativePath(Navigation.Uri);
            int separatorIndex = path.IndexOfAny(['?', '#']);

            if (separatorIndex >= 0)
                path = path[..separatorIndex];

            return string.IsNullOrWhiteSpace(path) ? "/" : $"/{path.Trim('/')}";
        }
    }

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private bool ShowDocsSidebar => CurrentPath != "/";

    private string MainClass => ShowDocsSidebar
        ? "min-w-0 flex-1 px-4 py-6 md:px-6 lg:px-8 lg:py-8"
        : "min-w-0 flex-1";

    private string GetTopNavClass(DocsNavLink item)
    {
        const string baseClass = "inline-flex h-8 items-center gap-2 rounded-md px-2.5 text-sm transition-colors";

        return IsTopNavActive(item)
            ? $"{baseClass} font-medium text-foreground"
            : $"{baseClass} text-foreground/70 hover:text-foreground";
    }

    private bool IsTopNavActive(DocsNavLink item)
    {
        return item.Href switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsSectionActive(DocsNavLink item)
    {
        return item.Href switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsCurrentPath(string href, bool exactMatch)
    {
        string normalized = href == "/" ? "/" : $"/{href.Trim('/')}";

        return exactMatch ? CurrentPath == normalized : CurrentPath == normalized;
    }

    private static string GetMobileOverlayLinkClass(bool active)
    {
        const string baseClass = "inline-flex items-center gap-2 rounded-md px-3 py-2 text-2xl font-medium transition-colors";
        return active ? $"{baseClass} bg-accent text-foreground" : $"{baseClass} text-foreground hover:bg-accent/60";
    }

    private string GetMobileMenuLineOneClass()
    {
        return _docsSidebarOpenMobile
            ? "absolute top-1/2 left-1/2 h-0.5 w-4 -translate-x-1/2 -translate-y-1/2 rotate-45 rounded-full bg-current transition-all duration-200 ease-out"
            : "absolute top-[calc(50%-0.22rem)] left-1/2 h-0.5 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-current transition-all duration-200 ease-out";
    }

    private string GetMobileMenuLineTwoClass()
    {
        return _docsSidebarOpenMobile
            ? "absolute top-1/2 left-1/2 h-0.5 w-4 -translate-x-1/2 -translate-y-1/2 -rotate-45 rounded-full bg-current transition-all duration-200 ease-out"
            : "absolute top-[calc(50%+0.22rem)] left-1/2 h-0.5 w-4 -translate-x-1/2 -translate-y-1/2 rounded-full bg-current transition-all duration-200 ease-out";
    }

    private void ToggleDocsSidebar()
    {
        _docsSidebarOpenMobile = !_docsSidebarOpenMobile;
    }

    private void CloseDocsSidebar()
    {
        _docsSidebarOpenMobile = false;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _docsSidebarOpenMobile = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await ThemeService.InitializeAsync();
        StateHasChanged();
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleAsync();
    }

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
