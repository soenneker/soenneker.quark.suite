@inherits LayoutComponentBase
@using Target = Soenneker.Quark.Target
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Services.ThemeService ThemeService
@implements IDisposable

<CascadingValue Value="ThemeService">
    <SidebarProvider Class="flex h-svh min-h-svh flex-col overflow-hidden bg-background text-foreground"
                     SidebarWidth="calc(var(--spacing) * 72)"
                     SidebarWidthMobile="100vw"
                     style="--header-height: 4.5rem;">
        @if (IsLandingPage)
        {
            <Div Class="sticky top-0 z-50 w-full bg-background">
                <Div Class="container-wrapper px-4 sm:px-6">
                    <Div Class="container mx-auto flex max-w-7xl items-center gap-3" Style="height: var(--header-height);">
                        <Div Display="Display.Flex" Align="Align.Center" Gap="Gap.Is2">
                            <Div Class="flex items-center gap-2 lg:hidden">
                                <SidebarTrigger Class="inline-flex size-8 items-center justify-center rounded-md transition-colors hover:bg-accent hover:text-accent-foreground"
                                                aria-label="Toggle menu">
                                    <Div Class="relative flex h-4 w-4 items-center justify-center">
                                        <Span Class="absolute left-0 top-1 block h-0.5 w-4 bg-foreground"></Span>
                                        <Span Class="absolute left-0 top-2.5 block h-0.5 w-4 bg-foreground"></Span>
                                    </Div>
                                </SidebarTrigger>
                                <Span Class="flex h-8 items-center text-lg leading-none font-medium">Menu</Span>
                            </Div>

                            <Anchor To=""
                                    Class="inline-flex items-center gap-2 rounded-md px-1 py-1 text-sm font-medium text-foreground transition-colors hover:bg-accent hover:text-accent-foreground">
                                <img src="https://user-images.githubusercontent.com/4441470/224455560-91ed3ee7-f510-4041-a8d2-3fc093025112.png"
                                     alt="Quark Suite"
                                     class="size-5 rounded-sm object-cover" />
                            </Anchor>
                        </Div>

                        <nav class="hidden items-center gap-0 lg:flex">
                            <Anchor To="" Class="@LandingNavLinkClass(true)">Docs</Anchor>
                            <Anchor To="components" Class="@LandingNavLinkClass()">Components</Anchor>
                        </nav>

                        <Div Class="ml-auto flex items-center gap-2">
                            <Anchor To="https://github.com/soenneker/soenneker.quark.suite"
                                    Target="Target.Blank"
                                    Rel="noreferrer"
                                    Class="inline-flex h-8 shrink-0 items-center justify-center gap-1.5 rounded-md px-3 text-sm font-medium text-foreground transition-all hover:bg-accent hover:text-accent-foreground">
                                <Icon Name="LucideIcon.Star" BoxSize="Size.Is4" />
                                <Span Class="w-fit text-xs text-muted-foreground tabular-nums">1</Span>
                            </Anchor>

                            <Div Class="h-4 w-px bg-border"></Div>

                            <Button Variant="ButtonVariant.Ghost"
                                    Size="ButtonSize.IconSm"
                                    aria-label="Toggle theme"
                                    OnClick="ToggleTheme">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                                     class="size-4.5">
                                    <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                                    <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"></path>
                                    <path d="M12 3l0 18"></path>
                                    <path d="M12 9l4.65 -4.65"></path>
                                    <path d="M12 14.3l7.37 -7.37"></path>
                                    <path d="M12 19.6l8.85 -8.85"></path>
                                </svg>
                            </Button>
                        </Div>
                    </Div>
                </Div>
            </Div>
        }
        else
        {
            <Header ShowSidebarTrigger="@ShowSidebarTrigger">
                <BrandContent>
                    <HeaderBrand To=""
                                 AriaLabel="Quark Suite home"
                                 ImageSource="https://user-images.githubusercontent.com/4441470/224455560-91ed3ee7-f510-4041-a8d2-3fc093025112.png"
                                 ImageAlt="Soenneker Quark Suite"
                                 Title="Soenneker Quark Suite"
                                 Subtitle="Blazor components for .NET" />
                </BrandContent>
                <NavigationContent>
                    <NavigationLinks Items="DocsNavigation.TopLinks"
                                     Mode="NavigationLinksMode.Header"
                                     IsActive="IsTopNavActive" />
                </NavigationContent>
                <ActionsContent>
                    <HeaderActionLink To="https://github.com/soenneker/soenneker.quark.suite"
                                      Target="Target.Blank"
                                      Rel="noreferrer"
                                      Label="GitHub"
                                      AriaLabel="View Soenneker Quark Suite on GitHub">
                        <IconContent>
                            <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                                <path d="M12 .5C5.65.5.5 5.65.5 12A11.5 11.5 0 0 0 8.36 22.9c.57.1.78-.25.78-.56 0-.28-.01-1.2-.02-2.18-3.2.7-3.88-1.36-3.88-1.36-.52-1.33-1.28-1.68-1.28-1.68-1.04-.72.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.76 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.53-2.55-.29-5.23-1.27-5.23-5.68 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.17 1.18a10.97 10.97 0 0 1 5.77 0c2.2-1.5 3.17-1.18 3.17-1.18.62 1.58.23 2.75.11 3.04.73.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.25 5.67.41.35.78 1.04.78 2.1 0 1.52-.01 2.75-.01 3.12 0 .31.21.67.79.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z" />
                            </svg>
                        </IconContent>
                    </HeaderActionLink>
                    <ThemeToggleButton IsDark="ThemeService.IsDark"
                                       AriaLabel="Toggle dark mode"
                                       OnClick="ToggleTheme" />
                </ActionsContent>
            </Header>
        }

        @if (ShowDesktopNavigationSidebar)
        {
            <Div class="container-wrapper min-h-0 flex-1 overflow-hidden" Padding="Padding.Is2.OnX">
                <Div class="flex h-full min-h-0">
                    <Sidebar Collapsible="SidebarCollapsible.None"
                             Shell="SidebarShell.Navigation"
                             MobileMode="SidebarMobileMode.FullScreen"
                             MobileShowBackdrop="false"
                             MobileLockScroll="false"
                             MobileShowCloseButton="false"
                             MobileOffsetTop="var(--header-height)">
                        <MobileContent>
                            <NavigationLinks Items="DocsNavigation.TopLinks"
                                             Mode="NavigationLinksMode.Stack"
                                             Title="Menu"
                                             IsActive="IsTopNavActive" />
                            <NavigationLinks Items="DocsNavigation.SectionLinks"
                                             Mode="NavigationLinksMode.Stack"
                                             Title="Sections"
                                             IsActive="IsSectionActive" />
                            <NavigationLinks Items="DocsNavigation.ComponentLinks"
                                             Mode="NavigationLinksMode.Stack"
                                             Title="Components"
                                             IsActive="IsCurrentPath" />
                            <NavigationLinks Items="DocsNavigation.PrimitiveLinks"
                                             Mode="NavigationLinksMode.Stack"
                                             Title="Primitives"
                                             IsActive="IsCurrentPath" />
                        </MobileContent>
                        <ChildContent>
                            <SidebarContent>
                                <NavigationLinks Items="DocsNavigation.SectionLinks"
                                                 Mode="NavigationLinksMode.Sidebar"
                                                 Title="Sections"
                                                 GroupClass="pt-4 lg:pt-6"
                                                 IsActive="IsSectionActive" />
                                <NavigationLinks Items="DocsNavigation.ComponentLinks"
                                                 Mode="NavigationLinksMode.Sidebar"
                                                 Title="Components"
                                                 IsActive="IsCurrentPath" />
                                <NavigationLinks Items="DocsNavigation.PrimitiveLinks"
                                                 Mode="NavigationLinksMode.Sidebar"
                                                 Title="Primitives"
                                                 IsActive="IsCurrentPath" />
                            </SidebarContent>
                        </ChildContent>
                    </Sidebar>

                    <div @ref="_scrollContainerRef" class="h-full min-w-0 flex-1 overflow-y-auto overflow-x-hidden">
                        <Main class="@MainClass">
                            @if (CurrentPageTitle is not null)
                            {
                                <Div class="mb-8 space-y-2">
                                    <h1 class="text-4xl font-bold tracking-tight">@CurrentPageTitle</h1>
                                </Div>
                            }
                            @Body
                        </Main>
                    </div>
                </Div>
            </Div>
        }
        else
        {
            <Div class="flex min-h-0 flex-1 flex-col overflow-hidden">
                @if (ShowSidebarTrigger)
                {
                    <Div class="lg:hidden">
                        <Sidebar Collapsible="SidebarCollapsible.None"
                                 Shell="SidebarShell.Navigation"
                                 MobileMode="SidebarMobileMode.FullScreen"
                                 MobileShowBackdrop="false"
                                 MobileLockScroll="false"
                                 MobileShowCloseButton="false"
                                 MobileOffsetTop="var(--header-height)">
                            <MobileContent>
                                <NavigationLinks Items="DocsNavigation.TopLinks"
                                                 Mode="NavigationLinksMode.Stack"
                                                 Title="Menu"
                                                 IsActive="IsTopNavActive" />
                                <NavigationLinks Items="DocsNavigation.SectionLinks"
                                                 Mode="NavigationLinksMode.Stack"
                                                 Title="Sections"
                                                 IsActive="IsSectionActive" />
                                <NavigationLinks Items="DocsNavigation.ComponentLinks"
                                                 Mode="NavigationLinksMode.Stack"
                                                 Title="Components"
                                                 IsActive="IsCurrentPath" />
                                <NavigationLinks Items="DocsNavigation.PrimitiveLinks"
                                                 Mode="NavigationLinksMode.Stack"
                                                 Title="Primitives"
                                                 IsActive="IsCurrentPath" />
                            </MobileContent>
                        </Sidebar>
                    </Div>
                }

                <div @ref="_scrollContainerRef" class="min-h-0 flex-1 overflow-y-auto overflow-x-hidden">
                    <Main class="@MainClass">
                        @if (CurrentPageTitle is not null)
                        {
                            <Div class="mb-8 space-y-2">
                                <h1 class="text-4xl font-bold tracking-tight">@CurrentPageTitle</h1>
                            </Div>
                        }
                        @Body
                    </Main>
                </div>
            </Div>
        }
    </SidebarProvider>

    <Sonner Theme="@(ThemeService.IsDark ? "dark" : "light")" />
</CascadingValue>

@code {
    private ElementReference _scrollContainerRef;
    private string? _lastScrolledPath;

    private string CurrentPath
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            var separatorIndex = path.IndexOfAny(['?', '#']);

            if (separatorIndex >= 0)
                path = path[..separatorIndex];

            return string.IsNullOrWhiteSpace(path) ? "/" : $"/{path.Trim('/')}";
        }
    }

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += OnThemeChanged;
        Navigation.LocationChanged += OnLocationChanged;
    }

    private bool ShowDesktopNavigationSidebar => CurrentPath != "/";
    private bool IsLandingPage => CurrentPath == "/";
    private bool ShowSidebarTrigger => true;

    private string? CurrentPageTitle
    {
        get
        {
            if (!ShowDesktopNavigationSidebar)
                return null;

            NavigationItem[] groups =
            [
                ..DocsNavigation.ComponentLinks,
                ..DocsNavigation.PrimitiveLinks,
                ..DocsNavigation.SectionLinks
            ];

            foreach (var item in groups)
            {
                if (IsCurrentPath(item))
                    return item.Title;
            }

            return null;
        }
    }

    private string MainClass => ShowDesktopNavigationSidebar
        ? "mx-auto min-w-0 w-full max-w-6xl flex-1 px-4 py-6 md:px-6 lg:px-8 lg:py-8"
        : "min-w-0 flex-1";

    private static string LandingNavLinkClass(bool active = false)
    {
        const string baseClass = "inline-flex h-8 shrink-0 items-center justify-center rounded-md px-2.5 text-sm font-medium whitespace-nowrap transition-all";
        return active
            ? $"{baseClass} text-foreground"
            : $"{baseClass} text-muted-foreground hover:bg-accent hover:text-accent-foreground";
    }

    private bool IsTopNavActive(NavigationItem item)
    {
        return NormalizeRoute(item.Href) switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsSectionActive(NavigationItem item)
    {
        return NormalizeRoute(item.Href) switch
        {
            "/" => CurrentPath == "/",
            "/components" => CurrentPath != "/",
            _ => false
        };
    }

    private bool IsCurrentPath(NavigationItem item)
    {
        return IsCurrentPath(item.Href, item.ExactMatch);
    }

    private bool IsCurrentPath(string? href, bool exactMatch)
    {
        var normalized = NormalizeRoute(href);

        return exactMatch ? CurrentPath == normalized : CurrentPath == normalized;
    }

    private static string NormalizeRoute(string? href)
    {
        return string.IsNullOrWhiteSpace(href) ? "/" : $"/{href.Trim('/')}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            StateHasChanged();
        }

        if (_lastScrolledPath != CurrentPath)
        {
            _lastScrolledPath = CurrentPath;
            await JSRuntime.InvokeVoidAsync("quarkDemo.scrollElementToTop", _scrollContainerRef);
        }
    }

    private void OnThemeChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ToggleTheme()
    {
        await ThemeService.ToggleAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= OnThemeChanged;
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
