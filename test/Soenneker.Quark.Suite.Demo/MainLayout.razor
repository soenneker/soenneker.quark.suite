                        {
                            <Div Margin="Margin.Is8.FromBottom" Gap="Gap.Is2" Display="Display.Flex" Flex=@("flex flex-col")>
                                <H1 ScrollMargin="ScrollMargin.Is24.FromTop" TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Semibold" Tracking="Tracking.Tight">@CurrentPageTitle</H1>
