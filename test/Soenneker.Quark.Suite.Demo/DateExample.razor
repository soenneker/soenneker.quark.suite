@namespace Soenneker.Quark.Suite.Demo

<Card Class="rounded-lg">
    <CardHeader Class="pb-2">
        <CardTitle Class="text-sm">@Label</CardTitle>
    </CardHeader>
    <CardBody Class="pt-0">
        @ChildContent
    </CardBody>
</Card>

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
