<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <IsPackable>false</IsPackable>
        <UseMicrosoftTestingPlatformRunner>true</UseMicrosoftTestingPlatformRunner>
    </PropertyGroup>

    <ItemGroup>
        <None Remove="appsettings.json" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="appsettings.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <Content Include="testconfig.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.4.0" />
        <PackageReference Include="Soenneker.Playwrights.Extensions.TestPages" Version="4.0.3" />
        <PackageReference Include="Soenneker.Playwrights.Tests.Unit" Version="4.0.8" />
        <PackageReference Include="Soenneker.Utils.Test" Version="4.0.314" />
        <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.6" />
        <PackageReference Include="Soenneker.Extensions.Configuration" Version="4.0.812" />
        <PackageReference Include="xunit.v3" Version="3.2.2" />
    </ItemGroup>
</Project>
