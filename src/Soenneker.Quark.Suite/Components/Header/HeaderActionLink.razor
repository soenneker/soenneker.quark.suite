@namespace Soenneker.Quark.Header

<Anchor Href="@Href"
        Target="@Target"
        rel="@Rel"
        data-slot="button"
        data-variant="ghost"
        data-size="sm"
        Display="Display.InlineFlex"
        Shrink="Shrink.Is0"
        ItemsAlign="Items.Center"
        Justify="Justify.Center"
        Gap='Gap.Is1_5'
        Rounded="Rounded.Md"
        Border="Border.Is1"
        BorderColor='@(Quark.BorderColor.Transparent.OnFocusVisible.Ring.Custom("aria-invalid").Destructive)'
        BackgroundColor='@(Quark.BackgroundColor.Accent.OnHover.OnDark.OnHover.Token("accent/50"))'
        TextColor="@(Quark.TextColor.AccentForeground.OnHover)"
        RingColor='@(Quark.RingColor.Ring50.OnFocusVisible.Custom("aria-invalid").Token("destructive/20").OnDark.Custom("aria-invalid").Token("destructive/40"))'
        PointerEvents="@(Quark.PointerEvents.None.OnDisabled)"
        Opacity="@(Quark.Opacity.Is50.OnDisabled)"
        Height="Height.Is8"
        Padding='@(Quark.Padding.OnX.Is3.Custom("has-[>svg]").OnX.Is2_5)'
        TextSize="TextSize.Sm"
        FontWeight="FontWeight.Medium"
        Whitespace="Whitespace.Nowrap"
        Transition="Transition.All"
        OutlineStyle="OutlineStyle.None"
        UserSelect="UserSelect.None"
        Shadow="Shadow.None"
        Class="bg-clip-padding focus-visible:ring-[3px] [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4"
        aria-label="@AriaLabel">
    @if (IconContent is not null)
    {
        @IconContent
    }

    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <Span>@Label</Span>
    }
</Anchor>

@code {
    [Parameter]
    public string Href { get; set; } = string.Empty;

    [Parameter]
    public Target? Target { get; set; }

    [Parameter]
    public string? Rel { get; set; }

    [Parameter]
    public string AriaLabel { get; set; } = string.Empty;

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public RenderFragment? IconContent { get; set; }
}
