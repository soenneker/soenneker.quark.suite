@namespace Soenneker.Quark.Header
@using Soenneker.Quark.Dtos
@inherits Soenneker.Quark.Element

<header @attributes="BuildAttributes()">
    <Div Presets="@ContainerPresets" Class="@ContainerClassValue">
        <Div Class="@InnerClassValue">
            @if (ShowSidebarTrigger)
            {
                <button type="button"
                        data-slot="sidebar-trigger"
                        data-variant="ghost"
                        data-size="default"
                        aria-label="@SidebarTriggerLabel"
                        aria-haspopup="dialog"
                        aria-expanded="@(SidebarIsExpanded ? "true" : "false")"
                        aria-controls="@SidebarTriggerControls"
                        data-state="@(SidebarIsExpanded ? "open" : "closed")"
                        class="@SidebarTriggerClass"
                        @onclick="HandleSidebarTriggerClick">
                    @if (SidebarIsExpanded && SidebarTriggerOpenContent is not null)
                    {
                        @SidebarTriggerOpenContent
                    }
                    else if (SidebarTriggerClosedContent is not null)
                    {
                        @SidebarTriggerClosedContent
                    }
                    else
                    {
                        <Div Position="Quark.Position.Relative" Display="Quark.Display.Flex" Height="Quark.Height.Is8" Width='Quark.Width.Token("4")' ItemsAlign="Items.Center" Justify="Quark.Justify.Center">
                            <Div Position="Quark.Position.Relative" BoxSize="Quark.Size.Is4">
                                <Span Position="Quark.Position.Absolute" Display="Quark.Display.Block" Height='Quark.Height.Token("0.5")' Width='Quark.Width.Token("4")' BackgroundColor='Quark.BackgroundColor.Token("foreground")' Transition="Quark.Transition.All" Class="left-0 top-1 duration-100"></Span>
                                <Span Position="Quark.Position.Absolute" Display="Quark.Display.Block" Height='Quark.Height.Token("0.5")' Width='Quark.Width.Token("4")' BackgroundColor='Quark.BackgroundColor.Token("foreground")' Transition="Quark.Transition.All" Class="left-0 top-2.5 duration-100"></Span>
                            </Div>
                            <Span ScreenReader="Quark.ScreenReader.Only">@SidebarTriggerLabel</Span>
                        </Div>
                    }

                    <Span Display="Quark.Display.Flex" Height="Quark.Height.Is8" ItemsAlign="Items.Center" TextSize="Quark.TextSize.Lg" Leading="Quark.Leading.None" FontWeight="Quark.FontWeight.Medium">@SidebarTriggerText</Span>
                </button>
            }

            @if (BrandContent is not null)
            {
                @BrandContent
            }

            @if (NavigationContent is not null)
            {
                <nav class="@NavigationClassValue">
                    @NavigationContent
                </nav>
            }

            @if (ActionsContent is not null)
            {
                <Div Class="@ActionsClassValue">
                    @ActionsContent
                </Div>
            }
        </Div>
    </Div>
</header>

@code {
    private static readonly IReadOnlyList<QuarkPresetToken> DefaultContainerPresets = [QuarkPresets.ContainerWrapper];

    [CascadingParameter(Name = "SidebarProvider")]
    public SidebarProvider? SidebarProvider { get; set; }

    [CascadingParameter(Name = "SidebarContextState")]
    public SidebarContextState? SidebarState { get; set; }

    [Parameter]
    public bool ShowSidebarTrigger { get; set; }

    [Parameter]
    public string SidebarTriggerLabel { get; set; } = "Toggle Menu";

    [Parameter]
    public string SidebarTriggerText { get; set; } = "Menu";

    [Parameter]
    public string? SidebarTriggerControls { get; set; }

    [Parameter]
    public IReadOnlyList<QuarkPresetToken>? ContainerPresets { get; set; } = DefaultContainerPresets;

    [Parameter]
    public string ContainerClass { get; set; } = "px-6 group-has-data-[slot=designer]/layout:max-w-none 3xl:fixed:px-0";

    [Parameter]
    public string InnerClass { get; set; } = "flex min-h-12 h-(--header-height) items-center **:data-[slot=separator]:h-4! group-has-data-[slot=designer]/layout:fixed:max-w-none 3xl:fixed:container";

    [Parameter]
    public string SidebarTriggerClass { get; set; } = "shrink-0 rounded-md text-sm font-medium whitespace-nowrap transition-all outline-none focus-visible:border-ring focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 hover:text-accent-foreground px-4 py-2 has-[>svg]:px-3 extend-touch-target h-8 touch-manipulation items-center justify-start gap-2.5 p-0! hover:bg-transparent focus-visible:bg-transparent focus-visible:ring-0 active:bg-transparent dark:hover:bg-transparent flex lg:hidden";

    [Parameter]
    public string NavigationClass { get; set; } = "hidden items-center gap-0 lg:flex";

    [Parameter]
    public string ActionsClass { get; set; } = "ml-auto flex items-center gap-2 md:flex-1 md:justify-end";

    [Parameter]
    public RenderFragment? BrandContent { get; set; }

    [Parameter]
    public RenderFragment? NavigationContent { get; set; }

    [Parameter]
    public RenderFragment? ActionsContent { get; set; }

    [Parameter]
    public RenderFragment? SidebarTriggerOpenContent { get; set; }

    [Parameter]
    public RenderFragment? SidebarTriggerClosedContent { get; set; }

    private string ContainerClassValue => ClassNames.Combine(ContainerClass);
    private string InnerClassValue => ClassNames.Combine(InnerClass);
    private string NavigationClassValue => ClassNames.Combine(NavigationClass);
    private string ActionsClassValue => ClassNames.Combine(ActionsClass);
    private bool SidebarIsExpanded => SidebarState?.IsMobile == true ? SidebarState?.OpenMobile == true : SidebarState?.Open == true;

    private async Task HandleSidebarTriggerClick()
    {
        if (SidebarProvider is not null)
            await SidebarProvider.ToggleSidebar();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "header";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "sticky top-0 z-50 w-full bg-background");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ShowSidebarTrigger);
        hc.Add(SidebarTriggerLabel);
        hc.Add(SidebarTriggerText);
        hc.Add(SidebarTriggerControls);
        hc.Add(SidebarIsExpanded);
        if (ContainerPresets is { Count: > 0 })
        {
            for (var i = 0; i < ContainerPresets.Count; i++)
            {
                hc.Add(ContainerPresets[i]);
            }
        }
        hc.Add(ContainerClass);
        hc.Add(InnerClass);
        hc.Add(SidebarTriggerClass);
        hc.Add(NavigationClass);
        hc.Add(ActionsClass);
        hc.Add(BrandContent is not null);
        hc.Add(NavigationContent is not null);
        hc.Add(ActionsContent is not null);
        hc.Add(SidebarTriggerOpenContent is not null);
        hc.Add(SidebarTriggerClosedContent is not null);
    }
}
