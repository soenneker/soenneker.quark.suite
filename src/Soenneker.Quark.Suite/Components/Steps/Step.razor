@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids

@inherits Soenneker.Quark.Element
@implements IStep

<li @attributes="BuildAttributes()">
    <Anchor To="@GetHref()" PreventDefault="true" OnClick="HandleAnchorClick" @onkeydown="HandleKeyDown" @attributes="BuildAnchorAttributes()">
        @ChildContent
    </Anchor>
</li>

@code {
    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private StepsState? _parentStepsState;

    /// <summary>
    /// Gets or sets the index of the step.
    /// </summary>
    [Parameter]
    public int? Index { get; set; }

    /// <summary>
    /// Gets or sets whether the step is completed.
    /// </summary>
    [Parameter]
    public bool Completed { get; set; }

    [CascadingParameter(Name = nameof(ParentStepsState))]
    public StepsState? ParentStepsState
    {
        get => _parentStepsState;
        set
        {
            if (_parentStepsState == value)
                return;

            _parentStepsState = value;
        }
    }

    [CascadingParameter(Name = nameof(ParentSteps))]
    public Steps? ParentSteps { get; set; }

    private bool Active 
    { 
        get 
        {
            var isActive = _parentStepsState?.SelectedStep == Name && !string.IsNullOrEmpty(Name);
            return isActive;
        }
    }

    private bool IsClickable => !Disabled && Name.HasContent() && ParentSteps is not null;

    private string? _fallbackRoot;

    private string RootId => ParentStepsState?.RootId is { Length: > 0 } id ? id : (_fallbackRoot ??= BlazorIdGenerator.New("quark-steps"));

    private string StepId => BlazorIdGenerator.Child(RootId, Name.HasContent() ? $"tab-{Name}" : $"tab-{CalculatedIndex}");

    private string? PanelId => Name.HasContent() ? BlazorIdGenerator.Child(RootId, $"panel-{Name}") : null;

    private int CalculatedIndex => Index ?? ParentSteps?.IndexOfStep(Name ?? string.Empty) ?? 1;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Start;
        Flex ??= Quark.Flex.Is1;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "step";
        attributes["role"] = "presentation";
    }

    private Dictionary<string, object> BuildAnchorAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "step-link",
            ["data-active"] = Active ? "true" : "false",
            ["data-completed"] = Completed && !Active ? "true" : "false",
            ["data-disabled"] = Disabled ? "true" : "false",
            ["data-clickable"] = IsClickable ? "true" : "false",
            ["role"] = "tab",
            ["id"] = StepId,
            ["aria-selected"] = Active ? "true" : "false",
            ["aria-disabled"] = Disabled ? "true" : "false",
            ["aria-posinset"] = CalculatedIndex,
            ["aria-setsize"] = ParentSteps?.StepCount ?? 1,
            ["tabindex"] = Active ? 0 : -1
        };

        if (PanelId is not null)
            attributes["aria-controls"] = PanelId;
        if (Active)
            attributes["aria-current"] = "step";
        
        return attributes;
    }

    private Task HandleAnchorClick(MouseEventArgs args)
    {
        if (!IsClickable)
            return Task.CompletedTask;

        return HandleStepClick(args);
    }

    private string? GetHref()
    {
        return IsClickable && Name.HasContent() ? $"#{Name}" : null;
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (ParentSteps is null || Disabled || !Name.HasContent())
            return Task.CompletedTask;

        return ParentSteps.HandleStepKeyDown(Name!, args);
    }

    private async Task HandleStepClick(MouseEventArgs args)
    {
        await OnClick.InvokeAsync(args);

        if (ParentSteps != null && Name.HasContent())
        {
            await ParentSteps.SelectStep(Name);
        }
    }

    protected override void OnInitialized()
    {
        ParentSteps?.NotifyStepInitialized(Name ?? string.Empty, Disabled);
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        ParentSteps?.NotifyStepInitialized(Name ?? string.Empty, Disabled);
        base.OnParametersSet();
    }

    public override void Dispose()
    {
        ParentSteps?.NotifyStepRemoved(Name ?? string.Empty);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Name);
        hc.Add(Completed);
        hc.Add(Disabled);
        hc.Add(OnClick.HasDelegate);
        if (_parentStepsState?.SelectedStep is not null)
            hc.Add(_parentStepsState.SelectedStep);
    }
}
