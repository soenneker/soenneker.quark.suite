@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Microsoft.AspNetCore.Components.Routing
@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids
@implements ISteps
@inject IStepsInterop StepsInterop
@inject NavigationManager Navigation

    <CascadingValue Name="ParentStepsState" Value="_state">
    <CascadingValue Name="ParentSteps" Value="this">
        <Div data-slot="steps-container" Display="Quark.Display.Flex" Width="Quark.Width.IsFull" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is4">
            <ul @attributes="BuildAttributes()">
                @if (Items != null)
                {
                    @Items
                }
                else
                {
                    @ChildContent
                }
            </ul>
        </Div>
    </CascadingValue>
</CascadingValue>

@code {
    private readonly string _rootId = BlazorIdGenerator.New("quark-steps");
    private StepsState _state = new();

    private readonly List<string> _stepItems = [];
    private readonly List<string> _stepPanels = [];
    private readonly HashSet<string> _disabledSteps = [];
    private bool _navigationSubscribed;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(_state.RootId))
            _state = _state with { RootId = _rootId };

        base.OnInitialized();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await StepsInterop.Initialize();

            // Sync initial selection from URL fragment if present
            var fragment = GetFragment();
            if (fragment.HasContent() && _stepItems.Contains(fragment) && fragment != _state.SelectedStep)
            {
                await SetSelectedStep(fragment, notifyChanged: true);
            }

            // Subscribe to fragment changes
            if (!_navigationSubscribed)
            {
                Navigation.LocationChanged += HandleLocationChanged;
                _navigationSubscribed = true;
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    /// <summary>
    /// Gets or sets the currently selected step.
    /// </summary>
    [Parameter]
    public string SelectedStep { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the render mode for the steps.
    /// </summary>
    [Parameter]
    public StepsRenderMode RenderMode { get; set; } = StepsRenderMode.Default;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        FlexWrap ??= Quark.FlexWrap.Wrap;
        ItemsAlign ??= Quark.Items.Start;
        Margin ??= Quark.Margin.Is0;
        Padding ??= Quark.Padding.Is0;
        Width ??= Quark.Width.IsFull;
        Position ??= Quark.Position.Relative;
    }

    protected override Task OnParametersSetAsync()
    {
        if (SelectedStep != _state.SelectedStep)
            TryUpdateSelectedStepState(SelectedStep);

        if (RenderMode != _state.RenderMode)
        {
            _state = _state with { RenderMode = RenderMode };
            InvalidateRender();
        }

        return base.OnParametersSetAsync();
    }

    /// <summary>
    /// Gets or sets the callback invoked When the selected step changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> SelectedStepChanged { get; set; }

    /// <summary>
    /// Gets or sets the function that determines whether navigation to a step is allowed.
    /// </summary>
    [Parameter]
    public Func<StepNavigationContext, bool>? NavigationAllowed { get; set; }

    /// <summary>
    /// Gets or sets whether successful step navigation updates the current URL fragment.
    /// </summary>
    [Parameter]
    public bool UpdateUrlFragment { get; set; } = true;

    /// <summary>
    /// Gets or sets the render fragment for step items.
    /// </summary>
    [Parameter]
    public RenderFragment? Items { get; set; }

    /// <summary>
    /// Notifies that a step has been initialized.
    /// </summary>
    /// <param name="name">The name of the step.</param>
    /// <param name="disabled">Whether the step is disabled.</param>
    internal void NotifyStepInitialized(string name, bool disabled = false)
    {
        if (disabled)
            _disabledSteps.Add(name);
        else
            _disabledSteps.Remove(name);

        if (!_stepItems.Contains(name))
        {
            _stepItems.Add(name);

            // Set initial selected step if not already set
            if (string.IsNullOrEmpty(_state.SelectedStep))
            {
                var fragment = GetFragment();
                var initial = fragment.HasContent() && _stepItems.Contains(fragment) && IsStepEnabled(fragment) ? fragment : GetFirstEnabledStep() ?? name;
                if (TryUpdateSelectedStepState(initial))
                    Refresh();
            }
        }
    }

    /// <summary>
    /// Notifies that a step has been removed.
    /// </summary>
    /// <param name="name">The name of the step.</param>
    internal void NotifyStepRemoved(string name)
    {
        if (_stepItems.Contains(name))
            _stepItems.Remove(name);

        _disabledSteps.Remove(name);
    }

    /// <summary>
    /// Selects the specified step.
    /// </summary>
    /// <param name="stepName">The name of the step to select.</param>
    /// <returns>A task that represents the asynchronous operation.</returns>
    public Task SelectStep(string stepName)
    {
        return SetSelectedStep(stepName, notifyChanged: true);
    }

    /// <summary>
    /// Moves to the next step.
    /// </summary>
    /// <returns>A task that represents the asynchronous operation.</returns>
    public Task NextStep()
    {
        var nextStep = GetAdjacentEnabledStep(_state.SelectedStep, 1, wrap: false);
        if (!nextStep.HasContent())
            return Task.CompletedTask;

        return SetSelectedStep(nextStep, notifyChanged: true);
    }

    /// <summary>
    /// Moves to the previous step.
    /// </summary>
    /// <returns>A task that represents the asynchronous operation.</returns>
    public Task PreviousStep()
    {
        var previousStep = GetAdjacentEnabledStep(_state.SelectedStep, -1, wrap: false);
        if (!previousStep.HasContent())
            return Task.CompletedTask;

        return SetSelectedStep(previousStep, notifyChanged: true);
    }

    /// <summary>
    /// Gets the index of the specified step.
    /// </summary>
    /// <param name="name">The name of the step.</param>
    /// <returns>The 1-based index of the step.</returns>
    public int IndexOfStep(string name)
    {
        return _stepItems.IndexOf(name) + 1;
    }

    internal int StepCount => _stepItems.Count;

    internal async Task HandleStepKeyDown(string currentName, KeyboardEventArgs args)
    {
        if (_stepItems.Count == 0 || string.IsNullOrWhiteSpace(currentName))
            return;

        var next = args.Key switch
        {
            "ArrowRight" or "ArrowDown" => GetAdjacentEnabledStep(currentName, 1),
            "ArrowLeft" or "ArrowUp" => GetAdjacentEnabledStep(currentName, -1),
            "Home" => GetFirstEnabledStep(),
            "End" => GetLastEnabledStep(),
            _ => null
        };

        if (!next.HasContent() || next == _state.SelectedStep)
            return;

        await SetSelectedStep(next, notifyChanged: true);
        await StepsInterop.FocusById(GetStepTabId(next));
    }

    /// <summary>
    /// Notifies that a step panel has been initialized.
    /// </summary>
    /// <param name="name">The name of the step panel.</param>
    internal void NotifyStepPanelInitialized(string name)
    {
        if (!_stepPanels.Contains(name))
            _stepPanels.Add(name);
    }

    /// <summary>
    /// Notifies that a step panel has been removed.
    /// </summary>
    /// <param name="name">The name of the step panel.</param>
    internal void NotifyStepPanelRemoved(string name)
    {
        if (_stepPanels.Contains(name))
            _stepPanels.Remove(name);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "steps";
        attributes["role"] = "tablist";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "justify-between");
            AppendClass(ref cls, "list-none");
            AppendClass(ref cls, "gap-y-6");

            if (RenderMode == StepsRenderMode.LazyLoad)
                attributes["data-render-mode"] = "lazy-load";
            else if (RenderMode == StepsRenderMode.LazyReload)
                attributes["data-render-mode"] = "lazy-reload";
        });
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        _ = HandleLocationChanged(args);
    }

    private async Task HandleLocationChanged(LocationChangedEventArgs args)
    {
        var fragment = GetFragment(args.Location);
        if (!fragment.HasContent())
            return;

        if (_stepItems.Contains(fragment) && fragment != _state.SelectedStep)
        {
            await SetSelectedStep(fragment, notifyChanged: true);
        }
    }

    private string GetFragment(string? uri = null)
    {
        var current = uri ?? Navigation.Uri;
        try
        {
            var u = new Uri(current);
            var frag = u.Fragment;
            return string.IsNullOrEmpty(frag) ? string.Empty : Uri.UnescapeDataString(frag.TrimStart('#'));
        }
        catch
        {
            return string.Empty;
        }
    }

    private string GetStepTabId(string name)
    {
        return BlazorIdGenerator.Child(_state.RootId.HasContent() ? _state.RootId : _rootId, $"tab-{name}");
    }

    private string? GetFirstEnabledStep()
    {
        return _stepItems.FirstOrDefault(IsStepEnabled);
    }

    private string? GetLastEnabledStep()
    {
        for (var i = _stepItems.Count - 1; i >= 0; i--)
        {
            if (IsStepEnabled(_stepItems[i]))
                return _stepItems[i];
        }

        return null;
    }

    private string? GetAdjacentEnabledStep(string currentName, int direction, bool wrap = true)
    {
        var currentIndex = _stepItems.IndexOf(currentName);
        if (currentIndex < 0)
            return null;

        for (var offset = 1; offset < _stepItems.Count; offset++)
        {
            var nextIndex = currentIndex + (offset * direction);
            if (wrap)
            {
                nextIndex %= _stepItems.Count;
                if (nextIndex < 0)
                    nextIndex += _stepItems.Count;
            }
            else if (nextIndex < 0 || nextIndex >= _stepItems.Count)
            {
                return null;
            }

            var candidate = _stepItems[nextIndex];
            if (IsStepEnabled(candidate))
                return candidate;
        }

        return null;
    }

    private bool IsStepEnabled(string name)
    {
        return _disabledSteps.Contains(name) == false;
    }

    public override void Dispose()
    {
        if (_navigationSubscribed)
        {
            Navigation.LocationChanged -= HandleLocationChanged;
            _navigationSubscribed = false;
        }

        base.Dispose();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AriaDescribedBy);
        hc.Add(SelectedStep);
        hc.Add(RenderMode);
        hc.Add(UpdateUrlFragment);
        hc.Add(Items is not null);
    }

    private bool TryUpdateSelectedStepState(string value)
    {
        if (value == _state.SelectedStep)
            return false;

        if (!IsStepEnabled(value))
            return false;

        var allowNavigation = NavigationAllowed?.Invoke(new StepNavigationContext
        {
            CurrentStepName = _state.SelectedStep,
            CurrentStepIndex = IndexOfStep(_state.SelectedStep),
            NextStepName = value,
            NextStepIndex = IndexOfStep(value),
        }) ?? true;

        if (!allowNavigation)
        {
            SelectedStep = _state.SelectedStep;
            return false;
        }

        _state = _state with { SelectedStep = value, RenderMode = RenderMode };
        SelectedStep = value;
        InvalidateRender();
        return true;
    }

    private async Task SetSelectedStep(string value, bool notifyChanged)
    {
        if (!TryUpdateSelectedStepState(value))
            return;

        if (notifyChanged)
            await SelectedStepChanged.InvokeIfHasDelegate(_state.SelectedStep);

        UpdateFragment(value);
        await RefreshOffThread();
    }

    private void UpdateFragment(string value)
    {
        if (!UpdateUrlFragment || !value.HasContent() || GetFragment() == value)
            return;

        var current = Navigation.ToAbsoluteUri(Navigation.Uri);
        var next = $"{current.GetLeftPart(UriPartial.Path)}{current.Query}#{Uri.EscapeDataString(value)}";
        Navigation.NavigateTo(next);
    }
}
