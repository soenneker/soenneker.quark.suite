@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IStepContent

<CascadingValue Name="ParentStepContentState" Value="_state">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
    
</CascadingValue>

@code {
    private StepsContentState _state = new();
    private readonly List<string> _stepPanels = [];
    private StepsState? _parentStepsState;

    /// <summary>
    /// Gets or sets the currently selected panel.
    /// </summary>
    [Parameter]
    public string SelectedPanel { get; set; } = string.Empty;

    /// <summary>
    /// Gets or sets the callback invoked When the selected panel changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> SelectedPanelChanged { get; set; }

    [CascadingParameter(Name = nameof(ParentStepsState))]
    public StepsState? ParentStepsState
    {
        get => _parentStepsState;
        set
        {
            if (_parentStepsState == value)
                return;

            _parentStepsState = value;

            // Sync with the parent Steps component's selected step
            if (_parentStepsState != null && _parentStepsState.SelectedStep != _state.SelectedPanel)
            {
                _state = _state with { SelectedPanel = _parentStepsState.SelectedStep };
                SelectedPanel = _state.SelectedPanel;
                InvalidateRender();
                Refresh();
            }
        }
    }

    /// <summary>
    /// Notifies that a step panel has been initialized.
    /// </summary>
    /// <param name="name">The name of the step panel.</param>
    internal void NotifyStepPanelInitialized(string name)
    {
        if (!_stepPanels.Contains(name))
            _stepPanels.Add(name);
    }

    /// <summary>
    /// Notifies that a step panel has been removed.
    /// </summary>
    /// <param name="name">The name of the step panel.</param>
    internal void NotifyStepPanelRemoved(string name)
    {
        if (_stepPanels.Contains(name))
            _stepPanels.Remove(name);
    }

    /// <summary>
    /// Selects the specified panel.
    /// </summary>
    /// <param name="name">The name of the panel to select.</param>
    /// <returns>A task that represents the asynchronous operation.</returns>
    public Task SelectPanel(string name)
    {
        return SetSelectedPanelAsync(name, notifyChanged: true);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Block;
        Margin ??= Quark.Margin.Is3.FromTop;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "steps-content";
    }

    protected override Task OnParametersSetAsync()
    {
        if (SelectedPanel != _state.SelectedPanel)
        {
            _state = _state with { SelectedPanel = SelectedPanel };
            InvalidateRender();
        }

        return base.OnParametersSetAsync();
    }

    private async Task SetSelectedPanelAsync(string name, bool notifyChanged)
    {
        if (name == _state.SelectedPanel)
            return;

        _state = _state with { SelectedPanel = name };
        SelectedPanel = _state.SelectedPanel;

        if (notifyChanged)
            await SelectedPanelChanged.InvokeAsync(_state.SelectedPanel);

        InvalidateRender();
        await RefreshOffThread();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedPanel);
    }
}
