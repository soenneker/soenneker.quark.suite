@namespace Soenneker.Quark
@inject NavigationManager Navigation

@if (ReferenceEquals(Mode, NavigationLinksMode.Header))
{
    @foreach (var item in Items)
    {
        @if (item.Href is not null)
        {
            <Anchor Href="@item.Href"
                    data-slot="button"
                    data-variant="ghost"
                    data-size="sm"
                    data-active="@IsItemActive(item).ToString().ToLowerInvariant()"
                    data-new="@item.IsNew.ToString().ToLowerInvariant()"
                    aria-current="@(IsItemActive(item) ? "page" : null)"
                    class="@GetHeaderItemClass(item)">
                @item.Title
            </Anchor>
        }
        else
        {
            <Span DataSlot="button"
                  data-variant="ghost"
                  data-size="sm"
                  data-active="false"
                  data-new="@item.IsNew.ToString().ToLowerInvariant()"
                  class="@($"{GetHeaderItemClass(item)} opacity-75")">
                @item.Title
            </Span>
        }
    }
}
else if (ReferenceEquals(Mode, NavigationLinksMode.Stack))
{
    <Div Display="Quark.Display.Flex" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is4">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <Div TextSize="Quark.TextSize.Sm" FontWeight="Quark.FontWeight.Medium" TextColor="Quark.TextColor.MutedForeground">@Title</Div>
        }

        <Div Display="Quark.Display.Flex" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is3">
            @foreach (var item in Items)
            {
                @if (item.Href is not null)
                {
                    <Anchor Href="@item.Href" PreventDefault="@ShouldHandleStackNavigation(item)" OnClick="@(() => HandleStackItemClick(item))" aria-current="@(IsItemActive(item) ? "page" : null)" class="@GetStackItemClass(item)">
                        @item.Title
                        @if (item.IsNew)
                        {
                            <Span Size="Quark.Size.Is2" Display="Quark.Display.Flex" Rounded="Quark.Rounded.Full" BackgroundColor='Quark.BackgroundColor.Utility("blue-500")' title="New"></Span>
                        }
                    </Anchor>
                }
                else
                {
                    <Span class="@($"{GetStackItemClass(item)} opacity-70")">
                        @item.Title
                    </Span>
                }
            }
        </Div>
    </Div>
}
else
{
    <SidebarGroup Class="@GroupClass">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <SidebarGroupLabel>@Title</SidebarGroupLabel>
        }

        <SidebarGroupContent>
            <SidebarMenu>
                @foreach (var item in Items)
                {
                    <SidebarMenuItem>
                        @if (item.Href is not null)
                        {
                            <SidebarMenuButton To="@item.Href"
                                               Active="@IsItemActive(item)"
                                               aria-current="@(IsItemActive(item) ? "page" : null)"
                                               Variant="SidebarMenuButtonVariant.Navigation">
                                <Span>@item.Title</Span>
                                @if (item.IsNew)
                                {
                                    <Span Size="Quark.Size.Is2" Display="Quark.Display.Flex" Rounded="Quark.Rounded.Full" BackgroundColor='Quark.BackgroundColor.Utility("blue-500")' title="New"></Span>
                                }
                            </SidebarMenuButton>
                        }
                        else
                        {
                            <SidebarMenuButton Variant="SidebarMenuButtonVariant.Navigation"
                                               Opacity="Opacity.Is70"
                                               aria-disabled="true"
                                               tabindex="-1">
                                <Span>@item.Title</Span>
                                @if (item.IsNew)
                                {
                                    <Span Size="Quark.Size.Is2" Display="Quark.Display.Flex" Rounded="Quark.Rounded.Full" BackgroundColor='Quark.BackgroundColor.Utility("blue-500")' title="New"></Span>
                                }
                            </SidebarMenuButton>
                        }
                    </SidebarMenuItem>
                }
            </SidebarMenu>
        </SidebarGroupContent>
    </SidebarGroup>
}

@code {
    [CascadingParameter(Name = "SidebarProvider")]
    public SidebarProvider? SidebarProvider { get; set; }

    [CascadingParameter(Name = "SidebarContextState")]
    public Soenneker.Quark.Dtos.SidebarContextState? SidebarState { get; set; }

    [Parameter]
    public IEnumerable<NavigationItem> Items { get; set; } = [];

    [Parameter]
    public NavigationLinksMode Mode { get; set; } = NavigationLinksMode.Sidebar;

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? GroupClass { get; set; }

    [Parameter]
    public Func<NavigationItem, bool>? IsActive { get; set; }

    private string? _navigationTargetAfterClose;

    private bool IsItemActive(NavigationItem item)
    {
        return IsActive?.Invoke(item) ?? false;
    }

    private async Task HandleStackItemClick(NavigationItem item)
    {
        if (!ShouldHandleStackNavigation(item))
            return;

        await CloseAndNavigateStackItem(item);
    }

    private async Task CloseAndNavigateStackItem(NavigationItem item)
    {
        var href = item.Href;

        if (!href.HasContent())
            return;

        _navigationTargetAfterClose = GetNavigationTarget(href);
        await SidebarProvider!.SetOpenMobile(false);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (_navigationTargetAfterClose is null || SidebarState?.OpenMobile == true)
            return;

        var target = _navigationTargetAfterClose;
        _navigationTargetAfterClose = null;
        Navigation.NavigateTo(target);
    }

    private string GetNavigationTarget(string href)
    {
        return href is "." or "./"
            ? Navigation.BaseUri
            : href;
    }

    private bool ShouldHandleStackNavigation(NavigationItem item)
    {
        return CanCoordinateStackNavigation(item) &&
               SidebarState?.OpenMobile == true;
    }

    private bool CanCoordinateStackNavigation(NavigationItem item)
    {
        return item.Href.HasContent() &&
               SidebarProvider is not null &&
               !item.Href!.StartsWith('#') &&
               !Uri.TryCreate(item.Href, UriKind.Absolute, out _);
    }

    private string GetHeaderItemClass(NavigationItem item)
    {
        const string baseClass = "inline-flex shrink-0 items-center justify-center text-sm font-medium whitespace-nowrap transition-all outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50 h-8 gap-1.5 rounded-md has-[>svg]:px-2.5 px-2.5 relative items-center";

        return IsItemActive(item)
            ? $"{baseClass} bg-accent text-accent-foreground dark:bg-accent/50"
            : baseClass;
    }

    private string GetStackItemClass(NavigationItem item)
    {
        const string baseClass = "inline-flex items-center gap-2 text-2xl leading-none font-medium transition-all";

        return IsItemActive(item)
            ? $"{baseClass} text-foreground"
            : $"{baseClass} text-foreground hover:text-foreground/80";
    }
}
