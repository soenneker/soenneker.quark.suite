@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        SetDefaultDataSlot("message-markdown");

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "prose max-w-none text-primary font-normal text-sm leading-6.5");
            AppendClass(ref cls, "prose-headings:font-[450] prose-headings:leading-5.5 prose-h2:tracking-[-0.45px] prose-headings:mb-4 prose-headings:mt-6 prose-h1:text-xl prose-h2:text-lg prose-h3:text-base prose-h3:leading-4.5 prose-h3:tracking-[-0.4px] prose-h4:text-sm prose-h5:text-xs prose-h6:text-xs");
            AppendClass(ref cls, "prose-p:mb-1 prose-p:mt-4 prose-li:my-[-0.5px] prose-li:marker:text-muted-foreground/50 prose-ul:my-0 prose-ol:my-0 prose-ol:pl-3");
            AppendClass(ref cls, "[&>*:first-child]:mt-0 [&>*:last-child]:mb-0");
        });
    }
}
