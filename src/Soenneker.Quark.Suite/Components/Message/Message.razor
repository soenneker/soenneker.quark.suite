@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Value="@Context" IsFixed="false">
    <div @attributes="BuildAttributes()">@ChildContent</div>
</CascadingValue>

@code {
    private MessageContext Context => new(From);

    [Parameter]
    public string From { get; set; } = "assistant";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "message";
        Role ??= "article";
        AriaLabel ??= From == "user" ? "User message" : "Assistant message";
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        MaxWidth ??= Quark.MaxWidth.Token("[90%]");
        ItemsAlign ??= Quark.Items.Start;
        Gap ??= Quark.Gap.Is2;
        Margin ??= From == "user" ? Quark.Margin.FromStart.Auto : Quark.Margin.FromEnd.Auto;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-from"] = From;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/message");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(From);
    }
}
