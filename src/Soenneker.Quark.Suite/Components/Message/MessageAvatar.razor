@namespace Soenneker.Quark
@inherits Soenneker.Quark.Component

<Avatar AvatarSize="@AvatarSize" Attributes="@BuildAttributes()">
    <AvatarImage Src="@Src" Alt="@Alt" Margin='Quark.Margin.OnY.Token("0!")' Attributes="@ImageAttributes" />
    <AvatarFallback Margin='Quark.Margin.OnY.Token("0!")' Shrink="Quark.Shrink.Is0" Attributes="@FallbackAttributes">@Fallback</AvatarFallback>
</Avatar>

@code {
    [Parameter]
    public string? Src { get; set; }

    [Parameter]
    public string Alt { get; set; } = "";

    [Parameter]
    public RenderFragment? Fallback { get; set; }

    [Parameter]
    public string AvatarSize { get; set; } = "default";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Size ??= Quark.Size.Is7;
        Shrink ??= Quark.Shrink.Is0;
    }

    private static readonly IReadOnlyDictionary<string, object> ImageAttributes = new Dictionary<string, object>
    {
        ["data-slot"] = "message-avatar-image"
    };

    private static readonly IReadOnlyDictionary<string, object> FallbackAttributes = new Dictionary<string, object>
    {
        ["data-slot"] = "message-avatar-fallback"
    };
}
