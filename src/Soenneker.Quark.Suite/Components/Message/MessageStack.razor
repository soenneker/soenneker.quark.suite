@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "message-stack";
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        FlexDirection ??= Quark.FlexDirection.Col;
        Gap ??= Quark.Gap.Is2;
        ItemsAlign ??= From == "user" ? Quark.Items.End : Quark.Items.Start;
    }

    [CascadingParameter]
    private MessageContext? MessageContext { get; set; }

    private string From => MessageContext?.From ?? "assistant";

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(From);
    }
}
