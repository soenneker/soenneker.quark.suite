@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "message-content";
        Rounded ??= Quark.Rounded.Token("[20px]");
        TextSize ??= Quark.TextSize.Sm;
        Leading ??= Quark.Leading.Token("6.5");
        TextColor ??= Quark.TextColor.Primary;

        if (From == "user")
        {
            Width ??= Quark.Width.IsFit;
            BackgroundColor ??= Quark.BackgroundColor.Muted;
            Padding ??= Quark.Padding.OnX.Is4.OnY.Is2;
        }
        else
        {
            Width ??= Quark.Width.IsFull;
            BackgroundColor ??= Quark.BackgroundColor.Transparent;
            Padding ??= Quark.Padding.OnX.Is2;
            Margin ??= Quark.Margin.Is2.FromBottom;
        }
    }

    [CascadingParameter]
    private MessageContext? MessageContext { get; set; }

    private string From => MessageContext?.From ?? "assistant";

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(From);
    }
}
