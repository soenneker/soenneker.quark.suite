@namespace Soenneker.Quark
@inherits TriggerElement
@implements IButton
@inject NavigationManager Navigation
@inject ICollapseCoordinator CollapseCoordinator

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else if (RenderAsLink)
{
    <a href="@To" @ref="_elementRef" @onclick="HandleClick" @onclick:preventDefault="PreventLinkDefault" @onclick:stopPropagation="StopClickPropagation" @attributes="BuildAttributes()">
        @if (Loading)
        {
            <span class="animate-spin size-4 mr-2 inline-block rounded-full border-2 border-current border-t-transparent" role="status" aria-hidden="true"></span>
        }
        @if (LoadingTemplate is not null && Loading)
        {
            @LoadingTemplate
        }
        else
        {
            @RenderChildContent()
        }
    </a>
}
else
{
    <button @ref="_elementRef" @onclick="HandleClick" @onclick:stopPropagation="StopClickPropagation" @attributes="BuildAttributes()">
        @if (Loading)
        {
            <span class="animate-spin size-4 mr-2 inline-block rounded-full border-2 border-current border-t-transparent" role="status" aria-hidden="true"></span>
        }
        @if (LoadingTemplate is not null && Loading)
        {
            @LoadingTemplate
        }
        else
        {
            @RenderChildContent()
        }
    </button>
}

@code {

    [CascadingParameter]
    public IButtonGroup? ButtonGroup { get; set; }

    [CascadingParameter(Name = "TriggerContext")]
    private TriggerContext? TriggerContext { get; set; }

    private ElementReference _elementRef;
    private bool _triggerElementRegistered;
    private string? _registeredTriggerId;

    private bool RenderAsLink => string.Equals(Type?.Value, "link", StringComparison.Ordinal) || To.HasContent();

    private bool PreventLinkDefault =>
        Disabled || Loading || CollapseTarget.HasContent() || TriggerContext?.Toggle is not null || (To.HasContent() && !To!.StartsWith("#", StringComparison.Ordinal));

    private bool StopClickPropagation => TriggerContext?.Toggle is not null || IsInputGroupButton();

    private static readonly TriggerContext? NoTriggerContext = null;

    private bool IsInputGroupButton()
    {
        return Attributes is not null &&
               Attributes.TryGetValue("data-slot", out var dataSlot) &&
               string.Equals(dataSlot?.ToString(), "input-group-button", StringComparison.Ordinal);
    }

    /// <summary>
    /// Gets or sets the size of the button (shadcn: default, xs, sm, lg, icon, icon-xs, icon-sm, icon-lg).
    /// </summary>
    [Parameter]
    public CssValue<ButtonSizeBuilder>? Size { get; set; } = ButtonSize.Default;

    /// <summary>
    /// Gets or sets whether the button should span the full width of its container.
    /// </summary>
    [Parameter]
    public bool Block { get; set; }

    /// <summary>
    /// Gets or sets whether the child component should receive button styling directly.
    /// </summary>
    [Parameter]
    public bool AsChild { get; set; }

    /// <summary>
    /// Gets or sets whether the button is in a loading state (opinionated extension with shadcn styling).
    /// </summary>
    [Parameter]
    public bool Loading { get; set; }

    /// <summary>
    /// Gets or sets the type of the button (button, submit, reset, or link).
    /// </summary>
    [Parameter]
    public ButtonType Type { get; set; } = ButtonType.Button;

    /// <summary>
    /// Gets or sets the template to display When the button is in a loading state.
    /// </summary>
    [Parameter]
    public RenderFragment? LoadingTemplate { get; set; }

    /// <summary>
    /// Gets or sets the button value submitted with a form.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Gets or sets the button name submitted with a form.
    /// </summary>
    [Parameter]
    public string? Name { get; set; }

    /// <summary>
    /// Gets or sets the form ID that this button is associated with.
    /// </summary>
    [Parameter]
    public string? Form { get; set; }

    /// <summary>
    /// Gets or sets the navigation target URL When the button type is Link.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    /// <summary>
    /// Gets or sets the visual style variant (shadcn/ui).
    /// </summary>
    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    /// <summary>
    /// Gets or sets one or more collapse targets (id, #id, .class, or space/comma-delimited list).
    /// </summary>
    [Parameter]
    public string? CollapseTarget { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.InlineFlex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;

        if (Block)
            Width ??= Quark.Width.IsFull;

    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (TriggerContext?.RegisterElement is not null && (!_triggerElementRegistered || !string.Equals(_registeredTriggerId, TriggerContext.TriggerId, StringComparison.Ordinal)))
        {
            TriggerContext.RegisterElement(_elementRef);
            _triggerElementRegistered = true;
            _registeredTriggerId = TriggerContext.TriggerId;
        }

        return base.OnAfterRenderAsync(firstRender);
    }

    /// <summary>
    /// Builds the attributes dictionary for the button component.
    /// </summary>
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes.Remove("onclick");

        var isLink = RenderAsLink;
        var isDisabled = Disabled || Loading || TriggerContext?.ParentDisabled == true || attributes.ContainsKey("disabled");

        if (!attributes.ContainsKey("data-slot"))
            attributes["data-slot"] = TriggerContext?.DataSlot ?? "button";

        attributes["data-variant"] = Variant?.Value ?? ButtonVariant.Default.Value;

        var effectiveSize = Size ?? ButtonGroup?.Size ?? "default";
        attributes["data-size"] = GetButtonSizeDataAttribute(effectiveSize);

        if (isLink)
        {
            attributes.Remove("autofocus");
            attributes.Remove("disabled");
        }

        if (isLink && isDisabled)
            attributes.TryAdd("tabindex", -1);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, GetButtonFocusClass(Variant));
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, GetButtonVariantClass(Variant));
            AppendClass(ref cls, GetButtonSizeClass(effectiveSize));

            if (isLink && isDisabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });

        if (Loading)
            attributes["aria-busy"] = "true";

        if (CollapseTarget.HasContent())
            attributes["aria-controls"] = CollapseTarget!;

        if (TriggerContext is not null)
        {
            if (TriggerContext.TriggerId is not null)
                attributes["id"] = TriggerContext.TriggerId;

            if (TriggerContext.DataState is not null)
                attributes["data-state"] = TriggerContext.DataState;

            if (TriggerContext.AriaHasPopup is not null)
                attributes["aria-haspopup"] = TriggerContext.AriaHasPopup;

            if (TriggerContext.AriaControls is not null)
            {
                attributes["aria-expanded"] = TriggerContext.IsOpen ? "true" : "false";
                attributes["aria-controls"] = TriggerContext.AriaControls;
            }

            if (TriggerContext.AriaDescribedBy is not null)
                attributes["aria-describedby"] = TriggerContext.AriaDescribedBy;

            if (TriggerContext.ParentDisabled)
                attributes["data-disabled"] = "true";
        }

        if (!isLink)
            attributes["type"] = Type?.Value ?? "button";

        if (isLink)
        {
            if (isDisabled)
                attributes["aria-disabled"] = "true";
        }
        else
        {
            if (isDisabled)
                attributes["disabled"] = true;
        }

        if (Value.HasContent())
            attributes["value"] = Value!;
        if (Name.HasContent())
            attributes["name"] = Name!;
        if (Form.HasContent())
            attributes["form"] = Form!;
    }

    protected override void BuildOwnedAttributes(Dictionary<string, object> attributes)
    {
        base.BuildOwnedAttributes(attributes);

        if (TriggerContext?.OnMouseEnter is not null)
            attributes["onmouseenter"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleTriggerMouseEnter);

        if (TriggerContext?.OnMouseMove is not null)
            attributes["onmousemove"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleTriggerMouseMove);

        if (TriggerContext?.OnMouseLeave is not null)
            attributes["onmouseleave"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleTriggerMouseLeave);

        if (TriggerContext?.OnPointerMove is not null)
            attributes["onpointermove"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandleTriggerPointerMove);

        if (TriggerContext?.OnPointerLeave is not null)
            attributes["onpointerleave"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandleTriggerPointerLeave);

        if (TriggerContext?.OnPointerDown is not null)
            attributes["onpointerdown"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandleTriggerPointerDown);

        if (TriggerContext?.OnPointerUp is not null)
            attributes["onpointerup"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandleTriggerPointerUp);

        if (TriggerContext?.OnFocusIn is not null)
            attributes["onfocusin"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleTriggerFocusIn);

        if (TriggerContext?.OnFocusOut is not null)
            attributes["onfocusout"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleTriggerFocusOut);

        if (TriggerContext?.OnKeyDown is not null)
            attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleTriggerKeyDown);
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        var attributes = new Dictionary<string, object>(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("disabled");
        attributes.Remove("form");
        attributes.Remove("name");
        attributes.Remove("value");

        return attributes;
    }

    private RenderFragment? RenderChildContent()
    {
        if (TriggerContext is null || ChildContent is null)
            return ChildContent;

        return @<CascadingValue Name="TriggerContext" Value="@NoTriggerContext" IsFixed="true">
                   @ChildContent
               </CascadingValue>;
    }

    protected override async Task HandleClick(MouseEventArgs args)
    {
        var isDisabled = Disabled || Loading || TriggerContext?.ParentDisabled == true || (Attributes is not null && Attributes.ContainsKey("disabled"));
        if (isDisabled)
            return;

        if (TriggerContext?.OnClick is not null)
            await TriggerContext.OnClick();

        if (TriggerContext?.Toggle is not null)
            await TriggerContext.Toggle();

        if (To.HasContent() && !To!.StartsWith("#"))
            Navigation.NavigateTo(To!);

        if (CollapseTarget.HasContent())
            await CollapseCoordinator.ToggleTargets(CollapseTarget);
        else if (Attributes is not null && Attributes.TryGetValue("data-toggle", out var dataToggleObj) && string.Equals(dataToggleObj?.ToString(), "collapse", StringComparison.OrdinalIgnoreCase) && Attributes.TryGetValue("data-target", out var dataTargetObj))
            await CollapseCoordinator.ToggleTargets(dataTargetObj?.ToString());

        await InvokeCapturedClick(args);
        await base.HandleClick(args);
    }

    private async Task InvokeCapturedClick(MouseEventArgs args)
    {
        if (Attributes is null || !Attributes.TryGetValue("onclick", out var callback) || callback is null)
            return;

        switch (callback)
        {
            case EventCallback<MouseEventArgs> eventCallback when eventCallback.HasDelegate:
                await eventCallback.InvokeAsync(args);
                break;
            case EventCallback eventCallback when eventCallback.HasDelegate:
                await eventCallback.InvokeAsync(args);
                break;
            case Func<MouseEventArgs, Task> func:
                await func(args);
                break;
            case Func<Task> func:
                await func();
                break;
            case Action<MouseEventArgs> action:
                action(args);
                break;
            case Action action:
                action();
                break;
        }
    }

    private Task HandleTriggerMouseEnter(MouseEventArgs args)
    {
        return TriggerContext?.OnMouseEnter?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerMove(PointerEventArgs args)
    {
        return TriggerContext?.OnPointerMove?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerMouseMove(MouseEventArgs args)
    {
        return TriggerContext?.OnMouseMove?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerMouseLeave(MouseEventArgs args)
    {
        return TriggerContext?.OnMouseLeave?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerLeave(PointerEventArgs args)
    {
        return TriggerContext?.OnPointerLeave?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerDown(PointerEventArgs args)
    {
        return TriggerContext?.OnPointerDown?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerUp(PointerEventArgs args)
    {
        return TriggerContext?.OnPointerUp?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerFocusIn(FocusEventArgs args)
    {
        return TriggerContext?.OnFocusIn?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerFocusOut(FocusEventArgs args)
    {
        return TriggerContext?.OnFocusOut?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerKeyDown(KeyboardEventArgs args)
    {
        return TriggerContext?.OnKeyDown?.Invoke(args) ?? Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Size);
        hc.Add(Disabled);
        hc.Add(Block);
        hc.Add(AsChild);
        hc.Add(Loading);
        hc.Add(Type);
        hc.Add(LoadingTemplate);
        hc.Add(Value);
        hc.Add(Form);
        hc.Add(AutoFocus);
        hc.Add(To);
        hc.Add(Name);
        hc.Add(Variant);
        hc.Add(CollapseTarget);
        hc.Add(TriggerContext?.DataSlot);
        hc.Add(TriggerContext?.TriggerId);
        hc.Add(TriggerContext?.AriaControls);
        hc.Add(TriggerContext?.AriaDescribedBy);
        hc.Add(TriggerContext?.IsOpen);
        hc.Add(TriggerContext?.ParentDisabled == true);
    }

    internal static string GetButtonVariantClass(ButtonVariant? variant)
    {
        if (ReferenceEquals(variant, ButtonVariant.Destructive))
            return "bg-destructive text-white hover:bg-destructive/90 focus-visible:ring-destructive/20 dark:bg-destructive/60 dark:focus-visible:ring-destructive/40";

        if (ReferenceEquals(variant, ButtonVariant.Outline))
            return "border bg-background shadow-xs hover:bg-accent hover:text-accent-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50";

        if (ReferenceEquals(variant, ButtonVariant.Secondary))
            return "bg-secondary text-secondary-foreground hover:bg-secondary/80";

        if (ReferenceEquals(variant, ButtonVariant.Ghost))
            return "hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50";

        if (ReferenceEquals(variant, ButtonVariant.Link))
            return "text-primary underline-offset-4 hover:underline";

        return "bg-primary text-primary-foreground hover:bg-primary/90";
    }

    internal static string GetButtonVariantClass(string? variant)
    {
        return variant switch
        {
            ButtonVariant.DestructiveValue => GetButtonVariantClass(ButtonVariant.Destructive),
            ButtonVariant.OutlineValue => GetButtonVariantClass(ButtonVariant.Outline),
            ButtonVariant.SecondaryValue => GetButtonVariantClass(ButtonVariant.Secondary),
            ButtonVariant.GhostValue => GetButtonVariantClass(ButtonVariant.Ghost),
            ButtonVariant.LinkValue => GetButtonVariantClass(ButtonVariant.Link),
            _ => GetButtonVariantClass(ButtonVariant.Default)
        };
    }

    internal static string GetButtonSizeClass(CssValue<ButtonSizeBuilder>? size)
    {
        if (size?.TryGetThemeToken(out var token) == true && !string.IsNullOrWhiteSpace(token))
            return ResolveButtonSizeClass(token);

        var raw = size?.ToString();

        if (!string.IsNullOrWhiteSpace(raw))
        {
            var mapped = ResolveButtonSizeClass(raw);

            if (!string.IsNullOrWhiteSpace(mapped))
                return mapped;

            if (raw.Contains('-') || raw.Contains(' ') || raw.Contains(':') || raw.Contains('['))
                return raw;
        }

        return ResolveButtonSizeClass(ButtonSize.Default.Value);
    }

    internal static string ResolveButtonSizeClass(string? size)
    {
        return size switch
        {
            "xs" => "h-6 gap-1 rounded-md px-2 text-xs has-[>svg]:px-1.5 [&_svg:not([class*='size-'])]:size-3",
            "sm" => "h-8 gap-1.5 rounded-md px-3 has-[>svg]:px-2.5",
            "lg" => "h-10 rounded-md px-6 has-[>svg]:px-4",
            "icon" => "size-9",
            "icon-xs" => "size-6 rounded-md [&_svg:not([class*='size-'])]:size-3",
            "icon-sm" => "size-8",
            "icon-lg" => "size-10",
            _ => "h-9 px-4 py-2 has-[>svg]:px-3"
        };
    }

    private static string GetButtonFocusClass(ButtonVariant? variant)
    {
        if (ReferenceEquals(variant, ButtonVariant.Destructive))
            return string.Empty;

        return string.Empty;
    }

    internal static string GetInputGroupButtonSizeClass(string? size)
    {
        return size switch
        {
            "sm" => "h-8 gap-1.5 rounded-md px-2.5 has-[>svg]:px-2.5",
            "icon-xs" => "size-6 rounded-[calc(var(--radius)-5px)] p-0 has-[>svg]:p-0",
            "icon-sm" => "size-8 p-0 has-[>svg]:p-0",
            _ => "h-6 gap-1 rounded-[calc(var(--radius)-5px)] px-2 has-[>svg]:px-2 [&>svg:not([class*='size-'])]:size-3.5"
        };
    }

    internal static string GetButtonSizeDataAttribute(CssValue<ButtonSizeBuilder>? size)
    {
        if (size?.TryGetThemeToken(out var token) == true && !string.IsNullOrWhiteSpace(token))
            return ResolveButtonSizeDataAttribute(token);

        var raw = size?.ToString();

        if (!string.IsNullOrWhiteSpace(raw))
            return ResolveButtonSizeDataAttribute(raw);

        return ResolveButtonSizeDataAttribute(ButtonSize.Default.Value);
    }

    internal static string ResolveButtonSizeDataAttribute(string? size)
    {
        return size switch
        {
            "xs" => "xs",
            "sm" => "sm",
            "lg" => "lg",
            "icon" => "icon",
            "icon-xs" => "icon-xs",
            "icon-sm" => "icon-sm",
            "icon-lg" => "icon-lg",
            _ => "default"
        };
    }

}
