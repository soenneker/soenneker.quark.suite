@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits TriggerElement
@implements IButton
@inject NavigationManager Navigation
@inject ICollapseCoordinator CollapseCoordinator

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else if (RenderAsLink)
{
    <a href="@To" @ref="_elementRef" @onclick="HandleClick" @onclick:preventDefault="PreventLinkDefault" @onclick:stopPropagation="StopClickPropagation" @onpointerdown="HandleTriggerPointerDown" @onpointerdown:preventDefault="PreventPointerDownDefault" @onkeydown="HandleKeyDown" @onkeyup="HandleKeyUp" @attributes="BuildAttributes()">
        @if (Loading)
        {
            <Span Animation="Quark.Animation.Spin" Size="Quark.Size.Is4" Margin="Quark.Margin.FromRight.Is2" Display="Quark.Display.InlineBlock" Rounded="Quark.Rounded.Full" Border="Quark.Border.Is2" BorderColor='Quark.BorderColor.Current' Class="border-t-transparent" role="status" aria-hidden="true"></Span>
        }
        @if (LoadingTemplate is not null && Loading)
        {
            @LoadingTemplate
        }
        else
        {
            @RenderChildContent()
        }
    </a>
}
else
{
    <button @ref="_elementRef" @onclick="HandleClick" @onclick:stopPropagation="StopClickPropagation" @onpointerdown="HandleTriggerPointerDown" @onpointerdown:preventDefault="PreventPointerDownDefault" @onkeydown="HandleKeyDown" @onkeyup="HandleKeyUp" @attributes="BuildAttributes()">
        @if (Loading)
        {
            <Span Animation="Quark.Animation.Spin" Size="Quark.Size.Is4" Margin="Quark.Margin.FromRight.Is2" Display="Quark.Display.InlineBlock" Rounded="Quark.Rounded.Full" Border="Quark.Border.Is2" BorderColor='Quark.BorderColor.Current' Class="border-t-transparent" role="status" aria-hidden="true"></Span>
        }
        @if (LoadingTemplate is not null && Loading)
        {
            @LoadingTemplate
        }
        else
        {
            @RenderChildContent()
        }
    </button>
}

@code {

    [CascadingParameter]
    public IButtonGroup? ButtonGroup { get; set; }

    [CascadingParameter(Name = "TriggerContext")]
    private TriggerContext? TriggerContext { get; set; }

    [CascadingParameter(Name = "BradixDialogCloseContext")]
    private BradixDialogCloseContext? DialogCloseContext { get; set; }

    private ElementReference _elementRef;
    private bool _triggerElementRegistered;
    private bool _ignoreNextKeyboardClick;
    private string? _registeredTriggerId;

    private bool RenderAsLink => string.Equals(Type?.Value, "link", StringComparison.Ordinal) || To.HasContent();

    private bool PreventLinkDefault =>
        Disabled || Loading || CollapseTarget.HasContent() || TriggerContext?.Toggle is not null || DialogCloseContext is not null || (To.HasContent() && !To!.StartsWith("#", StringComparison.Ordinal));

    private bool StopClickPropagation => TriggerContext?.Toggle is not null || InputGroupButton;

    private bool PreventPointerDownDefault => TriggerContext?.PreventPointerDownDefault == true;

    private static readonly TriggerContext? NoTriggerContext = null;

    /// <summary>
    /// Gets or sets the size of the button (shadcn: default, xs, sm, lg, icon, icon-xs, icon-sm, icon-lg).
    /// </summary>
    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = "default";

    /// <summary>
    /// Gets or sets whether the button should span the full width of its container.
    /// </summary>
    [Parameter]
    public bool Block { get; set; }

    /// <summary>
    /// Gets or sets whether the child component should receive button styling directly.
    /// </summary>
    [Parameter]
    public bool AsChild { get; set; }

    /// <summary>
    /// Gets or sets whether the button is in a loading state (opinionated extension with shadcn styling).
    /// </summary>
    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public bool InputGroupButton { get; set; }

    /// <summary>
    /// Gets or sets the type of the button (button, submit, reset, or link).
    /// </summary>
    [Parameter]
    public ButtonType? Type { get; set; }

    /// <summary>
    /// Gets or sets the template to display When the button is in a loading state.
    /// </summary>
    [Parameter]
    public RenderFragment? LoadingTemplate { get; set; }

    /// <summary>
    /// Gets or sets the button value submitted with a form.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Gets or sets the button name submitted with a form.
    /// </summary>
    [Parameter]
    public string? Name { get; set; }

    /// <summary>
    /// Gets or sets the form ID that this button is associated with.
    /// </summary>
    [Parameter]
    public string? Form { get; set; }

    /// <summary>
    /// Gets or sets the navigation target URL When the button type is Link.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    /// <summary>
    /// Gets or sets the visual style variant (shadcn/ui).
    /// </summary>
    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    /// <summary>
    /// Gets or sets one or more collapse targets (id, #id, .class, or space/comma-delimited list).
    /// </summary>
    [Parameter]
    public string? CollapseTarget { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= ResolveDataSlot() ?? "button";
        Display ??= Quark.Display.InlineFlex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        if (!HasTailwindUtility(Class, "justify-"))
            Justify ??= Quark.Justify.Center;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
        Border ??= Quark.Border.Default;
        UserSelect ??= Quark.UserSelect.None;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;

        if (Block)
            Width ??= Quark.Width.IsFull;
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (TriggerContext?.RegisterElement is not null && (!_triggerElementRegistered || !string.Equals(_registeredTriggerId, TriggerContext.TriggerId, StringComparison.Ordinal)))
        {
            TriggerContext.RegisterElement(_elementRef);
            _triggerElementRegistered = true;
            _registeredTriggerId = TriggerContext.TriggerId;
        }

        return base.OnAfterRenderAsync(firstRender);
    }

    /// <summary>
    /// Builds the attributes dictionary for the button component.
    /// </summary>
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        RemoveAttribute(attributes, "onclick");
        RemoveAttribute(attributes, "onkeydown");
        RemoveAttribute(attributes, "onkeyup");

        var isLink = RenderAsLink;
        var isDisabled = Disabled || Loading || TriggerContext?.ParentDisabled == true || DialogCloseContext?.Disabled == true || attributes.ContainsKey("disabled");

        attributes["data-variant"] = Variant?.Value ?? ButtonVariant.Default.Value;

        var effectiveSize = ButtonSize ?? ButtonGroup?.ButtonSize ?? "default";
        attributes["data-size"] = GetButtonSizeDataAttribute(effectiveSize);

        if (isLink)
        {
            attributes.Remove("autofocus");
            attributes.Remove("disabled");
        }

        if (isLink && isDisabled)
            attributes.TryAdd("tabindex", -1);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/button bg-clip-padding focus-visible:ring-3 active:not-aria-[haspopup]:translate-y-px");

            var hasExplicitRadius = Rounded is not null || HasTailwindUtility(Class, "rounded");

            if (!hasExplicitRadius && !HasSizeSpecificRadius(effectiveSize))
                AppendClass(ref cls, "rounded-lg");

            AppendClass(ref cls, GetButtonFocusClass(Variant));
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, GetButtonVariantClass(Variant));
            if (!InputGroupButton)
                AppendClass(ref cls, GetButtonSizeClass(effectiveSize, !hasExplicitRadius));

            if (isLink && isDisabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });

        if (Loading)
            attributes["aria-busy"] = "true";

        if (CollapseTarget.HasContent())
            attributes["aria-controls"] = CollapseTarget!;

        if (TriggerContext is not null)
        {
            if (TriggerContext.TriggerId is not null && !attributes.ContainsKey("id"))
                attributes["id"] = TriggerContext.TriggerId;

            if (TriggerContext.DataState is not null)
                attributes["data-state"] = TriggerContext.DataState;

            if (TriggerContext.AriaHasPopup is not null)
                attributes["aria-haspopup"] = TriggerContext.AriaHasPopup;

            if (TriggerContext.AriaControls is not null)
            {
                attributes["aria-expanded"] = TriggerContext.IsOpen ? "true" : "false";
                attributes["aria-controls"] = TriggerContext.AriaControls;
            }

            if (TriggerContext.AriaDescribedBy is not null)
                attributes["aria-describedby"] = TriggerContext.AriaDescribedBy;

            if (TriggerContext.ParentDisabled)
                attributes["data-disabled"] = "true";
        }

        if (DialogCloseContext is not null)
        {
            if (!string.IsNullOrWhiteSpace(DialogCloseContext.AriaLabel) && !attributes.ContainsKey("aria-label"))
                attributes["aria-label"] = DialogCloseContext.AriaLabel;

            if (DialogCloseContext.Disabled)
                attributes["data-disabled"] = string.Empty;
        }

        if (!isLink && Type is not null)
            attributes["type"] = Type.Value;

        if (isLink)
        {
            if (isDisabled)
                attributes["aria-disabled"] = "true";
        }
        else
        {
            if (isDisabled)
                attributes["disabled"] = true;
        }

        if (Value.HasContent())
            attributes["value"] = Value!;
        if (Name.HasContent())
            attributes["name"] = Name!;
        if (Form.HasContent())
            attributes["form"] = Form!;
    }

    private string? ResolveDataSlot()
    {
        return string.Equals(TriggerContext?.DataSlot, "tooltip-trigger", StringComparison.Ordinal)
            ? "button"
            : TriggerContext?.DataSlot;
    }

    protected override void BuildOwnedAttributes(Dictionary<string, object> attributes)
    {
        base.BuildOwnedAttributes(attributes);

        if (TriggerContext?.OnMouseEnter is not null)
            attributes["onmouseenter"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleTriggerMouseEnter);

        if (TriggerContext?.OnMouseMove is not null)
            attributes["onmousemove"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleTriggerMouseMove);

        if (TriggerContext?.OnMouseLeave is not null)
            attributes["onmouseleave"] = EventCallback.Factory.Create<MouseEventArgs>(this, HandleTriggerMouseLeave);

        if (TriggerContext?.OnPointerMove is not null)
            attributes["onpointermove"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandleTriggerPointerMove);

        if (TriggerContext?.OnPointerLeave is not null)
            attributes["onpointerleave"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandleTriggerPointerLeave);

        if (TriggerContext?.OnPointerUp is not null)
            attributes["onpointerup"] = EventCallback.Factory.Create<PointerEventArgs>(this, HandleTriggerPointerUp);

        if (TriggerContext?.OnFocusIn is not null)
            attributes["onfocusin"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleTriggerFocusIn);

        if (TriggerContext?.OnFocusOut is not null)
            attributes["onfocusout"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleTriggerFocusOut);
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        var attributes = new Dictionary<string, object>(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("disabled");
        attributes.Remove("form");
        attributes.Remove("name");
        attributes.Remove("value");

        return attributes;
    }

    private RenderFragment? RenderChildContent()
    {
        if (TriggerContext is null || ChildContent is null)
            return ChildContent;

        return @<CascadingValue Name="TriggerContext" Value="@NoTriggerContext" IsFixed="true">
                   @ChildContent
               </CascadingValue>;
    }

    protected override async Task HandleClick(MouseEventArgs args)
    {
        var isDisabled = Disabled || Loading || TriggerContext?.ParentDisabled == true || DialogCloseContext?.Disabled == true || (Attributes is not null && Attributes.ContainsKey("disabled"));
        if (isDisabled)
            return;

        if (_ignoreNextKeyboardClick)
        {
            _ignoreNextKeyboardClick = false;
            return;
        }

        if (TriggerContext?.OnClick is not null)
            await TriggerContext.OnClick();

        if (TriggerContext?.Toggle is not null)
            await TriggerContext.Toggle();

        if (DialogCloseContext is not null)
            await DialogCloseContext.Close(args);

        if (To.HasContent() && !To!.StartsWith("#"))
            Navigation.NavigateTo(To!);

        if (CollapseTarget.HasContent())
            await CollapseCoordinator.ToggleTargets(CollapseTarget);
        else if (Attributes is not null && Attributes.TryGetValue("data-toggle", out var dataToggleObj) && string.Equals(dataToggleObj?.ToString(), "collapse", StringComparison.OrdinalIgnoreCase) && Attributes.TryGetValue("data-target", out var dataTargetObj))
            await CollapseCoordinator.ToggleTargets(dataTargetObj?.ToString());

        await InvokeCapturedClick(args);

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);
    }

    private async Task InvokeCapturedClick(MouseEventArgs args)
    {
        object? callback = null;

        if (AdditionalAttributes is not null)
            callback = GetAttribute(AdditionalAttributes, "onclick");

        if (callback is null && Attributes is not null)
            callback = GetAttribute(Attributes, "onclick");

        if (callback is null)
            return;

        switch (callback)
        {
            case EventCallback<MouseEventArgs> eventCallback when eventCallback.HasDelegate:
                await eventCallback.InvokeAsync(args);
                break;
            case EventCallback eventCallback when eventCallback.HasDelegate:
                await eventCallback.InvokeAsync(args);
                break;
            case Func<MouseEventArgs, Task> func:
                await func(args);
                break;
            case Func<Task> func:
                await func();
                break;
            case Action<MouseEventArgs> action:
                action(args);
                break;
            case Action action:
                action();
                break;
        }
    }

    private static object? GetAttribute(IReadOnlyDictionary<string, object> attributes, string name)
    {
        if (attributes.TryGetValue(name, out var value))
            return value;

        foreach ((var key, var candidate) in attributes)
        {
            if (string.Equals(key, name, StringComparison.OrdinalIgnoreCase))
                return candidate;
        }

        return null;
    }

    private static void RemoveAttribute(IDictionary<string, object> attributes, string name)
    {
        if (attributes.Remove(name))
            return;

        foreach (var key in attributes.Keys.ToArray())
        {
            if (string.Equals(key, name, StringComparison.OrdinalIgnoreCase))
            {
                attributes.Remove(key);
                return;
            }
        }
    }

    private Task HandleTriggerMouseEnter(MouseEventArgs args)
    {
        return TriggerContext?.OnMouseEnter?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerMove(PointerEventArgs args)
    {
        return TriggerContext?.OnPointerMove?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerMouseMove(MouseEventArgs args)
    {
        return TriggerContext?.OnMouseMove?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerMouseLeave(MouseEventArgs args)
    {
        return TriggerContext?.OnMouseLeave?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerLeave(PointerEventArgs args)
    {
        return TriggerContext?.OnPointerLeave?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerDown(PointerEventArgs args)
    {
        if (TriggerContext?.OnPointerDownEvent is not null)
            return TriggerContext.OnPointerDownEvent(args);

        return TriggerContext?.OnPointerDown?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerUp(PointerEventArgs args)
    {
        return TriggerContext?.OnPointerUp?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerFocusIn(FocusEventArgs args)
    {
        return TriggerContext?.OnFocusIn?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleTriggerFocusOut(FocusEventArgs args)
    {
        return TriggerContext?.OnFocusOut?.Invoke() ?? Task.CompletedTask;
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs args)
    {
        await base.HandleKeyDown(args);

        if (TriggerContext?.OnKeyDown is not null)
        {
            if (args.Key is "ArrowDown" or "Enter" or " " or "Space" or "Spacebar")
                _ignoreNextKeyboardClick = true;

            await TriggerContext.OnKeyDown(args);
        }
    }

    private static Task HandleKeyUp(KeyboardEventArgs args)
    {
        return Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ButtonSize);
        hc.Add(Disabled);
        hc.Add(Block);
        hc.Add(AsChild);
        hc.Add(Loading);
        hc.Add(Type);
        hc.Add(LoadingTemplate);
        hc.Add(Value);
        hc.Add(Form);
        hc.Add(AutoFocus);
        hc.Add(To);
        hc.Add(Name);
        hc.Add(Variant);
        hc.Add(CollapseTarget);
        hc.Add(TriggerContext?.DataSlot);
        hc.Add(TriggerContext?.TriggerId);
        hc.Add(TriggerContext?.AriaControls);
        hc.Add(TriggerContext?.AriaDescribedBy);
        hc.Add(TriggerContext?.IsOpen);
        hc.Add(TriggerContext?.ParentDisabled == true);
        hc.Add(DialogCloseContext?.Disabled == true);
        hc.Add(DialogCloseContext?.AriaLabel);
    }

    internal static string GetButtonVariantClass(ButtonVariant? variant)
    {
        if (ReferenceEquals(variant, ButtonVariant.Destructive))
            return "border-transparent bg-destructive/10 text-destructive hover:bg-destructive/20 focus-visible:border-destructive/40 focus-visible:ring-destructive/20 dark:bg-destructive/20 dark:hover:bg-destructive/30 dark:focus-visible:ring-destructive/40";

        if (ReferenceEquals(variant, ButtonVariant.Outline))
            return "border-border bg-background hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50";

        if (ReferenceEquals(variant, ButtonVariant.Secondary))
            return "border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80 aria-expanded:bg-secondary aria-expanded:text-secondary-foreground";

        if (ReferenceEquals(variant, ButtonVariant.Ghost))
            return "border-transparent hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:hover:bg-muted/50";

        if (ReferenceEquals(variant, ButtonVariant.Link))
            return "border-transparent text-primary underline-offset-4 hover:underline";

        return "border-transparent bg-primary text-primary-foreground [a]:hover:bg-primary/80";
    }

    internal static string GetButtonSizeClass(CssValue<ButtonSizeBuilder>? size, bool includeSizeRadius = true)
    {
        if (size?.TryGetThemeToken(out var token) == true && !string.IsNullOrWhiteSpace(token))
            return ResolveButtonSizeClass(token, includeSizeRadius);

        var raw = size?.ToString();

        if (!string.IsNullOrWhiteSpace(raw))
        {
            if (IsKnownButtonSize(raw))
                return ResolveButtonSizeClass(raw, includeSizeRadius);

            if (raw.Contains('-') || raw.Contains(' ') || raw.Contains(':') || raw.Contains('[') || raw.Contains('('))
                return raw;

            var mapped = ResolveButtonSizeClass(raw, includeSizeRadius);

            if (!string.IsNullOrWhiteSpace(mapped))
                return mapped;
        }

        return ResolveButtonSizeClass("default", includeSizeRadius);
    }

    internal static string ResolveButtonSizeClass(string? size, bool includeSizeRadius = true)
    {
        return size switch
        {
            "xs" => includeSizeRadius ? "h-6 gap-1 rounded-[min(var(--radius-md),10px)] px-2 text-xs in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3 [&_svg[data-slot=icon]]:size-3" : "h-6 gap-1 px-2 text-xs in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3 [&_svg[data-slot=icon]]:size-3",
            "sm" => includeSizeRadius ? "h-7 gap-1 rounded-[min(var(--radius-md),12px)] px-2.5 text-[0.8rem] leading-normal in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3.5 [&_svg[data-slot=icon]]:size-3.5" : "h-7 gap-1 px-2.5 text-[0.8rem] leading-normal in-data-[slot=button-group]:rounded-lg has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3.5 [&_svg[data-slot=icon]]:size-3.5",
            "lg" => "h-9 gap-1.5 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2",
            "icon" => "size-8",
            "icon-xs" => includeSizeRadius ? "size-6 rounded-[min(var(--radius-md),10px)] in-data-[slot=button-group]:rounded-lg [&_svg:not([class*='size-'])]:size-3 [&_svg[data-slot=icon]]:size-3" : "size-6 in-data-[slot=button-group]:rounded-lg [&_svg:not([class*='size-'])]:size-3 [&_svg[data-slot=icon]]:size-3",
            "icon-sm" => includeSizeRadius ? "size-7 rounded-[min(var(--radius-md),12px)] in-data-[slot=button-group]:rounded-lg" : "size-7 in-data-[slot=button-group]:rounded-lg",
            "icon-lg" => "size-9",
            _ => "h-8 gap-1.5 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2"
        };
    }

    private static bool IsKnownButtonSize(string? size)
    {
        return size is "default" or "xs" or "sm" or "lg" or "icon" or "icon-xs" or "icon-sm" or "icon-lg";
    }

    private static bool HasTailwindUtility(string? className, string utilityPrefix)
    {
        if (string.IsNullOrWhiteSpace(className))
            return false;

        return className.Split(' ', StringSplitOptions.RemoveEmptyEntries).Any(token =>
        {
            var utility = token;
            var modifierIndex = utility.LastIndexOf(':');

            if (modifierIndex >= 0)
                utility = utility[(modifierIndex + 1)..];

            return utility.StartsWith(utilityPrefix, StringComparison.Ordinal);
        });
    }

    internal static string GetButtonFocusClass(ButtonVariant? variant)
    {
        if (ReferenceEquals(variant, ButtonVariant.Destructive))
            return string.Empty;

        return "focus-visible:border-ring focus-visible:ring-ring/50";
    }

    internal static string GetInputGroupButtonSizeClass(string? size)
    {
        return size switch
        {
            "default" => "h-8 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2",
            "sm" => string.Empty,
            "xs" => "h-6 gap-1 rounded-[calc(var(--radius)-3px)] px-1.5 [&>svg:not([class*='size-'])]:size-3.5",
            "icon-xs" => "size-6 rounded-[calc(var(--radius)-3px)] p-0 has-[>svg]:p-0",
            "icon-sm" => "size-8 p-0 has-[>svg]:p-0",
            _ => string.Empty
        };
    }

    internal static string GetButtonSizeDataAttribute(CssValue<ButtonSizeBuilder>? size)
    {
        if (size?.TryGetThemeToken(out var token) == true && !string.IsNullOrWhiteSpace(token))
            return ResolveButtonSizeDataAttribute(token);

        var raw = size?.ToString();

        if (!string.IsNullOrWhiteSpace(raw))
            return ResolveButtonSizeDataAttribute(raw);

        return ResolveButtonSizeDataAttribute("default");
    }

    private static bool HasSizeSpecificRadius(CssValue<ButtonSizeBuilder>? size)
    {
        var value = GetButtonSizeDataAttribute(size);
        return value is "xs" or "sm" or "icon-xs" or "icon-sm";
    }

    internal static string ResolveButtonSizeDataAttribute(string? size)
    {
        return size switch
        {
            "xs" => "xs",
            "sm" => "sm",
            "lg" => "lg",
            "icon" => "icon",
            "icon-xs" => "icon-xs",
            "icon-sm" => "icon-sm",
            "icon-lg" => "icon-lg",
            _ => "default"
        };
    }

}
