@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSeparator Orientation="@ResolvedOrientation"
                 Decorative="true"
                 AdditionalAttributes="@SeparatorAttributes" />

@code {
    [Parameter]
    public SeparatorOrientation? Orientation { get; set; }

    private Orientation ResolvedOrientation
    {
        get
        {
            var effectiveOrientation = Orientation ?? SeparatorOrientation.Vertical;
            return effectiveOrientation == SeparatorOrientation.Horizontal ? Soenneker.Bradix.Orientation.Horizontal : Soenneker.Bradix.Orientation.Vertical;
        }
    }

    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "button-group-separator";
        Position ??= Quark.Position.Relative;
        SelfAlign ??= Self.Stretch;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-input");
        Shrink ??= Quark.Shrink.Is0;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-[orientation=horizontal]:mx-px data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-auto data-[orientation=vertical]:my-px data-[orientation=vertical]:h-auto data-[orientation=vertical]:w-px");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
    }
}