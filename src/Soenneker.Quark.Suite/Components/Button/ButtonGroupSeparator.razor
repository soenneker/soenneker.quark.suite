@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSeparator Orientation="@ResolvedOrientation"
                 Decorative="true"
                 AdditionalAttributes="@SeparatorAttributes" />

@code {
    [CascadingParameter]
    public Components.Surface.Interactive.Buttons.Abstract.IButtonGroup? ButtonGroup { get; set; }

    [Parameter]
    public SeparatorOrientation? Orientation { get; set; }

    private BradixOrientation ResolvedOrientation
    {
        get
        {
            var effectiveOrientation = Orientation ?? (ButtonGroup?.Vertical == true ? SeparatorOrientation.Horizontal : SeparatorOrientation.Vertical);
            return effectiveOrientation == SeparatorOrientation.Horizontal ? BradixOrientation.Horizontal : BradixOrientation.Vertical;
        }
    }

    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildSeparatorAttributes();

    private IReadOnlyDictionary<string, object> BuildSeparatorAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("aria-hidden");
        attributes.Remove("data-orientation");
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var effectiveOrientation = Orientation ?? (ButtonGroup?.Vertical == true ? SeparatorOrientation.Horizontal : SeparatorOrientation.Vertical);
        var orientation = effectiveOrientation == SeparatorOrientation.Horizontal ? "horizontal" : "vertical";

        attributes["data-slot"] = "button-group-separator";
        attributes["data-orientation"] = orientation;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "relative m-0! self-stretch bg-input");
            AppendClass(ref cls, "data-[orientation=vertical]:h-auto data-[orientation=vertical]:w-px");
            AppendClass(ref cls, "data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ButtonGroup?.Vertical);
        hc.Add(Orientation);
    }
}
