@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSeparator Orientation="@ResolvedOrientation"
                 Decorative="true"
                 AdditionalAttributes="@SeparatorAttributes" />

@code {
    [CascadingParameter]
    public IButtonGroup? ButtonGroup { get; set; }

    [Parameter]
    public SeparatorOrientation? Orientation { get; set; }

    private Orientation ResolvedOrientation
    {
        get
        {
            var effectiveOrientation = Orientation ?? (ButtonGroup?.Vertical == true ? SeparatorOrientation.Horizontal : SeparatorOrientation.Vertical);
            return effectiveOrientation == SeparatorOrientation.Horizontal ? Soenneker.Bradix.Orientation.Horizontal : Soenneker.Bradix.Orientation.Vertical;
        }
    }

    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildSeparatorAttributes();

    private IReadOnlyDictionary<string, object> BuildSeparatorAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("aria-hidden");
        attributes.Remove("data-orientation");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        Position ??= Quark.Position.Relative;
        SelfAlign ??= Quark.Self.Stretch;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-input");

        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var effectiveOrientation = Orientation ?? (ButtonGroup?.Vertical == true ? SeparatorOrientation.Horizontal : SeparatorOrientation.Vertical);
        var orientation = effectiveOrientation == SeparatorOrientation.Horizontal ? "horizontal" : "vertical";

        attributes["data-slot"] = "button-group-separator";
        attributes["data-orientation"] = orientation;
        attributes[effectiveOrientation == SeparatorOrientation.Horizontal ? "data-horizontal" : "data-vertical"] = string.Empty;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-horizontal:mx-px data-horizontal:h-px data-horizontal:w-auto");
            AppendClass(ref cls, "data-vertical:my-px data-vertical:h-auto data-vertical:w-px data-vertical:self-stretch");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ButtonGroup?.Vertical);
        hc.Add(Orientation);
    }
}
