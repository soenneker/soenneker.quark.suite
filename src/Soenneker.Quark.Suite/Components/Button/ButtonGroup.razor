@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IButtonGroup

<CascadingValue Value="this">
    <CascadingValue Name="DirectionProviderDir" Value="@EffectiveDirection">
        <div @attributes="BuildAttributes()">
            @ChildContent
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = "default";

    [Parameter]
    public bool Vertical { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "button-group";
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFit;
        ItemsAlign ??= Items.Stretch;

        if (Vertical)
            FlexDirection ??= Quark.FlexDirection.Col;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        if (Vertical)
            attributes["data-orientation"] = "vertical";

        if (Dir.HasContent())
            attributes["dir"] = Dir!;

        if (!attributes.ContainsKey("role"))
            attributes["role"] = Role ?? "group";

        if (AriaLabel.HasContent())
            attributes["aria-label"] = AriaLabel;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/button-group *:focus-visible:relative *:focus-visible:z-10 has-[>[data-slot=button-group]]:gap-2");
            AppendClass(ref cls, "has-[select[aria-hidden=true]:last-child]:[&>[data-slot=select-trigger]:last-of-type]:rounded-r-lg");
            AppendClass(ref cls, "[&>[data-slot=select-trigger]:not([class*='w-'])]:w-fit [&>input]:flex-1");

            if (Vertical)
            {
                AppendClass(ref cls, "[&>*:not(:first-child)]:rounded-t-none [&>*:not(:first-child)]:border-t-0 [&>*:not(:last-child)]:rounded-b-none");
                AppendClass(ref cls, "[&>[data-slot]:not(:has(~[data-slot]))]:rounded-b-lg!");
            }
            else
            {
                AppendClass(ref cls, "[&>*:not(:first-child)]:rounded-l-none [&>*:not(:first-child)]:border-l-0 [&>*:not(:last-child)]:rounded-r-none");
                AppendClass(ref cls, "[&>[data-slot]:not(:has(~[data-slot]))]:rounded-r-lg!");
            }
        });
    }

    private string? EffectiveDirection => GetOwnDirection() ?? DirectionProviderDir;

    private string? GetOwnDirection()
    {
        if (string.Equals(Dir, "rtl", StringComparison.OrdinalIgnoreCase))
            return "rtl";

        if (string.Equals(Dir, "ltr", StringComparison.OrdinalIgnoreCase))
            return "ltr";

        if (Attributes is not null && Attributes.TryGetValue("dir", out var dir) && string.Equals(dir?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
            return "rtl";

        if (Attributes is not null && Attributes.TryGetValue("dir", out dir) && string.Equals(dir?.ToString(), "ltr", StringComparison.OrdinalIgnoreCase))
            return "ltr";

        return null;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ButtonSize);
        hc.Add(Vertical);
        hc.Add(Dir);
        hc.Add(Role);
        hc.Add(AriaLabel);
        hc.Add(EffectiveDirection);
    }
}