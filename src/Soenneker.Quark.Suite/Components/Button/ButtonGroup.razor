@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IButtonGroup

<CascadingValue Value="this">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public CssValue<ButtonSizeBuilder>? Size { get; set; } = "default";

    [Parameter]
    public bool Vertical { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFit;
        ItemsAlign ??= Items.Stretch;

        if (Vertical)
            FlexDirection ??= Quark.FlexDirection.Col;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "button-group";

        if (Vertical)
            attributes["data-orientation"] = "vertical";

        if (!attributes.ContainsKey("role"))
            attributes["role"] = Role ?? "group";

        if (AriaLabel.HasContent())
            attributes["aria-label"] = AriaLabel;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "*:focus-visible:relative *:focus-visible:z-10 has-[>[data-slot=button-group]]:gap-2");
            AppendClass(ref cls, "has-[select[aria-hidden=true]:last-child]:[&>[data-slot=select-trigger]:last-of-type]:rounded-r-lg");
            AppendClass(ref cls, "[&>[data-slot=select-trigger]:not([class*='w-'])]:w-fit [&>input]:flex-1");

            if (Vertical)
            {
                AppendClass(ref cls,
                    "[&>*:not(:first-child)]:rounded-t-none " +
                    "[&>*:not(:first-child)]:border-t-0 " +
                    "[&>*:not(:last-child)]:rounded-b-none " +
                    "[&>[data-slot]:not(:has(~[data-slot]))]:rounded-b-lg!");
            }
            else
            {
                AppendClass(ref cls,
                    "[&>*:not(:first-child)]:rounded-l-none " +
                    "[&>*:not(:first-child)]:border-l-0 " +
                    "[&>*:not(:last-child)]:rounded-r-none " +
                    "[&>[data-slot]:not(:has(~[data-slot]))]:rounded-r-lg!");
            }
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Size);
        hc.Add(Vertical);
        hc.Add(Role);
        hc.Add(AriaLabel);
    }
}
