@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    [CascadingParameter(Name = "ParentResizablePanelGroup")]
    private ResizablePanelGroup? ParentPanelGroup { get; set; }

    private int _index;
    private int _lastDefaultSize;
    private int? _lastMinSize;
    private int? _lastMaxSize;

    /// <summary>
    /// Gets or sets the default size as a flex grow value (1 = equal, 2 = twice, etc.).
    /// </summary>
    [Parameter]
    public int DefaultSize { get; set; } = 1;

    /// <summary>
    /// Gets or sets minimum size in pixels.
    /// </summary>
    [Parameter]
    public int? MinSize { get; set; }

    /// <summary>
    /// Gets or sets maximum size in pixels.
    /// </summary>
    [Parameter]
    public int? MaxSize { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var sizeChanged = _lastDefaultSize != DefaultSize || _lastMinSize != MinSize || _lastMaxSize != MaxSize;

        if (ParentPanelGroup is not null)
            _index = ParentPanelGroup.RegisterPanel(this);

        if (sizeChanged)
        {
            ParentPanelGroup?.NotifyPanelConfigurationChanged();
            _lastDefaultSize = DefaultSize;
            _lastMinSize = MinSize;
            _lastMaxSize = MaxSize;
        }
    }

    internal void SetIndex(int index)
    {
        if (_index == index)
            return;

        _index = index;
        _ = InvokeAsync(StateHasChanged);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "resizable-panel";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-resizable-panel");
            AppendClass(ref cls, "overflow-auto");
        });

        if (ParentPanelGroup is not null)
            attributes["style"] = ParentPanelGroup.BuildPanelStyle(this, _index);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(DefaultSize);
        hc.Add(MinSize);
        hc.Add(MaxSize);
        hc.Add(_index);
    }

}
