@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@implements IAsyncDisposable

@inject IResizableInterop ResizableInterop

<div @ref="ElementRef"
     @attributes="BuildAttributes()"
     @onkeydown="HandleKeyDown">
    @if (WithHandle)
    {
        <div class="z-10 flex h-4 w-3 items-center justify-center rounded-xs border bg-border">
            <Icon Name="LucideIcon.GripVertical" class="size-2.5" aria-hidden="true" />
        </div>
    }
</div>

@code {
    [CascadingParameter(Name = "ParentResizablePanelGroup")]
    private ResizablePanelGroup? ParentPanelGroup { get; set; }

    private ResizablePanelGroup? _registeredParentPanelGroup;
    private int _index;

    /// <summary>
    /// Gets or sets whether to show a visible grip handle.
    /// </summary>
    [Parameter]
    public bool WithHandle { get; set; }

    private bool IsVertical => ParentPanelGroup?.IsVertical == true;
    private string SeparatorOrientation => ParentPanelGroup?.GetSeparatorOrientation() ?? "vertical";

    protected override void ApplyDefaultParameters()
    {
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsPx;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");

        base.ApplyDefaultParameters();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        RegisterWithParent();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!ReferenceEquals(_registeredParentPanelGroup, ParentPanelGroup))
        {
            _registeredParentPanelGroup?.UnregisterHandle(this);
            RegisterWithParent();
        }
    }

    private void RegisterWithParent()
    {
        if (ParentPanelGroup is null)
            return;

        _registeredParentPanelGroup = ParentPanelGroup;
        _index = ParentPanelGroup.RegisterHandle(this);
    }

    internal void SetIndex(int index)
    {
        if (_index == index)
            return;

        _index = index;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (ParentPanelGroup is null)
            return;

        await ParentPanelGroup.HandleHandleKeyDownAsync(_index, e);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ParentPanelGroup is not null)
        {
            await ResizableInterop.RegisterHandle(ElementRef, ParentPanelGroup.GroupElementRef, ParentPanelGroup.OrientationValue, ParentPanelGroup.GetOrCreateDotNetRef(), _index);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "resizable-handle";
        attributes["role"] = "separator";
        attributes["tabindex"] = 0;
        attributes["aria-orientation"] = SeparatorOrientation;
        attributes["aria-valuemin"] = 0;
        attributes["aria-valuemax"] = 100;
        attributes["aria-valuenow"] = ParentPanelGroup?.GetHandleValue(_index) ?? 50d;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "after:absolute after:inset-y-0 after:left-1/2 after:w-1 after:-translate-x-1/2 focus-visible:ring-1 focus-visible:ring-ring focus-visible:ring-offset-1 focus-visible:outline-hidden");
            AppendClass(ref cls, "aria-[orientation=horizontal]:h-px aria-[orientation=horizontal]:w-full");
            AppendClass(ref cls, "aria-[orientation=horizontal]:after:left-0 aria-[orientation=horizontal]:after:h-1 aria-[orientation=horizontal]:after:w-full aria-[orientation=horizontal]:after:translate-x-0 aria-[orientation=horizontal]:after:-translate-y-1/2");
            AppendClass(ref cls, "[&[aria-orientation=horizontal]>div]:rotate-90");
        });

        BuildStyleAttribute(attributes, (ref sty) =>
        {
            AppendStyleDecl(ref sty, "flex-basis:auto");
            AppendStyleDecl(ref sty, "flex-grow:0");
            AppendStyleDecl(ref sty, "flex-shrink:0");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(WithHandle);
        hc.Add(IsVertical);
        hc.Add(_index);
        hc.Add(SeparatorOrientation);
        hc.Add(ParentPanelGroup?.GetHandleValue(_index));
    }

    public override void Dispose()
    {
        _registeredParentPanelGroup?.UnregisterHandle(this);
        base.Dispose();
    }

    public override async ValueTask DisposeAsync()
    {
        await ResizableInterop.UnregisterHandle(ElementRef);
        await base.DisposeAsync();
    }
}
