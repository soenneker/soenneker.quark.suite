@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentAvatar" Value="@this" IsFixed="true">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    /// <summary>
    /// Size token aligned with shadcn avatar sizing.
    /// Supported values: default, sm, lg.
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "default";

    private string? _registeredImageSource;
    private bool _hasImageSource;
    private bool _imageLoaded;
    private bool _imageFailed;

    internal bool ShowFallback => !_hasImageSource || !_imageLoaded;
    internal bool ShowImage => _hasImageSource && !_imageFailed;
    internal bool IsImageVisible => _imageLoaded && !_imageFailed;

    internal void RegisterImage(string? src)
    {
        bool hasImageSource = src.HasContent();
        bool sourceChanged = !string.Equals(_registeredImageSource, src, StringComparison.Ordinal);

        if (!sourceChanged && _hasImageSource == hasImageSource)
            return;

        _registeredImageSource = src;
        _hasImageSource = hasImageSource;
        _imageLoaded = false;
        _imageFailed = !hasImageSource;

        _ = RefreshOffThread();
    }

    internal Task NotifyImageLoaded()
    {
        if (_imageLoaded && !_imageFailed)
            return Task.CompletedTask;

        _imageLoaded = true;
        _imageFailed = false;

        return RefreshOffThread();
    }

    internal Task NotifyImageFailed()
    {
        if (_imageFailed && !_imageLoaded)
            return Task.CompletedTask;

        _imageLoaded = false;
        _imageFailed = true;

        return RefreshOffThread();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "avatar";
        attributes["data-size"] = Size;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-avatar");
            AppendClass(ref cls, "group/avatar relative flex size-8 shrink-0 overflow-hidden rounded-full select-none data-[size=lg]:size-10 data-[size=sm]:size-6");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Size);
    }
}
