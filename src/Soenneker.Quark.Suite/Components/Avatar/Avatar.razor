@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixAvatar AdditionalAttributes="@AvatarAttributes">
    @ChildContent
</BradixAvatar>

@code {

    /// <summary>
    /// Size token aligned with shadcn avatar sizing.
    /// Supported values: default, sm, lg.
    /// </summary>
    [Parameter]
    public string AvatarSize { get; set; } = "default";

    private IReadOnlyDictionary<string, object> AvatarAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "avatar";
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        Size ??= Quark.Size.Is8;
        Rounded ??= Quark.Rounded.Full;
        Shrink ??= Quark.Shrink.Is0;
        UserSelect ??= Quark.UserSelect.None;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-size"] = AvatarSize;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/avatar data-[size=lg]:size-10 data-[size=sm]:size-6");
            AppendClass(ref cls, "after:absolute after:inset-0 after:rounded-full after:border after:border-border after:mix-blend-darken dark:after:mix-blend-lighten");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AvatarSize);
    }

}