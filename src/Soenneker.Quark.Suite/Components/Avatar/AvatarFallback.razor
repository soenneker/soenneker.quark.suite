@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixAvatarFallback AdditionalAttributes="@FallbackAttributes">
    @ChildContent
</BradixAvatarFallback>

@code {
    private IReadOnlyDictionary<string, object> FallbackAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Absolute;
        BackgroundColor ??= Quark.BackgroundColor.Muted;
        TextColor ??= Quark.TextColor.MutedForeground;
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        Height ??= Quark.Height.IsFull;
        Rounded ??= Quark.Rounded.Full;
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "avatar-fallback";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "inset-0");
            AppendClass(ref cls, "items-center justify-center group-data-[size=sm]/avatar:text-xs");
        });
    }
}
