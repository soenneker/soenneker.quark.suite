@namespace Soenneker.Quark
@inherits Soenneker.Quark.MediaElement

@if (ParentAvatar?.ShowImage ?? Src.HasContent())
{
    <img @attributes="BuildAttributes()" />
}

@code {
    [CascadingParameter(Name = nameof(ParentAvatar))]
    protected Avatar? ParentAvatar { get; set; }

    [Parameter]
    public string? Src { get; set; }

    protected override void OnParametersSet()
    {
        ParentAvatar?.RegisterImage(Src);
        base.OnParametersSet();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "avatar-image";

        if (Src.HasContent())
            attributes["src"] = Src!;

        if (Alt.HasContent())
            attributes["alt"] = Alt!;

        attributes["onload"] = EventCallback.Factory.Create<ProgressEventArgs>(this, HandleLoad);
        attributes["onerror"] = EventCallback.Factory.Create<ErrorEventArgs>(this, HandleError);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-avatar-image");
            AppendClass(ref cls, "absolute inset-0 aspect-square size-full object-cover transition-opacity");

            if (ParentAvatar?.IsImageVisible ?? false)
                AppendClass(ref cls, "opacity-100");
            else
                AppendClass(ref cls, "opacity-0");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Src);
        hc.Add(Alt);
    }

    private Task HandleLoad(ProgressEventArgs _)
    {
        return ParentAvatar?.NotifyImageLoaded() ?? Task.CompletedTask;
    }

    private Task HandleError(ErrorEventArgs _)
    {
        return ParentAvatar?.NotifyImageFailed() ?? Task.CompletedTask;
    }
}
