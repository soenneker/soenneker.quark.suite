@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.MediaElement

<BradixAvatarImage Src="@Src"
                   Alt="@ResolvedAlt"
                   AdditionalAttributes="@ImageAttributes" />

@code {
    [Parameter]
    public string? Src { get; set; }

    private string ResolvedAlt => Alt ?? string.Empty;
    private IReadOnlyDictionary<string, object> ImageAttributes => BuildImageAttributes();

    private IReadOnlyDictionary<string, object> BuildImageAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("src");
        attributes.Remove("alt");
        attributes.Remove("onload");
        attributes.Remove("onerror");
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "avatar-image";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-avatar-image");
            AppendClass(ref cls, "absolute inset-0 aspect-square size-full transition-opacity");
            AppendClass(ref cls, "opacity-100");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Rounded ??= global::Soenneker.Quark.Rounded.Full;
        ObjectFit ??= global::Soenneker.Quark.ObjectFit.Cover;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Src);
        hc.Add(Alt);
    }
}
