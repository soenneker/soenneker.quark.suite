@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using System.Linq

@if (ShouldRenderControl)
{
    <button @onclick="HandleClick" @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <Icon Name="LucideIcon.ArrowDown" Size='Quark.Size.Token("4.5")' />
        }
    </button>
}

@code {
    [CascadingParameter]
    internal Thread? ParentThread { get; set; }

    [Parameter]
    public bool HideWhenAtBottom { get; set; } = true;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private bool ShouldRenderControl => ParentThread is null || !HideWhenAtBottom || !ParentThread.IsAtBottom;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Title ??= "Scroll to bottom";
        Position ??= Quark.Position.Absolute;
        Bottom ??= Quark.Bottom.Token("6");
        Left ??= Quark.Left.Token("[50%]");
        Display ??= Quark.Display.Flex;
        Size ??= Quark.Size.Is8;
        Cursor ??= Quark.Cursor.Pointer;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Full;
        Border ??= Quark.Border.Is1;
        BorderColor ??= Quark.BorderColor.Border;
        BackgroundColor ??= Quark.BackgroundColor.Secondary;
        TextColor ??= Quark.TextColor.MutedForeground;
        Shadow ??= Quark.Shadow.Sm;
        Transition ??= Quark.Transition.All;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "thread-scroll-to-bottom";
        attributes["type"] = "button";
        attributes["aria-label"] = Title ?? "Scroll to bottom";

        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "translate-x-[-50%] hover:bg-border active:scale-95"));
    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (ParentThread is not null)
            await ParentThread.ScrollToBottom();

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);
    }
}
