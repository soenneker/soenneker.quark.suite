@using System.Text
@using Soenneker.Blazor.Utils.Clipboard.Abstract

<Div Width="Quark.Width.IsFull" Space="Quark.Space.Y.Is4">
    <Div Space="Quark.Space.Y.Is2">
        @if (Title != null)
        {
            <H3 Id="@ResolvedTitleId" TextSize="Quark.TextSize.Xl" FontWeight="Quark.FontWeight.Semibold" Tracking="Quark.Tracking.Tight" Margin="Quark.Margin.Is0" ScrollMargin="@ResolvedTitleScrollMargin">
                @if (ShouldRenderTitleAnchor)
                {
                    <Anchor Href="@ResolvedTitleHref" Class="group/title-anchor inline-flex items-baseline gap-1.5 text-inherit no-underline outline-none">
                        <span class="group-hover/title-anchor:underline group-focus-visible/title-anchor:underline underline-offset-4">@Title</span>
                        <span aria-hidden="true" class="select-none text-muted-foreground opacity-0 transition-opacity group-hover/title-anchor:opacity-100 group-focus-visible/title-anchor:opacity-100">#</span>
                    </Anchor>
                }
                else
                {
                    @Title
                }
            </H3>
        }
        @if (DescriptionContent != null)
        {
            <Span Display="Quark.Display.Block" TextSize="Quark.TextSize.Sm" TextColor="Quark.TextColor.MutedForeground">@DescriptionContent</Span>
        }
        else if (Description != null)
        {
            @if (ShouldRenderIntroDescription)
            {
                <Paragraph TextSize='Quark.TextSize.Token("[1.05rem]").OnSm.Base' TextColor="Quark.TextColor.MutedForeground" TextWrap='@("sm:text-balance")' MaxWidth='@("md:max-w-[80%]")'>@Description</Paragraph>
            }
            else
            {
                <Span Display="Quark.Display.Block" TextSize="Quark.TextSize.Sm" TextColor="Quark.TextColor.MutedForeground">@Description</Span>
            }
        }
    </Div>

    <Div DataSlot="component-preview"
         Class="group [&_[data-slot=header]]:relative [&_[data-slot=header]]:top-auto"
         Position="Quark.Position.Relative"
         Margin='Quark.Margin.FromTop.Is4.FromBottom.Token("12")'
         Display="Quark.Display.Flex"
         FlexDirection="Quark.FlexDirection.Col"
         Overflow="Quark.Overflow.Hidden"
         Rounded="Quark.Rounded.Xl"
         Border="Quark.Border.Default">
        <Div DataSlot="preview" dir="@PreviewDir" data-lang="@PreviewLang">
            @if (ShowPreviewToolbar)
            {
                <Div DataSlot="preview-toolbar"
                     dir="ltr"
                     Display="Quark.Display.Flex"
                     Height="Quark.Height.Is14"
                     ItemsAlign="Items.Center"
                     Justify="Quark.Justify.Between"
                     Border="Quark.Border.FromBottom.Default"
                     Padding="Quark.Padding.OnX.Is4">
                    @if (!string.IsNullOrWhiteSpace(ResolvedPreviewLanguageLabel))
                    {
                        <select aria-label="Language"
                                dir="ltr"
                                class="border-input bg-background text-foreground shadow-xs hover:bg-accent hover:text-accent-foreground focus-visible:border-ring focus-visible:ring-ring/50 inline-flex h-8 items-center justify-center gap-1.5 rounded-md border px-3 py-1 text-sm font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px]">
                            <option>@ResolvedPreviewLanguageLabel</option>
                        </select>
                    }
                    else
                    {
                        <Span></Span>
                    }

                    <Span TextColor="Quark.TextColor.MutedForeground"
                          Display="Quark.Display.InlineFlex"
                          Size="Quark.Size.Is4"
                          ItemsAlign="Items.Center"
                          Justify="Quark.Justify.Center"
                          aria-hidden="true">
                        <Svg NativeWidth="16"
                             NativeHeight="16"
                             ViewBox="0 0 24 24"
                             Fill="Quark.Fill.None"
                             Stroke='Quark.Stroke.Current'
                             StrokeWidth="Quark.StrokeWidth.Is2"
                             StrokeLineCap="Quark.StrokeLineCap.Round"
                             StrokeLineJoin="Quark.StrokeLineJoin.Round">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M12 16v-4" />
                            <path d="M12 8h.01" />
                        </Svg>
                    </Span>
                </Div>
            }
            <Div data-align="@PreviewAlign"
                 data-chromeless="@_previewChromeless"
                 class="@ResolvedPreviewClass">
                <Div Class="@ResolvedPreviewInnerClass">
                    @ChildContent
                </Div>
            </Div>
        </Div>

        @if (Code != null)
        {
            <Div DataSlot="code"
                 data-mobile-code-visible="@_showCodeCss"
                 class="@GetCodeSectionClass()">
                <Div Position="Quark.Position.Relative">
                    @if (!ShouldShowCollapsedCodeOverlay)
                    {
                        <Button DataSlot="copy-button"
                                Type="@ButtonType.Button"
                                Variant="ButtonVariant.Outline"
                                ButtonSize="@NoButtonSize"
                                Position="Quark.Position.Absolute"
                                Top="Quark.Top.Is3"
                                Right="Quark.Right.Is2"
                                ZIndex="Quark.ZIndex.Is10"
                                Size="Quark.Size.Is7"
                                Gap="Quark.Gap.Is2"
                                Rounded="Quark.Rounded.Lg"
                                Padding="Quark.Padding.Is0"
                                BorderColor="Quark.BorderColor.Border"
                                BackgroundColor="Quark.BackgroundColor.Background"
                                TextColor="Quark.TextColor.MutedForeground.OnHover.Foreground"
                                Title="@_copyButtonLabel"
                                OnClick="CopyCode">
                            <Span ScreenReader="Quark.ScreenReader.Only">@_copyButtonLabel</Span>
                            <Svg NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Current' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round">
                                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 1.818.785 2 1.5"/>
                            </Svg>
                        </Button>
                    }

                    <Div BackgroundColor='Quark.BackgroundColor.Utility("bg-muted/25")'>
                        <CodeEditor @key="_showCode"
                                    ReadOnly="true"
                                    Language="@(CodeLanguage ?? "html")"
                                    AutoHeight="true"
                                    Minimap="false"
                                    MinLines="@CodeEditorMinLines"
                                    MaxLines="@CodeEditorMaxLines"
                                    Text="@Code"
                                    Width="Quark.Width.IsFull"
                                    MinWidth="Quark.MinWidth.Is0"
                                    TextSize="Quark.TextSize.Sm"/>
                    </Div>

                    @if (ShouldShowCollapsedCodeOverlay)
                    {
                        <Div PointerEvents="Quark.PointerEvents.None"
                             Position="Quark.Position.Absolute"
                             Inset="Quark.Inset.Is0"
                             Display="Quark.Display.Flex"
                             ItemsAlign="Items.Center"
                             Justify="Quark.Justify.Center"
                             Padding="Quark.Padding.FromBottom.Is4">
                            <Div Position="Quark.Position.Absolute"
                                 Inset="Quark.Inset.Is0"
                                 Class="bg-gradient-to-t from-background via-background/90 via-35% to-background/10 backdrop-blur-[1px]"></Div>
                            <Button Type="@ButtonType.Button"
                                    Variant="ButtonVariant.Outline"
                                    ButtonSize="ButtonSize.Sm"
                                    PointerEvents="Quark.PointerEvents.Auto"
                                    Position="Quark.Position.Relative"
                                    ZIndex="Quark.ZIndex.Is10"
                                    Rounded="Quark.Rounded.Lg"
                                    BorderColor="Quark.BorderColor.Input"
                                    BackgroundColor="Quark.BackgroundColor.Background.OnHover.Muted"
                                    TextColor="Quark.TextColor.Foreground"
                                    Shadow="Quark.Shadow.None"
                                    OnClick="ShowCode">
                                View Code
                            </Button>
                        </Div>
                    }
                </Div>
            </Div>
        }
    </Div>
</Div>

@code{

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? TitleId { get; set; }

    [Parameter]
    public bool ShowTitleAnchor { get; set; }

    [Parameter]
    public string? Description { get; set; }

    /// <summary>Optional rich description (e.g. inline Badge). When set, Description is ignored.</summary>
    [Parameter]
    public RenderFragment? DescriptionContent { get; set; }

    [Parameter]
    public string? Code { get; set; }

    [Parameter]
    public string? CodeLanguage { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string PreviewAlign { get; set; } = "center";

    [Parameter]
    public string PreviewDir { get; set; } = "ltr";

    [Parameter]
    public string? PreviewLang { get; set; }

    [Parameter]
    public bool ShowPreviewToolbar { get; set; }

    [Parameter]
    public string? PreviewLanguageLabel { get; set; }

    [Parameter]
    public bool PreviewChromeless { get; set; }

    [Parameter]
    public string? PreviewClass { get; set; }

    [Parameter]
    public string? PreviewInnerClass { get; set; }

    [Inject]
    private IClipboardUtil ClipboardUtil { get; set; } = null!;

    private bool _showCode;
    private string _copyButtonLabel = "Copy";
    private string? ResolvedTitleId => TitleId ?? CreateTitleId(Title);
    private bool ShouldRenderTitleAnchor => ShowTitleAnchor && ResolvedTitleId.HasContent();
    private string? ResolvedTitleHref => ShouldRenderTitleAnchor ? $"#{ResolvedTitleId}" : null;
    private CssValue<ScrollMarginBuilder>? ResolvedTitleScrollMargin
    {
        get
        {
            if (!ShouldRenderTitleAnchor)
                return null;

            return Quark.ScrollMargin.Is24.FromTop;
        }
    }
    private string _showCodeCss => ShouldShowCollapsedCodeOverlay ? "false" : "true";
    private string _previewChromeless => PreviewChromeless ? "true" : "false";
    private string? ResolvedPreviewLanguageLabel => !string.IsNullOrWhiteSpace(PreviewLanguageLabel)
        ? PreviewLanguageLabel
        : PreviewLang switch
        {
            "ar" => "Arabic (العربية)",
            "he" => "Hebrew (עברית)",
            _ => PreviewLang
        };
    private bool ShouldShowViewCodeButton => GetCodeLineCount() > 0;
    private bool ShouldShowCollapsedCodeOverlay => ShouldShowViewCodeButton && !_showCode;
    private bool ShouldRenderIntroDescription => Title is null;
    private int CodeEditorMinLines => ShouldShowCollapsedCodeOverlay ? 4 : 1;
    private int? CodeEditorMaxLines => ShouldShowCollapsedCodeOverlay ? 4 : null;
    private static readonly CssValue<ButtonSizeBuilder>? NoButtonSize = null;
    private string ResolvedPreviewClass => string.IsNullOrWhiteSpace(PreviewClass)
        ? "preview relative flex min-h-72 w-full justify-center p-2 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0"
        : PreviewClass;
    private string ResolvedPreviewInnerClass => string.IsNullOrWhiteSpace(PreviewInnerClass)
        ? "demo-section-preview-inner mx-auto flex w-full max-w-full flex-col items-center justify-center [&_img]:mx-auto [&_img]:block [&_img]:max-h-72 [&_img]:max-w-full"
        : PreviewInnerClass;

    private string GetCodeSectionClass()
    {
        const string baseClass = "relative overflow-hidden border-t border-border **:data-[slot=copy-button]:right-4 **:data-[slot=copy-button]:hidden data-[mobile-code-visible=true]:**:data-[slot=copy-button]:flex [&_pre]:max-h-72";

        if (ShouldShowCollapsedCodeOverlay)
            return $"{baseClass} pointer-events-none block min-h-[104px]";

        return baseClass;
    }

    private void ShowCode()
    {
        _showCode = true;
    }

    private int GetCodeLineCount()
    {
        if (string.IsNullOrEmpty(Code))
            return 0;

        var count = 1;

        for (var i = 0; i < Code.Length; i++)
        {
            if (Code[i] == '\n')
                count++;
        }

        return count;
    }

    private async Task CopyCode()
    {
        if (string.IsNullOrEmpty(Code))
            return;
        try
        {
            await ClipboardUtil.WriteText(Code);
            _copyButtonLabel = "Copied!";
            StateHasChanged();
            await Task.Delay(1500);
            _copyButtonLabel = "Copy";
            StateHasChanged();
        }
        catch
        {
            _copyButtonLabel = "Copy";
        }
    }

    private static string? CreateTitleId(string? title)
    {
        if (string.IsNullOrWhiteSpace(title))
            return null;

        var builder = new StringBuilder(title.Length);
        var lastWasSeparator = false;

        foreach (var character in title.Trim())
        {
            if (char.IsLetterOrDigit(character))
            {
                builder.Append(char.ToLowerInvariant(character));
                lastWasSeparator = false;
                continue;
            }

            if (!lastWasSeparator && builder.Length > 0)
            {
                builder.Append('-');
                lastWasSeparator = true;
            }
        }

        if (builder.Length > 0 && builder[^1] == '-')
            builder.Length--;

        return builder.Length == 0 ? null : builder.ToString();
    }

}
