@using Microsoft.JSInterop

<div class="w-full space-y-4">
    <div class="space-y-2">
        @if (Title != null)
        {
            <h3 class="text-xl font-semibold tracking-tight">@Title</h3>
        }
        @if (DescriptionContent != null)
        {
            <p class="text-sm text-muted-foreground">@DescriptionContent</p>
        }
        else if (Description != null)
        {
            <p class="text-sm text-muted-foreground">@Description</p>
        }
    </div>

    <div data-slot="component-preview" class="group relative mt-4 mb-10 flex flex-col overflow-hidden rounded-xl border border-border">
        <div data-slot="preview" dir="ltr">
            <div data-align="center"
                 data-chromeless="false"
                 class="preview relative flex min-h-[10rem] w-full items-center justify-center p-6 sm:min-h-[12rem] sm:p-8 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:h-auto data-[chromeless=true]:p-0">
                <div class="mx-auto flex max-w-full flex-col items-center justify-center [&>*]:max-w-full [&_img]:mx-auto [&_img]:block [&_img]:max-h-72 [&_img]:max-w-full [&_img]:object-contain">
                    @ChildContent
                </div>
            </div>
        </div>

        @if (Code != null)
        {
            @if (ShouldShowCollapsedCodeOverlay)
            {
                <div class="flex justify-center border-t border-border bg-muted/10 px-4 py-4 md:hidden">
                    <button data-slot="button"
                            type="button"
                            class="inline-flex h-8 items-center justify-center rounded-lg border border-input bg-background px-3 text-sm font-medium text-foreground shadow-none transition-all hover:bg-muted"
                            @onclick="ShowCode"
                            @onkeydown="@(e =>
                                        {
                                            if (e.Key == "Enter" || e.Key == " ")
                                                ShowCode();
                                        })">
                        View Code
                    </button>
                </div>
            }

            <div data-slot="code"
                 data-mobile-code-visible="@_showCodeCss"
                 class="@GetCodeSectionClass()">
                <div class="relative">
                    @if (!ShouldShowCollapsedCodeOverlay)
                    {
                        <button data-slot="copy-button"
                                type="button"
                                class="absolute top-3 right-3 z-10 inline-flex size-7 items-center justify-center rounded-md border border-border bg-background text-muted-foreground transition-all hover:bg-muted hover:text-foreground"
                                title="@_copyButtonLabel"
                                @onclick="CopyCodeAsync">
                            <span class="sr-only">@_copyButtonLabel</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 1.818.785 2 1.5"/>
                            </svg>
                        </button>
                    }

                    <div class="bg-muted/25">
                        <CodeEditor @key="_showCode"
                                    ReadOnly="true"
                                    Language="@(CodeLanguage ?? "html")"
                                    AutoHeight="true"
                                    MinLines="@CodeEditorMinLines"
                                    MaxLines="@CodeEditorMaxLines"
                                    Text="@Code"
                                    Class="w-full min-w-0 text-sm"/>
                    </div>

                    @if (ShouldShowCollapsedCodeOverlay)
                    {
                        <div class="absolute inset-0 hidden items-center justify-center pb-4 md:flex">
                            <div class="absolute inset-0 bg-gradient-to-t from-background via-background/90 via-35% to-background/10 backdrop-blur-[1px]"></div>
                            <button data-slot="button"
                                    type="button"
                                    class="relative z-10 inline-flex h-8 items-center justify-center rounded-lg border border-input bg-background px-3 text-sm font-medium text-foreground shadow-none transition-all hover:bg-muted"
                                    @onclick="ShowCode"
                                    @onkeydown="@(e =>
                                                {
                                                    if (e.Key == "Enter" || e.Key == " ")
                                                        ShowCode();
                                                })">
                                View Code
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
</div>
</div>

@code{

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    /// <summary>Optional rich description (e.g. inline Badge). When set, Description is ignored.</summary>
    [Parameter]
    public RenderFragment? DescriptionContent { get; set; }

    [Parameter]
    public string? Code { get; set; }

    [Parameter]
    public string? CodeLanguage { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    private bool _showCode;
    private string _copyButtonLabel = "Copy";
    private string _showCodeCss => ShouldShowCollapsedCodeOverlay ? "false" : "true";
    private bool ShouldShowViewCodeButton => GetCodeLineCount() > 0;
    private bool ShouldShowCollapsedCodeOverlay => ShouldShowViewCodeButton && !_showCode;
    private int CodeEditorMinLines => ShouldShowCollapsedCodeOverlay ? 3 : 1;
    private int? CodeEditorMaxLines => ShouldShowCollapsedCodeOverlay ? 3 : null;

    private string GetCodeSectionClass()
    {
        const string baseClass = "relative overflow-hidden border-t border-border";

        if (ShouldShowCollapsedCodeOverlay)
            return $"{baseClass} hidden md:block";

        return baseClass;
    }

    private void ShowCode()
    {
        _showCode = true;
    }

    private int GetCodeLineCount()
    {
        if (string.IsNullOrEmpty(Code))
            return 0;

        return Code.Replace("\r\n", "\n").Split('\n').Length;
    }

    private async Task CopyCodeAsync()
    {
        if (string.IsNullOrEmpty(Code))
            return;
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", Code);
            _copyButtonLabel = "Copied!";
            StateHasChanged();
            await Task.Delay(1500);
            _copyButtonLabel = "Copy";
            StateHasChanged();
        }
        catch
        {
            _copyButtonLabel = "Copy";
        }
    }


}
