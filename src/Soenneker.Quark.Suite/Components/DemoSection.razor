@using Microsoft.JSInterop

<div class="w-full space-y-4">
    <div class="space-y-2">
        @if (Title != null)
        {
            <h3 class="text-xl font-semibold tracking-tight">@Title</h3>
        }
        @if (DescriptionContent != null)
        {
            <p class="text-sm text-muted-foreground">@DescriptionContent</p>
        }
        else if (Description != null)
        {
            <p class="text-sm text-muted-foreground">@Description</p>
        }
    </div>

    <div data-slot="component-preview" class="group relative mt-4 mb-12 flex flex-col overflow-hidden rounded-xl border [&_[data-slot=header]]:relative [&_[data-slot=header]]:top-auto">
        <div data-slot="preview" dir="@PreviewDir" data-lang="@PreviewLang">
            @if (ShowPreviewToolbar)
            {
                <div data-slot="preview-toolbar" dir="ltr" class="flex h-14 items-center justify-between border-b px-4">
                    @if (!string.IsNullOrWhiteSpace(ResolvedPreviewLanguageLabel))
                    {
                        <select aria-label="Language"
                                dir="ltr"
                                class="border-input bg-background text-foreground shadow-xs hover:bg-accent hover:text-accent-foreground focus-visible:border-ring focus-visible:ring-ring/50 inline-flex h-8 items-center justify-center gap-1.5 rounded-md border px-3 py-1 text-sm font-medium whitespace-nowrap transition-all outline-none focus-visible:ring-[3px]">
                            <option>@ResolvedPreviewLanguageLabel</option>
                        </select>
                    }
                    else
                    {
                        <span></span>
                    }

                    <span class="text-muted-foreground inline-flex size-4 items-center justify-center" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="16"
                             height="16"
                             viewBox="0 0 24 24"
                             fill="none"
                             stroke="currentColor"
                             stroke-width="2"
                             stroke-linecap="round"
                             stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10" />
                            <path d="M12 16v-4" />
                            <path d="M12 8h.01" />
                        </svg>
                    </span>
                </div>
            }
            <div data-align="@PreviewAlign"
                 data-chromeless="@_previewChromeless"
                 class="@ResolvedPreviewClass">
                <div class="@ResolvedPreviewInnerClass">
                    @ChildContent
                </div>
            </div>
        </div>

        @if (Code != null)
        {
            <div data-slot="code"
                 data-mobile-code-visible="@_showCodeCss"
                 class="@GetCodeSectionClass()">
                <div class="relative">
                    @if (!ShouldShowCollapsedCodeOverlay)
                    {
                        <button data-slot="copy-button"
                                type="button"
                                class="absolute top-3 right-2 z-10 inline-flex size-7 shrink-0 items-center justify-center gap-2 rounded-lg text-sm font-medium whitespace-nowrap transition-all outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 border border-border bg-background text-muted-foreground hover:bg-muted hover:text-foreground"
                                title="@_copyButtonLabel"
                                @onclick="CopyCode">
                            <span class="sr-only">@_copyButtonLabel</span>
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
                                <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 1.818.785 2 1.5"/>
                            </svg>
                        </button>
                    }

                    <div class="bg-muted/25">
                        <CodeEditor @key="_showCode"
                                    ReadOnly="true"
                                    Language="@(CodeLanguage ?? "html")"
                                    AutoHeight="true"
                                    MinLines="@CodeEditorMinLines"
                                    MaxLines="@CodeEditorMaxLines"
                                    Text="@Code"
                                    Class="w-full min-w-0 text-sm"/>
                    </div>

                    @if (ShouldShowCollapsedCodeOverlay)
                    {
                        <div class="pointer-events-none absolute inset-0 flex items-center justify-center pb-4">
                            <div class="absolute inset-0 bg-gradient-to-t from-background via-background/90 via-35% to-background/10 backdrop-blur-[1px]"></div>
                            <button data-slot="button"
                                    type="button"
                                    class="pointer-events-auto relative z-10 inline-flex h-8 items-center justify-center rounded-lg border border-input bg-background px-3 text-sm font-medium text-foreground shadow-none transition-all hover:bg-muted"
                                    @onclick="ShowCode"
                                    @onkeydown="@(e =>
                                                {
                                                    if (e.Key == "Enter" || e.Key == " ")
                                                        ShowCode();
                                                })">
                                View Code
                            </button>
                        </div>
                    }
                </div>
            </div>
        }
</div>
</div>

@code{

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string? Description { get; set; }

    /// <summary>Optional rich description (e.g. inline Badge). When set, Description is ignored.</summary>
    [Parameter]
    public RenderFragment? DescriptionContent { get; set; }

    [Parameter]
    public string? Code { get; set; }

    [Parameter]
    public string? CodeLanguage { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string PreviewAlign { get; set; } = "center";

    [Parameter]
    public string PreviewDir { get; set; } = "ltr";

    [Parameter]
    public string? PreviewLang { get; set; }

    [Parameter]
    public bool ShowPreviewToolbar { get; set; }

    [Parameter]
    public string? PreviewLanguageLabel { get; set; }

    [Parameter]
    public bool PreviewChromeless { get; set; }

    [Parameter]
    public string? PreviewClass { get; set; }

    [Parameter]
    public string? PreviewInnerClass { get; set; }

    [Inject]
    private IJSRuntime JSRuntime { get; set; } = null!;

    private bool _showCode;
    private string _copyButtonLabel = "Copy";
    private string _showCodeCss => ShouldShowCollapsedCodeOverlay ? "false" : "true";
    private string _previewChromeless => PreviewChromeless ? "true" : "false";
    private string? ResolvedPreviewLanguageLabel => !string.IsNullOrWhiteSpace(PreviewLanguageLabel)
        ? PreviewLanguageLabel
        : PreviewLang switch
        {
            "ar" => "Arabic (العربية)",
            "he" => "Hebrew (עברית)",
            _ => PreviewLang
        };
    private bool ShouldShowViewCodeButton => GetCodeLineCount() > 0;
    private bool ShouldShowCollapsedCodeOverlay => ShouldShowViewCodeButton && !_showCode;
    private int CodeEditorMinLines => ShouldShowCollapsedCodeOverlay ? 3 : 1;
    private int? CodeEditorMaxLines => ShouldShowCollapsedCodeOverlay ? 3 : null;
    private string ResolvedPreviewClass => string.IsNullOrWhiteSpace(PreviewClass)
        ? "preview relative flex min-h-72 w-full justify-center p-10 data-[align=center]:items-center data-[align=end]:items-end data-[align=start]:items-start data-[chromeless=true]:min-h-0 data-[chromeless=true]:p-0"
        : PreviewClass;
    private string ResolvedPreviewInnerClass => string.IsNullOrWhiteSpace(PreviewInnerClass)
        ? "mx-auto flex w-full max-w-full flex-col items-center justify-center [&_img]:mx-auto [&_img]:block [&_img]:max-h-72 [&_img]:max-w-full [&_img]:object-contain"
        : PreviewInnerClass;

    private string GetCodeSectionClass()
    {
        const string baseClass = "relative overflow-hidden border-t border-border **:data-[slot=copy-button]:right-4 **:data-[slot=copy-button]:hidden data-[mobile-code-visible=true]:**:data-[slot=copy-button]:flex [&_pre]:max-h-72";

        if (ShouldShowCollapsedCodeOverlay)
            return $"{baseClass} pointer-events-none block";

        return baseClass;
    }

    private void ShowCode()
    {
        _showCode = true;
    }

    private int GetCodeLineCount()
    {
        if (string.IsNullOrEmpty(Code))
            return 0;

        return Code.Replace("\r\n", "\n").Split('\n').Length;
    }

    private async Task CopyCode()
    {
        if (string.IsNullOrEmpty(Code))
            return;
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", Code);
            _copyButtonLabel = "Copied!";
            StateHasChanged();
            await Task.Delay(1500);
            _copyButtonLabel = "Copy";
            StateHasChanged();
        }
        catch
        {
            _copyButtonLabel = "Copy";
        }
    }


}
