@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<SortableList Id="@Id"
              ListId="@ListId"
              Group="@Group"
              Sort="@Sort"
              Disabled="@Disabled"
              AnimationMs="@AnimationMs"
              ForceFallback="@ForceFallback"
              HandleOnly="@HandleOnly"
              HandleSelector="@HandleSelector"
              ItemSelector="[data-kanban-column]"
              DataSlot="@DataSlot"
              Role="@Role"
              FlexDirection="Quark.FlexDirection.Row"
              Class="@GetClass()"
              OnReorder="@OnReorder">
    @ChildContent
</SortableList>

@code {
    private const string _baseClass = "flex h-full w-full items-start gap-3 overflow-x-auto overflow-y-hidden p-1";

    [Parameter]
    public string? ListId { get; set; }

    [Parameter]
    public string Group { get; set; } = "kanban-columns";

    [Parameter]
    public bool Sort { get; set; } = true;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public int AnimationMs { get; set; } = 150;

    [Parameter]
    public bool ForceFallback { get; set; }

    [Parameter]
    public bool HandleOnly { get; set; }

    [Parameter]
    public string? HandleSelector { get; set; } = "[data-kanban-column-handle]";

    [Parameter]
    public EventCallback<SortableReorderEventArgs> OnReorder { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "kanban-board";
        Role ??= "list";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ListId);
        hc.Add(Group);
        hc.Add(Sort);
        hc.Add(Disabled);
        hc.Add(AnimationMs);
        hc.Add(ForceFallback);
        hc.Add(HandleOnly);
        hc.Add(HandleSelector);
        hc.Add(OnReorder.HasDelegate);
    }

    private string GetClass()
    {
        return $"{_baseClass} {Class}".Trim();
    }
}
