@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDisposable

<Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" OnClick="HandlePreviousClick" Disabled="@(!(ParentCarousel?.CanScrollPrevious ?? false))" @attributes="BuildAttributes()">
    <span class="sr-only">Previous slide</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
</Button>

@code {
    [CascadingParameter(Name = "ParentCarousel")]
    private Carousel? ParentCarousel { get; set; }

    private Carousel? _subscribedCarousel;

    private async Task HandlePreviousClick(MouseEventArgs e)
    {
        ParentCarousel?.Previous();
        await base.HandleClick(e);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ReferenceEquals(_subscribedCarousel, ParentCarousel))
            return;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        _subscribedCarousel = ParentCarousel;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged += OnCarouselStateChanged;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "carousel-previous";

        var horizontal = ParentCarousel?.Orientation != "vertical";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "absolute touch-manipulation rounded-full");
            if (horizontal)
                AppendClass(ref cls, "top-1/2 -left-12 -translate-y-1/2");
            else
                AppendClass(ref cls, "-top-12 left-1/2 -translate-x-1/2 rotate-90");
        });
    }

    private async void OnCarouselStateChanged()
    {
        await RefreshOffThread();
    }

    public override void Dispose()
    {
        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        base.Dispose();
    }
}
