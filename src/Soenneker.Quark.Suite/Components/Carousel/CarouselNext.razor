@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Button Variant="ButtonVariant.Outline" Size="ButtonSize.IconSm" OnClick="HandleNextClick" Disabled="@(!(ParentCarousel?.CanScrollNext ?? false))" @attributes="BuildAttributes()">
    <Svg BoxSize="Quark.Size.Is4" Class="rtl:rotate-180" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2">
        <path d="m9 18 6-6-6-6"/>
    </Svg>
    <Span ScreenReader="Quark.ScreenReader.Only">Next slide</Span>
</Button>

@code {

    [CascadingParameter(Name = "ParentCarousel")]
    private Carousel? ParentCarousel { get; set; }

    private Carousel? _subscribedCarousel;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Absolute;
        Rounded ??= Quark.Rounded.Full;
    }

    private async Task HandleNextClick(MouseEventArgs e)
    {
        if (ParentCarousel is not null)
            await ParentCarousel.Next();

        await base.HandleClick(e);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ReferenceEquals(_subscribedCarousel, ParentCarousel))
            return;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        _subscribedCarousel = ParentCarousel;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged += OnCarouselStateChanged;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "carousel-next";

        var horizontal = ParentCarousel?.IsVertical != true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (horizontal)
                AppendClass(ref cls, ParentCarousel?.IsRtl == true
                    ? "touch-manipulation -end-12 top-1/2 -translate-y-1/2"
                    : "touch-manipulation top-1/2 -right-12 -translate-y-1/2");
            else
                AppendClass(ref cls, "touch-manipulation -bottom-12 left-1/2 -translate-x-1/2 rotate-90");
        });
    }

    private void OnCarouselStateChanged()
    {
        _ = RefreshOffThread();
    }

    public override void Dispose()
    {
        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        base.Dispose();
    }

}
