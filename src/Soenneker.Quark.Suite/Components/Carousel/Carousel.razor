@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using System.Linq
@using Soenneker.Bradix

<CascadingValue Name="ParentCarousel" Value="@this" IsFixed="true">
    <div @attributes="BuildAttributes()" role="region" aria-roledescription="carousel" @onkeydown="HandleKeyDown">
        @ChildContent
    </div>
</CascadingValue>

@code {

    /// <summary>
    /// Gets or sets orientation: horizontal or vertical.
    /// </summary>
    [Parameter]
    public Orientation Orientation { get; set; } = Orientation.Horizontal;

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public Action<CarouselApi>? SetApi { get; set; }

    internal event Action? StateChanged;
    private readonly CarouselApi _api = new();
    private Action<CarouselApi>? _lastSetApi;
    private double? _pointerStart;
    private bool _pointerDragStarted;

    internal int CurrentIndex { get; private set; }
    internal int ItemCount { get; private set; }
    internal bool IsVertical => Orientation == Orientation.Vertical;
    internal bool CanScrollPrevious => ItemCount > 1 && (Loop || CurrentIndex > 0);
    internal bool CanScrollNext => ItemCount > 1 && (Loop || CurrentIndex < ItemCount - 1);

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
    }

    protected override void OnInitialized()
    {
        _api.SelectedIndexAccessor = () => CurrentIndex;
        _api.ScrollSnapListAccessor = () => ItemCount <= 0 ? Array.Empty<int>() : Enumerable.Range(0, ItemCount).ToArray();
        _api.CanScrollPreviousAccessor = () => CanScrollPrevious;
        _api.CanScrollNextAccessor = () => CanScrollNext;
        _api.ScrollPreviousAction = Previous;
        _api.ScrollNextAction = Next;
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (SetApi is not null && !ReferenceEquals(_lastSetApi, SetApi))
        {
            _lastSetApi = SetApi;
            SetApi(_api);
        }
    }

    internal void RegisterItem()
    {
        ItemCount++;
        NotifyStateChanged();
    }

    internal void UnregisterItem()
    {
        if (ItemCount == 0)
            return;

        ItemCount--;

        if (ItemCount == 0)
            CurrentIndex = 0;
        else if (CurrentIndex >= ItemCount)
            CurrentIndex = ItemCount - 1;

        NotifyStateChanged();
    }

    internal void Previous()
    {
        GoTo(CurrentIndex - 1);
    }

    internal void Next()
    {
        GoTo(CurrentIndex + 1);
    }

    internal void BeginPointerDrag(PointerEventArgs args)
    {
        if (ItemCount <= 1 || (args.PointerType != "touch" && args.Button != 0))
            return;

        _pointerStart = GetAxisCoordinate(args);
        _pointerDragStarted = true;
    }

    internal void CompletePointerDrag(PointerEventArgs args)
    {
        if (!_pointerDragStarted || _pointerStart is null)
            return;

        CompleteDrag(GetAxisCoordinate(args));
    }

    internal void BeginTouchDrag(TouchEventArgs args)
    {
        if (ItemCount <= 1 || !TryGetTouchAxisCoordinate(args, out var coordinate))
            return;

        _pointerStart = coordinate;
        _pointerDragStarted = true;
    }

    internal void CompleteTouchDrag(TouchEventArgs args)
    {
        if (!_pointerDragStarted || _pointerStart is null || !TryGetTouchAxisCoordinate(args, out var coordinate))
            return;

        CompleteDrag(coordinate);
    }

    private void CompleteDrag(double endCoordinate)
    {
        if (!_pointerDragStarted || _pointerStart is null)
            return;

        var delta = endCoordinate - _pointerStart.Value;
        _pointerStart = null;
        _pointerDragStarted = false;

        const double threshold = 40;
        if (Math.Abs(delta) < threshold)
            return;

        if (delta < 0)
            Next();
        else
            Previous();
    }

    internal void CancelPointerDrag()
    {
        _pointerStart = null;
        _pointerDragStarted = false;
    }

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowLeft")
            Previous();
        else if (e.Key == "ArrowRight")
            Next();

        return Task.CompletedTask;
    }

    private void GoTo(int index)
    {
        if (ItemCount == 0)
            return;

        var nextIndex = index;

        if (nextIndex < 0)
            nextIndex = Loop ? ItemCount - 1 : 0;
        else if (nextIndex >= ItemCount)
            nextIndex = Loop ? 0 : ItemCount - 1;

        if (nextIndex == CurrentIndex)
            return;

        CurrentIndex = nextIndex;
        NotifyStateChanged();
    }

    private void NotifyStateChanged()
    {
        _api.NotifySelect();
        StateChanged?.Invoke();
    }

    private double GetAxisCoordinate(PointerEventArgs args)
    {
        return IsVertical ? args.ClientY : args.ClientX;
    }

    private bool TryGetTouchAxisCoordinate(TouchEventArgs args, out double coordinate)
    {
        var point = args.ChangedTouches.Length > 0 ? args.ChangedTouches[0] : args.Touches.Length > 0 ? args.Touches[0] : null;

        if (point is null)
        {
            coordinate = 0;
            return false;
        }

        coordinate = IsVertical ? point.ClientY : point.ClientX;
        return true;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "carousel";
        attributes["data-orientation"] = Orientation.Value;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
        hc.Add(Loop);
        hc.Add(CurrentIndex);
        hc.Add(ItemCount);
    }

}