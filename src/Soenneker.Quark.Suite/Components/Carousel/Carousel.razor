@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using System.Collections.Generic
@using System.Linq

<CascadingValue Name="ParentCarousel" Value="@this" IsFixed="true">
<div @attributes="BuildAttributes()" role="region" aria-roledescription="carousel" @onkeydown="HandleKeyDown">
    @ChildContent
</div>
</CascadingValue>

@code {
    /// <summary>
    /// Gets or sets orientation: horizontal or vertical.
    /// </summary>
    [Parameter]
    public string Orientation { get; set; } = "horizontal";

    [Parameter]
    public bool Loop { get; set; }

    [Parameter]
    public Action<CarouselApi>? SetApi { get; set; }

    internal event Action? StateChanged;
    private readonly CarouselApi _api = new();
    private Action<CarouselApi>? _lastSetApi;
    private readonly List<CarouselItem> _items = [];
    private int _lastPublishedCount = -1;
    private int _lastPublishedIndex = -1;

    internal int CurrentIndex { get; private set; }
    internal int ItemCount => _items.Count;
    internal bool CanScrollPrevious => ItemCount > 1 && (Loop || CurrentIndex > 0);
    internal bool CanScrollNext => ItemCount > 1 && (Loop || CurrentIndex < ItemCount - 1);

    protected override void OnInitialized()
    {
        _api.SelectedIndexAccessor = () => CurrentIndex;
        _api.ScrollSnapListAccessor = () => ItemCount <= 0 ? Array.Empty<int>() : Enumerable.Range(0, ItemCount).ToArray();
        _api.CanScrollPreviousAccessor = () => CanScrollPrevious;
        _api.CanScrollNextAccessor = () => CanScrollNext;
        _api.ScrollPreviousAction = Previous;
        _api.ScrollNextAction = Next;
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        _items.Clear();
        base.OnParametersSet();

        if (SetApi is not null && !ReferenceEquals(_lastSetApi, SetApi))
        {
            _lastSetApi = SetApi;
            SetApi(_api);
        }
    }

    /// <summary>
    /// Called from each <see cref="CarouselItem"/> during <c>OnParametersSet</c> (after this component clears the list).
    /// </summary>
    internal int RegisterItem(CarouselItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);

        if (CurrentIndex >= _items.Count)
            CurrentIndex = _items.Count - 1;

        return _items.IndexOf(item);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (_items.Count == 0)
            CurrentIndex = 0;
        else if (CurrentIndex >= _items.Count)
            CurrentIndex = _items.Count - 1;

        var count = _items.Count;
        var index = CurrentIndex;
        if (count != _lastPublishedCount || index != _lastPublishedIndex)
        {
            _lastPublishedCount = count;
            _lastPublishedIndex = index;
            NotifyStateChanged();
        }

        base.OnAfterRender(firstRender);
    }

    internal void Previous()
    {
        GoTo(CurrentIndex - 1);
    }

    internal void Next()
    {
        GoTo(CurrentIndex + 1);
    }

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Home")
        {
            GoTo(0);
            return Task.CompletedTask;
        }

        if (e.Key == "End")
        {
            if (ItemCount > 0)
                GoTo(ItemCount - 1);

            return Task.CompletedTask;
        }

        var vertical = string.Equals(Orientation, "vertical", StringComparison.OrdinalIgnoreCase);

        if (vertical)
        {
            if (e.Key == "ArrowUp")
                Previous();
            else if (e.Key == "ArrowDown")
                Next();
        }
        else
        {
            if (e.Key == "ArrowLeft")
                Previous();
            else if (e.Key == "ArrowRight")
                Next();
        }

        return Task.CompletedTask;
    }

    private void GoTo(int index)
    {
        if (ItemCount == 0)
            return;

        var nextIndex = index;

        if (nextIndex < 0)
            nextIndex = Loop ? ItemCount - 1 : 0;
        else if (nextIndex >= ItemCount)
            nextIndex = Loop ? 0 : ItemCount - 1;

        if (nextIndex == CurrentIndex)
            return;

        CurrentIndex = nextIndex;
    }

    private void NotifyStateChanged()
    {
        _api.NotifySelect();
        StateChanged?.Invoke();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "carousel";
        attributes["data-orientation"] = Orientation;

        if (!attributes.ContainsKey("tabindex"))
            attributes["tabindex"] = TabIndex ?? 0;

        if (!attributes.ContainsKey("aria-label"))
            attributes["aria-label"] = AriaLabel ?? "Carousel";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-carousel");
            AppendClass(ref cls, "relative");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
        hc.Add(Loop);
        hc.Add(CurrentIndex);
        hc.Add(ItemCount);
    }
}
