@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDisposable

<div @attributes="BuildAttributes()">
    <div @attributes="BuildInnerAttributes()">
        @ChildContent
    </div>
</div>

@code {
    [CascadingParameter(Name = "ParentCarousel")]
    private Carousel? ParentCarousel { get; set; }

    private Carousel? _subscribedCarousel;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ReferenceEquals(_subscribedCarousel, ParentCarousel))
            return;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        _subscribedCarousel = ParentCarousel;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged += OnCarouselStateChanged;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "carousel-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "overflow-hidden");
        });
    }

    private Dictionary<string, object> BuildInnerAttributes()
    {
        var attrs = new Dictionary<string, object>();
        var horizontal = ParentCarousel?.Orientation != "vertical";
        BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "flex");
            if (horizontal)
                AppendClass(ref cls, "-ml-4");
            else
                AppendClass(ref cls, "-mt-4 flex-col");
        });
        BuildStyleAttribute(attrs, (ref sty) =>
        {
            var index = ParentCarousel?.CurrentIndex ?? 0;
            var count = ParentCarousel?.ItemCount ?? 0;
            var axis = horizontal ? "X" : "Y";
            var step = count > 0 ? 100.0 / count : 0;
            AppendStyleDecl(ref sty, $"transform: translate{axis}(-{index * step}%); transition: transform 300ms ease-in-out");
        });
        return attrs;
    }

    private async void OnCarouselStateChanged()
    {
        await RefreshOffThread();
    }

    public override void Dispose()
    {
        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        base.Dispose();
    }
}
