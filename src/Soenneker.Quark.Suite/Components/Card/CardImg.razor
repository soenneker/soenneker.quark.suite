@namespace Soenneker.Quark
@inherits Soenneker.Quark.MediaElement
@implements ICardImg

<Image @attributes="BuildAttributes()"/>

@code {
    /// <summary>
    /// Gets or sets whether the image should be positioned at the top of the card.
    /// </summary>
    [Parameter]
    public bool Top { get; set; }

    /// <summary>
    /// Gets or sets whether the image should be positioned at the bottom of the card.
    /// </summary>
    [Parameter]
    public bool Bottom { get; set; }

    protected override void ApplyDefaultParameters()
    {
        Width ??= Quark.Width.IsFull;

        if (Top)
            Rounded ??= Quark.Rounded.Top.Xl;
        else if (Bottom)
            Rounded ??= Quark.Rounded.Bottom.Xl;

        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "card-img";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "object-cover");
        });

        if (Source.HasContent())
            attributes["src"] = Source;

        if (Alt.HasContent())
            attributes["alt"] = Alt;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Top);
        hc.Add(Bottom);
        hc.Add(Source);
        hc.Add(Alt);
    }
}
