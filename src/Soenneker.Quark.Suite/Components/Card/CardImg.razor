@namespace Soenneker.Quark
@inherits Soenneker.Quark.MediaElement
@implements ICardImg

<Image @attributes="BuildAttributes()"/>

@code {
    /// <summary>
    /// Gets or sets whether the image should be positioned at the top of the card.
    /// </summary>
    [Parameter]
    public bool AtTop { get; set; }

    /// <summary>
    /// Gets or sets whether the image should be positioned at the bottom of the card.
    /// </summary>
    [Parameter]
    public bool AtBottom { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Width ??= Quark.Width.IsFull;

        if (AtTop)
            Rounded ??= Quark.Rounded.Top.Xl;
        else if (AtBottom)
            Rounded ??= Quark.Rounded.Bottom.Xl;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        SetDefaultDataSlot("card-img");
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "object-cover");
        });

        if (Source.HasContent())
            attributes["src"] = Source;

        if (Alt.HasContent())
            attributes["alt"] = Alt;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AtTop);
        hc.Add(AtBottom);
        hc.Add(Source);
        hc.Add(Alt);
    }
}
