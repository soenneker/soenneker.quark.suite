@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ICardHeader

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "card-header";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-card-header");
            AppendClass(ref cls, "@container/card-header grid auto-rows-min grid-rows-[auto_auto] items-start gap-2 px-6");
            AppendClass(ref cls, "has-data-[slot=card-action]:grid-cols-[1fr_auto] [.border-b]:pb-6");
        });
    }
}
