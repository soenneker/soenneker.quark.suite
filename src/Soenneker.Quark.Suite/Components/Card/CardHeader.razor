@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ICardHeader

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "card-header";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/card-header @container/card-header grid auto-rows-min items-start gap-1 rounded-t-xl px-4");
            AppendClass(ref cls, "group-data-[size=sm]/card:px-3 has-data-[slot=card-action]:grid-cols-[1fr_auto] has-data-[slot=card-description]:grid-rows-[auto_auto]");
            AppendClass(ref cls, "[.border-b]:pb-4 group-data-[size=sm]/card:[.border-b]:pb-3");
        });
    }
}
