@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Button Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.IconSm" OnClick="HandlePreviousClick" Disabled="@(!(ParentCarousel?.CanScrollPrevious ?? false))" @attributes="BuildAttributes()">
    <Svg Size="Quark.Size.Is4" Class="cn-rtl-flip" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke="Quark.Stroke.Current" StrokeWidth="Quark.StrokeWidth.Is2"><path d="m15 18-6-6 6-6"/></Svg>
    <Span ScreenReader="Quark.ScreenReader.Only">Previous slide</Span>
</Button>

@code {
    [CascadingParameter(Name = "ParentCarousel")]
    private Carousel? ParentCarousel { get; set; }

    private Carousel? _subscribedCarousel;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "carousel-previous";

        Position ??= Quark.Position.Absolute;
        Rounded ??= Quark.Rounded.Full;
    }

    private async Task HandlePreviousClick(MouseEventArgs e)
    {
        if (ParentCarousel is not null)
            await ParentCarousel.Previous();

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ReferenceEquals(_subscribedCarousel, ParentCarousel))
            return;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        _subscribedCarousel = ParentCarousel;

        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged += OnCarouselStateChanged;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        var horizontal = ParentCarousel?.IsVertical != true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (horizontal)
                AppendClass(ref cls, "touch-manipulation top-1/2 -left-12 -translate-y-1/2");
            else
                AppendClass(ref cls, "touch-manipulation -top-12 left-1/2 -translate-x-1/2 rotate-90");
        });
    }

    private void OnCarouselStateChanged()
    {
        _ = RefreshOffThread();
    }

    public override async ValueTask DisposeAsync()
    {
        if (_subscribedCarousel is not null)
            _subscribedCarousel.StateChanged -= OnCarouselStateChanged;

        await base.DisposeAsync();
    }
}