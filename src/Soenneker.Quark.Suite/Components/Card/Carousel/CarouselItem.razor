@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()" role="group" aria-roledescription="slide">
    @ChildContent
</div>

@code {

    [CascadingParameter(Name = "ParentCarousel")]
    private Carousel? ParentCarousel { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        ParentCarousel?.RegisterItem();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "carousel-item";

        MinWidth ??= Quark.MinWidth.Is0;
        Shrink ??= Quark.Shrink.Is0;
        Grow ??= Quark.Grow.Is0;
        if (ParentCarousel?.IsVertical == true)
        {
            if (!HasClassToken("pt-"))
                Padding ??= Quark.Padding.FromTop.Is4;
        }
        else if (!HasClassToken("pl-"))
        {
            Padding ??= Quark.Padding.FromLeft.Is4;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (!HasClassToken("basis-"))
                AppendClass(ref cls, "basis-full");
        });
    }

    private bool HasClassToken(string tokenPart)
    {
        return Class?.Contains(tokenPart, StringComparison.Ordinal) == true;
    }

    public override async ValueTask DisposeAsync()
    {
        ParentCarousel?.UnregisterItem();
        await base.DisposeAsync();
    }

}