@namespace Soenneker.Quark
@inherits Soenneker.Quark.Component
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix

<Div Attributes="@BuildAttributes()">
    @if (ShowLabel)
    {
        <HoverCard OpenDelay="200">
            <HoverCardTrigger AsChild="true">
                <Label For="@_triggerId">@Label</Label>
            </HoverCardTrigger>
            <HoverCardContent Side="Side.Left" Align="Alignment.Start" Width='Quark.Width.Token("[260px]")' TextSize="Quark.TextSize.Sm">
                @Description
            </HoverCardContent>
        </HoverCard>
    }

    <Popover Open="@_open" OpenChanged="HandleOpenChanged">
        <PopoverTrigger AsChild="true">
            <Button Id="@_triggerId" Variant="ButtonVariant.Ghost" Role="button" AriaLabel="@AriaLabel" Class="@GetTriggerClass()">
                <Span DataSlot="model-selector-trigger-content" Display="Quark.Display.Flex" MinWidth="Quark.MinWidth.Is0" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is1">
                    <Span DataSlot="model-selector-trigger-title" Truncate="Quark.Truncate.Default" TextSize="Quark.TextSize.Sm">@SelectedLabel</Span>
                </Span>
                <Span DataSlot="model-selector-trigger-chevron" Transition="Quark.Transition.Transform" Duration="Quark.Duration.Is200" Class="data-[state=open]:rotate-180">
                    <Icon Name="LucideIcon.ChevronDown" Size="Quark.Size.Is4" Shrink="Quark.Shrink.Is0"/>
                </Span>
            </Button>
        </PopoverTrigger>
        <PopoverContent Align="Alignment.Start" Class="@MenuClass">
            <Div DataSlot="model-selector-group">
                <Div DataSlot="model-selector-label" Padding="Quark.Padding.OnX.Is3.OnY.Is2" TextSize="Quark.TextSize.Xs" FontWeight="Quark.FontWeight.Medium" TextColor="Quark.TextColor.MutedForeground">Select model</Div>
                <Div DataSlot="model-selector-radio-group">
                    @foreach (var option in Options)
                    {
                        <Button Type="@ButtonType.Button" DataSlot="model-selector-radio-item" Variant="ButtonVariant.Ghost" Width="Quark.Width.IsFull" MinHeight="Quark.Height.Is9" Position="Quark.Position.Relative" Cursor="Quark.Cursor.Pointer" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Start" Gap="Quark.Gap.Is2" Rounded="Quark.Rounded.Md" Padding='Quark.Padding.OnY.Is2.FromRight.Token("9").FromLeft.Is3' TextAlign="Quark.TextAlign.Start" TextSize="Quark.TextSize.Sm" BackgroundColor="Quark.BackgroundColor.OnFocus.Accent" TextColor="Quark.TextColor.OnFocus.AccentForeground" OutlineStyle="Quark.OutlineStyle.Hidden" Transition="Quark.Transition.Colors" Duration="Quark.Duration.Is0" UserSelect="Quark.UserSelect.None" @onclick="@(() => SelectOption(option))">
                            <Span DataSlot="model-selector-item-icon" Display="Quark.Display.Flex" Shrink="Quark.Shrink.Is0" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Center">
                                <Icon Name="@GetModelIcon(option)" Size="Quark.Size.Is4"/>
                            </Span>
                            <Span DataSlot="model-selector-radio-item-content" Display="Quark.Display.Flex" MinWidth="Quark.MinWidth.Is0" Flex="Quark.Flex.Is1" FlexDirection="Quark.FlexDirection.Col" Gap='Quark.Gap.Is0_25'>
                                <Span DataSlot="model-selector-item-title" Truncate="Quark.Truncate.Default" TextSize="Quark.TextSize.Sm" FontWeight="Quark.FontWeight.Normal">@option.Label</Span>
                                @if (option.Description.HasContent())
                                {
                                    <Span DataSlot="model-selector-item-description" Truncate="Quark.Truncate.Default" TextSize="Quark.TextSize.Xs" FontWeight="Quark.FontWeight.Light" TextColor="Quark.TextColor.MutedForeground">@option.Description</Span>
                                }
                            </Span>
                            <Span DataSlot="model-selector-item-indicator" PointerEvents="Quark.PointerEvents.None" Position="Quark.Position.Absolute" Right="Quark.Right.Is3" Display="Quark.Display.Flex" Size="Quark.Size.Is4" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Center" Opacity="@(IsSelected(option) ? Quark.Opacity.Is100 : Quark.Opacity.Is0)">
                                <Icon Name="LucideIcon.Check" Size="Quark.Size.Is4"/>
                            </Span>
                        </Button>
                    }
                </Div>
            </Div>
        </PopoverContent>
    </Popover>
</Div>

@code {
    private readonly string _triggerId = BlazorIdGenerator.New("model-selector");
    private bool _open;
    private ModelSelectorOption? _peekedOption;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public IReadOnlyList<ModelSelectorOption> Options { get; set; } =
    [
        new("gpt-4", "GPT-4", "OpenAI", "Most capable, best for complex tasks"),
        new("gpt-4o-mini", "GPT-4o Mini", "OpenAI", "Fast and affordable"),
        new("claude-3.5", "Claude 3.5", "Anthropic", "Strong reasoning and analysis"),
        new("gemini-1.5-flash", "Gemini 1.5 Flash", "Google", "Fast and versatile")
    ];

    [Parameter]
    public IReadOnlyList<ModelSelectorOption> SubmenuOptions { get; set; } =
    [
        new("claude-opus-4.1", "Claude Opus 4.1", "Anthropic"),
        new("gemini-2.5-pro", "Gemini 2.5 Pro", "Google")
    ];

    [Parameter]
    public string Placeholder { get; set; } = "Select a model...";

    [Parameter]
    public string Label { get; set; } = "Model";

    [Parameter]
    public string Description { get; set; } = "The model which will generate the completion. Some models are suitable for natural language tasks, others specialize in code.";

    [Parameter]
    public bool ShowLabel { get; set; }

    [Parameter]
    public string SearchPlaceholder { get; set; } = "Search Models...";

    [Parameter]
    public string EmptyText { get; set; } = "No Models found.";

    [Parameter]
    public string? AriaLabel { get; set; } = "Select a model";

    [Parameter]
    public string MenuClass { get; set; } = "w-[264px] p-1";

    [Parameter]
    public bool RightAligned { get; set; } = true;

    private ModelSelectorOption? SelectedOption => Options.FirstOrDefault(IsSelected);

    private string SelectedLabel => SelectedOption?.Label ?? Placeholder;

    private string PeekedLabel => _peekedOption?.Label ?? SelectedOption?.Label ?? Placeholder;

    private string? PeekedDescription => _peekedOption?.Description ?? SelectedOption?.Description;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Grid;
        Gap ??= Quark.Gap.Is3;
    }

    protected override void OnParametersSet()
    {
        _peekedOption ??= SelectedOption ?? Options.FirstOrDefault();
        base.OnParametersSet();
    }

    private Task HandleOpenChanged(bool open)
    {
        _open = open;

        if (open)
            _peekedOption = SelectedOption ?? Options.FirstOrDefault();

        return Task.CompletedTask;
    }

    private bool IsSelected(ModelSelectorOption option) => string.Equals(Value, option.Value, StringComparison.Ordinal);

    private async Task SelectOption(ModelSelectorOption option)
    {
        _peekedOption = option;
        _open = false;

        if (string.Equals(Value, option.Value, StringComparison.Ordinal))
            return;

        Value = option.Value;
        await ValueChanged.InvokeAsync(option.Value);
    }

    private string GetTriggerClass()
    {
        const string triggerClass = "inline-flex h-8 cursor-pointer items-center gap-1 rounded-full bg-muted px-3 text-sm font-normal text-primary shadow-none transition-all duration-200 ease-out hover:bg-border";
        return string.IsNullOrWhiteSpace(Class) ? triggerClass : $"{triggerClass} {Class}";
    }

    private static LucideIcon GetModelIcon(ModelSelectorOption option)
    {
        return option.Group switch
        {
            "Anthropic" => LucideIcon.Bot,
            "Google" => LucideIcon.Sparkles,
            _ => LucideIcon.Circle
        };
    }

}
