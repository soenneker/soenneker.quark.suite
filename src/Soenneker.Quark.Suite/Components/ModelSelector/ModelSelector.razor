@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids

<Div Display="Display.Grid" Gap="Gap.Is3">
    @if (ShowLabel)
    {
        <HoverCard OpenDelay="200">
            <HoverCardTrigger AsChild="true">
                <Label For="@_triggerId">@Label</Label>
            </HoverCardTrigger>
            <HoverCardContent Side="left" PlacementAlign="start" Class="w-[260px] text-sm">
                @Description
            </HoverCardContent>
        </HoverCard>
    }

    <Popover Open="@_open" OpenChanged="HandleOpenChanged">
        <PopoverTrigger AsChild="true">
            <Button Id="@_triggerId"
                    Variant="ButtonVariant.Ghost"
                    Role="button"
                    AriaLabel="@AriaLabel"
                    Class="@GetTriggerClass()">
                <span data-slot="model-selector-trigger-content" class="flex min-w-0 items-center gap-1">
                    <span data-slot="model-selector-trigger-title" class="truncate text-sm">@SelectedLabel</span>
                </span>
                <span data-slot="model-selector-trigger-chevron" class="transition-transform duration-200 data-[state=open]:rotate-180">
                    <Icon Name="LucideIcon.ChevronDown" Class="size-4 shrink-0" />
                </span>
            </Button>
        </PopoverTrigger>
        <PopoverContent PlacementAlign="start" Class="@MenuClass">
            <div data-slot="model-selector-group">
                <div data-slot="model-selector-label" class="px-3 py-2 text-xs font-medium text-muted-foreground">Select model</div>
                <div data-slot="model-selector-radio-group">
                    @foreach (ModelSelectorOption option in Options)
                    {
                        <button type="button"
                                data-slot="model-selector-radio-item"
                                class="relative flex min-h-9 w-full cursor-pointer items-center gap-2 rounded-md py-2 pr-9 pl-3 text-left text-sm outline-hidden transition-colors duration-0 select-none hover:bg-accent focus:bg-accent focus:text-accent-foreground"
                                @onclick="@(() => SelectOption(option))">
                            <span data-slot="model-selector-item-icon" class="flex shrink-0 items-center justify-center">
                                <Icon Name="@GetModelIcon(option)" Class="size-4" />
                            </span>
                            <span data-slot="model-selector-radio-item-content" class="flex min-w-0 flex-1 flex-col gap-0.25">
                                <span data-slot="model-selector-item-title" class="truncate text-sm font-normal">@option.Label</span>
                                @if (option.Description.HasContent())
                                {
                                    <span data-slot="model-selector-item-description" class="truncate text-xs font-light text-muted-foreground">@option.Description</span>
                                }
                            </span>
                            <span data-slot="model-selector-item-indicator" class="@GetCheckClass(option)">
                                <Icon Name="LucideIcon.Check" Class="size-4" />
                            </span>
                        </button>
                    }
                </div>
            </div>
        </PopoverContent>
    </Popover>
</Div>

@code {
    private readonly string _triggerId = BlazorIdGenerator.New("model-selector");
    private bool _open;
    private ModelSelectorOption? _peekedOption;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public IReadOnlyList<ModelSelectorOption> Options { get; set; } =
    [
        new("gpt-4", "GPT-4", "OpenAI", "Most capable, best for complex tasks"),
        new("gpt-4o-mini", "GPT-4o Mini", "OpenAI", "Fast and affordable"),
        new("claude-3.5", "Claude 3.5", "Anthropic", "Strong reasoning and analysis"),
        new("gemini-1.5-flash", "Gemini 1.5 Flash", "Google", "Fast and versatile")
    ];

    [Parameter]
    public IReadOnlyList<ModelSelectorOption> SubmenuOptions { get; set; } =
    [
        new("claude-opus-4.1", "Claude Opus 4.1", "Anthropic"),
        new("gemini-2.5-pro", "Gemini 2.5 Pro", "Google")
    ];

    [Parameter]
    public string Placeholder { get; set; } = "Select a model...";

    [Parameter]
    public string Label { get; set; } = "Model";

    [Parameter]
    public string Description { get; set; } =
        "The model which will generate the completion. Some models are suitable for natural language tasks, others specialize in code.";

    [Parameter]
    public bool ShowLabel { get; set; }

    [Parameter]
    public string SearchPlaceholder { get; set; } = "Search Models...";

    [Parameter]
    public string EmptyText { get; set; } = "No Models found.";

    [Parameter]
    public string? AriaLabel { get; set; } = "Select a model";

    [Parameter]
    public string Class { get; set; } = "";

    [Parameter]
    public string MenuClass { get; set; } = "w-[264px] p-1";

    [Parameter]
    public bool RightAligned { get; set; } = true;

    private ModelSelectorOption? SelectedOption => Options.FirstOrDefault(IsSelected);

    private string SelectedLabel => SelectedOption?.Label ?? Placeholder;

    private string PeekedLabel => _peekedOption?.Label ?? SelectedOption?.Label ?? Placeholder;

    private string? PeekedDescription => _peekedOption?.Description ?? SelectedOption?.Description;

    protected override void OnParametersSet()
    {
        _peekedOption ??= SelectedOption ?? Options.FirstOrDefault();
        base.OnParametersSet();
    }

    private Task HandleOpenChanged(bool open)
    {
        _open = open;

        if (open)
            _peekedOption = SelectedOption ?? Options.FirstOrDefault();

        return Task.CompletedTask;
    }

    private bool IsSelected(ModelSelectorOption option) => string.Equals(Value, option.Value, StringComparison.Ordinal);

    private async Task SelectOption(ModelSelectorOption option)
    {
        _peekedOption = option;
        _open = false;

        if (string.Equals(Value, option.Value, StringComparison.Ordinal))
            return;

        Value = option.Value;
        await ValueChanged.InvokeAsync(option.Value);
    }

    private string GetTriggerClass()
    {
        const string triggerClass = "inline-flex h-8 cursor-pointer items-center gap-1 rounded-full bg-muted px-3 text-sm font-normal text-primary shadow-none transition-all duration-200 ease-out hover:bg-border";
        return string.IsNullOrWhiteSpace(Class) ? triggerClass : $"{triggerClass} {Class}";
    }

    private string GetCheckClass(ModelSelectorOption option) =>
        IsSelected(option)
            ? "pointer-events-none absolute right-3 flex size-4 items-center justify-center opacity-100"
            : "pointer-events-none absolute right-3 flex size-4 items-center justify-center opacity-0";

    private static LucideIcon GetModelIcon(ModelSelectorOption option)
    {
        return option.Group switch
        {
            "Anthropic" => LucideIcon.Bot,
            "Google" => LucideIcon.Sparkles,
            _ => LucideIcon.Circle
        };
    }
}
