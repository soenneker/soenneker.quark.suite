
@using Soenneker.Bradix
@using System.Collections.Generic

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements IDropdownMenu

<BradixDropdownMenuPortal>
    <BradixDropdownMenuContent Side="@ResolvedSide"
                               Align="@ResolvedAlign"
                               SideOffset="@SideOffset"
                               AlignOffset="@AlignOffset"
                               ArrowPadding="@ArrowPadding"
                               AvoidCollisions="@AvoidCollisions"
                               CollisionPadding="@CollisionPadding"
                               CollisionBoundarySelector="@CollisionBoundarySelector"
                               CollisionBoundarySelectors="@CollisionBoundarySelectors"
                               Sticky="@Sticky"
                               HideWhenDetached="@HideWhenDetached"
                               AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixDropdownMenuContent>
</BradixDropdownMenuPortal>

@code {
    /// <summary>
    /// Gets or sets whether the dropdown menu should be right-aligned.
    /// </summary>
    [Parameter]
    public bool RightAligned { get; set; }

    /// <summary>
    /// Gets or sets the direction of the dropdown menu.
    /// </summary>
    [Parameter]
    public Direction Direction { get; set; } = Direction.Default;

    [Parameter]
    public double SideOffset { get; set; } = 4;

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [CascadingParameter(Name = nameof(ParentDropdown))]
    public Dropdown? ParentDropdown { get; set; }

    private bool ResolvedRightAligned => ParentDropdown?.RightAligned ?? RightAligned;

    private Direction ResolvedDirection => ParentDropdown?.Direction ?? Direction;

    private BradixSide ResolvedSide => ResolvedDirection?.Value switch
    {
        Direction.UpValue => BradixSide.Top,
        Direction.EndValue => BradixSide.Right,
        Direction.StartValue => BradixSide.Left,
        _ => BradixSide.Bottom
    };

    private BradixAlignment ResolvedAlign => ResolvedRightAligned ? BradixAlignment.End : BradixAlignment.Start;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        ZIndex ??= "z-50";
        MaxHeight ??= "max-h-(--radix-dropdown-menu-content-available-height)";
        Width ??= "w-(--radix-dropdown-menu-trigger-width)";
        MinWidth ??= "min-w-32";
        OverflowX ??= Quark.Overflow.X.Hidden;
        OverflowY ??= Quark.Overflow.Y.Auto;
        Rounded ??= Quark.Rounded.Lg;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is1;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Ring ??= Quark.Ring.One;
        RingColor ??= "ring-foreground/10";
        OutlineStyle ??= Quark.OutlineStyle.None;
        BoxShadow ??= Quark.BoxShadow.Md;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-content";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "origin-(--radix-dropdown-menu-content-transform-origin) duration-100");
            AppendClass(ref cls, "data-[state=closed]:animate-out data-[state=closed]:overflow-hidden data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
        });
    }

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("id");
        attributes.Remove("data-state");
        attributes.Remove("role");
        attributes.Remove("tabindex");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ResolvedRightAligned);
        hc.Add(ResolvedDirection);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (string selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
    }
}
