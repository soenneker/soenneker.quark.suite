
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements IDropdownMenu

<BradixDropdownMenuPortal>
    <BradixDropdownMenuContent Side="@ResolvedSide"
                               Align="@ResolvedAlign"
                               SideOffset="4"
                               AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixDropdownMenuContent>
</BradixDropdownMenuPortal>

@code {
    /// <summary>
    /// Gets or sets whether the dropdown menu should be right-aligned.
    /// </summary>
    [Parameter]
    public bool RightAligned { get; set; }

    /// <summary>
    /// Gets or sets the direction of the dropdown menu.
    /// </summary>
    [Parameter]
    public Direction Direction { get; set; } = Direction.Default;

    [CascadingParameter(Name = nameof(ParentDropdown))]
    public Dropdown? ParentDropdown { get; set; }

    private bool ResolvedRightAligned => ParentDropdown?.RightAligned ?? RightAligned;

    private Direction ResolvedDirection => ParentDropdown?.Direction ?? Direction;

    private BradixSide ResolvedSide => ResolvedDirection?.Value switch
    {
        Direction.UpValue => BradixSide.Top,
        Direction.EndValue => BradixSide.Right,
        Direction.StartValue => BradixSide.Left,
        _ => BradixSide.Bottom
    };

    private BradixAlignment ResolvedAlign => ResolvedRightAligned ? BradixAlignment.End : BradixAlignment.Start;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-content";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown-menu");
            AppendClass(ref cls, "z-50 max-h-(--radix-dropdown-menu-content-available-height) min-w-[8rem] origin-(--radix-dropdown-menu-content-transform-origin) overflow-x-hidden overflow-y-auto rounded-md border bg-popover p-1 text-popover-foreground shadow-md");
            AppendClass(ref cls, "data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");

            var directionClass = ResolvedDirection?.Value switch
            {
                Direction.UpValue => "data-[state=open]:slide-in-from-bottom-2",
                Direction.EndValue => "data-[state=open]:slide-in-from-left-2 rtl:data-[state=open]:slide-in-from-right-2",
                Direction.StartValue => "data-[state=open]:slide-in-from-right-2 rtl:data-[state=open]:slide-in-from-left-2",
                _ => "data-[state=open]:slide-in-from-top-2",
            };
            if (directionClass != null)
                AppendClass(ref cls, directionClass);
        });
    }

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("id");
        attributes.Remove("data-state");
        attributes.Remove("role");
        attributes.Remove("tabindex");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ResolvedRightAligned);
        hc.Add(ResolvedDirection);
    }
}