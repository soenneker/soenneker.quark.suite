
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDropdownDivider

<BradixDropdownMenuSeparator AdditionalAttributes="@SeparatorAttributes" />

@code {
    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-separator";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "-mx-1 my-1 h-px bg-border");
        });
    }
}
