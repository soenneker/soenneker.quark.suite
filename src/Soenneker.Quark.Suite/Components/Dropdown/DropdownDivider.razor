
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDropdownDivider

<BradixDropdownMenuSeparator AdditionalAttributes="@SeparatorAttributes" />

@code {
    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "dropdown-menu-separator";
        Margin ??= Quark.Margin.OnX.Negative1.OnY.Is1;
        Height ??= Quark.Height.IsPx;
        BackgroundColor ??= Quark.BackgroundColor.Border;

    }
}