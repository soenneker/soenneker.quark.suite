@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix
@using BradixCheckboxCheckedState = Soenneker.Bradix.Enums.BradixCheckboxCheckedState

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement

<BradixDropdownMenuCheckboxItem Checked="@ResolvedCheckedState"
                                CheckedChanged="HandleCheckedStateChanged"
                                CloseOnSelect="@AutoClose"
                                Disabled="@Disabled"
                                AdditionalAttributes="@CheckboxAttributes">
    <span class="pointer-events-none absolute right-2 flex items-center justify-center"
          data-slot="dropdown-menu-checkbox-item-indicator">
        <BradixDropdownMenuItemIndicator>
            <Icon Name="LucideIcon.Check" />
        </BradixDropdownMenuItemIndicator>
    </span>
    @ChildContent
</BradixDropdownMenuCheckboxItem>

@code {
    [Parameter]
    public bool AutoClose { get; set; }

    [Parameter]
    public bool Indented { get; set; }

    private BradixCheckboxCheckedState ResolvedCheckedState =>
        Checked ? BradixCheckboxCheckedState.Checked : BradixCheckboxCheckedState.Unchecked;

    private IReadOnlyDictionary<string, object> CheckboxAttributes => BuildCheckboxAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-checkbox-item";
        attributes["data-state"] = Checked ? "checked" : "unchecked";

        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "outline-hidden");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground focus:**:text-accent-foreground data-inset:pl-7 data-disabled:pointer-events-none data-disabled:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is1.Token("1.5");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is2.OnY.FromRight.Token("8").FromLeft.Token("1.5");
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;
    }

    private IReadOnlyDictionary<string, object> BuildCheckboxAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("aria-checked");
        attributes.Remove("tabindex");
        attributes.Remove("data-disabled");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(AutoClose);
        hc.Add(Indented);
    }

    private async Task HandleCheckedStateChanged(BradixCheckboxCheckedState state)
    {
        var next = state == BradixCheckboxCheckedState.Checked;
        Checked = next;
        await CheckedChanged.InvokeIfHasDelegate(next);
    }
}
