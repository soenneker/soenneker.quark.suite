@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements IDropdownFocusableItem

<div @onclick="OnClickHandler" @onkeydown="HandleMenuKeyDown" @attributes="BuildAttributes()" @ref="_elementRef">
    <span class="pointer-events-none absolute left-2 flex size-3.5 items-center justify-center rtl:left-auto rtl:right-2">
        @if (Checked)
        {
            <Icon Name="LucideIcon.Check" Class="size-4" />
        }
    </span>
    @ChildContent
</div>

@code {
    private ElementReference _elementRef;

    [Parameter]
    public bool AutoClose { get; set; }

    [Parameter]
    public bool Inset { get; set; }

    [CascadingParameter(Name = nameof(ParentDropdown))]
    public Dropdown? ParentDropdown { get; set; }

    [CascadingParameter(Name = "DropdownNavigationSub")]
    private DropdownSub? NavigationSub { get; set; }

    bool IDropdownFocusableItem.IsDisabledForNavigation => Disabled;

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (!firstRender)
            return;

        if (NavigationSub is not null)
            NavigationSub.RegisterItem(this);
        else
            ParentDropdown?.RegisterItem(this);
    }

    private async Task OnClickHandler()
    {
        if (Disabled)
            return;

        var next = !Checked;
        Checked = next;
        await CheckedChanged.InvokeIfHasDelegate(next);

        if (AutoClose && ParentDropdown is not null)
            await ParentDropdown.Hide();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-checkbox-item";
        attributes["data-state"] = Checked ? "checked" : "unchecked";
        attributes["role"] = "menuitemcheckbox";
        attributes["aria-checked"] = Checked ? "true" : "false";
        attributes["tabindex"] = -1;

        if (Inset)
            attributes["data-inset"] = "true";

        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown-checkbox-item");
            AppendClass(ref cls, "relative flex cursor-default items-center gap-2 rounded-sm py-1.5 pr-2 pl-8 rtl:pr-8 rtl:pl-2 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50");
            AppendClass(ref cls, "data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(AutoClose);
        hc.Add(Inset);
    }

    private async Task HandleMenuKeyDown(KeyboardEventArgs e)
    {
        if (ParentDropdown is null)
            return;

        if (e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
        {
            if (NavigationSub is not null)
                await NavigationSub.HandleItemNavigationAsync(this, e.Key);
            else
                await ParentDropdown.HandleItemNavigationAsync(this, e.Key);
        }
        else if (e.Key is "Enter" or " ")
            await OnClickHandler();
        else if (e.Key == "ArrowLeft" && NavigationSub is not null)
            await NavigationSub.CloseAndFocusTriggerAsync();
        else if (e.Key == "Escape")
        {
            if (NavigationSub is not null)
                await NavigationSub.CloseAndFocusTriggerAsync();
            else
            {
                await ParentDropdown.Hide();
                await ParentDropdown.FocusTriggerAsync();
            }
        }
    }

    async Task IDropdownFocusableItem.FocusAsync()
    {
        await _elementRef.FocusAsync();
    }

    public override void Dispose()
    {
        if (NavigationSub is not null)
            NavigationSub.UnregisterItem(this);
        else
            ParentDropdown?.UnregisterItem(this);

        base.Dispose();
    }
}
