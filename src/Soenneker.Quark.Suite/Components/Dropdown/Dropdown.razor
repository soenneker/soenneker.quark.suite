
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@using Soenneker.Blazor.Extensions.EventCallback
@implements IDropdown

<BradixDropdownMenu Open="@Visible"
                    OpenChanged="HandleOpenChanged"
                    ContentIdOverride="@DropdownMenuTargetId">
    <CascadingValue Name="ParentDropdown" Value="this" IsFixed="true">
        <div @attributes="BuildAttributes()">
            @ChildContent
        </div>
    </CascadingValue>
</BradixDropdownMenu>

@code {
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets whether the dropdown menu should be right-aligned.
    /// </summary>
    [Parameter]
    public bool RightAligned { get; set; }

    /// <summary>
    /// Gets or sets the direction of the dropdown.
    /// </summary>
    [Parameter]
    public Direction Direction { get; set; } = Direction.Default;

    /// <summary>
    /// Gets or sets whether this is a submenu dropdown.
    /// </summary>
    [Parameter]
    public bool IsSubmenu { get; set; }

    /// <summary>
    /// Gets or sets whether this is a button group dropdown.
    /// </summary>
    [Parameter]
    public bool IsGroup { get; set; }

    /// <summary>
    /// Gets or sets the target ID for the dropdown menu.
    /// </summary>
    [Parameter]
    public string? DropdownMenuTargetId { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (Id.IsNullOrEmpty())
            Id = $"dropdown_{Guid.NewGuid():N}";
    }

    private Task HandleOpenChanged(bool open)
    {
        return SetVisibleAsync(open);
    }

    private async Task SetVisibleAsync(bool visible)
    {
        if (Visible == visible)
            return;

        Visible = visible;
        InvalidateRender();
        Refresh();

        await VisibleChanged.InvokeIfHasDelegate(visible);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu";
        attributes["data-state"] = Visible ? "open" : "closed";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown");
            AppendClass(ref cls, IsGroup ? "inline-flex relative" : "relative");
            
            if (Visible)
                AppendClass(ref cls, "show z-50");
            if (RightAligned)
                AppendClass(ref cls, "dropend");
            if (Disabled)
                AppendClass(ref cls, "disabled");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Visible);
        hc.Add(RightAligned);
        hc.Add(Disabled);
        hc.Add(Direction);
        hc.Add(IsSubmenu);
        hc.Add(IsGroup);
        hc.Add(DropdownMenuTargetId);
    }
}