
@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@using Soenneker.Blazor.Extensions.EventCallback
@implements IDropdown

<CascadingValue Name="ParentDropdown" Value="this" IsFixed="true">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly List<IDropdownFocusableItem> _items = [];
    private DropdownToggle? _toggle;
    private ElementReference _triggerElement;
    private bool _hasTriggerElement;

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets whether the dropdown menu should be right-aligned.
    /// </summary>
    [Parameter]
    public bool RightAligned { get; set; }

    /// <summary>
    /// Gets or sets the direction of the dropdown.
    /// </summary>
    [Parameter]
    public Direction Direction { get; set; } = Direction.Default;

    /// <summary>
    /// Gets or sets whether this is a submenu dropdown.
    /// </summary>
    [Parameter]
    public bool IsSubmenu { get; set; }

    /// <summary>
    /// Gets or sets whether this is a button group dropdown.
    /// </summary>
    [Parameter]
    public bool IsGroup { get; set; }

    /// <summary>
    /// Gets or sets the target ID for the dropdown menu.
    /// </summary>
    [Parameter]
    public string? DropdownMenuTargetId { get; set; }

    internal string MenuId => DropdownMenuTargetId.HasContent() ? DropdownMenuTargetId! : $"{Id}_menu";

    internal bool HasTriggerElement => _hasTriggerElement;

    internal ElementReference TriggerElement => _triggerElement;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (Id.IsNullOrEmpty())
            Id = $"dropdown_{Guid.NewGuid():N}";
    }

    internal async Task Toggle()
    {
        if (Disabled)
            return;

        Visible = !Visible;
        InvalidateRender();
        Refresh();
        await VisibleChanged.InvokeIfHasDelegate(Visible);
    }

    internal async Task Hide()
    {
        if (!Visible)
            return;

        Visible = false;
        InvalidateRender();
        Refresh();
        await VisibleChanged.InvokeIfHasDelegate(false);
    }

    internal void RegisterItem(IDropdownFocusableItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);
    }

    internal void UnregisterItem(IDropdownFocusableItem item)
    {
        _items.Remove(item);
    }

    internal void RegisterToggle(DropdownToggle toggle)
    {
        _toggle = toggle;
    }

    internal void SetTriggerElement(ElementReference elementReference)
    {
        _triggerElement = elementReference;
        _hasTriggerElement = true;
    }

    internal async Task OpenAndFocusFirstItemAsync()
    {
        if (!Visible)
            await Toggle();

        var firstItem = _items.FirstOrDefault(i => !i.IsDisabledForNavigation);
        if (firstItem is not null)
            await firstItem.FocusAsync();
    }

    internal async Task FocusTriggerAsync()
    {
        if (_toggle is not null)
            await _toggle.FocusAsync();
    }

    internal async Task HandleItemNavigationAsync(IDropdownFocusableItem currentItem, string key)
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
            return;

        var currentIndex = enabledItems.FindIndex(i => ReferenceEquals(i, currentItem));
        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledItems.Count - 1,
            "ArrowDown" => (currentIndex + 1) % enabledItems.Count,
            "ArrowUp" => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            _ => -1
        };

        if (nextIndex >= 0)
            await enabledItems[nextIndex].FocusAsync();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu";
        attributes["data-state"] = Visible ? "open" : "closed";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown");
            AppendClass(ref cls, IsGroup ? "inline-flex relative" : "relative");
            
            if (Visible)
                AppendClass(ref cls, "show z-50");
            if (RightAligned)
                AppendClass(ref cls, "dropend");
            if (Disabled)
                AppendClass(ref cls, "disabled");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Visible);
        hc.Add(RightAligned);
        hc.Add(Disabled);
        hc.Add(Direction);
        hc.Add(IsSubmenu);
        hc.Add(IsGroup);
        hc.Add(DropdownMenuTargetId);
    }
}