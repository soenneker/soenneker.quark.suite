@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixDropdownMenuSubTrigger Disabled="@Disabled"
                              AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <Icon Name="LucideIcon.ChevronRight" Margin="Quark.Margin.Auto.FromLeft" Class="cn-rtl-flip" />
</BradixDropdownMenuSubTrigger>

@code {
    [Parameter]
    public bool Indented { get; set; }

    [Parameter]
    public bool Open { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Token("1.5");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Token("1.5").OnX.Is1.OnY;
        TextSize ??= Quark.TextSize.Sm;
        OutlineStyle ??= "outline-hidden";
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        SetDefaultDataSlot("dropdown-menu-sub-trigger");

        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground not-data-[variant=destructive]:focus:**:text-accent-foreground data-inset:pl-7 data-open:bg-accent data-open:text-accent-foreground");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Indented);
        hc.Add(Open);
    }
}
