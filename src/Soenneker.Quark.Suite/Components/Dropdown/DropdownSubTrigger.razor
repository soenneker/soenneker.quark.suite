@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixDropdownMenuSubTrigger Disabled="@Disabled"
                              AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <Icon Name="LucideIcon.ChevronRight" Class="ml-auto size-4 rtl:ml-0 rtl:mr-auto rtl:rotate-180" />
</BradixDropdownMenuSubTrigger>

@code {
    [Parameter]
    public bool Indented { get; set; }

    [Parameter]
    public bool Open { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Is2.OnX;
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        var isOpen = Open;
        attributes["data-slot"] = "dropdown-menu-sub-trigger";
        attributes["data-state"] = isOpen ? "open" : "closed";

        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "cursor-default py-1.5 outline-hidden");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8 data-[state=open]:bg-accent data-[state=open]:text-accent-foreground");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Indented);
        hc.Add(Open);
    }
}
