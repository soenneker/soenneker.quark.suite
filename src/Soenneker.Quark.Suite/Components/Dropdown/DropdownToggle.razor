@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IDropdownToggle

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixDropdownMenuTrigger Disabled="@(Disabled || ParentDropdown?.Disabled == true)"
                               OnClick="Clicked"
                               AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixDropdownMenuTrigger>
}

@code {
    /// <summary>
    /// Gets or sets whether this is a split button toggle.
    /// </summary>
    [Parameter]
    public bool IsSplit { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the toggle is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> Clicked { get; set; }

    [CascadingParameter(Name = nameof(ParentDropdown))]
    public Dropdown? ParentDropdown { get; set; }

    [CascadingParameter]
    private BradixDropdownMenu? DropdownMenu { get; set; }

    [CascadingParameter]
    private BradixMenu? Menu { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        AlignUtility ??= Quark.Align.ItemsCenter.JustifyCenter;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-trigger";
        attributes["data-state"] = DropdownMenu?.CurrentOpen == true ? "open" : "closed";
        attributes["aria-haspopup"] = "menu";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "shrink-0 outline-none cursor-pointer focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            if (IsSplit)
                AppendClass(ref cls, "border border-input bg-background shadow-xs hover:bg-accent hover:text-accent-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50 h-9 px-4 py-2 has-[>svg]:px-3");
            else
                AppendClass(ref cls, "bg-secondary text-secondary-foreground hover:bg-secondary/80 h-9 px-4 py-2 has-[>svg]:px-3");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });

        attributes["aria-expanded"] = DropdownMenu?.CurrentOpen == true ? "true" : "false";

        if (DropdownMenu is not null)
            attributes["aria-controls"] = DropdownMenu.ContentId;

        if (Disabled || ParentDropdown?.Disabled == true)
        {
            attributes["disabled"] = true;
        }
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            ParentDisabled = Disabled || ParentDropdown?.Disabled == true,
            IsOpen = DropdownMenu?.CurrentOpen == true,
            DataState = DropdownMenu?.CurrentOpen == true ? "open" : "closed",
            AriaHasPopup = "menu",
            AriaControls = DropdownMenu?.ContentId,
            RegisterElement = elementReference => { Menu?.RegisterTrigger(elementReference); },
            Toggle = DropdownMenu is null ? null : async () =>
            {
                Menu?.SetFocusFirstItemOnOpen(false);
                await DropdownMenu.ToggleOpen();
            },
            Open = DropdownMenu is null ? null : async () =>
            {
                Menu?.SetFocusFirstItemOnOpen(true);
                await DropdownMenu.SetOpen(true);
            },
            Close = DropdownMenu is null ? null : () => DropdownMenu.SetOpen(false),
            OnKeyDown = HandleToggleKeyDown
        };
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("type");
        attributes.Remove("id");
        attributes.Remove("data-state");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("disabled");

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(IsSplit);
        hc.Add(AsChild);
        hc.Add(DropdownMenu?.CurrentOpen == true);
        hc.Add(ParentDropdown?.Disabled == true);
    }

    private async Task HandleToggleKeyDown(KeyboardEventArgs e)
    {
        if (DropdownMenu is null || ParentDropdown is null || Disabled || ParentDropdown.Disabled)
            return;

        if (e.Key is "ArrowDown" or "Enter" or " ")
        {
            Menu?.SetFocusFirstItemOnOpen(true);
            await DropdownMenu.SetOpen(true);
        }
        else if (e.Key == "Escape" && DropdownMenu.CurrentOpen)
            await DropdownMenu.SetOpen(false);
    }
}
