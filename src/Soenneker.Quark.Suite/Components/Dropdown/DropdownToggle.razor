@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@using Soenneker.Blazor.Extensions.EventCallback
@implements IDropdownToggle

@if (AsChild)
{
    <span @ref="_buttonRef" @onclick="OnClickHandler" @onkeydown="HandleToggleKeyDown" @attributes="BuildWrapperAttributes()">
        <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
            @ChildContent
        </CascadingValue>
    </span>
}
else
{
    <button @attributes="BuildAttributes()" type="button" @onclick="OnClickHandler" @onkeydown="HandleToggleKeyDown" @ref="_buttonRef">
        @ChildContent
    </button>
}

@code {
    private ElementReference _buttonRef;

    /// <summary>
    /// Gets or sets whether this is a split button toggle.
    /// </summary>
    [Parameter]
    public bool IsSplit { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the toggle is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> Clicked { get; set; }

    [CascadingParameter(Name = nameof(ParentDropdown))]
    public Dropdown? ParentDropdown { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender)
        {
            ParentDropdown?.RegisterToggle(this);
            ParentDropdown?.SetTriggerElement(_buttonRef);
        }
    }

    private async Task OnClickHandler(MouseEventArgs e)
    {
        if (Disabled || ParentDropdown?.Disabled == true)
            return;

        if (ParentDropdown is not null)
            await ParentDropdown.Toggle();

        await Clicked.InvokeIfHasDelegate(e);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-trigger";
        attributes["data-state"] = ParentDropdown?.Visible == true ? "open" : "closed";
        attributes["aria-haspopup"] = "menu";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown-toggle");
            AppendClass(ref cls, "inline-flex items-center justify-center gap-2 rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed");
            if (IsSplit)
                AppendClass(ref cls, "border border-input bg-background hover:bg-accent hover:text-accent-foreground h-10 px-4 py-2");
            else
                AppendClass(ref cls, "bg-secondary text-secondary-foreground hover:bg-secondary/80 h-10 px-4 py-2");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });

        attributes["aria-expanded"] = ParentDropdown?.Visible == true ? "true" : "false";

        if (ParentDropdown is not null)
            attributes["aria-controls"] = ParentDropdown.MenuId;

        if (Disabled || ParentDropdown?.Disabled == true)
        {
            attributes["disabled"] = true;
        }
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            IsOpen = ParentDropdown?.Visible == true,
            DataState = ParentDropdown?.Visible == true ? "open" : "closed",
            AriaHasPopup = "menu",
            AriaControls = ParentDropdown?.MenuId,
            Toggle = ParentDropdown is null ? null : () => ParentDropdown.Toggle(),
            Open = ParentDropdown is null ? null : () => ParentDropdown.OpenAndFocusFirstItemAsync(),
            Close = ParentDropdown is null ? null : () => ParentDropdown.Hide(),
            OnKeyDown = HandleToggleKeyDown
        };
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        attributes["data-slot"] = "dropdown-menu-trigger-wrapper";
        attributes["data-state"] = ParentDropdown?.Visible == true ? "open" : "closed";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown-toggle-wrapper inline-flex");
            if (Disabled || ParentDropdown?.Disabled == true)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Disabled);
        hc.Add(IsSplit);
        hc.Add(AsChild);
        hc.Add(ParentDropdown?.Visible == true);
        hc.Add(ParentDropdown?.Disabled == true);
    }

    private async Task HandleToggleKeyDown(KeyboardEventArgs e)
    {
        if (ParentDropdown is null || Disabled || ParentDropdown.Disabled)
            return;

        if (e.Key is "ArrowDown" or "Enter" or " ")
            await ParentDropdown.OpenAndFocusFirstItemAsync();
        else if (e.Key == "Escape" && ParentDropdown.Visible)
            await ParentDropdown.Hide();
    }

    internal async Task FocusAsync()
    {
        await _buttonRef.FocusAsync();
    }
}
