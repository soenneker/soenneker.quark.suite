@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IDropdownItem
@implements IDropdownFocusableItem

@if (IsLink)
{
    <a @attributes="BuildAttributes()" @onclick="OnClickHandler" @onkeydown="HandleMenuKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onkeydown:stopPropagation="_stopPropagation" @ref="_elementRef">
        @ChildContent
    </a>
}
else
{
    <button @attributes="BuildAttributes()" type="button" @onclick="OnClickHandler" @onkeydown="HandleMenuKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onkeydown:stopPropagation="_stopPropagation" @ref="_elementRef">
        @ChildContent
    </button>
}

@code {
    private ElementReference _elementRef;
    private bool _preventDefaultKeys;
    private bool _stopPropagation;

    [Parameter]
    public bool Inset { get; set; }

    /// <summary>
    /// Gets or sets whether the dropdown item is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets whether the dropdown item should be rendered as a link.
    /// </summary>
    [Parameter]
    public bool IsLink { get; set; }

    /// <summary>
    /// Gets or sets the href attribute for the link.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Gets or sets the target attribute for the link.
    /// </summary>
    [Parameter]
    public string? Target { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the dropdown item is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> Clicked { get; set; }

    /// <summary>
    /// Variant: default or destructive.
    /// </summary>
    [Parameter]
    public string Variant { get; set; } = "default";

    [CascadingParameter(Name = nameof(ParentDropdown))]
    public Dropdown? ParentDropdown { get; set; }

    [CascadingParameter(Name = "DropdownNavigationSub")]
    private DropdownSub? NavigationSub { get; set; }

    bool IDropdownFocusableItem.IsDisabledForNavigation => Disabled;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (NavigationSub is not null)
            NavigationSub.RegisterItem(this);
        else
            ParentDropdown?.RegisterItem(this);
    }

    private async Task OnClickHandler(MouseEventArgs e)
    {
        if (Disabled)
            return;

        if (Clicked.HasDelegate)
            await Clicked.InvokeAsync(e);

        if (ParentDropdown is not null)
            await ParentDropdown.Hide();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        var variant = Variant.Equals("destructive", StringComparison.OrdinalIgnoreCase) ? "destructive" : "default";
        attributes["data-slot"] = "dropdown-menu-item";
        attributes["data-variant"] = variant;
        attributes["role"] = "menuitem";
        attributes["tabindex"] = -1;

        if (Inset)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown-item");
            AppendClass(ref cls, "relative flex cursor-default items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-hidden select-none focus:bg-accent focus:text-accent-foreground");
            AppendClass(ref cls, "data-[disabled]:pointer-events-none data-[disabled]:opacity-50 data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8");
            AppendClass(ref cls, "data-[variant=destructive]:text-destructive data-[variant=destructive]:focus:bg-destructive/10 data-[variant=destructive]:focus:text-destructive dark:data-[variant=destructive]:focus:bg-destructive/20");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground data-[variant=destructive]:*:[svg]:text-destructive!");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            attributes["data-disabled"] = "true";
        }

        if (IsLink && Href.HasContent())
        {
            attributes["href"] = Href;
        }

        if (IsLink && Target.HasContent())
        {
            attributes["target"] = Target;
        }

        if (Active)
        {
            attributes["aria-current"] = "page";
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Active);
        hc.Add(Disabled);
        hc.Add(IsLink);
        hc.Add(Href);
        hc.Add(Target);
        hc.Add(Inset);
        hc.Add(Variant);
    }

    private async Task HandleMenuKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;
        _stopPropagation = false;

        if (ParentDropdown is null)
            return;

        if (e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
        {
            if (NavigationSub is not null)
            {
                await NavigationSub.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
            else
            {
                await ParentDropdown.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
        }
        else if (e.Key == "ArrowLeft" && NavigationSub is not null)
        {
            await NavigationSub.CloseAndFocusTriggerAsync();
            _preventDefaultKeys = true;
        }
        else if (e.Key == "Escape")
        {
            if (NavigationSub is not null)
                await NavigationSub.CloseAndFocusTriggerAsync();
            else
            {
                await ParentDropdown.Hide();
                await ParentDropdown.FocusTriggerAsync();
            }

            _preventDefaultKeys = true;
            _stopPropagation = true;
        }
    }

    async Task IDropdownFocusableItem.FocusAsync()
    {
        await _elementRef.FocusAsync();
    }

    public override void Dispose()
    {
        if (NavigationSub is not null)
            NavigationSub.UnregisterItem(this);
        else
            ParentDropdown?.UnregisterItem(this);

        base.Dispose();
    }
}