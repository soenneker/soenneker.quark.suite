@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IDropdownItem

<BradixDropdownMenuItem Disabled="@Disabled"
                        Href="@(IsLink ? Href : null)"
                        Target="@(IsLink ? Target : null)"
                        OnSelect="HandleSelect"
                        AdditionalAttributes="@ItemAttributes">
    @ChildContent
</BradixDropdownMenuItem>

@code {
    [Parameter]
    public bool Indented { get; set; }

    /// <summary>
    /// Gets or sets whether the dropdown item is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets whether the dropdown item should be rendered as a link.
    /// </summary>
    [Parameter]
    public bool IsLink { get; set; }

    /// <summary>
    /// Gets or sets the href attribute for the link.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Gets or sets the target attribute for the link.
    /// </summary>
    [Parameter]
    public string? Target { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the dropdown item is clicked.
    /// </summary>
    [Parameter]
    public EventCallback<MouseEventArgs> Clicked { get; set; }

    /// <summary>
    /// Variant: default or destructive.
    /// </summary>
    [Parameter]
    public string Variant { get; set; } = "default";

    private IReadOnlyDictionary<string, object> ItemAttributes => BuildItemAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Quark.Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Is2.OnX;
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        var variant = Variant.Equals("destructive", StringComparison.OrdinalIgnoreCase) ? "destructive" : "default";
        attributes["data-slot"] = "dropdown-menu-item";
        attributes["data-variant"] = variant;
        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "cursor-default py-1.5 outline-hidden focus:bg-accent focus:text-accent-foreground");
            AppendClass(ref cls, "data-[disabled]:pointer-events-none data-[disabled]:opacity-50 data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8");
            AppendClass(ref cls, "data-[variant=destructive]:text-destructive data-[variant=destructive]:focus:bg-destructive/10 data-[variant=destructive]:focus:text-destructive dark:data-[variant=destructive]:focus:bg-destructive/20");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground data-[variant=destructive]:*:[svg]:text-destructive!");
        });

        if (Active)
        {
            attributes["aria-current"] = "page";
        }
    }

    private IReadOnlyDictionary<string, object> BuildItemAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("tabindex");
        attributes.Remove("aria-disabled");
        attributes.Remove("data-disabled");
        attributes.Remove("href");
        attributes.Remove("target");
        attributes.Remove("type");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Active);
        hc.Add(Disabled);
        hc.Add(IsLink);
        hc.Add(Href);
        hc.Add(Target);
        hc.Add(Indented);
        hc.Add(Variant);
    }

    private Task HandleSelect()
    {
        return Clicked.HasDelegate
            ? Clicked.InvokeAsync(new MouseEventArgs())
            : Task.CompletedTask;
    }
}
