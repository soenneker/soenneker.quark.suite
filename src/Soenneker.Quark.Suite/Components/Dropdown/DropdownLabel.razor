@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixDropdownMenuLabel AdditionalAttributes="@LabelAttributes">
    @ChildContent
</BradixDropdownMenuLabel>

@code {
    [Parameter]
    public bool Indented { get; set; }

    private IReadOnlyDictionary<string, object> LabelAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "dropdown-menu-label";

        Padding ??= Quark.Padding.OnX.Token("1.5").OnY.Is1;
        TextSize ??= Quark.TextSize.Xs;
        FontWeight ??= Quark.FontWeight.Medium;
        TextColor ??= Quark.TextColor.MutedForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-inset:pl-7");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Indented);
    }
}
