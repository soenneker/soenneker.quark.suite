@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Value="@RadioGroupContext" IsFixed="false">
    <BradixDropdownMenuRadioGroup AdditionalAttributes="@GroupAttributes">
        @ChildContent
    </BradixDropdownMenuRadioGroup>
</CascadingValue>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    private IReadOnlyDictionary<string, object> GroupAttributes => BuildAttributes();

    private DropdownRadioGroupContext RadioGroupContext => new()
    {
        Value = Value,
        SetValue = SetValue
    };

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-radio-group";
    }

    private async Task SetValue(string value)
    {
        if (string.Equals(Value, value, StringComparison.Ordinal))
            return;

        Value = value;
        await ValueChanged.InvokeAsync(value);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
    }
}
