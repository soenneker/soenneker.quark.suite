@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixDropdownMenuSub Open="@Open"
                       DefaultOpen="@DefaultOpen"
                       OpenChanged="@OpenChanged"
                       OnOpenChange="@OnOpenChange"
                       AdditionalAttributes="@SubAttributes">
    @ChildContent
</BradixDropdownMenuSub>

@code {
    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    private IReadOnlyDictionary<string, object> SubAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-sub";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(DefaultOpen);
    }
}
