@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @onmouseenter="OpenSubmenu" @onmouseleave="CloseSubmenu" @attributes="BuildAttributes()">
    <CascadingValue Name="ParentDropdownSub" Value="@this" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private readonly List<IDropdownFocusableItem> _items = [];
    private DropdownSubTrigger? _trigger;

    internal string SubTriggerId { get; } = $"dropdown-sub-trigger-{Guid.NewGuid():N}";

    internal string SubContentId { get; } = $"dropdown-sub-menu-{Guid.NewGuid():N}";

    /// <summary>
    /// Clears focusable item order and trigger ref before children re-register in DOM order each render.
    /// </summary>
    protected override void OnParametersSet()
    {
        _items.Clear();
        _trigger = null;
        base.OnParametersSet();
    }

    internal bool Open { get; private set; }

    internal void OpenSubmenu()
    {
        if (!Open)
        {
            Open = true;
            InvalidateRender();
            Refresh();
        }
    }

    internal async Task OpenAndFocusFirstItemAsync()
    {
        OpenSubmenu();

        var firstItem = _items.FirstOrDefault(i => !i.IsDisabledForNavigation);
        if (firstItem is not null)
            await firstItem.FocusAsync();
    }

    internal void CloseSubmenu()
    {
        if (Open)
        {
            Open = false;
            InvalidateRender();
            Refresh();
        }
    }

    internal async Task CloseAndFocusTriggerAsync()
    {
        CloseSubmenu();

        if (_trigger is not null)
            await _trigger.FocusAsync();
    }

    internal void RegisterItem(IDropdownFocusableItem item)
    {
        if (_items.Contains(item))
            return;

        _items.Add(item);
    }

    internal void RegisterTrigger(DropdownSubTrigger trigger)
    {
        _trigger = trigger;
    }

    internal async Task HandleItemNavigationAsync(IDropdownFocusableItem currentItem, string key)
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
            return;

        var currentIndex = enabledItems.FindIndex(i => ReferenceEquals(i, currentItem));
        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledItems.Count - 1,
            "ArrowDown" => (currentIndex + 1) % enabledItems.Count,
            "ArrowUp" => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            _ => -1
        };

        if (nextIndex >= 0)
            await enabledItems[nextIndex].FocusAsync();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-sub";
        attributes["data-state"] = Open ? "open" : "closed";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dropdown-sub relative");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(_items.Count);
    }
}
