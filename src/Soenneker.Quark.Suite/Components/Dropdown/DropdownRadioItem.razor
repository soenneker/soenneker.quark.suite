@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement

<BradixMenuItem Role="menuitemradio"
                Disabled="@Disabled"
                CloseOnSelect="@AutoClose"
                OnSelect="HandleSelect"
                AdditionalAttributes="@RadioItemAttributes">
    <Span data-slot="dropdown-menu-radio-item-indicator"
          PointerEvents="Quark.PointerEvents.None"
          Position="Quark.Position.Absolute"
          Display="Quark.Display.Flex"
          ItemsAlign="Items.Center"
          Justify="Quark.Justify.Center"
          Class="right-2">
        @if (ResolvedSelected)
        {
            <Icon Name="LucideIcon.Check" Size="Quark.Size.Is4" />
        }
    </Span>
    @ChildContent
</BradixMenuItem>

@code {
    [CascadingParameter]
    private DropdownRadioGroupContext? RadioGroupContext { get; set; }

    [Parameter]
    public bool Selected { get; set; }

    [Parameter]
    public EventCallback<bool> SelectedChanged { get; set; }

    [Parameter]
    public bool AutoClose { get; set; }

    [Parameter]
    public bool Indented { get; set; }

    private IReadOnlyDictionary<string, object> RadioItemAttributes => BuildRadioItemAttributes();

    private bool ResolvedSelected =>
        RadioGroupContext?.Value is { } groupValue && Value is not null
            ? string.Equals(groupValue, Value, StringComparison.Ordinal)
            : Selected;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dropdown-menu-radio-item";
        attributes["data-state"] = ResolvedSelected ? "checked" : "unchecked";
        attributes["aria-checked"] = ResolvedSelected ? "true" : "false";

        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground focus:**:text-accent-foreground data-inset:pl-7 data-[inset]:pl-7 data-disabled:pointer-events-none data-disabled:opacity-50 data-[disabled]:pointer-events-none data-[disabled]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Token("1.5");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Token("8").FromRight.Token("1.5").FromLeft.Is1.OnY;
        TextSize ??= Quark.TextSize.Sm;
        OutlineStyle ??= "outline-hidden";
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    private IReadOnlyDictionary<string, object> BuildRadioItemAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Selected);
        hc.Add(Value);
        hc.Add(ResolvedSelected);
        hc.Add(RadioGroupContext?.Value);
        hc.Add(Disabled);
        hc.Add(AutoClose);
        hc.Add(Indented);
    }

    private async Task HandleSelect()
    {
        if (Disabled || ResolvedSelected)
            return;

        if (RadioGroupContext?.SetValue is not null && Value is not null)
        {
            await RadioGroupContext.SetValue(Value);
            return;
        }

        Selected = true;
        await SelectedChanged.InvokeIfHasDelegate(true);
    }
}
