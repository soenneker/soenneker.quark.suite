@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IFieldLabel

<BradixLabel For="@ResolvedFor"
             AdditionalAttributes="@LabelAttributes">
    @ChildContent
    @if (RequiredIndicator)
    {
        <span class="field-required">*</span>
    }
</BradixLabel>

@code {
    /// <summary>
    /// Gets or sets the for attribute, which associates the label with a form control.
    /// </summary>
    [Parameter]
    public string? For { get; set; }

    /// <summary>
    /// Gets or sets whether to show the required indicator.
    /// </summary>
    [Parameter]
    public bool RequiredIndicator { get; set; }

    // Prefer a simple cascading bool rather than poking into ParentField.
    [CascadingParameter(Name = "FieldHorizontal")]
    protected bool FieldHorizontal { get; set; }

    [CascadingParameter]
    private FieldContext? FieldContext { get; set; }

    protected virtual bool IsHorizontal => FieldHorizontal;
    private string? ResolvedFor => For.HasContent() ? For! : FieldContext?.ControlId;
    private IReadOnlyDictionary<string, object> LabelAttributes => BuildLabelAttributes();

    private IReadOnlyDictionary<string, object> BuildLabelAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("for");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Leading ??= Quark.Leading.Snug;
        UserSelect ??= Quark.UserSelect.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "field-label";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "items-center group/field-label peer/field-label flex w-fit gap-2 leading-snug group-data-[disabled=true]/field:opacity-50");
            AppendClass(ref cls, "has-[[data-slot=checkbox][data-state=checked]]:border-primary/30 has-[[data-slot=checkbox][data-state=checked]]:bg-muted");
            AppendClass(ref cls, "has-[[data-slot=radio-group-item][data-state=checked]]:border-primary/30 has-[[data-slot=radio-group-item][data-state=checked]]:bg-muted");
            AppendClass(ref cls, "has-[>[data-slot=field]]:rounded-lg has-[>[data-slot=field]]:border *:data-[slot=field]:p-2.5");
            AppendClass(ref cls, "dark:has-[[data-slot=checkbox][data-state=checked]]:border-primary/20 dark:has-[[data-slot=checkbox][data-state=checked]]:bg-primary/10");
            AppendClass(ref cls, "dark:has-[[data-slot=radio-group-item][data-state=checked]]:border-primary/20 dark:has-[[data-slot=radio-group-item][data-state=checked]]:bg-primary/10");
            AppendClass(ref cls, "has-[>[data-slot=field]]:w-full has-[>[data-slot=field]]:flex-col");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(For);
        hc.Add(RequiredIndicator);
        hc.Add(IsHorizontal);
        hc.Add(FieldContext?.ControlId);
    }
}
