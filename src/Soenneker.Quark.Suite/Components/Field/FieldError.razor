@namespace Soenneker.Quark
@using System.Linq
@inherits Soenneker.Quark.TypographyElement

@if (HasContent)
{
    <div @attributes="BuildAttributes()" role="alert">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else if (UniqueErrorMessages.Count == 1)
        {
            @UniqueErrorMessages[0]
        }
        else if (UniqueErrorMessages.Count > 1)
        {
            <UnorderedList Margin="Quark.Margin.Is4.FromLeft" Display="Quark.Display.Flex" ListStyleType="Quark.ListStyleType.Disc" Flex="Quark.Flex.Col" Gap="Quark.Gap.Is1">
                @foreach (var message in UniqueErrorMessages)
                {
                    <UnorderedListItem>@message</UnorderedListItem>
                }
            </UnorderedList>
        }
    </div>
}

@code {
    [Parameter]
    public IReadOnlyList<string?>? Errors { get; set; }

    [CascadingParameter]
    private FieldContext? FieldContext { get; set; }

    private IDisposable? _registration;
    private FieldContext? _registeredContext;
    private IReadOnlyList<string> UniqueErrorMessages =>
        Errors?
            .Where(message => !message.IsNullOrWhiteSpace())
            .Select(message => message!.Trim())
            .Distinct(StringComparer.Ordinal)
            .ToArray()
        ?? [];

    private bool HasContent => ChildContent is not null || UniqueErrorMessages.Count > 0;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var contextToRegister = HasContent ? FieldContext : null;

        if (!ReferenceEquals(_registeredContext, contextToRegister))
        {
            _registration?.Dispose();
            _registeredContext = contextToRegister;
            _registration = contextToRegister?.RegisterError();
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Normal;
        TextColor ??= Quark.TextColor.Destructive;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "field-error";
        if (FieldContext is not null && !attributes.ContainsKey("id"))
            attributes["id"] = FieldContext.ErrorId;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(HasContent);
        if (Errors is not null)
        {
            foreach (var error in Errors)
                hc.Add(error);
        }
        hc.Add(FieldContext?.ErrorId);
    }

    public override void Dispose()
    {
        _registration?.Dispose();
        base.Dispose();
    }
}
