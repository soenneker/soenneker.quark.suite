@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix
@using BradixOrientation = Soenneker.Bradix.Orientation
@implements IField

<CascadingValue Name="ParentField" Value="@this" IsFixed="true">
    <CascadingValue Value="_fieldContext" IsFixed="false">
        <CascadingValue Name="FieldHorizontal" Value="IsHorizontalResolved">
            <div @attributes="BuildAttributes()">
                @ChildContent
            </div>
        </CascadingValue>
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter]
    public BradixOrientation? Orientation { get; set; }

    /// <summary>
    /// Gets or sets whether the field should expose disabled state to composed label/title content.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets whether the field is invalid for data-[invalid=true] styling.
    /// </summary>
    [Parameter]
    public bool IsInvalid { get; set; }

    /// <summary>
    /// Gets or sets whether the field should render with selectable card/chip styling
    /// that responds to nested checkbox or radio checked state.
    /// </summary>
    [Parameter]
    public bool Selectable { get; set; }

    /// <summary>
    /// Gets or sets the text direction for the field.
    /// </summary>
    [Parameter]
    public string? Dir { get; set; }

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    private readonly FieldContext _fieldContext = new();
    private BradixOrientation _resolvedOrientation = BradixOrientation.Vertical;
    private bool IsHorizontalResolved => _resolvedOrientation == BradixOrientation.Horizontal;
    private string? ResolvedDir => !string.IsNullOrWhiteSpace(Dir) ? Dir : DirectionProviderDir;

    protected override void OnInitialized()
    {
        _fieldContext.StateChanged += OnFieldContextStateChanged;
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        _resolvedOrientation = Orientation == BradixOrientation.Horizontal ? BradixOrientation.Horizontal : BradixOrientation.Vertical;
        _fieldContext.Update(IsHorizontalResolved, IsInvalid);
        base.OnParametersSet();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "field";

        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        Gap ??= Quark.Gap.Is2;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes.TryAdd("role", "group");
        attributes["data-orientation"] = _resolvedOrientation.Value;

        if (!string.IsNullOrWhiteSpace(ResolvedDir))
            attributes["dir"] = ResolvedDir!;

        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["aria-disabled"] = "true";
        }

        if (_fieldContext.IsInvalid)
            attributes["data-invalid"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/field data-[invalid=true]:text-destructive");
            if (_resolvedOrientation == BradixOrientation.Horizontal)
            {
                AppendClass(ref cls, "flex-row items-center");
                AppendClass(ref cls, "*:data-[slot=field-label]:flex-auto");
                AppendClass(ref cls, "has-[>[data-slot=field-content]]:items-start has-[>[data-slot=field-content]]:[&>[role=checkbox],[role=radio]]:mt-px");

                if (Selectable)
                {
                    AppendClass(ref cls, "overflow-hidden rounded-lg border px-3! py-1.5! transition-all duration-100 ease-linear");
                    AppendClass(ref cls, "has-[>[data-slot=checkbox][data-state=checked]]:border-primary/30 has-[>[data-slot=checkbox][data-state=checked]]:bg-muted");
                    AppendClass(ref cls, "dark:has-[>[data-slot=checkbox][data-state=checked]]:border-primary/20 dark:has-[>[data-slot=checkbox][data-state=checked]]:bg-primary/10");
                    AppendClass(ref cls, "has-[>[data-slot=radio-group-item][data-state=checked]]:border-primary/30 has-[>[data-slot=radio-group-item][data-state=checked]]:bg-muted");
                    AppendClass(ref cls, "dark:has-[>[data-slot=radio-group-item][data-state=checked]]:border-primary/20 dark:has-[>[data-slot=radio-group-item][data-state=checked]]:bg-primary/10");
                }
            }
            else
            {
                AppendClass(ref cls, "flex-col *:w-full [&>.sr-only]:w-auto");
            }
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
        hc.Add(Disabled);
        hc.Add(IsInvalid);
        hc.Add(Selectable);
        hc.Add(Dir);
        hc.Add(DirectionProviderDir);
        hc.Add(_fieldContext.IsInvalid);
    }

    private void OnFieldContextStateChanged()
    {
        _ = RefreshOffThread();
    }

    public override async ValueTask DisposeAsync()
    {
        _fieldContext.StateChanged -= OnFieldContextStateChanged;
        await base.DisposeAsync();
    }
}
