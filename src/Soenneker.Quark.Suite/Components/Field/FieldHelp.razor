@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IFieldHelp

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected virtual bool ParentIsFieldBody => ParentFieldBody is not null;

    [CascadingParameter(Name = nameof(ParentFieldBody))]
    protected FieldBody? ParentFieldBody { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "field-description";

        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Normal;
        TextColor ??= Quark.TextColor.MutedForeground;
        Leading ??= Quark.Leading.Normal;
        TextAlign ??= Quark.TextAlign.Start;

        if (ParentIsFieldBody)
            MinWidth ??= Quark.MinWidth.Is0;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group-data-[orientation=horizontal]/field:text-balance");
            AppendClass(ref cls, "last:mt-0 nth-last-2:-mt-1 [[data-variant=legend]+&]:-mt-1.5");
            AppendClass(ref cls, "[&>a]:underline [&>a]:underline-offset-4 [&>a:hover]:text-primary");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentIsFieldBody);
    }
}
