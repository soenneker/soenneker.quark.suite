@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<fieldset @attributes="BuildAttributes()">
    @ChildContent
</fieldset>

@code {
    [Parameter]
    public bool Disabled { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "field-set";

        if (Disabled)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-field-set flex flex-col gap-4");
            AppendClass(ref cls, "group/field-set rounded-lg border p-4");
            AppendClass(ref cls, "has-[>[data-slot=checkbox-group]]:gap-3 has-[>[data-slot=radio-group]]:gap-3");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
    }
}
