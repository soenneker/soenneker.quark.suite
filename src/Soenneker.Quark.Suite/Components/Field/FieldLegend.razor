@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

<legend @attributes="BuildAttributes()">
    @ChildContent
</legend>

@code {
    [Parameter]
    public string Variant { get; set; } = "legend";

    private string ResolvedVariant => Variant.Equals("label", StringComparison.OrdinalIgnoreCase) ? "label" : "legend";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        FontWeight ??= Quark.FontWeight.Medium;
        Margin ??= Quark.Margin.Is3.FromBottom;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "field-legend";
        attributes["data-variant"] = ResolvedVariant;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-[variant=label]:text-sm data-[variant=legend]:text-base");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
    }
}
