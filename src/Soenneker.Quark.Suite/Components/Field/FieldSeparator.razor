@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    <Hr Orientation="@SeparatorOrientation.Horizontal" Decorative="true" Class="absolute inset-0 top-1/2" />
    @if (ChildContent != null)
    {
        <span class="relative mx-auto block w-fit bg-background px-2 text-muted-foreground" data-slot="field-separator-content">
            @ChildContent
        </span>
    }
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Margin ??= Quark.Margin.Token("-2").OnY;
        Height ??= Quark.Height.Token("5");
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "field-separator";
        attributes["data-content"] = ChildContent != null ? "true" : "false";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group-data-[variant=outline]/field-group:-mb-2");
        });
    }
}
