@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    <Hr Orientation="@SeparatorOrientation.Horizontal" Decorative="true" Class="absolute inset-0 top-1/2" />
    @if (ChildContent != null)
    {
        <Span data-slot="field-separator-content"
              Position="Quark.Position.Relative"
              Margin="Quark.Margin.Auto.OnX"
              Display="Quark.Display.Block"
              Width="Quark.Width.IsFit"
              BackgroundColor="Quark.BackgroundColor.Background"
              Padding="Quark.Padding.Is2.OnX"
              TextColor="Quark.TextColor.MutedForeground">
            @ChildContent
        </Span>
    }
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Margin ??= Quark.Margin.Token("-2").OnY;
        Height ??= Quark.Height.Token("5");
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "field-separator";
        attributes["data-content"] = ChildContent != null ? "true" : "false";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group-data-[variant=outline]/field-group:-mb-2");
        });
    }
}
