@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements INavigationMenuViewport

<div @attributes="BuildWrapperAttributes()">
    <BradixNavigationMenuViewport AdditionalAttributes="@ViewportAttributes" />
</div>

@code {
    private static Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>(1);

        RenderComponent.BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "absolute top-full left-0 isolate z-50 flex justify-center");
        });

        return attributes;
    }

    private IReadOnlyDictionary<string, object> ViewportAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        BackgroundColor ??= Quark.BackgroundColor.Popover;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Position ??= Quark.Position.Relative;
        Width ??= Quark.Width.IsFull;
        Rounded ??= Quark.Rounded.Md;
        Margin ??= Quark.Margin.Token("1.5").FromTop;
        Overflow ??= Quark.Overflow.Hidden;
        Shadow ??= Quark.Shadow.Default;
        Border ??= Quark.Border.Default;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu-viewport";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "origin-top-center h-(--radix-navigation-menu-viewport-height) data-open:animate-in data-closed:animate-out");
            AppendClass(ref cls, "data-closed:zoom-out-95 data-open:zoom-in-90 data-[state=closed]:animate-out data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:zoom-in-90");
            AppendClass(ref cls, "md:w-(--radix-navigation-menu-viewport-width)");
        });
    }
}
