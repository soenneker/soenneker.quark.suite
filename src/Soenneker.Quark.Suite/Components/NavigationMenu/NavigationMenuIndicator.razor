@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements INavigationMenuIndicator

<BradixNavigationMenuIndicator ForceMount="@Visible"
                              AdditionalAttributes="@IndicatorAttributes">
    <div class="bg-border relative top-[60%] h-2 w-2 rotate-45 rounded-tl-sm shadow-md"></div>
</BradixNavigationMenuIndicator>

@code {
    private IReadOnlyDictionary<string, object> IndicatorAttributes => BuildIndicatorAttributes();

    private IReadOnlyDictionary<string, object> BuildIndicatorAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-state");
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu-indicator";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-[state=visible]:animate-in data-[state=hidden]:animate-out data-[state=hidden]:fade-out data-[state=visible]:fade-in");
            AppendClass(ref cls, "top-full z-[1] flex h-1.5 items-end justify-center overflow-hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Visible);
    }
}
