@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements INavigationMenuIndicator

<BradixNavigationMenuIndicator ForceMount="@Visible"
                              AdditionalAttributes="@IndicatorAttributes">
    <Div BackgroundColor='Quark.BackgroundColor.Utility("border")'
         Position="Quark.Position.Relative"
         Class="top-[60%] rotate-45"
         Height='Quark.Height.Token("2")'
         Width='Quark.Width.Token("2")'
         Rounded="Quark.Rounded.TopLeft.Sm"
         Shadow="Quark.Shadow.Md"></Div>
</BradixNavigationMenuIndicator>

@code {
    private IReadOnlyDictionary<string, object> IndicatorAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        ZIndex ??= "z-[1]";
        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Token("1.5");
        ItemsAlign ??= Items.End;
        Justify ??= Quark.Justify.Center;
        Overflow ??= Quark.Overflow.Hidden;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu-indicator";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-[state=visible]:animate-in data-[state=hidden]:animate-out data-[state=hidden]:fade-out data-[state=visible]:fade-in");
            AppendClass(ref cls, "top-full");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Visible);
    }
}
