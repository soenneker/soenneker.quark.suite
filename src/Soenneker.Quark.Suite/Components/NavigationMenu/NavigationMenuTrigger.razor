@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INavigationMenuTrigger

<button @attributes="BuildAttributes()" @onclick="HandleTriggerClick" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onmouseenter="HandleMouseEnter" @ref="_buttonRef">
    @ChildContent
    @if (ShowChevron)
    {
        <Icon Name="LucideIcon.ChevronDown"
                Class="relative top-[1px] ml-1 size-3 transition duration-300 group-data-[state=open]:rotate-180" />
    }
</button>

@code {
    private ElementReference _buttonRef;
    private bool _preventDefaultKeys;

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool ShowChevron { get; set; } = true;

    [CascadingParameter(Name = "ParentNavigationMenu")]
    private NavigationMenu? ParentNavigationMenu { get; set; }

    [CascadingParameter]
    private NavigationMenuItem? ParentNavigationMenuItem { get; set; }

    private bool ResolvedOpen => ParentNavigationMenuItem is not null ? ParentNavigationMenuItem.IsOpenResolved : Open;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ParentNavigationMenu is not null && ParentNavigationMenuItem is not null)
            ParentNavigationMenu.RegisterTrigger(ParentNavigationMenuItem, this);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["type"] = "button";
        attributes["data-slot"] = "navigation-menu-trigger";
        attributes["data-state"] = ResolvedOpen ? "open" : "closed";
        attributes["aria-expanded"] = ResolvedOpen ? "true" : "false";
        attributes["aria-haspopup"] = "true";

        if (ParentNavigationMenuItem is not null)
            attributes["aria-controls"] = ParentNavigationMenuItem.ContentPanelId;

        attributes["tabindex"] = Disabled ? -1 : 0;

        if (Disabled)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-navigation-menu-trigger group");
            AppendClass(ref cls, "inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium");
            AppendClass(ref cls, "hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "data-[state=open]:hover:bg-accent data-[state=open]:text-accent-foreground data-[state=open]:focus:bg-accent data-[state=open]:bg-accent/50");
            AppendClass(ref cls, "focus-visible:ring-ring/50 outline-none transition-[color,box-shadow] focus-visible:ring-[3px] focus-visible:outline-1");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(ResolvedOpen);
        hc.Add(Disabled);
        hc.Add(ShowChevron);
    }

    private async Task HandleTriggerClick(MouseEventArgs _)
    {
        if (Disabled || ParentNavigationMenu is null || ParentNavigationMenuItem is null)
            return;

        await ParentNavigationMenu.ToggleItemAsync(ParentNavigationMenuItem);
    }

    private async Task HandleMouseEnter(MouseEventArgs _)
    {
        if (Disabled || ParentNavigationMenu is null || ParentNavigationMenuItem is null)
            return;

        await ParentNavigationMenu.OpenItemAsync(ParentNavigationMenuItem);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (Disabled || ParentNavigationMenu is null || ParentNavigationMenuItem is null)
        {
            await base.HandleKeyDown(e);
            return;
        }

        _preventDefaultKeys = false;

        if (e.Key is "ArrowRight" or "ArrowLeft" or "Home" or "End")
        {
            _preventDefaultKeys = true;
            await ParentNavigationMenu.HandleTriggerNavigationAsync(ParentNavigationMenuItem, e.Key);
        }
        else if (e.Key is "Enter" or " " or "ArrowDown")
        {
            _preventDefaultKeys = true;
            await ParentNavigationMenu.OpenItemAsync(ParentNavigationMenuItem);
            await ParentNavigationMenuItem.ScheduleFocusFirstLinkAsync();
        }
        else if (e.Key == "Escape" && ResolvedOpen)
        {
            _preventDefaultKeys = true;
            await ParentNavigationMenu.CloseAllAsync(restoreFocusToTrigger: true);
        }

        await base.HandleKeyDown(e);
    }

    internal async Task FocusAsync()
    {
        await _buttonRef.FocusAsync();
    }
}
