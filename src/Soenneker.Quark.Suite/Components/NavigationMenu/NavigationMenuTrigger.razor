@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INavigationMenuTrigger

<BradixNavigationMenuTrigger Disabled="@ResolvedDisabled"
                            AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    @if (ShowChevron)
    {
        <Icon Name="LucideIcon.ChevronDown"
              Position="Quark.Position.Relative"
              Top='Quark.Top.Token("[1px]")'
              Margin="Quark.Margin.FromLeft.Is1"
              Size="Quark.Size.Is3"
              Transition='Quark.Transition.Token("transition")'
              Duration="Quark.Duration.Is300"
              Rotate='Quark.Rotate.Is180.Modifier("group-data-[state=open]")'
              aria-hidden="true" />
    }
</BradixNavigationMenuTrigger>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool ShowChevron { get; set; } = true;

    [CascadingParameter]
    private NavigationMenuItem? ParentNavigationMenuItem { get; set; }

    private bool ResolvedDisabled => Disabled || ParentNavigationMenuItem?.Disabled == true;
    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "navigation-menu-trigger";

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Height ??= Quark.Height.Is9;
        Width ??= Quark.Width.IsMax;
        Rounded ??= Quark.Rounded.Lg;
        Padding ??= Quark.Padding.OnX.Is2_5.OnY.Token("1.5");
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "hover:bg-muted focus:bg-muted");
            AppendClass(ref cls, "focus-visible:ring-3 focus-visible:outline-1");
            AppendClass(ref cls, "data-popup-open:bg-muted/50 data-popup-open:hover:bg-muted data-open:bg-muted/50 data-open:hover:bg-muted data-open:focus:bg-muted");
            AppendClass(ref cls, "group/navigation-menu-trigger group");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Disabled);
        hc.Add(ParentNavigationMenuItem?.Disabled);
        hc.Add(ShowChevron);
    }
}
