@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INavigationMenuTrigger

<BradixNavigationMenuTrigger Disabled="@ResolvedDisabled"
                            AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    @if (ShowChevron)
    {
        <Icon Name="LucideIcon.ChevronDown"
                Class="relative top-px ms-1 size-3 transition duration-300 group-data-popup-open/navigation-menu-trigger:rotate-180 group-data-open/navigation-menu-trigger:rotate-180" />
    }
</BradixNavigationMenuTrigger>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool ShowChevron { get; set; } = true;

    [CascadingParameter]
    private NavigationMenuItem? ParentNavigationMenuItem { get; set; }

    private bool ResolvedDisabled => Disabled || ParentNavigationMenuItem?.Disabled == true;
    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("type");
        attributes.Remove("disabled");
        attributes.Remove("data-disabled");
        attributes.Remove("data-state");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("tabindex");
        attributes.Remove("onmouseenter");
        attributes.Remove("onkeydown");
        attributes.Remove("onclick");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Lg;
        Padding ??= Quark.Padding.Token("2.5").OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu-trigger";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/navigation-menu-trigger h-9 w-max transition-all outline-none");
            AppendClass(ref cls, "hover:bg-muted focus:bg-muted");
            AppendClass(ref cls, "focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-1");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "data-popup-open:bg-muted/50 data-popup-open:hover:bg-muted");
            AppendClass(ref cls, "data-open:bg-muted/50 data-open:hover:bg-muted data-open:focus:bg-muted");
            AppendClass(ref cls, "group");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Disabled);
        hc.Add(ParentNavigationMenuItem?.Disabled);
        hc.Add(ShowChevron);
    }
}
