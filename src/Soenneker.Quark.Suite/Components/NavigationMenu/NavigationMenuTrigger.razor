@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INavigationMenuTrigger

<BradixNavigationMenuTrigger Disabled="@ResolvedDisabled"
                            AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    @if (ShowChevron)
    {
        <Icon Name="LucideIcon.ChevronDown"
              Class="relative top-[1px] ml-1 size-3 transition duration-300 group-data-[state=open]:rotate-180"
              aria-hidden="true" />
    }
</BradixNavigationMenuTrigger>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool ShowChevron { get; set; } = true;

    [CascadingParameter]
    private NavigationMenuItem? ParentNavigationMenuItem { get; set; }

    private bool ResolvedDisabled => Disabled || ParentNavigationMenuItem?.Disabled == true;
    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("type");
        attributes.Remove("disabled");
        attributes.Remove("data-disabled");
        attributes.Remove("data-state");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("tabindex");
        attributes.Remove("onmouseenter");
        attributes.Remove("onkeydown");
        attributes.Remove("onclick");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Md;
        BackgroundColor ??= Quark.BackgroundColor.Background;
        Padding ??= Quark.Padding.Is4.OnX.Is2.OnY;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu-trigger";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group h-9 w-max transition-[color,box-shadow] outline-none");
            AppendClass(ref cls, "hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground");
            AppendClass(ref cls, "focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:outline-1");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "data-[state=open]:bg-accent/50 data-[state=open]:text-accent-foreground data-[state=open]:hover:bg-accent data-[state=open]:focus:bg-accent");
            AppendClass(ref cls, "data-popup-open:bg-accent/50 data-popup-open:text-accent-foreground data-popup-open:hover:bg-accent data-open:bg-accent/50 data-open:text-accent-foreground data-open:hover:bg-accent data-open:focus:bg-accent");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Disabled);
        hc.Add(ParentNavigationMenuItem?.Disabled);
        hc.Add(ShowChevron);
    }
}
