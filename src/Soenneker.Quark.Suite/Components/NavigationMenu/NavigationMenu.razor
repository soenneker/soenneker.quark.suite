@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements INavigationMenu

<BradixNavigationMenu Dir="@ResolvedDir"
                      AdditionalAttributes="@RootAttributes">
    @ChildContent
    @if (Viewport)
    {
        <NavigationMenuViewport />
    }
</BradixNavigationMenu>

@code {
    [Parameter]
    public bool Viewport { get; set; } = true;

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    private string? ResolvedDir
    {
        get
        {
            if (Attributes is not null &&
                Attributes.TryGetValue("dir", out var dirValue) &&
                dirValue?.ToString().HasContent() == true)
            {
                return dirValue.ToString();
            }

            return DirectionProviderDir;
        }
    }

    private IReadOnlyDictionary<string, object> RootAttributes => BuildRootAttributes();

    private IReadOnlyDictionary<string, object> BuildRootAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("dir");
        attributes.Remove("data-orientation");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu";
        attributes["data-viewport"] = Viewport ? "true" : "false";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/navigation-menu max-w-max flex-1");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Viewport);
        hc.Add(DirectionProviderDir);
        hc.Add(ResolvedDir);
    }
}
