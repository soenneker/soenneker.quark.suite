@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INavigationMenuItem

<CascadingValue Value="@this" IsFixed="true">
    <li @attributes="BuildAttributes()">
        @ChildContent
    </li>
</CascadingValue>

@code {
    private readonly List<NavigationMenuLink> _links = [];
    private bool _pendingFocusFirstLink;

    [Parameter]
    public bool Open { get; set; }

    [CascadingParameter(Name = "ParentNavigationMenu")]
    private NavigationMenu? ParentNavigationMenu { get; set; }

    internal bool IsOpenResolved => ParentNavigationMenu?.IsItemOpen(this) ?? Open;

    internal string ContentPanelId { get; } = $"nav-menu-panel-{Guid.NewGuid():N}";

    internal string TriggerId { get; } = $"nav-menu-trigger-{Guid.NewGuid():N}";

    internal void RegisterLink(NavigationMenuLink link)
    {
        if (_links.Contains(link))
            return;

        _links.Add(link);
    }

    internal async Task ScheduleFocusFirstLinkAsync()
    {
        _pendingFocusFirstLink = true;
        await RefreshOffThread();
    }

    protected override void OnParametersSet()
    {
        _links.Clear();
        base.OnParametersSet();
        ParentNavigationMenu?.RegisterItem(this);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (_pendingFocusFirstLink)
        {
            _pendingFocusFirstLink = false;
            var first = _links.FirstOrDefault();

            if (first is not null)
                await first.FocusAsync();
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu-item";
        attributes["data-state"] = IsOpenResolved ? "open" : "closed";

        if (Disabled)
            attributes["aria-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-navigation-menu-item");
            AppendClass(ref cls, "group/navigation-menu-item relative");

            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(IsOpenResolved);
        hc.Add(Disabled);
        hc.Add(_links.Count);
    }
}
