@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements INavigationMenuLink

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixNavigationMenuLink Active="@Active"
                              AdditionalAttributes="@LinkAttributes">
        @ChildContent
    </BradixNavigationMenuLink>
}

@code {
    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public string? Target { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private IReadOnlyDictionary<string, object> LinkAttributes => BuildAttributes();
    private bool UsesTriggerStyle => Class?.Contains("group/navigation-menu-trigger", StringComparison.Ordinal) == true;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "navigation-menu-link";

        if (!UsesTriggerStyle)
        {
            Display ??= Quark.Display.Flex;
            ItemsAlign ??= Items.Center;
            Gap ??= Quark.Gap.Is2;
            Rounded ??= Quark.Rounded.Lg;
            Padding ??= Quark.Padding.Is2;
            TextSize ??= Quark.TextSize.Sm;
            Transition ??= Quark.Transition.All;
            OutlineStyle ??= Quark.OutlineStyle.None;
            RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (Href.HasContent())
            attributes["href"] = Href!;

        if (Target.HasContent())
            attributes["target"] = Target!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (!UsesTriggerStyle)
            {
                AppendClass(ref cls, "hover:bg-muted focus:bg-muted focus-visible:ring-3 focus-visible:outline-1");
                AppendClass(ref cls, "in-data-[slot=navigation-menu-content]:rounded-md data-active:bg-muted/50 data-active:hover:bg-muted data-active:focus:bg-muted");
                AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-4");
            }
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        if (Active)
        {
            attributes["data-active"] = "true";
            attributes["aria-current"] = "page";
        }

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Href);
        hc.Add(Active);
        hc.Add(Target);
        hc.Add(AsChild);
    }
}
