@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements INavigationMenuLink

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixNavigationMenuLink Active="@Active"
                              AdditionalAttributes="@LinkAttributes">
        @ChildContent
    </BradixNavigationMenuLink>
}

@code {
    [Parameter]
    public string? Href { get; set; }

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public string? Target { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private IReadOnlyDictionary<string, object> LinkAttributes => BuildLinkAttributes();

    private IReadOnlyDictionary<string, object> BuildLinkAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-active");
        attributes.Remove("aria-current");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Lg;
        Padding ??= Quark.Padding.Is2.Token("2.5").OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "navigation-menu-link";
        attributes["data-active"] = Active ? "true" : "false";

        if (Href.HasContent())
            attributes["href"] = Href!;

        if (Target.HasContent())
            attributes["target"] = Target!;

        if (Active)
            attributes["aria-current"] = "page";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "in-data-[slot=navigation-menu-content]:rounded-md");
            AppendClass(ref cls, "data-active:bg-muted/50 data-active:hover:bg-muted data-active:focus:bg-muted");
            AppendClass(ref cls, "group/navigation-menu-trigger h-9 w-max transition-all outline-none");
            AppendClass(ref cls, "hover:bg-muted focus:bg-muted focus-visible:ring-3 focus-visible:ring-ring/50 focus-visible:outline-1");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "data-popup-open:bg-muted/50 data-popup-open:hover:bg-muted");
            AppendClass(ref cls, "data-open:bg-muted/50 data-open:hover:bg-muted data-open:focus:bg-muted");
            AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-4");
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Href);
        hc.Add(Active);
        hc.Add(Target);
        hc.Add(AsChild);
    }
}
