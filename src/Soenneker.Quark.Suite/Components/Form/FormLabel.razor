@namespace Soenneker.Quark.Forms
@inherits Soenneker.Quark.TypographyElement

<label @attributes="BuildAttributes()">
    @ChildContent
    @if (RequiredIndicator)
    {
        <Span TextColor="Quark.TextColor.Destructive">*</Span>
    }
</label>

@code {
    [Parameter]
    public string? For { get; set; }

    [Parameter]
    public bool RequiredIndicator { get; set; }

    [CascadingParameter(Name = "FormHorizontal")]
    protected bool FormHorizontal { get; set; }

    [CascadingParameter]
    private FieldContext? FieldContext { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "form-label";

        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFit;
        Gap ??= Quark.Gap.Is2;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Leading ??= Quark.Leading.None;
        UserSelect ??= Quark.UserSelect.None;
        Opacity ??= Quark.Opacity.OnPeerDisabled.Is50;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-error"] = FieldContext?.IsInvalid == true ? "true" : "false";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-[error=true]:text-destructive");
            AppendClass(ref cls, "group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50");
            AppendClass(ref cls, "peer-disabled:cursor-not-allowed");
        });

        if (For.HasContent())
            attributes["for"] = For!;
        else if (FieldContext is not null)
            attributes["for"] = FieldContext.ControlId;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(For);
        hc.Add(RequiredIndicator);
        hc.Add(FormHorizontal);
        hc.Add(FieldContext?.ControlId);
        hc.Add(FieldContext?.IsInvalid);
    }
}