@namespace Soenneker.Quark.Forms
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentFormField" Value="@this" IsFixed="true">
    <CascadingValue Value="_fieldContext" IsFixed="false">
        <CascadingValue Name="FormHorizontal" Value="Horizontal" IsFixed="true">
            @ChildContent
        </CascadingValue>
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter]
    public bool Horizontal { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool IsInvalid { get; set; }

    private readonly FieldContext _fieldContext = new();

    protected override void OnInitialized()
    {
        _fieldContext.StateChanged += OnFieldContextStateChanged;
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        _fieldContext.Update(Horizontal, IsInvalid);
        base.OnParametersSet();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Horizontal);
        hc.Add(Disabled);
        hc.Add(IsInvalid);
        hc.Add(_fieldContext.IsInvalid);
    }

    private void OnFieldContextStateChanged()
    {
        _ = RefreshOffThread();
    }

    public override void Dispose()
    {
        _fieldContext.StateChanged -= OnFieldContextStateChanged;
        base.Dispose();
    }
}
