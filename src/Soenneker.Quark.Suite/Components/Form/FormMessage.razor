@namespace Soenneker.Quark.Forms
@inherits Soenneker.Quark.TypographyElement

@if (HasChildContent)
{
    <p @attributes="BuildAttributes()">
        @ChildContent
    </p>
}
else if (ShowErrorMessages && ParentValidation is { Messages: { } parentMessages } && ParentValidation.Status == ValidationStatus.Error && HasMessages(parentMessages))
{
    <p @attributes="BuildAttributes()">
        @foreach (var message in parentMessages)
        {
            <span>@message</span>
        }
    </p>
}
else if (ShowErrorMessages && _visible && _status == ValidationStatus.Error && (_messages?.Count > 0) && ParentValidation == null)
{
    <p @attributes="BuildAttributes()">
        @foreach (var message in _messages!)
        {
            <span>@message</span>
        }
    </p>
}

@code {
    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    [CascadingParameter(Name = nameof(ParentValidations))]
    public Validations? ParentValidations { get; set; }

    [CascadingParameter]
    private FieldContext? FieldContext { get; set; }

    [Parameter]
    public bool ShowErrorMessages { get; set; } = true;

    private bool _visible;
    private ValidationStatus _status = ValidationStatus.None;
    private IReadOnlyCollection<string>? _messages;
    private IDisposable? _registration;
    private FieldContext? _registeredFieldContext;
    private bool HasChildContent => ChildContent is not null;

    protected override void OnInitialized()
    {
        if (ParentValidations is not null)
        {
            ParentValidations._statusChanged += OnStatusChanged;
            ParentValidations.ClearingAll += OnClearingAll;
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var shouldRegister = FieldContext is not null && (HasChildContent || ShowErrorMessages);
        var fieldContext = shouldRegister ? FieldContext : null;

        if (!ReferenceEquals(_registeredFieldContext, fieldContext))
        {
            _registration?.Dispose();
            _registeredFieldContext = fieldContext;
            _registration = fieldContext?.RegisterError();
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "form-message";

        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Normal;
        TextColor ??= Quark.TextColor.Destructive;
    }

    private void OnStatusChanged(ValidationsStatusChangedEventArgs args)
    {
        _status = args.Status;
        _messages = args.Messages;
        _visible = args.Status != ValidationStatus.None;
        _ = RefreshOffThread();
    }

    private void OnClearingAll()
    {
        _visible = false;
        _status = ValidationStatus.None;
        _messages = null;
        _ = RefreshOffThread();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        if (FieldContext is not null && !attributes.ContainsKey("id"))
            attributes["id"] = FieldContext.ErrorId;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(HasChildContent);
        hc.Add(ShowErrorMessages);
        hc.Add(_visible);
        hc.Add(_status);

        if (_messages is not null)
            hc.Add(_messages.Count);

        if (ParentValidation is not null)
        {
            hc.Add(ParentValidation.Status);
            if (ParentValidation.Messages is not null)
                hc.Add(CountMessages(ParentValidation.Messages));
        }

        hc.Add(FieldContext?.ErrorId);
    }

    public override async ValueTask DisposeAsync()
    {
        _registration?.Dispose();
        await base.DisposeAsync();

        if (ParentValidations is not null)
        {
            ParentValidations._statusChanged -= OnStatusChanged;
            ParentValidations.ClearingAll -= OnClearingAll;
        }
        }

    private static bool HasMessages(IEnumerable<string>? messages)
    {
        if (messages is null)
            return false;

        using IEnumerator<string> enumerator = messages.GetEnumerator();
        return enumerator.MoveNext();
    }

    private static int CountMessages(IEnumerable<string>? messages)
    {
        if (messages is null)
            return 0;

        var count = 0;

        foreach (var _ in messages)
            count++;

        return count;
    }
}
