@namespace Soenneker.Quark.Forms
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentFormControl" Value="this" IsFixed="true">
    <CascadingValue Name="FormControlSlot" Value="true" IsFixed="true">
        @ChildContent
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter]
    public CssValue<GridColsBuilder>? Columns { get; set; }

    [CascadingParameter(Name = "FormHorizontal")]
    protected bool FormHorizontal { get; set; }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        AddIf(ref hc, Columns);
        hc.Add(FormHorizontal);
    }
}
