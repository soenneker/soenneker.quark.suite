@namespace Soenneker.Quark.Forms
@inherits Soenneker.Quark.TypographyElement

@if (HasContent)
{
    <p @attributes="BuildAttributes()">
        @ChildContent
    </p>
}

@code {
    [CascadingParameter]
    private FieldContext? FieldContext { get; set; }

    private IDisposable? _registration;
    private FieldContext? _registeredContext;
    private bool HasContent => ChildContent is not null;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var contextToRegister = HasContent ? FieldContext : null;

        if (!ReferenceEquals(_registeredContext, contextToRegister))
        {
            _registration?.Dispose();
            _registeredContext = contextToRegister;
            _registration = contextToRegister?.RegisterDescription();
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Normal;
        TextColor ??= Quark.TextColor.MutedForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "form-description";

        if (FieldContext is not null && !attributes.ContainsKey("id"))
            attributes["id"] = FieldContext.DescriptionId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "[&>a]:underline [&>a]:underline-offset-4 [&>a:hover]:text-primary");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(HasContent);
        hc.Add(FieldContext?.DescriptionId);
    }

    public override void Dispose()
    {
        _registration?.Dispose();
        base.Dispose();
    }
}
