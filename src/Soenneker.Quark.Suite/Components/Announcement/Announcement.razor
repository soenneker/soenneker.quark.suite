@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (Href.HasContent())
{
    <a href="@Href"
       target="@Target?.Value"
       @onclick="HandleClick"
       @attributes="BuildAttributes()">
        @RenderContent()
    </a>
}
else
{
    <span @onclick="HandleClick"
          @attributes="BuildAttributes()">
        @RenderContent()
    </span>
}

@code {
    private const string _baseClass =
        "group/announcement inline-flex max-w-full items-center gap-1 rounded-full border px-2 py-1 text-sm font-medium shadow-sm outline-none transition-all hover:shadow-md focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 [&_svg]:pointer-events-none [&_svg]:shrink-0";

    /// <summary>
    /// Gets or sets the compact label shown before the announcement text.
    /// </summary>
    [Parameter]
    public string? TagText { get; set; }

    /// <summary>
    /// Gets or sets custom content for the compact label shown before the announcement text.
    /// </summary>
    [Parameter]
    public RenderFragment? TagContent { get; set; }

    /// <summary>
    /// Gets or sets optional leading icon content.
    /// </summary>
    [Parameter]
    public RenderFragment? IconContent { get; set; }

    /// <summary>
    /// Gets or sets whether the trailing chevron is rendered.
    /// </summary>
    [Parameter]
    public bool ShowChevron { get; set; } = true;

    /// <summary>
    /// Gets or sets whether primary themed colors are used.
    /// </summary>
    [Parameter]
    public bool Themed { get; set; }

    /// <summary>
    /// Gets or sets the URL to navigate to.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Gets or sets the target attribute for the link.
    /// </summary>
    [Parameter]
    public Target? Target { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "announcement";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (!Href.HasContent() && OnClick.HasDelegate)
        {
            attributes["role"] = "button";
            attributes.TryAdd("tabindex", "0");
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, _baseClass);
            AppendClass(ref cls, Themed
                ? "border-primary/20 bg-primary/5 text-primary shadow-primary/5 hover:bg-primary/10 dark:bg-primary/10 dark:hover:bg-primary/15"
                : "border-border bg-background text-foreground hover:bg-muted/50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(TagText);
        hc.Add(TagContent);
        hc.Add(IconContent);
        hc.Add(ShowChevron);
        hc.Add(Themed);
        hc.Add(Href);
        hc.Add(Target);
        hc.Add(OnClick.HasDelegate);
    }

    private RenderFragment RenderContent() =>
        @<text>
            @if (TagContent is not null)
            {
                <span data-slot="announcement-tag" class="@GetTagClass()">@TagContent</span>
            }
            else if (TagText.HasContent())
            {
                <span data-slot="announcement-tag" class="@GetTagClass()">@TagText</span>
            }

            @if (IconContent is not null)
            {
                <span data-slot="announcement-icon" class="inline-flex shrink-0 items-center">
                    @IconContent
                </span>
            }

            <span data-slot="announcement-text" class="min-w-0 truncate">
                @ChildContent
            </span>

            @if (ShowChevron)
            {
                <Icon Name="LucideIcon.ChevronRight" data-slot="announcement-chevron" Class="size-3.5 shrink-0 transition-transform group-hover/announcement:translate-x-0.5 cn-rtl-flip" aria-hidden="true" />
            }
        </text>;

    private string GetTagClass()
    {
        return Themed
            ? "shrink-0 rounded-full bg-primary px-2 py-0.5 text-xs font-semibold text-primary-foreground"
            : "shrink-0 rounded-full bg-muted px-2 py-0.5 text-xs font-semibold text-muted-foreground";
    }

    private Task HandleClick(MouseEventArgs args)
    {
        return OnClick.HasDelegate ? OnClick.InvokeAsync(args) : Task.CompletedTask;
    }
}
