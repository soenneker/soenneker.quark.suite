@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (Href.HasContent())
{
    <a href="@Href" target="@Target?.Value" @onclick="HandleClick" @attributes="BuildAttributes()">
        @RenderContent()
    </a>
}
else
{
    <span @onclick="HandleClick" @attributes="BuildAttributes()">
        @RenderContent()
    </span>
}

@code {

    /// <summary>
    /// Gets or sets the compact label shown before the announcement text.
    /// </summary>
    [Parameter]
    public string? TagText { get; set; }

    /// <summary>
    /// Gets or sets custom content for the compact label shown before the announcement text.
    /// </summary>
    [Parameter]
    public RenderFragment? TagContent { get; set; }

    /// <summary>
    /// Gets or sets optional leading icon content.
    /// </summary>
    [Parameter]
    public RenderFragment? IconContent { get; set; }

    /// <summary>
    /// Gets or sets whether the trailing chevron is rendered.
    /// </summary>
    [Parameter]
    public bool ShowChevron { get; set; } = true;

    /// <summary>
    /// Gets or sets whether primary themed colors are used.
    /// </summary>
    [Parameter]
    public bool Themed { get; set; }

    /// <summary>
    /// Gets or sets the URL to navigate to.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Gets or sets the target attribute for the link.
    /// </summary>
    [Parameter]
    public Target? Target { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        DataSlot ??= "announcement";
        Display ??= Quark.Display.InlineFlex;
        MaxWidth ??= Quark.MaxWidth.IsFull;
        ItemsAlign ??= Quark.Items.Center;
        Gap ??= Quark.Gap.Is1;
        Rounded ??= Quark.Rounded.Full;
        Border ??= Quark.Border.Default;
        Padding ??= Quark.Padding.OnX.Is2.OnY.Is1;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Shadow ??= Quark.Shadow.Sm;
        OutlineStyle ??= Quark.OutlineStyle.None;
        Transition ??= Quark.Transition.All;
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (!Href.HasContent() && OnClick.HasDelegate)
        {
            attributes["role"] = "button";
            attributes.TryAdd("tabindex", "0");
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/announcement");
            AppendClass(ref cls, "hover:shadow-md focus-visible:border-ring focus-visible:ring-[3px] [&_svg]:pointer-events-none [&_svg]:shrink-0");
            AppendClass(ref cls, Themed ? "shadow-primary/5 hover:bg-primary/10 dark:bg-primary/10 dark:hover:bg-primary/15" : "hover:bg-muted/50");
        });
    }

    protected override void ApplyBorderColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls, CssValue<BorderColorBuilder>? value)
    {
        base.ApplyBorderColor(ref sty, ref cls, value ?? (Themed ? Quark.BorderColor.Utility("border-primary/20") : Quark.BorderColor.Border));
    }

    protected override void ApplyBackgroundColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls, CssValue<BackgroundColorBuilder>? value)
    {
        base.ApplyBackgroundColor(ref sty, ref cls, value ?? (Themed ? Quark.BackgroundColor.Utility("bg-primary/5") : Quark.BackgroundColor.Background));
    }

    protected override void ApplyTextColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls, CssValue<TextColorBuilder>? value)
    {
        base.ApplyTextColor(ref sty, ref cls, value ?? (Themed ? Quark.TextColor.Primary : Quark.TextColor.Foreground));
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(TagText);
        hc.Add(TagContent);
        hc.Add(IconContent);
        hc.Add(ShowChevron);
        hc.Add(Themed);
        hc.Add(Href);
        hc.Add(Target);
        hc.Add(OnClick.HasDelegate);
    }

    private RenderFragment RenderContent() =>
        @<text>
             @if (TagContent is not null)
             {
                 <Span DataSlot="announcement-tag" Shrink="Quark.Shrink.Is0" Rounded="Quark.Rounded.Full" BackgroundColor="@(Themed ? Quark.BackgroundColor.Primary : Quark.BackgroundColor.Muted)" Padding='Quark.Padding.OnX.Is2.OnY.Token("0.5")' TextSize="Quark.TextSize.Xs" FontWeight="Quark.FontWeight.Semibold" TextColor="@(Themed ? Quark.TextColor.PrimaryForeground : Quark.TextColor.MutedForeground)">@TagContent</Span>
             }
             else if (TagText.HasContent())
             {
                 <Span DataSlot="announcement-tag" Shrink="Quark.Shrink.Is0" Rounded="Quark.Rounded.Full" BackgroundColor="@(Themed ? Quark.BackgroundColor.Primary : Quark.BackgroundColor.Muted)" Padding='Quark.Padding.OnX.Is2.OnY.Token("0.5")' TextSize="Quark.TextSize.Xs" FontWeight="Quark.FontWeight.Semibold" TextColor="@(Themed ? Quark.TextColor.PrimaryForeground : Quark.TextColor.MutedForeground)">@TagText</Span>
             }

             @if (IconContent is not null)
             {
                 <Span DataSlot="announcement-icon" Display="Quark.Display.InlineFlex" Shrink="Quark.Shrink.Is0" ItemsAlign="Quark.Items.Center">
                     @IconContent
                 </Span>
             }

             <Span DataSlot="announcement-text" MinWidth="Quark.MinWidth.Is0" Truncate="Quark.Truncate.Default">
                 @ChildContent
             </Span>

             @if (ShowChevron)
             {
                 <Icon Name="LucideIcon.ChevronRight" DataSlot="announcement-chevron" Size="Quark.Size.Is3_5" Shrink="Quark.Shrink.Is0" Transition="Quark.Transition.Transform" Class="group-hover/announcement:translate-x-0.5 cn-rtl-flip" aria-hidden="true"/>
             }
    </text>;

    private Task HandleClick(MouseEventArgs args)
    {
        return OnClick.HasDelegate ? OnClick.InvokeAsync(args) : Task.CompletedTask;
    }

}
