@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarSeparator AdditionalAttributes="@SeparatorAttributes" />

@code {
    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");
        Margin ??= Quark.Margin.Token("-1").OnX.Is1.OnY;
        Height ??= Quark.Height.IsPx;

        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-separator";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, string.Empty);
        });
    }
}
