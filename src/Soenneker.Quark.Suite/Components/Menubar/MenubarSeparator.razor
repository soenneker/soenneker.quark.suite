@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarSeparator AdditionalAttributes="@SeparatorAttributes" />

@code {
    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "menubar-separator";
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");
        Margin ??= Quark.Margin.Token("-1").OnX.Is1.OnY;
        Height ??= Quark.Height.IsPx;

    }
}