@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement

<BradixMenuItem Role="menuitemradio"
                Disabled="@Disabled"
                OnSelect="HandleSelect"
                AdditionalAttributes="@RadioItemAttributes">
    <span class="pointer-events-none absolute left-2 flex size-3.5 items-center justify-center rtl:left-auto rtl:right-2">
        @if (Selected)
        {
            <span class="size-2 rounded-full bg-current"></span>
        }
    </span>
    @ChildContent
</BradixMenuItem>

@code {
    [Parameter]
    public bool Selected { get; set; }

    [Parameter]
    public EventCallback<bool> SelectedChanged { get; set; }

    private IReadOnlyDictionary<string, object> RadioItemAttributes => BuildRadioItemAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-radio-item";
        attributes["data-state"] = Selected ? "checked" : "unchecked";
        attributes["aria-checked"] = Selected ? "true" : "false";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-menubar-radio-item");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground relative flex cursor-default items-center gap-2 rounded-xs py-1.5 pr-2 pl-8 rtl:pr-8 rtl:pl-2 text-sm outline-hidden select-none data-[disabled]:pointer-events-none data-[disabled]:opacity-50 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    private IReadOnlyDictionary<string, object> BuildRadioItemAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("tabindex");
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Selected);
        hc.Add(Disabled);
    }

    private async Task HandleSelect()
    {
        if (Disabled || Selected)
            return;

        Selected = true;
        await SelectedChanged.InvokeAsync(true);
    }
}
