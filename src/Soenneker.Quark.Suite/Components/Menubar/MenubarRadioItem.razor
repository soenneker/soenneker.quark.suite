@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarRadioItem Value="@Value"
                        Disabled="@Disabled"
                        CloseOnSelect="@CloseOnSelect"
                        AdditionalAttributes="@RadioItemAttributes">
    <span class="pointer-events-none absolute left-2 flex size-3.5 items-center justify-center"
          data-slot="menubar-radio-item-indicator">
        <BradixMenubarItemIndicator>
            <Icon Name="LucideIcon.Circle" Class="size-2 fill-current" />
        </BradixMenubarItemIndicator>
    </span>
    @ChildContent
</BradixMenubarRadioItem>

@code {
    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Indented { get; set; }

    [Parameter]
    public bool CloseOnSelect { get; set; }

    private IReadOnlyDictionary<string, object> RadioItemAttributes => BuildRadioItemAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-radio-item";

        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "outline-hidden");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is1.Token("1.5");
        Rounded ??= Quark.Rounded.Token("xs");
        Padding ??= Quark.Padding.Is2.FromRight.Token("8").FromLeft.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;
    }

    private IReadOnlyDictionary<string, object> BuildRadioItemAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(Indented);
        hc.Add(CloseOnSelect);
    }
}
