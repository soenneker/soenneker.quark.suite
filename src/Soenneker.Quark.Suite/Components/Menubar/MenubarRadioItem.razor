@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarRadioItem Value="@Value"
                        Disabled="@Disabled"
                        CloseOnSelect="@CloseOnSelect"
                        AdditionalAttributes="@RadioItemAttributes">
    <span class="pointer-events-none absolute left-2 flex size-3.5 items-center justify-center rtl:left-auto rtl:right-2">
        <BradixMenubarItemIndicator>
            <span class="size-2 rounded-full bg-current"></span>
        </BradixMenubarItemIndicator>
    </span>
    @ChildContent
</BradixMenubarRadioItem>

@code {
    [Parameter, EditorRequired]
    public string Value { get; set; } = null!;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Indented { get; set; }

    [Parameter]
    public bool CloseOnSelect { get; set; }

    private IReadOnlyDictionary<string, object> RadioItemAttributes => BuildRadioItemAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        ApplyDefaultParameters();

        attributes["data-slot"] = "menubar-radio-item";

        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground cursor-default py-1.5 pr-2 pl-8 rtl:pr-8 rtl:pl-2 outline-hidden data-[disabled]:pointer-events-none data-[disabled]:opacity-50 data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Sm;
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
    }

    private IReadOnlyDictionary<string, object> BuildRadioItemAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(Indented);
        hc.Add(CloseOnSelect);
    }
}
