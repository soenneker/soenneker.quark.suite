@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentMenubar" Value="@this" IsFixed="true">
    <BradixMenubar Value="@_openMenuValue"
                   ValueChanged="HandleValueChanged"
                   AdditionalAttributes="@MenubarAttributes">
        @ChildContent
    </BradixMenubar>
</CascadingValue>

@code {
    private readonly string _menubarId = BlazorIdGenerator.New("quark-menubar");
    private readonly List<MenubarTrigger> _triggers = [];
    private string? _openMenuValue;
    private IReadOnlyDictionary<string, object> MenubarAttributes => BuildMenubarAttributes();


    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    internal void RegisterTrigger(MenubarTrigger trigger)
    {
        if (!_triggers.Contains(trigger))
            _triggers.Add(trigger);
    }

    internal void UnregisterTrigger(MenubarTrigger trigger)
    {
        _triggers.Remove(trigger);
    }

    internal async Task HandleTriggerNavigation(MenubarTrigger currentTrigger, string key, bool openMenu = false)
    {
        var enabledTriggers = _triggers.Where(trigger => !trigger.Disabled).ToList();
        if (enabledTriggers.Count == 0)
            return;

        var currentIndex = enabledTriggers.FindIndex(trigger => ReferenceEquals(trigger, currentTrigger));
        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledTriggers.Count - 1,
            "ArrowRight" when IsHorizontalRtl() => (currentIndex - 1 + enabledTriggers.Count) % enabledTriggers.Count,
            "ArrowLeft" when IsHorizontalRtl() => (currentIndex + 1) % enabledTriggers.Count,
            "ArrowRight" => (currentIndex + 1) % enabledTriggers.Count,
            "ArrowLeft" => (currentIndex - 1 + enabledTriggers.Count) % enabledTriggers.Count,
            _ => -1
        };

        if (nextIndex < 0)
            return;

        var targetTrigger = enabledTriggers[nextIndex];
        await targetTrigger.Focus();

        if (openMenu)
            await targetTrigger.FocusMenuFirstItem();
    }

    internal async Task HandleMenuTraversal(MenubarMenu currentMenu, string key)
    {
        if (currentMenu.Trigger is not null)
            await HandleTriggerNavigation(currentMenu.Trigger, key, openMenu: true);
    }

    internal Task CloseCurrentMenu()
    {
        if (_openMenuValue is null)
            return Task.CompletedTask;

        _openMenuValue = null;
        return InvokeAsync(StateHasChanged);
    }

    internal bool IsSubmenuOpenKey(string key)
    {
        return IsHorizontalRtl() ? key == "ArrowLeft" : key == "ArrowRight";
    }

    internal bool IsSubmenuCloseKey(string key)
    {
        return IsHorizontalRtl() ? key == "ArrowRight" : key == "ArrowLeft";
    }

    private bool IsHorizontalRtl()
    {
        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    private string GetResolvedDirection()
    {
        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return "rtl";

        if (string.Equals(DirectionProviderDir, "ltr", StringComparison.OrdinalIgnoreCase))
            return "ltr";

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return "rtl";
        }

        return "ltr";
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Token("9");
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is1;
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Background;
        Padding ??= Quark.Padding.Is1;
        Shadow ??= Quark.Shadow.Xs;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["id"] = _menubarId;
        attributes["data-slot"] = "menubar";
        attributes["data-orientation"] = "horizontal";
        attributes["data-modal"] = "false";
        attributes["role"] = "menubar";
        attributes["aria-orientation"] = "horizontal";
        attributes["dir"] = GetResolvedDirection();
    }

    private IReadOnlyDictionary<string, object> BuildMenubarAttributes()
    {
        return BuildAttributes();
    }

    private Task HandleValueChanged(string? value)
    {
        _openMenuValue = value;
        return Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(DirectionProviderDir);
        hc.Add(_openMenuValue);
    }
}
