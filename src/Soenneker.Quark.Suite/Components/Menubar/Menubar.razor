@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    private readonly string _menubarId = $"menubar-{Guid.NewGuid():N}";

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["id"] = _menubarId;
        attributes["data-slot"] = "menubar";
        attributes["data-orientation"] = "horizontal";
        attributes["data-modal"] = "false";
        attributes["role"] = "menubar";
        attributes["aria-orientation"] = "horizontal";
        attributes["dir"] = "ltr";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-menubar");
            AppendClass(ref cls, "bg-background flex h-9 items-center gap-1 rounded-md border p-1 shadow-xs");
        });
    }
}
