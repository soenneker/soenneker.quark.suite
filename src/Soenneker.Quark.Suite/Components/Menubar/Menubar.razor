@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentMenubar" Value="@this" IsFixed="true">
    <BradixMenubar Value="@_openMenuValue"
                   ValueChanged="HandleValueChanged"
                   AdditionalAttributes="@MenubarAttributes">
        @ChildContent
    </BradixMenubar>
</CascadingValue>

@code {
    private readonly string _menubarId = BlazorIdGenerator.New("quark-menubar");
    private string? _openMenuValue;
    private IReadOnlyDictionary<string, object> MenubarAttributes => BuildMenubarAttributes();


    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    private string GetResolvedDirection()
    {
        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return "rtl";

        if (string.Equals(DirectionProviderDir, "ltr", StringComparison.OrdinalIgnoreCase))
            return "ltr";

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return "rtl";
        }

        return "ltr";
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Token("8");
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Token("0.5");
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        Padding ??= Quark.Padding.Token("[3px]");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["id"] = _menubarId;
        attributes["data-slot"] = "menubar";
        attributes["data-orientation"] = "horizontal";
        attributes["data-modal"] = "false";
        attributes["role"] = "menubar";
        attributes["aria-orientation"] = "horizontal";
        attributes["dir"] = GetResolvedDirection();
    }

    private IReadOnlyDictionary<string, object> BuildMenubarAttributes()
    {
        return BuildAttributes();
    }

    private Task HandleValueChanged(string? value)
    {
        _openMenuValue = value;
        return Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(DirectionProviderDir);
        hc.Add(_openMenuValue);
    }
}
