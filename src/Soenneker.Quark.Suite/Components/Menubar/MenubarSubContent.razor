@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarSubContent AdditionalAttributes="@ContentAttributes">
    <div class="contents">
        @ChildContent
    </div>
</BradixMenubarSubContent>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public string Side { get; set; } = "right";

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        OverflowX ??= Quark.Overflow.X.Hidden;
        OverflowY ??= Quark.Overflow.Y.Auto;
        Rounded ??= Quark.Rounded.Md;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is1;
        TextColor ??= Quark.TextColor.PopoverForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-sub-content";
        attributes["data-side"] = Side;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "z-50 min-w-32 origin-(--radix-menubar-content-transform-origin) ring-1 ring-foreground/10 shadow-lg duration-100");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-open:animate-in data-open:fade-in-0 data-open:zoom-in-95 data-closed:animate-out data-closed:fade-out-0 data-closed:zoom-out-95");
        });
    }

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-state");
        attributes.Remove("data-side");
        attributes.Remove("role");
        attributes.Remove("aria-orientation");
        attributes.Remove("aria-hidden");
        attributes.Remove("tabindex");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Side);
        hc.Add(DisableAutoOpen);
    }
}
