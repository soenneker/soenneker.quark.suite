@using Soenneker.Bradix
@using System.Collections.Generic

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarSubContent ForceMount="@ForceMount"
                         SideOffset="@SideOffset"
                         AlignOffset="@AlignOffset"
                         ArrowPadding="@ArrowPadding"
                         AvoidCollisions="@AvoidCollisions"
                         CollisionPadding="@CollisionPadding"
                         CollisionBoundarySelector="@CollisionBoundarySelector"
                         CollisionBoundarySelectors="@CollisionBoundarySelectors"
                         Sticky="@Sticky"
                         HideWhenDetached="@HideWhenDetached"
                         AdditionalAttributes="@ContentAttributes">
    @ChildContent
</BradixMenubarSubContent>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public Side Side { get; set; } = Side.Right;

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    [Parameter]
    public double SideOffset { get; set; }

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        ZIndex ??= "z-50";
        MinWidth ??= Quark.MinWidth.Token("[8rem]");
        Overflow ??= Quark.Overflow.Hidden;
        Rounded ??= Quark.Rounded.Lg;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is1;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Shadow ??= Quark.Shadow.Md;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-sub-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "cn-menu-target cn-menu-translucent origin-(--radix-menubar-content-transform-origin) ring-1 ring-foreground/10 duration-100");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-open:animate-in data-open:fade-in-0 data-open:zoom-in-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
        });
    }

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(ForceMount);
        hc.Add(Side);
        hc.Add(DisableAutoOpen);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (var selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
    }
}
