@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarGroup AdditionalAttributes="@GroupAttributes">
    @ChildContent
</BradixMenubarGroup>

@code {
    private IReadOnlyDictionary<string, object> GroupAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "menubar-group";
    }
}
