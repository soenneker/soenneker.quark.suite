@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixMenubarItem Disabled="@Disabled"
                   OnSelect="HandleSelect"
                   AdditionalAttributes="@ItemAttributes">
    @ChildContent
</BradixMenubarItem>

@code {
    [Parameter]
    public bool Indented { get; set; }

    [Parameter]
    public bool Destructive { get; set; }

    private IReadOnlyDictionary<string, object> ItemAttributes => BuildItemAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        ApplyDefaultParameters();

        attributes["data-slot"] = "menubar-item";
        attributes["data-inset"] = Indented ? "true" : "false";
        attributes["data-variant"] = Destructive ? "destructive" : "default";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[variant=destructive]:text-destructive data-[variant=destructive]:focus:bg-destructive/10 dark:data-[variant=destructive]:focus:bg-destructive/20 data-[variant=destructive]:focus:text-destructive data-[variant=destructive]:*:[svg]:!text-destructive [&_svg:not([class*='text-'])]:text-muted-foreground cursor-default py-1.5 outline-hidden data-[disabled]:pointer-events-none data-[disabled]:opacity-50 data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");

        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Position ??= Quark.Position.Relative;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Is2.OnX;
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
    }

    private IReadOnlyDictionary<string, object> BuildItemAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("tabindex");
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Indented);
        hc.Add(Disabled);
        hc.Add(Destructive);
    }

    private Task HandleSelect()
    {
        return Task.CompletedTask;
    }
}
