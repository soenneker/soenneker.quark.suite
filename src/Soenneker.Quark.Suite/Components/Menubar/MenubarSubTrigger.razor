@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IMenubarFocusableItem

<div @attributes="BuildAttributes()" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onkeydown:stopPropagation="_stopPropagation" @onmouseenter="HandlePointerOpen" @onclick="HandlePointerOpen" @ref="_elementRef">
    @ChildContent
    <Icon Name="LucideIcon.ChevronRight" Class="ml-auto h-4 w-4 rtl:ml-0 rtl:mr-auto rtl:rotate-180" />
</div>

@code {
    private ElementReference _elementRef;
    private bool _preventDefaultKeys;
    private bool _stopPropagation;

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool Inset { get; set; }

    [CascadingParameter(Name = "ParentMenubarSub")]
    private MenubarSub? ParentMenubarSub { get; set; }

    [CascadingParameter(Name = "ParentMenubar")]
    private Menubar? ParentMenubar { get; set; }

    [CascadingParameter(Name = "ParentMenubarMenu")]
    private MenubarMenu? ParentMenubarMenu { get; set; }

    [CascadingParameter(Name = "MenubarNavigationSub")]
    private MenubarSub? NavigationSub { get; set; }

    bool IMenubarFocusableItem.IsDisabledForNavigation => Disabled;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        ParentMenubarSub?.RegisterTrigger(this);

        if (NavigationSub is not null)
            NavigationSub.RegisterItem(this);
        else
            ParentMenubarMenu?.RegisterItem(this);
    }

    private void HandlePointerOpen()
    {
        // Focus-within/hover CSS controls visibility; this ensures the trigger itself receives focusable interaction.
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-sub-trigger";
        attributes["data-state"] = Open ? "open" : "closed";
        attributes["data-inset"] = Inset ? "true" : "false";
        attributes["role"] = "menuitem";
        attributes["aria-haspopup"] = "menu";
        attributes["aria-expanded"] = Open ? "true" : "false";
        attributes["tabindex"] = Disabled ? -1 : 0;

        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["aria-disabled"] = "true";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-menubar-sub-trigger");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[state=open]:bg-accent data-[state=open]:text-accent-foreground flex cursor-default items-center rounded-sm px-2 py-1.5 text-sm outline-none select-none data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Inset);
        hc.Add(Disabled);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;
        _stopPropagation = false;

        if (e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
        {
            if (NavigationSub is not null)
            {
                await NavigationSub.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
            else if (ParentMenubarMenu is not null)
            {
                await ParentMenubarMenu.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
        }
        else if ((ParentMenubar?.IsSubmenuOpenKey(e.Key) ?? (e.Key == "ArrowRight")) || e.Key is "Enter" or " ")
        {
            if (ParentMenubarSub is not null)
            {
                await ParentMenubarSub.FocusFirstItemAsync();
                _preventDefaultKeys = true;
            }
        }
        else if (NavigationSub is not null && ParentMenubar?.IsSubmenuCloseKey(e.Key) == true)
        {
            await NavigationSub.FocusTriggerAsync();
            _preventDefaultKeys = true;
        }
        else if (NavigationSub is null && ParentMenubar is not null && ParentMenubarMenu is not null && e.Key is "ArrowRight" or "ArrowLeft")
        {
            await ParentMenubar.HandleMenuTraversalAsync(ParentMenubarMenu, e.Key);
            _preventDefaultKeys = true;
        }
        else if (e.Key == "Escape" && ParentMenubarMenu is not null)
        {
            await ParentMenubarMenu.FocusTriggerAsync();
            _preventDefaultKeys = true;
            _stopPropagation = true;
        }

        await base.HandleKeyDown(e);
    }

    async Task IMenubarFocusableItem.FocusAsync()
    {
        await _elementRef.FocusAsync();
    }

    internal async Task FocusAsync()
    {
        await _elementRef.FocusAsync();
    }

    public override void Dispose()
    {
        if (NavigationSub is not null)
            NavigationSub.UnregisterItem(this);
        else
            ParentMenubarMenu?.UnregisterItem(this);

        base.Dispose();
    }
}
