@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixMenubarSubTrigger Disabled="@Disabled"
                         AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <Icon Name="LucideIcon.ChevronRight" Class="ml-auto h-4 w-4 rtl:ml-0 rtl:mr-auto rtl:rotate-180" />
</BradixMenubarSubTrigger>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool Inset { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        ApplyDefaultParameters();

        attributes["data-slot"] = "menubar-sub-trigger";
        attributes["data-inset"] = Inset ? "true" : "false";

        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[state=open]:bg-accent data-[state=open]:text-accent-foreground cursor-default py-1.5 outline-none data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        AlignUtility ??= Quark.Align.ItemsCenter;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Is2.OnX;
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("tabindex");
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Inset);
        hc.Add(Disabled);
    }
}
