@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixMenubarSubTrigger Disabled="@Disabled"
                         AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <Icon Name="LucideIcon.ChevronRight" Class="ml-auto h-4 w-4" />
</BradixMenubarSubTrigger>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool Indented { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-sub-trigger";
        if (Indented)
            attributes["data-inset"] = "true";

        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "gap-1.5 focus:bg-accent focus:text-accent-foreground data-inset:pl-7 data-[inset]:pl-7 data-open:bg-accent data-open:text-accent-foreground data-[state=open]:bg-accent data-[state=open]:text-accent-foreground [&_svg:not([class*='size-'])]:size-4");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Token("1.5").OnX.Is1.OnY;
        TextSize ??= Quark.TextSize.Sm;
        OutlineStyle ??= Quark.OutlineStyle.None;
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Indented);
        hc.Add(Disabled);
    }

    public override void Dispose() => base.Dispose();
}
