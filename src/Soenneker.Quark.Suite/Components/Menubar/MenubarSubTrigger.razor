@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixMenubarSubTrigger Disabled="@Disabled"
                         AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <Icon Name="LucideIcon.ChevronRight" Class="cn-rtl-flip ml-auto size-4" />
</BradixMenubarSubTrigger>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool Indented { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-sub-trigger";
        attributes["data-inset"] = Indented ? "true" : "false";

        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "outline-none focus:bg-accent focus:text-accent-foreground data-[inset]:pl-7 data-open:bg-accent data-open:text-accent-foreground");
            AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-4");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is1.Token("1.5");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is2.OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("tabindex");
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Indented);
        hc.Add(Disabled);
    }
}
