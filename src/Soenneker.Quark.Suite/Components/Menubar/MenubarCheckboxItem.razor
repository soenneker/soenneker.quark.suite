@using Soenneker.Bradix
@using BradixCheckboxCheckedState = Soenneker.Bradix.BradixCheckboxCheckedState

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement

<BradixMenubarCheckboxItem Checked="@ResolvedCheckedState"
                           CheckedChanged="HandleCheckedStateChanged"
                           Disabled="@Disabled"
                           CloseOnSelect="@CloseOnSelect"
                           AdditionalAttributes="@CheckboxAttributes">
    <Span DataSlot="menubar-checkbox-item-indicator"
          PointerEvents="Quark.PointerEvents.None"
          Position="Quark.Position.Absolute"
          Display="Quark.Display.Flex"
          Size="Quark.Size.Is4"
          ItemsAlign="Items.Center"
          Justify="Quark.Justify.Center"
          Left='Quark.Left.Token("1.5")'
          Class="[&_svg:not([class*='size-'])]:size-4">
        <BradixMenubarItemIndicator>
            <Icon Name="LucideIcon.Check" Size="Quark.Size.Is4" />
        </BradixMenubarItemIndicator>
    </Span>
    @ChildContent
</BradixMenubarCheckboxItem>

@code {
    [Parameter]
    public bool CloseOnSelect { get; set; }

    [Parameter]
    public bool Indented { get; set; }

    private BradixCheckboxCheckedState ResolvedCheckedState =>
        Checked ? BradixCheckboxCheckedState.Checked : BradixCheckboxCheckedState.Unchecked;

    private IReadOnlyDictionary<string, object> CheckboxAttributes => BuildCheckboxAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-state"] = Checked ? "checked" : "unchecked";
        attributes["aria-checked"] = Checked ? "true" : "false";
        if (Indented)
            attributes["data-inset"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:**:text-accent-foreground data-inset:pl-7 data-disabled:pointer-events-none");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0");
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "menubar-checkbox-item";
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Token("1.5");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Token("1.5").FromRight.Token("7").FromLeft.Is1.OnY;
        TextSize ??= Quark.TextSize.Sm;
        BackgroundColor ??= Quark.BackgroundColor.OnFocus.Accent;
        TextColor ??= Quark.TextColor.OnFocus.AccentForeground;
        OutlineStyle ??= Quark.OutlineStyle.Hidden;
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    private IReadOnlyDictionary<string, object> BuildCheckboxAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(CloseOnSelect);
        hc.Add(Indented);
    }

    private async Task HandleCheckedStateChanged(BradixCheckboxCheckedState state)
    {
        var next = state == BradixCheckboxCheckedState.Checked;
        Checked = next;
        await CheckedChanged.InvokeAsync(next);
    }
}
