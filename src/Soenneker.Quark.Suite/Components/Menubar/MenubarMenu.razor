@using Soenneker.Bradix
@using Soenneker.Blazor.Utils.Ids

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentMenubarMenu" Value="@this" IsFixed="true">
    <BradixMenubarMenu Value="@_menuValue">
        @ChildContent
    </BradixMenubarMenu>
</CascadingValue>

@code {
    private readonly string _menuValue = BlazorIdGenerator.New("quark-menubar-menu");
    private readonly List<IMenubarFocusableItem> _items = [];
    private MenubarTrigger? _trigger;

    internal void RegisterItem(IMenubarFocusableItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);
    }

    internal void UnregisterItem(IMenubarFocusableItem item)
    {
        _items.Remove(item);
    }

    internal void RegisterTrigger(MenubarTrigger trigger)
    {
        _trigger = trigger;
    }

    internal MenubarTrigger? Trigger => _trigger;

    internal async Task FocusFirstItem()
    {
        IMenubarFocusableItem? firstItem = GetFirstEnabledItem();
        if (firstItem is not null)
            await firstItem.Focus();
    }

    internal async Task FocusLastItem()
    {
        IMenubarFocusableItem? lastItem = GetLastEnabledItem();
        if (lastItem is not null)
            await lastItem.Focus();
    }

    internal async Task HandleItemNavigation(IMenubarFocusableItem currentItem, string key)
    {
        int enabledCount = CountEnabledItems(currentItem, out int currentIndex);
        if (enabledCount == 0 || currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledCount - 1,
            "ArrowDown" => (currentIndex + 1) % enabledCount,
            "ArrowUp" => (currentIndex - 1 + enabledCount) % enabledCount,
            _ => -1
        };

        IMenubarFocusableItem? nextItem = nextIndex >= 0 ? GetEnabledItemAt(nextIndex) : null;
        if (nextItem is not null)
            await nextItem.Focus();
    }

    internal async Task FocusTrigger()
    {
        if (_trigger is not null)
            await _trigger.Focus();
    }

    private IMenubarFocusableItem? GetFirstEnabledItem()
    {
        foreach (IMenubarFocusableItem item in _items)
        {
            if (!item.IsDisabledForNavigation)
                return item;
        }

        return null;
    }

    private IMenubarFocusableItem? GetLastEnabledItem()
    {
        IMenubarFocusableItem? last = null;

        foreach (IMenubarFocusableItem item in _items)
        {
            if (!item.IsDisabledForNavigation)
                last = item;
        }

        return last;
    }

    private int CountEnabledItems(IMenubarFocusableItem currentItem, out int currentIndex)
    {
        currentIndex = -1;
        int count = 0;

        foreach (IMenubarFocusableItem item in _items)
        {
            if (item.IsDisabledForNavigation)
                continue;

            if (ReferenceEquals(item, currentItem))
                currentIndex = count;

            count++;
        }

        return count;
    }

    private IMenubarFocusableItem? GetEnabledItemAt(int targetIndex)
    {
        int index = 0;

        foreach (IMenubarFocusableItem item in _items)
        {
            if (item.IsDisabledForNavigation)
                continue;

            if (index == targetIndex)
                return item;

            index++;
        }

        return null;
    }

}
