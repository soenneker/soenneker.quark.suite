@using Soenneker.Bradix
@using Soenneker.Blazor.Utils.Ids

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentMenubarMenu" Value="@this" IsFixed="true">
    <BradixMenubarMenu Value="@_menuValue">
        @ChildContent
    </BradixMenubarMenu>
</CascadingValue>

@code {
    private readonly string _menuValue = BlazorIdGenerator.New("quark-menubar-menu");
    private readonly List<IMenubarFocusableItem> _items = [];
    private MenubarTrigger? _trigger;

    internal void RegisterItem(IMenubarFocusableItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);
    }

    internal void UnregisterItem(IMenubarFocusableItem item)
    {
        _items.Remove(item);
    }

    internal void RegisterTrigger(MenubarTrigger trigger)
    {
        _trigger = trigger;
    }

    internal MenubarTrigger? Trigger => _trigger;

    internal async Task FocusFirstItem()
    {
        var firstItem = _items.FirstOrDefault(i => !i.IsDisabledForNavigation);
        if (firstItem is not null)
            await firstItem.Focus();
    }

    internal async Task FocusLastItem()
    {
        var lastItem = _items.LastOrDefault(i => !i.IsDisabledForNavigation);
        if (lastItem is not null)
            await lastItem.Focus();
    }

    internal async Task HandleItemNavigation(IMenubarFocusableItem currentItem, string key)
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
            return;

        var currentIndex = enabledItems.FindIndex(i => ReferenceEquals(i, currentItem));
        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledItems.Count - 1,
            "ArrowDown" => (currentIndex + 1) % enabledItems.Count,
            "ArrowUp" => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            _ => -1
        };

        if (nextIndex >= 0)
            await enabledItems[nextIndex].Focus();
    }

    internal async Task FocusTrigger()
    {
        if (_trigger is not null)
            await _trigger.Focus();
    }

}
