@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<button @attributes="BuildAttributes()" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @ref="_elementRef">
    @ChildContent
</button>

@code {
    private ElementReference _elementRef;
    private bool _preventDefaultKeys;
    private Menubar? _registeredMenubar;
    private MenubarMenu? _registeredMenubarMenu;

    [Parameter]
    public bool Open { get; set; }

    [CascadingParameter(Name = "ParentMenubar")]
    private Menubar? ParentMenubar { get; set; }

    [CascadingParameter(Name = "ParentMenubarMenu")]
    private MenubarMenu? ParentMenubarMenu { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        SyncRegistrationWithParents();
    }

    private void SyncRegistrationWithParents()
    {
        if (!ReferenceEquals(_registeredMenubar, ParentMenubar))
        {
            if (_registeredMenubar is not null)
                _registeredMenubar.UnregisterTrigger(this);

            _registeredMenubar = ParentMenubar;

            if (_registeredMenubar is not null)
                _registeredMenubar.RegisterTrigger(this);
        }

        if (!ReferenceEquals(_registeredMenubarMenu, ParentMenubarMenu))
        {
            if (_registeredMenubarMenu is not null)
                _registeredMenubarMenu.UnregisterTrigger(this);

            _registeredMenubarMenu = ParentMenubarMenu;

            if (_registeredMenubarMenu is not null)
                _registeredMenubarMenu.RegisterTrigger(this);
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["type"] = "button";
        attributes["data-slot"] = "menubar-trigger";
        attributes["data-state"] = Open ? "open" : "closed";
        attributes["role"] = "menuitem";
        attributes["aria-haspopup"] = "menu";
        attributes["aria-expanded"] = Open ? "true" : "false";
        attributes["tabindex"] = Disabled ? -1 : 0;

        if (Disabled)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-menubar-trigger");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[state=open]:bg-accent data-[state=open]:text-accent-foreground flex items-center rounded-sm px-2 py-1 text-sm font-medium outline-hidden select-none");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Disabled);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;

        if (ParentMenubar is not null && e.Key is "ArrowRight" or "ArrowLeft" or "Home" or "End")
        {
            _preventDefaultKeys = true;
            await ParentMenubar.HandleTriggerNavigationAsync(this, e.Key);
        }
        else if (ParentMenubarMenu is not null)
        {
            if (e.Key is "ArrowDown" or "Enter" or " ")
            {
                _preventDefaultKeys = true;
                await ParentMenubarMenu.FocusFirstItemAsync();
            }
            else if (e.Key == "ArrowUp")
            {
                _preventDefaultKeys = true;
                await ParentMenubarMenu.FocusLastItemAsync();
            }
        }

        await base.HandleKeyDown(e);
    }

    internal async Task FocusAsync()
    {
        await _elementRef.FocusAsync();
    }

    internal async Task FocusMenuFirstItemAsync()
    {
        if (ParentMenubarMenu is not null)
            await ParentMenubarMenu.FocusFirstItemAsync();
    }

    public override void Dispose()
    {
        if (_registeredMenubarMenu is not null)
            _registeredMenubarMenu.UnregisterTrigger(this);

        if (_registeredMenubar is not null)
            _registeredMenubar.UnregisterTrigger(this);

        base.Dispose();
    }
}
