@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixMenubarTrigger Disabled="@Disabled"
                      OnElementReferenceCaptured="HandleElementCaptured"
                      AdditionalAttributes="@TriggerAttributes">
    @ChildContent
</BradixMenubarTrigger>

@code {
    private ElementReference _elementRef;

    [Parameter]
    public bool Open { get; set; }

    [CascadingParameter(Name = "ParentMenubarMenu")]
    private MenubarMenu? ParentMenubarMenu { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Token("1.5").OnX.Token("[2px]").OnY;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        OutlineStyle ??= "outline-hidden";
        UserSelect ??= Quark.UserSelect.None;

    }

    private Task HandleElementCaptured(ElementReference elementReference)
    {
        _elementRef = elementReference;

        ParentMenubarMenu?.RegisterTrigger(this);

        return Task.CompletedTask;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-trigger";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "hover:bg-muted aria-expanded:bg-muted");
        });
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Disabled);
    }

    internal async Task Focus()
    {
        await _elementRef.FocusAsync();
    }

    public override void Dispose() => base.Dispose();
}
