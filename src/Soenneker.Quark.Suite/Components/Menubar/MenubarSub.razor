@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentMenubarSub" Value="@this" IsFixed="true">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly List<IMenubarFocusableItem> _items = [];
    private MenubarSubTrigger? _trigger;

    internal string SubTriggerId { get; } = $"menubar-sub-trigger-{Guid.NewGuid():N}";

    internal string SubContentId { get; } = $"menubar-sub-menu-{Guid.NewGuid():N}";

    /// <summary>
    /// Clears focusable item order and trigger ref before children re-register in DOM order each render.
    /// </summary>
    protected override void OnParametersSet()
    {
        _items.Clear();
        _trigger = null;
        base.OnParametersSet();
    }

    internal void RegisterItem(IMenubarFocusableItem item)
    {
        if (_items.Contains(item))
            return;

        _items.Add(item);
    }

    internal void RegisterTrigger(MenubarSubTrigger trigger)
    {
        _trigger = trigger;
    }

    internal async Task FocusFirstItemAsync()
    {
        var firstItem = _items.FirstOrDefault(i => !i.IsDisabledForNavigation);
        if (firstItem is not null)
            await firstItem.FocusAsync();
    }

    internal async Task HandleItemNavigationAsync(IMenubarFocusableItem currentItem, string key)
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
            return;

        var currentIndex = enabledItems.FindIndex(i => ReferenceEquals(i, currentItem));
        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledItems.Count - 1,
            "ArrowDown" => (currentIndex + 1) % enabledItems.Count,
            "ArrowUp" => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            _ => -1
        };

        if (nextIndex >= 0)
            await enabledItems[nextIndex].FocusAsync();
    }

    internal async Task FocusTriggerAsync()
    {
        if (_trigger is not null)
            await _trigger.FocusAsync();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-sub";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-menubar-sub");
            AppendClass(ref cls, "group/menubar-sub relative");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(_items.Count);
    }
}
