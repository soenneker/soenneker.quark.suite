@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarSub AdditionalAttributes="@SubAttributes">
    @ChildContent
</BradixMenubarSub>

@code {
    private IReadOnlyDictionary<string, object> SubAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-sub";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-menubar-sub");
            AppendClass(ref cls, "group/menubar-sub relative");
        });
    }
}
