@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onkeydown:stopPropagation="_stopPropagation">
    @ChildContent
</div>

@code {
    private bool _preventDefaultKeys;
    private bool _stopPropagation;

    [CascadingParameter(Name = "ParentMenubarMenu")]
    private MenubarMenu? ParentMenubarMenu { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-content";
        attributes["data-state"] = Open ? "open" : "closed";
        attributes["data-side"] = Side;
        attributes["role"] = "menu";
        attributes["aria-orientation"] = "vertical";
        attributes["aria-hidden"] = Open ? "false" : "true";
        attributes["tabindex"] = -1;

        if (ParentMenubarMenu is not null)
        {
            attributes["id"] = ParentMenubarMenu.MenuContentId;

            if (!attributes.ContainsKey("aria-labelledby"))
                attributes["aria-labelledby"] = ParentMenubarMenu.TriggerId;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-menubar-content");
            AppendClass(ref cls, "bg-popover text-popover-foreground data-[state=open]:animate-in data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2 z-[110] min-w-[12rem] origin-(--radix-menubar-content-transform-origin) overflow-hidden rounded-md border p-1 shadow-md");
            AppendClass(ref cls, "absolute top-full left-0 mt-2 rtl:left-auto rtl:right-0");
            AppendClass(ref cls, "data-[state=closed]:hidden data-[state=open]:block");

            if (!DisableAutoOpen)
                AppendClass(ref cls, "group-hover/menubar-menu:block group-focus-within/menubar-menu:block");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Side);
        hc.Add(DisableAutoOpen);
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;
        _stopPropagation = false;

        if (e.Key != "Escape" || ParentMenubarMenu is null)
            return;

        _preventDefaultKeys = true;
        _stopPropagation = true;
        await ParentMenubarMenu.FocusTriggerAsync();
    }
}
