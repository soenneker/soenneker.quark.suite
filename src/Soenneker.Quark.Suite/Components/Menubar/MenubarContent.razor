@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixMenubarPortal>
    <BradixMenubarContent AdditionalAttributes="@ContentAttributes"
                          Align="@ResolvedAlign"
                          SideOffset="4">
        @ChildContent
    </BradixMenubarContent>
</BradixMenubarPortal>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    private BradixAlignment ResolvedAlign => Side == "right" ? BradixAlignment.End : BradixAlignment.Start;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "menubar-content";
        attributes["data-state"] = Open ? "open" : "closed";
        attributes["data-side"] = Side;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "bg-popover text-popover-foreground data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2 z-50 max-h-(--radix-menubar-content-available-height) min-w-[12rem] origin-(--radix-menubar-content-transform-origin) overflow-x-hidden overflow-y-auto rounded-md border p-1 shadow-md");
        });
    }

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-state");
        attributes.Remove("data-side");
        attributes.Remove("role");
        attributes.Remove("aria-orientation");
        attributes.Remove("aria-hidden");
        attributes.Remove("tabindex");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Side);
        hc.Add(DisableAutoOpen);
    }
}
