@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <button @onclick="HandleClick" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [Parameter]
    public bool AsChild { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Absolute;
        Display ??= Quark.Display.Flex;
        AlignUtility ??= Quark.Align.ItemsCenter.JustifyCenter;
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is0;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "sidebar-group-action";
        attributes["data-sidebar"] = "group-action";

        if (!AsChild)
            attributes["type"] = "button";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "text-sidebar-foreground ring-sidebar-ring hover:bg-sidebar-accent hover:text-sidebar-accent-foreground top-3.5 right-3 aspect-square w-5 outline-hidden transition-transform focus-visible:ring-2 [&>svg]:size-4 [&>svg]:shrink-0");
            AppendClass(ref cls, "after:absolute after:-inset-2 md:after:hidden");
            AppendClass(ref cls, "group-data-[collapsible=icon]:hidden");
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
    }
}
