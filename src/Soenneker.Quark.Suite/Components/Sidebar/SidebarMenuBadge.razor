@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Absolute;
        Display ??= Quark.Display.Flex;
        AlignUtility ??= Quark.Align.ItemsCenter.JustifyCenter;
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is1.OnX;
        TextSize ??= Quark.TextSize.Xs;
        FontWeight ??= Quark.FontWeight.Medium;
        UserSelect ??= Quark.UserSelect.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "sidebar-menu-badge";
        attributes["data-sidebar"] = "menu-badge";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "text-sidebar-foreground pointer-events-none right-1 h-5 min-w-5 tabular-nums");
            AppendClass(ref cls, "peer-hover/menu-button:text-sidebar-accent-foreground peer-data-[active=true]/menu-button:text-sidebar-accent-foreground");
            AppendClass(ref cls, "peer-data-[size=sm]/menu-button:top-1 peer-data-[size=default]/menu-button:top-1.5 peer-data-[size=lg]/menu-button:top-2.5");
            AppendClass(ref cls, "group-data-[collapsible=icon]:hidden");
        });
    }
}
