@namespace Soenneker.Quark
@using Soenneker.Quark.Dtos
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

@if (ShouldRenderMobileSidebar)
{
    <Sheet Visible="State?.OpenMobile == true"
           VisibleChanged="OnMobileVisibleChanged"
           ShowBackdrop="MobileShowBackdrop"
           CloseOnBackdropClick="@ResolvedMobileCloseOnBackdropClick"
           CloseOnEscape="MobileCloseOnEscape"
           LockScroll="MobileLockScroll"
           TrapFocus="@ResolvedMobileTrapFocus">
        <SheetContent Side="@ToSheetSide(Side)"
                      ShowCloseButton="MobileShowCloseButton"
                      ContainerClass="@GetMobileContainerClass()"
                      ContainerStyle="@GetMobileContainerStyle()"
                      OverlayClass="@MobileOverlayClass"
                      OverlayStyle="@GetMobileOverlayStyle()"
                      @attributes="BuildMobileAttributes()">
            <SheetHeader Class="sr-only">
                <SheetTitle>Sidebar</SheetTitle>
                <SheetDescription>Displays the mobile sidebar.</SheetDescription>
            </SheetHeader>
            <div class="flex h-full w-full flex-col">
                @if (IsNavigationShell(Shell))
                {
                    <div class="no-scrollbar flex min-h-0 flex-1 flex-col gap-12 overflow-y-auto bg-background px-6 py-6">
                        @RenderMobileBody()
                    </div>
                }
                else
                {
                    @RenderMobileBody()
                }
            </div>
        </SheetContent>
    </Sheet>
}
else if (IsNoneCollapsible(Collapsible))
{
    <aside @attributes="BuildStaticAttributes()">
        @if (IsNavigationShell(Shell))
        {
            <div class="hidden h-9 lg:block"></div>
            <div class="absolute top-8 z-10 hidden h-8 w-(--sidebar-menu-width) shrink-0 bg-linear-to-b from-background via-background/80 to-background/50 blur-xs lg:block"></div>
            <div class="absolute top-12 right-2 bottom-0 hidden h-full w-px bg-linear-to-b from-transparent via-border to-transparent lg:flex"></div>
        }

        @ChildContent

        @if (IsNavigationShell(Shell))
        {
            <div class="sticky -bottom-1 z-10 hidden h-16 shrink-0 bg-linear-to-t from-background via-background/80 to-background/50 blur-xs lg:block"></div>
        }
    </aside>
}
else
{
    <div @attributes="BuildAttributes()">
        <div @attributes="BuildGapAttributes()"></div>
        <aside @attributes="BuildContainerAttributes()">
            <div @attributes="BuildInnerAttributes()">
                @ChildContent
            </div>
        </aside>
    </div>
}

@code {

    [Parameter]
    public SidebarSide Side { get; set; } = SidebarSide.Left;

    [Parameter]
    public SidebarVariant Variant { get; set; } = SidebarVariant.Sidebar;

    [Parameter]
    public SidebarShell Shell { get; set; } = SidebarShell.Default;

    [Parameter]
    public SidebarCollapsible Collapsible { get; set; } = SidebarCollapsible.Offcanvas;

    [Parameter]
    public SidebarMobileMode MobileMode { get; set; } = SidebarMobileMode.Auto;

    [Parameter]
    public string? Dir { get; set; }

    [CascadingParameter(Name = "DirectionProviderDir")]
    public string? DirectionProviderDir { get; set; }

    [Parameter]
    public bool MobileCloseOnBackdropClick { get; set; } = true;

    [Parameter]
    public bool MobileShowBackdrop { get; set; } = true;

    [Parameter]
    public bool MobileCloseOnEscape { get; set; } = true;

    [Parameter]
    public bool MobileLockScroll { get; set; } = true;

    [Parameter]
    public bool MobileShowCloseButton { get; set; }

    [Parameter]
    public bool? MobileTrapFocus { get; set; }

    [Parameter]
    public string? MobileClass { get; set; }

    [Parameter]
    public string? MobileStyle { get; set; }

    [Parameter]
    public string? MobileOffsetTop { get; set; }

    [Parameter]
    public string? MobileContainerClass { get; set; }

    [Parameter]
    public string? MobileContainerStyle { get; set; }

    [Parameter]
    public string? MobileOverlayClass { get; set; }

    [Parameter]
    public string? MobileOverlayStyle { get; set; }

    [Parameter]
    public RenderFragment? MobileTopContent { get; set; }

    [Parameter]
    public RenderFragment? MobileContent { get; set; }

    [CascadingParameter(Name = "SidebarProvider")]
    public SidebarProvider? SidebarProvider { get; set; }

    [CascadingParameter(Name = "SidebarContextState")]
    public SidebarContextState? State { get; set; }

    private static bool IsRightSide(SidebarSide? side) => ReferenceEquals(side, SidebarSide.Right);
    private static bool IsNavigationShell(SidebarShell? shell) => ReferenceEquals(shell, SidebarShell.Navigation);
    private static bool IsNoneCollapsible(SidebarCollapsible? collapsible) => ReferenceEquals(collapsible, SidebarCollapsible.None);
    private static bool IsAutoMobileMode(SidebarMobileMode? mode) => ReferenceEquals(mode, SidebarMobileMode.Auto);
    private static bool IsHiddenMobileMode(SidebarMobileMode? mode) => ReferenceEquals(mode, SidebarMobileMode.Hidden);
    private static bool IsFullScreenMobileMode(SidebarMobileMode? mode) => ReferenceEquals(mode, SidebarMobileMode.FullScreen);
    private static bool IsFloatingLikeVariant(SidebarVariant? variant) => ReferenceEquals(variant, SidebarVariant.Floating) || ReferenceEquals(variant, SidebarVariant.Inset);

    private static string ToDataSide(SidebarSide? side) => IsRightSide(side) ? "right" : "left";

    private static Side ToSheetSide(SidebarSide? side) => IsRightSide(side) ? Soenneker.Bradix.Side.Right : Soenneker.Bradix.Side.Left;

    private static string ToDataVariant(SidebarVariant? variant)
    {
        if (ReferenceEquals(variant, SidebarVariant.Floating))
            return "floating";

        if (ReferenceEquals(variant, SidebarVariant.Inset))
            return "inset";

        return "sidebar";
    }

    private static string ToDataCollapsible(SidebarCollapsible? collapsible)
    {
        if (ReferenceEquals(collapsible, SidebarCollapsible.Icon))
            return "icon";

        if (IsNoneCollapsible(collapsible))
            return "none";

        return "offcanvas";
    }

    private static string ToDataMobileMode(SidebarMobileMode? mode)
    {
        if (IsHiddenMobileMode(mode))
            return "hidden";

        if (ReferenceEquals(mode, SidebarMobileMode.Sheet))
            return "sheet";

        if (IsFullScreenMobileMode(mode))
            return "full-screen";

        return "auto";
    }

    private static string ToDataShell(SidebarShell? shell) => IsNavigationShell(shell) ? "navigation" : "default";

    private bool IsCollapsed => State is not null && !State.Open;

    private string? ResolvedDir => Dir.HasContent() ? Dir : DirectionProviderDir;

    private SidebarMobileMode ResolvedMobileMode
    {
        get
        {
            var mode = MobileMode ?? SidebarMobileMode.Auto;
            return IsAutoMobileMode(mode) ? IsNoneCollapsible(Collapsible) ? SidebarMobileMode.Hidden : SidebarMobileMode.Sheet : mode;
        }
    }

    private bool ShouldRenderMobileSidebar => State?.IsMobile == true && !IsHiddenMobileMode(ResolvedMobileMode);

    private bool ResolvedMobileTrapFocus => MobileTrapFocus ?? MobileShowBackdrop;

    private bool ResolvedMobileCloseOnBackdropClick => MobileShowBackdrop && MobileCloseOnBackdropClick;

    private Task OnMobileVisibleChanged(bool visible)
    {
        return SidebarProvider?.SetOpenMobile(visible) ?? Task.CompletedTask;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sidebar";
        attributes["data-side"] = ToDataSide(Side);
        attributes["data-variant"] = ToDataVariant(Variant);
        attributes["data-shell"] = ToDataShell(Shell);
        attributes["data-state"] = IsCollapsed ? "collapsed" : "expanded";
        attributes["data-collapsible"] = IsCollapsed ? ToDataCollapsible(Collapsible) : "";

        if (ResolvedDir.HasContent())
            attributes["dir"] = ResolvedDir!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group peer hidden text-sidebar-foreground md:block");
        });
    }

    private Dictionary<string, object> BuildStaticAttributes()
    {
        var attributes = BuildRootAttributes(12);
        attributes["data-slot"] = "sidebar";
        attributes["data-sidebar"] = "sidebar";
        attributes["data-side"] = ToDataSide(Side);
        attributes["data-variant"] = ToDataVariant(Variant);
        attributes["data-shell"] = ToDataShell(Shell);
        attributes["data-state"] = State?.State ?? "expanded";
        attributes["data-collapsible"] = "none";

        if (ResolvedDir.HasContent())
            attributes["dir"] = ResolvedDir!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, IsNavigationShell(Shell) ? "group peer hidden h-full w-(--sidebar-width) flex-col bg-sidebar text-sidebar-foreground lg:flex" : "group peer flex h-full w-(--sidebar-width) flex-col bg-sidebar text-sidebar-foreground");

            if (IsNavigationShell(Shell))
                AppendClass(ref cls, "relative shrink-0 overflow-hidden [--sidebar-menu-width:--spacing(56)] lg:bg-transparent");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildMobileAttributes()
    {
        var attributes = BuildRootAttributes(15);
        attributes["data-slot"] = "sidebar";
        attributes["data-sidebar"] = "sidebar";
        attributes["data-mobile"] = "true";
        attributes["data-mobile-mode"] = ToDataMobileMode(ResolvedMobileMode);
        attributes["data-side"] = ToDataSide(Side);
        attributes["data-variant"] = ToDataVariant(Variant);
        attributes["data-shell"] = ToDataShell(Shell);
        attributes["data-state"] = State?.OpenMobile == true ? "expanded" : "collapsed";

        if (ResolvedDir.HasContent())
            attributes["dir"] = ResolvedDir!;

        BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
        {
            AppendClass(ref cls, "group w-(--sidebar-width) bg-sidebar p-0 text-sidebar-foreground");
            AppendStyleDecl(ref sty, "--sidebar-width: var(--sidebar-width-mobile)");

            if (MobileOffsetTop.HasContent())
            {
                AppendStyleDecl(ref sty, $"top: {MobileOffsetTop}");
                AppendStyleDecl(ref sty, $"height: calc(100svh - {MobileOffsetTop})");
            }

            if (!MobileShowCloseButton)
                AppendClass(ref cls, "[&>button]:hidden");

            if (IsFullScreenMobileMode(ResolvedMobileMode))
                AppendClass(ref cls, "inset-0 h-svh w-screen! max-w-none! rounded-none border-0 sm:max-w-none!");

            if (IsNavigationShell(Shell))
                AppendClass(ref cls, "gap-0 border-none bg-background/90 shadow-none backdrop-blur");

            if (MobileClass.HasContent())
                AppendClass(ref cls, MobileClass!);

            if (MobileStyle.HasContent())
                AppendStyleDecl(ref sty, MobileStyle!);
        });

        return attributes;
    }

    private string? GetMobileContainerClass()
    {
        return IsNavigationShell(Shell) ? ClassNames.Combine("z-40", MobileContainerClass) : MobileContainerClass;
    }

    private string? GetMobileContainerStyle()
    {
        if (!MobileOffsetTop.HasContent())
            return MobileContainerStyle;

        return CombineStyleDecls($"top: {MobileOffsetTop};", MobileContainerStyle);
    }

    private string? GetMobileOverlayStyle()
    {
        if (!MobileOffsetTop.HasContent())
            return MobileOverlayStyle;

        return CombineStyleDecls($"top: {MobileOffsetTop};", MobileOverlayStyle);
    }

    private static string? CombineStyleDecls(string? first, string? second)
    {
        var hasFirst = first.HasContent();
        var hasSecond = second.HasContent();

        if (!hasFirst && !hasSecond)
            return null;

        if (!hasFirst)
            return second;

        if (!hasSecond)
            return first;

        return $"{first} {second}";
    }

    private RenderFragment RenderMobileBody() => builder =>
    {
        if (MobileContent is not null)
        {
            builder.AddContent(0, MobileContent);
            return;
        }

        if (MobileTopContent is not null)
            builder.AddContent(1, MobileTopContent);

        builder.AddContent(2, ChildContent);
    };

    private Dictionary<string, object> BuildGapAttributes()
    {
        var attributes = new Dictionary<string, object>(8)
        {
            ["data-slot"] = "sidebar-gap"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "relative w-(--sidebar-width) bg-transparent transition-[width] duration-200 ease-linear");
            AppendClass(ref cls, "group-data-[collapsible=offcanvas]:w-0");
            AppendClass(ref cls, "group-data-[side=right]:rotate-180");

            if (IsFloatingLikeVariant(Variant))
                AppendClass(ref cls, "group-data-[collapsible=icon]:w-[calc(var(--sidebar-width-icon)+(--spacing(4)))]");
            else
                AppendClass(ref cls, "group-data-[collapsible=icon]:w-(--sidebar-width-icon)");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildContainerAttributes()
    {
        var attributes = new Dictionary<string, object>(10)
        {
            ["data-slot"] = "sidebar-container",
            ["data-side"] = ToDataSide(Side)
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "fixed inset-y-0 z-10 hidden h-svh w-(--sidebar-width) transition-[left,right,width] duration-200 ease-linear data-[side=left]:left-0 data-[side=left]:group-data-[collapsible=offcanvas]:left-[calc(var(--sidebar-width)*-1)] data-[side=right]:right-0 data-[side=right]:group-data-[collapsible=offcanvas]:right-[calc(var(--sidebar-width)*-1)] md:flex");

            if (IsFloatingLikeVariant(Variant))
                AppendClass(ref cls, "p-2 group-data-[collapsible=icon]:w-[calc(var(--sidebar-width-icon)+(--spacing(4))+2px)]");
            else
                AppendClass(ref cls, "group-data-[collapsible=icon]:w-(--sidebar-width-icon) group-data-[side=left]:border-r group-data-[side=right]:border-l");
        });

        return attributes;
    }

    private static Dictionary<string, object> BuildInnerAttributes()
    {
        var attributes = new Dictionary<string, object>(4)
        {
            ["data-slot"] = "sidebar-inner",
            ["data-sidebar"] = "sidebar"
        };

        RenderComponent.BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex size-full flex-col bg-sidebar group-data-[variant=floating]:rounded-lg group-data-[variant=floating]:shadow-sm group-data-[variant=floating]:ring-1 group-data-[variant=floating]:ring-sidebar-border");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildRootAttributes(int capacity)
    {
        var attributes = new Dictionary<string, object>(capacity + (Attributes?.Count ?? 0));
        base.BuildOwnedAttributes(attributes);

        var cls = new PooledStringBuilder(64);
        var sty = new PooledStringBuilder(128);

        try
        {
            base.BuildOwnedClassAndStyle(ref sty, ref cls);

            if (Attributes is not null)
            {
                foreach (var kv in Attributes)
                {
                    if (kv.Key.Equals("class", StringComparison.OrdinalIgnoreCase))
                    {
                        if (kv.Value is not null)
                            AppendClass(ref cls, kv.Value.ToString()!);

                        continue;
                    }

                    if (kv.Key.Equals("style", StringComparison.OrdinalIgnoreCase))
                    {
                        if (kv.Value is not null)
                            AppendStyleDecl(ref sty, kv.Value.ToString()!);

                        continue;
                    }

                    attributes[kv.Key] = kv.Value!;
                }
            }

            if (cls.Length > 0)
                attributes["class"] = ClassNames.Combine(cls.ToString());

            if (sty.Length > 0)
                attributes["style"] = sty.ToString();

            return attributes;
        }
        finally
        {
            cls.Dispose();
            sty.Dispose();
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(Variant);
        hc.Add(Shell);
        hc.Add(Collapsible);
        hc.Add(MobileMode);
        hc.Add(Dir);
        hc.Add(DirectionProviderDir);
        hc.Add(MobileCloseOnBackdropClick);
        hc.Add(MobileShowBackdrop);
        hc.Add(MobileCloseOnEscape);
        hc.Add(MobileLockScroll);
        hc.Add(MobileShowCloseButton);
        hc.Add(MobileTrapFocus);
        hc.Add(MobileClass);
        hc.Add(MobileStyle);
        hc.Add(MobileOffsetTop);
        hc.Add(MobileContainerClass);
        hc.Add(MobileContainerStyle);
        hc.Add(MobileOverlayClass);
        hc.Add(MobileOverlayStyle);
        hc.Add(MobileTopContent is not null);
        hc.Add(MobileContent is not null);
        hc.Add(State?.Open);
        hc.Add(State?.OpenMobile);
        hc.Add(State?.IsMobile);
    }

}
