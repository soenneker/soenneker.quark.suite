@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<input @attributes="BuildAttributes()" />

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "sidebar-input";
        attributes["data-sidebar"] = "input";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-sidebar-input");
            AppendClass(ref cls, "h-8 w-full min-w-0 rounded-md border border-input bg-background px-3 py-1 text-sm shadow-none outline-none");
            AppendClass(ref cls, "placeholder:text-muted-foreground disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-2 focus-visible:ring-ring/50");
        });
    }
}
