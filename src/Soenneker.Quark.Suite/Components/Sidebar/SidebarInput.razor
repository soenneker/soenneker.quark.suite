@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<input @attributes="BuildAttributes()" />

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "sidebar-input";
        attributes["data-sidebar"] = "input";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-sidebar-input");
            AppendClass(ref cls, "h-8 w-full min-w-0 rounded-md border border-input bg-background px-3 py-1 text-base shadow-none transition-[color,box-shadow] outline-none selection:bg-primary selection:text-primary-foreground");
            AppendClass(ref cls, "file:inline-flex file:h-7 file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground");
            AppendClass(ref cls, "placeholder:text-muted-foreground disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-input/30");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
        });
    }
}
