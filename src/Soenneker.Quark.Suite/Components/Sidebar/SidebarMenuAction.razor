@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <button @onclick="HandleClick" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [Parameter]
    public bool ShowOnHover { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private Task HandleClick(MouseEventArgs args)
    {
        return OnClick.HasDelegate ? OnClick.InvokeAsync(args) : Task.CompletedTask;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "sidebar-menu-action";

        Position ??= Quark.Position.Absolute;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Size ??= Quark.Size.Token("5");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is0;
        TextColor ??= Quark.TextColor.Token("sidebar-foreground");
        RingColor ??= Quark.RingColor.Utility("ring-sidebar-ring");
        OutlineStyle ??= Quark.OutlineStyle.Hidden;
        Transition ??= Quark.Transition.Transform;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-sidebar"] = "menu-action";

        if (!AsChild)
            attributes["type"] = "button";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "hover:bg-sidebar-accent hover:text-sidebar-accent-foreground peer-hover/menu-button:text-sidebar-accent-foreground top-1.5 right-1 aspect-square focus-visible:ring-2 [&>svg]:size-4 [&>svg]:shrink-0");
            AppendClass(ref cls, "after:absolute after:-inset-2 md:after:hidden");
            AppendClass(ref cls, "peer-data-[size=sm]/menu-button:top-1 peer-data-[size=default]/menu-button:top-1.5 peer-data-[size=lg]/menu-button:top-2.5");
            AppendClass(ref cls, "group-data-[collapsible=icon]:hidden");

            if (ShowOnHover)
                AppendClass(ref cls, "peer-data-active/menu-button:text-sidebar-accent-foreground group-focus-within/menu-item:opacity-100 group-hover/menu-item:opacity-100 aria-expanded:opacity-100 md:opacity-0");
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ShowOnHover);
        hc.Add(AsChild);
    }
}