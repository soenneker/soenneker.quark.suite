@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<ul @attributes="BuildAttributes()">
    @ChildContent
</ul>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        MinWidth ??= Quark.MinWidth.Is0;
        Flex ??= "flex flex-col";
        Gap ??= Quark.Gap.Is1;
        Margin ??= Quark.Margin.Token("3.5").OnX;
        Border ??= Quark.Border.Default.FromLeft;
        BorderColor ??= Quark.BorderColor.Token("sidebar-border");
        Padding ??= Quark.Padding.Token("2.5").OnX.Token("0.5").OnY;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "sidebar-menu-sub";
        attributes["data-sidebar"] = "menu-sub";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "translate-x-px");
            AppendClass(ref cls, "group-data-[collapsible=icon]:hidden");
        });
    }
}
