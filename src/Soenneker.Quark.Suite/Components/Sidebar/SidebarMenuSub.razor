@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<ul @attributes="BuildAttributes()">
    @ChildContent
</ul>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        MinWidth ??= Quark.MinWidth.Is0;
        Flex ??= "flex flex-col";
        Gap ??= Quark.Gap.Is1;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "sidebar-menu-sub";
        attributes["data-sidebar"] = "menu-sub";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "border-sidebar-border mx-3.5 translate-x-px border-l px-2.5 py-0.5");
            AppendClass(ref cls, "group-data-[collapsible=icon]:hidden");
        });
    }
}
