@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Microsoft.AspNetCore.Components.Routing
@using Soenneker.Quark.Dtos

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else if (ShouldRenderNavLink)
{
    <NavLink href="@To"
             Match="@Match"
             ActiveClass="@_activeClass"
             @onclick="HandleActivate"
             @attributes="BuildAttributes()">
        @ChildContent
    </NavLink>
}
else if (To.HasContent())
{
    <Anchor Href="@To"
            Target="@Target"
            @onclick="HandleActivate"
            @attributes="BuildAttributes()">
        @ChildContent
    </Anchor>
}
else
{
    <button @ref="_elementRef"
            @onclick="HandleActivate"
            @onclick:stopPropagation="StopClickPropagation"
            @onkeydown="HandleKeyDown"
            @attributes="BuildAttributes()">
        @RenderChildContent()
    </button>
}

@code {
    [Parameter]
    public SidebarMenuButtonVariant Variant { get; set; } = SidebarMenuButtonVariant.Default;

    [Parameter]
    public SidebarMenuButtonSize ButtonSize { get; set; } = SidebarMenuButtonSize.Default;

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public string? To { get; set; }

    [Parameter]
    public Target? Target { get; set; }

    [Parameter]
    public string? Tooltip { get; set; }

    [Parameter]
    public NavLinkMatch Match { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [CascadingParameter(Name = "SidebarProvider")]
    public SidebarProvider? SidebarProvider { get; set; }

    [CascadingParameter(Name = "SidebarContextState")]
    public SidebarContextState? State { get; set; }

    [CascadingParameter(Name = "TriggerContext")]
    private TriggerContext? TriggerContext { get; set; }

    private ElementReference _elementRef;
    private bool _triggerElementRegistered;
    private string? _registeredTriggerId;

    private const string _activeClass = "bg-sidebar-accent text-sidebar-accent-foreground font-medium";

    private bool StopClickPropagation => TriggerContext?.Toggle is not null;

    private static readonly TriggerContext? NoChildTriggerContext = null;

    private bool ShowCollapsedTooltip =>
        Tooltip.HasContent() &&
        State?.IsMobile != true &&
        State?.Open == false;

    private bool ShouldRenderNavLink =>
        To.HasContent() &&
        Target is null &&
        !To!.StartsWith('#') &&
        !Uri.TryCreate(To, UriKind.Absolute, out _);

    private static string GetVariantClass(SidebarMenuButtonVariant variant)
    {
        if (ReferenceEquals(variant, SidebarMenuButtonVariant.Outline))
            return "hover:bg-sidebar-accent hover:text-sidebar-accent-foreground hover:shadow-[0_0_0_1px_hsl(var(--sidebar-accent))]";

        if (ReferenceEquals(variant, SidebarMenuButtonVariant.Navigation))
            return "hover:bg-sidebar-accent hover:text-sidebar-accent-foreground after:absolute after:inset-x-0 after:-inset-y-1 after:z-0 after:rounded-md data-[active=true]:border-accent data-[active=true]:bg-accent 3xl:fixed:w-full 3xl:fixed:max-w-48";

        return "hover:bg-sidebar-accent hover:text-sidebar-accent-foreground";
    }

    private static string GetSizeClass(SidebarMenuButtonSize size)
    {
        if (ReferenceEquals(size, SidebarMenuButtonSize.Lg))
            return "group-data-[collapsible=icon]:p-0!";

        return "";
    }

    private static string GetDataSize(SidebarMenuButtonSize size)
    {
        if (ReferenceEquals(size, SidebarMenuButtonSize.Sm))
            return "sm";

        if (ReferenceEquals(size, SidebarMenuButtonSize.Lg))
            return "lg";

        return "default";
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "sidebar-menu-button";

        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is2;
        Width ??= Quark.Width.IsFull;
        Overflow ??= Quark.Overflow.Hidden;
        TextAlign ??= Quark.TextAlign.Token("left");
        RingColor ??= Quark.RingColor.Utility("ring-sidebar-ring");
        OutlineStyle ??= Quark.OutlineStyle.Hidden;
        Transition ??= Quark.Transition.Token("transition-[width,height,padding]");
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;

        if (ReferenceEquals(Variant, SidebarMenuButtonVariant.Outline))
        {
            ApplySizeDefaults();
            BackgroundColor ??= Quark.BackgroundColor.Background;
            Shadow ??= "shadow-[0_0_0_1px_hsl(var(--sidebar-border))]";
        }
        else if (ReferenceEquals(Variant, SidebarMenuButtonVariant.Navigation))
        {
            Position ??= Quark.Position.Relative;
            Height ??= Quark.Height.Token("[30px]");
            Width ??= Quark.Width.IsFit;
            Overflow ??= Quark.Overflow.Visible;
            Border ??= Quark.Border.Default;
            BorderColor ??= Quark.BorderColor.Transparent;
            TextSize ??= Quark.TextSize.Token("[0.8rem]");
            FontWeight ??= Quark.FontWeight.Medium;
        }
        else
        {
            ApplySizeDefaults();
        }
    }

    private void ApplySizeDefaults()
    {
        if (ReferenceEquals(ButtonSize, SidebarMenuButtonSize.Sm))
        {
            Height ??= Quark.Height.Token("7");
            TextSize ??= Quark.TextSize.Xs;
        }
        else if (ReferenceEquals(ButtonSize, SidebarMenuButtonSize.Lg))
        {
            Height ??= Quark.Height.Token("12");
            TextSize ??= Quark.TextSize.Sm;
        }
        else
        {
            Height ??= Quark.Height.Is8;
            TextSize ??= Quark.TextSize.Sm;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var triggerDataState = TriggerContext?.DataState;
        attributes["data-sidebar"] = "menu-button";
        attributes["data-size"] = GetDataSize(ButtonSize);
        attributes["data-state"] = triggerDataState ?? (Open ? "open" : "closed");

        attributes["data-active"] = Active ? "true" : "false";

        if (TriggerContext?.TriggerId is not null && !attributes.ContainsKey("id"))
            attributes["id"] = TriggerContext.TriggerId;

        if (TriggerContext?.AriaHasPopup is not null)
            attributes["aria-haspopup"] = TriggerContext.AriaHasPopup;

        if (TriggerContext?.AriaControls is not null)
        {
            attributes["aria-expanded"] = TriggerContext.IsOpen ? "true" : "false";
            attributes["aria-controls"] = TriggerContext.AriaControls;
        }
        else if (Open)
        {
            attributes["aria-expanded"] = "true";
        }

        if (TriggerContext?.ParentDisabled == true)
            attributes["disabled"] = true;

        if (ShowCollapsedTooltip)
            attributes["title"] = Tooltip!;

        if (!AsChild && !To.HasContent())
            attributes["type"] = "button";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "peer/menu-button group/menu-button group-has-data-[sidebar=menu-action]/menu-item:pr-8 group-data-[collapsible=icon]:size-8! group-data-[collapsible=icon]:p-2! focus-visible:ring-2 active:bg-sidebar-accent active:text-sidebar-accent-foreground aria-disabled:pointer-events-none aria-disabled:opacity-50 data-[state=open]:hover:bg-sidebar-accent data-[state=open]:hover:text-sidebar-accent-foreground data-[active=true]:bg-sidebar-accent data-[active=true]:font-medium data-[active=true]:text-sidebar-accent-foreground [&_svg]:size-4 [&_svg]:shrink-0 [&>span:last-child]:truncate");
            AppendClass(ref cls, GetSizeClass(ButtonSize));
            AppendClass(ref cls, GetVariantClass(Variant));
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    private RenderFragment? RenderChildContent()
    {
        if (TriggerContext is null || ChildContent is null)
            return ChildContent;

        return @<CascadingValue Name="TriggerContext" Value="@NoChildTriggerContext" IsFixed="true">
            @ChildContent
        </CascadingValue>;
    }

    private async Task HandleActivate(MouseEventArgs args)
    {
        if (TriggerContext?.OnClick is not null)
            await TriggerContext.OnClick();

        if (TriggerContext?.Toggle is not null)
            await TriggerContext.Toggle();

        if (To.HasContent() && State?.IsMobile == true && SidebarProvider is not null)
            await SidebarProvider.SetOpenMobile(false);

        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (TriggerContext?.OnKeyDown is not null)
            await TriggerContext.OnKeyDown(args);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (TriggerContext?.RegisterElement is not null &&
            (!_triggerElementRegistered || !string.Equals(_registeredTriggerId, TriggerContext.TriggerId, StringComparison.Ordinal)))
        {
            TriggerContext.RegisterElement(_elementRef);
            _triggerElementRegistered = true;
            _registeredTriggerId = TriggerContext.TriggerId;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(ButtonSize);
        hc.Add(Active);
        hc.Add(Open);
        hc.Add(To);
        hc.Add(Target);
        hc.Add(Tooltip);
        hc.Add(Match);
        hc.Add(AsChild);
        hc.Add(State?.Open);
        hc.Add(State?.IsMobile);
        hc.Add(TriggerContext?.TriggerId);
        hc.Add(TriggerContext?.DataState);
        hc.Add(TriggerContext?.AriaHasPopup);
        hc.Add(TriggerContext?.AriaControls);
        hc.Add(TriggerContext?.IsOpen);
        hc.Add(TriggerContext?.ParentDisabled == true);
    }
}
