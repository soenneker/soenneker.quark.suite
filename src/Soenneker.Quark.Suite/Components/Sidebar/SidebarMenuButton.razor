@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Microsoft.AspNetCore.Components.Routing
@using Soenneker.Quark.Dtos

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else if (ShouldRenderNavLink)
{
    <NavLink href="@To"
             Match="@Match"
             ActiveClass="@_activeClass"
             @onclick="HandleActivate"
             @attributes="BuildAttributes()">
        @ChildContent
    </NavLink>
}
else if (To.HasContent())
{
    <Anchor To="@To"
            Target="@Target"
            @onclick="HandleActivate"
            @attributes="BuildAttributes()">
        @ChildContent
    </Anchor>
}
else
{
    <button @onclick="HandleActivate"
            @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [Parameter]
    public SidebarMenuButtonVariant Variant { get; set; } = SidebarMenuButtonVariant.Default;

    [Parameter]
    public SidebarMenuButtonSize Size { get; set; } = SidebarMenuButtonSize.Default;

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public string? To { get; set; }

    [Parameter]
    public Target? Target { get; set; }

    [Parameter]
    public string? Tooltip { get; set; }

    [Parameter]
    public NavLinkMatch Match { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [CascadingParameter(Name = "SidebarProvider")]
    public SidebarProvider? SidebarProvider { get; set; }

    [CascadingParameter(Name = "SidebarContextState")]
    public SidebarContextState? State { get; set; }

    private const string _activeClass = "bg-sidebar-accent text-sidebar-accent-foreground font-medium";

    private bool ShowCollapsedTooltip =>
        Tooltip.HasContent() &&
        State?.IsMobile != true &&
        State?.Open == false;

    private bool ShouldRenderNavLink =>
        To.HasContent() &&
        Target is null &&
        !To!.StartsWith('#') &&
        !Uri.TryCreate(To, UriKind.Absolute, out _);

    private static string GetVariantClass(SidebarMenuButtonVariant variant)
    {
        return variant?.Value switch
        {
            SidebarMenuButtonVariant.OutlineValue => "bg-background shadow-[0_0_0_1px_hsl(var(--sidebar-border))] hover:bg-sidebar-accent hover:text-sidebar-accent-foreground hover:shadow-[0_0_0_1px_hsl(var(--sidebar-accent))]",
            SidebarMenuButtonVariant.NavigationValue => "relative h-[30px] w-fit overflow-visible border border-transparent text-[0.8rem] font-medium hover:bg-sidebar-accent hover:text-sidebar-accent-foreground after:absolute after:inset-x-0 after:-inset-y-1 after:z-0 after:rounded-md data-[active=true]:border-accent data-[active=true]:bg-accent 3xl:fixed:w-full 3xl:fixed:max-w-48",
            _ => "hover:bg-sidebar-accent hover:text-sidebar-accent-foreground"
        };
    }

    private static string GetSizeClass(SidebarMenuButtonSize size)
    {
        return size?.Value switch
        {
            SidebarMenuButtonSize.SmValue => "h-7 text-xs",
            SidebarMenuButtonSize.LgValue => "h-12 text-sm group-data-[collapsible=icon]:p-0!",
            _ => "h-8 text-sm"
        };
    }

    private static string GetDataSize(SidebarMenuButtonSize size)
    {
        return size?.Value switch
        {
            SidebarMenuButtonSize.SmValue => "sm",
            SidebarMenuButtonSize.LgValue => "lg",
            _ => "default"
        };
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is2;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sidebar-menu-button";
        attributes["data-sidebar"] = "menu-button";
        attributes["data-size"] = GetDataSize(Size);
        attributes["data-active"] = Active ? "true" : "false";
        attributes["data-state"] = Open ? "open" : "closed";

        if (ShowCollapsedTooltip)
            attributes["title"] = Tooltip!;

        if (!AsChild && !To.HasContent())
            attributes["type"] = "button";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "peer/menu-button w-full overflow-hidden text-left ring-sidebar-ring outline-hidden transition-[width,height,padding] group-has-data-[sidebar=menu-action]/menu-item:pr-8 group-data-[collapsible=icon]:size-8! group-data-[collapsible=icon]:p-2! focus-visible:ring-2 active:bg-sidebar-accent active:text-sidebar-accent-foreground disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 data-[active=true]:bg-sidebar-accent data-[active=true]:font-medium data-[active=true]:text-sidebar-accent-foreground data-[state=open]:hover:bg-sidebar-accent data-[state=open]:hover:text-sidebar-accent-foreground [&>span:last-child]:truncate [&>svg]:size-4 [&>svg]:shrink-0");
            AppendClass(ref cls, GetSizeClass(Size));
            AppendClass(ref cls, GetVariantClass(Variant));
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    private async Task HandleActivate(MouseEventArgs args)
    {
        if (To.HasContent() && State?.IsMobile == true && SidebarProvider is not null)
            await SidebarProvider.SetOpenMobile(false);

        await base.HandleClick(args);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(Active);
        hc.Add(Open);
        hc.Add(To);
        hc.Add(Target);
        hc.Add(Tooltip);
        hc.Add(Match);
        hc.Add(AsChild);
        hc.Add(State?.Open);
        hc.Add(State?.IsMobile);
    }
}
