@namespace Soenneker.Quark
@using Soenneker.Quark.Dtos
@inherits Soenneker.Quark.Element

<button @onclick="HandleTriggerClick" @attributes="BuildAttributes()">
    @if (OpenContent is not null || ClosedContent is not null)
    {
        @if (State?.IsMobile == true && State?.OpenMobile == true && OpenContent is not null)
        {
            @OpenContent
        }
        else if (ClosedContent is not null)
        {
            @ClosedContent
        }

        @if (ChildContent is not null)
        {
            @ChildContent
        }
    }
    else if (ChildContent is null)
    {
        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2"></rect>
            <path d="M9 3v18"></path>
        </svg>
        <span class="sr-only">Toggle Sidebar</span>
    }
    else
    {
        @ChildContent
    }
</button>

@code {
    [Parameter]
    public bool Unstyled { get; set; }

    [Parameter]
    public string? UnstyledDataSlot { get; set; }

    [Parameter]
    public string? UnstyledAriaHasPopup { get; set; }

    [Parameter]
    public string? UnstyledAriaControls { get; set; }

    [Parameter]
    public RenderFragment? OpenContent { get; set; }

    [Parameter]
    public RenderFragment? ClosedContent { get; set; }

    [CascadingParameter(Name = "SidebarProvider")]
    public SidebarProvider? SidebarProvider { get; set; }

    [CascadingParameter(Name = "SidebarContextState")]
    public SidebarContextState? State { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        BoxSize ??= Size.Token("7");
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    private async Task HandleTriggerClick(MouseEventArgs args)
    {
        if (SidebarProvider is not null)
            await SidebarProvider.ToggleSidebar();

        await base.HandleClick(args);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (Unstyled)
        {
            attributes["data-slot"] = UnstyledDataSlot ?? "popover-trigger";
            attributes["data-variant"] = "ghost";
            attributes["data-size"] = "default";
        }
        else
        {
            attributes["data-slot"] = "sidebar-trigger";
            attributes["data-sidebar"] = "trigger";
        }

        attributes["type"] = "button";
        var isExpanded = State?.IsMobile == true ? State?.OpenMobile == true : State?.Open == true;
        attributes["aria-expanded"] = isExpanded ? "true" : "false";

        if (Unstyled)
        {
            attributes["data-state"] = isExpanded ? "open" : "closed";

            if (!string.IsNullOrWhiteSpace(UnstyledAriaHasPopup))
                attributes["aria-haspopup"] = UnstyledAriaHasPopup;

            if (!string.IsNullOrWhiteSpace(UnstyledAriaControls))
                attributes["aria-controls"] = UnstyledAriaControls;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (Unstyled)
                return;

            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(State?.IsMobile);
        hc.Add(State?.Open);
        hc.Add(State?.OpenMobile);
        hc.Add(Unstyled);
        hc.Add(UnstyledDataSlot);
        hc.Add(UnstyledAriaHasPopup);
        hc.Add(UnstyledAriaControls);
        hc.Add(OpenContent is not null);
        hc.Add(ClosedContent is not null);
    }
}
