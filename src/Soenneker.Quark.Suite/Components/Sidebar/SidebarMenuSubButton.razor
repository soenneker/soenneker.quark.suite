@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Microsoft.AspNetCore.Components.Routing

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else if (ShouldRenderNavLink)
{
    <NavLink href="@To"
             Match="@Match"
             ActiveClass="@_activeClass"
             @onclick="HandleActivate"
             @attributes="BuildAttributes()">
        @ChildContent
    </NavLink>
}
else
{
    <Anchor To="@To" Target="@Target" @onclick="HandleActivate" @attributes="BuildAttributes()">
        @ChildContent
    </Anchor>
}

@code {
    private const string _activeClass = "bg-sidebar-accent text-sidebar-accent-foreground";

    [Parameter]
    public string? To { get; set; }

    [Parameter]
    public Target? Target { get; set; }

    [Parameter]
    public SidebarMenuSubButtonSize Size { get; set; } = SidebarMenuSubButtonSize.Md;

    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public NavLinkMatch Match { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [CascadingParameter(Name = "SidebarProvider")]
    public SidebarProvider? SidebarProvider { get; set; }

    [CascadingParameter(Name = "SidebarContextState")]
    public SidebarContextState? State { get; set; }

    private bool ShouldRenderNavLink =>
        To.HasContent() &&
        Target is null &&
        !To!.StartsWith('#') &&
        !Uri.TryCreate(To, UriKind.Absolute, out _);

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sidebar-menu-sub-button";
        attributes["data-sidebar"] = "menu-sub-button";
        attributes["data-size"] = Size == SidebarMenuSubButtonSize.Sm ? "sm" : "md";
        attributes["data-active"] = Active ? "true" : "false";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-sidebar-menu-sub-button");
            AppendClass(ref cls, "text-sidebar-foreground ring-sidebar-ring hover:bg-sidebar-accent hover:text-sidebar-accent-foreground active:bg-sidebar-accent active:text-sidebar-accent-foreground [&>svg]:text-sidebar-accent-foreground flex h-7 min-w-0 -translate-x-px items-center gap-2 overflow-hidden rounded-md px-2 outline-hidden focus-visible:ring-2 disabled:pointer-events-none disabled:opacity-50 aria-disabled:pointer-events-none aria-disabled:opacity-50 [&>span:last-child]:truncate [&>svg]:size-4 [&>svg]:shrink-0");
            AppendClass(ref cls, "data-[active=true]:bg-sidebar-accent data-[active=true]:text-sidebar-accent-foreground");
            AppendClass(ref cls, Size == SidebarMenuSubButtonSize.Sm ? "text-xs" : "text-sm");
            AppendClass(ref cls, "group-data-[collapsible=icon]:hidden");
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    private async Task HandleActivate(MouseEventArgs args)
    {
        if (To.HasContent() && State?.IsMobile == true && SidebarProvider is not null)
            await SidebarProvider.SetOpenMobile(false);

        await base.HandleClick(args);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(To);
        hc.Add(Target);
        hc.Add(Size);
        hc.Add(Active);
        hc.Add(Match);
        hc.Add(AsChild);
        hc.Add(State?.IsMobile);
    }
}
