@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INativeSelect
@implements IDisposable

<div class="group/native-select relative w-fit has-[select:disabled]:opacity-50" data-slot="native-select-wrapper" data-size="@(Size == NativeSelectSize.Sm ? "sm" : "default")">
    <select value="@Value" @onchange="HandleChange" @attributes="BuildAttributes()">
        @ChildContent
    </select>
    <svg class="pointer-events-none absolute top-1/2 right-3.5 size-4 -translate-y-1/2 text-muted-foreground opacity-50 select-none"
         aria-hidden="true"
         data-slot="native-select-icon"
         xmlns="http://www.w3.org/2000/svg"
         width="24"
         height="24"
         viewBox="0 0 24 24"
         fill="none"
         stroke="currentColor"
         stroke-width="2"
         stroke-linecap="round"
         stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"></path>
    </svg>
</div>

@code {

    /// <summary>
    /// Gets or sets callback invoked when selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the control size.
    /// </summary>
    [Parameter]
    public NativeSelectSize Size { get; set; } = NativeSelectSize.Default;

    private async Task HandleChange(ChangeEventArgs e)
    {
        var next = e.Value?.ToString();
        if (!string.Equals(Value, next, StringComparison.Ordinal))
        {
            Value = next;
            await ValueChanged.InvokeIfHasDelegate(Value);
            InvalidateRender();
            Refresh();
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Width ??= Quark.Width.IsFull;
        MinWidth ??= Quark.MinWidth.Is0;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Input;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Height ??= Quark.Height.Token("9");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is3.OnX.Is2.OnY.Token("9").FromRight;
        TextSize ??= Quark.TextSize.Sm;
        Shadow ??= Quark.Shadow.Xs;
        Transition ??= Quark.Transition.Token("transition-[color,shadow]");
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "native-select";
        attributes["data-size"] = Size == NativeSelectSize.Sm ? "sm" : "default";
        ApplyFieldControlAttributes(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "appearance-none");
            AppendClass(ref cls, "selection:bg-primary selection:text-primary-foreground placeholder:text-muted-foreground");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:cursor-not-allowed");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "data-[size=sm]:h-8 data-[size=sm]:py-1 dark:bg-input/30 dark:hover:bg-input/50 dark:aria-invalid:ring-destructive/40");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Size);
        hc.Add(Disabled);
        hc.Add(Required);
    }

    public override void Dispose()
    {
        base.Dispose();
    }
}
