@using Soenneker.Blazor.Extensions.EventCallback
@using System.Threading

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INativeSelect

<Div DataSlot="native-select-wrapper" data-size="@GetSizeValue()" dir="@(IsRtl ? "rtl" : null)" Position="Quark.Position.Relative" Width="Quark.Width.IsFit" Class="group/native-select has-[select:disabled]:opacity-50">
    <select value="@Value" @onchange="HandleChange" @attributes="BuildAttributes()">
        @ChildContent
    </select>
    <AutoSaveStatus State="@_autoSave.State"
                    HasSaved="@_autoSave.HasSaved"
                    Visible="@UsesAutoSaveStatusSlot"
                    Class="@GetAutoSaveStatusClass()"
                    SavingClass="@AutoSaveSavingClass"
                    SavedClass="@AutoSaveSavedClass"
                    FailedClass="@AutoSaveFailedClass" />
    <Svg PointerEvents="Quark.PointerEvents.None" Position="Quark.Position.Absolute" Size="Quark.Size.Is4" TextColor="Quark.TextColor.MutedForeground" UserSelect="Quark.UserSelect.None" Class="@GetIconClass()"
         aria-hidden="true"
         data-slot="native-select-icon"
         NativeWidth="24"
         NativeHeight="24"
         ViewBox="0 0 24 24"
         Fill="Quark.Fill.None"
         Stroke="Quark.Stroke.Current"
         StrokeWidth="Quark.StrokeWidth.Is2"
         StrokeLineCap="Quark.StrokeLineCap.Round"
         StrokeLineJoin="Quark.StrokeLineJoin.Round">
        <path d="m6 9 6 6 6-6"></path>
    </Svg>
</Div>

@code {
    private readonly AutoSaveController<string?> _autoSave = new();

    /// <summary>
    /// Gets or sets callback invoked when selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the control size.
    /// </summary>
    [Parameter]
    public NativeSelectSize NativeSelectSize { get; set; } = NativeSelectSize.Default;

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<string?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    private string GetSizeValue() => ReferenceEquals(NativeSelectSize, NativeSelectSize.Sm) ? "sm" : "default";

    private bool IsRtl => string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase);
    private bool UsesAutoSaveStatusSlot => AutoSave && OnAutoSave is not null && ShowAutoSaveStatus;

    private string GetIconClass() => IsRtl
        ? "end-2.5 top-1/2 -translate-y-1/2"
        : "top-1/2 right-2.5 -translate-y-1/2";

    private string GetAutoSaveStatusClass()
    {
        var overlayClass = IsRtl
            ? "absolute end-8 top-1/2 -translate-y-1/2"
            : "absolute right-8 top-1/2 -translate-y-1/2";

        return string.IsNullOrWhiteSpace(AutoSaveStatusClass)
            ? overlayClass
            : $"{overlayClass} {AutoSaveStatusClass}";
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        var next = e.Value?.ToString();
        if (!string.Equals(Value, next, StringComparison.Ordinal))
        {
            Value = next;
            await ValueChanged.InvokeIfHasDelegate(Value);
            await _autoSave.NotifyValueChanged(Value, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
            InvalidateRender();
            Refresh();
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "native-select";

        Width ??= Quark.Width.IsFull;
        MinWidth ??= Quark.MinWidth.Is0;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Input.OnFocusVisible.Ring;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Height ??= Quark.Height.Is8;
        Rounded ??= Quark.Rounded.Lg;
        Padding ??= UsesAutoSaveStatusSlot
            ? IsRtl ? "py-1 ps-2.5 pe-12" : "py-1 pr-12 pl-2.5"
            : IsRtl ? "py-1 ps-2.5 pe-8" : "py-1 pr-8 pl-2.5";
        TextSize ??= Quark.TextSize.Sm;
        Transition ??= Quark.Transition.Colors;
        OutlineStyle ??= Quark.OutlineStyle.None;
        UserSelect ??= Quark.UserSelect.None;
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Cursor ??= Quark.Cursor.NotAllowed.OnDisabled;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        attributes["data-size"] = GetSizeValue();

        if (IsRtl)
            attributes["dir"] = "rtl";

        if (OnBlur.HasDelegate || (AutoSave && AutoSaveOnBlur && OnAutoSave is not null))
            attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleSelectBlur);

        if (OnKeyDown.HasDelegate || (AutoSave && AutoSaveOnEnter && OnAutoSave is not null))
            attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleSelectKeyDown);

        ApplyFieldControlAttributes(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "appearance-none");
            AppendClass(ref cls, "selection:bg-primary selection:text-primary-foreground");
            AppendClass(ref cls, "placeholder:text-muted-foreground");
            AppendClass(ref cls, "focus-visible:ring-3");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "data-[size=sm]:h-7 data-[size=sm]:rounded-[min(var(--radius-md),10px)] data-[size=sm]:py-0.5");
            AppendClass(ref cls, "dark:bg-input/30 dark:hover:bg-input/50 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(NativeSelectSize);
        hc.Add(DirectionProviderDir);
        hc.Add(Disabled);
        hc.Add(Required);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(_autoSave.State);
        hc.Add(_autoSave.HasSaved);
        hc.Add(OnAutoSave is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
    }

    public override async ValueTask DisposeAsync()
    {
        await _autoSave.DisposeAsync();
        await base.DisposeAsync();
    }

    private async Task HandleSelectBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            _autoSave.QueueFlush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleSelectKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await _autoSave.Flush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnKeyDown.InvokeIfHasDelegate(e);
    }
}
