@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements INativeSelectOption

<option @attributes="BuildAttributes()">@ChildContent</option>

@code {
    /// <summary>
    /// Gets or sets the option value.
    /// </summary>

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "native-select-option";
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "bg-[Canvas] text-[CanvasText]"));

        if (!string.IsNullOrWhiteSpace(Value))
            attributes["value"] = Value!;

        if (Disabled)
            attributes["disabled"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
    }
}
