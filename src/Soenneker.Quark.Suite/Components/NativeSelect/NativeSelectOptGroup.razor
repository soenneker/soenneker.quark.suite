@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements INativeSelectOptGroup

<optgroup @attributes="BuildAttributes()">@ChildContent</optgroup>

@code {
    /// <summary>
    /// Gets or sets the group label.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Gets or sets whether this option group is disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "native-select-optgroup";

        if (!string.IsNullOrWhiteSpace(Label))
            attributes["label"] = Label!;

        if (Disabled)
            attributes["disabled"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(Disabled);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        BackgroundColor ??= Quark.BackgroundColor.Token("[Canvas]");
        TextColor ??= Quark.TextColor.Token("[CanvasText]");

    }
}
