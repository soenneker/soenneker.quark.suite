@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @onmouseenter="HandleMouseEnter" @onmouseleave="HandleMouseLeave" @attributes="BuildAttributes()">
    @ChildContent
    @if (ShowArrow)
    {
        <div class="z-[110] size-2.5 translate-y-[calc(-50%_-_2px)] rotate-45 rounded-[2px] bg-foreground fill-foreground" aria-hidden="true"></div>
    }
</div>

@code {
    [CascadingParameter]
    private TooltipContext? Context { get; set; }

    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets side placement: top, right, bottom, or left.
    /// </summary>
    [Parameter]
    public string Side { get; set; } = "top";

    /// <summary>
    /// Gets or sets whether hover/focus should auto-open the tooltip.
    /// </summary>
    [Parameter]
    public bool DisableAutoOpen { get; set; }

    /// <summary>
    /// Gets or sets whether the decorative arrow is shown.
    /// </summary>
    [Parameter]
    public bool ShowArrow { get; set; } = true;

    /// <summary>
    /// Gets or sets offset from the trigger in pixels.
    /// </summary>
    [Parameter]
    public int SideOffset { get; set; }

    private bool IsOpen => Context?.IsOpen ?? Open;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tooltip-content";
        attributes["data-state"] = IsOpen ? "open" : "closed";
        attributes["data-side"] = Side;
        attributes["role"] = "tooltip";
        attributes["aria-hidden"] = IsOpen ? "false" : "true";

        if (Context is not null)
            attributes["id"] = Context.ContentId;

        var offset = SideOffset >= 0 ? SideOffset : 0;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-tooltip-content");
            AppendClass(ref cls, "z-[110] w-fit origin-(--radix-tooltip-content-transform-origin) rounded-md bg-foreground px-3 py-1.5 text-xs text-balance text-background data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2 data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
            AppendClass(ref cls, "absolute");
            AppendClass(ref cls, "data-[side=top]:bottom-full data-[side=top]:left-1/2 data-[side=top]:-translate-x-1/2");
            AppendClass(ref cls, "data-[side=bottom]:top-full data-[side=bottom]:left-1/2 data-[side=bottom]:-translate-x-1/2");
            AppendClass(ref cls, "data-[side=left]:right-full data-[side=left]:top-1/2 data-[side=left]:-translate-y-1/2");
            AppendClass(ref cls, "data-[side=right]:left-full data-[side=right]:top-1/2 data-[side=right]:-translate-y-1/2");
            AppendClass(ref cls, "data-[state=closed]:hidden data-[state=open]:block");

            if (Context is null && !DisableAutoOpen)
                AppendClass(ref cls, "group-hover/tooltip:block group-focus-within/tooltip:block");
        });

        var offsetStyle = Side switch
        {
            "bottom" => $"margin-top: {offset}px;",
            "left" => $"margin-inline-end: {offset}px;",
            "right" => $"margin-inline-start: {offset}px;",
            _ => $"margin-bottom: {offset}px;"
        };

        BuildStyleAttribute(attributes, (ref sty) => AppendStyleDecl(ref sty, offsetStyle));
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(IsOpen);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(DisableAutoOpen);
        hc.Add(ShowArrow);
    }

    private Task HandleMouseEnter(MouseEventArgs e)
    {
        return Context?.OpenImmediate() ?? Task.CompletedTask;
    }

    private Task HandleMouseLeave(MouseEventArgs e)
    {
        return Context?.Close() ?? Task.CompletedTask;
    }
}
