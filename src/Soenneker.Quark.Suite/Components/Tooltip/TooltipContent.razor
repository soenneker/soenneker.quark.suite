@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixTooltipPortal ForceMount="@ForceMount">
    <BradixTooltipContent ForceMount="@ForceMount"
                          Side="@Side"
                          Align="@Align"
                          SideOffset="@SideOffset"
                          AlignOffset="@AlignOffset"
                          ArrowPadding="@ArrowPadding"
                          AvoidCollisions="@AvoidCollisions"
                          CollisionPadding="@CollisionPadding"
                          CollisionBoundarySelector="@CollisionBoundarySelector"
                          CollisionBoundarySelectors="@CollisionBoundarySelectors"
                          Sticky="@Sticky"
                          HideWhenDetached="@HideWhenDetached"
                          AdditionalAttributes="@ContentAttributes">
        @ChildContent
        @if (ShowArrow)
        {
            <BradixTooltipArrow Width="10" Height="10" Class="z-50 size-2.5 translate-y-[calc(-50%_-_2px)] rotate-45 rounded-[2px] bg-foreground fill-foreground" />
        }
    </BradixTooltipContent>
</BradixTooltipPortal>

@code {
    [CascadingParameter]
    private BradixTooltip? Tooltip { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    /// <summary>
    /// Gets or sets side placement: top, right, bottom, or left.
    /// </summary>
    [Parameter]
    public Side Side { get; set; } = Side.Top;

    /// <summary>
    /// Gets or sets alignment along the placement axis: start, center, or end.
    /// </summary>
    [Parameter]
    public Alignment Align { get; set; } = Alignment.Center;

    /// <summary>
    /// Gets or sets whether hover/focus should auto-open the tooltip.
    /// </summary>
    [Parameter]
    public bool DisableAutoOpen { get; set; }

    /// <summary>
    /// Gets or sets whether the decorative arrow is shown.
    /// </summary>
    [Parameter]
    public bool ShowArrow { get; set; } = true;

    /// <summary>
    /// Gets or sets offset from the trigger in pixels.
    /// </summary>
    [Parameter]
    public int SideOffset { get; set; }

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        ZIndex ??= "z-50";
        Width ??= Quark.Width.IsFit;
        Rounded ??= Quark.Rounded.Md;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-foreground");
        Padding ??= Quark.Padding.Token("3").OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Xs;
        TextColor ??= Quark.TextColor.Utility("text-background");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tooltip-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "origin-(--radix-tooltip-content-transform-origin) animate-in text-balance fade-in-0 zoom-in-95");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Tooltip?.CurrentOpen ?? Open);
        hc.Add(ForceMount);
        hc.Add(Side);
        hc.Add(Align);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (var selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
        hc.Add(DisableAutoOpen);
        hc.Add(ShowArrow);
    }

}
