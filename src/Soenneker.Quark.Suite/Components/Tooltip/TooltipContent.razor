@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixTooltipPortal>
    <BradixTooltipContent Side="@ResolvedSide"
                          SideOffset="@SideOffset"
                          AdditionalAttributes="@ContentAttributes">
        @ChildContent
        @if (ShowArrow)
        {
            <BradixTooltipArrow Class="z-50 size-2.5 translate-y-[calc(-50%_-_2px)] rotate-45 rounded-[2px] bg-foreground fill-foreground" />
        }
    </BradixTooltipContent>
</BradixTooltipPortal>

@code {
    [CascadingParameter]
    private BradixTooltip? Tooltip { get; set; }

    [Parameter]
    public bool Open { get; set; }

    /// <summary>
    /// Gets or sets side placement: top, right, bottom, or left.
    /// </summary>
    [Parameter]
    public string Side { get; set; } = "top";

    /// <summary>
    /// Gets or sets whether hover/focus should auto-open the tooltip.
    /// </summary>
    [Parameter]
    public bool DisableAutoOpen { get; set; }

    /// <summary>
    /// Gets or sets whether the decorative arrow is shown.
    /// </summary>
    [Parameter]
    public bool ShowArrow { get; set; } = true;

    /// <summary>
    /// Gets or sets offset from the trigger in pixels.
    /// </summary>
    [Parameter]
    public int SideOffset { get; set; }

    private bool IsOpen => Tooltip?.CurrentOpen ?? Open;
    private BradixSide ResolvedSide => Side switch
    {
        "bottom" => BradixSide.Bottom,
        "left" => BradixSide.Left,
        "right" => BradixSide.Right,
        _ => BradixSide.Top
    };
    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("id");
        attributes.Remove("role");
        attributes.Remove("aria-hidden");
        attributes.Remove("data-state");
        attributes.Remove("data-side");
        attributes.Remove("onmouseenter");
        attributes.Remove("onmouseleave");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        Width ??= Quark.Width.IsFit;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Token("1.5");
        Rounded ??= Quark.Rounded.Md;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-foreground");
        Padding ??= Quark.Padding.Token("3").OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Xs;
        TextColor ??= Quark.TextColor.Utility("text-background");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tooltip-content";
        attributes["data-state"] = IsOpen ? "open" : "closed";
        attributes["data-side"] = Side;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "z-[80] max-w-xs origin-(--radix-tooltip-content-transform-origin) has-data-[slot=kbd]:pr-1.5");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "**:data-[slot=kbd]:relative **:data-[slot=kbd]:isolate **:data-[slot=kbd]:z-50 **:data-[slot=kbd]:rounded-sm");
            AppendClass(ref cls, "data-[state=delayed-open]:animate-in data-[state=delayed-open]:fade-in-0 data-[state=delayed-open]:zoom-in-95");
            AppendClass(ref cls, "data-open:animate-in data-open:fade-in-0 data-open:zoom-in-95");
            AppendClass(ref cls, "data-closed:animate-out data-closed:fade-out-0 data-closed:zoom-out-95");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(IsOpen);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(DisableAutoOpen);
        hc.Add(ShowArrow);
    }

}
