@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Microsoft.JSInterop

@inject IOverlayInterop OverlayInterop

<CascadingValue Name="TooltipProvider" Value="@this" IsFixed="true">
    @ChildContent
</CascadingValue>

@code {
    private readonly List<Tooltip> _openTooltips = [];
    private DotNetObjectReference<TooltipProvider>? _escapeRef;

    /// <summary>
    /// Gets or sets the delay in milliseconds before showing the tooltip.
    /// </summary>
    [Parameter]
    public int DelayDuration { get; set; }

    /// <summary>
    /// Clears the open-tooltip list before each <see cref="Tooltip"/> with <c>_open</c> re-registers in tree order.
    /// </summary>
    protected override void OnParametersSet()
    {
        _openTooltips.Clear();
        base.OnParametersSet();
    }

    internal void RegisterOpenTooltip(Tooltip tooltip)
    {
        if (_openTooltips.Contains(tooltip))
            return;

        _openTooltips.Add(tooltip);
    }

    [JSInvokable]
    public async Task OnTooltipDocumentEscape()
    {
        var copy = _openTooltips.ToArray();
        foreach (var tooltip in copy)
            await tooltip.DismissFromDocumentEscapeAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        _escapeRef = DotNetObjectReference.Create(this);
        await OverlayInterop.RegisterTooltipEscapeAsync(_escapeRef);
    }

    protected override async Task OnDisposeAsync()
    {
        await OverlayInterop.UnregisterTooltipEscapeAsync();
        _escapeRef?.Dispose();
        _escapeRef = null;
        await base.OnDisposeAsync();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(DelayDuration);
        hc.Add(_openTooltips.Count);
    }
}
