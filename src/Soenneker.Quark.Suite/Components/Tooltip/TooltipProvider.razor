@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixTooltipProvider DelayDuration="@DelayDuration"
                      DisableHoverableContent="@DisableHoverableContent">
    @ChildContent
</BradixTooltipProvider>

@code {
    /// <summary>
    /// Gets or sets the delay in milliseconds before showing the tooltip.
    /// </summary>
    [Parameter]
    public int DelayDuration { get; set; }

    /// <summary>
    /// shadcn tooltips are typically terse/non-interactive, so closing on pointer leave is the safer default.
    /// </summary>
    [Parameter]
    public bool DisableHoverableContent { get; set; } = true;

}
