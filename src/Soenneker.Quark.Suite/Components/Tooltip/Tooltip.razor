@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixTooltip Open="@(OpenChanged.HasDelegate ? Open : (bool?)null)"
               DefaultOpen="@DefaultOpen"
               OpenChanged="@OpenChanged"
               DelayDuration="@DelayDuration">
    @ChildContent
</BradixTooltip>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "tooltip";
    }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public int? DelayDuration { get; set; }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(DefaultOpen);
        hc.Add(DelayDuration);
    }
}