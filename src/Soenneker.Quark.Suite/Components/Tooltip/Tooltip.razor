@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixTooltip Open="@(OpenChanged.HasDelegate ? Open : (bool?)null)"
               DefaultOpen="@DefaultOpen"
               OpenChanged="@OpenChanged"
               DelayDuration="@DelayDuration"
               AdditionalAttributes="@RootAttributes">
    @ChildContent
</BradixTooltip>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public int? DelayDuration { get; set; }
    private IReadOnlyDictionary<string, object> RootAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tooltip";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/tooltip");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(DefaultOpen);
        hc.Add(DelayDuration);
    }
}
