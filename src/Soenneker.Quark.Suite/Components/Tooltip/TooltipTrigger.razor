@using Soenneker.Bradix
@using Microsoft.JSInterop

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@inject IBradixSuiteInterop Interop

@if (AsChild)
{
    <BradixPopperAnchor>
        <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
            @ChildContent
        </CascadingValue>
    </BradixPopperAnchor>
}
else
{
    <BradixTooltipTrigger AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixTooltipTrigger>
}

@code {
    private bool _hasPointerMoveOpened;
    private bool _pointerDown;
    private ElementReference _triggerElement;
    private DotNetObjectReference<TooltipTrigger>? _dotNetReference;
    private bool _triggerRegistered;

    [CascadingParameter]
    private BradixTooltip? Tooltip { get; set; }

    [CascadingParameter(Name = "TriggerContext")]
    private TriggerContext? ParentTriggerContext { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        MaxWidth ??= Quark.MaxWidth.IsFull;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        await EnsureTriggerRegisteredAsync();
    }

    public override async ValueTask DisposeAsync()
    {
        if (_triggerRegistered)
            await Interop.UnregisterTooltipTrigger(_triggerElement);

        _dotNetReference?.Dispose();

        await base.DisposeAsync();
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("type");
        attributes.Remove("data-state");
        attributes.Remove("id");
        attributes.Remove("aria-describedby");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("onpointermove");
        attributes.Remove("onpointerleave");
        attributes.Remove("onpointerdown");
        attributes.Remove("onpointerup");
        attributes.Remove("onmouseenter");
        attributes.Remove("onmousemove");
        attributes.Remove("onmouseleave");
        attributes.Remove("onfocusin");
        attributes.Remove("onfocusout");
        attributes.Remove("onclick");
        attributes.Remove("onkeydown");
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tooltip-trigger";

        if (ParentTriggerContext?.TriggerId is not null)
            attributes["id"] = ParentTriggerContext.TriggerId;

        var describedBy = BuildAriaDescribedBy();
        if (describedBy is not null)
            attributes["aria-describedby"] = describedBy;

        if (ParentTriggerContext?.AriaHasPopup is not null)
            attributes["aria-haspopup"] = ParentTriggerContext.AriaHasPopup;

        if (ParentTriggerContext?.AriaControls is not null)
        {
            attributes["aria-expanded"] = ParentTriggerContext.IsOpen ? "true" : "false";
            attributes["aria-controls"] = ParentTriggerContext.AriaControls;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "transition-[color,box-shadow]");
            AppendClass(ref cls, "focus-visible:ring-ring/50 outline-none focus-visible:ring-[3px]");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
        });
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = ParentTriggerContext?.TriggerId,
            IsOpen = ParentTriggerContext?.AriaControls is not null ? ParentTriggerContext.IsOpen : Tooltip?.CurrentOpen == true,
            DataState = ParentTriggerContext?.AriaControls is not null
                ? ParentTriggerContext.IsOpen ? "open" : "closed"
                : Tooltip?.StateAttribute ?? "closed",
            AriaHasPopup = ParentTriggerContext?.AriaHasPopup,
            AriaControls = ParentTriggerContext?.AriaControls,
            AriaDescribedBy = BuildAriaDescribedBy(),
            Toggle = ParentTriggerContext?.Toggle,
            OnClick = HandleTriggerClick,
            OnPointerMove = HandleTriggerPointerMove,
            OnPointerLeave = HandleTriggerPointerLeave,
            OnPointerDown = HandleTriggerPointerDown,
            OnPointerUp = HandleTriggerPointerUp,
            Open = Tooltip is null ? null : () => Tooltip.HandleTriggerEnter(),
            Close = Tooltip is null ? null : () => Tooltip.Close(),
            OnMouseEnter = HandleTriggerMouseEnter,
            OnMouseMove = HandleTriggerMouseMove,
            OnMouseLeave = HandleTriggerMouseLeave,
            OnFocusIn = HandleTriggerFocusIn,
            OnFocusOut = Tooltip is null ? null : () => Tooltip.HandleTriggerBlur(),
            OnKeyDown = Tooltip is null ? null : e => HandleTriggerKeyDownCore(e, Tooltip),
            RegisterElement = Tooltip is null
                ? null
                : elementReference => _ = InvokeAsync(() => HandleTriggerElementRegisteredAsync(elementReference))
        };
    }

    private async Task HandleTriggerElementRegisteredAsync(ElementReference elementReference)
    {
        _triggerElement = elementReference;
        Tooltip?.RegisterTrigger(elementReference);
        await EnsureTriggerRegisteredAsync();
    }

    private async Task EnsureTriggerRegisteredAsync()
    {
        if (_triggerRegistered || Tooltip is null || _triggerElement.Context is null)
            return;

        _dotNetReference ??= DotNetObjectReference.Create(this);
        await Interop.RegisterTooltipTrigger(_triggerElement, _dotNetReference);
        _triggerRegistered = true;
    }

    private string? BuildAriaDescribedBy()
    {
        var tooltipId = Tooltip?.CurrentOpen == true ? Tooltip.ContentId : null;
        var parentDescribedBy = ParentTriggerContext?.AriaDescribedBy;

        if (parentDescribedBy is null)
            return tooltipId;

        if (tooltipId is null)
            return parentDescribedBy;

        return $"{parentDescribedBy} {tooltipId}";
    }

    protected override Task HandleClick(MouseEventArgs e)
    {
        return HandleTriggerClickCore(Tooltip, ParentTriggerContext);
    }

    private Task HandleKeyDown(KeyboardEventArgs e)
    {
        return Tooltip is null ? Task.CompletedTask : HandleTriggerKeyDownCore(e, Tooltip);
    }

    private Task HandleTriggerPointerMove()
    {
        if (Tooltip is null || _hasPointerMoveOpened || ShouldBlockOpenFromPointerTransit())
            return Task.CompletedTask;

        _hasPointerMoveOpened = true;
        return Tooltip.HandleTriggerEnter();
    }

    private Task HandleTriggerMouseEnter()
    {
        return HandleTriggerMouseMove();
    }

    private Task HandleTriggerMouseMove()
    {
        if (Tooltip is null || _hasPointerMoveOpened || ShouldBlockOpenFromPointerTransit())
            return Task.CompletedTask;

        _hasPointerMoveOpened = true;
        return Tooltip.HandleTriggerEnter();
    }

    private bool ShouldBlockOpenFromPointerTransit()
    {
        return Tooltip is not null &&
               !Tooltip.EffectiveDisableHoverableContent &&
               Tooltip.ShouldBlockTriggerHoverOpen;
    }

    private Task HandleTriggerMouseLeave()
    {
        _hasPointerMoveOpened = false;

        return Tooltip?.HandleTriggerLeave() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerLeave()
    {
        _hasPointerMoveOpened = false;

        return Tooltip?.HandleTriggerLeave() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerDown()
    {
        _pointerDown = true;

        return Tooltip?.Close() ?? Task.CompletedTask;
    }

    private Task HandleTriggerPointerUp()
    {
        _pointerDown = false;
        return Task.CompletedTask;
    }

    private Task HandleTriggerFocusIn()
    {
        return Tooltip is null
            ? Task.CompletedTask
            : Tooltip.HandleTriggerFocus(_pointerDown);
    }

    private static Task HandleTriggerKeyDownCore(KeyboardEventArgs e, BradixTooltip tooltip)
    {
        if ((e.Key == "Escape" || e.Key == "Enter" || e.Key == " ") && tooltip.CurrentOpen)
            return tooltip.Close();

        return Task.CompletedTask;
    }

    private static async Task HandleTriggerClickCore(BradixTooltip? tooltip, TriggerContext? parentTriggerContext)
    {
        if (tooltip is not null)
            await tooltip.Close();

        if (parentTriggerContext?.Toggle is not null)
            await parentTriggerContext.Toggle();
    }

    private Task HandleTriggerClick()
    {
        _pointerDown = false;
        return Tooltip?.HandleTriggerClick() ?? Task.CompletedTask;
    }

    [JSInvokable]
    public Task HandleDocumentPointerUp()
    {
        _pointerDown = false;
        return Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Tooltip);
        hc.Add(Tooltip?.CurrentOpen);
        hc.Add(Tooltip?.ContentId);
        hc.Add(AsChild);
        hc.Add(ParentTriggerContext?.TriggerId);
        hc.Add(ParentTriggerContext?.AriaHasPopup);
        hc.Add(ParentTriggerContext?.AriaControls);
        hc.Add(ParentTriggerContext?.AriaDescribedBy);
        hc.Add(ParentTriggerContext?.IsOpen);
    }
}
