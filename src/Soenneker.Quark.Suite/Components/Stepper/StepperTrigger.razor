@namespace Soenneker.Quark
@using Microsoft.AspNetCore.Components.Web
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <span @attributes="BuildAttributes()">
        @ChildContent
    </span>
}
else
{
    <button @ref="_button" @onclick="HandleClick" @onkeydown="HandleKeyDown" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    private ElementReference _button;

    [CascadingParameter(Name = nameof(ParentStepper))]
    internal Stepper? ParentStepper { get; set; }

    [CascadingParameter(Name = nameof(ParentStepperItem))]
    internal StepperItemContext? ParentStepperItem { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private int Step => ParentStepperItem?.Step ?? 0;
    private string StepValue => ParentStepperItem?.Value ?? Step.ToString();
    private bool Selected => ParentStepper?.IsStepActive(Step, StepValue) == true;

    protected override void OnAfterRender(bool firstRender)
    {
        if (!AsChild && Step > 0)
            ParentStepper?.RegisterTrigger(Step, _button);

        base.OnAfterRender(firstRender);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "stepper-trigger";
        Display ??= ParentStepperItem?.IsStacked == true ? Quark.Display.Flex : Quark.Display.InlineFlex;
        Cursor ??= Quark.Cursor.Pointer;
        ItemsAlign ??= Quark.Items.Center;
        OutlineStyle ??= Quark.OutlineStyle.None;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is60.OnDisabled;
        Rounded ??= Quark.Rounded.Full;
        Gap ??= Quark.Gap.Is2_5;

        if (ParentStepperItem?.IsStacked == true)
            FlexDirection ??= Quark.FlexDirection.Col;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (AsChild)
        {
            attributes["data-state"] = ParentStepperItem?.State ?? "inactive";

            if (ParentStepperItem?.Loading == true)
                attributes["data-loading"] = "true";

            return;
        }

        attributes["type"] = "button";
        attributes["role"] = "tab";
        attributes["id"] = $"stepper-tab-{StepValue}";
        attributes["aria-selected"] = Selected ? "true" : "false";
        attributes["aria-controls"] = $"stepper-panel-{StepValue}";
        attributes["tabindex"] = Selected ? 0 : -1;
        attributes["data-state"] = ParentStepperItem?.State ?? "inactive";
        attributes["data-loading"] = ParentStepperItem?.Loading == true ? "true" : "false";

        if (ParentStepperItem?.Disabled == true)
            attributes["disabled"] = true;

    }

    private async Task HandleClick(MouseEventArgs args)
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(args);

        if (ParentStepper is not null && Step > 0)
            await ParentStepper.SetActiveStep(Step, StepValue);
    }

    private Task HandleKeyDown(KeyboardEventArgs args)
    {
        return ParentStepper is not null && Step > 0
            ? ParentStepper.HandleTriggerKeyDown(Step, args)
            : Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Step);
        hc.Add(StepValue);
        hc.Add(Selected);
        hc.Add(ParentStepperItem);
        hc.Add(AsChild);
    }
}
