@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentStepperItem" Value="ItemContext" IsFixed="false">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [CascadingParameter(Name = nameof(ParentStepper))]
    internal Stepper? ParentStepper { get; set; }

    [Parameter]
    [EditorRequired]
    public int Step { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool Completed { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public StepperItemVariant Variant { get; set; } = StepperItemVariant.Default;

    internal string ResolvedValue => ParentStepper?.GetStepValue(Step, Value) ?? Step.ToString();

    internal string State => ParentStepper?.GetStepState(Step, ResolvedValue, Completed) ?? "inactive";

    private bool IsLoading => Loading && ParentStepper?.IsStepActive(Step, ResolvedValue) == true;

    private bool IsResponsive => ParentStepper?.Responsive == true;

    private StepperItemContext ItemContext => new(Step, ResolvedValue, State, Disabled, IsLoading, ParentStepper?.ResolvedOrientation ?? "horizontal", Variant, IsResponsive);

    protected override void OnInitialized()
    {
        ParentStepper?.RegisterStep(Step, Disabled, Value);
        base.OnInitialized();
    }

    protected override void OnParametersSet()
    {
        ParentStepper?.RegisterStep(Step, Disabled, Value);
        base.OnParametersSet();
    }

    public override async ValueTask DisposeAsync()
    {
        ParentStepper?.UnregisterStep(Step);
        await base.DisposeAsync();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "stepper-item";
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;

        if (IsResponsive)
        {
            ItemsAlign ??= Quark.Items.Start;
            FlexDirection ??= Quark.FlexDirection.Col.OnMd.Row;
            Width ??= Quark.Width.IsFull.OnMd.Auto;
        }
        else
        {
            FlexDirection ??= ParentStepper?.ResolvedOrientation == "vertical" ? Quark.FlexDirection.Col : Quark.FlexDirection.Row;
        }

        if (ReferenceEquals(Variant, StepperItemVariant.Stacked))
        {
            Position ??= Quark.Position.Relative;
            Flex ??= Quark.Flex.Is1;
        }
        else if (IsResponsive)
        {
            Flex ??= Quark.Flex.None.OnMd.Custom("not-last").Is1;
        }
        else
        {
            Flex ??= Soenneker.Quark.Variant.Of(Quark.Flex.Is1).Custom("not-last");
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-state"] = State;

        if (IsLoading)
            attributes["data-loading"] = "true";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Step);
        hc.Add(Value);
        hc.Add(Completed);
        hc.Add(Disabled);
        hc.Add(Loading);
        hc.Add(Variant);
        hc.Add(ParentStepper?.ActiveStep);
    }
}
