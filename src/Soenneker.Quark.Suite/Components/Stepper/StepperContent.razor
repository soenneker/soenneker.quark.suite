@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (ForceMount || IsActive)
{
    <div @attributes="BuildAttributes()">@ChildContent</div>
}

@code {
    [CascadingParameter(Name = nameof(ParentStepper))]
    internal Stepper? ParentStepper { get; set; }

    [Parameter]
    [EditorRequired]
    public int Value { get; set; }

    [Parameter]
    public string? ValueKey { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    private string ResolvedValue => ParentStepper?.GetStepValue(Value, ValueKey) ?? Value.ToString();

    private bool IsActive => ParentStepper?.IsStepActive(Value, ResolvedValue) == true;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "stepper-content";
        Width ??= Quark.Width.IsFull;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["role"] = "tabpanel";
        attributes["id"] = $"stepper-panel-{ResolvedValue}";
        attributes["aria-labelledby"] = $"stepper-tab-{ResolvedValue}";
        attributes["data-state"] = ParentStepper?.ActiveValue ?? "1";

        if (!IsActive && ForceMount)
            attributes["hidden"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(ValueKey);
        hc.Add(ForceMount);
        hc.Add(ParentStepper?.ActiveValue);
    }
}
