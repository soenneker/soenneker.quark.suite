@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (ForceMount || IsActive)
{
    <div @attributes="BuildAttributes()">@ChildContent</div>
}

@code {
    [CascadingParameter(Name = nameof(ParentStepper))]
    internal Stepper? ParentStepper { get; set; }

    [Parameter]
    [EditorRequired]
    public int Value { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    private bool IsActive => Value == (ParentStepper?.ActiveStep ?? 1);

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "stepper-content";
        Width ??= Quark.Width.IsFull;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["role"] = "tabpanel";
        attributes["id"] = $"stepper-panel-{Value}";
        attributes["aria-labelledby"] = $"stepper-tab-{Value}";
        attributes["data-state"] = ParentStepper?.ActiveStep ?? 1;

        if (!IsActive && ForceMount)
            attributes["hidden"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "w-full");
            if (!IsActive && ForceMount)
                AppendClass(ref cls, "hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(ForceMount);
        hc.Add(ParentStepper?.ActiveStep);
    }
}
