@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<h3 @attributes="BuildAttributes()">@ChildContent</h3>

@code {
    [CascadingParameter(Name = nameof(ParentStepperItem))]
    internal StepperItemContext? ParentStepperItem { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "stepper-title";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-state"] = ParentStepperItem?.State ?? "inactive";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "style-vega:text-sm style-maia:text-sm style-nova:text-sm style-lyra:text-xs style-mira:text-xs leading-none font-medium");
        });
    }
}
