@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@inherits Soenneker.Quark.FormControlElement
@implements IAsyncDisposable

<CascadingValue Name="ParentCombobox" Value="@this">
    <Popover Open="@Open"
             OpenChanged="HandlePopoverOpenChanged">
        <div @attributes="BuildAttributes()">
            @ChildContent
        </div>
    </Popover>
</CascadingValue>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "combobox";
        Position ??= Quark.Position.Relative;
    }

    private readonly string _comboboxId = BlazorIdGenerator.New("quark-combobox");
    private readonly List<ComboboxItem> _items = [];
    private ElementReference _triggerElement;
    private bool _hasTriggerElement;
    private bool _triggerReservesInlineEndAction;

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public bool Multiple { get; set; }

    [Parameter]
    public string[]? Values { get; set; }

    [Parameter]
    public EventCallback<string[]> ValueChangedMultiple { get; set; }

    [Parameter]
    public string? Search { get; set; }

    [Parameter]
    public EventCallback<string?> SearchChanged { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool AutoHighlight { get; set; }

    [Parameter]
    public bool ShowClear { get; set; }

    internal string InputId => BlazorIdGenerator.Child(_comboboxId, "input");

    internal string ContentId => BlazorIdGenerator.Child(_comboboxId, "listbox");

    internal string? ActiveItemId => GetActiveItemId();

    internal bool HasVisibleItems => HasAnyVisibleItem();

    internal bool HasTriggerElement => _hasTriggerElement;

    internal ElementReference TriggerElement => _triggerElement;

    internal bool TriggerReservesInlineEndAction => _triggerReservesInlineEndAction;

    internal bool HasClearValue => Multiple
        ? Values?.Length > 0 || !Search.IsNullOrEmpty()
        : !Value.IsNullOrEmpty() || !Search.IsNullOrEmpty();

    internal IReadOnlyList<string> SelectedValues => Values ?? [];

    private async Task HandlePopoverOpenChanged(bool open)
    {
        Open = open;
        var searchChanged = false;
        if (Open)
        {
            searchChanged = ClearSelectedSearchForSingle();
            EnsureActiveItem();
        }
        else
        {
            SetActiveValue(null);
        }

        if (searchChanged)
            await SearchChanged.InvokeAsync(Search);

        await OpenChanged.InvokeAsync(open);
        InvalidateRender();
        Refresh();
    }

    internal void SetTriggerElement(ElementReference elementReference, bool reservesInlineEndAction = false)
    {
        _triggerElement = elementReference;
        _hasTriggerElement = true;
        _triggerReservesInlineEndAction = reservesInlineEndAction;
    }

    internal async Task Select(string? v)
    {
        if (Multiple)
        {
            await ToggleValue(v);
            return;
        }

        Value = v;
        Search = "";
        Open = false;
        SetActiveValue(v);
        await ValueChanged.InvokeAsync(v);
        await SearchChanged.InvokeAsync(Search);
        await OpenChanged.InvokeAsync(false);
        InvalidateRender();
        Refresh();
    }

    internal bool IsSelected(string? value)
    {
        if (value.IsNullOrEmpty())
            return false;

        if (Multiple)
            return IndexOfSelectedValue(value) >= 0;

        return string.Equals(Value, value, StringComparison.Ordinal);
    }

    internal async Task SetOpen(bool open)
    {
        Open = open;
        var searchChanged = false;
        if (open)
        {
            searchChanged = ClearSelectedSearchForSingle();
            EnsureActiveItem();
        }
        else
        {
            SetActiveValue(null);
        }

        await OpenChanged.InvokeAsync(open);
        if (searchChanged)
            await SearchChanged.InvokeAsync(Search);

        InvalidateRender();
        Refresh();
    }

    internal async Task SetSearch(string? s)
    {
        Search = s ?? "";
        await SearchChanged.InvokeAsync(Search);
        EnsureActiveItem();
        InvalidateRender();
        Refresh();
    }

    internal void RegisterItem(ComboboxItem item)
    {
        if (!_items.Contains(item))
        {
            _items.Add(item);
            EnsureActiveItem();
            InvalidateRender();
            Refresh();
        }
    }

    internal void UnregisterItem(ComboboxItem item)
    {
        if (!_items.Remove(item))
            return;

        if (item.IsActiveItem)
            EnsureActiveItem();

        InvalidateRender();
        Refresh();
    }

    internal void SetActiveItem(ComboboxItem item)
    {
        if (!item.Disabled && !item.Hidden)
        {
            SetActiveValue(item.Value);
            Refresh();
        }
    }

    internal async Task HandleInputKeyDown(string key)
    {
        switch (key)
        {
            case "ArrowDown":
            case "ArrowUp":
            case "Home":
            case "End":
                if (!Open)
                    Open = true;

                MoveActiveItem(key);
                await OpenChanged.InvokeAsync(Open);
                InvalidateRender();
                Refresh();
                break;
            case "Enter":
                var activeItem = FindActiveSelectableItem();
                if (activeItem is not null)
                    await Select(activeItem.Value);
                break;
            case "Escape":
                await SetOpen(false);
                break;
            case "Backspace":
                if (Multiple && Search.IsNullOrEmpty())
                    await RemoveLastValue();
                break;
        }
    }

    internal async Task RemoveValue(string value)
    {
        if (!Multiple || value.IsNullOrEmpty())
            return;

        if (Values is null || Values.Length == 0)
            return;

        var index = IndexOfSelectedValue(value);
        if (index < 0)
            return;

        var next = new string[Values.Length - 1];
        if (index > 0)
            Array.Copy(Values, 0, next, 0, index);

        var remaining = Values.Length - index - 1;
        if (remaining > 0)
            Array.Copy(Values, index + 1, next, index, remaining);

        Values = next;
        await ValueChangedMultiple.InvokeAsync(Values);
        EnsureActiveItem();
        InvalidateRender();
        Refresh();
    }

    internal async Task Clear()
    {
        Search = "";

        if (Multiple)
        {
            Values = [];
            await ValueChangedMultiple.InvokeAsync(Values);
        }
        else
        {
            Value = null;
            await ValueChanged.InvokeAsync(null);
        }

        Open = false;
        SetActiveValue(null);
        await SearchChanged.InvokeAsync(Search);
        await OpenChanged.InvokeAsync(false);
        InvalidateRender();
        Refresh();
    }

    private void MoveActiveItem(string key)
    {
        var count = CountVisibleSelectableItems(out var currentIndex);
        if (count == 0)
        {
            SetActiveValue(null);
            return;
        }

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => count - 1,
            "ArrowUp" when currentIndex < 0 => count - 1,
            "ArrowDown" when currentIndex < 0 => 0,
            "ArrowDown" => (currentIndex + 1) % count,
            "ArrowUp" => (currentIndex - 1 + count) % count,
            _ => currentIndex
        };

        var next = GetVisibleSelectableItemAt(nextIndex);
        if (next is not null)
            SetActiveValue(next.Value);
    }

    private void EnsureActiveItem()
    {
        var count = CountVisibleSelectableItems(out _);
        if (count == 0)
        {
            SetActiveValue(null);
            return;
        }

        if (FindActiveSelectableItem() is not null)
            return;

        if (AutoHighlight)
        {
            SetActiveValue(GetVisibleSelectableItemAt(0)?.Value);
            return;
        }

        if (Value is not null)
        {
            var selectedItem = FindVisibleSelectableItem(Value);
            if (selectedItem is not null)
            {
                SetActiveValue(selectedItem.Value);
                return;
            }
        }

        SetActiveValue(null);
    }

    private async Task ToggleValue(string? value)
    {
        if (value.IsNullOrEmpty())
            return;

        var existingIndex = IndexOfSelectedValue(value);
        if (existingIndex >= 0)
        {
            var next = new string[Values!.Length - 1];
            if (existingIndex > 0)
                Array.Copy(Values, 0, next, 0, existingIndex);

            var remaining = Values.Length - existingIndex - 1;
            if (remaining > 0)
                Array.Copy(Values, existingIndex + 1, next, existingIndex, remaining);

            Values = next;
        }
        else if (Values is { Length: > 0 })
        {
            var next = new string[Values.Length + 1];
            Array.Copy(Values, next, Values.Length);
            next[^1] = value;
            Values = next;
        }
        else
        {
            Values = [value];
        }

        Search = "";
        Open = true;
        SetActiveValue(value);

        await ValueChangedMultiple.InvokeAsync(Values);
        await SearchChanged.InvokeAsync(Search);
        await OpenChanged.InvokeAsync(Open);
        InvalidateRender();
        Refresh();
    }

    private bool ClearSelectedSearchForSingle()
    {
        if (!Multiple && Value is not null && string.Equals(Search, Value, StringComparison.Ordinal))
        {
            Search = "";
            return true;
        }

        return false;
    }

    private async Task RemoveLastValue()
    {
        if (!Multiple || Values is null || Values.Length == 0)
            return;

        await RemoveValue(Values[^1]);
    }

    private void SetActiveValue(string? value)
    {
        foreach (var item in _items)
            item.SetActive(string.Equals(item.Value, value, StringComparison.Ordinal));
    }

    private string? GetActiveItemId()
    {
        foreach (var item in _items)
        {
            if (item.IsActiveItem)
                return item.ItemId;
        }

        return null;
    }

    private bool HasAnyVisibleItem()
    {
        foreach (var item in _items)
        {
            if (!item.Hidden)
                return true;
        }

        return false;
    }

    private ComboboxItem? FindActiveSelectableItem()
    {
        foreach (var item in _items)
        {
            if (item.IsActiveItem && !item.Hidden && !item.Disabled)
                return item;
        }

        return null;
    }

    private ComboboxItem? FindVisibleSelectableItem(string value)
    {
        foreach (var item in _items)
        {
            if (!item.Hidden && !item.Disabled && string.Equals(item.Value, value, StringComparison.Ordinal))
                return item;
        }

        return null;
    }

    private int CountVisibleSelectableItems(out int activeIndex)
    {
        activeIndex = -1;
        var count = 0;

        foreach (var item in _items)
        {
            if (item.Hidden || item.Disabled)
                continue;

            if (item.IsActiveItem)
                activeIndex = count;

            count++;
        }

        return count;
    }

    private ComboboxItem? GetVisibleSelectableItemAt(int targetIndex)
    {
        var index = 0;

        foreach (var item in _items)
        {
            if (item.Hidden || item.Disabled)
                continue;

            if (index == targetIndex)
                return item;

            index++;
        }

        return null;
    }

    private int IndexOfSelectedValue(string value)
    {
        if (Values is null)
            return -1;

        for (var i = 0; i < Values.Length; i++)
        {
            if (string.Equals(Values[i], value, StringComparison.Ordinal))
                return i;
        }

        return -1;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-state"] = Open ? "open" : "closed";
        if (Disabled)
            attributes["data-disabled"] = "true";

    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Search);
        hc.Add(Open);
        hc.Add(Disabled);
        hc.Add(AutoHighlight);
        hc.Add(ShowClear);
        hc.Add(Multiple);

        if (Values is not null)
        {
            foreach (var value in Values)
            {
                hc.Add(value);
            }
        }
    }

    public override ValueTask DisposeAsync()
    {
        _hasTriggerElement = false;
        return base.DisposeAsync();
    }
}
