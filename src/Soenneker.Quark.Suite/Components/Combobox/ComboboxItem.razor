@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@inherits Soenneker.Quark.FormControlElement

<div @onclick="HandleItemClick" @onmouseenter="HandleMouseEnter" @attributes="BuildAttributes()" role="option">
    @ChildContent
    @if (IsSelected)
    {
        <span class="ml-auto rtl:ml-0 rtl:mr-auto inline-flex items-center">
            <Icon Name="LucideIcon.Check" Class="size-4" />
        </span>
    }
</div>

@code {
    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    private bool IsSelected => ParentCombobox?.IsSelected(Value) == true;
    internal bool IsActiveItem { get; private set; }
    internal string ItemId => BlazorIdGenerator.Child(Id!, "option");

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        Cursor ??= Quark.Cursor.Default;
        UserSelect ??= Quark.UserSelect.None;
        ItemsAlign ??= Items.Center;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Is2.OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (Id.IsNullOrEmpty())
            Id = BlazorIdGenerator.New("quark-combobox-item");
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender)
            ParentCombobox?.RegisterItem(this);
    }

    private async Task HandleItemClick(MouseEventArgs _)
    {
        if (!Disabled && ParentCombobox != null)
            await ParentCombobox.Select(Value);
    }

    private Task HandleMouseEnter(MouseEventArgs _)
    {
        ParentCombobox?.SetActiveItem(this);
        return Task.CompletedTask;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "combobox-item";
        attributes["data-value"] = Value ?? "";
        attributes["data-selected"] = IsSelected ? "true" : "false";
        attributes["aria-selected"] = IsSelected ? "true" : "false";
        attributes["id"] = ItemId;
        attributes["tabindex"] = -1;

        if (IsActiveItem)
            attributes["data-highlighted"] = string.Empty;

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            attributes["data-disabled"] = "true";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "outline-none");
            AppendClass(ref cls, "data-[selected=true]:bg-accent data-[selected=true]:text-accent-foreground");
            AppendClass(ref cls, "data-[highlighted]:bg-accent data-[highlighted]:text-accent-foreground");
            AppendClass(ref cls, "hover:bg-accent hover:text-accent-foreground");
            AppendClass(ref cls, "data-[disabled=true]:pointer-events-none data-[disabled=true]:opacity-50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(IsSelected);
        hc.Add(IsActiveItem);
    }

    internal void SetActive(bool active)
    {
        if (IsActiveItem != active)
        {
            IsActiveItem = active;
            Refresh();
        }
    }

    public override void Dispose()
    {
        ParentCombobox?.UnregisterItem(this);
        base.Dispose();
    }
}
