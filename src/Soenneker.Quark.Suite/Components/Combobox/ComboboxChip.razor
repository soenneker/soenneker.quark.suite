@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Span @attributes="BuildAttributes()">
    @ChildContent
    @if (ShowRemove)
    {
        <Button Type="@ButtonType.Button" DataSlot="combobox-chip-remove" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.IconXs" Margin='Quark.Margin.FromLeft.Negative1' Opacity="CssValue<OpacityBuilder>.For(Quark.Opacity.Is50, Quark.Opacity.Is100.OnHover)" tabindex="-1" aria-label="Remove selection" Disabled="@(ParentCombobox?.Disabled == true)" @onclick="HandleRemoveClick" @onmousedown:preventDefault="true">
            <Icon Name="LucideIcon.X" PointerEvents="Quark.PointerEvents.None" />
        </Button>
    }
</Span>

@code {
    [Parameter]
    public string Value { get; set; } = string.Empty;

    [Parameter]
    public bool ShowRemove { get; set; } = true;

    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    private async Task HandleRemoveClick(MouseEventArgs _)
    {
        if (ParentCombobox is null || ParentCombobox.Disabled)
            return;

        await ParentCombobox.RemoveValue(Value);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "combobox-chip";
        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Token("[calc(--spacing(5.25))]");
        Width ??= Quark.Width.IsFit;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is1;
        Rounded ??= Quark.Rounded.Sm;
        BackgroundColor ??= Quark.BackgroundColor.Muted;
        Padding ??= Quark.Padding.OnX.Is1_5;
        TextSize ??= Quark.TextSize.Xs;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        TextColor ??= Quark.TextColor.Foreground;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-value"] = Value;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "has-data-[slot=combobox-chip-remove]:pr-0");

            if (ParentCombobox?.Disabled == true)
                AppendClass(ref cls, "has-disabled:pointer-events-none has-disabled:cursor-not-allowed has-disabled:opacity-50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(ShowRemove);
        hc.Add(ParentCombobox?.Disabled);
    }
}
