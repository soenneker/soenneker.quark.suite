@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<div @ref="_wrapperRef" @attributes="BuildWrapperAttributes()">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    <input value="@GetDisplayValue()"
           @oninput="HandleInput"
           @onfocus="HandleFocus"
           @onkeydown="HandleKeyDown"
           @onkeydown:preventDefault="_preventDefaultKeys"
           @onkeydown:stopPropagation="_escapeStopPropagation"
           @attributes="BuildAttributes()" />
    <button type="button" @onclick="ToggleOpen" @attributes="BuildButtonAttributes()">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
    </button>
</div>

@code {
    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    private bool _preventDefaultKeys;
    private bool _escapeStopPropagation;
    private ElementReference _wrapperRef;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        ParentCombobox?.SetTriggerElement(_wrapperRef);
        return base.OnAfterRenderAsync(firstRender);
    }

    private string GetDisplayValue()
    {
        if (ParentCombobox == null) return "";
        if (ParentCombobox.Multiple)
            return ParentCombobox.Search ?? "";

        return ParentCombobox.Open ? (ParentCombobox.Search ?? "") : (ParentCombobox.Value ?? "");
    }

    private async Task HandleInput(ChangeEventArgs args)
    {
        if (ParentCombobox != null)
        {
            var value = args.Value?.ToString();
            await ParentCombobox.SetSearch(value ?? "");
            await ParentCombobox.SetOpen(true);
        }
    }

    protected override async Task HandleFocus(FocusEventArgs e)
    {
        if (ParentCombobox != null && !ParentCombobox.Disabled)
            await ParentCombobox.SetOpen(true);

        await base.HandleFocus(e);
    }

    private async Task ToggleOpen(MouseEventArgs _)
    {
        if (ParentCombobox != null)
            await ParentCombobox.SetOpen(!ParentCombobox.Open);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        _escapeStopPropagation = false;
        bool preventBackspace = e.Key == "Backspace" && ParentCombobox?.Multiple == true && (ParentCombobox.Search.IsNullOrEmpty());
        var listOpen = ParentCombobox?.Open == true;
        // Enter must not swallow form submit when the list is closed; Escape only when we handle close.
        _preventDefaultKeys = e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End"
            || (e.Key == "Enter" && listOpen)
            || preventBackspace
            || (e.Key == "Escape" && listOpen);

        if (ParentCombobox != null && _preventDefaultKeys)
        {
            var wasOpen = ParentCombobox.Open;
            await ParentCombobox.HandleInputKeyDownAsync(e.Key);

            if (e.Key == "Escape" && wasOpen)
                _escapeStopPropagation = true;
        }

        await base.HandleKeyDown(e);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["type"] = "text";
        attributes["data-slot"] = "input-group-control";
        attributes["data-combobox-slot"] = "combobox-input";
        ApplyFieldControlAttributes(attributes, false);

        if (!attributes.ContainsKey("id") && ParentCombobox is not null)
            attributes["id"] = ParentCombobox.InputId;

        attributes["role"] = "combobox";
        attributes["autocomplete"] = "off";
        attributes["aria-autocomplete"] = "list";
        attributes["aria-expanded"] = ParentCombobox?.Open == true ? "true" : "false";

        if (ParentCombobox?.ActiveItemId.HasContent() == true)
            attributes["aria-activedescendant"] = ParentCombobox.ActiveItemId;

        if (ParentCombobox is not null)
            attributes["aria-controls"] = ParentCombobox.ContentId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-combobox-input");
            AppendClass(ref cls, "h-9 w-full min-w-0 rounded-md border border-input bg-transparent px-3 py-1 pr-10 rtl:pr-3 rtl:pl-10 text-base shadow-xs transition-[color,box-shadow] outline-none");
            AppendClass(ref cls, "placeholder:text-muted-foreground disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm dark:bg-input/30");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
        });
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "input-group",
            ["data-combobox-slot"] = "combobox-control",
            ["role"] = "group"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-combobox-control q-input-group group/input-group border-input relative flex h-9 w-full min-w-0 items-center rounded-md border shadow-xs transition-[color,box-shadow] outline-none dark:bg-input/30");
            AppendClass(ref cls, "has-[[data-slot=input-group-control]:focus-visible]:border-ring has-[[data-slot=input-group-control]:focus-visible]:ring-ring/50 has-[[data-slot=input-group-control]:focus-visible]:ring-[3px]");
            AppendClass(ref cls, "has-[[data-slot][aria-invalid=true]]:ring-destructive/20 has-[[data-slot][aria-invalid=true]]:border-destructive dark:has-[[data-slot][aria-invalid=true]]:ring-destructive/40");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildButtonAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "combobox-trigger",
            ["data-align"] = "inline-end",
            ["type"] = "button",
            ["aria-label"] = ParentCombobox?.Open == true ? "Close combobox" : "Open combobox",
            ["aria-controls"] = ParentCombobox?.ContentId ?? string.Empty,
            ["aria-expanded"] = ParentCombobox?.Open == true ? "true" : "false",
            ["tabindex"] = -1
        };

        if (ParentCombobox?.Disabled == true)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-combobox-trigger");
            AppendClass(ref cls, "text-muted-foreground absolute inset-y-0 right-0 rtl:right-auto rtl:left-0 inline-flex items-center justify-center px-3");
        });

        return attributes;
    }
}
