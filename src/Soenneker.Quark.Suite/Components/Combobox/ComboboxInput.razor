@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

@if (Anchor)
{
<PopoverAnchor>
    <div @ref="_wrapperRef" @attributes="BuildWrapperAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        <input value="@GetDisplayValue()"
               @oninput="HandleInput"
               @onfocus="HandleFocus"
               @onclick="HandleClickOpen"
               @onkeydown="HandleKeyDown"
               @onkeydown:preventDefault="_preventDefaultKeys"
               @attributes="BuildAttributes()" />
        @if (ParentCombobox?.ShowClear == true && ParentCombobox.HasClearValue)
        {
            <button type="button" @onclick="Clear" @onmousedown:preventDefault="true" @attributes="BuildClearButtonAttributes()">
                <svg data-slot="combobox-clear-icon" class="pointer-events-none size-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                <span class="sr-only">Clear</span>
            </button>
        }
        @if (ShowTrigger)
        {
            <button type="button" @onclick="ToggleOpen" @attributes="BuildButtonAttributes()">
                <svg data-slot="combobox-trigger-icon" class="pointer-events-none size-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </button>
        }
    </div>
</PopoverAnchor>
}
else
{
    <div @ref="_wrapperRef" @attributes="BuildWrapperAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        <input value="@GetDisplayValue()"
               @oninput="HandleInput"
               @onfocus="HandleFocus"
               @onclick="HandleClickOpen"
               @onkeydown="HandleKeyDown"
               @onkeydown:preventDefault="_preventDefaultKeys"
               @attributes="BuildAttributes()" />
        @if (ParentCombobox?.ShowClear == true && ParentCombobox.HasClearValue)
        {
            <button type="button" @onclick="Clear" @onmousedown:preventDefault="true" @attributes="BuildClearButtonAttributes()">
                <svg data-slot="combobox-clear-icon" class="pointer-events-none size-4" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                <span class="sr-only">Clear</span>
            </button>
        }
        @if (ShowTrigger)
        {
            <button type="button" @onclick="ToggleOpen" @attributes="BuildButtonAttributes()">
                <svg data-slot="combobox-trigger-icon" class="pointer-events-none size-4 text-muted-foreground" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
            </button>
        }
    </div>
}

@code {
    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    [Parameter]
    public bool Anchor { get; set; } = true;

    [Parameter]
    public bool ShowTrigger { get; set; } = true;

    private bool _preventDefaultKeys;
    private ElementReference _wrapperRef;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (Anchor)
            ParentCombobox?.SetTriggerElement(_wrapperRef);

        return base.OnAfterRenderAsync(firstRender);
    }

    private string GetDisplayValue()
    {
        if (ParentCombobox == null) return "";
        if (ParentCombobox.Multiple)
            return ParentCombobox.Search ?? "";

        return ParentCombobox.Open ? (ParentCombobox.Search ?? "") : (ParentCombobox.Value ?? "");
    }

    private async Task HandleInput(ChangeEventArgs args)
    {
        if (ParentCombobox != null)
        {
            var value = args.Value?.ToString();
            await ParentCombobox.SetSearch(value ?? "");
            await ParentCombobox.SetOpen(true);
        }
    }

    protected override async Task HandleFocus(FocusEventArgs e)
    {
        if (ParentCombobox != null && !ParentCombobox.Disabled)
            await ParentCombobox.SetOpen(true);

        await base.HandleFocus(e);
    }

    private async Task HandleClickOpen(MouseEventArgs _)
    {
        if (ParentCombobox != null && !ParentCombobox.Disabled && !ParentCombobox.Open)
            await ParentCombobox.SetOpen(true);
    }

    private async Task ToggleOpen(MouseEventArgs _)
    {
        if (ParentCombobox != null)
            await ParentCombobox.SetOpen(!ParentCombobox.Open);
    }

    private async Task Clear(MouseEventArgs _)
    {
        if (ParentCombobox is not null && !ParentCombobox.Disabled)
            await ParentCombobox.Clear();
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        var preventBackspace = e.Key == "Backspace" && ParentCombobox?.Multiple == true && (ParentCombobox.Search.IsNullOrEmpty());
        _preventDefaultKeys = e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End" or "Enter" or "Escape" || preventBackspace;

        if (ParentCombobox != null && _preventDefaultKeys)
            await ParentCombobox.HandleInputKeyDown(e.Key);

        await base.HandleKeyDown(e);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Height ??= Quark.Height.Is8;
        Width ??= Quark.Width.IsFull;
        MinWidth ??= Quark.MinWidth.Is0;
        Flex ??= Quark.Flex.Is1;
        Rounded ??= Quark.Rounded.None;
        Border ??= Quark.Border.Is0;
        BorderColor ??= Quark.BorderColor.Input;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Padding ??= Quark.Padding.Token("2.5").OnX.Is1.OnY;
        TextSize ??= Quark.TextSize.Base.OnMd.Sm;
        Transition ??= Quark.Transition.Colors;
        OutlineStyle ??= Quark.OutlineStyle.None;
        Shadow ??= Quark.Shadow.None;
        Ring ??= Quark.Ring.None;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["type"] = "text";
        attributes["data-slot"] = "input-group-control";
        attributes["data-combobox-slot"] = "combobox-input";
        attributes["role"] = "combobox";
        attributes["autocomplete"] = "off";
        attributes["aria-autocomplete"] = "list";
        attributes["aria-expanded"] = ParentCombobox?.Open == true ? "true" : "false";
        attributes["aria-activedescendant"] = ParentCombobox?.ActiveItemId ?? string.Empty;

        if (ParentCombobox is not null)
        {
            attributes["id"] = ParentCombobox.InputId;
            attributes["aria-controls"] = ParentCombobox.ContentId;
        }

        if (ParentCombobox?.Disabled == true)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "file:inline-flex file:h-6 file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground");
            AppendClass(ref cls, "placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 md:text-sm");
            AppendClass(ref cls, "dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "disabled:bg-transparent aria-invalid:ring-0 dark:bg-transparent dark:disabled:bg-transparent");
        });
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "input-group",
            ["data-combobox-slot"] = "combobox-control",
            ["role"] = "group"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/input-group relative flex h-8 min-w-0 items-center rounded-lg border border-input");
            AppendClass(ref cls, "transition-[color,box-shadow] outline-none dark:bg-input/30");
            AppendClass(ref cls, "has-[[data-slot=input-group-control]:focus-visible]:border-ring has-[[data-slot=input-group-control]:focus-visible]:ring-[3px]");
            AppendClass(ref cls, "has-[[data-slot=input-group-control]:focus-visible]:ring-ring/50");
            AppendClass(ref cls, "has-[[data-slot][aria-invalid=true]]:border-destructive has-[[data-slot][aria-invalid=true]]:ring-destructive/20 dark:has-[[data-slot][aria-invalid=true]]:ring-destructive/40");
            AppendClass(ref cls, "has-[>textarea]:h-auto");
            AppendClass(ref cls, "has-[>[data-align=block-end]]:h-auto has-[>[data-align=block-end]]:flex-col");
            AppendClass(ref cls, "has-[>[data-align=block-start]]:h-auto has-[>[data-align=block-start]]:flex-col");
            AppendClass(ref cls, "has-[>[data-align=block-end]]:[&>input]:pt-3 has-[>[data-align=block-start]]:[&>input]:pb-3");
            AppendClass(ref cls, "has-[>[data-align=inline-end]]:[&>input]:pr-1.5 has-[>[data-align=inline-start]]:[&>input]:pl-1.5");
            AppendClass(ref cls, "w-auto");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildButtonAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "combobox-trigger",
            ["data-align"] = "inline-end",
            ["type"] = "button",
            ["aria-label"] = ParentCombobox?.Open == true ? "Close combobox" : "Open combobox",
            ["aria-controls"] = ParentCombobox?.ContentId ?? string.Empty,
            ["aria-expanded"] = ParentCombobox?.Open == true ? "true" : "false",
            ["tabindex"] = -1
        };

        if (ParentCombobox?.Disabled == true)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/button shrink-0 justify-center border border-transparent bg-clip-padding font-medium whitespace-nowrap");
            AppendClass(ref cls, "transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "active:not-aria-[haspopup]:translate-y-px disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "hover:bg-muted hover:text-foreground dark:hover:bg-muted/50");
            AppendClass(ref cls, "has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2 flex items-center gap-2 text-sm shadow-none");
            AppendClass(ref cls, "size-6 rounded-[calc(var(--radius)-3px)] p-0 has-[>svg]:p-0 group-has-data-[slot=combobox-clear]/input-group:hidden data-pressed:bg-transparent");
            AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-4");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildClearButtonAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "combobox-clear",
            ["data-align"] = "inline-end",
            ["type"] = "button",
            ["aria-label"] = "Clear"
        };

        if (ParentCombobox?.Disabled == true)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/button shrink-0 justify-center border border-transparent bg-clip-padding font-medium whitespace-nowrap");
            AppendClass(ref cls, "transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "active:not-aria-[haspopup]:translate-y-px disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 hover:bg-muted hover:text-foreground dark:hover:bg-muted/50");
            AppendClass(ref cls, "flex size-6 items-center gap-2 rounded-[calc(var(--radius)-3px)] p-0 text-sm text-muted-foreground hover:text-foreground");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentCombobox?.Open);
        hc.Add(ParentCombobox?.ActiveItemId);
        hc.Add(ParentCombobox?.Search);
        hc.Add(ParentCombobox?.Value);
        hc.Add(ParentCombobox?.ShowClear);
        hc.Add(ParentCombobox?.HasClearValue);
        hc.Add(Anchor);
        hc.Add(ShowTrigger);
    }
}
