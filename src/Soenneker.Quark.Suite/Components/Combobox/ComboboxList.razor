@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        MaxHeight ??= Quark.Height.Token("[min(calc(--spacing(72)---spacing(9)),calc(var(--available-height)---spacing(9)))]");
        OverflowY ??= Quark.Overflow.Y.Auto;
        Padding ??= Quark.Padding.Is1;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "combobox-list";

        if (ParentCombobox?.HasVisibleItems != true)
            attributes["data-empty"] = string.Empty;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "no-scrollbar scroll-py-1 overscroll-contain data-empty:p-0");
        });
    }
}
