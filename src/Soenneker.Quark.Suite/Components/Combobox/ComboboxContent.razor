@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix

<PopoverContent Side="@Side"
                SideOffset="@SideOffset"
                Align="@Align"
                AlignOffset="@AlignOffset"
                AvoidCollisions="@AvoidCollisions"
                Slot="combobox-content"
                Id="@ResolvedContentId"
                Width='Quark.Width.Token("(--anchor-width)")'
                MaxWidth='Quark.MaxWidth.Token("(--available-width)")'
                Rounded="Quark.Rounded.Lg"
                Border="Quark.Border.Is0"
                Padding="Quark.Padding.Is0"
                Display="Quark.Display.Block"
                UseDefaultLayout="false"
                UseDefaultMotion="false"
                OnOpenAutoFocusDetailed="HandleOpenAutoFocus"
                @attributes="ContentAttributes">
    @ChildContent
</PopoverContent>

@code {
    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    [Parameter]
    public Side Side { get; set; } = Side.Bottom;

    [Parameter]
    public int SideOffset { get; set; } = 6;

    [Parameter]
    public Alignment Align { get; set; } = Alignment.Start;

    [Parameter]
    public int AlignOffset { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    private string? ResolvedContentId => ParentCombobox?.ContentId;

    private static Task HandleOpenAutoFocus(BradixAutoFocusEventArgs args)
    {
        args.PreventDefault();
        return Task.CompletedTask;
    }

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes())
            {
                ["data-slot"] = "combobox-content",
                ["data-chips"] = ParentCombobox?.Multiple == true ? "true" : "false",
                ["role"] = "presentation",
                ["tabindex"] = -1
            };

            if (ParentCombobox?.Open == true)
                attributes["data-open"] = string.Empty;
            else
                attributes["data-closed"] = string.Empty;

            if (ParentCombobox?.HasVisibleItems != true)
                attributes["data-empty"] = string.Empty;

            var anchorWidth = ParentCombobox?.Multiple == true
                ? "var(--radix-popper-anchor-width)"
                : ParentCombobox?.TriggerReservesInlineEndAction == true
                    ? "calc(var(--radix-popper-anchor-width) - 1.75rem)"
                    : "var(--radix-popper-anchor-width)";
            var minWidth = ParentCombobox?.Multiple == true
                ? "var(--anchor-width)"
                : "calc(var(--anchor-width) + 1.75rem)";

            attributes["style"] =
                $"--anchor-width: {anchorWidth}; --available-width: var(--radix-popper-available-width); --available-height: var(--radix-popper-available-height); --transform-origin: var(--radix-popover-content-transform-origin); width: var(--anchor-width); min-width: {minWidth}; max-width: var(--available-width); max-height: var(--available-height);" +
                (AlignOffset == 0 ? string.Empty : $" margin-left: {AlignOffset}px;");

            if (ParentCombobox?.Multiple == true)
                attributes["aria-multiselectable"] = "true";

            return attributes;
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        MinWidth ??= Quark.MinWidth.Token("[calc(var(--anchor-width)+--spacing(7))]");
        Overflow ??= Quark.Overflow.Hidden;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Is0;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is0;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Shadow ??= Quark.Shadow.Md;
        Ring ??= Quark.Ring.Is1;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "cn-menu-target cn-menu-translucent group/combobox-content origin-(--transform-origin) ring-foreground/10 duration-100");
            AppendClass(ref cls, "data-[chips=true]:min-w-(--anchor-width) data-[side=bottom]:slide-in-from-top-2 data-[side=inline-end]:slide-in-from-left-2 data-[side=inline-start]:slide-in-from-right-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "*:data-[slot=input-group]:m-1 *:data-[slot=input-group]:mb-0 *:data-[slot=input-group]:h-8 *:data-[slot=input-group]:border-input/30 *:data-[slot=input-group]:bg-input/30 *:data-[slot=input-group]:shadow-none");
            AppendClass(ref cls, "data-open:animate-in data-open:fade-in-0 data-open:zoom-in-95 data-closed:animate-out data-closed:fade-out-0 data-closed:zoom-out-95");
            AppendClass(ref cls, "[&:has([data-slot=combobox-item]:not([hidden]))>[data-slot=combobox-empty]]:hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(Align);
        hc.Add(AlignOffset);
        hc.Add(AvoidCollisions);
        hc.Add(ParentCombobox?.Open ?? false);
        hc.Add(ParentCombobox?.TriggerReservesInlineEndAction ?? false);
        hc.Add(ParentCombobox?.HasVisibleItems ?? false);
    }

}
