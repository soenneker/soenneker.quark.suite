@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<PopoverContent Side="@Side"
                SideOffset="@SideOffset"
                Align="@Align"
                Id="@ResolvedContentId"
                Class="@ContentClass"
                Style="@ContentStyle"
                @attributes="ContentAttributes">
    @ChildContent
</PopoverContent>

@code {
    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public int SideOffset { get; set; } = 6;

    [Parameter]
    public string Align { get; set; } = "start";

    [Parameter]
    public int AlignOffset { get; set; }

    private string? ResolvedContentId => ParentCombobox?.ContentId;

    private string ContentClass =>
        "z-50 max-h-96 min-w-[8rem] overflow-auto rounded-lg border bg-popover p-1 text-popover-foreground shadow-md animate-in fade-in-0 zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=top]:slide-in-from-bottom-2";

    private string ContentStyle =>
        "min-width: var(--radix-popper-anchor-width); max-height: min(24rem, var(--radix-popper-available-height));" +
        (AlignOffset == 0 ? string.Empty : $" margin-left: {AlignOffset}px;");

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            var attributes = new Dictionary<string, object>
            {
                ["data-slot"] = "combobox-content",
                ["data-state"] = ParentCombobox?.Open == true ? "open" : "closed",
                ["role"] = "listbox",
                ["tabindex"] = -1,
                ["aria-hidden"] = ParentCombobox?.Open == true ? "false" : "true"
            };

            if (ParentCombobox?.Multiple == true)
                attributes["aria-multiselectable"] = "true";

            return attributes;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(Align);
        hc.Add(AlignOffset);
        hc.Add(ParentCombobox?.Open ?? false);
    }

}
