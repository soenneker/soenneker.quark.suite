@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<PopoverContent Side="@Side"
                SideOffset="@SideOffset"
                Align="@PlacementAlign"
                Id="@ResolvedContentId"
                @attributes="ContentAttributes">
    @ChildContent
</PopoverContent>

@code {
    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public int SideOffset { get; set; } = 6;

    [Parameter]
    public string PlacementAlign { get; set; } = "start";

    [Parameter]
    public int AlignOffset { get; set; }

    private string? ResolvedContentId => ParentCombobox?.ContentId;

    private IReadOnlyDictionary<string, object> ContentAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes())
            {
                ["data-slot"] = "combobox-content",
                ["data-state"] = ParentCombobox?.Open == true ? "open" : "closed",
                ["role"] = "listbox",
                ["tabindex"] = -1,
                ["aria-hidden"] = ParentCombobox?.Open == true ? "false" : "true"
            };

            attributes["style"] =
                "min-width: var(--radix-popper-anchor-width); max-height: min(24rem, var(--radix-popper-available-height));" +
                (AlignOffset == 0 ? string.Empty : $" margin-left: {AlignOffset}px;");

            if (ParentCombobox?.Multiple == true)
                attributes["aria-multiselectable"] = "true";

            return attributes;
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        MaxHeight ??= Quark.Height.Token("96");
        Overflow ??= Quark.Overflow.Auto;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is1;
        TextColor ??= Quark.TextColor.PopoverForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "z-50 min-w-[8rem] shadow-md");
            AppendClass(ref cls, "animate-in fade-in-0 zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=top]:slide-in-from-bottom-2");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(PlacementAlign);
        hc.Add(AlignOffset);
        hc.Add(ParentCombobox?.Open ?? false);
    }

}
