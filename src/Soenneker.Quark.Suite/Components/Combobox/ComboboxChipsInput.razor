@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<input value="@GetDisplayValue()"
       @oninput="HandleInput"
       @onfocus="HandleFocus"
       @onclick="HandleClickOpen"
       @onkeydown="HandleKeyDown"
       @onkeydown:preventDefault="_preventDefaultKeys"
       @attributes="BuildAttributes()" />

@code {
    private bool _preventDefaultKeys;

    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    private string GetDisplayValue()
    {
        return ParentCombobox?.Search ?? string.Empty;
    }

    private async Task HandleInput(ChangeEventArgs args)
    {
        if (ParentCombobox is null)
            return;

        var value = args.Value?.ToString();
        await ParentCombobox.SetSearch(value ?? string.Empty);
        await ParentCombobox.SetOpen(true);
    }

    protected override async Task HandleFocus(FocusEventArgs e)
    {
        if (ParentCombobox != null && !ParentCombobox.Disabled)
            await ParentCombobox.SetOpen(true);

        await base.HandleFocus(e);
    }

    private async Task HandleClickOpen(MouseEventArgs _)
    {
        if (ParentCombobox != null && !ParentCombobox.Disabled && !ParentCombobox.Open)
            await ParentCombobox.SetOpen(true);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        var preventBackspace = e.Key == "Backspace" && (ParentCombobox?.Search.IsNullOrEmpty() ?? false);
        _preventDefaultKeys = e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End" or "Enter" or "Escape" || preventBackspace;

        if (ParentCombobox != null && _preventDefaultKeys)
            await ParentCombobox.HandleInputKeyDownAsync(e.Key);

        await base.HandleKeyDown(e);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["type"] = "text";
        attributes["data-slot"] = "combobox-chip-input";
        attributes["data-combobox-slot"] = "combobox-chip-input";
        attributes["role"] = "combobox";
        attributes["autocomplete"] = "off";
        attributes["aria-autocomplete"] = "list";
        attributes["aria-expanded"] = ParentCombobox?.Open == true ? "true" : "false";
        attributes["aria-activedescendant"] = ParentCombobox?.ActiveItemId ?? string.Empty;

        if (ParentCombobox is not null)
        {
            attributes["id"] = ParentCombobox.InputId;
            attributes["aria-controls"] = ParentCombobox.ContentId;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-combobox-chip-input");
            AppendClass(ref cls, "min-w-20 flex-1 bg-transparent px-1 py-1 text-sm outline-none placeholder:text-muted-foreground disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentCombobox?.Open);
        hc.Add(ParentCombobox?.ActiveItemId);
        hc.Add(ParentCombobox?.Search);
    }
}
