@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<PopoverAnchor>
    <div @ref="_wrapperRef" @attributes="BuildAttributes()">
        @ChildContent
    </div>
</PopoverAnchor>

@code {
    private ElementReference _wrapperRef;

    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        ParentCombobox?.SetTriggerElement(_wrapperRef);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        MinHeight ??= Quark.Height.Token("9");
        FlexWrap ??= Quark.FlexWrap.Wrap;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Token("1.5");
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Input;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Padding ??= Quark.Padding.Token("2.5").OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        Shadow ??= Quark.Shadow.Xs;
        Transition ??= Quark.Transition.Token("transition-[color,box-shadow]");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "combobox-chips";
        attributes["role"] = "toolbar";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "bg-clip-padding");
            AppendClass(ref cls, "focus-within:border-ring focus-within:ring-[3px] focus-within:ring-ring/50");
            AppendClass(ref cls, "has-aria-invalid:border-destructive has-aria-invalid:ring-[3px] has-aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "has-data-[slot=combobox-chip]:px-1.5 dark:bg-input/30 dark:has-aria-invalid:border-destructive/50 dark:has-aria-invalid:ring-destructive/40");
        });
    }
}
