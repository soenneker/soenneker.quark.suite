@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<PopoverAnchor>
    <div @ref="_wrapperRef" @attributes="BuildAttributes()">
        @ChildContent
    </div>
</PopoverAnchor>

@code {
    private ElementReference _wrapperRef;

    [CascadingParameter(Name = "ParentCombobox")]
    private Combobox? ParentCombobox { get; set; }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        ParentCombobox?.SetTriggerElement(_wrapperRef);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "combobox-chips";
        attributes["role"] = "toolbar";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex min-h-8 flex-wrap items-center gap-1 rounded-lg border border-input bg-transparent bg-clip-padding px-2.5 py-1 text-sm transition-colors");
            AppendClass(ref cls, "focus-within:border-ring focus-within:ring-3 focus-within:ring-ring/50");
            AppendClass(ref cls, "has-aria-invalid:border-destructive has-aria-invalid:ring-3 has-aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "has-data-[slot=combobox-chip]:px-1 dark:bg-input/30 dark:has-aria-invalid:border-destructive/50 dark:has-aria-invalid:ring-destructive/40");
        });
    }
}
