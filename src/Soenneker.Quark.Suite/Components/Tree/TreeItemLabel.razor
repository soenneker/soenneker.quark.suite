@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Span Attributes="@BuildAttributes()">
    @if (ShowToggleIcon && ParentTreeItem?.Folder == true)
    {
        if (ParentTreeItem.ToggleIconType == TreeToggleIconType.PlusMinus)
        {
            <Icon Name="@(ParentTreeItem.Expanded ? LucideIcon.Minus : LucideIcon.Plus)" Size="Quark.Size.Is3_5" TextColor="Quark.TextColor.MutedForeground" />
        }
        else
        {
            <Icon Name="LucideIcon.ChevronDown" TextColor="Quark.TextColor.MutedForeground" Size="Quark.Size.Is4" Transition="Quark.Transition.Transform" Class="@GetChevronClass()" />
        }
    }
    @ChildContent
</Span>

@code {
    [CascadingParameter(Name = "ParentTreeItem")]
    public TreeItem? ParentTreeItem { get; set; }

    [Parameter]
    public bool ShowToggleIcon { get; set; } = true;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "tree-item-label";
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Quark.Items.Center;
        Gap ??= Quark.Gap.Is1;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.OnX.Is2.OnY.Token("1.5");
        TextSize ??= Quark.TextSize.Sm;
        BackgroundColor ??= Quark.BackgroundColor.Background.OnHover.Accent;
        Transition ??= Quark.Transition.Colors;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "in-data-[selected=true]:bg-accent in-data-[selected=true]:text-accent-foreground not-in-data-[folder=true]:ps-7 in-focus-visible:ring-3 in-focus-visible:ring-ring/50 [&_svg]:pointer-events-none [&_svg]:shrink-0");
        });
    }

    private string GetChevronClass()
    {
        var cls = "";

        if (ParentTreeItem?.Expanded != true)
            cls += " -rotate-90";

        return cls;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ShowToggleIcon);
        hc.Add(ParentTreeItem?.Expanded);
        hc.Add(ParentTreeItem?.Folder);
        hc.Add(ParentTreeItem?.ToggleIconType);
    }
}
