@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<DialogClose Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.Icon" Class="@BuildClass()" Attributes="@CloseAttributes">
    @if (ChildContent is null)
    {
        <Icon Name="LucideIcon.X" />
        <Span ScreenReader="Quark.ScreenReader.Only">Close</Span>
    }
    else
    {
        @ChildContent
    }
</DialogClose>

@code {
    private static readonly IReadOnlyDictionary<string, object> CloseAttributes = new Dictionary<string, object>
    {
        ["data-slot"] = "image-lightbox-close"
    };

    private string BuildClass()
    {
        const string baseClass = "text-white hover:bg-white/10 hover:text-white";
        return string.IsNullOrWhiteSpace(Class) ? baseClass : $"{baseClass} {Class}";
    }
}
