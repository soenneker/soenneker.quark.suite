@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    [Parameter]
    public string Align { get; set; } = "block-end";

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "image-actions";
        attributes["data-align"] = Align;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "pointer-events-none absolute z-10 flex shrink-0 items-center justify-between px-3 py-3");
            AppendClass(ref cls, Align switch
            {
                "inline-start" => "top-1/2 left-0 h-full -translate-y-1/2 flex-col",
                "inline-end" => "top-1/2 right-0 h-full -translate-y-1/2 flex-col",
                "block-start" => "top-0 left-1/2 w-full -translate-x-1/2",
                _ => "bottom-0 left-1/2 w-full -translate-x-1/2"
            });
        });
    }
}
