@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<DialogContent ShowCloseButton="false" Class="@BuildClass()" Attributes="@LightboxAttributes">
    @ChildContent
</DialogContent>

@code {
    private string BuildClass() => string.Join(" ", new[]
    {
        "!flex !max-w-none !items-center !justify-center !border-0 !bg-transparent !p-0 !shadow-none !ring-0 sm:!max-w-none",
        Class
    }.Where(x => !string.IsNullOrWhiteSpace(x)));

    private IReadOnlyDictionary<string, object> LightboxAttributes => new Dictionary<string, object>
    {
        ["data-slot"] = "image-lightbox"
    };
}
