@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<DialogContent ShowCloseButton="false" Class="@BuildClass()" Attributes="@LightboxAttributes">
    @ChildContent
</DialogContent>

@code {
    private static readonly IReadOnlyDictionary<string, object> LightboxAttributes = new Dictionary<string, object>
    {
        ["data-slot"] = "image-lightbox"
    };

    private string BuildClass()
    {
        const string baseClass = "!flex !max-w-none !items-center !justify-center !border-0 !bg-transparent !p-0 !shadow-none !ring-0 sm:!max-w-none";
        return string.IsNullOrWhiteSpace(Class) ? baseClass : $"{baseClass} {Class}";
    }
}
