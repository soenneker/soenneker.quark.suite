@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Button Variant="@Variant" ButtonSize="@ButtonSize" Class="@BuildClass()" Attributes="@ActionAttributes">
    @ChildContent
</Button>

@code {
    private static readonly IReadOnlyDictionary<string, object> ActionAttributes = new Dictionary<string, object>
    {
        ["data-slot"] = "image-action"
    };

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Secondary;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = "icon-sm";

    private string BuildClass()
    {
        const string baseClass = "pointer-events-auto bg-background/90 shadow-xs backdrop-blur hover:bg-background";
        return string.IsNullOrWhiteSpace(Class) ? baseClass : $"{baseClass} {Class}";
    }
}
