@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentCommand" Value="@this">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly List<CommandEntry> _entries = [];
    private CommandItem? _activeItem;
    private string? _search;
    private readonly string _listId = BlazorIdGenerator.New("quark-command-list");

    internal string? Search => _search;

    internal bool HasVisibleItems => HasAnyVisibleEntry();

    internal string? ActiveItemId => _activeItem?.Id;

    internal string ListId => _listId;

    internal bool HasRegisteredItems => _entries.Count > 0;

    internal void RegisterItem(CommandItem item, CommandGroup? group)
    {
        var existingEntry = FindEntry(item);
        if (existingEntry is not null)
        {
            existingEntry.Group = group;
            return;
        }

        _entries.Add(new CommandEntry { Item = item, Group = group });

        if (_activeItem is null && item.IsVisibleResolved && !item.Disabled)
            _activeItem = item;

        Refresh();
    }

    internal void UpdateItemGroup(CommandItem item, CommandGroup? group)
    {
        var entry = FindEntry(item);
        if (entry is not null)
            entry.Group = group;
    }

    internal void UnregisterItem(CommandItem item)
    {
        var entry = FindEntry(item);
        if (entry is null)
            return;

        _entries.Remove(entry);

        if (ReferenceEquals(_activeItem, item))
            _activeItem = GetFirstVisibleEntry()?.Item;

        Refresh();
    }

    internal bool IsItemActive(CommandItem item)
    {
        return ReferenceEquals(_activeItem, item);
    }

    internal bool IsItemVisible(CommandItem item)
    {
        var entry = FindEntry(item);
        return entry?.Matches(_search) ?? true;
    }

    internal int? GetItemOrder(CommandItem item)
    {
        if (string.IsNullOrWhiteSpace(_search))
            return null;

        var entry = FindEntry(item);
        if (entry is null || !entry.Matches(_search))
            return null;

        int order = 0;
        var comparer = StringComparer.OrdinalIgnoreCase;
        bool reachedItem = false;

        foreach (CommandEntry candidate in _entries)
        {
            if (!IsSameEntryGroup(candidate.Group, entry.Group) || !candidate.Matches(_search))
                continue;

            int comparison = comparer.Compare(candidate.Item.SearchText, item.SearchText);
            if (comparison < 0)
            {
                order++;
                continue;
            }

            if (comparison == 0)
            {
                if (ReferenceEquals(candidate.Item, item))
                {
                    reachedItem = true;
                    continue;
                }

                if (!reachedItem)
                    order++;
            }
        }

        return order;
    }

    internal bool GroupHasVisibleItems(CommandGroup group)
    {
        foreach (CommandEntry entry in _entries)
        {
            if (entry.Group is null && entry.Matches(_search))
                return true;
        }

        foreach (CommandEntry entry in _entries)
        {
            if (IsSameGroup(entry.Group, group) && entry.Matches(_search))
                return true;
        }

        return false;
    }

    private static bool IsSameGroup(CommandGroup? entryGroup, CommandGroup group)
    {
        if (ReferenceEquals(entryGroup, group))
            return true;

        if (entryGroup is null)
            return false;

        return string.Equals(entryGroup.Heading, group.Heading, StringComparison.Ordinal);
    }

    private static bool IsSameEntryGroup(CommandGroup? left, CommandGroup? right)
    {
        if (ReferenceEquals(left, right))
            return true;

        if (left is null || right is null)
            return false;

        return string.Equals(left.Heading, right.Heading, StringComparison.Ordinal);
    }

    internal async Task SetSearch(string? value)
    {
        _search = value;
        _activeItem = GetFirstVisibleEntry()?.Item;
        await RefreshOffThread();
    }

    internal async Task SetActiveItem(CommandItem item)
    {
        if (!item.IsVisibleResolved || item.Disabled)
            return;

        if (!ReferenceEquals(_activeItem, item))
        {
            _activeItem = item;
            await RefreshOffThread();
        }
    }

    internal async Task HandleInputNavigation(string key)
    {
        int visibleCount = CountVisibleEntries(out int currentIndex);
        if (visibleCount == 0)
            return;

        var nextIndex = key switch
        {
            "ArrowDown" => currentIndex < 0 ? 0 : Math.Min(currentIndex + 1, visibleCount - 1),
            "ArrowUp" => currentIndex < 0 ? visibleCount - 1 : Math.Max(currentIndex - 1, 0),
            "Home" => 0,
            "End" => visibleCount - 1,
            _ => -1
        };

        if (nextIndex < 0)
            return;

        var nextEntry = GetVisibleEntryAt(nextIndex);
        if (nextEntry is null)
            return;

        _activeItem = nextEntry.Item;
        await RefreshOffThread();
    }

    internal async Task SelectActiveItem()
    {
        if (_activeItem is null || !_activeItem.IsVisibleResolved || _activeItem.Disabled)
            return;

        await _activeItem.Select();
    }

    private CommandEntry? FindEntry(CommandItem item)
    {
        foreach (CommandEntry entry in _entries)
        {
            if (ReferenceEquals(entry.Item, item))
                return entry;
        }

        return null;
    }

    private bool HasAnyVisibleEntry()
    {
        foreach (CommandEntry entry in _entries)
        {
            if (entry.Matches(_search))
                return true;
        }

        return false;
    }

    private CommandEntry? GetFirstVisibleEntry()
    {
        foreach (CommandEntry entry in _entries)
        {
            if (entry.IsVisible && !entry.IsDisabled)
                return entry;
        }

        return null;
    }

    private int CountVisibleEntries(out int activeIndex)
    {
        activeIndex = -1;
        int count = 0;

        foreach (CommandEntry entry in _entries)
        {
            if (!entry.IsVisible || entry.IsDisabled)
                continue;

            if (ReferenceEquals(entry.Item, _activeItem))
                activeIndex = count;

            count++;
        }

        return count;
    }

    private CommandEntry? GetVisibleEntryAt(int targetIndex)
    {
        int index = 0;

        foreach (CommandEntry entry in _entries)
        {
            if (!entry.IsVisible || entry.IsDisabled)
                continue;

            if (index == targetIndex)
                return entry;

            index++;
        }

        return null;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "command";

        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.IsFull;
        Width ??= Quark.Width.IsFull;
        FlexDirection ??= Quark.FlexDirection.Col;
        Overflow ??= Quark.Overflow.Hidden;
        Rounded ??= Quark.Rounded.Xl;
        Padding ??= Quark.Padding.Is1;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        TextColor ??= Quark.TextColor.PopoverForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "size-full rounded-xl!");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(_search);
        hc.Add(_activeItem?.Id);
    }
}
