@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement

<Dialog Visible="@Visible" VisibleChanged="@VisibleChanged" OnBackdropClick="@Close" Static="false">
    <DialogContent ShowCloseButton="@ShowCloseButton" Padding="Quark.Padding.Is0" Class="top-1/3 translate-y-0 overflow-hidden rounded-xl!">
        <DialogHeader Class="sr-only">
            <DialogTitle Class="sr-only">@Title</DialogTitle>
            <DialogDescription Class="sr-only">@Description</DialogDescription>
        </DialogHeader>
        <Command>
            @ChildContent
        </Command>
    </DialogContent>
</Dialog>

@code {

    [Parameter]
    public string Description { get; set; } = "Search for a command to run...";

    [Parameter]
    public bool ShowCloseButton { get; set; }

    private async Task Close()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(Visible);
    }
}
