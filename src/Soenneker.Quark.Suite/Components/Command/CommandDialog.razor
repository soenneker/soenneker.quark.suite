@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement

<Dialog Visible="@Visible" VisibleChanged="@VisibleChanged" OnBackdropClick="@Close" Static="false">
    <DialogContent ShowCloseButton="@ShowCloseButton" Padding="Quark.Padding.Is0" Top="Quark.Top.Is1of3" Overflow="Quark.Overflow.Hidden" Class="translate-y-0 rounded-xl!">
        <DialogHeader ScreenReader="Quark.ScreenReader.Only">
            <DialogTitle ScreenReader="Quark.ScreenReader.Only">@Title</DialogTitle>
            <DialogDescription ScreenReader="Quark.ScreenReader.Only">@Description</DialogDescription>
        </DialogHeader>
        <Command>
            @ChildContent
        </Command>
    </DialogContent>
</Dialog>

@code {
    public CommandDialog()
    {
        LockScroll = false;
    }

    [Parameter]
    public string Description { get; set; } = "Search for a command to run...";

    [Parameter]
    public bool ShowCloseButton { get; set; }

    private async Task Close()
    {
        Visible = false;
        await VisibleChanged.InvokeAsync(Visible);
    }
}
