@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<div @attributes="BuildWrapperAttributes()">
    <div data-slot="input-group" role="group" class="group/input-group relative flex h-8 w-full min-w-0 items-center rounded-lg border border-input/30 bg-input/30 transition-colors outline-none shadow-none! dark:bg-input/30">
        <input value="@Value" @oninput="HandleInput" @onkeydown="HandleKeyDown" @attributes="BuildAttributes()" placeholder="@Placeholder" />
        <div role="group" data-slot="input-group-addon" data-align="inline-start" class="order-first flex h-auto cursor-text items-center justify-center gap-2 py-1.5 pl-2 text-sm font-medium text-muted-foreground select-none [&>svg:not([class*='size-'])]:size-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 shrink-0 opacity-50">
                <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
            </svg>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [CascadingParameter(Name = "ParentCommand")]
    private Command? ParentCommand { get; set; }

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";

        if (ParentCommand is not null)
            await ParentCommand.SetSearchAsync(Value);

        await ValueChanged.InvokeAsync(Value);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (ParentCommand is not null && e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
            await ParentCommand.HandleInputNavigationAsync(e.Key);
        else if (ParentCommand is not null && e.Key == "Enter")
            await ParentCommand.SelectActiveItemAsync();

        await base.HandleKeyDown(e);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "command-input";
        attributes["type"] = "text";
        attributes["role"] = "combobox";
        attributes["aria-expanded"] = "true";
        attributes["aria-controls"] = ParentCommand?.ListId ?? "command-list";

        if (ParentCommand?.ActiveItemId is not null)
            attributes["aria-activedescendant"] = ParentCommand.ActiveItemId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "w-full bg-transparent text-sm outline-hidden placeholder:text-muted-foreground disabled:cursor-not-allowed disabled:opacity-50");
        });
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attrs = new Dictionary<string, object>();
        attrs["data-slot"] = "command-input-wrapper";
        BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "p-1 pb-0");
        });
        return attrs;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentCommand?.ActiveItemId);
    }
}
