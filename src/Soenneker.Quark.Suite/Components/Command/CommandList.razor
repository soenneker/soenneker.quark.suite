@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    private static readonly string _orphanListId = BlazorIdGenerator.New("quark-command-list");

    [CascadingParameter(Name = "ParentCommand")]
    private Command? ParentCommand { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        MaxHeight ??= Quark.Height.Token("72");
        OverflowX ??= Quark.Overflow.X.Hidden;
        OverflowY ??= Quark.Overflow.Y.Auto;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "command-list";
        attributes["id"] = ParentCommand?.ListId ?? _orphanListId;
        attributes["role"] = "listbox";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "no-scrollbar scroll-py-1 outline-none");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentCommand?.ListId);
    }
}
