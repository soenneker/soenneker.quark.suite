@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Value="@this" IsFixed="true">
    <Div @attributes="BuildAttributes()">
        @if (Heading.HasContent())
        {
            <Div cmdk-group-heading Padding='Quark.Padding.Is2.OnX.Token("1.5").OnY' TextSize="Quark.TextSize.Xs" FontWeight="Quark.FontWeight.Medium" TextColor="Quark.TextColor.MutedForeground">@Heading</Div>
        }

        <Div data-slot="command-group-items">
            @ChildContent
        </Div>
    </Div>
</CascadingValue>

@code {
    [Parameter]
    public string? Heading { get; set; }

    [CascadingParameter(Name = "ParentCommand")]
    private Command? ParentCommand { get; set; }

    internal bool IsVisibleResolved => ParentCommand?.GroupHasVisibleItems(this) ?? true;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Overflow ??= Quark.Overflow.Hidden;
        Padding ??= Quark.Padding.Is1;
        TextColor ??= Quark.TextColor.Foreground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "command-group";
        attributes["cmdk-group"] = string.Empty;
        attributes["role"] = "group";
        if (Heading.HasContent())
            attributes["aria-label"] = Heading!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "[&_[cmdk-group-heading]]:px-2 [&_[cmdk-group-heading]]:py-1.5 [&_[cmdk-group-heading]]:text-xs [&_[cmdk-group-heading]]:font-medium [&_[cmdk-group-heading]]:text-muted-foreground");
            AppendClass(ref cls, "not-has-[>[data-slot=command-group-items]>*]:hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Heading);
        hc.Add(IsVisibleResolved);
    }
}
