@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@inherits Soenneker.Quark.FormControlElement

<div @onclick="HandleItemClick" @onkeydown="HandleKeyDown" @onmousemove="HandleMouseMove" @attributes="BuildAttributes()" role="option" @ref="_elementRef">
    @ChildContent
    <Icon Name="LucideIcon.Check" Margin="Quark.Margin.FromLeft.Auto" Display='Quark.Display.None.Modifier("group-has-data-[slot=command-shortcut]/command-item")' Opacity='CssValue<OpacityBuilder>.For(Quark.Opacity.Is0, Quark.Opacity.Is100.Modifier("group-data-[checked=true]/command-item"))' />
</div>

@code {
    private ElementReference _elementRef;
    private string _searchText = string.Empty;

    [Parameter]
    public EventCallback OnSelect { get; set; }

    [Parameter]
    public string? SearchValue { get; set; }

    [Parameter]
    public string[]? Keywords { get; set; }

    [Parameter]
    public bool Checked { get; set; }

    [CascadingParameter(Name = "ParentCommand")]
    private Command? ParentCommand { get; set; }

    [CascadingParameter]
    private CommandGroup? ParentCommandGroup { get; set; }

    internal bool IsVisibleResolved => ParentCommand?.IsItemVisible(this) ?? true;

    internal string SearchText => _searchText;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "command-item";
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.OnX.Is2.OnY.Token("1.5");
        TextSize ??= Quark.TextSize.Sm;
        OutlineStyle ??= Quark.OutlineStyle.Hidden;
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (!Id.HasContent())
            Id = BlazorIdGenerator.New("quark-command-item");

        ParentCommand?.RegisterItem(this, ParentCommandGroup);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        _searchText = BuildSearchText();
        ParentCommand?.UpdateItemGroup(this, ParentCommandGroup);
    }

    private async Task HandleItemClick(MouseEventArgs _)
    {
        if (!Disabled && OnSelect.HasDelegate)
            await OnSelect.InvokeAsync();
    }

    private async Task HandleMouseMove(MouseEventArgs _)
    {
        if (Disabled || ParentCommand is null)
            return;

        await ParentCommand.SetActiveItem(this);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await Select();
        else if (ParentCommand is not null && e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
            await ParentCommand.HandleInputNavigation(e.Key);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["cmdk-item"] = string.Empty;
        attributes["id"] = Id!;
        attributes["tabindex"] = Disabled ? -1 : -1;
        var selected = ParentCommand?.IsItemActive(this) == true;
        attributes["aria-selected"] = selected ? "true" : "false";
        attributes["data-selected"] = selected ? "true" : "false";
        if (!IsVisibleResolved)
            attributes["hidden"] = string.Empty;
        attributes["data-value"] = SearchText;
        attributes["data-disabled"] = Disabled ? "true" : "false";
        attributes["data-checked"] = Checked ? "true" : "false";
        if (Disabled)
            attributes["aria-disabled"] = "true";

        if (ParentCommand?.GetItemOrder(this) is { } order)
            BuildStyleAttribute(attributes, (ref sty) => AppendStyleDecl(ref sty, "order: ", order.ToString()));

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/command-item in-data-[slot=dialog-content]:rounded-lg!");
            AppendClass(ref cls, "data-[disabled=true]:pointer-events-none data-[disabled=true]:opacity-50");
            AppendClass(ref cls, "data-selected:bg-muted data-selected:text-foreground");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 data-selected:*:[svg]:text-foreground");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(IsVisibleResolved);
        hc.Add(ParentCommand?.IsItemActive(this));
        hc.Add(ParentCommand?.GetItemOrder(this));
        hc.Add(SearchValue);
        if (Keywords is not null)
        {
            foreach (string keyword in Keywords)
                hc.Add(keyword);
        }

        hc.Add(Checked);
    }

    private string BuildSearchText()
    {
        bool hasSearchValue = !string.IsNullOrWhiteSpace(SearchValue);
        int keywordCount = Keywords?.Length ?? 0;

        if (!hasSearchValue && keywordCount == 0)
            return string.Empty;

        if (keywordCount == 0)
            return SearchValue!;

        int length = hasSearchValue ? SearchValue!.Length : 0;
        int parts = hasSearchValue ? 1 : 0;

        foreach (string keyword in Keywords!)
        {
            if (string.IsNullOrWhiteSpace(keyword))
                continue;

            length += keyword.Length;
            parts++;
        }

        if (parts == 0)
            return string.Empty;

        length += parts - 1;
        return string.Create(length, (SearchValue, Keywords, hasSearchValue), static (span, state) =>
        {
            int position = 0;
            bool wrotePart = false;

            if (state.hasSearchValue)
            {
                state.SearchValue.AsSpan().CopyTo(span);
                position += state.SearchValue!.Length;
                wrotePart = true;
            }

            foreach (string keyword in state.Keywords!)
            {
                if (string.IsNullOrWhiteSpace(keyword))
                    continue;

                if (wrotePart)
                    span[position++] = ' ';

                keyword.AsSpan().CopyTo(span[position..]);
                position += keyword.Length;
                wrotePart = true;
            }
        });
    }

    internal async Task Focus()
    {
        await _elementRef.FocusAsync();
    }

    internal async Task Select()
    {
        if (!Disabled && OnSelect.HasDelegate)
            await OnSelect.InvokeAsync();
    }

    public override void Dispose()
    {
        ParentCommand?.UnregisterItem(this);
        base.Dispose();
    }
}
