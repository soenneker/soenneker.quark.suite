@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@* Content is rendered by parent ContextMenu when open *@

@code {
    [CascadingParameter(Name = "ParentContextMenu")]
    private ContextMenu? ParentContextMenu { get; set; }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ParentContextMenu is not null && ChildContent is not null)
            ParentContextMenu.RegisterContent(ChildContent);
    }
}
