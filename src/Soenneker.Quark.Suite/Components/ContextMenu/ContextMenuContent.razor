@using Soenneker.Bradix
@using System.Collections.Generic

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixContextMenuPortal>
    <BradixContextMenuContent ForceMount="@ForceMount"
                              SideOffset="@SideOffset"
                              AlignOffset="@AlignOffset"
                              ArrowPadding="@ArrowPadding"
                              AvoidCollisions="@AvoidCollisions"
                              CollisionPadding="@CollisionPadding"
                              CollisionBoundarySelector="@CollisionBoundarySelector"
                              CollisionBoundarySelectors="@CollisionBoundarySelectors"
                              Sticky="@Sticky"
                              HideWhenDetached="@HideWhenDetached"
                              AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixContextMenuContent>
</BradixContextMenuPortal>

@code {
    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public double SideOffset { get; set; } = 2;

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        OverflowX ??= Quark.Overflow.X.Hidden;
        OverflowY ??= Quark.Overflow.Y.Auto;
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is1;
        TextColor ??= Quark.TextColor.PopoverForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "context-menu-content";
        attributes["data-side"] = "bottom";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "z-50 max-h-(--radix-context-menu-content-available-height) min-w-[8rem] origin-(--radix-context-menu-content-transform-origin) shadow-md");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
        });
    }
}
