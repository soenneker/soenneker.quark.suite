@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @onmouseenter="HandleOpen" @onclick="HandleOpen" @attributes="BuildAttributes()">
    @ChildContent
    <Icon Name="chevron-right" Class="ml-auto size-4" />
</div>

@code {
    [Parameter]
    public bool Open { get; set; }

    [CascadingParameter(Name = "ParentContextMenuSub")]
    private ContextMenuSub? ParentContextMenuSub { get; set; }

    private void HandleOpen()
    {
        ParentContextMenuSub?.OpenSubmenu();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        var isOpen = Open || ParentContextMenuSub?.Open == true;
        attributes["data-slot"] = "context-menu-sub-trigger";
        attributes["data-state"] = isOpen ? "open" : "closed";
        // if (Inset)
        //     attributes["data-inset"] = "true";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-context-menu-sub-trigger");
            AppendClass(ref cls, "flex cursor-default items-center rounded-sm px-2 py-1.5 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[inset]:pl-8 data-[state=open]:bg-accent data-[state=open]:text-accent-foreground");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Inset);
        hc.Add(Open);
        hc.Add(ParentContextMenuSub?.Open ?? false);
    }
}
