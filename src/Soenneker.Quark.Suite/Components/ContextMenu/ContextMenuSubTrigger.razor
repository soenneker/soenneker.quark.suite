@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<BradixContextMenuSubTrigger Disabled="@Disabled"
                             AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <Icon Name="LucideIcon.ChevronRight" Class="ml-auto size-4" />
</BradixContextMenuSubTrigger>

@code {
    [Parameter]
    public bool Indented { get; set; }

    [Parameter]
    public bool Open { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is1.Token("1.5");
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Is2.OnX.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        OutlineStyle ??= "outline-hidden";
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        var isOpen = Open;
        attributes["data-slot"] = "context-menu-sub-trigger";
        attributes["data-state"] = isOpen ? "open" : "closed";
        if (Indented)
            attributes["data-inset"] = "true";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[inset]:pl-8 data-[state=open]:bg-accent data-[state=open]:text-accent-foreground");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Indented);
        hc.Add(Open);
    }
}
