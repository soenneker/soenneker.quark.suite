@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixContextMenuSub Open="@Open"
                      DefaultOpen="@DefaultOpen"
                      OpenChanged="@OpenChanged"
                      OnOpenChange="@OnOpenChange"
                      AdditionalAttributes="@SubAttributes">
    @ChildContent
</BradixContextMenuSub>

@code {
    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public EventCallback<bool> OnOpenChange { get; set; }

    private IReadOnlyDictionary<string, object> SubAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "context-menu-sub";
    }
}
