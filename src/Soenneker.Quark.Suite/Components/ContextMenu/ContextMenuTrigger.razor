@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixContextMenuTrigger Disabled="false"
                          AdditionalAttributes="@TriggerAttributes">
    @ChildContent
</BradixContextMenuTrigger>

@code {
    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "context-menu-trigger";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-context-menu-trigger");
            AppendClass(ref cls, "cursor-context-menu");
        });
    }

}
