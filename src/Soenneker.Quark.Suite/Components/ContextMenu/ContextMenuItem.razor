@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IContextMenuFocusableItem

<div @onclick="OnClickHandler" @onkeydown="HandleMenuKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onkeydown:stopPropagation="_stopPropagation" @attributes="BuildAttributes()" @ref="_elementRef">
    @ChildContent
</div>

@code {
    private ElementReference _elementRef;
    private bool _preventDefaultKeys;
    private bool _stopPropagation;

    [Parameter]
    public bool Inset { get; set; }

    [Parameter]
    public string Variant { get; set; } = "default";

    [Parameter]
    public EventCallback<MouseEventArgs> Clicked { get; set; }

    [CascadingParameter(Name = "ParentContextMenu")]
    private ContextMenu? ParentContextMenu { get; set; }

    [CascadingParameter(Name = "ContextMenuNavigationSub")]
    private ContextMenuSub? NavigationSub { get; set; }

    bool IContextMenuFocusableItem.IsDisabledForNavigation => Disabled;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (NavigationSub is not null)
            NavigationSub.RegisterItem(this);
        else
            ParentContextMenu?.RegisterItem(this);
    }

    private async Task OnClickHandler(MouseEventArgs e)
    {
        if (Disabled)
            return;

        await Clicked.InvokeIfHasDelegate(e);

        if (ParentContextMenu is not null)
            await ParentContextMenu.CloseAsync();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var variant = Variant.Equals("destructive", StringComparison.OrdinalIgnoreCase) ? "destructive" : "default";
        attributes["data-slot"] = "context-menu-item";
        attributes["data-variant"] = variant;
        attributes["role"] = "menuitem";
        attributes["tabindex"] = -1;
        if (Inset)
            attributes["data-inset"] = "true";
        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["aria-disabled"] = "true";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-context-menu-item");
            AppendClass(ref cls, "relative flex cursor-default items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50 data-[inset]:pl-8 rtl:data-[inset]:pl-2 rtl:data-[inset]:pr-8");
            AppendClass(ref cls, "data-[variant=destructive]:text-destructive data-[variant=destructive]:focus:bg-destructive/10 data-[variant=destructive]:focus:text-destructive dark:data-[variant=destructive]:focus:bg-destructive/20");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground data-[variant=destructive]:*:[svg]:text-destructive!");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(Inset);
        hc.Add(Variant);
    }

    private async Task HandleMenuKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;
        _stopPropagation = false;

        if (ParentContextMenu is null)
            return;

        if (e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
        {
            if (NavigationSub is not null)
            {
                await NavigationSub.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
            else
            {
                await ParentContextMenu.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
        }
        else if (e.Key is "Enter" or " ")
        {
            await OnClickHandler(new MouseEventArgs());
            _preventDefaultKeys = true;
        }
        else if (e.Key == "ArrowLeft" && NavigationSub is not null)
        {
            await NavigationSub.CloseAndFocusTriggerAsync();
            _preventDefaultKeys = true;
        }
        else if (e.Key == "Escape")
        {
            if (NavigationSub is not null)
                await NavigationSub.CloseAndFocusTriggerAsync();
            else
                await ParentContextMenu.CloseAsync();

            _preventDefaultKeys = true;
            _stopPropagation = true;
        }
    }

    async Task IContextMenuFocusableItem.FocusAsync()
    {
        await _elementRef.FocusAsync();
    }
}
