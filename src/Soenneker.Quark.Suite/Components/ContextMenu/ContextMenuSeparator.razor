@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixContextMenuSeparator AdditionalAttributes="@SeparatorAttributes" />

@code {
    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "context-menu-separator";
        Margin ??= Quark.Margin.Token("-1").OnX.Is1.OnY;
        Height ??= Quark.Height.IsPx;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");

    }
}