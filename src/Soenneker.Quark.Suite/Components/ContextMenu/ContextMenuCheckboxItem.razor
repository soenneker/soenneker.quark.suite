@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements IContextMenuFocusableItem

<div @onclick="OnClickHandler" @onkeydown="HandleMenuKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onkeydown:stopPropagation="_stopPropagation" @attributes="BuildAttributes()" @ref="_elementRef">
    <span class="pointer-events-none absolute left-2 flex size-3.5 items-center justify-center rtl:left-auto rtl:right-2">
        @if (Checked)
        {
            <Icon Name="LucideIcon.Check" Class="size-4" />
        }
    </span>
    @ChildContent
</div>

@code {
    private ElementReference _elementRef;
    private bool _preventDefaultKeys;
    private bool _stopPropagation;

    [CascadingParameter(Name = "ParentContextMenu")]
    private ContextMenu? ParentContextMenu { get; set; }

    [CascadingParameter(Name = "ContextMenuNavigationSub")]
    private ContextMenuSub? NavigationSub { get; set; }

    bool IContextMenuFocusableItem.IsDisabledForNavigation => Disabled;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (NavigationSub is not null)
            NavigationSub.RegisterItem(this);
        else
            ParentContextMenu?.RegisterItem(this);
    }

    private async Task OnClickHandler()
    {
        if (Disabled)
            return;

        var next = !Checked;
        Checked = next;
        await CheckedChanged.InvokeIfHasDelegate(next);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "context-menu-checkbox-item";
        attributes["data-state"] = Checked ? "checked" : "unchecked";
        attributes["role"] = "menuitemcheckbox";
        attributes["aria-checked"] = Checked ? "true" : "false";
        attributes["tabindex"] = -1;
        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["aria-disabled"] = "true";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-context-menu-checkbox-item");
            AppendClass(ref cls, "relative flex cursor-default items-center gap-2 rounded-sm py-1.5 pr-2 pl-8 rtl:pr-8 rtl:pl-2 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
    }

    private async Task HandleMenuKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;
        _stopPropagation = false;

        if (ParentContextMenu is null)
            return;

        if (e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
        {
            if (NavigationSub is not null)
            {
                await NavigationSub.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
            else
            {
                await ParentContextMenu.HandleItemNavigationAsync(this, e.Key);
                _preventDefaultKeys = true;
            }
        }
        else if (e.Key is "Enter" or " ")
        {
            await OnClickHandler();
            _preventDefaultKeys = true;
        }
        else if (e.Key == "ArrowLeft" && NavigationSub is not null)
        {
            await NavigationSub.CloseAndFocusTriggerAsync();
            _preventDefaultKeys = true;
        }
        else if (e.Key == "Escape")
        {
            if (NavigationSub is not null)
                await NavigationSub.CloseAndFocusTriggerAsync();
            else
                await ParentContextMenu.CloseAsync();

            _preventDefaultKeys = true;
            _stopPropagation = true;
        }
    }

    async Task IContextMenuFocusableItem.FocusAsync()
    {
        await _elementRef.FocusAsync();
    }
}
