@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement

<BradixContextMenuCheckboxItem Checked="@ResolvedCheckedState"
                               CheckedChanged="HandleCheckedStateChanged"
                               Disabled="@Disabled"
                               AdditionalAttributes="@CheckboxAttributes">
    <span class="pointer-events-none absolute left-2 flex size-3.5 items-center justify-center rtl:left-auto rtl:right-2">
        <BradixMenuItemIndicator>
            <Icon Name="LucideIcon.Check" Class="size-4" />
        </BradixMenuItemIndicator>
    </span>
    @ChildContent
</BradixContextMenuCheckboxItem>

@code {
    private BradixCheckboxCheckedState ResolvedCheckedState =>
        Checked ? BradixCheckboxCheckedState.Checked : BradixCheckboxCheckedState.Unchecked;

    private IReadOnlyDictionary<string, object> CheckboxAttributes => BuildCheckboxAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "context-menu-checkbox-item";
        attributes["data-state"] = Checked ? "checked" : "unchecked";
        attributes["aria-checked"] = Checked ? "true" : "false";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-context-menu-checkbox-item");
            AppendClass(ref cls, "relative flex cursor-default items-center gap-2 rounded-sm py-1.5 pr-2 pl-8 rtl:pr-8 rtl:pl-2 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    private IReadOnlyDictionary<string, object> BuildCheckboxAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("tabindex");
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
    }

    private async Task HandleCheckedStateChanged(BradixCheckboxCheckedState state)
    {
        bool next = state == BradixCheckboxCheckedState.Checked;
        Checked = next;
        await CheckedChanged.InvokeIfHasDelegate(next);
    }
}
