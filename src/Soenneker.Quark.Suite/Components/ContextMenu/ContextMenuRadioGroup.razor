@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixContextMenuRadioGroup AdditionalAttributes="@RadioGroupAttributes">
    @ChildContent
</BradixContextMenuRadioGroup>

@code {
    private IReadOnlyDictionary<string, object> RadioGroupAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "context-menu-radio-group";
    }
}
