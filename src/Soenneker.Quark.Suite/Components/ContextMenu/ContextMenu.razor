@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="ParentContextMenu" Value="@this" IsFixed="true">
    @ChildContent
</CascadingValue>

@if (Open)
{
    <div class="fixed inset-0 z-[109]" aria-hidden="true" @onclick="CloseAsync"></div>
    <div @attributes="BuildContentAttributes()" @onclick:stopPropagation="true" @onkeydown="HandleContentKeyDown" @onkeydown:preventDefault="_contentKeyPreventDefault" @onkeydown:stopPropagation="_contentKeyStopPropagation">
        @_content
    </div>
}

@code {
    private readonly List<IContextMenuFocusableItem> _items = [];
    private ElementReference _triggerElement;
    private bool _hasTriggerElement;
    private bool _contentKeyPreventDefault;
    private bool _contentKeyStopPropagation;

    internal string TriggerId { get; } = $"ctx-menu-trigger-{Guid.NewGuid():N}";

    internal string MenuContentId { get; } = $"ctx-menu-panel-{Guid.NewGuid():N}";

    internal bool Open { get; set; }
    internal double X { get; set; }
    internal double Y { get; set; }
    internal RenderFragment? _content;

    internal void RegisterContent(RenderFragment content) => _content = content;

    internal async Task ShowAsync(double x, double y)
    {
        X = x;
        Y = y;
        Open = true;
        InvalidateRender();
        await RefreshOffThread();

        var firstItem = _items.FirstOrDefault(i => !i.IsDisabledForNavigation);
        if (firstItem is not null)
            await firstItem.FocusAsync();
    }

    internal void RegisterTriggerElement(ElementReference elementReference)
    {
        _triggerElement = elementReference;
        _hasTriggerElement = true;
    }

    internal async Task FocusTriggerAsync()
    {
        if (!_hasTriggerElement)
            return;

        try
        {
            await _triggerElement.FocusAsync();
        }
        catch
        {
        }
    }

    internal async Task CloseAsync()
    {
        if (!Open)
            return;

        Open = false;
        InvalidateRender();
        await RefreshOffThread();
        await FocusTriggerAsync();
    }

    /// <summary>
    /// Clears focusable item order before children re-register in DOM order each render.
    /// </summary>
    protected override void OnParametersSet()
    {
        _items.Clear();
        base.OnParametersSet();
    }

    internal void RegisterItem(IContextMenuFocusableItem item)
    {
        if (_items.Contains(item))
            return;

        _items.Add(item);
    }

    internal async Task HandleItemNavigationAsync(IContextMenuFocusableItem currentItem, string key)
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
            return;

        var currentIndex = enabledItems.FindIndex(i => ReferenceEquals(i, currentItem));
        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledItems.Count - 1,
            "ArrowDown" => (currentIndex + 1) % enabledItems.Count,
            "ArrowUp" => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            _ => -1
        };

        if (nextIndex >= 0)
            await enabledItems[nextIndex].FocusAsync();
    }

    private Dictionary<string, object> BuildContentAttributes()
    {
        var attrs = new Dictionary<string, object>();
        attrs["data-state"] = Open ? "open" : "closed";
        attrs["data-side"] = "bottom";
        attrs["data-slot"] = "context-menu-content";
        attrs["id"] = MenuContentId;
        attrs["role"] = "menu";
        attrs["aria-orientation"] = "vertical";
        attrs["aria-hidden"] = "false";
        attrs["tabindex"] = -1;

        if (!attrs.ContainsKey("aria-labelledby"))
            attrs["aria-labelledby"] = TriggerId;

        attrs["style"] = $"position: fixed; left: {X}px; top: {Y}px;";
        BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "q-context-menu-content");
            AppendClass(ref cls, "z-[110] max-h-(--radix-context-menu-content-available-height) min-w-[8rem] origin-(--radix-context-menu-content-transform-origin) overflow-x-hidden overflow-y-auto rounded-md border bg-popover p-1 text-popover-foreground shadow-md");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
        });
        return attrs;
    }

    private async Task HandleContentKeyDown(KeyboardEventArgs e)
    {
        _contentKeyPreventDefault = false;
        _contentKeyStopPropagation = false;

        if (e.Key != "Escape")
            return;

        _contentKeyPreventDefault = true;
        _contentKeyStopPropagation = true;
        await CloseAsync();
    }
}
