@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixContextMenuGroup AdditionalAttributes="@GroupAttributes">
    @ChildContent
</BradixContextMenuGroup>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "context-menu-group";
    }

    private IReadOnlyDictionary<string, object> GroupAttributes => BuildAttributes();
}