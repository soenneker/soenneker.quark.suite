@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IFieldset

<fieldset @attributes="BuildAttributes()">
	@ChildContent
</fieldset>

@code {

    /// <summary>
    /// Gets or sets the form attribute value, which associates the fieldset with a form.
    /// </summary>
    [Parameter]
    public string? Form { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "field-set";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-fieldset");
            AppendClass(ref cls, "flex flex-col gap-6");
            AppendClass(ref cls, "has-[>[data-slot=checkbox-group]]:gap-3 has-[>[data-slot=radio-group]]:gap-3");
            AppendClass(ref cls, "has-[>[role=checkbox]]:gap-3 has-[>[role=radio]]:gap-3");
        });

        if (Disabled)
            attributes["disabled"] = true;

        if (Form.HasContent())
            attributes["form"] = Form;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Disabled);
        hc.Add(Form);
    }
}