@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Microsoft.AspNetCore.Components.Web

@if (ParentCollapsible is not null)
{
    <div @onkeydown="HandleContentKeyDown"
         @onkeydown:preventDefault="_contentEscapePreventDefault"
         @onkeydown:stopPropagation="_contentEscapeStopPropagation"
         @attributes="BuildAttributes()">
        @if (ParentCollapsible.Open)
        {
            @ChildContent
        }
    </div>
}

@code {
    private bool _contentEscapePreventDefault;
    private bool _contentEscapeStopPropagation;

    [CascadingParameter(Name = nameof(ParentCollapsible))]
    public Collapsible? ParentCollapsible { get; set; }

    /// <summary>When <c>true</c> (default), Escape collapses the panel (Radix/shadcn-style; helps when focus is inside the region).</summary>
    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    /// <summary>When <c>true</c> (default), after Escape closes the panel, focus returns to the trigger (requires a registered trigger element).</summary>
    [Parameter]
    public bool RestoreFocusToTriggerOnEscape { get; set; } = true;

    private async Task HandleContentKeyDown(KeyboardEventArgs e)
    {
        _contentEscapePreventDefault = false;
        _contentEscapeStopPropagation = false;

        if (!CloseOnEscape || e.Key != "Escape" || ParentCollapsible is null || ParentCollapsible.Disabled || !ParentCollapsible.Open)
            return;

        _contentEscapePreventDefault = true;
        _contentEscapeStopPropagation = true;
        await ParentCollapsible.SetOpen(false, RestoreFocusToTriggerOnEscape);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var open = ParentCollapsible?.Open == true;
        attributes["data-slot"] = "collapsible-content";
        attributes["data-state"] = open ? "open" : "closed";
        attributes["aria-hidden"] = open ? "false" : "true";

        if (ParentCollapsible is not null)
        {
            attributes["id"] = ParentCollapsible.ContentId;
            attributes["role"] = "region";
            attributes["aria-labelledby"] = ParentCollapsible.TriggerId;
            if (ParentCollapsible.Disabled)
                attributes["data-disabled"] = "true";
        }

        if (!open)
        {
            attributes["hidden"] = true;
            attributes["inert"] = true;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-collapsible-content overflow-hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentCollapsible?.Open == true);
        hc.Add(ParentCollapsible?.Disabled == true);
        hc.Add(ParentCollapsible?.TriggerId);
        hc.Add(CloseOnEscape);
        hc.Add(RestoreFocusToTriggerOnEscape);
    }
}
