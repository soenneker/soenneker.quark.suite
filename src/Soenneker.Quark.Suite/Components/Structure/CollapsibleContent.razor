@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

@if (Collapsible is not null)
{
    <BradixCollapsibleContent ForceMount="@ForceMount"
                              AriaLabelledBy="@Collapsible.TriggerId"
                              AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixCollapsibleContent>
}

@code {
    [Parameter]
    public bool ForceMount { get; set; }

    [CascadingParameter]
    private BradixCollapsible? Collapsible { get; set; }

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("id");
        attributes.Remove("role");
        attributes.Remove("aria-labelledby");
        attributes.Remove("hidden");
        attributes.Remove("data-state");

        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "collapsible-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-collapsible-content overflow-hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ForceMount);
        hc.Add(Collapsible?.IsOpen == true);
        hc.Add(Collapsible?.Disabled == true);
        hc.Add(Collapsible?.ContentId);
    }
}
