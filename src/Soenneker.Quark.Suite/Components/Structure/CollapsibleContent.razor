@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (ParentCollapsible is not null)
{
    <div @attributes="BuildAttributes()">
        @if (ParentCollapsible.Open)
        {
            @ChildContent
        }
    </div>
}

@code {
    [CascadingParameter(Name = nameof(ParentCollapsible))]
    public Collapsible? ParentCollapsible { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var open = ParentCollapsible?.Open == true;
        attributes["data-slot"] = "collapsible-content";
        attributes["data-state"] = open ? "open" : "closed";

        if (ParentCollapsible is not null)
        {
            attributes["id"] = ParentCollapsible.ContentId;
            attributes["role"] = "region";
            attributes["aria-labelledby"] = ParentCollapsible.TriggerId;
            if (ParentCollapsible.Disabled)
                attributes["data-disabled"] = "true";
        }

        if (!open)
            attributes["hidden"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-collapsible-content overflow-hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentCollapsible?.Open == true);
        hc.Add(ParentCollapsible?.Disabled == true);
        hc.Add(ParentCollapsible?.TriggerId);
    }
}
