@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixCollapsibleTrigger Disabled="@Disabled"
                              OnClick="@OnClick"
                              AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixCollapsibleTrigger>
}

@code {
    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [CascadingParameter]
    private BradixCollapsible? Collapsible { get; set; }

    [CascadingParameter(Name = SlotAttributes.Name)]
    private IReadOnlyDictionary<string, object>? SlotAttributeOverrides { get; set; }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = Collapsible?.TriggerId,
            ParentDisabled = Collapsible?.Disabled == true,
            IsOpen = Collapsible?.IsOpen == true,
            DataState = Collapsible?.IsOpen == true ? "open" : "closed",
            AriaControls = Collapsible?.ContentId,
            Toggle = Collapsible is null ? null : () => Collapsible.Toggle(),
            Open = Collapsible is null ? null : () => Collapsible.SetOpen(true),
            Close = Collapsible is null ? null : () => Collapsible.SetOpen(false)
        };
    }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        AlignUtility ??= Quark.Align.ItemsCenter.JustifyBetween;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Transition ??= Quark.Transition.Colors;
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("disabled");
        attributes.Remove("id");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("data-state");
        attributes.Remove("onclick");

        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "collapsible-trigger";
        attributes["data-state"] = Collapsible?.IsOpen == true ? "open" : "closed";
        attributes["aria-expanded"] = Collapsible?.IsOpen == true ? "true" : "false";
        if (Collapsible is not null)
        {
            attributes["id"] = Collapsible.TriggerId;
            attributes["aria-controls"] = Collapsible.ContentId;
        }

        if (Disabled || Collapsible?.Disabled == true)
        {
            attributes["data-disabled"] = "true";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50");
            if (Disabled || Collapsible?.Disabled == true)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });

        if (AsChild)
            SlotAttributes.MergeInto(attributes, SlotAttributeOverrides);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(AsChild);
        hc.Add(Collapsible?.IsOpen == true);
        hc.Add(Collapsible?.Disabled == true);
        hc.Add(Collapsible?.TriggerId);
        hc.Add(SlotAttributeOverrides?.Count ?? 0);
    }
}
