@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <button type="button" @onclick="OnTriggerClick" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [CascadingParameter(Name = nameof(ParentCollapsible))]
    public Collapsible? ParentCollapsible { get; set; }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = ParentCollapsible?.TriggerId,
            IsOpen = ParentCollapsible?.Open == true,
            DataState = ParentCollapsible?.Open == true ? "open" : "closed",
            AriaControls = ParentCollapsible?.ContentId,
            Toggle = ParentCollapsible is null ? null : () => ParentCollapsible.Toggle(),
            Open = ParentCollapsible is null ? null : () => ParentCollapsible.SetOpen(true),
            Close = ParentCollapsible is null ? null : () => ParentCollapsible.SetOpen(false)
        };
    }

    private async Task OnTriggerClick(MouseEventArgs args)
    {
        if (Disabled || ParentCollapsible?.Disabled == true)
            return;

        if (ParentCollapsible is not null)
            await ParentCollapsible.Toggle();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "collapsible-trigger";
        attributes["data-state"] = ParentCollapsible?.Open == true ? "open" : "closed";
        attributes["aria-expanded"] = ParentCollapsible?.Open == true ? "true" : "false";
        if (ParentCollapsible is not null)
        {
            attributes["id"] = ParentCollapsible.TriggerId;
            attributes["aria-controls"] = ParentCollapsible.ContentId;
        }

        if (Disabled || ParentCollapsible?.Disabled == true)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-collapsible-trigger flex w-full items-center justify-between gap-2 rounded-md text-sm font-medium transition-colors");
            AppendClass(ref cls, "focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50");
            if (Disabled || ParentCollapsible?.Disabled == true)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(AsChild);
        hc.Add(ParentCollapsible?.Open == true);
        hc.Add(ParentCollapsible?.Disabled == true);
    }
}
