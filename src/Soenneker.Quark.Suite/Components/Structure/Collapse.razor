@namespace Soenneker.Quark

@inherits Soenneker.Quark.Element
@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids
@implements ICollapse
@inject ICollapseCoordinator CollapseCoordinator

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    /// <summary>
    /// Gets or sets whether the collapse is expanded.
    /// </summary>
    [Parameter]
    public bool Expanded { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the expanded state changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> OnExpandedChanged { get; set; }

    /// <summary>
    /// Gets or sets whether the collapse should expand horizontally.
    /// </summary>
    [Parameter]
    public bool Horizontal { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();

        if (Id.IsNullOrEmpty())
            Id = BlazorIdGenerator.New("quark-collapse");

        await CollapseCoordinator.Register(this);
    }

    public async Task Toggle()
    {
        Expanded = !Expanded;

        InvalidateRender();
        Refresh();

        await OnExpandedChanged.InvokeIfHasDelegate(Expanded);
    }

    public async Task Show()
    {
        if (Expanded)
            return;

        Expanded = true;

        InvalidateRender();
        Refresh();

        await OnExpandedChanged.InvokeIfHasDelegate(Expanded);

    }

    public async Task Hide()
    {
        if (!Expanded)
            return;

        Expanded = false;

        InvalidateRender();
        Refresh();

        await OnExpandedChanged.InvokeIfHasDelegate(Expanded);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-collapse");
            AppendClass(ref cls, "overflow-hidden transition-all duration-200 ease-in-out");
            if (!Expanded)
                AppendClass(ref cls, Horizontal ? "max-w-0" : "max-h-0");
        });

        attributes["id"] = Id!;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Expanded);
        hc.Add(Horizontal);
        hc.Add(Id);
    }

    internal bool HasCssClass(string className)
    {
        if (className.IsNullOrEmpty())
            return false;

        if (ClassContainsToken(Class, className))
            return true;

        if (Attributes is not null && Attributes.TryGetValue("class", out var classObj))
            return ClassContainsToken(classObj?.ToString(), className);

        return false;
    }

    private static bool ClassContainsToken(string? classes, string token)
    {
        if (classes.IsNullOrWhiteSpace())
            return false;

        var values = classes.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        foreach (var value in values)
        {
            if (string.Equals(value, token, StringComparison.Ordinal))
                return true;
        }

        return false;
    }

    protected override async ValueTask OnDisposeAsync()
    {
        await CollapseCoordinator.Unregister(this);
    }
}