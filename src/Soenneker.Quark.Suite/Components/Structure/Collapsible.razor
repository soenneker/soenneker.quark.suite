@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

<BradixCollapsible Open="@Open"
                   Disabled="@Disabled"
                   OpenChanged="HandleOpenChanged"
                   AdditionalAttributes="@RootAttributes">
    @ChildContent
</BradixCollapsible>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }
    private IReadOnlyDictionary<string, object> RootAttributes => BuildRootAttributes();

    private Task HandleOpenChanged(bool open)
    {
        Open = open;
        InvalidateRender();
        Refresh();
        return OpenChanged.InvokeAsync(open);
    }

    private IReadOnlyDictionary<string, object> BuildRootAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("id");
        attributes.Remove("disabled");
        attributes.Remove("data-disabled");
        attributes.Remove("data-state");

        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "collapsible";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-collapsible");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Disabled);
    }
}
