@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

<BradixCollapsible Open="@Open"
                   DefaultOpen="@DefaultOpen"
                   Disabled="@Disabled"
                   OpenChanged="HandleOpenChanged"
                   AdditionalAttributes="@RootAttributes">
    @ChildContent
</BradixCollapsible>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "collapsible";
    }

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }
    private IReadOnlyDictionary<string, object> RootAttributes => BuildAttributes();

    private Task HandleOpenChanged(bool open)
    {
        return OpenChanged.InvokeAsync(open);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(DefaultOpen);
        hc.Add(Disabled);
    }
}