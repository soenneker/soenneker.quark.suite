@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Blazor.Extensions.EventCallback

<CascadingValue Name="ParentCollapsible" Value="this">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private string? _generatedId;

    internal string ResolvedId => Id.HasContent() ? Id! : _generatedId ??= $"collapsible-{Guid.NewGuid():N}";
    internal string TriggerId => $"{ResolvedId}-trigger";
    internal string ContentId => $"{ResolvedId}-content";

    internal async Task Toggle()
    {
        if (Disabled)
            return;

        await SetOpen(!Open);
    }

    internal async Task SetOpen(bool open)
    {
        if (Disabled || Open == open)
            return;

        Open = open;
        InvalidateRender();
        Refresh();
        await OpenChanged.InvokeIfHasDelegate(Open);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "collapsible";
        attributes["data-state"] = Open ? "open" : "closed";

        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-collapsible");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Disabled);
    }
}
