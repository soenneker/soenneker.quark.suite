@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements Soenneker.Quark.IValidationInput
@implements IRadio
@implements IDisposable
<div @attributes="BuildWrapperAttributes()">
    <label @attributes="BuildLabelAttributes()">
        <button
            id="@ControlId"
            type="button"
            role="radio"
            aria-checked="@EffectiveChecked.ToString().ToLowerInvariant()"
            aria-disabled="@EffectiveDisabled.ToString().ToLowerInvariant()"
            data-state="@(EffectiveChecked ? "checked" : "unchecked")"
            disabled="@EffectiveDisabled"
            tabindex="@TabStopIndex"
            @onclick="HandleClick"
            @onkeydown="HandleKeyDown"
            @onkeydown:preventDefault="_preventDefault"
            @ref="_elementRef"
            @attributes="BuildIndicatorAttributes()">
            @if (EffectiveChecked)
            {
                <span class="absolute top-1/2 left-1/2 size-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary"></span>
            }
        </button>
        @if (ChildContent != null)
        {
            @ChildContent
        }
    </label>
</div>

@code {
    /// <summary>
    /// Gets or sets the callback invoked When the radio state changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    [CascadingParameter(Name = "ParentRadioGroup")]
    public RadioGroup? ParentRadioGroup { get; set; }

    [CascadingParameter]
    private FieldContext? FieldContext { get; set; }

    private FieldContext? _subscribedFieldContext;
    private ElementReference _elementRef;
    private bool _preventDefault;

    /// <summary>
    /// When inside RadioGroup, reflects group value; otherwise uses Checked.
    /// </summary>
    private bool EffectiveChecked => ParentRadioGroup != null
        ? string.Equals(ParentRadioGroup.Value, Value, StringComparison.Ordinal)
        : Checked;

    /// <summary>
    /// When inside RadioGroup, true if group or this radio is disabled.
    /// </summary>
    private bool EffectiveDisabled => ParentRadioGroup?.Disabled == true || Disabled;

    private string ControlId => ParentRadioGroup is null && FieldContext is not null ? FieldContext.ControlId : Id!;

    private int TabStopIndex => EffectiveDisabled ? -1 : ParentRadioGroup?.IsTabStop(this) == false ? -1 : 0;

    /// <summary>
    /// Gets or sets the size of the radio.
    /// </summary>
    [Parameter]
    public CssValue<SizeBuilder>? Size { get; set; } = Quark.Size.Default;

    /// <summary>
    /// Gets or sets whether the radio should be displayed inline.
    /// </summary>
    [Parameter]
    public bool Inline { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// </summary>
    public object? ValidationValue => Checked;

    protected override void OnInitialized()
    {
        if (Id.IsNullOrEmpty())
            Id = $"radio_{Guid.NewGuid():N}";

        ParentRadioGroup?.RegisterRadio(this);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!ReferenceEquals(_subscribedFieldContext, FieldContext))
        {
            if (_subscribedFieldContext is not null)
                _subscribedFieldContext.StateChanged -= OnFieldContextStateChanged;

            _subscribedFieldContext = FieldContext;

            if (_subscribedFieldContext is not null)
                _subscribedFieldContext.StateChanged += OnFieldContextStateChanged;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);

            if (CheckedExpression is not null)
                await ParentValidation.InitializeInputExpression(CheckedExpression);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnFieldContextStateChanged()
    {
        await RefreshOffThread();
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        attributes["data-slot"] = "radio-group-item";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-radio");
            AppendClass(ref cls, "flex items-center gap-2");
            if (Inline)
                AppendClass(ref cls, "inline-flex");
        });

        return attributes;
    }

    private string? GetSizeClass()
    {
        if (Size == Quark.Size.Default)
            return null;

        var sizeValue = Size?.ToString()?.ToLowerInvariant();
        return sizeValue switch
        {
            "xs" => "h-3 w-3",
            "sm" => "h-3.5 w-3.5",
            "md" => "h-4 w-4",
            "lg" => "h-5 w-5",
            "xl" => "h-7 w-7",
            "xxl" => "h-8 w-8",
            _ => sizeValue.HasContent() ? "h-4 w-4" : null
        };
    }

    protected override async Task HandleClick(MouseEventArgs e)
    {
        if (ParentRadioGroup != null)
        {
            await ParentRadioGroup.SetValueAsync(Value);
            await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = true });
            if (ParentValidation is not null)
            {
                ParentValidation.MarkTouched();
                await ParentValidation.NotifyInputChanged(true);
            }
            return;
        }

        if (!Checked)
        {
            Checked = true;
            await CheckedChanged.InvokeAsync(true);
            InvalidateRender();
        }

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = Checked });

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(Checked);
        }
    }

    protected override Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventDefault = e.Key is "ArrowDown" or "ArrowUp" or "ArrowLeft" or "ArrowRight" or "Home" or "End";

        if (!EffectiveDisabled && ParentRadioGroup is not null && _preventDefault)
            ParentRadioGroup.HandleKeyNavigation(this, e.Key);

        return base.HandleKeyDown(e);
    }

    private const string _shadcnRadioItemBase =
        "border-input text-primary focus-visible:border-ring focus-visible:ring-ring/50 disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive dark:bg-input/30 aspect-square shrink-0 rounded-full border shadow-xs transition-[color,box-shadow] outline-none focus-visible:ring-[3px] relative flex items-center justify-center";

    private Dictionary<string, object> BuildLabelAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2 text-sm font-medium leading-none");
            AppendClass(ref cls, "focus-within:outline-none rounded-[4px] cursor-pointer");
            if (EffectiveDisabled)
                AppendClass(ref cls, "cursor-not-allowed opacity-50");
        });
        attributes["for"] = ControlId;
        return attributes;
    }

    private Dictionary<string, object> BuildIndicatorAttributes()
    {
        var attributes = new Dictionary<string, object>();
        attributes["data-slot"] = "radio-group-indicator";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-radio-input");
            AppendClass(ref cls, _shadcnRadioItemBase);
            AppendClass(ref cls, "data-[state=checked]:border-primary");
            var sizeClass = GetSizeClass();
            AppendClass(ref cls, sizeClass ?? "size-4");
            if (EffectiveDisabled)
                AppendClass(ref cls, "opacity-50");
            var validationClass = GetValidationClass();
            if (validationClass != null)
                AppendClass(ref cls, validationClass);
        });

        if (ParentRadioGroup is null && FieldContext is not null)
        {
            var describedBy = FieldContext.BuildDescribedBy(attributes.TryGetValue("aria-describedby", out var existingDescribedBy)
                ? existingDescribedBy?.ToString()
                : null);

            if (!string.IsNullOrWhiteSpace(describedBy))
                attributes["aria-describedby"] = describedBy;
        }

        if (ParentValidation?.Status == ValidationStatus.Error || (ParentRadioGroup is null && FieldContext?.IsInvalid == true))
            attributes["aria-invalid"] = "true";

        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
    }

    private string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error)
            return "border-destructive ring-destructive/20 dark:ring-destructive/40";
        return null;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(Name);
        hc.Add(Value);
        hc.Add(ParentRadioGroup?.Value);
        AddIf(ref hc, Size);
        hc.Add(Inline);
        hc.Add(FieldContext?.ControlId);
        hc.Add(FieldContext?.DescriptionId);
        hc.Add(FieldContext?.ErrorId);
        hc.Add(FieldContext?.IsInvalid);
        hc.Add(TabStopIndex);
    }

    internal bool IsCheckedInGroup()
    {
        return EffectiveChecked;
    }

    internal async Task SelectFromGroupNavigationAsync()
    {
        if (EffectiveDisabled)
            return;

        await ParentRadioGroup!.SetValueAsync(Value);

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = true });

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(true);
        }

        try
        {
            await _elementRef.FocusAsync();
        }
        catch
        {
        }
    }

    public override void Dispose()
    {
        if (_subscribedFieldContext is not null)
            _subscribedFieldContext.StateChanged -= OnFieldContextStateChanged;

        ParentRadioGroup?.UnregisterRadio(this);
        base.Dispose();
    }
}