@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements Soenneker.Quark.IValidationInput
@implements IRadio
@implements IDisposable
<div @attributes="BuildWrapperAttributes()">
    @if (ParentRadioGroup is not null)
    {
        @if (HasInlineLabel)
        {
            <label @attributes="BuildLabelAttributes()">
                <BradixRadioGroupItem Id="@ControlId"
                                      Value="@ResolvedGroupedValue"
                                      InputValue="@ResolvedGroupedValue"
                                      Disabled="@Disabled"
                                      OnClick="HandleGroupedClick"
                                      OnFocus="HandleGroupedFocus"
                                      OnKeyDown="HandleGroupedKeyDown"
                                      AdditionalAttributes="@BuildGroupedItemAttributes()">
                    <BradixRadioGroupIndicator AdditionalAttributes="@BuildGroupedIndicatorAttributes()" />
                </BradixRadioGroupItem>
                @if (ChildContent != null)
                {
                    @ChildContent
                }
            </label>
        }
        else
        {
            <BradixRadioGroupItem Id="@ControlId"
                                  Value="@ResolvedGroupedValue"
                                  InputValue="@ResolvedGroupedValue"
                                  Disabled="@Disabled"
                                  OnClick="HandleGroupedClick"
                                  OnFocus="HandleGroupedFocus"
                                  OnKeyDown="HandleGroupedKeyDown"
                                  AdditionalAttributes="@BuildGroupedItemAttributes()">
                <BradixRadioGroupIndicator AdditionalAttributes="@BuildGroupedIndicatorAttributes()" />
            </BradixRadioGroupItem>
        }
    }
    else if (HasInlineLabel)
    {
        <label @attributes="BuildLabelAttributes()">
            <input
                @attributes="BuildInputAttributes()"
                @onclick="HandleInputClick"
                @onchange="HandleChange"
                @onkeydown="HandleKeyDown"
                @onkeydown:preventDefault="_preventDefault"
                @ref="_elementRef" />
            <span @attributes="BuildIndicatorAttributes()">
                @if (EffectiveChecked)
                {
                    <span data-slot="radio-group-indicator" class="absolute top-1/2 left-1/2 size-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-foreground"></span>
                }
            </span>
            @if (ChildContent != null)
            {
                @ChildContent
            }
        </label>
    }
    else
    {
        <input
            @attributes="BuildInputAttributes()"
            @onclick="HandleInputClick"
            @onchange="HandleChange"
            @onkeydown="HandleKeyDown"
            @onkeydown:preventDefault="_preventDefault"
            @ref="_elementRef" />
        <span @attributes="BuildIndicatorAttributes()">
            @if (EffectiveChecked)
            {
                <span data-slot="radio-group-indicator" class="absolute top-1/2 left-1/2 size-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-foreground"></span>
            }
        </span>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the callback invoked When the radio state changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    [CascadingParameter(Name = "ParentRadioGroup")]
    public RadioGroup? ParentRadioGroup { get; set; }

    private ElementReference _elementRef;
    private bool _preventDefault;
    private bool _hasObservedGroupedCheckedState;
    private bool _lastGroupedCheckedState;
    private bool HasInlineLabel => ChildContent != null;

    /// <summary>
    /// When inside RadioGroup, reflects group value; otherwise uses Checked.
    /// </summary>
    private bool EffectiveChecked => ParentRadioGroup != null
        ? string.Equals(ParentRadioGroup.Value, ResolvedGroupedValue, StringComparison.Ordinal)
        : Checked;

    /// <summary>
    /// When inside RadioGroup, true if group or this radio is disabled.
    /// </summary>
    private bool EffectiveDisabled => ParentRadioGroup?.Disabled == true || Disabled;

    private string ControlId => ParentRadioGroup is null && CurrentFieldContext is not null ? CurrentFieldContext.ControlId : Id!;
    private string ResolvedGroupedValue => Value ?? ControlId;

    /// <summary>
    /// Gets or sets the size of the radio.
    /// </summary>
    [Parameter]
    public CssValue<SizeBuilder>? Size { get; set; } = Quark.Size.Default;

    /// <summary>
    /// Gets or sets whether the radio should be displayed inline.
    /// </summary>
    [Parameter]
    public bool Inline { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// Inside a radio group, the selected option value is the real control state.
    /// </summary>
    public object? ValidationValue => ParentRadioGroup is not null ? ParentRadioGroup.Value : EffectiveChecked;

    protected override void OnInitialized()
    {
        if (Id.IsNullOrEmpty())
            Id = BlazorIdGenerator.New("quark-radio");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;

            if (ParentRadioGroup is null && CheckedExpression is not null)
                await ParentValidation.InitializeInputExpression(CheckedExpression);
        }

        if (ParentRadioGroup is not null)
        {
            if (!_hasObservedGroupedCheckedState)
            {
                _lastGroupedCheckedState = EffectiveChecked;
                _hasObservedGroupedCheckedState = true;
            }
            else if (_lastGroupedCheckedState != EffectiveChecked)
            {
                _lastGroupedCheckedState = EffectiveChecked;

                if (EffectiveChecked)
                {
                    await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = true });

                    if (ParentValidation is not null)
                    {
                        ParentValidation.MarkTouched();
                        await ParentValidation.NotifyInputChanged(ParentRadioGroup.Value, overrideNewValue: true);
                    }
                }
            }
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        await RefreshOffThread();
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2");
            if (Inline)
                AppendClass(ref cls, "inline-flex");
        });

        return attributes;
    }

    private string? GetSizeClass()
    {
        if (Size == Quark.Size.Default)
            return null;

        var sizeValue = Size?.ToString()?.ToLowerInvariant();
        return sizeValue switch
        {
            "xs" => "h-3 w-3",
            "sm" => "h-3.5 w-3.5",
            "md" => "h-4 w-4",
            "lg" => "h-5 w-5",
            "xl" => "h-7 w-7",
            "xxl" => "h-8 w-8",
            _ => sizeValue.HasContent() ? "h-4 w-4" : null
        };
    }

    private Task HandleInputClick(MouseEventArgs e)
    {
        return base.HandleClick(e);
    }

    private Task HandleGroupedClick(MouseEventArgs e)
    {
        return base.HandleClick(e);
    }

    private Task HandleGroupedFocus(FocusEventArgs e)
    {
        return base.HandleFocus(e);
    }

    private Task HandleGroupedKeyDown(KeyboardEventArgs e)
    {
        return base.HandleKeyDown(e);
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (EffectiveDisabled)
            return;

        if (ParentRadioGroup != null)
        {
            await ParentRadioGroup.SetValueAsync(Value);
            await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = true });
            if (ParentValidation is not null)
            {
                ParentValidation.MarkTouched();
                await ParentValidation.NotifyInputChanged(ParentRadioGroup.Value, overrideNewValue: true);
            }
            return;
        }

        if (!Checked)
        {
            Checked = true;
            await CheckedChanged.InvokeAsync(true);
            InvalidateRender();
        }

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = Checked });

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(ValidationValue, overrideNewValue: true);
        }
    }

    protected override Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventDefault = ParentRadioGroup is null &&
                          e.Key is "Home" or "End" or "ArrowLeft" or "ArrowRight" or "ArrowUp" or "ArrowDown";

        return base.HandleKeyDown(e);
    }

    private const string _shadcnRadioItemBase =
        "group/radio-group-item peer relative flex aspect-square shrink-0 items-center justify-center rounded-full border border-input outline-none transition-[color,box-shadow] after:absolute after:-inset-x-3 after:-inset-y-2 focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:cursor-not-allowed disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:bg-input/30 dark:aria-invalid:ring-destructive/40";

    private Dictionary<string, object> BuildLabelAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2 text-sm font-medium leading-none select-none");
            AppendClass(ref cls, "focus-within:outline-none rounded-[4px] cursor-pointer");
            if (EffectiveDisabled)
                AppendClass(ref cls, "cursor-not-allowed opacity-50");
        });
        attributes["for"] = ControlId;
        return attributes;
    }

    private Dictionary<string, object> BuildInputAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["id"] = ControlId,
            ["type"] = "radio",
            ["name"] = ParentRadioGroup?.EffectiveName ?? Name ?? ControlId,
            ["value"] = Value ?? string.Empty,
            ["checked"] = EffectiveChecked,
            ["data-state"] = EffectiveChecked ? "checked" : "unchecked",
            ["tabindex"] = 0
        };

        if (Required)
            attributes["required"] = true;

        if (AutoFocus)
            attributes["autofocus"] = true;

        if (EffectiveDisabled)
            attributes["disabled"] = true;

        if (Attributes is not null)
        {
            foreach (var attribute in Attributes)
            {
                if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[attribute.Key] = attribute.Value;
            }
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "peer sr-only");
        });

        if (ParentRadioGroup is null)
            ApplyFieldControlAttributes(attributes, ParentValidation?.Status == ValidationStatus.Error);

        return attributes;
    }

    private Dictionary<string, object> BuildIndicatorAttributes()
    {
        var attributes = new Dictionary<string, object>();
        attributes["data-slot"] = "radio-group-item";
        attributes["data-state"] = EffectiveChecked ? "checked" : "unchecked";

        if (EffectiveChecked)
            attributes["data-checked"] = "true";
        else
            attributes["data-unchecked"] = "true";

        if (EffectiveDisabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, _shadcnRadioItemBase);
            AppendClass(ref cls, "text-primary shadow-xs");
            var sizeClass = GetSizeClass();
            AppendClass(ref cls, sizeClass ?? "size-4");
            var validationClass = GetValidationClass();
            if (validationClass != null)
                AppendClass(ref cls, validationClass);
        });

        return attributes;
    }

    private Dictionary<string, object> BuildGroupedItemAttributes()
    {
        var attributes = new Dictionary<string, object>(BuildIndicatorAttributes());

        attributes.Remove("data-checked");
        attributes.Remove("data-unchecked");

        if (Attributes is not null)
        {
            foreach (var attribute in Attributes)
            {
                if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("id", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("name", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("value", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("checked", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("disabled", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("type", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onclick", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onchange", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onkeydown", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onfocus", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[attribute.Key] = attribute.Value;
            }
        }

        return attributes;
    }

    private static IReadOnlyDictionary<string, object> BuildGroupedIndicatorAttributes()
    {
        return new Dictionary<string, object>
        {
            ["data-slot"] = "radio-group-indicator",
            ["class"] = "absolute top-1/2 left-1/2 size-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary-foreground"
        };
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
    }

    private string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error)
            return "border-destructive ring-destructive/20 dark:ring-destructive/40";
        return null;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(Name);
        hc.Add(Value);
        hc.Add(ParentRadioGroup?.Value);
        AddIf(ref hc, Size);
        hc.Add(Inline);
    }

    public override void Dispose()
    {
        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
        base.Dispose();
    }
}
