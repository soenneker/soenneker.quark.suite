@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix
@inherits Soenneker.Quark.FormControlElement
@implements IRadioGroup

<CascadingValue Name="ParentRadioGroup" Value="@this" IsFixed="true">
    <BradixRadioGroup Name="@EffectiveName"
                      Required="@Required"
                      Disabled="@Disabled"
                      Value="@Value"
                      Dir="@ResolvedDirection"
                      Orientation="@ResolvedOrientation"
                      ValueChanged="HandleValueChanged"
                      AdditionalAttributes="@GroupAttributes">
        @ChildContent
    </BradixRadioGroup>
</CascadingValue>

@code {
    private string? _name;

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? CascadedDirection { get; set; }
    /// <summary>
    /// Callback when the selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the orientation.
    /// </summary>
    [Parameter]
    public Orientation Orientation { get; set; } = Orientation.Vertical;

    [Parameter]
    public string? Dir { get; set; }

    private string OrientationValue => Orientation.Value;

    private Orientation ResolvedOrientation => Orientation;

    private string? ResolvedDirection => string.IsNullOrWhiteSpace(Dir) ? CascadedDirection : Dir;

    /// <summary>
    /// Gets the effective name for the group (generated if not set).
    /// </summary>
    public string EffectiveName => _name ??= Name ?? BlazorIdGenerator.New("quark-radiogroup");

    protected override void OnInitialized()
    {
        if (Name.HasContent())
            _name = Name;
        else
            _name = BlazorIdGenerator.New("quark-radiogroup");
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Grid;
        Gap ??= Quark.Gap.Is3;
    }

    /// <summary>
    /// Called by child Radio when selected. Sets Value and invokes ValueChanged.
    /// </summary>
    public async Task SetValue(string? value)
    {
        if (Value == value) return;
        Value = value;
        await ValueChanged.InvokeAsync(Value);
        InvalidateRender();
        Refresh();
    }

    private IReadOnlyDictionary<string, object> GroupAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("name");
            attributes.Remove("value");
            attributes.Remove("readonly");
            attributes.Remove("placeholder");
            attributes.Remove("required");
            attributes.Remove("autofocus");
            attributes.Remove("role");
            attributes.Remove("aria-orientation");

            attributes["data-slot"] = "radio-group";
            ApplyFieldControlAttributes(attributes);

            BuildClassAttribute(attributes, (ref cls) =>
            {
                if (OrientationValue == "horizontal")
                    AppendClass(ref cls, "grid-flow-col auto-cols-max");
            });

            return attributes;
        }
    }

    private Task HandleValueChanged(string? value)
    {
        return SetValue(value);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Name);
        hc.Add(Disabled);
        hc.Add(Orientation);
        hc.Add(Dir);
        hc.Add(CascadedDirection);
        hc.Add(AriaLabel);
    }
}
