@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix
@using Soenneker.Blazor.Extensions.EventCallback
@using System.Threading
@inherits Soenneker.Quark.FormControlElement
@implements IRadioGroup

<CascadingValue Name="ParentRadioGroup" Value="@this" IsFixed="true">
    @if (UsesAutoSaveStatusSlot)
    {
        <div class="inline-flex items-center gap-2">
            <BradixRadioGroup Name="@EffectiveName"
                              Required="@Required"
                              Disabled="@Disabled"
                              Value="@Value"
                              Dir="@ResolvedDirection"
                              Orientation="@ResolvedOrientation"
                              ValueChanged="HandleValueChanged"
                              AdditionalAttributes="@GroupAttributes">
                @ChildContent
            </BradixRadioGroup>
            <AutoSaveStatus State="@_autoSave.State"
                            Visible="@UsesAutoSaveStatusSlot"
                            Class="@AutoSaveStatusClass"
                            SavingClass="@AutoSaveSavingClass"
                            SavedClass="@AutoSaveSavedClass"
                            FailedClass="@AutoSaveFailedClass" />
        </div>
    }
    else
    {
        <BradixRadioGroup Name="@EffectiveName"
                          Required="@Required"
                          Disabled="@Disabled"
                          Value="@Value"
                          Dir="@ResolvedDirection"
                          Orientation="@ResolvedOrientation"
                          ValueChanged="HandleValueChanged"
                          AdditionalAttributes="@GroupAttributes">
            @ChildContent
        </BradixRadioGroup>
    }
</CascadingValue>

@code {
    private string? _name;
    private readonly AutoSaveController<string?> _autoSave = new();

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? CascadedDirection { get; set; }
    /// <summary>
    /// Callback when the selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the orientation.
    /// </summary>
    [Parameter]
    public Orientation? Orientation { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<string?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

    private Orientation? ResolvedOrientation => Orientation;

    private string? ResolvedDirection => string.IsNullOrWhiteSpace(Dir) ? CascadedDirection : Dir;
    private bool UsesAutoSaveStatusSlot => AutoSave && OnAutoSave is not null && ShowAutoSaveStatus;

    /// <summary>
    /// Gets the effective name for the group (generated if not set).
    /// </summary>
    public string EffectiveName => _name ??= Name ?? BlazorIdGenerator.New("quark-radiogroup");

    protected override void OnInitialized()
    {
        if (Name.HasContent())
            _name = Name;
        else
            _name = BlazorIdGenerator.New("quark-radiogroup");
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "radio-group";

        Display ??= Quark.Display.Grid;
        Width ??= Quark.Width.IsFull;
        Gap ??= Quark.Gap.Is2;
    }

    /// <summary>
    /// Called by child Radio when selected. Sets Value and invokes ValueChanged.
    /// </summary>
    public async Task SetValue(string? value)
    {
        if (Value == value) return;
        Value = value;
        await ValueChanged.InvokeAsync(Value);
        await _autoSave.NotifyValueChanged(Value, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
        InvalidateRender();
        Refresh();
    }

    private IReadOnlyDictionary<string, object> GroupAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        ApplyFieldControlAttributes(attributes);

        if (OnBlur.HasDelegate || (AutoSave && AutoSaveOnBlur && OnAutoSave is not null))
            attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleGroupBlur);

        if (OnKeyDown.HasDelegate || (AutoSave && AutoSaveOnEnter && OnAutoSave is not null))
            attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleGroupKeyDown);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (Orientation?.Value == "horizontal")
                AppendClass(ref cls, "grid-flow-col auto-cols-max");
        });
    }

    private Task HandleValueChanged(string? value)
    {
        return SetValue(value);
    }

    private async Task HandleGroupBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            await _autoSave.Flush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleGroupKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await _autoSave.Flush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Name);
        hc.Add(Disabled);
        hc.Add(Orientation);
        hc.Add(Dir);
        hc.Add(CascadedDirection);
        hc.Add(AriaLabel);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(_autoSave.State);
        hc.Add(OnAutoSave is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
    }

    public override async ValueTask DisposeAsync()
    {
        await _autoSave.DisposeAsync();
        await base.DisposeAsync();
    }
}
