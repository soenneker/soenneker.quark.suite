@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IRadioGroup
@implements IDisposable

<CascadingValue Name="ParentRadioGroup" Value="@this" IsFixed="true">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private string? _name;
    private readonly List<Radio> _radios = [];

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    /// <summary>
    /// Identifies the element(s) that label this radiogroup. When set, <see cref="Element.AriaLabel"/> is omitted so the group is not double-labeled.
    /// </summary>
    [Parameter]
    public string? AriaLabelledBy { get; set; }

    /// <summary>
    /// Callback when the selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Orientation: "horizontal" or "vertical".
    /// </summary>
    [Parameter]
    public string Orientation { get; set; } = "vertical";

    private string OrientationValue => Orientation?.ToLowerInvariantFast() == "horizontal" ? "horizontal" : "vertical";

    private bool IsHorizontalRtl()
    {
        if (OrientationValue != "horizontal")
            return false;

        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    /// <summary>
    /// Gets the effective name for the group (generated if not set).
    /// </summary>
    public string EffectiveName => _name ??= Name ?? $"radiogroup_{Guid.NewGuid():N}";

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (Name.HasContent())
            _name = Name;
        else
            _name = $"radiogroup_{Guid.NewGuid():N}";
    }

    /// <summary>
    /// Called by child Radio when selected. Sets Value and invokes ValueChanged.
    /// </summary>
    public async Task SetValueAsync(string? value)
    {
        if (Value == value) return;
        Value = value;
        await ValueChanged.InvokeAsync(Value);
        await RefreshOffThread();
    }

    internal void RegisterRadio(Radio radio)
    {
        if (!_radios.Contains(radio))
            _radios.Add(radio);
    }

    internal void UnregisterRadio(Radio radio)
    {
        _radios.Remove(radio);
    }

    internal bool IsTabStop(Radio radio)
    {
        if (radio.Disabled)
            return false;

        var checkedRadio = _radios.FirstOrDefault(r => !r.Disabled && r.IsCheckedInGroup());
        if (checkedRadio is not null)
            return ReferenceEquals(checkedRadio, radio);

        var firstEnabled = _radios.FirstOrDefault(r => !r.Disabled);
        return ReferenceEquals(firstEnabled, radio);
    }

    /// <summary>
    /// APG: vertical groups use ArrowUp/ArrowDown; horizontal groups use ArrowLeft/ArrowRight (mirrored in RTL). Home/End move to first/last.
    /// </summary>
    /// <returns><c>true</c> if the key was handled (caller should prevent default browser behavior).</returns>
    internal bool TryHandleKeyNavigation(Radio currentRadio, string key)
    {
        if (Disabled || _radios.Count == 0)
            return false;

        var enabledRadios = _radios.Where(r => !r.Disabled).ToList();
        if (enabledRadios.Count == 0)
            return false;

        var currentIndex = enabledRadios.FindIndex(r => ReferenceEquals(r, currentRadio));
        if (currentIndex < 0)
            return false;

        var vertical = OrientationValue == "vertical";
        var isRtl = IsHorizontalRtl();

        int nextIndex;

        if (key is "Home")
        {
            nextIndex = 0;
        }
        else if (key is "End")
        {
            nextIndex = enabledRadios.Count - 1;
        }
        else if (vertical)
        {
            nextIndex = key switch
            {
                "ArrowDown" => (currentIndex + 1) % enabledRadios.Count,
                "ArrowUp" => (currentIndex - 1 + enabledRadios.Count) % enabledRadios.Count,
                _ => -1
            };
        }
        else
        {
            nextIndex = key switch
            {
                "ArrowRight" when !isRtl => (currentIndex + 1) % enabledRadios.Count,
                "ArrowLeft" when !isRtl => (currentIndex - 1 + enabledRadios.Count) % enabledRadios.Count,
                "ArrowRight" when isRtl => (currentIndex - 1 + enabledRadios.Count) % enabledRadios.Count,
                "ArrowLeft" when isRtl => (currentIndex + 1) % enabledRadios.Count,
                _ => -1
            };
        }

        if (nextIndex < 0)
            return false;

        var target = enabledRadios[nextIndex];
        _ = target.SelectFromGroupNavigationAsync();
        return true;
    }

    protected override void BuildOwnedAttributes(Dictionary<string, object> attributes)
    {
        base.BuildOwnedAttributes(attributes);

        attributes.Remove("name");
        attributes.Remove("value");
        attributes.Remove("readonly");
        attributes.Remove("placeholder");
        attributes.Remove("required");
        attributes.Remove("autofocus");

        if (Required)
            attributes["aria-required"] = "true";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (!attributes.ContainsKey("role"))
            attributes["role"] = "radiogroup";

        attributes["aria-orientation"] = OrientationValue;

        if (Disabled)
            attributes["aria-disabled"] = "true";
        else
            attributes.Remove("aria-disabled");

        if (AriaLabelledBy.HasContent())
        {
            attributes["aria-labelledby"] = AriaLabelledBy;
            attributes.Remove("aria-label");
        }

        attributes["data-slot"] = "radio-group";
        ApplyFieldControlAttributes(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-radio-group");
            AppendClass(ref cls, "grid gap-3");
            if (OrientationValue == "horizontal")
                AppendClass(ref cls, "grid-flow-col auto-cols-max");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Name);
        hc.Add(Disabled);
        hc.Add(Orientation);
        hc.Add(AriaLabel);
        hc.Add(AriaLabelledBy);
        hc.Add(DirectionProviderDir);
    }

    public override void Dispose()
    {
        base.Dispose();
    }
}
