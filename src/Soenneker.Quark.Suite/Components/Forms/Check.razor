@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix
@using BradixCheckboxCheckedState = Soenneker.Bradix.BradixCheckboxCheckedState

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements Soenneker.Quark.IValidationInput
@implements ICheck

@if (HasInlineLabel)
{
    <div @attributes="BuildWrapperAttributes()">
        <label @attributes="BuildLabelAttributes()">
            <BradixCheckbox Checked="@CurrentCheckedState"
                            Required="@Required"
                            Disabled="@Disabled"
                            Name="@Name"
                            Value="@ResolvedCheckboxValue"
                            CheckedChanged="HandleCheckedStateChanged"
                            AdditionalAttributes="@BuildControlAttributes()">
                <BradixCheckboxIndicator AdditionalAttributes="@BuildIndicatorAttributes()">
                    @if (Indeterminate)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 shrink-0"><path d="M5 12h14"/></svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 shrink-0"><path d="M20 6 9 17 4 12"/></svg>
                    }
                </BradixCheckboxIndicator>
            </BradixCheckbox>
            @if (ChildContent is not null)
            {
                @ChildContent
            }
            else if (Label.HasContent())
            {
                @Label
            }
        </label>
    </div>
}
else
{
    <BradixCheckbox Checked="@CurrentCheckedState"
                    Required="@Required"
                    Disabled="@Disabled"
                    Name="@Name"
                    Value="@ResolvedCheckboxValue"
                    CheckedChanged="HandleCheckedStateChanged"
                    AdditionalAttributes="@BuildControlAttributes()">
        <BradixCheckboxIndicator AdditionalAttributes="@BuildIndicatorAttributes()">
            @if (Indeterminate)
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 shrink-0"><path d="M5 12h14"/></svg>
            }
            else
            {
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 shrink-0"><path d="M20 6 9 17 4 12"/></svg>
            }
        </BradixCheckboxIndicator>
    </BradixCheckbox>
}

@code {
    public override string? Id { get; set; } = BlazorIdGenerator.New("quark-check");

    [Parameter]
    public bool Indeterminate { get; set; }

    [Parameter]
    public CssValue<CheckSizeBuilder>? Size { get; set; } = CheckSizes.Default;

    [Parameter]
    public bool Switch { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    [Parameter]
    public bool Reverse { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? IndicatorClass { get; set; }

    [Parameter]
    public string? IndicatorStyle { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    public object? ValidationValue => Checked;

    private bool HasInlineLabel => ChildContent is not null || Label.HasContent();
    private string ControlId => Id ?? CurrentFieldContext?.ControlId ?? string.Empty;
    private string ResolvedCheckboxValue => Value.HasContent() ? Value! : "on";
    private BradixCheckboxCheckedState CurrentCheckedState => Indeterminate
        ? BradixCheckboxCheckedState.Indeterminate
        : Checked
            ? BradixCheckboxCheckedState.Checked
            : BradixCheckboxCheckedState.Unchecked;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            if (CheckedExpression is not null)
                await ParentValidation.InitializeInputExpression(CheckedExpression);

            await ParentValidation.InitializeInput(this);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnParentValidationStatusChanged(object? s, ValidationStatusChangedEventArgs e)
    {
        await RefreshOffThread();
    }

    public virtual Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2");
            if (Inline)
                AppendClass(ref cls, "inline-flex");
        });

        if (Style.HasContent())
            attributes["style"] = Style;

        return attributes;
    }

    public virtual Dictionary<string, object> BuildLabelAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["for"] = ControlId
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2 text-sm font-medium leading-none select-none");
            AppendClass(ref cls, "group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50");
            AppendClass(ref cls, "peer-disabled:cursor-not-allowed peer-disabled:opacity-50");

            if (Reverse)
                AppendClass(ref cls, "flex-row-reverse justify-end");

            if (Disabled)
                AppendClass(ref cls, "cursor-not-allowed opacity-50");
        });

        return attributes;
    }

    public virtual Dictionary<string, object> BuildControlAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["id"] = ControlId,
            ["data-slot"] = "checkbox"
        };

        if (Disabled)
        {
            attributes["data-disabled"] = "true";
        }

        if (Attributes is not null)
        {
            foreach (var attribute in Attributes)
            {
                if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("type", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("role", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("aria-checked", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("data-state", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("disabled", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("name", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("value", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onclick", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[attribute.Key] = attribute.Value;
            }
        }

        ApplyFieldControlAttributes(attributes, ParentValidation?.Status == ValidationStatus.Error);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "peer shrink-0 rounded-[4px] border border-input shadow-xs transition-shadow outline-none");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:cursor-not-allowed disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "data-[state=checked]:border-primary data-[state=checked]:bg-primary data-[state=checked]:text-primary-foreground");
            AppendClass(ref cls, "data-[state=indeterminate]:border-primary data-[state=indeterminate]:bg-primary data-[state=indeterminate]:text-primary-foreground");
            AppendClass(ref cls, "dark:bg-input/30 dark:aria-invalid:ring-destructive/40 dark:data-[state=checked]:bg-primary dark:data-[state=indeterminate]:bg-primary");
            AppendClass(ref cls, GetSizeClass() ?? "size-4");

            var validationClass = GetValidationClass();
            if (validationClass is not null)
                AppendClass(ref cls, validationClass);

            if (IndicatorClass.HasContent())
                AppendClass(ref cls, IndicatorClass!);
        });

        if (IndicatorStyle.HasContent())
            attributes["style"] = IndicatorStyle!;

        return attributes;
    }

    private static IReadOnlyDictionary<string, object> BuildIndicatorAttributes()
    {
        return new Dictionary<string, object>
        {
            ["data-slot"] = "checkbox-indicator",
            ["class"] = "grid place-content-center text-current transition-none"
        };
    }

    private string? GetValidationClass()
    {
        return ParentValidation?.Status == ValidationStatus.Error
            ? "border-destructive ring-[3px] ring-destructive/20 dark:ring-destructive/40"
            : null;
    }

    private string? GetSizeClass()
    {
        var sizeClass = Size?.ToString();
        return string.IsNullOrWhiteSpace(sizeClass) ? null : sizeClass;
    }

    private async Task HandleCheckedStateChanged(BradixCheckboxCheckedState state)
    {
        var next = state == BradixCheckboxCheckedState.Checked;
        Checked = next;
        Indeterminate = state == BradixCheckboxCheckedState.Indeterminate;
        await CheckedChanged.InvokeAsync(next);
        InvalidateRender();
        Refresh();

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(next);
        }

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = next });
        await base.HandleClick(new MouseEventArgs());
    }

    public override void Dispose()
    {
        base.Dispose();
        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(Name);
        hc.Add(Value);
        AddIf(ref hc, Size);
        hc.Add(Indeterminate);
        hc.Add(Switch);
        hc.Add(Inline);
        hc.Add(Reverse);
        hc.Add(Label);
        hc.Add(IndicatorClass);
        hc.Add(IndicatorStyle);
    }
}

