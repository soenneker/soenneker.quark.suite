@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix
@using System.Threading
@using BradixCheckboxCheckedState = Soenneker.Bradix.BradixCheckboxCheckedState

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements Soenneker.Quark.IValidationInput
@implements ICheck

@if (HasInlineLabel)
{
    <div @attributes="BuildWrapperAttributes()">
        <label @attributes="BuildLabelAttributes()">
            <BradixCheckbox Checked="@CurrentCheckedState"
                            Required="@Required"
                            Disabled="@Disabled"
                            Name="@Name"
                            Value="@ResolvedCheckboxValue"
                            CheckedChanged="HandleCheckedStateChanged"
                            AdditionalAttributes="@BuildControlAttributes()">
                <BradixCheckboxIndicator AdditionalAttributes="@BuildIndicatorAttributes()">
                    @if (Indeterminate)
                    {
                        <Icon Name="LucideIcon.Minus" Size='Quark.Size.Is3_5' aria-hidden="true" />
                    }
                    else
                    {
                        <Icon Name="LucideIcon.Check" Size='Quark.Size.Is3_5' aria-hidden="true" />
                    }
                </BradixCheckboxIndicator>
            </BradixCheckbox>
            @if (ChildContent is not null)
            {
                @ChildContent
            }
            else if (Label.HasContent())
            {
                @Label
            }
            <AutoSaveStatus State="@_autoSave.State"
                            HasSaved="@_autoSave.HasSaved"
                            Visible="@UsesAutoSaveStatusSlot"
                            Class="@AutoSaveStatusClass"
                            SavingClass="@AutoSaveSavingClass"
                            SavedClass="@AutoSaveSavedClass"
                            FailedClass="@AutoSaveFailedClass" />
        </label>
    </div>
}
else if (UsesAutoSaveStatusSlot)
{
    <Span Display="Quark.Display.InlineFlex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is2">
        <BradixCheckbox Checked="@CurrentCheckedState"
                        Required="@Required"
                        Disabled="@Disabled"
                        Name="@Name"
                        Value="@ResolvedCheckboxValue"
                        CheckedChanged="HandleCheckedStateChanged"
                        AdditionalAttributes="@BuildControlAttributes()">
            <BradixCheckboxIndicator AdditionalAttributes="@BuildIndicatorAttributes()">
                @if (Indeterminate)
                {
                    <Icon Name="LucideIcon.Minus" Size='Quark.Size.Is3_5' aria-hidden="true" />
                }
                else
                {
                    <Icon Name="LucideIcon.Check" Size='Quark.Size.Is3_5' aria-hidden="true" />
                }
            </BradixCheckboxIndicator>
        </BradixCheckbox>
        <AutoSaveStatus State="@_autoSave.State"
                        HasSaved="@_autoSave.HasSaved"
                        Visible="@UsesAutoSaveStatusSlot"
                        Class="@AutoSaveStatusClass"
                        SavingClass="@AutoSaveSavingClass"
                        SavedClass="@AutoSaveSavedClass"
                        FailedClass="@AutoSaveFailedClass" />
    </Span>
}
else
{
    <BradixCheckbox Checked="@CurrentCheckedState"
                    Required="@Required"
                    Disabled="@Disabled"
                    Name="@Name"
                    Value="@ResolvedCheckboxValue"
                    CheckedChanged="HandleCheckedStateChanged"
                    AdditionalAttributes="@BuildControlAttributes()">
        <BradixCheckboxIndicator AdditionalAttributes="@BuildIndicatorAttributes()">
            @if (Indeterminate)
            {
                <Icon Name="LucideIcon.Minus" Size='Quark.Size.Is3_5' aria-hidden="true" />
            }
            else
            {
                <Icon Name="LucideIcon.Check" Size='Quark.Size.Is3_5' aria-hidden="true" />
            }
        </BradixCheckboxIndicator>
    </BradixCheckbox>
}

@code {
    private static readonly IReadOnlyDictionary<string, object> IndicatorAttributes = new Dictionary<string, object>
    {
        ["data-slot"] = "checkbox-indicator",
        ["class"] = "grid place-content-center text-current transition-none [&>svg]:size-3.5"
    };

    private readonly AutoSaveController<bool?> _autoSave = new();

    [Parameter]
    public bool Indeterminate { get; set; }

    [Parameter]
    public CssValue<CheckSizeBuilder>? CheckSize { get; set; } = CheckSizes.Default;

    [Parameter]
    public bool Switch { get; set; }

    [Parameter]
    public bool Inline { get; set; }

    [Parameter]
    public bool Reverse { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? IndicatorClass { get; set; }

    [Parameter]
    public string? IndicatorStyle { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<bool?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    public object? ValidationValue => Checked;

    private bool HasInlineLabel => ChildContent is not null || Label.HasContent();
    private bool UsesAutoSaveStatusSlot => AutoSave && OnAutoSave is not null && ShowAutoSaveStatus;
    private string ControlId => Id ?? CurrentFieldContext?.ControlId ?? string.Empty;
    private string ResolvedCheckboxValue => Value.HasContent() ? Value! : "on";
    private BradixCheckboxCheckedState CurrentCheckedState => Indeterminate
        ? BradixCheckboxCheckedState.Indeterminate
        : Checked
            ? BradixCheckboxCheckedState.Checked
            : BradixCheckboxCheckedState.Unchecked;

    protected override void OnInitialized()
    {
        Id ??= BlazorIdGenerator.New("quark-check");

        base.OnInitialized();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            if (CheckedExpression is not null)
                await ParentValidation.InitializeInputExpression(CheckedExpression);

            await ParentValidation.InitializeInput(this);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnParentValidationStatusChanged(object? s, ValidationStatusChangedEventArgs e)
    {
        _ = RefreshOffThread();
    }

    public virtual Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2");
            if (Inline)
                AppendClass(ref cls, "inline-flex");
        });

        if (Style.HasContent())
            attributes["style"] = Style;

        return attributes;
    }

    public virtual Dictionary<string, object> BuildLabelAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["for"] = ControlId
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2 text-sm font-medium leading-none select-none");
            AppendClass(ref cls, "group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50");
            AppendClass(ref cls, "peer-disabled:cursor-not-allowed peer-disabled:opacity-50");

            if (Reverse)
                AppendClass(ref cls, "flex-row-reverse justify-end");

            if (Disabled)
                AppendClass(ref cls, "cursor-not-allowed opacity-50");
        });

        return attributes;
    }

    public virtual Dictionary<string, object> BuildControlAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["id"] = ControlId,
            ["data-slot"] = "checkbox"
        };

        if (AriaLabel.HasContent())
            attributes["aria-label"] = AriaLabel!;

        if (AriaLabelledBy.HasContent())
            attributes["aria-labelledby"] = AriaLabelledBy!;

        if (OnBlur.HasDelegate || (AutoSave && AutoSaveOnBlur && OnAutoSave is not null))
            attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleControlBlur);

        if (OnKeyDown.HasDelegate || (AutoSave && AutoSaveOnEnter && OnAutoSave is not null))
            attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleControlKeyDown);

        if (Attributes is not null)
        {
            foreach (var attribute in Attributes)
            {
                if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("type", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("role", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("aria-checked", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("data-state", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("disabled", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("name", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("value", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onclick", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[attribute.Key] = attribute.Value;
            }
        }

        ApplyFieldControlAttributes(attributes, ParentValidation?.Status == ValidationStatus.Error);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "peer relative flex size-4 shrink-0 items-center justify-center rounded-[4px] border border-input transition-colors outline-none");
            AppendClass(ref cls, "group-has-disabled/field:opacity-50 after:absolute after:-inset-x-3 after:-inset-y-2");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:cursor-not-allowed disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 aria-invalid:aria-checked:border-primary");
            AppendClass(ref cls, "dark:bg-input/30 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "data-[state=checked]:border-primary data-[state=checked]:bg-primary data-[state=checked]:text-primary-foreground dark:data-[state=checked]:bg-primary");

            var validationClass = GetValidationClass();
            if (validationClass is not null)
                AppendClass(ref cls, validationClass);

            if (IndicatorClass.HasContent())
                AppendClass(ref cls, IndicatorClass!);
        });

        if (IndicatorStyle.HasContent())
            attributes["style"] = IndicatorStyle!;

        return attributes;
    }

    private static IReadOnlyDictionary<string, object> BuildIndicatorAttributes() => IndicatorAttributes;

    private string? GetValidationClass()
    {
        return ParentValidation?.Status == ValidationStatus.Error
            ? "border-destructive ring-[3px] ring-destructive/20 dark:border-destructive/50 dark:ring-destructive/40"
            : null;
    }

    private async Task HandleCheckedStateChanged(BradixCheckboxCheckedState state)
    {
        var next = state == BradixCheckboxCheckedState.Checked;
        Checked = next;
        Indeterminate = state == BradixCheckboxCheckedState.Indeterminate;
        await CheckedChanged.InvokeAsync(next);
        await _autoSave.NotifyValueChanged(next, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
        InvalidateRender();
        Refresh();

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(next);
        }

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = next });
        await base.HandleClick(new MouseEventArgs());
    }

    private async Task HandleControlBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            _autoSave.QueueFlush(Checked, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleControlKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await _autoSave.Flush(Checked, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

    public override async ValueTask DisposeAsync()
    {
        await base.DisposeAsync();
        await _autoSave.DisposeAsync();
        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
        }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(Name);
        hc.Add(Value);
        AddIf(ref hc, CheckSize);
        hc.Add(Indeterminate);
        hc.Add(Switch);
        hc.Add(Inline);
        hc.Add(Reverse);
        hc.Add(Label);
        hc.Add(IndicatorClass);
        hc.Add(IndicatorStyle);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(_autoSave.State);
        hc.Add(_autoSave.HasSaved);
        hc.Add(OnAutoSave is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
    }
}

