@using System.Linq.Expressions
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElementBase
@implements ITextInput

<div @attributes="BuildWrapperAttributes()">
    <Input @ref="_inputComponent"
           Id="@Id"
           Name="@Name"
           Type="@InputType"
           Value="@Value"
           ValueChanged="@HandleValueChanged"
           InputSize="@InputSize"
           PlainText="@PlainText"
           FloatingLabel="@FloatingLabel"
           Label="@Label"
           Placeholder="@Placeholder"
           Disabled="@Disabled"
           ReadOnly="@ReadOnly"
           Required="@Required"
           Class="@ResolvedInputClass"
           Style="@Style"
           AriaLabel="@AriaLabel"
           AriaDescribedBy="@AriaDescribedBy"
           @attributes="BuildInputAttributes()"
           OnInput="HandleInput"
           OnChange="HandleChange"
           ValidationValueSelector="@(() => (object?)Value)" />

    <Button Type="@ButtonType.Button"
            Variant="ButtonVariant.Ghost"
            ButtonSize="ButtonSize.Sm"
            Disabled="@ToggleDisabled"
            Class="absolute right-0 top-0 h-full rounded-l-none px-3 py-2 hover:bg-transparent"
            AriaLabel="@ToggleAriaLabel"
            OnClick="TogglePasswordVisibility">
        <Icon Name="@ToggleIcon" Class="size-4 text-muted-foreground" aria-hidden="true" />
        <Span ScreenReader="Quark.ScreenReader.Only">@ToggleAriaLabel</Span>
    </Button>

    <style>
        .hide-password-toggle::-ms-reveal,
        .hide-password-toggle::-ms-clear {
            visibility: hidden;
            pointer-events: none;
            display: none;
        }
    </style>
</div>

@code {
    private Input? _inputComponent;
    private string? _registeredEditMask;
    private bool _showPassword;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public Expression<Func<string?>>? ValueExpression { get; set; }

    [Parameter]
    public int MaxLength { get; set; }

    [Parameter]
    public TextInputMode? InputMode { get; set; }

    [Parameter]
    public string? EditMask { get; set; }

    [Parameter]
    public CssValue<InputSizeBuilder>? InputSize { get; set; } = InputSizes.Default;

    [Parameter]
    public bool PlainText { get; set; }

    [Parameter]
    public bool FloatingLabel { get; set; }

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string AutoComplete { get; set; } = "current-password";

    [Parameter]
    public bool ShowPassword { get; set; }

    [Parameter]
    public EventCallback<bool> ShowPasswordChanged { get; set; }

    [Parameter]
    public bool DisableToggleWhenEmpty { get; set; } = true;

    [Parameter]
    public string? WrapperClass { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [Parameter]
    public EventCallback<ChangeEventArgs> OnInput { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    public object? ValidationValue => Value;

    private bool CurrentShowPassword => ShowPasswordChanged.HasDelegate ? ShowPassword : _showPassword;

    private string InputType => CurrentShowPassword ? "text" : "password";

    private bool ToggleDisabled => Disabled || ReadOnly || (DisableToggleWhenEmpty && Value.IsNullOrEmpty());

    private string ToggleAriaLabel => CurrentShowPassword ? "Hide password" : "Show password";

    private LucideIcon ToggleIcon => CurrentShowPassword && !ToggleDisabled ? LucideIcon.Eye : LucideIcon.EyeOff;

    private string ResolvedInputClass => Class.HasContent()
        ? AppendToClass("hide-password-toggle pr-10", Class!)
        : "hide-password-toggle pr-10";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "password-input";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ParentValidation is not null && _registeredEditMask != EditMask)
        {
            if (EditMask.HasContent())
                await ParentValidation.InitializeInputPattern(EditMask, Value ?? string.Empty, enablePatternValidation: true);
            else
                ParentValidation.ClearInputPattern();

            _registeredEditMask = EditMask;
        }

        if (firstRender && ParentValidation is not null && ValueExpression is not null)
        {
            await ParentValidation.InitializeInputExpression(ValueExpression);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        _ = RefreshOffThread();
    }

    private async Task HandleValueChanged(string? value)
    {
        var valueChanged = !string.Equals(Value, value, StringComparison.Ordinal);
        Value = value;

        if (!valueChanged)
            return;

        await ValueChanged.InvokeIfHasDelegate(Value);
        InvalidateRender();
        Refresh();
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await OnInput.InvokeIfHasDelegate(e);

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(Value);
        }
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        Value = e.Value?.ToString();
        await OnChange.InvokeIfHasDelegate(e);

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(Value);
        }
    }

    private async Task TogglePasswordVisibility()
    {
        if (ToggleDisabled)
            return;

        var next = !CurrentShowPassword;

        if (ShowPasswordChanged.HasDelegate)
            await ShowPasswordChanged.InvokeAsync(next);
        else
            _showPassword = next;

        InvalidateRender();
        Refresh();
    }

    public string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error)
            return "is-invalid";

        if (ParentValidation?.Status == ValidationStatus.Success)
            return "is-valid";

        return null;
    }

    public string? GetColorClass() => null;

    public string? GetSizeClass()
    {
        var sizeClass = InputSize?.ToString();
        return string.IsNullOrWhiteSpace(sizeClass) ? null : sizeClass;
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>(4)
        {
            ["data-slot"] = DataSlot!
        };

        RenderComponent.BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "relative");

            if (WrapperClass.HasContent())
                AppendClass(ref cls, WrapperClass!);
        });

        return attributes;
    }

    private Dictionary<string, object> BuildInputAttributes()
    {
        var attributes = new Dictionary<string, object>();

        if (MaxLength > 0)
            attributes["maxlength"] = MaxLength;

        if (InputMode is not null)
            attributes["inputmode"] = InputMode.Value;

        if (EditMask.HasContent())
            attributes["pattern"] = EditMask;

        if (AutoComplete.HasContent())
            attributes["autocomplete"] = AutoComplete;

        return attributes;
    }

    public override async ValueTask DisposeAsync()
    {
        await base.DisposeAsync();

        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(MaxLength);
        hc.Add(InputMode);
        hc.Add(EditMask);
        AddIf(ref hc, InputSize);
        hc.Add(PlainText);
        hc.Add(FloatingLabel);
        hc.Add(Label);
        hc.Add(AutoComplete);
        hc.Add(ShowPassword);
        hc.Add(_showPassword);
        hc.Add(ShowPasswordChanged.HasDelegate);
        hc.Add(DisableToggleWhenEmpty);
        hc.Add(WrapperClass);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
    }
}
