@using System.Linq.Expressions
@using System.Threading
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements Soenneker.Quark.IValidationInput
@implements IMemoInput
@inject IInputInterop InputInterop

@if (UsesAutoSaveStatusSlot)
{
    <Span Display="Quark.Display.InlineFlex" Width="Quark.Width.IsFull" MinWidth="Quark.MinWidth.Is0" ItemsAlign="Quark.Items.Start" Gap="Quark.Gap.Is2">
        <textarea @ref="_elementRef" @attributes="BuildAttributes()" @bind:get="Value" @bind:set="HandleInputValueChanged" @bind:event="oninput" @onchange="HandleChange"></textarea>
        <AutoSaveStatus State="@_autoSave.State"
                        HasSaved="@_autoSave.HasSaved"
                        Class="@ResolvedAutoSaveStatusClass"
                        SavingClass="@AutoSaveSavingClass"
                        SavedClass="@AutoSaveSavedClass"
                        FailedClass="@AutoSaveFailedClass" />
    </Span>
}
else
{
    <textarea @ref="_elementRef" @attributes="BuildAttributes()" @bind:get="Value" @bind:set="HandleInputValueChanged" @bind:event="oninput" @onchange="HandleChange"></textarea>
}

@code {
    private ElementReference _elementRef;
    private readonly AutoSaveController<string?> _autoSave = new();
    private InputSelectionSnapshot? _pendingSelectionRestore;

	/// <summary>
	/// Gets or sets the number of rows for the textarea.
	/// </summary>
	[Parameter]
	public int Rows { get; set; } = 3;

	/// <summary>
	/// Gets or sets the maximum length of the input.
	/// </summary>
	[Parameter]
	public int MaxLength { get; set; }

	/// <summary>
	/// Gets or sets the minimum length of the input.
	/// </summary>
	[Parameter]
	public int MinLength { get; set; }

	/// <summary>
	/// Gets or sets the pattern for validation.
	/// </summary>
	[Parameter]
	public string? Pattern { get; set; }

	/// <summary>
	/// Gets or sets whether the textarea should auto-resize.
	/// </summary>
	[Parameter]
	public bool AutoResize { get; set; }

	/// <summary>
	/// Gets or sets the size of the input.
	/// </summary>
	[Parameter]
	public CssValue<InputSizeBuilder>? InputSize { get; set; } = InputSizes.Default;

	/// <summary>
	/// Gets or sets the callback invoked When the value changes.
	/// </summary>
	[Parameter]
	public EventCallback<string?> ValueChanged { get; set; }

	/// <summary>
	/// Gets or sets the expression that identifies the bound value.
	/// </summary>
	[Parameter]
	public Expression<Func<string?>>? ValueExpression { get; set; }

	/// <summary>
	/// Gets or sets the callback invoked When the input changes.
	/// </summary>
	[Parameter]
	public EventCallback<ChangeEventArgs> OnChange { get; set; }

	/// <summary>
	/// Gets or sets the callback invoked When the input value changes.
	/// </summary>
	[Parameter]
	public EventCallback<ChangeEventArgs> OnInput { get; set; }

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<string?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

	[CascadingParameter(Name = nameof(ParentValidation))]
	public Validation? ParentValidation { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// </summary>
    public object? ValidationValue => Value;

    private bool UsesAutoSaveStatusSlot => AutoSave && OnAutoSave is not null && ShowAutoSaveStatus;

    private string ResolvedAutoSaveStatusClass
    {
        get
        {
            const string statusClass = "mt-3.5";

            return string.IsNullOrWhiteSpace(AutoSaveStatusClass)
                ? statusClass
                : $"{statusClass} {AutoSaveStatusClass}";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
	{
        if (firstRender)
            await InputInterop.Initialize();

		if (firstRender && ParentValidation is not null)
		{
			await ParentValidation.InitializeInput(this);
			
			if (ValueExpression is not null)
				await ParentValidation.InitializeInputExpression(ValueExpression);
			
			ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
		}

        await RestorePendingSelection();
        await base.OnAfterRenderAsync(firstRender);
	}

	private void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
	{
		_ = RefreshOffThread();
	}

	private bool ShouldShowInvalid()
	{
		if (ParentValidation is null || ParentValidation.Status != ValidationStatus.Error)
			return false;

		var showInvalidProp = ParentValidation.GetType().GetProperty("ShouldShowInvalid");
		var showInvalid = showInvalidProp?.GetValue(ParentValidation) as bool? ?? true;
		return showInvalid;
	}

	private string? GetValidationClass()
	{
		if (ShouldShowInvalid())
			return "border-destructive ring-destructive/20 dark:ring-destructive/40";
		return null;
	}

	private string? GetSizeClass()
	{
		var sizeClass = InputSize?.ToString();
		return string.IsNullOrWhiteSpace(sizeClass) ? null : sizeClass;
	}

	protected override void ApplyDefaultParameters()
	{
		base.ApplyDefaultParameters();
		DataSlot ??= "textarea";

		Display ??= Quark.Display.Flex;
		MinHeight ??= Quark.Height.Is16;
		Width ??= Quark.Width.IsFull;
		Rounded ??= Quark.Rounded.Lg;
		Border ??= Quark.Border.Default;
		BorderColor ??= Quark.BorderColor.Input.OnFocusVisible.Ring;
		BackgroundColor ??= Quark.BackgroundColor.Transparent;
		Padding ??= Quark.Padding.OnX.Is2_5.OnY.Is2;
		TextSize ??= Quark.TextSize.Base.OnMd.Sm;
		Transition ??= Quark.Transition.Colors;
		OutlineStyle ??= Quark.OutlineStyle.None;
		RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
		Cursor ??= Quark.Cursor.NotAllowed.OnDisabled;
		Opacity ??= Quark.Opacity.Is50.OnDisabled;
	}

	protected override void BuildAttributesCore(Dictionary<string, object> attributes)
	{
		base.BuildAttributesCore(attributes);
        attributes.Remove("value");
        ApplyFieldControlAttributes(attributes, ShouldShowInvalid());

		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "field-sizing-content placeholder:text-muted-foreground aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 dark:bg-input/30 focus-visible:ring-[3px]");

			var sizeClass = GetSizeClass();
			if (sizeClass != null)
				AppendClass(ref cls, sizeClass);

			var validationClass = GetValidationClass();
			if (validationClass != null)
				AppendClass(ref cls, validationClass);

            if (UsesAutoSaveStatusSlot)
                AppendClass(ref cls, "min-w-0 flex-1");
		});

		if (Placeholder.HasContent())
			attributes["placeholder"] = Placeholder;

		if (Disabled)
			attributes["disabled"] = true;

		if (ReadOnly)
			attributes["readonly"] = true;

		if (Required)
			attributes["required"] = true;

		if (Rows > 0)
			attributes["rows"] = Rows;

		if (MaxLength > 0)
			attributes["maxlength"] = MaxLength;

		if (MinLength > 0)
			attributes["minlength"] = MinLength;

		if (Pattern.HasContent())
			attributes["pattern"] = Pattern;

		if (AutoResize)
			BuildStyleAttribute(attributes, (ref sty) => AppendStyleDecl(ref sty, "resize: vertical; min-height: 60px;"));

        if (OnBlur.HasDelegate || (AutoSave && AutoSaveOnBlur && OnAutoSave is not null))
            attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleMemoBlur);

        if (OnKeyDown.HasDelegate || (AutoSave && AutoSaveOnEnter && OnAutoSave is not null))
            attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleMemoKeyDown);
	}

    private async Task HandleInputValueChanged(string? newValue)
	{
		newValue ??= string.Empty;
		var valueChanged = false;
		if (Value != newValue)
		{
			Value = newValue;
			await ValueChanged.InvokeAsync(Value);
            await CapturePendingSelection(Value);
			valueChanged = true;
		}

		if (OnInput.HasDelegate)
			await OnInput.InvokeIfHasDelegate(new ChangeEventArgs { Value = Value });

		if (ParentValidation is not null)
		{
			ParentValidation.MarkTouched();
			await ParentValidation.NotifyInputChanged(Value);
		}

		if (valueChanged)
            await _autoSave.NotifyValueChanged(Value, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
	}

    private async Task HandleChange(ChangeEventArgs e)
	{
		var newValue = e?.Value?.ToString() ?? string.Empty;
		var valueChanged = false;
		if (Value != newValue)
		{
			Value = newValue;
			await ValueChanged.InvokeAsync(Value);
			valueChanged = true;
		}

		await OnChange.InvokeIfHasDelegate(e);

		if (ParentValidation is not null)
		{
			ParentValidation.MarkTouched();
			await ParentValidation.NotifyInputChanged(Value);
		}

		if (valueChanged)
            await _autoSave.NotifyValueChanged(Value, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
	}

    private async Task CapturePendingSelection(string? value)
    {
        var selection = await InputInterop.GetSelection(_elementRef);

        if (selection is not null && string.Equals(selection.Value, value, StringComparison.Ordinal))
            _pendingSelectionRestore = selection;
    }

    private async Task RestorePendingSelection()
    {
        var selection = _pendingSelectionRestore;

        if (selection is null)
            return;

        _pendingSelectionRestore = null;
        await InputInterop.RestoreSelection(_elementRef, selection.Start, selection.End, selection.Value);
    }

    private async Task HandleMemoBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            _autoSave.QueueFlush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleMemoKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await _autoSave.Flush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

	public override async ValueTask DisposeAsync()
    {
		await base.DisposeAsync();
        await _autoSave.DisposeAsync();

		if (ParentValidation is not null)
			ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
	    }

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
        base.ComputeRenderKeyCore(ref hc);
		hc.Add(Value);
		hc.Add(Rows);
		hc.Add(MaxLength);
		hc.Add(MinLength);
		hc.Add(Pattern);
		hc.Add(AutoResize);
		AddIf(ref hc, InputSize);
		hc.Add(Placeholder);
		hc.Add(Disabled);
		hc.Add(ReadOnly);
		hc.Add(Required);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(_autoSave.State);
        hc.Add(_autoSave.HasSaved);
        hc.Add(OnAutoSave is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
	}
}
