@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements Soenneker.Quark.IValidationInput
@implements ISwitch
@implements IDisposable
<div @attributes="BuildWrapperAttributes()">
    <label class="inline-flex cursor-pointer items-center gap-2">
        <span class="group/switch relative inline-flex shrink-0">
            <input id="@ControlId" type="checkbox" checked="@Checked" @onclick="HandleInputClick" @onchange="HandleChange" @attributes="BuildInputAttributes()" />
            <span @attributes="BuildTrackAttributes()">
                <span @attributes="BuildThumbAttributes()"></span>
            </span>
        </span>
        @if (ChildContent != null)
        {
            <span @attributes="BuildLabelAttributes()">@ChildContent</span>
        }
        else if (Label.HasContent())
        {
            <span @attributes="BuildLabelAttributes()">@Label</span>
        }
    </label>
</div>

@code {
    public override string? Id { get; set; } = $"switch-{Guid.NewGuid():N}";

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public CssValue<SizeBuilder>? Size { get; set; } = Quark.Size.Default;

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    public object? ValidationValue => Checked;

    private string ControlId => CurrentFieldContext?.ControlId ?? Id!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            if (CheckedExpression is not null)
                await ParentValidation.InitializeInputExpression(CheckedExpression);

            await ParentValidation.InitializeInput(this);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
    }

    private async void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        await RefreshOffThread();
    }

    private bool IsSmSize()
    {
        if (Size == null) return false;
        var s = Size.Value.ToString()?.ToLowerInvariant();
        return s == "sm" || s == "xs";
    }

    protected Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-switch");
            AppendClass(ref cls, "flex items-center gap-2");
        });

        if (Style.HasContent())
            attributes["style"] = Style;

        return attributes;
    }

    private Dictionary<string, object> BuildLabelAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "text-sm font-medium leading-none peer-disabled:cursor-not-allowed peer-disabled:opacity-50"));
        return attributes;
    }

    // Switch track: peer inline-flex shrink-0 cursor-pointer items-center rounded-full border-2 border-transparent, transition-colors, focus-visible:ring-2, disabled:*, size, checked:bg-primary / bg-input
    private Dictionary<string, object> BuildTrackAttributes()
    {
        var attributes = new Dictionary<string, object>();
        var sm = IsSmSize();
        attributes["data-slot"] = "switch";
        attributes["data-size"] = sm ? "sm" : "default";
        attributes["data-state"] = Checked ? "checked" : "unchecked";

        if (Checked)
            attributes["data-checked"] = "true";
        else
            attributes["data-unchecked"] = "true";

        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/switch peer inline-flex shrink-0 cursor-pointer items-center rounded-full border border-transparent shadow-xs transition-all outline-none");
            AppendClass(ref cls, "peer-focus-visible:border-ring peer-focus-visible:ring-[3px] peer-focus-visible:ring-ring/50 peer-disabled:cursor-not-allowed peer-disabled:opacity-50");
            AppendClass(ref cls, "data-[state=checked]:bg-primary data-[state=unchecked]:bg-input dark:data-[state=unchecked]:bg-input/80");
            AppendClass(ref cls, sm ? "h-3.5 w-6" : "h-[1.15rem] w-8");
            var v = GetValidationClass();
            if (v != null) AppendClass(ref cls, v);
        });
        return attributes;
    }

    private Dictionary<string, object> BuildInputAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["class"] = "sr-only peer",
            ["role"] = "switch",
            ["aria-checked"] = Checked ? "true" : "false"
        };

        if (Name.HasContent())
            attributes["name"] = Name!;

        if (Value.HasContent())
            attributes["value"] = Value!;

        if (Required)
            attributes["required"] = true;

        if (AutoFocus)
            attributes["autofocus"] = true;

        if (Disabled)
            attributes["disabled"] = true;

        if (Attributes is not null)
        {
            foreach (var attribute in Attributes)
            {
                if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[attribute.Key] = attribute.Value;
            }
        }

        ApplyFieldControlAttributes(attributes, ParentValidation?.Status == ValidationStatus.Error);
        return attributes;
    }

    private string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error)
            return "peer-aria-invalid:ring-destructive/20 dark:peer-aria-invalid:ring-destructive/40 peer-aria-invalid:border-destructive";
        return null;
    }

    private Dictionary<string, object> BuildThumbAttributes()
    {
        var attributes = new Dictionary<string, object>();
        attributes["data-slot"] = "switch-thumb";
        attributes["data-state"] = Checked ? "checked" : "unchecked";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "pointer-events-none block rounded-full bg-background ring-0 transition-transform");
            AppendClass(ref cls, "group-data-[size=default]/switch:size-4 group-data-[size=sm]/switch:size-3");
            AppendClass(ref cls, "data-[state=checked]:translate-x-[calc(100%-2px)] data-[state=unchecked]:translate-x-0");
            AppendClass(ref cls, "dark:data-[state=checked]:bg-primary-foreground dark:data-[state=unchecked]:bg-foreground");
        });
        return attributes;
    }

    private Task HandleInputClick(MouseEventArgs args)
    {
        return base.HandleClick(args);
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (Disabled)
            return;

        var next = e.Value switch
        {
            bool value => value,
            string value when bool.TryParse(value, out var parsed) => parsed,
            _ => !Checked
        };

        if (next != Checked)
        {
            Checked = next;
            await CheckedChanged.InvokeAsync(next);
            InvalidateRender();
            Refresh();
        }

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(next);
        }

        await OnChange.InvokeIfHasDelegate(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);

        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(Name);
        hc.Add(Value);
        hc.Add(Label);
        AddIf(ref hc, Size);
    }

    public override void Dispose()
    {
        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;

        base.Dispose();
    }
}
