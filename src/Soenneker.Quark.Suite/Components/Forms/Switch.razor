@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix
@using System.Threading

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements Soenneker.Quark.IValidationInput
@implements ISwitch

@if (HasInlineLabel)
{
    <Label For="@ControlId" Display="Quark.Display.InlineFlex" Cursor="Quark.Cursor.Pointer" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is2">
        <BradixSwitch Checked="@Checked"
                      Required="@Required"
                      Disabled="@Disabled"
                      Name="@Name"
                      Value="@ResolvedSwitchValue"
                      CheckedChanged="HandleCheckedChanged"
                      OnClick="@OnClick"
                      AdditionalAttributes="@BuildControlAttributes()">
            <BradixSwitchThumb AdditionalAttributes="@BuildThumbAttributes()" />
        </BradixSwitch>
        @if (ChildContent != null)
        {
            <Span @attributes="BuildLabelAttributes()">@ChildContent</Span>
        }
        else if (Label.HasContent())
        {
            <Span @attributes="BuildLabelAttributes()">@Label</Span>
        }
        <AutoSaveStatus State="@_autoSave.State"
                        HasSaved="@_autoSave.HasSaved"
                        Visible="@UsesAutoSaveStatusSlot"
                        Class="@AutoSaveStatusClass"
                        SavingClass="@AutoSaveSavingClass"
                        SavedClass="@AutoSaveSavedClass"
                        FailedClass="@AutoSaveFailedClass" />
    </Label>
}
else if (UsesAutoSaveStatusSlot)
{
    <Span Display="Quark.Display.InlineFlex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is2">
        <BradixSwitch Checked="@Checked"
                      Required="@Required"
                      Disabled="@Disabled"
                      Name="@Name"
                      Value="@ResolvedSwitchValue"
                      CheckedChanged="HandleCheckedChanged"
                      OnClick="@OnClick"
                      AdditionalAttributes="@BuildControlAttributes()">
            <BradixSwitchThumb AdditionalAttributes="@BuildThumbAttributes()" />
        </BradixSwitch>
        <AutoSaveStatus State="@_autoSave.State"
                        HasSaved="@_autoSave.HasSaved"
                        Visible="@UsesAutoSaveStatusSlot"
                        Class="@AutoSaveStatusClass"
                        SavingClass="@AutoSaveSavingClass"
                        SavedClass="@AutoSaveSavedClass"
                        FailedClass="@AutoSaveFailedClass" />
    </Span>
}
else
{
    <BradixSwitch Checked="@Checked"
                  Required="@Required"
                  Disabled="@Disabled"
                  Name="@Name"
                  Value="@ResolvedSwitchValue"
                  CheckedChanged="HandleCheckedChanged"
                  OnClick="@OnClick"
                  AdditionalAttributes="@BuildControlAttributes()">
        <BradixSwitchThumb AdditionalAttributes="@BuildThumbAttributes()" />
    </BradixSwitch>
}

@code {
    private readonly AutoSaveController<bool?> _autoSave = new();

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public CssValue<SwitchSizeBuilder>? SwitchSize { get; set; } = SwitchSizes.Default;

    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<bool?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    public object? ValidationValue => Checked;

    private bool HasInlineLabel => ChildContent != null || Label.HasContent();
    private bool UsesAutoSaveStatusSlot => AutoSave && OnAutoSave is not null && ShowAutoSaveStatus;
    private string ControlId => CurrentFieldContext?.ControlId ?? Id!;
    private string ResolvedSwitchValue => Value.HasContent() ? Value! : "on";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "switch";
    }

    protected override void OnInitialized()
    {
        Id ??= BlazorIdGenerator.New("quark-switch");

        base.OnInitialized();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            if (CheckedExpression is not null)
                await ParentValidation.InitializeInputExpression(CheckedExpression);

            await ParentValidation.InitializeInput(this);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        _ = RefreshOffThread();
    }

    private bool IsSmSize()
    {
        if (SwitchSize == null)
            return false;

        return string.Equals(SwitchSize?.ToString(), "sm", StringComparison.OrdinalIgnoreCase);
    }

    private Dictionary<string, object> BuildLabelAttributes()
    {
        var attributes = new Dictionary<string, object>();
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "text-sm font-medium leading-none"));
        return attributes;
    }

    private Dictionary<string, object> BuildControlAttributes()
    {
        var attributes = new Dictionary<string, object>();
        var sm = IsSmSize();

        attributes["id"] = ControlId;
        attributes["data-slot"] = DataSlot!;
        attributes["data-size"] = sm ? "sm" : "default";

        if (Disabled)
            attributes["data-disabled"] = "";

        if (OnBlur.HasDelegate || (AutoSave && AutoSaveOnBlur && OnAutoSave is not null))
            attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleControlBlur);

        if (OnKeyDown.HasDelegate || (AutoSave && AutoSaveOnEnter && OnAutoSave is not null))
            attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleControlKeyDown);

        if (Attributes is not null)
        {
            foreach (var attribute in Attributes)
            {
                if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("type", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onclick", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("name", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("value", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("role", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("aria-checked", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("disabled", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[attribute.Key] = attribute.Value;
            }
        }

        ApplyFieldControlAttributes(attributes, ParentValidation?.Status == ValidationStatus.Error);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "peer group/switch relative inline-flex shrink-0 items-center rounded-full border border-transparent transition-all outline-none");
            AppendClass(ref cls, "after:absolute after:-inset-x-3 after:-inset-y-2");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "data-[size=default]:h-[18.4px] data-[size=default]:w-[32px] data-[size=sm]:h-[14px] data-[size=sm]:w-[24px]");
            AppendClass(ref cls, "data-checked:bg-primary data-unchecked:bg-input dark:data-unchecked:bg-input/80 data-disabled:cursor-not-allowed data-disabled:opacity-50");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildThumbAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "switch-thumb"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "pointer-events-none block rounded-full bg-background ring-0 transition-transform");
            AppendClass(ref cls, "group-data-[size=default]/switch:size-4 group-data-[size=sm]/switch:size-3");
            AppendClass(ref cls, "group-data-[size=default]/switch:data-checked:translate-x-[calc(100%-2px)] group-data-[size=sm]/switch:data-checked:translate-x-[calc(100%-2px)]");
            AppendClass(ref cls, "dark:data-checked:bg-primary-foreground group-data-[size=default]/switch:data-unchecked:translate-x-0 group-data-[size=sm]/switch:data-unchecked:translate-x-0");
            AppendClass(ref cls, "dark:data-unchecked:bg-foreground");
        });

        return attributes;
    }

    private async Task HandleCheckedChanged(bool next)
    {
        Checked = next;
        await CheckedChanged.InvokeAsync(next);
        await _autoSave.NotifyValueChanged(next, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(next);
        }

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = next });
        InvalidateRender();
        Refresh();
    }

    private async Task HandleControlBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            _autoSave.QueueFlush(Checked, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleControlKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await _autoSave.Flush(Checked, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Checked);
        hc.Add(Disabled);
        hc.Add(Name);
        hc.Add(Value);
        hc.Add(Label);
        AddIf(ref hc, SwitchSize);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(_autoSave.State);
        hc.Add(_autoSave.HasSaved);
        hc.Add(OnAutoSave is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
    }

    public override async ValueTask DisposeAsync()
    {
        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;

        await _autoSave.DisposeAsync();
        await base.DisposeAsync();
    }
}
