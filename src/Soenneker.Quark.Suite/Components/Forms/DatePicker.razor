@using System.Globalization
@using System.Linq.Expressions
@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements Soenneker.Quark.IValidationInput
@implements IDatePicker

<Popover Open="@_open"
         OpenChanged="HandleOpenChanged">
    <div @attributes="GetContainerAttributes()">
        <input type="hidden" @attributes="BuildHiddenInputAttributes()" />

        <PopoverTrigger AsChild="true">
            <Button Variant="ButtonVariant.Outline"
                    Disabled="Disabled"
                    Class="@GetTriggerClass()"
                    @attributes="BuildTriggerAttributes()">
                @if (SelectedDate.HasValue)
                {
                    <span>@FormatDisplay(SelectedDate.Value)</span>
                }
                else
                {
                    <span>@GetPlaceholderText()</span>
                }
                <Icon Name="LucideIcon.ChevronDown" />
            </Button>
        </PopoverTrigger>

        <PopoverContent Id="@_panelId"
                        Side="bottom"
                        PlacementAlign="start"
                        Width="Quark.Width.Auto"
                        Padding="Quark.Padding.Is0"
                        @attributes="PanelAttributes">
            <Calendar SelectedDate="SelectedDate"
                      SelectedDateChanged="HandleCalendarChanged"
                      DisplayMonth="_displayMonth"
                      DisplayMonthChanged="HandleCalendarMonthChanged"
                      Min="Min"
                      Max="Max"
                      Class="border-0 shadow-none p-0 min-w-0" />
        </PopoverContent>
    </div>
</Popover>

@code {

    /// <summary>
    /// Gets or sets the selected date value.
    /// </summary>
    [Parameter]
    public DateOnly? SelectedDate { get; set; }

    /// <summary>
    /// Gets or sets the expression that identifies the bound value.
    /// </summary>
    [Parameter]
    public Expression<Func<DateOnly?>>? SelectedDateExpression { get; set; }

    /// <summary>
    /// Gets or sets the minimum date value.
    /// </summary>
    [Parameter]
    public DateOnly? Min { get; set; }

    /// <summary>
    /// Gets or sets the maximum date value.
    /// </summary>
    [Parameter]
    public DateOnly? Max { get; set; }

    /// <summary>
    /// Gets or sets the size of the date picker.
    /// </summary>
    [Parameter]
    public CssValue<InputSizeBuilder>? Size { get; set; } = InputSizes.Default;

    /// <summary>
    /// Gets or sets the callback invoked When the value changes.
    /// </summary>
    [Parameter]
    public EventCallback<DateOnly?> SelectedDateChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the input changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the input value changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnInput { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// </summary>
    public object? ValidationValue => SelectedDate;

    private bool _open;
    private DateOnly _displayMonth = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _lastSyncedSelectedDate;
    private readonly string _panelId = BlazorIdGenerator.New("quark-datepicker-panel");

    private IReadOnlyDictionary<string, object> PanelAttributes => new Dictionary<string, object>
    {
        ["data-slot"] = "date-picker-panel"
    };

    private string TriggerId => CurrentFieldContext?.ControlId ?? Id ?? _panelId;

    private static string FormatDisplay(DateOnly value)
    {
        return value.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);
    }

    private string GetPlaceholderText()
    {
        return Placeholder.HasContent() ? Placeholder! : "Pick a date";
    }

    private string GetSerializedValue()
    {
        return SelectedDate?.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) ?? string.Empty;
    }

    private string GetTriggerClass()
    {
        var baseClass = "w-[212px] justify-between rounded-lg text-left font-normal data-[empty=true]:text-muted-foreground";
        return Class.HasContent() ? AppendToClass(Class, baseClass) : baseClass;
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["id"] = TriggerId,
            ["data-empty"] = SelectedDate.HasValue ? "false" : "true"
        };

        if (Attributes is not null)
        {
            foreach (var attribute in Attributes)
            {
                if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("value", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("name", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("placeholder", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("readonly", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("required", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("autocomplete", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("oninput", StringComparison.OrdinalIgnoreCase) ||
                    attribute.Key.Equals("onchange", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[attribute.Key] = attribute.Value;
            }
        }

        ApplyFieldControlAttributes(attributes, ParentValidation?.Status == ValidationStatus.Error);
        return attributes;
    }

    private IReadOnlyDictionary<string, object> BuildHiddenInputAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["aria-hidden"] = "true",
            ["tabindex"] = "-1",
            ["value"] = GetSerializedValue()
        };

        if (Name.HasContent())
            attributes["name"] = Name!;

        if (Disabled)
            attributes["disabled"] = true;

        return attributes;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);

            if (SelectedDateExpression is not null)
                await ParentValidation.InitializeInputExpression(SelectedDateExpression);
        }

        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            if (SelectedDate.HasValue)
                _displayMonth = new DateOnly(SelectedDate.Value.Year, SelectedDate.Value.Month, 1);
            else
                _displayMonth = new DateOnly(DateOnly.FromDateTime(DateTime.Today).Year, DateOnly.FromDateTime(DateTime.Today).Month, 1);
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (SelectedDate != _lastSyncedSelectedDate)
            SyncDisplayMonthToSelection(SelectedDate);
    }

    private Dictionary<string, object> GetContainerAttributes()
    {
        var attrs = new Dictionary<string, object>(2);
        BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "relative w-fit");
        });
        return attrs;
    }

    private Task HandleOpenChanged(bool open)
    {
        _open = open;
        InvalidateRender();
        Refresh();
        return Task.CompletedTask;
    }

    internal async Task ClosePanel()
    {
        if (_open)
            _open = false;

        await RefreshOffThread();
    }

    private async Task NotifyValueChanged(bool valueChanged)
    {
        var serializedValue = GetSerializedValue();
        var args = new ChangeEventArgs { Value = serializedValue };

        if (valueChanged)
            await SelectedDateChanged.InvokeIfHasDelegate(SelectedDate);

        await OnInput.InvokeIfHasDelegate(args);
        await OnChange.InvokeIfHasDelegate(args);

        if (ParentValidation is not null)
            await ParentValidation.NotifyInputChanged(SelectedDate);
    }

    private async Task HandleCalendarChanged(DateOnly? date)
    {
        if (!date.HasValue)
            return;

        if ((Min.HasValue && date.Value < Min.Value) || (Max.HasValue && date.Value > Max.Value))
            return;

        var valueChanged = SelectedDate != date;
        SelectedDate = date;
        SyncDisplayMonthToSelection(date);

        if (ParentValidation is not null)
            ParentValidation.MarkTouched();

        await NotifyValueChanged(valueChanged);
        await ClosePanel();
    }

    private Task HandleCalendarMonthChanged(DateOnly? month)
    {
        if (month.HasValue)
            _displayMonth = new DateOnly(month.Value.Year, month.Value.Month, 1);

        InvalidateRender();
        Refresh();
        return Task.CompletedTask;
    }

    private void SyncDisplayMonthToSelection(DateOnly? selectedDate)
    {
        _lastSyncedSelectedDate = selectedDate;

        if (!selectedDate.HasValue)
            return;

        _displayMonth = new DateOnly(selectedDate.Value.Year, selectedDate.Value.Month, 1);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(SelectedDate);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
        hc.Add(Min);
        hc.Add(Max);
        hc.Add(_open);
        hc.Add(_panelId);
        AddIf(ref hc, Size);
    }
}
