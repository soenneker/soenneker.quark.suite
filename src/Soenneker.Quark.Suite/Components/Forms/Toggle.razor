@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements IToggle

<BradixToggle Pressed="@Pressed"
              Disabled="@Disabled"
              PressedChanged="HandlePressedChanged"
              OnClick="@OnClick"
              OnFocus="@OnFocus"
              OnKeyDown="@OnKeyDown"
              AdditionalAttributes="@ToggleAttributes">
    @ChildContent
</BradixToggle>

@code {
    /// <summary>
    /// Gets or sets whether the toggle is pressed.
    /// </summary>
    [Parameter]
    public bool Pressed { get; set; }

    /// <summary>
    /// Gets or sets callback invoked when pressed state changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> PressedChanged { get; set; }

    /// <summary>
    /// Gets or sets visual variant.
    /// </summary>
    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    /// <summary>
    /// Gets or sets size.
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? Size { get; set; } = "default";

    protected override void ApplyDefaultParameters()
    {
        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.Token("transition-[color,shadow]");
        OutlineStyle ??= Quark.OutlineStyle.None;

        ApplyVariantDefaults();
        ApplySizeDefaults();

        base.ApplyDefaultParameters();
    }

    private void ApplyVariantDefaults()
    {
        if (Variant?.Value == ToggleVariant.OutlineValue)
        {
            Border ??= Quark.Border.Default;
            BorderColor ??= Quark.BorderColor.Input;
            BackgroundColor ??= Quark.BackgroundColor.Transparent;
            Shadow ??= Quark.Shadow.Xs;
        }
        else
        {
            BackgroundColor ??= Quark.BackgroundColor.Transparent;
        }
    }

    private void ApplySizeDefaults()
    {
        string? size = Size?.TryGetThemeToken(out var token) == true ? token : Size?.ToString();

        switch (size)
        {
            case "sm":
                Height ??= Quark.Height.Is8;
                MinWidth ??= Quark.MinWidth.Token("8");
                Padding ??= Quark.Padding.Token("1.5").OnX;
                break;
            case "lg":
                Height ??= Quark.Height.Token("10");
                MinWidth ??= Quark.MinWidth.Token("10");
                Padding ??= Quark.Padding.Token("2.5").OnX;
                break;
            default:
                Height ??= Quark.Height.Token("9");
                MinWidth ??= Quark.MinWidth.Token("9");
                Padding ??= Quark.Padding.Is2.OnX;
                break;
        }
    }

    private IReadOnlyDictionary<string, object> ToggleAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("aria-pressed");
            attributes.Remove("data-state");
            attributes.Remove("type");
            attributes.Remove("onclick");
            attributes.Remove("onfocus");
            attributes.Remove("onkeydown");

            attributes["data-slot"] = "toggle";
            attributes["data-variant"] = Variant?.Value ?? ToggleVariant.Default.Value;

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "hover:bg-muted hover:text-muted-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
                AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 data-[state=on]:bg-accent data-[state=on]:text-accent-foreground dark:aria-invalid:ring-destructive/40");
                AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");

                if (Variant?.Value == ToggleVariant.OutlineValue)
                    AppendClass(ref cls, "hover:bg-accent hover:text-accent-foreground");
            });

            return attributes;
        }
    }

    private async Task HandlePressedChanged(bool pressed)
    {
        Pressed = pressed;
        await PressedChanged.InvokeAsync(pressed);

        InvalidateRender();
        Refresh();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);

        hc.Add(Pressed);
        hc.Add(Disabled);
        hc.Add(Variant);
        hc.Add(Size);
    }

    internal static string GetToggleVariantClass(string? variant)
    {
        return variant switch
        {
            "outline" => "border border-input bg-transparent shadow-xs hover:bg-accent hover:text-accent-foreground",
            _ => "bg-transparent"
        };
    }

    internal static string GetToggleGroupVariantClass(string? variant)
    {
        return variant switch
        {
            _ => string.Empty
        };
    }

    internal static string ResolveToggleSizeClass(CssValue<ToggleSizeBuilder>? size, bool includeShrink)
    {
        if (size?.TryGetThemeToken(out var token) == true && token is not null)
            return ResolveToggleTokenSizeClass(token, includeShrink);

        var value = size?.ToString();
        return value is "default" or "sm" or "lg"
            ? ResolveToggleTokenSizeClass(value, includeShrink)
            : value ?? ResolveToggleTokenSizeClass(ToggleSize.Default.Value, includeShrink);
    }

    internal static string ResolveToggleTokenSizeClass(string? size, bool includeShrink)
    {
        var prefix = includeShrink ? "shrink-0 " : string.Empty;

        return size switch
        {
            "sm" => $"{prefix}h-8 min-w-8 px-1.5",
            "lg" => $"{prefix}h-10 min-w-10 px-2.5",
            _ => $"{prefix}h-9 min-w-9 px-2"
        };
    }
}
