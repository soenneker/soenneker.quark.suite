@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements IToggle

<BradixToggle Pressed="@Pressed"
              Disabled="@Disabled"
              PressedChanged="HandlePressedChanged"
              OnClick="@OnClick"
              OnFocus="@OnFocus"
              OnKeyDown="@OnKeyDown"
              AdditionalAttributes="@ToggleAttributes">
    @ChildContent
</BradixToggle>

@code {
    /// <summary>
    /// Gets or sets whether the toggle is pressed.
    /// </summary>
    [Parameter]
    public bool Pressed { get; set; }

    /// <summary>
    /// Gets or sets callback invoked when pressed state changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> PressedChanged { get; set; }

    /// <summary>
    /// Gets or sets visual variant.
    /// </summary>
    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    /// <summary>
    /// Gets or sets size.
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? Size { get; set; } = "default";

    private IReadOnlyDictionary<string, object> ToggleAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("aria-pressed");
            attributes.Remove("data-state");
            attributes.Remove("type");
            attributes.Remove("onclick");
            attributes.Remove("onfocus");
            attributes.Remove("onkeydown");

            attributes["data-slot"] = "toggle";
            attributes["data-variant"] = Variant?.Value ?? ToggleVariant.Default.Value;

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "group/toggle inline-flex items-center justify-center gap-1 rounded-lg text-sm font-medium whitespace-nowrap transition-all outline-none");
                AppendClass(ref cls, "hover:bg-muted hover:text-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
                AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
                AppendClass(ref cls, "aria-pressed:bg-muted data-[state=on]:bg-muted [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
                AppendClass(ref cls, GetToggleVariantClass(Variant?.Value));
                AppendClass(ref cls, ResolveToggleSizeClass(Size, includeShrink: false));
            });

            return attributes;
        }
    }

    private async Task HandlePressedChanged(bool pressed)
    {
        Pressed = pressed;
        await PressedChanged.InvokeAsync(pressed);

        InvalidateRender();
        Refresh();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);

        hc.Add(Pressed);
        hc.Add(Disabled);
        hc.Add(Variant);
        hc.Add(Size);
    }

    internal static string GetToggleVariantClass(string? variant)
    {
        return variant switch
        {
            "outline" => "border border-input bg-transparent hover:bg-muted",
            _ => "bg-transparent"
        };
    }

    internal static string GetToggleGroupVariantClass(string? variant)
    {
        return variant switch
        {
            "outline" => "data-[variant=outline]:shadow-xs",
            _ => string.Empty
        };
    }

    internal static string ResolveToggleSizeClass(CssValue<ToggleSizeBuilder>? size, bool includeShrink)
    {
        if (size?.TryGetThemeToken(out var token) == true && token is not null)
            return ResolveToggleTokenSizeClass(token, includeShrink);

        return size?.ToString() ?? ResolveToggleTokenSizeClass(ToggleSize.Default.Value, includeShrink);
    }

    internal static string ResolveToggleTokenSizeClass(string? size, bool includeShrink)
    {
        string prefix = includeShrink ? "shrink-0 " : string.Empty;

        return size switch
        {
            "sm" => $"{prefix}h-7 min-w-7 rounded-[min(var(--radius-md),12px)] px-2.5 text-[0.8rem] has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 [&_svg:not([class*='size-'])]:size-3.5",
            "lg" => $"{prefix}h-9 min-w-9 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2",
            _ => $"{prefix}h-8 min-w-8 px-2.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2"
        };
    }
}
