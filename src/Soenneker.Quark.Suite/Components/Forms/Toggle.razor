@using Soenneker.Bradix
@using Soenneker.Blazor.Extensions.EventCallback
@using System.Threading

@namespace Soenneker.Quark
@inherits Soenneker.Quark.ToggleElement
@implements IToggle

@if (UsesAutoSaveStatusSlot)
{
    <span class="inline-flex items-center gap-2">
        <BradixToggle Pressed="@Pressed" Disabled="@Disabled" PressedChanged="HandlePressedChanged" OnClick="@OnClick" OnFocus="@OnFocus" OnKeyDown="HandleToggleKeyDown" AdditionalAttributes="@ToggleAttributes">
            @ChildContent
        </BradixToggle>
        <AutoSaveStatus State="@_autoSave.State"
                        HasSaved="@_autoSave.HasSaved"
                        Visible="@UsesAutoSaveStatusSlot"
                        Class="@AutoSaveStatusClass"
                        SavingClass="@AutoSaveSavingClass"
                        SavedClass="@AutoSaveSavedClass"
                        FailedClass="@AutoSaveFailedClass" />
    </span>
}
else
{
    <BradixToggle Pressed="@Pressed" Disabled="@Disabled" PressedChanged="HandlePressedChanged" OnClick="@OnClick" OnFocus="@OnFocus" OnKeyDown="HandleToggleKeyDown" AdditionalAttributes="@ToggleAttributes">
        @ChildContent
    </BradixToggle>
}

@code {
    private readonly AutoSaveController<bool?> _autoSave = new();

    /// <summary>
    /// Gets or sets whether the toggle is pressed.
    /// </summary>
    [Parameter]
    public bool Pressed { get; set; }

    /// <summary>
    /// Gets or sets callback invoked when pressed state changes.
    /// </summary>
    [Parameter]
    public EventCallback<bool> PressedChanged { get; set; }

    /// <summary>
    /// Gets or sets visual variant.
    /// </summary>
    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    /// <summary>
    /// Gets or sets size.
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? ToggleSize { get; set; } = "default";

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<bool?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    /// <summary>
    /// Gets or sets the HTML direction for the toggle; falls back to <see cref="DirectionProvider"/>.
    /// </summary>
    [Parameter]
    public string? Dir { get; set; }

    private string? ResolvedDir => !string.IsNullOrWhiteSpace(Dir) ? Dir : DirectionProviderDir;
    private bool UsesAutoSaveStatusSlot => AutoSave && OnAutoSave is not null && ShowAutoSaveStatus;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "toggle";
        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is1;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;

        if (ReferenceEquals(Variant, ToggleVariant.Outline))
        {
            Border ??= Quark.Border.Default;
            BorderColor ??= Quark.BorderColor.Input.OnFocusVisible.Ring;
            BorderColor ??= Quark.BorderColor.OnFocusVisible.Ring;
        }

        BackgroundColor ??= Quark.BackgroundColor.Transparent;
    }

    private IReadOnlyDictionary<string, object> ToggleAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("aria-pressed");
            attributes.Remove("data-state");
            attributes.Remove("type");
            attributes.Remove("onclick");
            attributes.Remove("onfocus");
            attributes.Remove("onkeydown");

            if (!string.IsNullOrWhiteSpace(ResolvedDir))
                attributes["dir"] = ResolvedDir;

            attributes["data-state"] = Pressed ? "on" : "off";

            if (OnBlur.HasDelegate || (AutoSave && AutoSaveOnBlur && OnAutoSave is not null))
                attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleToggleBlur);

            BuildClassAttribute(attributes, (ref cls) =>
            {
                var isRtl = string.Equals(ResolvedDir, "rtl", StringComparison.OrdinalIgnoreCase);
                AppendClass(ref cls, "group/toggle hover:bg-muted hover:text-foreground focus-visible:ring-[3px]");
                AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 aria-pressed:bg-muted data-[state=on]:bg-muted dark:aria-invalid:ring-destructive/40");
                AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0");
                AppendClass(ref cls, GetToggleVariantClass(Variant));
                AppendClass(ref cls, ResolveToggleSizeClass(ToggleSize, includeShrink: false, isRtl));
            });

            return attributes;
        }
    }

    private async Task HandlePressedChanged(bool pressed)
    {
        Pressed = pressed;
        await PressedChanged.InvokeAsync(pressed);
        await _autoSave.NotifyValueChanged(pressed, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        InvalidateRender();
        Refresh();
    }

    private async Task HandleToggleBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            await _autoSave.Flush(Pressed, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleToggleKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await _autoSave.Flush(Pressed, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);

        hc.Add(Pressed);
        hc.Add(Disabled);
        hc.Add(Variant);
        hc.Add(ToggleSize);
        hc.Add(Dir);
        hc.Add(DirectionProviderDir);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(_autoSave.State);
        hc.Add(_autoSave.HasSaved);
        hc.Add(OnAutoSave is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
    }

    public override async ValueTask DisposeAsync()
    {
        await _autoSave.DisposeAsync();
        await base.DisposeAsync();
    }

    internal static string GetToggleVariantClass(ToggleVariant? variant)
    {
        if (ReferenceEquals(variant, ToggleVariant.Outline))
            return "border border-input bg-transparent hover:bg-muted";

        return "bg-transparent";
    }

    internal static string GetToggleGroupVariantClass(ToggleVariant? variant)
    {
        return string.Empty;
    }

    internal static string ResolveToggleSizeClass(CssValue<ToggleSizeBuilder>? size, bool includeShrink, bool isRtl = false)
    {
        var value = size?.ToString();

        if (string.IsNullOrWhiteSpace(value))
            return ResolveToggleTokenSizeClass("default", includeShrink, isRtl);

        var resolved = ResolveToggleTokenSizeClass(value, includeShrink, isRtl);
        return string.IsNullOrEmpty(resolved) ? value : resolved;
    }

    internal static string ResolveToggleTokenSizeClass(string? size, bool includeShrink, bool isRtl = false)
    {
        var prefix = includeShrink ? "shrink-0 " : string.Empty;
        var iconPadding = isRtl ? "has-data-[icon=inline-end]:pe-2 has-data-[icon=inline-start]:ps-2" : "has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2";
        var iconPaddingSm = isRtl ? "has-data-[icon=inline-end]:pe-1.5 has-data-[icon=inline-start]:ps-1.5" : "has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5";

        return size switch
        {
            "sm" => $"{prefix}h-7 min-w-7 rounded-[min(var(--radius-md),12px)] px-2.5 text-[0.8rem] {iconPaddingSm} [&_svg:not([class*='size-'])]:size-3.5",
            "lg" => $"{prefix}{(includeShrink ? string.Empty : "h-9 ")}min-w-9 rounded-lg text-sm px-2.5 {iconPadding} [&_svg:not([class*='size-'])]:size-4",
            "default" => $"{prefix}h-8 min-w-8 rounded-lg text-sm px-2.5 {iconPadding} [&_svg:not([class*='size-'])]:size-4",
            _ => string.Empty
        };
    }

}
