@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.FormControlElement

<CascadingValue Name="ParentToggleGroup" Value="@this" IsFixed="true">
    <BradixToggleGroup Type="@Type"
                       Disabled="@Disabled"
                       Value="@Value"
                       Values="@Values"
                       Dir="@ResolvedDirection"
                       Orientation="@Orientation"
                       ValueChanged="HandleSingleValueChanged"
                       ValuesChanged="HandleMultipleValuesChanged"
                       AdditionalAttributes="@GroupAttributes">
        @ChildContent
    </BradixToggleGroup>
</CascadingValue>

@code {
    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? CascadedDirection { get; set; }

    /// <summary>
    /// Gets or sets the type of toggle group: single (one at a time) or multiple (allow multiple pressed).
    /// </summary>
    [Parameter]
    public SelectionMode Type { get; set; } = SelectionMode.Single;

    /// <summary>
    /// Gets or sets callback when single value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the values for multiple-type groups.
    /// </summary>
    [Parameter]
    public string[]? Values { get; set; }

    /// <summary>
    /// Gets or sets callback when multiple values change.
    /// </summary>
    [Parameter]
    public EventCallback<string[]> ValueChangedMultiple { get; set; }

    /// <summary>
    /// Gets or sets visual variant.
    /// </summary>
    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    /// <summary>
    /// Gets or sets size.
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? Size { get; set; } = "default";

    /// <summary>
    /// Gets or sets the layout direction for toggle group items.
    /// </summary>
    [Parameter]
    public Orientation Orientation { get; set; } = Orientation.Horizontal;

    /// <summary>
    /// Gets or sets spacing between items (0 = no gap, uses default gap).
    /// </summary>
    [Parameter]
    public int Spacing { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    private string? ResolvedDirection => string.IsNullOrWhiteSpace(Dir) ? CascadedDirection : Dir;

    private IReadOnlyDictionary<string, object> GroupAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("value");
            attributes.Remove("name");
            attributes.Remove("readonly");
            attributes.Remove("placeholder");
            attributes.Remove("required");
            attributes.Remove("autofocus");
            attributes.Remove("role");
            attributes.Remove("aria-orientation");

            attributes["data-slot"] = "toggle-group";
            attributes["data-type"] = Type?.Value ?? SelectionMode.Single.Value;
            attributes["data-variant"] = ReferenceEquals(Variant, ToggleVariant.Outline) ? "outline" : "default";
            attributes["data-size"] = GetToggleSizeDataAttribute(Size);
            attributes["data-orientation"] = Orientation?.Value ?? Orientation.Horizontal.Value;
            attributes[Orientation == Orientation.Vertical ? "data-vertical" : "data-horizontal"] = string.Empty;
            attributes["data-spacing"] = Spacing.ToString();

            AppendStyleDeclAttr(attributes, $"--gap:{Spacing}");

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "group/toggle-group flex w-fit flex-row items-center gap-[--spacing(var(--gap))] rounded-md data-[spacing=default]:data-[variant=outline]:shadow-xs");
                AppendClass(ref cls, "data-vertical:flex-col data-vertical:items-stretch");
                AppendClass(ref cls, Toggle.GetToggleGroupVariantClass(Variant));
            });

            return attributes;
        }
    }

    private async Task HandleSingleValueChanged(string? value)
    {
        var normalized = value.HasContent() ? value : null;
        Value = normalized;
        await ValueChanged.InvokeAsync(normalized);
        InvalidateRender();
        Refresh();
    }

    private async Task HandleMultipleValuesChanged(IReadOnlyCollection<string> values)
    {
        Values = values.ToArray();
        await ValueChangedMultiple.InvokeAsync(Values);
        InvalidateRender();
        Refresh();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Type);
        hc.Add(Value);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(Orientation);
        hc.Add(Spacing);
        hc.Add(Dir);
        hc.Add(CascadedDirection);
        if (Values != null)
            foreach (var x in Values) hc.Add(x);
    }

    private static string GetToggleSizeDataAttribute(CssValue<ToggleSizeBuilder>? size)
    {
        if (size?.TryGetThemeToken(out var token) == true && token is not null)
            return token;

        return ToggleSize.Default.Value;
    }
}
