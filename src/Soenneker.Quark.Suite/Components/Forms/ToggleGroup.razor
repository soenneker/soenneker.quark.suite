@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.FormControlElement

<CascadingValue Name="ParentToggleGroup" Value="@this" IsFixed="true">
    <BradixToggleGroup Type="@ResolvedType"
                       Disabled="@Disabled"
                       Value="@Value"
                       Values="@Values"
                       Orientation="@ResolvedOrientation"
                       ValueChanged="HandleSingleValueChanged"
                       ValuesChanged="HandleMultipleValuesChanged"
                       AdditionalAttributes="@GroupAttributes">
        @ChildContent
    </BradixToggleGroup>
</CascadingValue>

@code {
    /// <summary>
    /// Gets or sets the type of toggle group: single (one at a time) or multiple (allow multiple pressed).
    /// </summary>
    [Parameter]
    public ToggleGroupType Type { get; set; } = ToggleGroupType.Single;

    /// <summary>
    /// Gets or sets callback when single value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the values for multiple-type groups.
    /// </summary>
    [Parameter]
    public string[]? Values { get; set; }

    /// <summary>
    /// Gets or sets callback when multiple values change.
    /// </summary>
    [Parameter]
    public EventCallback<string[]> ValueChangedMultiple { get; set; }

    /// <summary>
    /// Gets or sets visual variant.
    /// </summary>
    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    /// <summary>
    /// Gets or sets size.
    /// </summary>
    [Parameter]
    public ToggleSize Size { get; set; } = ToggleSize.Default;

    /// <summary>
    /// Gets or sets the layout direction for toggle group items.
    /// </summary>
    [Parameter]
    public ToggleGroupOrientation Orientation { get; set; } = ToggleGroupOrientation.Horizontal;

    /// <summary>
    /// Gets or sets spacing between items (0 = no gap, uses default gap).
    /// </summary>
    [Parameter]
    public int Spacing { get; set; }

    private static string GetVariantClass(ToggleVariant? variant)
        => (variant?.Value ?? ToggleVariant.DefaultValue) switch
        {
            ToggleVariant.OutlineValue => "data-[variant=outline]:shadow-xs",
            _ => ""
        };

    private BradixSelectionMode ResolvedType => Type == ToggleGroupType.Multiple
        ? BradixSelectionMode.Multiple
        : BradixSelectionMode.Single;

    private BradixOrientation ResolvedOrientation => Orientation == ToggleGroupOrientation.Vertical
        ? BradixOrientation.Vertical
        : BradixOrientation.Horizontal;

    private IReadOnlyDictionary<string, object> GroupAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("value");
            attributes.Remove("name");
            attributes.Remove("readonly");
            attributes.Remove("placeholder");
            attributes.Remove("required");
            attributes.Remove("autofocus");
            attributes.Remove("role");
            attributes.Remove("aria-orientation");

            attributes["data-slot"] = "toggle-group";
            attributes["data-type"] = Type?.Value ?? ToggleGroupType.Single.Value;
            attributes["data-variant"] = Variant?.Value ?? ToggleVariant.Default.Value;
            attributes["data-size"] = Size?.Value ?? ToggleSize.Default.Value;
            attributes["data-orientation"] = Orientation?.Value ?? ToggleGroupOrientation.Horizontal.Value;
            attributes["data-spacing"] = Spacing.ToString();

            if (Spacing > 0)
                AppendStyleDeclAttr(attributes, $"--toggle-gap: {Spacing}px;");

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "q-toggle-group");
                AppendClass(ref cls, "group/toggle-group flex w-fit flex-row items-center rounded-lg");
                AppendClass(ref cls, "data-[size=sm]:rounded-[min(var(--radius-md),10px)]");
                AppendClass(ref cls, "data-[orientation=vertical]:flex-col data-[orientation=vertical]:items-stretch");
                if (Spacing > 0)
                    AppendClass(ref cls, "gap-[var(--toggle-gap,0.5rem)]");
                else
                    AppendClass(ref cls, "gap-0");
            });

            return attributes;
        }
    }

    private async Task HandleSingleValueChanged(string? value)
    {
        var normalized = value.HasContent() ? value : null;
        Value = normalized;
        await ValueChanged.InvokeAsync(normalized);
        InvalidateRender();
        Refresh();
    }

    private async Task HandleMultipleValuesChanged(IReadOnlyCollection<string> values)
    {
        Values = values.ToArray();
        await ValueChangedMultiple.InvokeAsync(Values);
        InvalidateRender();
        Refresh();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Type);
        hc.Add(Value);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(Orientation);
        hc.Add(Spacing);
        if (Values != null)
            foreach (var x in Values) hc.Add(x);
    }
}
