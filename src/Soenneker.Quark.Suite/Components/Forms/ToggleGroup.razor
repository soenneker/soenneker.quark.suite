@namespace Soenneker.Quark
@using Soenneker.Bradix
@using Soenneker.Blazor.Extensions.EventCallback
@using System.Threading
@inherits Soenneker.Quark.FormControlElement

<CascadingValue Name="ParentToggleGroup" Value="@this" IsFixed="true">
    @if (UsesAutoSaveStatusSlot)
    {
        <div class="inline-flex items-center gap-2">
            <BradixToggleGroup Type="@Type"
                               Disabled="@Disabled"
                               Value="@Value"
                               Values="@Values"
                               Dir="@ResolvedDirection"
                               Orientation="@Orientation"
                               ValueChanged="HandleSingleValueChanged"
                               ValuesChanged="HandleMultipleValuesChanged"
                               AdditionalAttributes="@GroupAttributes">
                @ChildContent
            </BradixToggleGroup>
            <AutoSaveStatus State="@CurrentAutoSaveState"
                            Visible="@UsesAutoSaveStatusSlot"
                            Class="@AutoSaveStatusClass"
                            SavingClass="@AutoSaveSavingClass"
                            SavedClass="@AutoSaveSavedClass"
                            FailedClass="@AutoSaveFailedClass" />
        </div>
    }
    else
    {
        <BradixToggleGroup Type="@Type"
                           Disabled="@Disabled"
                           Value="@Value"
                           Values="@Values"
                           Dir="@ResolvedDirection"
                           Orientation="@Orientation"
                           ValueChanged="HandleSingleValueChanged"
                           ValuesChanged="HandleMultipleValuesChanged"
                           AdditionalAttributes="@GroupAttributes">
            @ChildContent
        </BradixToggleGroup>
    }
</CascadingValue>

@code {
    private readonly AutoSaveController<string?> _autoSave = new();
    private readonly AutoSaveController<string[]?> _autoSaveMultiple = new();

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? CascadedDirection { get; set; }

    /// <summary>
    /// Gets or sets the type of toggle group: single (one at a time) or multiple (allow multiple pressed).
    /// </summary>
    [Parameter]
    public SelectionMode Type { get; set; } = SelectionMode.Single;

    /// <summary>
    /// Gets or sets callback when single value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the values for multiple-type groups.
    /// </summary>
    [Parameter]
    public string[]? Values { get; set; }

    /// <summary>
    /// Gets or sets callback when multiple values change.
    /// </summary>
    [Parameter]
    public EventCallback<string[]> ValueChangedMultiple { get; set; }

    /// <summary>
    /// Gets or sets visual variant.
    /// </summary>
    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    /// <summary>
    /// Gets or sets size.
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? ToggleSize { get; set; } = "default";

    /// <summary>
    /// Gets or sets the layout direction for toggle group items.
    /// </summary>
    [Parameter]
    public Orientation Orientation { get; set; } = Orientation.Horizontal;

    /// <summary>
    /// Gets or sets spacing between items (0 = no gap, uses default gap).
    /// </summary>
    [Parameter]
    public int Spacing { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<string?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public Func<string[]?, CancellationToken, ValueTask>? OnAutoSaveMultiple { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

    internal string? ResolvedDirection => string.IsNullOrWhiteSpace(Dir) ? CascadedDirection : Dir;
    private bool UsesMultipleAutosave => Type == SelectionMode.Multiple;
    private AutoSaveState CurrentAutoSaveState => UsesMultipleAutosave ? _autoSaveMultiple.State : _autoSave.State;
    private bool UsesAutoSaveStatusSlot => AutoSave && ShowAutoSaveStatus && (OnAutoSave is not null || OnAutoSaveMultiple is not null);

    internal bool IsItemPressed(string value)
    {
        if (Type == SelectionMode.Multiple)
            return ContainsValue(value);

        return string.Equals(Value, value, StringComparison.Ordinal);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "toggle-group";
    }

    private IReadOnlyDictionary<string, object> GroupAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("value");
            attributes.Remove("name");
            attributes.Remove("readonly");
            attributes.Remove("placeholder");
            attributes.Remove("required");
            attributes.Remove("autofocus");
            attributes.Remove("role");
            attributes.Remove("aria-orientation");

            if (ReferenceEquals(Variant, ToggleVariant.Outline))
                attributes["data-variant"] = "outline";

            var sizeDataAttribute = GetToggleSizeDataAttribute(ToggleSize);
            if (!string.Equals(sizeDataAttribute, "default", StringComparison.Ordinal))
                attributes["data-size"] = sizeDataAttribute;

            attributes["data-orientation"] = Orientation?.Value ?? Orientation.Horizontal.Value;
            attributes["data-spacing"] = Spacing.ToString();

            if (OnBlur.HasDelegate || (AutoSave && AutoSaveOnBlur && (OnAutoSave is not null || OnAutoSaveMultiple is not null)))
                attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleGroupBlur);

            if (OnKeyDown.HasDelegate || (AutoSave && AutoSaveOnEnter && (OnAutoSave is not null || OnAutoSaveMultiple is not null)))
                attributes["onkeydown"] = EventCallback.Factory.Create<KeyboardEventArgs>(this, HandleGroupKeyDown);

            AppendStyleDeclAttr(attributes, $"--gap:{Spacing}");

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "group/toggle-group flex w-fit flex-row items-center gap-[--spacing(var(--gap))] rounded-lg data-[size=sm]:rounded-[min(var(--radius-md),10px)] data-vertical:flex-col data-vertical:items-stretch");
                AppendClass(ref cls, Toggle.GetToggleGroupVariantClass(Variant));
            });

            return attributes;
        }
    }

    private async Task HandleSingleValueChanged(string? value)
    {
        var normalized = value.HasContent() ? value : null;
        Value = normalized;
        await ValueChanged.InvokeAsync(normalized);
        await _autoSave.NotifyValueChanged(normalized, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
        InvalidateRender();
        Refresh();
    }

    private async Task HandleMultipleValuesChanged(IReadOnlyCollection<string> values)
    {
        Values = values as string[] ?? CopyValues(values);
        await ValueChangedMultiple.InvokeAsync(Values);
        await _autoSaveMultiple.NotifyValueChanged(Values, AutoSave, AutoSaveDelay, OnAutoSaveMultiple, AutoSaveStateChanged, RefreshOffThread);
        InvalidateRender();
        Refresh();
    }

    private async Task HandleGroupBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            await FlushAutoSave();

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleGroupKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await FlushAutoSave();

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

    private Task FlushAutoSave()
    {
        return UsesMultipleAutosave
            ? _autoSaveMultiple.Flush(Values, AutoSave, OnAutoSaveMultiple, AutoSaveStateChanged, RefreshOffThread)
            : _autoSave.Flush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
    }

    private bool ContainsValue(string value)
    {
        if (Values is null)
            return false;

        foreach (var candidate in Values)
        {
            if (string.Equals(candidate, value, StringComparison.Ordinal))
                return true;
        }

        return false;
    }

    private static string[] CopyValues(IReadOnlyCollection<string> values)
    {
        if (values.Count == 0)
            return [];

        var result = new string[values.Count];
        var index = 0;

        foreach (var value in values)
            result[index++] = value;

        return result;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Type);
        hc.Add(Value);
        hc.Add(Variant);
        hc.Add(ToggleSize);
        hc.Add(Orientation);
        hc.Add(Spacing);
        hc.Add(Dir);
        hc.Add(CascadedDirection);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(CurrentAutoSaveState);
        hc.Add(OnAutoSave is not null);
        hc.Add(OnAutoSaveMultiple is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
        if (Values != null)
            foreach (var x in Values) hc.Add(x);
    }

    public override async ValueTask DisposeAsync()
    {
        await _autoSave.DisposeAsync();
        await _autoSaveMultiple.DisposeAsync();
        await base.DisposeAsync();
    }

    private static string GetToggleSizeDataAttribute(CssValue<ToggleSizeBuilder>? size)
    {
        return size?.ToString() is "sm" ? "sm" : "default";
    }
}
