@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<CascadingValue Name="ParentToggleGroup" Value="@this" IsFixed="true">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    private readonly List<ToggleGroupItem> _items = [];
    private ToggleGroupItem? _focusedItem;
    private string? _pendingFocusedValue;

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    /// <summary>
    /// Gets or sets the type of toggle group: single (one at a time) or multiple (allow multiple pressed).
    /// </summary>
    [Parameter]
    public ToggleGroupType Type { get; set; } = ToggleGroupType.Single;

    /// <summary>
    /// Gets or sets callback when single value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the values for multiple-type groups.
    /// </summary>
    [Parameter]
    public string[]? Values { get; set; }

    /// <summary>
    /// Gets or sets callback when multiple values change.
    /// </summary>
    [Parameter]
    public EventCallback<string[]> ValueChangedMultiple { get; set; }

    /// <summary>
    /// Gets or sets visual variant.
    /// </summary>
    [Parameter]
    public ToggleVariant Variant { get; set; } = ToggleVariant.Default;

    /// <summary>
    /// Gets or sets size.
    /// </summary>
    [Parameter]
    public ToggleSize Size { get; set; } = ToggleSize.Default;

    /// <summary>
    /// Gets or sets the layout direction for toggle group items.
    /// </summary>
    [Parameter]
    public ToggleGroupOrientation Orientation { get; set; } = ToggleGroupOrientation.Horizontal;

    /// <summary>
    /// Gets or sets spacing between items (0 = no gap, uses default gap).
    /// </summary>
    [Parameter]
    public int Spacing { get; set; }

    private static string GetVariantClass(ToggleVariant? variant)
        => (variant?.Value ?? ToggleVariant.DefaultValue) switch
        {
            ToggleVariant.OutlineValue => "data-[variant=outline]:shadow-xs",
            _ => ""
        };

    /// <summary>
    /// Clears item order before children re-register in DOM order each render.
    /// </summary>
    protected override void OnParametersSet()
    {
        _pendingFocusedValue = _focusedItem?.Value;
        _items.Clear();
        _focusedItem = null;
        base.OnParametersSet();
    }

    internal void RegisterItem(ToggleGroupItem item)
    {
        if (_items.Contains(item))
            return;

        _items.Add(item);

        if (_pendingFocusedValue.HasContent() && string.Equals(item.Value, _pendingFocusedValue, StringComparison.Ordinal) && !item.IsDisabledInGroup)
            _focusedItem = item;
    }

    private void FinalizeFocusedItem()
    {
        if (_items.Count == 0)
        {
            _focusedItem = null;
            _pendingFocusedValue = null;
            return;
        }

        if (_focusedItem is null && _pendingFocusedValue.HasContent())
        {
            _focusedItem = _items.FirstOrDefault(i => string.Equals(i.Value, _pendingFocusedValue, StringComparison.Ordinal) && !i.IsDisabledInGroup);
        }

        _pendingFocusedValue = null;
    }

    internal bool IsItemTabStop(ToggleGroupItem item)
    {
        if (item.IsDisabledInGroup)
            return false;

        var enabledItems = _items.Where(i => !i.IsDisabledInGroup).ToList();
        if (enabledItems.Count == 0)
            return false;

        if (_focusedItem is not null && enabledItems.Contains(_focusedItem))
            return ReferenceEquals(_focusedItem, item);

        var selectedItem = enabledItems.FirstOrDefault(i => i.IsPressedInGroup);
        if (selectedItem is not null)
            return ReferenceEquals(selectedItem, item);

        return ReferenceEquals(enabledItems[0], item);
    }

    internal void NotifyItemFocused(ToggleGroupItem item)
    {
        if (!ReferenceEquals(_focusedItem, item))
        {
            _focusedItem = item;
            Refresh();
        }
    }

    private bool IsHorizontalRtl()
    {
        if (Orientation == ToggleGroupOrientation.Vertical)
            return false;

        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    /// <summary>
    /// Roving focus per orientation (horizontal: Left/Right + RTL; vertical: Up/Down) plus Home/End.
    /// </summary>
    /// <returns><c>true</c> if the key was handled (caller should prevent default).</returns>
    internal async Task<bool> TryHandleItemKeyNavigationAsync(ToggleGroupItem currentItem, string key)
    {
        if (Disabled || _items.Count == 0)
            return false;

        var enabledItems = _items.Where(i => !i.IsDisabledInGroup).ToList();
        if (enabledItems.Count == 0)
            return false;

        var currentIndex = enabledItems.FindIndex(i => ReferenceEquals(i, currentItem));
        if (currentIndex < 0)
            return false;

        var vertical = Orientation == ToggleGroupOrientation.Vertical;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledItems.Count - 1,
            "ArrowRight" when !vertical && IsHorizontalRtl() => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            "ArrowLeft" when !vertical && IsHorizontalRtl() => (currentIndex + 1) % enabledItems.Count,
            "ArrowRight" when !vertical => (currentIndex + 1) % enabledItems.Count,
            "ArrowLeft" when !vertical => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            "ArrowDown" when vertical => (currentIndex + 1) % enabledItems.Count,
            "ArrowUp" when vertical => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            _ => -1
        };

        if (nextIndex < 0)
            return false;

        _focusedItem = enabledItems[nextIndex];
        await enabledItems[nextIndex].FocusAsync();
        return true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        FinalizeFocusedItem();
        await base.OnAfterRenderAsync(firstRender);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "toggle-group";
        attributes["data-type"] = Type?.Value ?? ToggleGroupType.Single.Value;
        attributes["data-variant"] = Variant?.Value ?? ToggleVariant.Default.Value;
        attributes["data-size"] = Size?.Value ?? ToggleSize.Default.Value;
        attributes["data-orientation"] = Orientation?.Value ?? ToggleGroupOrientation.Horizontal.Value;
        attributes["data-spacing"] = Spacing.ToString();
        attributes["role"] = "group";
        attributes["aria-orientation"] = Orientation?.Value ?? ToggleGroupOrientation.Horizontal.Value;

        if (Disabled)
            attributes["aria-disabled"] = "true";

        if (Spacing > 0)
            attributes["style"] = $"--toggle-gap: {Spacing}px";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-toggle-group");
            AppendClass(ref cls, "group/toggle-group flex w-fit items-center rounded-md");
            AppendClass(ref cls, "data-[orientation=vertical]:flex-col data-[orientation=vertical]:items-stretch");
            if (Spacing > 0)
                AppendClass(ref cls, "gap-[var(--toggle-gap,0.5rem)]");
            else
                AppendClass(ref cls, "gap-0");
            AppendClass(ref cls, "data-[spacing=0]:data-[variant=outline]:shadow-xs");
            AppendClass(ref cls, GetVariantClass(Variant));
        });
    }

    internal async Task SelectValue(string? v)
    {
        if (Type == ToggleGroupType.Single)
        {
            var next = string.Equals(Value, v, StringComparison.Ordinal) ? null : v;
            Value = next;
            await ValueChanged.InvokeAsync(next);
        }
        else
        {
            var list = Values?.ToList() ?? new List<string>();
            if (v != null)
            {
                if (list.Contains(v))
                    list.Remove(v);
                else
                    list.Add(v);
            }
            Values = list.ToArray();
            await ValueChangedMultiple.InvokeAsync(Values);
        }
        InvalidateRender();
        Refresh();
    }

    internal bool IsPressed(string? v)
    {
        if (string.IsNullOrEmpty(v)) return false;
        if (Type == ToggleGroupType.Single)
            return Value == v;
        return Values?.Contains(v) ?? false;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Type);
        hc.Add(Value);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(Orientation);
        hc.Add(Spacing);
        hc.Add(DirectionProviderDir);
        hc.Add(_focusedItem?.Value);
        if (Values != null)
            foreach (var x in Values) hc.Add(x);
        hc.Add(_items.Count);
    }
}
