@using System.Globalization
@using System.Linq.Expressions
@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IValidationInput
@implements IDateTimePicker

<Popover Open="@_open" OpenChanged="HandleOpenChanged">
    <Div @attributes="GetContainerAttributes()">
        <PopoverAnchor>
            <input @ref="_ref" type="text" value="@(SelectedDateTime.HasValue ? FormatDisplay(SelectedDateTime.Value) : "")" @attributes="BuildAttributes()"/>
        </PopoverAnchor>

        <PopoverContent Id="@_panelId" Side="Side.Bottom" Align="Alignment.Start" MinWidth='Quark.MinWidth.Token("[18rem]")' Rounded="Quark.Rounded.Lg" Border="Quark.Border.Default" BackgroundColor="Quark.BackgroundColor.Popover" Padding="Quark.Padding.Is3" TextColor="Quark.TextColor.PopoverForeground" Shadow="Quark.Shadow.Md" @attributes="PanelAttributes">
            <Div Margin="Quark.Margin.FromBottom.Is2" Display="Quark.Display.Flex" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Between">
                <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.IconSm" AriaLabel="Previous month" @onclick="PrevMonth">‹</Button>
                <Div TextSize="Quark.TextSize.Sm" FontWeight="Quark.FontWeight.Medium">@_displayMonth.ToString("MMMM yyyy", CultureInfo.CurrentUICulture)</Div>
                <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.IconSm" AriaLabel="Next month" @onclick="NextMonth">›</Button>
            </Div>
            <Grid Columns="Quark.GridCols.Is7" Gap="Quark.Gap.Is1">
                @foreach (var dow in _dayNames)
                {
                    <Div Display="Quark.Display.Flex" Height="Quark.Height.Is8" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Center" TextSize="Quark.TextSize.Xs" FontWeight="Quark.FontWeight.Normal" TextColor="Quark.TextColor.MutedForeground">@dow</Div>
                }
                @foreach (var day in BuildMonthCells())
                {
                    <Button Type="@ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="ButtonSize.Icon" Class="@GetDayClass(day)" Disabled="@day.Disabled" @onclick="() => SelectDate(day.Date)">@day.Date.Day</Button>
                }
            </Grid>

            <Div Margin="Quark.Margin.FromTop.Is3" Display="Quark.Display.Flex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is2" Border="Quark.Border.FromTop.Is1" Padding="Quark.Padding.FromTop.Is3">
                <Div Display="Quark.Display.Flex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is1">
                    <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Icon" @onclick="DecrementHour">-</Button>
                    <Input Type="number" Value="@DisplayHour.ToString(CultureInfo.InvariantCulture)" Width="Quark.Width.Is14" TextAlign="Quark.TextAlign.Center" Class="[appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none" aria-label="Hour" step="1" min="1" max="12" OnInput="OnHourInput" @onwheel="OnHourWheel" @onkeydown="OnHourKeyDown"/>
                    <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Icon" @onclick="IncrementHour">+</Button>
                </Div>
                <Span TextSize="Quark.TextSize.Sm" TextColor="Quark.TextColor.MutedForeground">:</Span>
                <Div Display="Quark.Display.Flex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is1">
                    <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Icon" @onclick="DecrementMinute">-</Button>
                    <Input Type="number" Value="@_minute.ToString(CultureInfo.InvariantCulture)" Width="Quark.Width.Is14" TextAlign="Quark.TextAlign.Center" Class="[appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none [&::-webkit-outer-spin-button]:appearance-none" aria-label="Minute" step="@_minuteStep" min="0" max="59" OnInput="OnMinuteInput" @onwheel="OnMinuteWheel" @onkeydown="OnMinuteKeyDown"/>
                    <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Icon" @onclick="IncrementMinute">+</Button>
                </Div>
                <Button Type="@ButtonType.Button" Variant="ButtonVariant.Outline" ButtonSize="ButtonSize.Sm" Margin="Quark.Margin.FromLeft.Is1" Title="Click to toggle" @onclick="ToggleAmPm">@(_isAm ? "AM" : "PM")</Button>
            </Div>
        </PopoverContent>
    </Div>
</Popover>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "date-time-picker-input";

        Height ??= Quark.Height.Is8;
        Width ??= Quark.Width.IsFull;
        MinWidth ??= Quark.MinWidth.Is0;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Input.OnFocusVisible.Ring;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Padding ??= Quark.Padding.OnX.Is2_5.OnY.Is1;
        TextSize ??= Quark.TextSize.Sm;
        Transition ??= Quark.Transition.Colors;
        OutlineStyle ??= Quark.OutlineStyle.None;
        TextColor ??= Quark.TextColor.MutedForeground.Modifier("placeholder");
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Cursor ??= Quark.Cursor.NotAllowed.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }


    /// <summary>
    /// Gets or sets the selected date-time value.
    /// </summary>
    [Parameter]
    public DateTime? SelectedDateTime { get; set; }

    /// <summary>
    /// Gets or sets the expression that identifies the bound value.
    /// </summary>
    [Parameter]
    public Expression<Func<DateTime?>>? SelectedDateTimeExpression { get; set; }

    /// <summary>
    /// Gets or sets the minimum date-time value.
    /// </summary>
    [Parameter]
    public DateTime? Min { get; set; }

    /// <summary>
    /// Gets or sets the maximum date-time value.
    /// </summary>
    [Parameter]
    public DateTime? Max { get; set; }

    /// <summary>
    /// Gets or sets the size of the date-time picker.
    /// </summary>
    [Parameter]
    public CssValue<InputSizeBuilder>? InputSize { get; set; } = InputSizes.Default;

    /// <summary>
    /// Gets or sets the callback invoked When the value changes.
    /// </summary>
    [Parameter]
    public EventCallback<DateTime?> SelectedDateTimeChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the input changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the input value changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnInput { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// </summary>
    public object? ValidationValue => SelectedDateTime;

    private ElementReference _ref;
    private bool _open;
    private DateOnly _displayMonth = DateOnly.FromDateTime(DateTime.Today);
    private string[] _dayNames = [];
    private DateOnly? _pendingDate;
    private int _hour; // 0-23
    private int _minute; // 0-59
    private bool _isAm;
    private const int _minuteStep = 1;
    private readonly string _panelId = BlazorIdGenerator.New("quark-datetimepicker-panel");

    private IReadOnlyDictionary<string, object> PanelAttributes => new Dictionary<string, object>
    {
        ["data-slot"] = "date-time-picker-panel"
    };

    private static DateTime? Parse(ChangeEventArgs e)
    {
        if (e?.Value == null)
            return null;

        var text = e.Value.ToString();
        // Accept common formats (with T or space)
        if (text.IsNullOrWhiteSpace())
            return null;

        var normalized = text.Trim();
        if (normalized.Contains(' ') && !normalized.Contains('T'))
            normalized = normalized.Replace(' ', 'T');

        if (DateTime.TryParse(normalized, CultureInfo.InvariantCulture, DateTimeStyles.AssumeLocal, out var result))
            return result;

        return null;
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var next = Parse(e);
        var valueChanged = SelectedDateTime != next;
        SelectedDateTime = next;
        if (valueChanged)
            await SelectedDateTimeChanged.InvokeIfHasDelegate(SelectedDateTime);
        await OnInput.InvokeIfHasDelegate(e);

        if (ParentValidation is not null)
            await ParentValidation.NotifyInputChanged(SelectedDateTime);

        if (valueChanged)
        {
            InvalidateRender();
            Refresh();
        }
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        var next = Parse(e);
        var valueChanged = SelectedDateTime != next;
        SelectedDateTime = next;
        if (valueChanged)
            await SelectedDateTimeChanged.InvokeIfHasDelegate(SelectedDateTime);
        await OnChange.InvokeIfHasDelegate(e);

        if (ParentValidation is not null)
            await ParentValidation.NotifyInputChanged(SelectedDateTime);

        if (valueChanged)
        {
            InvalidateRender();
            Refresh();
        }
    }

    private string? GetSizeClass()
    {
        var sizeClass = InputSize?.ToString();
        return string.IsNullOrWhiteSpace(sizeClass) ? null : sizeClass;
    }


    private string? GetValidationClass()
    {
        return null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);

            if (SelectedDateTimeExpression is not null)
            {
                await ParentValidation.InitializeInputExpression(SelectedDateTimeExpression);
            }
        }

        if (firstRender)
        {
            InitializeDayNames();
            if (SelectedDateTime.HasValue)
            {
                _displayMonth = DateOnly.FromDateTime(SelectedDateTime.Value);
                _hour = SelectedDateTime.Value.Hour;
                _minute = SelectedDateTime.Value.Minute;
            }
            else
            {
                _displayMonth = DateOnly.FromDateTime(DateTime.Today);
                var now = DateTime.Now;
                _hour = now.Hour;
                _minute = now.Minute;
            }

            _isAm = _hour < 12;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private static string FormatDisplay(DateTime dt) => dt.ToString("yyyy-MM-dd hh:mm tt", CultureInfo.InvariantCulture);
    private int DisplayHour => _hour % 12 == 0 ? 12 : _hour % 12;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "selection:bg-primary selection:text-primary-foreground dark:bg-input/30 dark:hover:bg-input/50");
            AppendClass(ref cls, "focus-visible:ring-[3px]");
            AppendClass(ref cls, "aria-[invalid=true]:border-destructive aria-[invalid=true]:ring-destructive/20 dark:aria-[invalid=true]:ring-destructive/40");

            var sizeClass = GetSizeClass();
            if (sizeClass != null)
                AppendClass(ref cls, sizeClass);

            var validationClass = GetValidationClass();
            if (validationClass != null)
                AppendClass(ref cls, validationClass);
        });

        if (Placeholder.HasContent())
            attributes["placeholder"] = Placeholder!;

        if (Disabled)
            attributes["disabled"] = true;

        if (ReadOnly)
            attributes["readonly"] = true;

        if (Required)
            attributes["required"] = true;

        if (ParentValidation?.Status == ValidationStatus.Error)
            attributes["aria-invalid"] = "true";

        attributes["aria-expanded"] = _open ? "true" : "false";
        attributes["aria-controls"] = _panelId;

        // min/max intentionally omitted for text input (handled in panel)

        attributes["onclick"] = EventCallback.Factory.Create<MouseEventArgs>(this, OpenPanel);
        attributes["onfocus"] = EventCallback.Factory.Create<FocusEventArgs>(this, OpenPanel);

        attributes["autocomplete"] = "off";
        attributes["oninput"] = EventCallback.Factory.Create<ChangeEventArgs>(this, HandleInput);
        attributes["onchange"] = EventCallback.Factory.Create<ChangeEventArgs>(this, HandleChange);
    }

    private static Dictionary<string, object> GetContainerAttributes()
    {
        var attrs = new Dictionary<string, object>(2)
        {
            ["data-slot"] = "date-time-picker"
        };
        RenderComponent.BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "q-date-time-picker relative w-full");
        });
        return attrs;
    }

    private void InitializeDayNames()
    {
        var culture = CultureInfo.CurrentCulture;
        var first = culture.DateTimeFormat.FirstDayOfWeek;
        var names = culture.DateTimeFormat.AbbreviatedDayNames;
        _dayNames = Enumerable.Range(0, 7).Select(i => names[((int)first + i) % 7]).ToArray();
    }

    private readonly record struct Cell(DateOnly Date, bool InMonth, bool Disabled);

    private string GetDayClass(Cell day)
    {
        var css = "relative flex aspect-square h-8 w-8 items-center justify-center rounded-lg text-sm outline-none transition-all focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50";

        if (!day.InMonth)
            css += " text-muted-foreground opacity-50";

        if (day.Date == DateOnly.FromDateTime(DateTime.Today))
            css += " bg-accent text-accent-foreground";

        if (SelectedDateTime.HasValue && day.Date == DateOnly.FromDateTime(SelectedDateTime.Value))
            css += " bg-primary text-primary-foreground hover:bg-primary hover:text-primary-foreground";
        else
            css += " hover:bg-muted hover:text-foreground";

        return css;
    }

    private IEnumerable<Cell> BuildMonthCells()
    {
        var firstOfMonth = new DateOnly(_displayMonth.Year, _displayMonth.Month, 1);
        var culture = CultureInfo.CurrentCulture;
        var startDow = culture.DateTimeFormat.FirstDayOfWeek;
        var offset = ((int)firstOfMonth.DayOfWeek - (int)startDow + 7) % 7;
        var gridStart = firstOfMonth.AddDays(-offset);

        for (var i = 0; i < 42; i++)
        {
            var d = gridStart.AddDays(i);
            var inMonth = d.Month == _displayMonth.Month;
            var disabled = (Min.HasValue && d < DateOnly.FromDateTime(Min.Value)) || (Max.HasValue && d > DateOnly.FromDateTime(Max.Value));
            yield return new Cell(d, inMonth, disabled);
        }
    }

    private Task OpenPanel()
    {
        if (!_open)
            _open = true;
        InvalidateRender();
        Refresh();
        return Task.CompletedTask;
    }

    private Task HandleOpenChanged(bool open)
    {
        _open = open;
        InvalidateRender();
        Refresh();
        return Task.CompletedTask;
    }

    internal async Task ClosePanel()
    {
        if (_open)
            _open = false;
        await RefreshOffThread();
    }


    private async Task Commit()
    {
        var date = _pendingDate ?? (SelectedDateTime.HasValue ? DateOnly.FromDateTime(SelectedDateTime.Value) : DateOnly.FromDateTime(DateTime.Today));
        var dt = new DateTime(date.Year, date.Month, date.Day, _hour, _minute, 0);

        if (SelectedDateTime != dt)
        {
            SelectedDateTime = dt;
            await SelectedDateTimeChanged.InvokeAsync(SelectedDateTime);
        }

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(SelectedDateTime);
        }

        InvalidateRender();
        Refresh();
    }

    private async Task SelectDate(DateOnly date)
    {
        if ((Min.HasValue && date < DateOnly.FromDateTime(Min.Value)) || (Max.HasValue && date > DateOnly.FromDateTime(Max.Value)))
            return;

        _pendingDate = date;
        await Commit();
    }

    private Task IncrementHour()
    {
        _hour = (_hour + 1) % 24;
        _isAm = _hour < 12;
        return Commit();
    }

    private Task DecrementHour()
    {
        _hour = (_hour + 23) % 24;
        _isAm = _hour < 12;
        return Commit();
    }

    private Task IncrementMinute()
    {
        _minute = (_minute + _minuteStep) % 60;
        return Commit();
    }

    private Task DecrementMinute()
    {
        _minute = (_minute + 60 - _minuteStep) % 60;
        return Commit();
    }

    private Task SetAmPm(bool am)
    {
        _isAm = am;
        if (am && _hour >= 12)
            _hour -= 12;
        if (!am && _hour < 12)
            _hour += 12;
        return Commit();
    }

    private Task ToggleAmPm() => SetAmPm(!_isAm);
    private Task OnHourWheel(WheelEventArgs e) => e.DeltaY < 0 ? IncrementHour() : DecrementHour();
    private Task OnMinuteWheel(WheelEventArgs e) => e.DeltaY < 0 ? IncrementMinute() : DecrementMinute();

    private Task OnHourKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowUp")
            return IncrementHour();
        if (e.Key == "ArrowDown")
            return DecrementHour();
        return Task.CompletedTask;
    }

    private Task OnMinuteKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowUp")
            return IncrementMinute();
        if (e.Key == "ArrowDown")
            return DecrementMinute();
        return Task.CompletedTask;
    }

    private Task OnHourInput(ChangeEventArgs e)
    {
        if (e?.Value is null)
            return Task.CompletedTask;
        if (int.TryParse(e.Value.ToString(), out var v))
        {
            v = Math.Clamp(v, 1, 12);
            // preserve am/pm while mapping 12->0 for AM case
            var baseHour = _isAm ? 0 : 12;
            _hour = v % 12 + baseHour;
            return Commit();
        }

        return Task.CompletedTask;
    }

    private Task OnMinuteInput(ChangeEventArgs e)
    {
        if (e?.Value is null)
            return Task.CompletedTask;
        if (int.TryParse(e.Value.ToString(), out var v))
        {
            v = (v % 60 + 60) % 60;
            _minute = v;
            return Commit();
        }

        return Task.CompletedTask;
    }

    private Task PrevMonth()
    {
        _displayMonth = _displayMonth.AddMonths(-1);
        InvalidateRender();
        Refresh();
        return Task.CompletedTask;
    }

    private Task NextMonth()
    {
        _displayMonth = _displayMonth.AddMonths(1);
        InvalidateRender();
        Refresh();
        return Task.CompletedTask;
    }

    protected override void ApplyBackgroundColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls)
    {
        if (BackgroundColor is { IsEmpty: false })
        {
            string? token = null;
            var isTheme = BackgroundColor.Value.TryGetThemeToken(out token);

            var result = BackgroundColor.ToString();
            if (!result.HasContent())
                return;

            if (BackgroundColor.Value.IsCssStyle)
                AppendStyleDecl(ref sty, $"background-color: {result}");
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedDateTime);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
        hc.Add(Min);
        hc.Add(Max);
        hc.Add(_open);
        hc.Add(_panelId);
        hc.Add(_displayMonth);
        hc.Add(_pendingDate);
        hc.Add(_hour);
        hc.Add(_minute);
        hc.Add(_isAm);
        AddIf(ref hc, InputSize);
    }

}
