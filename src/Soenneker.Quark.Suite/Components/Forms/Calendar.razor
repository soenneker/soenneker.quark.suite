@using System.Globalization
@using System.Linq

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<Div @attributes="BuildAttributes()">
    <Div Position="Quark.Position.Relative" Display="Quark.Display.Flex" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is4" Class="md:flex-row rdp-months">
        <Nav Position="Quark.Position.Absolute" Inset="Quark.Inset.OnX.Is0" Top="Quark.Top.Is0" Display="Quark.Display.Flex" Width="Quark.Width.IsFull" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Between" Gap="Quark.Gap.Is1" AriaLabel="" Class="rdp-nav">
            <Button Type="@ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="@CalendarNavButtonSize" UserSelect="Quark.UserSelect.None" Opacity='Quark.Opacity.Is50.Aria("disabled")' Class="rdp-button_previous" AriaLabel="Go to the Previous Month" aria-disabled="@GetAriaDisabled(!CanNavigatePrevious())" TabIndex="@GetNavTabIndex(CanNavigatePrevious())" OnClick="@(_ => PrevMonth())">
                <Icon Name="LucideIcon.ChevronLeft" Size="Quark.Size.Is4" Class="cn-rtl-flip rdp-chevron" aria-hidden="true"/>
            </Button>
            <Button Type="@ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="@CalendarNavButtonSize" UserSelect="Quark.UserSelect.None" Opacity='Quark.Opacity.Is50.Aria("disabled")' Class="rdp-button_next" AriaLabel="Go to the Next Month" aria-disabled="@GetAriaDisabled(!CanNavigateNext())" TabIndex="@GetNavTabIndex(CanNavigateNext())" OnClick="@(_ => NextMonth())">
                <Icon Name="LucideIcon.ChevronRight" Size="Quark.Size.Is4" Class="cn-rtl-flip rdp-chevron" aria-hidden="true"/>
            </Button>
        </Nav>

        @for (var monthIndex = 0; monthIndex < Math.Max(NumberOfMonths, 1); monthIndex++)
        {
            var month = _displayMonth.AddMonths(monthIndex);
            var weeks = BuildMonthWeeks(month);

            <Div Display="Quark.Display.Flex" Width="Quark.Width.IsFull" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is4" Class="rdp-month">
                <Div Display="Quark.Display.Flex" Height='Quark.Height.Token("(--cell-size)")' Width="Quark.Width.IsFull" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Center" Padding='Quark.Padding.OnX.Token("(--cell-size)")' Class="rdp-month_caption">
                    @if (CaptionLayout == "dropdown")
                    {
                        <Div Display="Quark.Display.Flex" Height='Quark.Height.Token("(--cell-size)")' Width="Quark.Width.IsFull" ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Center" Gap='Quark.Gap.Is1_5' TextSize="Quark.TextSize.Sm" FontWeight="Quark.FontWeight.Medium" Class="rdp-dropdowns">
                            <Span data-disabled="false" Position="Quark.Position.Relative" Class="cn-calendar-dropdown-root relative rounded-(--cell-radius) rdp-dropdown_root">
                                <SelectPrimitive Position="Quark.Position.Absolute" Inset="Quark.Inset.Is0" BackgroundColor="Quark.BackgroundColor.Popover" Opacity="Quark.Opacity.Is0" Class="rdp-dropdown rdp-months_dropdown" aria-label="Choose the Month" Value="@((month.Month - 1).ToString(CultureInfo.InvariantCulture))" OnChange="OnMonthChanged">
                                    @foreach (var optionMonth in Enumerable.Range(0, 12))
                                    {
                                        <option value="@optionMonth">@GetMonthDropdownLabel(optionMonth + 1)</option>
                                    }
                                </SelectPrimitive>
                                <Span FontWeight="Quark.FontWeight.Medium" UserSelect="Quark.UserSelect.None" Display="Quark.Display.Flex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is1" TextSize="Quark.TextSize.Sm" Class="cn-calendar-caption-label rounded-(--cell-radius) [&>svg]:size-3.5 [&>svg]:text-muted-foreground rdp-caption_label" aria-hidden="true">
                                    <Span>@GetMonthDropdownLabel(month.Month)</Span>
                                    <Icon Name="LucideIcon.ChevronDown" Size="Quark.Size.Is4" Class="rdp-chevron"/>
                                </Span>
                            </Span>
                            <Span data-disabled="false" Position="Quark.Position.Relative" Class="cn-calendar-dropdown-root relative rounded-(--cell-radius) rdp-dropdown_root">
                                <SelectPrimitive Position="Quark.Position.Absolute" Inset="Quark.Inset.Is0" BackgroundColor="Quark.BackgroundColor.Popover" Opacity="Quark.Opacity.Is0" Class="rdp-dropdown rdp-years_dropdown" aria-label="Choose the Year" Value="@month.Year.ToString(CultureInfo.InvariantCulture)" OnChange="OnYearChanged">
                                    @foreach (var year in GetSelectableYears())
                                    {
                                        <option value="@year">@year</option>
                                    }
                                </SelectPrimitive>
                                <Span FontWeight="Quark.FontWeight.Medium" UserSelect="Quark.UserSelect.None" Display="Quark.Display.Flex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is1" TextSize="Quark.TextSize.Sm" Class="cn-calendar-caption-label rounded-(--cell-radius) [&>svg]:size-3.5 [&>svg]:text-muted-foreground rdp-caption_label" aria-hidden="true">
                                    <Span>@month.Year</Span>
                                    <Icon Name="LucideIcon.ChevronDown" Size="Quark.Size.Is4" Class="rdp-chevron"/>
                                </Span>
                            </Span>
                        </Div>
                    }
                    else
                    {
                        <Span Role="status" aria-live="polite" FontWeight="Quark.FontWeight.Medium" UserSelect="Quark.UserSelect.None" TextSize="Quark.TextSize.Sm" Class="cn-calendar-caption rdp-caption_label">@GetMonthCaption(month)</Span>
                    }
                </Div>
                <table role="grid" aria-multiselectable="@GetDataBoolean(IsMultipleMode || IsRangeMode)" aria-label="@GetMonthCaption(month)" class="rdp-month_grid">
                    <TheadPrimitive aria-hidden="true">
                        <TrPrimitive Display="Quark.Display.Flex" Class="rdp-weekdays">
                            @if (ShowWeekNumber)
                            {
                                <ThPrimitive Width='Quark.Width.Token("(--cell-size)")' UserSelect="Quark.UserSelect.None" Class="rdp-week_number_header" scope="col" aria-label="Week Number"></ThPrimitive>
                            }

                            @for (var dayIndex = 0; dayIndex < _dayNames.Length; dayIndex++)
                            {
                                var capturedDayIndex = dayIndex;

                                <ThPrimitive Flex="Quark.Flex.Is1" Rounded='Quark.Rounded.Token("(--cell-radius)")' TextSize='Quark.TextSize.Token("[0.8rem]")' FontWeight="Quark.FontWeight.Normal" TextColor="Quark.TextColor.MutedForeground" UserSelect="Quark.UserSelect.None" Class="rdp-weekday" scope="col" aria-label="@_fullDayNames[capturedDayIndex]">@_dayNames[capturedDayIndex]</ThPrimitive>
                            }
                        </TrPrimitive>
                    </TheadPrimitive>
                    <TbodyPrimitive Class="rdp-weeks">
                        @foreach (var week in weeks)
                        {
                            <TrPrimitive Margin="Quark.Margin.FromTop.Is2" Display="Quark.Display.Flex" Width="Quark.Width.IsFull" Class="rdp-week">
                                @if (ShowWeekNumber)
                                {
                                    <TdPrimitive TextSize='Quark.TextSize.Token("[0.8rem]")' TextColor="Quark.TextColor.MutedForeground" UserSelect="Quark.UserSelect.None" Class="rdp-week_number" role="rowheader" scope="row" aria-label="@($"Week {GetWeekNumber(week[0].Date)}")">
                                        <Div Display="Quark.Display.Flex" Size='Quark.Size.Token("(--cell-size)")' ItemsAlign="Quark.Items.Center" Justify="Quark.Justify.Center" TextAlign="Quark.TextAlign.Center">
                                            @GetWeekNumber(week[0].Date).ToString("00", CultureInfo.InvariantCulture)
                                        </Div>
                                    </TdPrimitive>
                                }

                                @foreach (var day in week)
                                {
                                    var dayContext = BuildDayContext(day);
                                    var cellCss = GetDayCellClass(dayContext, day);
                                    var buttonCss = GetDayButtonClass(dayContext, day);

                                    <TdPrimitive Class="@cellCss" role="gridcell" aria-selected="@GetDataBoolean(dayContext.IsSelected || dayContext.IsRangeStart || dayContext.IsRangeEnd || dayContext.IsRangeMiddle)" data-day="@day.Date.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)" data-month="@day.Date.ToString("yyyy-MM", CultureInfo.InvariantCulture)" data-selected="@(GetDataBoolean(dayContext.IsSelected || dayContext.IsRangeStart || dayContext.IsRangeEnd || dayContext.IsRangeMiddle))">
                                        <Button Type="@ButtonType.Button" Variant="ButtonVariant.Ghost" ButtonSize="@CalendarDayButtonSize" Display="Quark.Display.Flex" Width="Quark.Width.IsFull" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is1" Leading="Quark.Leading.None" FontWeight="Quark.FontWeight.Normal" Class="@buttonCss" Disabled="@day.Disabled" AriaLabel="@GetDayAriaLabel(dayContext)" aria-disabled="@GetDataBoolean(day.Disabled)" TabIndex="@GetDayTabIndex(dayContext, day)" data-day="@GetDataDay(day.Date)" data-selected-single="@(GetDataBoolean(dayContext.IsSelected && !dayContext.IsRangeStart && !dayContext.IsRangeEnd && !dayContext.IsRangeMiddle))" data-range-start="@(GetDataBoolean(dayContext.IsRangeStart))" data-range-end="@(GetDataBoolean(dayContext.IsRangeEnd))" data-range-middle="@(GetDataBoolean(dayContext.IsRangeMiddle))" OnClick="@(_ => SelectDate(day.Date))">
                                            @if (DayContent is not null)
                                            {
                                                @DayContent(dayContext)
                                            }
                                            else
                                            {
                                                @GetDayLabel(day.Date)
                                            }
                                        </Button>
                                    </TdPrimitive>
                                }
                            </TrPrimitive>
                        }
                    </TbodyPrimitive>
                </table>
            </Div>
        }
    </Div>
</Div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "calendar";
    }

    private static readonly CssValue<ButtonSizeBuilder> CalendarNavButtonSize = "gap-1.5 has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2 size-(--cell-size) p-0";
    private static readonly CssValue<ButtonSizeBuilder> CalendarDayButtonSize = "relative isolate z-10 flex aspect-square size-auto w-full min-w-(--cell-size) flex-col gap-1 border-0 leading-none font-normal";

    [Parameter]
    public DateOnly? SelectedDate { get; set; }

    [Parameter]
    public EventCallback<DateOnly?> SelectedDateChanged { get; set; }

    [Parameter]
    public DateOnly[]? SelectedDates { get; set; }

    [Parameter]
    public EventCallback<DateOnly[]> SelectedDatesChanged { get; set; }

    [Parameter]
    public CalendarSelectionMode Mode { get; set; } = CalendarSelectionMode.Single;

    [Parameter]
    public CalendarDateRange? SelectedRange { get; set; }

    [Parameter]
    public EventCallback<CalendarDateRange?> SelectedRangeChanged { get; set; }

    [Parameter]
    public DateOnly? DisplayMonth { get; set; }

    [Parameter]
    public EventCallback<DateOnly?> DisplayMonthChanged { get; set; }

    /// <summary>
    /// Gets or sets the selected date.
    /// </summary>
    [Parameter]
    public DateOnly? DateOnlyValue { get; set; }

    /// <summary>
    /// Gets or sets callback when date is selected.
    /// </summary>
    [Parameter]
    public EventCallback<DateOnly?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the minimum selectable date.
    /// </summary>
    [Parameter]
    public DateOnly? Min { get; set; }

    /// <summary>
    /// Gets or sets the maximum selectable date.
    /// </summary>
    [Parameter]
    public DateOnly? Max { get; set; }

    [Parameter]
    public bool ShowOutsideDays { get; set; } = true;

    [Parameter]
    public int NumberOfMonths { get; set; } = 1;

    [Parameter]
    public bool ShowWeekNumber { get; set; }

    [Parameter]
    public bool FixedWeeks { get; set; }

    [Parameter]
    public string CaptionLayout { get; set; } = "label";

    [Parameter]
    public bool UseFullMonthNames { get; set; }

    [Parameter]
    public string? CultureName { get; set; }

    [Parameter]
    public bool UseCultureCalendar { get; set; }

    [Parameter]
    public string? Dir { get; set; }

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    [Parameter]
    public DateOnly[]? DisabledDates { get; set; }

    [Parameter]
    public Dictionary<string, Func<DateOnly, bool>>? Modifiers { get; set; }

    [Parameter]
    public Dictionary<string, string>? ModifierClasses { get; set; }

    [Parameter]
    public RenderFragment<CalendarDayContext>? DayContent { get; set; }

    private DateOnly _displayMonth = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _lastAppliedDisplayMonth;
    private string[] _dayNames = [];
    private string[] _fullDayNames = [];
    private bool _initialized;
    private bool IsRangeMode => Mode == CalendarSelectionMode.Range;
    private bool IsMultipleMode => Mode == CalendarSelectionMode.Multiple;
    private DateOnly? EffectiveSelectedDate => SelectedDate ?? DateOnlyValue;
    private CalendarDateRange? EffectiveSelectedRange => SelectedRange;
    private IReadOnlyList<DateOnly> EffectiveSelectedDates => SelectedDates ?? [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        InitializeDayNames();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        InitializeDayNames();

        if (!IsRangeMode && SelectedDate is null && DateOnlyValue.HasValue)
            SelectedDate = DateOnlyValue;

        if (DisplayMonth.HasValue)
        {
            var displayMonth = new DateOnly(DisplayMonth.Value.Year, DisplayMonth.Value.Month, 1);

            if (!_initialized || _lastAppliedDisplayMonth != displayMonth)
                _displayMonth = displayMonth;

            _lastAppliedDisplayMonth = displayMonth;
            _initialized = true;
            return;
        }

        _lastAppliedDisplayMonth = null;

        if (!_initialized)
        {
            var initialDate = IsRangeMode ? EffectiveSelectedRange?.From ?? EffectiveSelectedRange?.To ?? DateOnly.FromDateTime(DateTime.Today) : IsMultipleMode ? EffectiveSelectedDates.FirstOrDefault(DateOnly.FromDateTime(DateTime.Today)) : EffectiveSelectedDate ?? DateOnly.FromDateTime(DateTime.Today);
            _displayMonth = new DateOnly(initialDate.Year, initialDate.Month, 1);
            _initialized = true;
        }
    }

    private void InitializeDayNames()
    {
        var culture = ResolveCulture();
        var first = GetFirstDayOfWeek(culture);
        var names = culture.DateTimeFormat.AbbreviatedDayNames;
        var fullNames = culture.DateTimeFormat.DayNames;
        _dayNames = Enumerable.Range(0, 7).Select(i =>
        {
            var name = names[((int)first + i) % 7];
            return name.Length > 2 ? name[..2] : name;
        }).ToArray();
        _fullDayNames = Enumerable.Range(0, 7).Select(i => fullNames[((int)first + i) % 7]).ToArray();
    }

    private record Cell(DateOnly Date, bool InMonth, bool Disabled);

    private List<List<Cell>> BuildMonthWeeks(DateOnly month)
    {
        var culture = ResolveCulture();
        var calendar = culture.Calendar;
        DateOnly firstOfMonth;
        Func<DateOnly, bool> isInDisplayedMonth;

        if (UseCultureCalendar)
        {
            var displayDate = month.ToDateTime(TimeOnly.MinValue);
            var calendarYear = calendar.GetYear(displayDate);
            var calendarMonth = calendar.GetMonth(displayDate);
            firstOfMonth = DateOnly.FromDateTime(calendar.ToDateTime(calendarYear, calendarMonth, 1, 0, 0, 0, 0));
            isInDisplayedMonth = date =>
            {
                var dateTime = date.ToDateTime(TimeOnly.MinValue);
                return calendar.GetYear(dateTime) == calendarYear && calendar.GetMonth(dateTime) == calendarMonth;
            };
        }
        else
        {
            firstOfMonth = new DateOnly(month.Year, month.Month, 1);
            isInDisplayedMonth = date => date.Month == month.Month;
        }

        var startDow = GetFirstDayOfWeek(culture);
        var offset = ((int)firstOfMonth.DayOfWeek - (int)startDow + 7) % 7;
        var gridStart = firstOfMonth.AddDays(-offset);
        var weeks = new List<List<Cell>>(6);
        var currentWeek = new List<Cell>(7);

        for (var i = 0; i < 42; i++)
        {
            var d = gridStart.AddDays(i);
            var inMonth = isInDisplayedMonth(d);
            var disabled = (Min.HasValue && d < Min.Value) || (Max.HasValue && d > Max.Value) || (DisabledDates?.Contains(d) == true);
            if (!ShowOutsideDays && !inMonth)
                disabled = true;

            currentWeek.Add(new Cell(d, inMonth, disabled));

            if (currentWeek.Count == 7)
            {
                weeks.Add(currentWeek);
                currentWeek = new List<Cell>(7);
            }
        }

        if (!FixedWeeks)
        {
            var lastWeekWithMonthDays = weeks.FindLastIndex(week => week.Any(cell => cell.InMonth));
            if (lastWeekWithMonthDays >= 0)
                weeks = weeks.Take(lastWeekWithMonthDays + 1).ToList();
        }

        return weeks;
    }

    private async Task SelectDate(DateOnly date)
    {
        if ((Min.HasValue && date < Min.Value) || (Max.HasValue && date > Max.Value) || (DisabledDates?.Contains(date) == true))
            return;

        if (IsRangeMode)
        {
            var nextRange = BuildNextRange(date);
            SelectedRange = nextRange;
            await SelectedRangeChanged.InvokeAsync(nextRange);
            InvalidateRender();
            Refresh();
            return;
        }

        if (IsMultipleMode)
        {
            var values = EffectiveSelectedDates.ToList();
            var existingIndex = values.FindIndex(candidate => candidate == date);

            if (existingIndex >= 0)
                values.RemoveAt(existingIndex);
            else
                values.Add(date);

            SelectedDates = values.ToArray();
            await SelectedDatesChanged.InvokeAsync(SelectedDates);
            InvalidateRender();
            Refresh();
            return;
        }

        SelectedDate = date;
        DateOnlyValue = date;
        await SelectedDateChanged.InvokeAsync(SelectedDate);
        await ValueChanged.InvokeAsync(DateOnlyValue);
        InvalidateRender();
        Refresh();
    }

    private CalendarDateRange BuildNextRange(DateOnly date)
    {
        if (SelectedRange?.From is null || SelectedRange.To is not null)
            return new CalendarDateRange(date, null);

        if (date < SelectedRange.From.Value)
            return new CalendarDateRange(date, SelectedRange.From.Value);

        return new CalendarDateRange(SelectedRange.From.Value, date);
    }

    private bool IsDateInRange(DateOnly date)
    {
        if (EffectiveSelectedRange?.From is null || EffectiveSelectedRange.To is null)
            return false;

        return date > EffectiveSelectedRange.From.Value && date < EffectiveSelectedRange.To.Value;
    }

    private bool IsDateSelected(DateOnly date)
    {
        if (IsMultipleMode)
            return EffectiveSelectedDates.Contains(date);

        return EffectiveSelectedDate.HasValue && date == EffectiveSelectedDate.Value;
    }

    private int GetWeekNumber(DateOnly date)
    {
        var culture = ResolveCulture();
        return culture.Calendar.GetWeekOfYear(date.ToDateTime(TimeOnly.MinValue), culture.DateTimeFormat.CalendarWeekRule, GetFirstDayOfWeek(culture));
    }

    private DayOfWeek GetFirstDayOfWeek(CultureInfo culture)
    {
        return UseCultureCalendar ? culture.DateTimeFormat.FirstDayOfWeek : DayOfWeek.Sunday;
    }

    private async Task OnMonthChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var monthIndex))
            return;

        var month = monthIndex + 1;
        _displayMonth = new DateOnly(_displayMonth.Year, month, 1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    private async Task OnYearChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var year))
            return;

        _displayMonth = new DateOnly(year, _displayMonth.Month, 1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    private IEnumerable<int> GetSelectableYears()
    {
        var currentYear = DateTime.Today.Year;
        var minYear = Min?.Year ?? (currentYear - 100);
        var maxYear = Max?.Year ?? currentYear;

        return Enumerable.Range(minYear, maxYear - minYear + 1);
    }

    private string GetMonthDropdownLabel(int month)
    {
        var culture = ResolveCulture();

        return GetLocalizedGregorianMonthName(culture, month, abbreviated: !UseFullMonthNames);
    }

    private string GetMonthCaption(DateOnly month)
    {
        var culture = ResolveCulture();

        if (UseCultureCalendar && culture.Calendar.GetType().Name == "PersianCalendar")
        {
            var dateTime = month.ToDateTime(TimeOnly.MinValue);
            var names = new[]
            {
                "فروردین", "اردیبهشت", "خرداد", "تیر", "مرداد", "شهریور",
                "مهر", "آبان", "آذر", "دی", "بهمن", "اسفند"
            };
            var monthIndex = culture.Calendar.GetMonth(dateTime) - 1;
            var year = ToNativeDigits(culture.Calendar.GetYear(dateTime).ToString(CultureInfo.InvariantCulture), culture);
            return $"{names[monthIndex]} {year}";
        }

        if (!culture.Name.StartsWith("en", StringComparison.OrdinalIgnoreCase) && TryGetGregorianMonthNames(culture, out _))
            return $"{GetLocalizedGregorianMonthName(culture, month.Month, abbreviated: false)} {month.Year.ToString(CultureInfo.InvariantCulture)}";

        return month.ToString("MMMM yyyy", culture);
    }

    private static string GetLocalizedGregorianMonthName(CultureInfo culture, int month, bool abbreviated)
    {
        if (TryGetGregorianMonthNames(culture, out var localizedNames) && localizedNames is not null)
        {
            var names = abbreviated ? localizedNames.Abbreviated : localizedNames.Full;
            return names[month - 1];
        }

        return abbreviated ? culture.DateTimeFormat.GetAbbreviatedMonthName(month) : culture.DateTimeFormat.GetMonthName(month);
    }

    private static bool TryGetGregorianMonthNames(CultureInfo culture, out GregorianMonthNames? names)
    {
        var key = culture.Name;

        while (key.Length > 0)
        {
            if (_gregorianMonthNamesByCulture.TryGetValue(key, out names))
                return true;

            var separatorIndex = key.LastIndexOf('-');
            key = separatorIndex > 0 ? key[..separatorIndex] : string.Empty;
        }

        names = null;
        return false;
    }

    private sealed record GregorianMonthNames(string[] Full, string[] Abbreviated);

    private static readonly Dictionary<string, GregorianMonthNames> _gregorianMonthNamesByCulture = new(StringComparer.OrdinalIgnoreCase)
    {
        ["ar"] = new([
            "يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو",
            "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر"
        ], [
            "يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو",
            "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر"
        ]),
        ["es"] = new([
            "enero", "febrero", "marzo", "abril", "mayo", "junio",
            "julio", "agosto", "septiembre", "octubre", "noviembre", "diciembre"
        ], [
            "ene", "feb", "mar", "abr", "may", "jun",
            "jul", "ago", "sept", "oct", "nov", "dic"
        ]),
        ["fa"] = new([
            "ژانویه", "فوریه", "مارس", "آوریل", "مه", "ژوئن",
            "ژوئیه", "اوت", "سپتامبر", "اکتبر", "نوامبر", "دسامبر"
        ], [
            "ژانویه", "فوریه", "مارس", "آوریل", "مه", "ژوئن",
            "ژوئیه", "اوت", "سپتامبر", "اکتبر", "نوامبر", "دسامبر"
        ]),
        ["fr"] = new([
            "janvier", "février", "mars", "avril", "mai", "juin",
            "juillet", "août", "septembre", "octobre", "novembre", "décembre"
        ], [
            "janv.", "févr.", "mars", "avr.", "mai", "juin",
            "juil.", "août", "sept.", "oct.", "nov.", "déc."
        ]),
        ["de"] = new([
            "Januar", "Februar", "März", "April", "Mai", "Juni",
            "Juli", "August", "September", "Oktober", "November", "Dezember"
        ], [
            "Jan", "Feb", "Mär", "Apr", "Mai", "Jun",
            "Jul", "Aug", "Sep", "Okt", "Nov", "Dez"
        ]),
        ["it"] = new([
            "gennaio", "febbraio", "marzo", "aprile", "maggio", "giugno",
            "luglio", "agosto", "settembre", "ottobre", "novembre", "dicembre"
        ], [
            "gen", "feb", "mar", "apr", "mag", "giu",
            "lug", "ago", "set", "ott", "nov", "dic"
        ]),
        ["pt"] = new([
            "janeiro", "fevereiro", "março", "abril", "maio", "junho",
            "julho", "agosto", "setembro", "outubro", "novembro", "dezembro"
        ], [
            "jan", "fev", "mar", "abr", "mai", "jun",
            "jul", "ago", "set", "out", "nov", "dez"
        ]),
        ["he"] = new([
            "ינואר", "פברואר", "מרץ", "אפריל", "מאי", "יוני",
            "יולי", "אוגוסט", "ספטמבר", "אוקטובר", "נובמבר", "דצמבר"
        ], [
            "ינו׳", "פבר׳", "מרץ", "אפר׳", "מאי", "יוני",
            "יולי", "אוג׳", "ספט׳", "אוק׳", "נוב׳", "דצמ׳"
        ])
    };

    private CultureInfo ResolveCulture()
    {
        if (CultureName.IsNullOrEmpty())
            return CultureInfo.CurrentCulture;

        try
        {
            return CultureInfo.GetCultureInfo(CultureName);
        }
        catch (CultureNotFoundException)
        {
            return CultureInfo.CurrentCulture;
        }
    }

    private string GetDayLabel(DateOnly date)
    {
        var culture = ResolveCulture();
        var day = UseCultureCalendar ? culture.Calendar.GetDayOfMonth(date.ToDateTime(TimeOnly.MinValue)) : date.Day;

        return ToNativeDigits(day.ToString(CultureInfo.InvariantCulture), culture);
    }

    private string GetDayAriaLabel(CalendarDayContext dayContext)
    {
        var label = GetDayAriaLabel(dayContext.Date);

        if (dayContext.IsToday)
            label = $"Today, {label}";

        if (dayContext.IsSelected || dayContext.IsRangeStart || dayContext.IsRangeEnd || dayContext.IsRangeMiddle)
            label = $"{label}, selected";

        return label;
    }

    private string GetDayAriaLabel(DateOnly date)
    {
        var culture = ResolveCulture();

        if (UseCultureCalendar && culture.Calendar.GetType().Name == "PersianCalendar")
        {
            var dateTime = date.ToDateTime(TimeOnly.MinValue);
            var weekdays = new[]
            {
                "یک\u200cشنبه", "دوشنبه", "سه\u200cشنبه", "چهارشنبه", "پنج\u200cشنبه", "جمعه", "شنبه"
            };
            var months = new[]
            {
                "فروردین", "اردیبهشت", "خرداد", "تیر", "مرداد", "شهریور",
                "مهر", "آبان", "آذر", "دی", "بهمن", "اسفند"
            };
            var day = ToNativeDigits(culture.Calendar.GetDayOfMonth(dateTime).ToString(CultureInfo.InvariantCulture), culture);
            var month = months[culture.Calendar.GetMonth(dateTime) - 1];
            var year = ToNativeDigits(culture.Calendar.GetYear(dateTime).ToString(CultureInfo.InvariantCulture), culture);

            return $"{weekdays[(int)date.DayOfWeek]} {day}-ام {month} {year}";
        }

        if (culture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase))
        {
            var weekdays = new[]
            {
                "الأحد", "الاثنين", "الثلاثاء", "الأربعاء", "الخميس", "الجمعة", "السبت"
            };
            var months = new[]
            {
                "يناير", "فبراير", "مارس", "أبريل", "مايو", "يونيو",
                "يوليو", "أغسطس", "سبتمبر", "أكتوبر", "نوفمبر", "ديسمبر"
            };

            return $"{weekdays[(int)date.DayOfWeek]}, {months[date.Month - 1]} {date.Day.ToString(CultureInfo.InvariantCulture)}, {date.Year.ToString(CultureInfo.InvariantCulture)}";
        }

        if (culture.Name.StartsWith("en", StringComparison.OrdinalIgnoreCase))
        {
            var dayOfWeek = culture.DateTimeFormat.GetDayName(date.DayOfWeek);
            var month = culture.DateTimeFormat.GetMonthName(date.Month);
            return $"{dayOfWeek}, {month} {GetEnglishOrdinal(date.Day)}, {date.Year.ToString(CultureInfo.InvariantCulture)}";
        }

        return date.ToString("D", culture);
    }

    private string GetDataDay(DateOnly date)
    {
        var culture = ResolveCulture();

        if (UseCultureCalendar && culture.Calendar.GetType().Name == "PersianCalendar")
            return date.ToString("M/d/yyyy", CultureInfo.GetCultureInfo("en-US"));

        if (culture.Name.StartsWith("ar", StringComparison.OrdinalIgnoreCase))
            return $"{ToArabicDigits(date.Day)}\u200f/{ToArabicDigits(date.Month)}\u200f/{ToArabicDigits(date.Year)}";

        return date.ToString("M/d/yyyy", CultureInfo.GetCultureInfo("en-US"));
    }

    private static string ToArabicDigits(int value)
    {
        var result = value.ToString(CultureInfo.InvariantCulture);
        var digits = new[] { "٠", "١", "٢", "٣", "٤", "٥", "٦", "٧", "٨", "٩" };

        for (var i = 0; i < digits.Length; i++)
            result = result.Replace(i.ToString(CultureInfo.InvariantCulture), digits[i], StringComparison.Ordinal);

        return result;
    }

    private static string GetEnglishOrdinal(int day)
    {
        var lastTwo = day % 100;
        var lastDigit = day % 10;

        var suffix = lastTwo is >= 11 and <= 13
            ? "th"
            : lastDigit switch
            {
                1 => "st",
                2 => "nd",
                3 => "rd",
                _ => "th"
            };

        return day.ToString(CultureInfo.InvariantCulture) + suffix;
    }

    private int GetDayTabIndex(CalendarDayContext dayContext, Cell day)
    {
        return !day.Disabled && IsFocusableDay(dayContext, day.Date) ? 0 : -1;
    }

    private bool IsFocusableDay(CalendarDayContext dayContext, DateOnly date)
    {
        if (dayContext.IsSelected || dayContext.IsRangeStart)
            return true;

        if (IsMultipleMode && EffectiveSelectedDates.Count > 0)
            return EffectiveSelectedDates[0] == date;

        if (EffectiveSelectedDate.HasValue || EffectiveSelectedRange?.From is not null || EffectiveSelectedDates.Count > 0)
            return false;

        return date == DateOnly.FromDateTime(DateTime.Today);
    }

    private static string ToNativeDigits(string value, CultureInfo culture)
    {
        var nativeDigits = culture.NumberFormat.NativeDigits;

        if (culture.Name.StartsWith("fa", StringComparison.OrdinalIgnoreCase))
            nativeDigits = ["۰", "۱", "۲", "۳", "۴", "۵", "۶", "۷", "۸", "۹"];
        else if (nativeDigits.Length != 10 || nativeDigits[0] == "0")
            return value;

        var result = value;

        for (var i = 0; i < nativeDigits.Length; i++)
            result = result.Replace(i.ToString(CultureInfo.InvariantCulture), nativeDigits[i], StringComparison.Ordinal);

        return result;
    }

    private CalendarDayContext BuildDayContext(Cell day)
    {
        var modifiers = GetModifierNames(day.Date);

        return new CalendarDayContext(day.Date, day.InMonth, day.Disabled, day.Date == DateOnly.FromDateTime(DateTime.Today), IsDateSelected(day.Date), EffectiveSelectedRange?.From == day.Date, EffectiveSelectedRange?.To == day.Date, IsDateInRange(day.Date), modifiers);
    }

    private List<string> GetModifierNames(DateOnly date)
    {
        if (Modifiers is null || Modifiers.Count == 0)
            return [];

        var matches = new List<string>();

        foreach (var pair in Modifiers)
        {
            if (pair.Value.Invoke(date))
                matches.Add(pair.Key);
        }

        return matches;
    }

    private string AppendModifierClasses(string css, IReadOnlyList<string> modifiers)
    {
        if (ModifierClasses is null || modifiers.Count == 0)
            return css;

        foreach (var modifier in modifiers)
        {
            if (ModifierClasses.TryGetValue(modifier, out var classes) && !classes.IsNullOrEmpty())
                css += $" {classes}";
        }

        return css;
    }

    private string GetDayCellClass(CalendarDayContext dayContext, Cell day)
    {
        var css = "group/day relative aspect-square h-full w-full rounded-(--cell-radius) p-0 text-center select-none";

        if (ShowWeekNumber)
            css += " [&:last-child[data-selected=true]_button]:rounded-r-(--cell-radius) [&:nth-child(2)[data-selected=true]_button]:rounded-l-(--cell-radius)";
        else
            css += " [&:last-child[data-selected=true]_button]:rounded-r-(--cell-radius) [&:first-child[data-selected=true]_button]:rounded-l-(--cell-radius)";

        css += " rdp-day";

        if (dayContext.IsRangeStart)
            css += " relative isolate z-0 rounded-l-(--cell-radius) bg-muted after:absolute after:inset-y-0 after:right-0 after:w-4 after:bg-muted";
        if (dayContext.IsRangeEnd)
            css += " relative isolate z-0 rounded-r-(--cell-radius) bg-muted after:absolute after:inset-y-0 after:left-0 after:w-4 after:bg-muted";
        if (dayContext.IsRangeMiddle)
            css += " rounded-none";

        if (!ShowOutsideDays && !day.InMonth)
            css += " invisible";

        if (!day.InMonth)
            css += " text-muted-foreground aria-selected:text-muted-foreground rdp-outside";

        if (dayContext.IsToday)
            css += " rounded-(--cell-radius) bg-muted text-foreground data-[selected=true]:rounded-none rdp-today";

        if (day.Disabled)
            css += " text-muted-foreground opacity-50";

        css = AppendModifierClasses(css, dayContext.Modifiers);

        return css;
    }

    private string GetDayButtonClass(CalendarDayContext dayContext, Cell day)
    {
        var css = "relative isolate z-10 aspect-square size-auto min-w-(--cell-size) rounded-(--cell-radius) rounded-lg border-0";
        css += " group-data-[focused=true]/day:relative group-data-[focused=true]/day:z-10 group-data-[focused=true]/day:border-ring";
        css += " group-data-[focused=true]/day:ring-[3px] group-data-[focused=true]/day:ring-ring/50";
        css += " data-[range-end=true]:rounded-(--cell-radius) data-[range-end=true]:rounded-r-(--cell-radius)";
        css += " data-[range-end=true]:bg-primary data-[range-end=true]:text-primary-foreground data-[range-end=true]:hover:bg-primary data-[range-end=true]:hover:text-primary-foreground";
        css += " data-[range-middle=true]:rounded-none data-[range-middle=true]:bg-muted data-[range-middle=true]:text-foreground";
        css += " data-[range-start=true]:rounded-(--cell-radius) data-[range-start=true]:rounded-l-(--cell-radius)";
        css += " data-[range-start=true]:bg-primary data-[range-start=true]:text-primary-foreground data-[range-start=true]:hover:bg-primary data-[range-start=true]:hover:text-primary-foreground";
        css += " data-[selected-single=true]:bg-primary data-[selected-single=true]:text-primary-foreground data-[selected-single=true]:hover:bg-primary data-[selected-single=true]:hover:text-primary-foreground";
        css += " [&>span]:text-xs [&>span]:opacity-70 rdp-day rdp-day_button";

        if (day.Disabled)
            css += " pointer-events-none opacity-50";

        return css;
    }

    private async Task PrevMonth()
    {
        if (!CanNavigatePrevious())
            return;

        _displayMonth = _displayMonth.AddMonths(-1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    private async Task NextMonth()
    {
        if (!CanNavigateNext())
            return;

        _displayMonth = _displayMonth.AddMonths(1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    private bool CanNavigatePrevious()
    {
        var minMonth = Min.HasValue ? new DateOnly(Min.Value.Year, Min.Value.Month, 1) : new DateOnly(DateTime.Today.Year - 100, 1, 1);

        return _displayMonth.AddMonths(-1) >= minMonth;
    }

    private bool CanNavigateNext()
    {
        var maxMonth = Max.HasValue ? new DateOnly(Max.Value.Year, Max.Value.Month, 1) : new DateOnly(DateTime.Today.Year, 12, 1);

        return _displayMonth.AddMonths(Math.Max(NumberOfMonths, 1)) <= maxMonth;
    }

    private static int? GetNavTabIndex(bool enabled)
    {
        return enabled ? null : -1;
    }

    private static string? GetAriaDisabled(bool disabled)
    {
        return disabled ? "true" : null;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-mode"] = ReferenceEquals(Mode, CalendarSelectionMode.Multiple) ? "multiple" : ReferenceEquals(Mode, CalendarSelectionMode.Range) ? "range" : "single";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "w-fit rdp-root group/calendar bg-background");

            if (!HasClassOverride("p-"))
                AppendClass(ref cls, "p-2");

            if (!HasClassOverride("--cell-radius"))
                AppendClass(ref cls, "[--cell-radius:var(--radius-md)]");

            if (!HasClassOverride("--cell-size"))
                AppendClass(ref cls, "[--cell-size:--spacing(7)]");

            AppendClass(ref cls, "in-data-[slot=card-content]:bg-transparent in-data-[slot=popover-content]:bg-transparent");
            AppendClass(ref cls, "rtl:**:[.rdp-button_next>svg]:rotate-180 rtl:**:[.rdp-button_previous>svg]:rotate-180");
        });

        if (ShowWeekNumber)
            attributes["data-week-numbers"] = "true";

        var resolvedDir = !string.IsNullOrWhiteSpace(Dir) ? Dir : DirectionProviderDir;
        if (!string.IsNullOrWhiteSpace(resolvedDir))
            attributes["dir"] = resolvedDir;
    }

    private bool HasClassOverride(string value)
    {
        return Class?.Contains(value, StringComparison.Ordinal) == true;
    }

    private static string? GetDataBoolean(bool value)
    {
        return value ? "true" : null;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedDate);
        hc.Add(Mode);
        hc.Add(SelectedRange?.From);
        hc.Add(SelectedRange?.To);
        hc.Add(DateOnlyValue);
        hc.Add(Min);
        hc.Add(Max);
        hc.Add(_displayMonth);
        hc.Add(DisplayMonth);
        hc.Add(ShowOutsideDays);
        hc.Add(NumberOfMonths);
        hc.Add(ShowWeekNumber);
        hc.Add(FixedWeeks);
        hc.Add(CaptionLayout);
        hc.Add(UseFullMonthNames);
        hc.Add(CultureName);
        hc.Add(UseCultureCalendar);
        hc.Add(Dir);
        hc.Add(DirectionProviderDir);
        hc.Add(DisabledDates?.Length ?? 0);
        hc.Add(Modifiers?.Count ?? 0);
        hc.Add(ModifierClasses?.Count ?? 0);

        if (SelectedDates is not null)
        {
            foreach (var selectedDate in SelectedDates)
            {
                hc.Add(selectedDate);
            }
        }
    }

}
