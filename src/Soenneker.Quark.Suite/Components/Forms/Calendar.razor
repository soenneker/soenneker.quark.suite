@using System.Globalization
@using System.Linq

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<div @attributes="BuildAttributes()">
    <div class="q-calendar-months relative flex flex-col gap-4 md:flex-row">
        @for (var monthIndex = 0; monthIndex < Math.Max(NumberOfMonths, 1); monthIndex++)
        {
            var month = _displayMonth.AddMonths(monthIndex);
            var weeks = BuildMonthWeeks(month);

            <div class="q-calendar-month flex w-full flex-col gap-4">
                <div class="q-calendar-header relative flex h-8 w-full items-center justify-center px-8">
                    @if (monthIndex == 0)
                    {
                        <Button Variant="ButtonVariant.Ghost"
                                Size="ButtonSize.IconSm"
                                Class="absolute left-0 size-8 p-0 select-none"
                                OnClick="PrevMonth"
                                aria-label="Previous month">
                            <Icon Name="LucideIcon.ChevronLeft" Class="size-4" />
                        </Button>
                    }
                    else
                    {
                        <span class="absolute left-0 inline-flex size-8"></span>
                    }

                    @if (CaptionLayout == "dropdown")
                    {
                        <div class="q-calendar-title flex h-8 w-full items-center justify-center gap-1.5 text-sm font-medium">
                            <div class="relative rounded-md border border-input shadow-xs has-focus:border-ring has-focus:ring-[3px] has-focus:ring-ring/50">
                                <select class="absolute inset-0 bg-popover opacity-0"
                                        value="@month.Month"
                                        @onchange="OnMonthChanged">
                                    @foreach (var optionMonth in Enumerable.Range(1, 12))
                                    {
                                        <option value="@optionMonth">@GetMonthLabel(optionMonth)</option>
                                    }
                                </select>
                                <div class="flex h-8 items-center gap-1 rounded-md pr-1 pl-2 text-sm">
                                    <span>@GetMonthLabel(month.Month)</span>
                                    <Icon Name="LucideIcon.ChevronDown" Class="size-3.5 text-muted-foreground" />
                                </div>
                            </div>
                            <div class="relative rounded-md border border-input shadow-xs has-focus:border-ring has-focus:ring-[3px] has-focus:ring-ring/50">
                                <select class="absolute inset-0 bg-popover opacity-0"
                                        value="@month.Year"
                                        @onchange="OnYearChanged">
                                    @foreach (var year in GetSelectableYears())
                                    {
                                        <option value="@year">@year</option>
                                    }
                                </select>
                                <div class="flex h-8 items-center gap-1 rounded-md pr-1 pl-2 text-sm">
                                    <span>@month.Year</span>
                                    <Icon Name="LucideIcon.ChevronDown" Class="size-3.5 text-muted-foreground" />
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="q-calendar-title flex h-8 w-full items-center justify-center text-sm font-medium select-none">@month.ToString("MMMM yyyy", ResolveCulture())</div>
                    }

                    @if (monthIndex == Math.Max(NumberOfMonths, 1) - 1)
                    {
                        <Button Variant="ButtonVariant.Ghost"
                                Size="ButtonSize.IconSm"
                                Class="absolute right-0 size-8 p-0 select-none"
                                OnClick="NextMonth"
                                aria-label="Next month">
                            <Icon Name="LucideIcon.ChevronRight" Class="size-4" />
                        </Button>
                    }
                    else
                    {
                        <span class="absolute right-0 inline-flex size-8"></span>
                    }
                </div>

                <div class="q-calendar-weekdays flex">
                    @if (ShowWeekNumber)
                    {
                        <div class="q-calendar-week-number-header flex size-8 items-center justify-center text-center text-[0.8rem] text-muted-foreground select-none">Wk</div>
                    }

                    @foreach (var dow in _dayNames)
                    {
                        <div class="q-calendar-weekday flex-1 rounded-md text-center text-[0.8rem] font-normal text-muted-foreground select-none">@dow</div>
                    }
                </div>

                <div class="q-calendar-grid w-full border-collapse">
                    @foreach (var week in weeks)
                    {
                        <div class="q-calendar-week mt-2 flex w-full">
                            @if (ShowWeekNumber)
                            {
                                <div class="q-calendar-week-number flex size-8 items-center justify-center text-center text-[0.8rem] text-muted-foreground select-none">
                                    @GetWeekNumber(week[0].Date)
                                </div>
                            }

                            @foreach (var day in week)
                            {
                                var dayContext = BuildDayContext(day);
                                var cellCss = GetDayCellClass(dayContext, day);
                                var buttonCss = GetDayButtonClass(dayContext, day);

                                <div class="@cellCss"
                                     data-selected="@(GetDataBoolean(dayContext.IsSelected || dayContext.IsRangeStart || dayContext.IsRangeEnd || dayContext.IsRangeMiddle))"
                                     data-range-start="@(GetDataBoolean(dayContext.IsRangeStart))"
                                     data-range-end="@(GetDataBoolean(dayContext.IsRangeEnd))"
                                     data-range-middle="@(GetDataBoolean(dayContext.IsRangeMiddle))">
                                    <button type="button"
                                            class="@buttonCss"
                                            disabled="@day.Disabled"
                                            data-day="@day.Date.ToString("yyyy-MM-dd")"
                                            data-selected-single="@(GetDataBoolean(dayContext.IsSelected && !dayContext.IsRangeStart && !dayContext.IsRangeEnd && !dayContext.IsRangeMiddle))"
                                            data-range-start="@(GetDataBoolean(dayContext.IsRangeStart))"
                                            data-range-end="@(GetDataBoolean(dayContext.IsRangeEnd))"
                                            data-range-middle="@(GetDataBoolean(dayContext.IsRangeMiddle))"
                                            @onclick="() => SelectDate(day.Date)">
                                        @if (DayContent is not null)
                                        {
                                            @DayContent(dayContext)
                                        }
                                        else
                                        {
                                            @day.Date.Day
                                        }
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public DateOnly? SelectedDate { get; set; }

    [Parameter]
    public EventCallback<DateOnly?> SelectedDateChanged { get; set; }

    [Parameter]
    public DateOnly[]? SelectedDates { get; set; }

    [Parameter]
    public EventCallback<DateOnly[]> SelectedDatesChanged { get; set; }

    [Parameter]
    public CalendarSelectionMode Mode { get; set; } = CalendarSelectionMode.Single;

    [Parameter]
    public CalendarDateRange? SelectedRange { get; set; }

    [Parameter]
    public EventCallback<CalendarDateRange?> SelectedRangeChanged { get; set; }

    [Parameter]
    public DateOnly? DisplayMonth { get; set; }

    [Parameter]
    public EventCallback<DateOnly?> DisplayMonthChanged { get; set; }

    /// <summary>
    /// Gets or sets the selected date.
    /// </summary>
    [Parameter]
    public DateOnly? DateOnlyValue { get; set; }

    /// <summary>
    /// Gets or sets callback when date is selected.
    /// </summary>
    [Parameter]
    public EventCallback<DateOnly?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the minimum selectable date.
    /// </summary>
    [Parameter]
    public DateOnly? Min { get; set; }

    /// <summary>
    /// Gets or sets the maximum selectable date.
    /// </summary>
    [Parameter]
    public DateOnly? Max { get; set; }

    [Parameter]
    public bool ShowOutsideDays { get; set; } = true;

    [Parameter]
    public int NumberOfMonths { get; set; } = 1;

    [Parameter]
    public bool ShowWeekNumber { get; set; }

    [Parameter]
    public bool FixedWeeks { get; set; } = true;

    [Parameter]
    public string CaptionLayout { get; set; } = "label";

    [Parameter]
    public string? CultureName { get; set; }

    [Parameter]
    public DateOnly[]? DisabledDates { get; set; }

    [Parameter]
    public Dictionary<string, Func<DateOnly, bool>>? Modifiers { get; set; }

    [Parameter]
    public Dictionary<string, string>? ModifierClasses { get; set; }

    [Parameter]
    public RenderFragment<CalendarDayContext>? DayContent { get; set; }

    private DateOnly _displayMonth = DateOnly.FromDateTime(DateTime.Today);
    private string[] _dayNames = [];
    private bool _initialized;
    private bool IsRangeMode => Mode == CalendarSelectionMode.Range;
    private bool IsMultipleMode => Mode == CalendarSelectionMode.Multiple;
    private DateOnly? EffectiveSelectedDate => SelectedDate ?? DateOnlyValue;
    private CalendarDateRange? EffectiveSelectedRange => SelectedRange;
    private IReadOnlyList<DateOnly> EffectiveSelectedDates => SelectedDates ?? [];

    protected override void OnInitialized()
    {
        base.OnInitialized();
        InitializeDayNames();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        InitializeDayNames();

        if (!IsRangeMode && SelectedDate is null && DateOnlyValue.HasValue)
            SelectedDate = DateOnlyValue;

        if (DisplayMonth.HasValue)
        {
            _displayMonth = new DateOnly(DisplayMonth.Value.Year, DisplayMonth.Value.Month, 1);
            _initialized = true;
            return;
        }

        if (!_initialized)
        {
            var initialDate = IsRangeMode
                ? EffectiveSelectedRange?.From ?? EffectiveSelectedRange?.To ?? DateOnly.FromDateTime(DateTime.Today)
                : IsMultipleMode
                    ? EffectiveSelectedDates.FirstOrDefault(DateOnly.FromDateTime(DateTime.Today))
                    : EffectiveSelectedDate ?? DateOnly.FromDateTime(DateTime.Today);
            _displayMonth = new DateOnly(initialDate.Year, initialDate.Month, 1);
            _initialized = true;
        }
    }

    private void InitializeDayNames()
    {
        var culture = ResolveCulture();
        var first = culture.DateTimeFormat.FirstDayOfWeek;
        var names = culture.DateTimeFormat.AbbreviatedDayNames;
        _dayNames = Enumerable.Range(0, 7).Select(i => names[((int)first + i) % 7]).ToArray();
    }

    private record Cell(DateOnly Date, bool InMonth, bool Disabled);

    private List<List<Cell>> BuildMonthWeeks(DateOnly month)
    {
        var firstOfMonth = new DateOnly(month.Year, month.Month, 1);
        var culture = ResolveCulture();
        var startDow = culture.DateTimeFormat.FirstDayOfWeek;
        var offset = ((int)firstOfMonth.DayOfWeek - (int)startDow + 7) % 7;
        var gridStart = firstOfMonth.AddDays(-offset);
        var weeks = new List<List<Cell>>(6);
        var currentWeek = new List<Cell>(7);

        for (var i = 0; i < 42; i++)
        {
            var d = gridStart.AddDays(i);
            var inMonth = d.Month == month.Month;
            var disabled = (Min.HasValue && d < Min.Value) ||
                           (Max.HasValue && d > Max.Value) ||
                           (DisabledDates?.Contains(d) == true);
            if (!ShowOutsideDays && !inMonth)
                disabled = true;

            currentWeek.Add(new Cell(d, inMonth, disabled));

            if (currentWeek.Count == 7)
            {
                weeks.Add(currentWeek);
                currentWeek = new List<Cell>(7);
            }
        }

        if (!FixedWeeks)
        {
            var lastWeekWithMonthDays = weeks.FindLastIndex(week => week.Any(cell => cell.InMonth));
            if (lastWeekWithMonthDays >= 0)
                weeks = weeks.Take(lastWeekWithMonthDays + 1).ToList();
        }

        return weeks;
    }

    private async Task SelectDate(DateOnly date)
    {
        if ((Min.HasValue && date < Min.Value) || (Max.HasValue && date > Max.Value) || (DisabledDates?.Contains(date) == true))
            return;

        if (IsRangeMode)
        {
            var nextRange = BuildNextRange(date);
            SelectedRange = nextRange;
            await SelectedRangeChanged.InvokeAsync(nextRange);
            InvalidateRender();
            Refresh();
            return;
        }

        if (IsMultipleMode)
        {
            var values = EffectiveSelectedDates.ToList();
            var existingIndex = values.FindIndex(candidate => candidate == date);

            if (existingIndex >= 0)
                values.RemoveAt(existingIndex);
            else
                values.Add(date);

            SelectedDates = values.ToArray();
            await SelectedDatesChanged.InvokeAsync(SelectedDates);
            InvalidateRender();
            Refresh();
            return;
        }

        SelectedDate = date;
        DateOnlyValue = date;
        await SelectedDateChanged.InvokeAsync(SelectedDate);
        await ValueChanged.InvokeAsync(DateOnlyValue);
        InvalidateRender();
        Refresh();
    }

    private CalendarDateRange BuildNextRange(DateOnly date)
    {
        if (SelectedRange?.From is null || SelectedRange.To is not null)
            return new CalendarDateRange(date, null);

        if (date < SelectedRange.From.Value)
            return new CalendarDateRange(date, SelectedRange.From.Value);

        return new CalendarDateRange(SelectedRange.From.Value, date);
    }

    private bool IsDateInRange(DateOnly date)
    {
        if (EffectiveSelectedRange?.From is null || EffectiveSelectedRange.To is null)
            return false;

        return date > EffectiveSelectedRange.From.Value && date < EffectiveSelectedRange.To.Value;
    }

    private bool IsRangeEndpoint(DateOnly date)
    {
        if (EffectiveSelectedRange?.From is null)
            return false;

        return date == EffectiveSelectedRange.From.Value || (EffectiveSelectedRange.To.HasValue && date == EffectiveSelectedRange.To.Value);
    }

    private bool IsDateSelected(DateOnly date)
    {
        if (IsMultipleMode)
            return EffectiveSelectedDates.Contains(date);

        return EffectiveSelectedDate.HasValue && date == EffectiveSelectedDate.Value;
    }

    private int GetWeekNumber(DateOnly date)
    {
        var culture = ResolveCulture();
        return culture.Calendar.GetWeekOfYear(date.ToDateTime(TimeOnly.MinValue), culture.DateTimeFormat.CalendarWeekRule, culture.DateTimeFormat.FirstDayOfWeek);
    }

    private async Task OnMonthChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var month))
            return;

        _displayMonth = new DateOnly(_displayMonth.Year, month, 1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    private async Task OnYearChanged(ChangeEventArgs args)
    {
        if (!int.TryParse(args.Value?.ToString(), out var year))
            return;

        _displayMonth = new DateOnly(year, _displayMonth.Month, 1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    private IEnumerable<int> GetSelectableYears()
    {
        var minYear = Min?.Year ?? (_displayMonth.Year - 10);
        var maxYear = Max?.Year ?? (_displayMonth.Year + 10);

        return Enumerable.Range(minYear, maxYear - minYear + 1);
    }

    private string GetMonthLabel(int month)
    {
        return ResolveCulture().DateTimeFormat.GetMonthName(month);
    }

    private CultureInfo ResolveCulture()
    {
        if (CultureName.IsNullOrEmpty())
            return CultureInfo.CurrentCulture;

        try
        {
            return CultureInfo.GetCultureInfo(CultureName);
        }
        catch (CultureNotFoundException)
        {
            return CultureInfo.CurrentCulture;
        }
    }

    private CalendarDayContext BuildDayContext(Cell day)
    {
        var modifiers = GetModifierNames(day.Date);

        return new CalendarDayContext(
            day.Date,
            day.InMonth,
            day.Disabled,
            day.Date == DateOnly.FromDateTime(DateTime.Today),
            IsDateSelected(day.Date),
            EffectiveSelectedRange?.From == day.Date,
            EffectiveSelectedRange?.To == day.Date,
            IsDateInRange(day.Date),
            modifiers);
    }

    private List<string> GetModifierNames(DateOnly date)
    {
        if (Modifiers is null || Modifiers.Count == 0)
            return [];

        var matches = new List<string>();

        foreach (var pair in Modifiers)
        {
            if (pair.Value.Invoke(date))
                matches.Add(pair.Key);
        }

        return matches;
    }

    private string AppendModifierClasses(string css, IReadOnlyList<string> modifiers)
    {
        if (ModifierClasses is null || modifiers.Count == 0)
            return css;

        foreach (var modifier in modifiers)
        {
            if (ModifierClasses.TryGetValue(modifier, out var classes) && !classes.IsNullOrEmpty())
                css += $" {classes}";
        }

        return css;
    }

    private string GetDayCellClass(CalendarDayContext dayContext, Cell day)
    {
        var css = "q-calendar-day group/day relative aspect-square h-8 w-8 p-0 text-center select-none";

        if (ShowWeekNumber)
            css += " [&:nth-child(2)[data-selected=true]_button]:rounded-l-md";
        else
            css += " [&:first-child[data-selected=true]_button]:rounded-l-md";

        css += " [&:last-child[data-selected=true]_button]:rounded-r-md";

        if (dayContext.IsRangeStart)
            css += " rounded-l-md bg-accent";
        if (dayContext.IsRangeEnd)
            css += " rounded-r-md bg-accent";

        if (!ShowOutsideDays && !day.InMonth)
            css += " invisible";

        css = AppendModifierClasses(css, dayContext.Modifiers);

        return css;
    }

    private string GetDayButtonClass(CalendarDayContext dayContext, Cell day)
    {
        var css = "flex aspect-square size-auto h-8 w-full min-w-8 flex-col items-center justify-center gap-1 rounded-md text-sm leading-none font-normal outline-none transition-[color,background-color,box-shadow]";

        if (day.Disabled)
            css += " pointer-events-none opacity-50";

        if (!day.InMonth)
            css += " text-muted-foreground aria-selected:text-muted-foreground";

        css += " focus-visible:relative focus-visible:z-10 focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50";

        if (dayContext.IsRangeStart || dayContext.IsRangeEnd)
            css += " bg-primary text-primary-foreground hover:bg-primary hover:text-primary-foreground";
        else if (dayContext.IsRangeMiddle)
            css += " rounded-none bg-accent text-accent-foreground";
        else if (dayContext.IsSelected)
            css += " bg-primary text-primary-foreground hover:bg-primary hover:text-primary-foreground";
        else if (dayContext.IsToday)
            css += " bg-accent text-accent-foreground";
        else
            css += " hover:bg-accent hover:text-accent-foreground";

        return css;
    }

    private async Task PrevMonth()
    {
        _displayMonth = _displayMonth.AddMonths(-1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    private async Task NextMonth()
    {
        _displayMonth = _displayMonth.AddMonths(1);
        await DisplayMonthChanged.InvokeAsync(_displayMonth);
        InvalidateRender();
        Refresh();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "calendar";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-calendar");
            AppendClass(ref cls, "group/calendar w-fit bg-background p-3 rounded-md [--cell-size:2rem]");
        });
    }

    private static string GetDataBoolean(bool value)
    {
        return value ? "true" : "false";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedDate);
        hc.Add(Mode);
        hc.Add(SelectedRange?.From);
        hc.Add(SelectedRange?.To);
        hc.Add(DateOnlyValue);
        hc.Add(Min);
        hc.Add(Max);
        hc.Add(_displayMonth);
        hc.Add(DisplayMonth);
        hc.Add(ShowOutsideDays);
        hc.Add(NumberOfMonths);
        hc.Add(ShowWeekNumber);
        hc.Add(FixedWeeks);
        hc.Add(CaptionLayout);
        hc.Add(CultureName);
        hc.Add(DisabledDates?.Length ?? 0);
        hc.Add(Modifiers?.Count ?? 0);
        hc.Add(ModifierClasses?.Count ?? 0);

        if (SelectedDates is not null)
        {
            foreach (var selectedDate in SelectedDates)
            {
                hc.Add(selectedDate);
            }
        }
    }
}
