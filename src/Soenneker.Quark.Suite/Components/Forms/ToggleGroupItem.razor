@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.FormControlElement

<BradixToggleGroupItem Value="@ResolvedValue"
                       Disabled="@Disabled"
                       AdditionalAttributes="@ItemAttributes">
    @ChildContent
</BradixToggleGroupItem>

@code {
    [CascadingParameter(Name = "ParentToggleGroup")]
    private ToggleGroup? ParentToggleGroup { get; set; }

    /// <summary>
    /// Gets or sets visual variant (overrides group).
    /// </summary>
    [Parameter]
    public ToggleVariant? Variant { get; set; }

    /// <summary>
    /// Gets or sets size (overrides group).
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? Size { get; set; }

    private string ResolvedValue => Value ?? string.Empty;

    private IReadOnlyDictionary<string, object> ItemAttributes
    {
        get
        {
            var variant = Variant ?? ParentToggleGroup?.Variant ?? ToggleVariant.Default;
            var size = Size ?? ParentToggleGroup?.Size ?? "default";
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("value");
            attributes.Remove("type");
            attributes.Remove("aria-pressed");
            attributes.Remove("data-state");
            attributes.Remove("tabindex");
            attributes.Remove("onclick");
            attributes.Remove("onkeydown");
            attributes.Remove("onfocus");

            attributes["data-slot"] = "toggle-group-item";
            attributes["data-value"] = ResolvedValue;
            attributes["data-variant"] = variant?.Value ?? ToggleVariant.Default.Value;
            attributes["data-size"] = GetToggleSizeDataAttribute(size);
            attributes["data-spacing"] = ParentToggleGroup?.Spacing.ToString() ?? "0";
            attributes["data-orientation"] = ParentToggleGroup?.Orientation?.Value ?? ToggleGroupOrientation.Horizontal.Value;
            attributes[ParentToggleGroup?.Orientation == ToggleGroupOrientation.Vertical ? "data-vertical" : "data-horizontal"] = string.Empty;

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "shrink-0 group-data-[spacing=0]/toggle-group:rounded-none group-data-[spacing=0]/toggle-group:px-2 focus:z-10 focus-visible:z-10");
                AppendClass(ref cls, "group-data-[spacing=0]/toggle-group:has-data-[icon=inline-end]:pr-1.5 group-data-[spacing=0]/toggle-group:has-data-[icon=inline-start]:pl-1.5");
                AppendClass(ref cls, "group-data-horizontal/toggle-group:data-[spacing=0]:first:rounded-l-lg group-data-vertical/toggle-group:data-[spacing=0]:first:rounded-t-lg group-data-horizontal/toggle-group:data-[spacing=0]:last:rounded-r-lg group-data-vertical/toggle-group:data-[spacing=0]:last:rounded-b-lg");
                AppendClass(ref cls, "group-data-horizontal/toggle-group:data-[spacing=0]:data-[variant=outline]:border-l-0 group-data-vertical/toggle-group:data-[spacing=0]:data-[variant=outline]:border-t-0 group-data-horizontal/toggle-group:data-[spacing=0]:data-[variant=outline]:first:border-l group-data-vertical/toggle-group:data-[spacing=0]:data-[variant=outline]:first:border-t");
                AppendClass(ref cls, "group/toggle inline-flex items-center justify-center gap-1 rounded-lg text-sm font-medium whitespace-nowrap transition-all outline-none");
                AppendClass(ref cls, "hover:text-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 aria-pressed:bg-muted data-[state=on]:bg-muted dark:aria-invalid:ring-destructive/40");
                AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
                AppendClass(ref cls, Toggle.GetToggleVariantClass(variant?.Value));
                AppendClass(ref cls, Toggle.ResolveToggleSizeClass(size, includeShrink: true));
                AppendClass(ref cls, "data-vertical:w-full");
            });

            return attributes;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(ParentToggleGroup?.Variant);
        hc.Add(ParentToggleGroup?.Size);
        hc.Add(ParentToggleGroup?.Spacing);
        hc.Add(ParentToggleGroup?.Orientation);
    }

    private static string GetToggleSizeDataAttribute(CssValue<ToggleSizeBuilder>? size)
    {
        if (size?.TryGetThemeToken(out var token) == true && token is not null)
            return token;

        return ToggleSize.Default.Value;
    }
}
