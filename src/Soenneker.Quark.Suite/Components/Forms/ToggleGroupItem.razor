@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.FormControlElement

<BradixToggleGroupItem Value="@ResolvedValue"
                       Disabled="@Disabled"
                       AdditionalAttributes="@ItemAttributes">
    @ChildContent
</BradixToggleGroupItem>

@code {
    [CascadingParameter(Name = "ParentToggleGroup")]
    private ToggleGroup? ParentToggleGroup { get; set; }

    /// <summary>
    /// Gets or sets visual variant (overrides group).
    /// </summary>
    [Parameter]
    public ToggleVariant? Variant { get; set; }

    /// <summary>
    /// Gets or sets size (overrides group).
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? Size { get; set; }

    private string ResolvedValue => Value ?? string.Empty;

    private IReadOnlyDictionary<string, object> ItemAttributes
    {
        get
        {
            var variant = Variant ?? ParentToggleGroup?.Variant ?? ToggleVariant.Default;
            var size = Size ?? ParentToggleGroup?.Size ?? "default";
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("value");
            attributes.Remove("type");
            attributes.Remove("aria-pressed");
            attributes.Remove("data-state");
            attributes.Remove("tabindex");
            attributes.Remove("onclick");
            attributes.Remove("onkeydown");
            attributes.Remove("onfocus");

            attributes["data-slot"] = "toggle-group-item";
            attributes["data-value"] = ResolvedValue;
            attributes["data-variant"] = ReferenceEquals(variant, ToggleVariant.Outline) ? "outline" : "default";
            attributes["data-size"] = GetToggleSizeDataAttribute(size);
            attributes["data-spacing"] = ParentToggleGroup?.Spacing.ToString() ?? "0";
            attributes["data-orientation"] = ParentToggleGroup?.Orientation?.Value ?? Orientation.Horizontal.Value;

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "focus:z-10 focus-visible:z-10");
                AppendClass(ref cls, "data-[spacing=0]:rounded-none data-[spacing=0]:shadow-none data-[spacing=0]:first:rounded-l-md data-[spacing=0]:last:rounded-r-md");
                AppendClass(ref cls, "data-[spacing=0]:data-[variant=outline]:border-l-0 data-[spacing=0]:data-[variant=outline]:first:border-l");
                AppendClass(ref cls, "hover:bg-muted hover:text-muted-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 data-[state=on]:bg-accent data-[state=on]:text-accent-foreground dark:aria-invalid:ring-destructive/40");
                AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
                AppendClass(ref cls, Toggle.GetToggleVariantClass(variant));
                AppendClass(ref cls, Toggle.ResolveToggleSizeClass(size, includeShrink: true));
            });

            return attributes;
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        Width ??= Quark.Width.Auto;
        MinWidth ??= Quark.MinWidth.Is0;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is3.OnX;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.Token("transition-[color,box-shadow]");
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(ParentToggleGroup?.Variant);
        hc.Add(ParentToggleGroup?.Size);
        hc.Add(ParentToggleGroup?.Spacing);
        hc.Add(ParentToggleGroup?.Orientation);
    }

    private static string GetToggleSizeDataAttribute(CssValue<ToggleSizeBuilder>? size)
    {
        if (size?.TryGetThemeToken(out var token) == true && token is not null)
            return token;

        return ToggleSize.Default.Value;
    }
}
