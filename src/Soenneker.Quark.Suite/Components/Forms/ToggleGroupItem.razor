@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.FormControlElement

<BradixToggleGroupItem Value="@ResolvedValue"
                       Disabled="@Disabled"
                       AdditionalAttributes="@ItemAttributes">
    @ChildContent
</BradixToggleGroupItem>

@code {
    [CascadingParameter(Name = "ParentToggleGroup")]
    private ToggleGroup? ParentToggleGroup { get; set; }

    /// <summary>
    /// Gets or sets visual variant (overrides group).
    /// </summary>
    [Parameter]
    public ToggleVariant? Variant { get; set; }

    /// <summary>
    /// Gets or sets size (overrides group).
    /// </summary>
    [Parameter]
    public CssValue<ToggleSizeBuilder>? Size { get; set; }

    private string ResolvedValue => Value ?? string.Empty;

    private IReadOnlyDictionary<string, object> ItemAttributes
    {
        get
        {
            var variant = Variant ?? ParentToggleGroup?.Variant ?? ToggleVariant.Default;
            var size = Size ?? ParentToggleGroup?.Size ?? "default";
            Dictionary<string, object> attributes = new(BuildAttributes());

            attributes.Remove("disabled");
            attributes.Remove("value");
            attributes.Remove("type");
            attributes.Remove("aria-pressed");
            attributes.Remove("data-state");
            attributes.Remove("tabindex");
            attributes.Remove("onclick");
            attributes.Remove("onkeydown");
            attributes.Remove("onfocus");

            attributes["data-slot"] = "toggle-group-item";
            attributes["data-value"] = ResolvedValue;
            attributes["data-variant"] = ReferenceEquals(variant, ToggleVariant.Outline) ? "outline" : "default";
            attributes["data-size"] = GetToggleSizeDataAttribute(size);
            attributes["data-spacing"] = ParentToggleGroup?.Spacing.ToString() ?? "0";

            BuildClassAttribute(attributes, (ref cls) =>
            {
                var isRtl = string.Equals(ParentToggleGroup?.ResolvedDirection, "rtl", StringComparison.OrdinalIgnoreCase);
                var horizontalEdgeClasses = isRtl
                    ? "group-data-[spacing=0]/toggle-group:has-data-[icon=inline-end]:pe-1.5 group-data-[spacing=0]/toggle-group:has-data-[icon=inline-start]:ps-1.5 group-data-horizontal/toggle-group:data-[spacing=0]:first:rounded-s-lg group-data-horizontal/toggle-group:data-[spacing=0]:last:rounded-e-lg group-data-horizontal/toggle-group:data-[spacing=0]:data-[variant=outline]:border-s-0 group-data-horizontal/toggle-group:data-[spacing=0]:data-[variant=outline]:first:border-s has-data-[icon=inline-end]:pe-2 has-data-[icon=inline-start]:ps-2"
                    : "group-data-[spacing=0]/toggle-group:has-data-[icon=inline-end]:pr-1.5 group-data-[spacing=0]/toggle-group:has-data-[icon=inline-start]:pl-1.5 group-data-horizontal/toggle-group:data-[spacing=0]:first:rounded-l-lg group-data-horizontal/toggle-group:data-[spacing=0]:last:rounded-r-lg group-data-horizontal/toggle-group:data-[spacing=0]:data-[variant=outline]:border-l-0 group-data-horizontal/toggle-group:data-[spacing=0]:data-[variant=outline]:first:border-l has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2";

                AppendClass(ref cls, "shrink-0 group-data-[spacing=0]/toggle-group:rounded-none group-data-[spacing=0]/toggle-group:px-2 focus:z-10 focus-visible:z-10");
                AppendClass(ref cls, horizontalEdgeClasses);
                AppendClass(ref cls, "group-data-vertical/toggle-group:data-[spacing=0]:first:rounded-t-lg group-data-vertical/toggle-group:data-[spacing=0]:last:rounded-b-lg group-data-vertical/toggle-group:data-[spacing=0]:data-[variant=outline]:border-t-0 group-data-vertical/toggle-group:data-[spacing=0]:data-[variant=outline]:first:border-t group/toggle");
                AppendClass(ref cls, "hover:text-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 aria-pressed:bg-muted data-[state=on]:bg-muted dark:aria-invalid:ring-destructive/40");
                AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0");
                AppendClass(ref cls, Toggle.GetToggleVariantClass(variant));
                AppendClass(ref cls, Toggle.ResolveToggleSizeClass(size, includeShrink: true, isRtl));
            });

            return attributes;
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is1;
        Rounded ??= Quark.Rounded.Lg;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(ParentToggleGroup?.Variant);
        hc.Add(ParentToggleGroup?.Size);
        hc.Add(ParentToggleGroup?.Spacing);
        hc.Add(ParentToggleGroup?.Orientation);
    }

    private static string GetToggleSizeDataAttribute(CssValue<ToggleSizeBuilder>? size)
    {
        if (size?.TryGetThemeToken(out var token) == true && token is not null)
            return token;

        return ToggleSize.Default.Value;
    }
}
