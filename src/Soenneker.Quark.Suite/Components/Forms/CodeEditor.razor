@using System.Linq.Expressions
@using System.Text.Json
@using Microsoft.JSInterop

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

@inject ICodeEditorInterop CodeEditorInterop
@inject IThemeInterop ThemeInterop

<div @ref="_container" @attributes="BuildContainerAttributes()"></div>

@code {
    /// <summary>
    /// Gets or sets the code text value.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the code text changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> TextChanged { get; set; }

    /// <summary>
    /// Gets or sets the expression that identifies the bound text value for validation.
    /// </summary>
    [Parameter]
    public Expression<Func<string?>>? TextExpression { get; set; }

    /// <summary>
    /// Gets or sets the programming language for syntax highlighting.
    /// </summary>
    [Parameter]
    public string Language { get; set; } = "csharp";

    /// <summary>
    /// Gets or sets the editor theme (e.g., "vs", "vs-dark", "hc-black", or "auto" to follow app light/dark mode).
    /// </summary>
    [Parameter]
    public string Theme { get; set; } = "auto";

    /// <summary>
    /// Gets or sets whether word wrapping is enabled.
    /// </summary>
    [Parameter]
    public bool WordWrap { get; set; }

    /// <summary>
    /// Gets or sets whether the minimap is displayed.
    /// </summary>
    [Parameter]
    public bool Minimap { get; set; } = true;

    /// <summary>
    /// Gets or sets whether the editor height should automatically adjust to content.
    /// </summary>
    [Parameter]
    public bool AutoHeight { get; set; }

    /// <summary>
    /// Gets or sets the minimum number of lines to display.
    /// </summary>
    [Parameter]
    public int? MinLines { get; set; } = 3;

    /// <summary>
    /// Gets or sets the maximum number of lines to display.
    /// </summary>
    [Parameter]
    public int? MaxLines { get; set; } = 30;

    private ElementReference _container;
    private string? _lastText;
    private string? _lastLanguage;
    private string? _lastTheme;
    private bool _lastAutoHeight;
    private int? _lastMinLines;
    private int? _lastMaxLines;
    private bool _initialized;
    private bool _valueChanged;
    private bool _themeIsAuto;
    private DotNetObjectReference<CodeEditor>? _themeCallbackRef;

    [JSInvokable]
    public async Task OnThemeChanged(bool isDark)
    {
        if (_themeIsAuto && _initialized)
            await CodeEditorInterop.SetTheme(isDark ? "vs-dark" : "vs");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CodeEditorInterop.Initialize();

            _themeIsAuto = string.Equals(Theme, "auto", StringComparison.OrdinalIgnoreCase);
            var effectiveTheme = Theme;
            if (_themeIsAuto)
            {
                await ThemeInterop.Initialize();
                var isDark = await ThemeInterop.GetIsDark();
                effectiveTheme = isDark ? "vs-dark" : "vs";
                _themeCallbackRef = DotNetObjectReference.Create(this);
                await CodeEditorInterop.RegisterThemeChangedCallback(_themeCallbackRef);
            }

            var options = new
            {
                value = Text ?? string.Empty,
                language = Language,
                theme = effectiveTheme,
                readOnly = ReadOnly,
                wordWrap = WordWrap ? "on" : "off",
                minimap = new { enabled = Minimap },
                automaticLayout = true
            };

            var json = JsonSerializer.Serialize(options);
            await CodeEditorInterop.CreateEditor(_container, json);

            // If auto-height is enabled, set up content change listener
            if (AutoHeight)
            {
                await CodeEditorInterop.AddContentChangeListener(_container, MinLines, MaxLines);
            }

            _initialized = true;
            _lastLanguage = Language;
            _lastTheme = Theme;
            _lastText = Text;
            _lastAutoHeight = AutoHeight;
            _lastMinLines = MinLines;
            _lastMaxLines = MaxLines;
        }
        else if (_initialized)
        {
            // OnParametersSet runs before the browser lays out visibility changes (e.g. DemoSection code panel
            // uses `hidden` on small viewports until "View Code"). Sync Monaco after paint.
            if (AutoHeight)
                await CodeEditorInterop.UpdateContentHeight(_container, MinLines, MaxLines);
            else
                await CodeEditorInterop.Layout(_container);
        }

        _valueChanged = false;
        await base.OnAfterRenderAsync(firstRender);
    }

    protected override async Task OnParametersSetAsync()
    {
        // Set default width and height if not specified
        Width ??= Soenneker.Quark.Width.Is100;
        
        // Don't set a fixed height if AutoHeight is enabled
        if (!AutoHeight && Height == null && Style == null)
        {
            Style = "height: 300px";
        }

        if (_initialized)
        {
            var heightSettingsChanged = AutoHeight != _lastAutoHeight || MinLines != _lastMinLines || MaxLines != _lastMaxLines;

            if (!string.Equals(Text, _lastText, StringComparison.Ordinal))
            {
                await CodeEditorInterop.SetValue(_container, Text ?? string.Empty);
                _lastText = Text;
            }

            if (!string.Equals(Language, _lastLanguage, StringComparison.OrdinalIgnoreCase))
            {
                await CodeEditorInterop.SetLanguage(_container, Language);
                _lastLanguage = Language;
            }

            if (!string.Equals(Theme, _lastTheme, StringComparison.OrdinalIgnoreCase))
            {
                var effectiveTheme = string.Equals(Theme, "auto", StringComparison.OrdinalIgnoreCase)
                    ? (await ThemeInterop.GetIsDark() ? "vs-dark" : "vs")
                    : Theme;
                await CodeEditorInterop.SetTheme(effectiveTheme);
                _lastTheme = Theme;
            }

            if (AutoHeight && heightSettingsChanged)
            {
                await CodeEditorInterop.UpdateContentHeight(_container, MinLines, MaxLines);
            }

            _lastAutoHeight = AutoHeight;
            _lastMinLines = MinLines;
            _lastMaxLines = MaxLines;
        }

        await base.OnParametersSetAsync();
    }

    protected override bool ShouldRender()
    {
        return _valueChanged || base.ShouldRender();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attrs)
    {
        base.BuildAttributesCore(attrs);
        // Not used on wrapper div; still apply base surface/interactive attributes
    }

    private Dictionary<string, object> BuildContainerAttributes()
    {
        var attrs = new Dictionary<string, object>(base.BuildAttributes())
        {
            ["data-slot"] = "code-editor"
        };
        // Monaco editor needs position: relative for proper rendering
        BuildStyleAttribute(attrs, (ref sty) =>
        {
            AppendStyleDecl(ref sty, "position: relative");
            AppendStyleDecl(ref sty, "width: 100%");
            AppendStyleDecl(ref sty, "min-width: 0");
        });

        return attrs;
    }

    public override async ValueTask DisposeAsync()
    {
        if (_themeCallbackRef != null)
        {
            await CodeEditorInterop.UnregisterThemeChangedCallback(_themeCallbackRef);
            _themeCallbackRef.Dispose();
            _themeCallbackRef = null;
        }

        if (_initialized)
        {
            try
            {
                await CodeEditorInterop.DisposeEditor(_container);
            }
            catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException or TaskCanceledException or ObjectDisposedException)
            {
                // Ignore navigation-time JS teardown races.
            }
        }

        await base.DisposeAsync();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Text);
        hc.Add(Language);
        hc.Add(Theme);
        hc.Add(WordWrap);
        hc.Add(Minimap);
        hc.Add(AutoHeight);
        hc.Add(MinLines);
        hc.Add(MaxLines);
    }
}
