@using System.Linq.Expressions
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements Soenneker.Quark.IValidationInput
@implements ITextArea

<textarea @ref="_elementRef"
          @attributes="BuildAttributes()"
          value="@Value"
          @oninput="HandleInput"
          @onchange="HandleChange"></textarea>

@code {
    private ElementReference _elementRef;

    [CascadingParameter]
    internal InputGroupContext? InputGroupContext { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the textarea value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the expression used for validation.
    /// </summary>
    [Parameter]
    public Expression<Func<string?>>? ValueExpression { get; set; }

    /// <summary>
    /// Gets or sets minimum length.
    /// </summary>
    [Parameter]
    public int? MinLength { get; set; }

    /// <summary>
    /// Gets or sets maximum length.
    /// </summary>
    [Parameter]
    public int? MaxLength { get; set; }

    /// <summary>
    /// Gets or sets visible row count.
    /// </summary>
    [Parameter]
    public int? Rows { get; set; }

    /// <summary>
    /// Gets or sets callback invoked for input events.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnInput { get; set; }

    /// <summary>
    /// Gets or sets callback invoked for change events.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    /// <summary>
    /// Gets or sets the textarea text direction.
    /// </summary>
    [Parameter]
    public string? Dir { get; set; }

    public object? ValidationValue => Value;
    private string? ResolvedDir => !string.IsNullOrWhiteSpace(Dir) ? Dir : DirectionProviderDir;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            InputGroupContext?.RegisterControl(_elementRef);

        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;

            if (ValueExpression is not null)
                await ParentValidation.InitializeInputExpression(ValueExpression);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        _ = RefreshOffThread();
    }

    private bool ShouldShowInvalid()
    {
        if (ParentValidation is null || ParentValidation.Status != ValidationStatus.Error)
            return false;

        var showInvalidProp = ParentValidation.GetType().GetProperty("ShouldShowInvalid");
        var showInvalid = showInvalidProp?.GetValue(ParentValidation) as bool? ?? true;
        return showInvalid;
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var next = e.Value?.ToString();
        var valueChanged = !string.Equals(Value, next, StringComparison.Ordinal);
        Value = next;

        if (valueChanged)
            await ValueChanged.InvokeIfHasDelegate(Value);

        await OnInput.InvokeIfHasDelegate(e);

        if (ParentValidation is not null)
            await ParentValidation.NotifyInputChanged(Value);

        if (valueChanged)
        {
            InvalidateRender();
            Refresh();
        }
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        var next = e.Value?.ToString();
        var valueChanged = !string.Equals(Value, next, StringComparison.Ordinal);
        Value = next;

        if (valueChanged)
            await ValueChanged.InvokeIfHasDelegate(Value);

        await OnChange.InvokeIfHasDelegate(e);

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(Value);
        }

        if (valueChanged)
        {
            InvalidateRender();
            Refresh();
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        MinHeight ??= Quark.Height.Token("16");
        Width ??= Quark.Width.IsFull;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Input;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Padding ??= Quark.Padding.Token("2.5").OnX.Is2.OnY;
        TextSize ??= Quark.TextSize.Base.OnMd.Sm;
        Transition ??= Quark.Transition.Token("transition-colors");
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes.TryAdd("data-slot", "textarea");
        var hadExplicitDescription = attributes.ContainsKey("aria-describedby");
        ApplyFieldControlAttributes(attributes, ShouldShowInvalid());
        if (!hadExplicitDescription)
            attributes.Remove("aria-describedby");

        if (!string.IsNullOrWhiteSpace(ResolvedDir))
            attributes["dir"] = ResolvedDir!;

        if (MinLength.HasValue)
            attributes["minlength"] = MinLength.Value;
        if (MaxLength.HasValue)
            attributes["maxlength"] = MaxLength.Value;
        if (Rows.HasValue)
            attributes["rows"] = Rows.Value;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "field-sizing-content");
            AppendClass(ref cls, "placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:cursor-not-allowed disabled:bg-input/50 disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "dark:bg-input/30 dark:disabled:bg-input/80 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
        hc.Add(MinLength);
        hc.Add(MaxLength);
        hc.Add(Rows);
        hc.Add(Dir);
        hc.Add(DirectionProviderDir);
    }

    public override void Dispose()
    {
        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;

        base.Dispose();
    }
}
