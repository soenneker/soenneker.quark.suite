@using System.Linq.Expressions
@using System.Threading
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IDateInput

<div @attributes="BuildWrapperAttributes()">
    <Input Type="@GetInputModeString()"
           Id="@Id"
           Name="@Name"
           Value="@GetCurrentValue()"
           ValueChanged="@HandleValueChanged"
           InputSize="@InputSize"
           PlainText="@PlainText"
           FloatingLabel="@FloatingLabel"
           Label="@Label"
           Placeholder="@Placeholder"
           Disabled="@Disabled"
           ReadOnly="@ReadOnly"
           Required="@Required"
           Class="@ResolvedInputClass"
           Style="@Style"
           AriaLabel="@AriaLabel"
           AriaDescribedBy="@AriaDescribedBy"
           @attributes="BuildInputAttributes()" 
           OnInput="HandleInput"
           OnChange="HandleChange"
           OnBlur="HandleInputBlur"
           OnKeyDown="HandleInputKeyDown"
           ValidationValueSelector="@(() => (object?)Date ?? (object?)DateOnly)" />
    <AutoSaveStatus State="@CurrentAutoSaveState"
                    Visible="@UsesAutoSaveStatusSlot"
                    Class="@AutoSaveStatusOverlayClass"
                    SavingClass="@AutoSaveSavingClass"
                    SavedClass="@AutoSaveSavedClass"
                    FailedClass="@AutoSaveFailedClass" />
</div>

@code {
    private readonly AutoSaveController<DateTime?> _dateAutoSave = new();
    private readonly AutoSaveController<DateOnly?> _dateOnlyAutoSave = new();

	/// <summary>
	/// Gets or sets the date value.
	/// </summary>
	[Parameter]
	public DateTime? Date { get; set; }

	/// <summary>
	/// Gets or sets the expression that identifies the bound date value.
	/// </summary>
	[Parameter]
	public Expression<Func<DateTime?>>? DateExpression { get; set; }

	/// <summary>
	/// Gets or sets the date-only value.
	/// </summary>
	[Parameter]
	public DateOnly? DateOnly { get; set; }

	/// <summary>
	/// Gets or sets the expression that identifies the bound date-only value.
	/// </summary>
	[Parameter]
	public Expression<Func<DateOnly?>>? DateOnlyExpression { get; set; }

	/// <summary>
	/// Gets or sets the minimum date value.
	/// </summary>
	[Parameter]
	public DateTime Min { get; set; }

	/// <summary>
	/// Gets or sets the maximum date value.
	/// </summary>
	[Parameter]
	public DateTime Max { get; set; }

	/// <summary>
	/// Gets or sets the minimum date-only value.
	/// </summary>
	[Parameter]
	public DateOnly MinDateOnly { get; set; }

	/// <summary>
	/// Gets or sets the maximum date-only value.
	/// </summary>
	[Parameter]
	public DateOnly MaxDateOnly { get; set; }

	/// <summary>
	/// Gets or sets the step value for date increments.
	/// </summary>
	[Parameter]
	public int Step { get; set; } = 1;

	/// <summary>
	/// Gets or sets the input mode for the date picker.
	/// </summary>
	[Parameter]
	public DateInputMode InputMode { get; set; } = DateInputMode.Date;

	/// <summary>
	/// Gets or sets the callback invoked When the date changes.
	/// </summary>
	[Parameter]
	public EventCallback<DateTime?> DateChanged { get; set; }

	/// <summary>
	/// Gets or sets the callback invoked When the date-only value changes.
	/// </summary>
	[Parameter]
	public EventCallback<DateOnly?> DateOnlyChanged { get; set; }

	/// <summary>
	/// Gets or sets the size of the input.
	/// </summary>
	[Parameter]
	public CssValue<InputSizeBuilder>? InputSize { get; set; } = InputSizes.Default;

	/// <summary>
	/// Gets or sets whether the input should be displayed as plain text.
	/// </summary>
	[Parameter]
	public bool PlainText { get; set; }

	/// <summary>
	/// Gets or sets whether the label should float.
	/// </summary>
	[Parameter]
	public bool FloatingLabel { get; set; }

	/// <summary>
	/// Gets or sets the label text.
	/// </summary>
	[Parameter]
	public string? Label { get; set; }

	/// <summary>
	/// Gets or sets the callback invoked When the input changes.
	/// </summary>
	[Parameter]
	public EventCallback<ChangeEventArgs> OnChange { get; set; }

	/// <summary>
	/// Gets or sets the callback invoked When the input value changes.
	/// </summary>
	[Parameter]
	public EventCallback<ChangeEventArgs> OnInput { get; set; }

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<DateTime?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public Func<DateOnly?, CancellationToken, ValueTask>? OnAutoSaveDateOnly { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

	[CascadingParameter(Name = nameof(ParentValidation))]
	public Validation? ParentValidation { get; set; }

	/// <summary>
	/// Gets the value used for validation.
	/// </summary>
	public object? ValidationValue => Date ?? (object?)DateOnly;

	public string? GetValidationClass()
	{
		if (ParentValidation?.Status == ValidationStatus.Error)
			return "is-invalid";

		if (ParentValidation?.Status == ValidationStatus.Success)
			return "is-valid";

		return null;
	}

	public string? GetColorClass()
	{
		return null;
	}

	public string? GetSizeClass()
	{
		var sizeClass = InputSize?.ToString();
		return string.IsNullOrWhiteSpace(sizeClass) ? null : sizeClass;
	}

    private string InputModeValue => InputMode?.Value ?? DateInputMode.Date.Value;
    private bool UsesDateOnlyValue => DateOnlyExpression is not null || DateOnly.HasValue || DateOnlyChanged.HasDelegate;
    private AutoSaveState CurrentAutoSaveState => UsesDateOnlyValue ? _dateOnlyAutoSave.State : _dateAutoSave.State;
    private bool UsesAutoSaveStatusSlot => AutoSave && ShowAutoSaveStatus && (OnAutoSave is not null || OnAutoSaveDateOnly is not null);

    private string ResolvedInputClass => UsesAutoSaveStatusSlot
        ? AppendToClass(Class, "pe-8")
        : Class ?? string.Empty;

    private string AutoSaveStatusOverlayClass
    {
        get
        {
            const string overlayClass = "absolute end-2.5 top-1/2 -translate-y-1/2";

            return string.IsNullOrWhiteSpace(AutoSaveStatusClass)
                ? overlayClass
                : $"{overlayClass} {AutoSaveStatusClass}";
        }
    }

	private string GetCurrentValue()
	{
		if (Date.HasValue)
            return FormatDateValue(Date.Value, InputModeValue);

		if (DateOnly.HasValue)
            return FormatDateOnlyValue(DateOnly.Value, InputModeValue);

		return string.Empty;
	}

    private async Task HandleValueChanged(string? value)
    {
        if (DateExpression is not null || Date.HasValue || DateChanged.HasDelegate)
        {
            DateTime? next = DateTime.TryParse(value, out var dateValue) ? dateValue : null;
            var valueChanged = Date != next;
            Date = next;

            if (valueChanged)
            {
                await DateChanged.InvokeIfHasDelegate(Date);
                await _dateAutoSave.NotifyValueChanged(Date, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
                InvalidateRender();
                Refresh();
            }

            return;
        }

        if (DateOnlyExpression is not null || DateOnly.HasValue || DateOnlyChanged.HasDelegate)
        {
            DateOnly? next = System.DateOnly.TryParse(value, out var dateOnlyValue) ? dateOnlyValue : null;
            var valueChanged = DateOnly != next;
            DateOnly = next;

            if (valueChanged)
            {
                await DateOnlyChanged.InvokeIfHasDelegate(DateOnly);
                await _dateOnlyAutoSave.NotifyValueChanged(DateOnly, AutoSave, AutoSaveDelay, OnAutoSaveDateOnly, AutoSaveStateChanged, RefreshOffThread);
                InvalidateRender();
                Refresh();
            }
        }
    }

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender && ParentValidation is not null)
		{
			if (DateExpression is not null)
			{
				await ParentValidation.InitializeInputExpression(DateExpression);
			}
			else if (DateOnlyExpression is not null)
			{
				await ParentValidation.InitializeInputExpression(DateOnlyExpression);
			}
			ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
		}

		await base.OnAfterRenderAsync(firstRender);
	}

	private void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
	{
		_ = RefreshOffThread();
	}

	private async Task HandleInput(ChangeEventArgs e)
	{
		await OnInput.InvokeIfHasDelegate(e);

		if (ParentValidation is not null)
		{
			ParentValidation.MarkTouched();
			await ParentValidation.NotifyInputChanged(ValidationValue);
		}
	}

    private async Task HandleInputBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            await FlushAutoSave();

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleInputKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await FlushAutoSave();

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

    private Task FlushAutoSave()
    {
        return UsesDateOnlyValue
            ? _dateOnlyAutoSave.Flush(DateOnly, AutoSave, OnAutoSaveDateOnly, AutoSaveStateChanged, RefreshOffThread)
            : _dateAutoSave.Flush(Date, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
    }

	/// <summary>
	/// Disposes the component.
	/// </summary>
	public override async ValueTask DisposeAsync()
    {
		await base.DisposeAsync();
        await _dateAutoSave.DisposeAsync();
        await _dateOnlyAutoSave.DisposeAsync();

		if (ParentValidation is not null)
			ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
	    }

	private async Task HandleChange(ChangeEventArgs e)
	{
		await OnChange.InvokeIfHasDelegate(e);

		if (ParentValidation is not null)
		{
			ParentValidation.MarkTouched();
			await ParentValidation.NotifyInputChanged(ValidationValue);
		}
	}

	private string GetInputModeString()
	{
		return InputModeValue;
	}

	private Dictionary<string, object> BuildInputAttributes()
	{
		var attributes = new Dictionary<string, object>((AdditionalAttributes?.Count ?? 0) + (Attributes?.Count ?? 0), StringComparer.OrdinalIgnoreCase);

        if (AdditionalAttributes is not null)
        {
            foreach (var pair in AdditionalAttributes)
            {
                if (pair.Key.Equals("oninput", StringComparison.OrdinalIgnoreCase) ||
                    pair.Key.Equals("onchange", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[pair.Key] = pair.Value;
            }
        }

        if (Attributes is not null)
        {
            foreach (var pair in Attributes)
            {
                if (pair.Key.Equals("oninput", StringComparison.OrdinalIgnoreCase) ||
                    pair.Key.Equals("onchange", StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                attributes[pair.Key] = pair.Value;
            }
        }

		// Add DateInput-specific attributes
		if (Min != default)
		{
			var minString = FormatDateValue(Min, InputModeValue);
			attributes["min"] = minString;
		}
		else if (MinDateOnly != default)
		{
			var minString = FormatDateOnlyValue(MinDateOnly, InputModeValue);
			attributes["min"] = minString;
		}

		if (Max != default)
		{
			var maxString = FormatDateValue(Max, InputModeValue);
			attributes["max"] = maxString;
		}
		else if (MaxDateOnly != default)
		{
			var maxString = FormatDateOnlyValue(MaxDateOnly, InputModeValue);
			attributes["max"] = maxString;
		}

		if (Step > 1)
			attributes["step"] = Step;

		return attributes;
	}

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();

        if (UsesAutoSaveStatusSlot)
            attributes["class"] = "relative";

        return attributes;
    }

    private static string FormatDateValue(DateTime value, string inputModeValue)
    {
        return inputModeValue switch
        {
            "date" => value.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture),
            "datetime-local" => value.ToString("yyyy-MM-ddTHH:mm", System.Globalization.CultureInfo.InvariantCulture),
            "month" => value.ToString("yyyy-MM", System.Globalization.CultureInfo.InvariantCulture),
            _ => value.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)
        };
    }

    private static string FormatDateOnlyValue(DateOnly value, string inputModeValue)
    {
        return inputModeValue switch
        {
            "date" => value.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture),
            "datetime-local" => value.ToDateTime(TimeOnly.MinValue).ToString("yyyy-MM-ddTHH:mm", System.Globalization.CultureInfo.InvariantCulture),
            "month" => value.ToString("yyyy-MM", System.Globalization.CultureInfo.InvariantCulture),
            _ => value.ToString("yyyy-MM-dd", System.Globalization.CultureInfo.InvariantCulture)
        };
    }

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
        base.ComputeRenderKeyCore(ref hc);
		hc.Add(Date);
		hc.Add(DateOnly);
		hc.Add(Min);
		hc.Add(Max);
		hc.Add(MinDateOnly);
		hc.Add(MaxDateOnly);
		hc.Add(Step);
		hc.Add(InputMode);
		AddIf(ref hc, InputSize);
		hc.Add(PlainText);
		hc.Add(FloatingLabel);
		hc.Add(Label);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(CurrentAutoSaveState);
        hc.Add(OnAutoSave is not null);
        hc.Add(OnAutoSaveDateOnly is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
		hc.Add(Placeholder);
		hc.Add(Disabled);
		hc.Add(ReadOnly);
		hc.Add(Required);
	}
}
