@using System.Globalization
@using System.Linq.Expressions
@using System.Threading
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElementBase
@implements INumericInput

<div @attributes="BuildWrapperAttributes()">
    <Input Id="@Id"
           Name="@Name"
           Type="number"
           Value="@GetNumericValueString()"
           ValueChanged="@HandleValueChanged"
           InputSize="@InputSize"
           PlainText="@PlainText"
           FloatingLabel="@FloatingLabel"
           Label="@Label"
           Placeholder="@Placeholder"
           Disabled="@Disabled"
           ReadOnly="@ReadOnly"
           Required="@Required"
           Class="@ResolvedInputClass"
           Style="@Style"
           AriaLabel="@AriaLabel"
           AriaDescribedBy="@AriaDescribedBy"
           @attributes="BuildInputAttributes()" 
           OnInput="HandleInput"
           OnChange="HandleChange"
           OnBlur="HandleInputBlur"
           OnKeyDown="HandleInputKeyDown"
           ValidationValueSelector="@(() => (object?)Value)" />
    <AutoSaveStatus State="@_autoSave.State"
                    Visible="@UsesAutoSaveStatusSlot"
                    Class="@AutoSaveStatusOverlayClass"
                    SavingClass="@AutoSaveSavingClass"
                    SavedClass="@AutoSaveSavedClass"
                    FailedClass="@AutoSaveFailedClass" />
</div>

@code {
    private readonly AutoSaveController<decimal?> _autoSave = new();

    /// <summary>
    /// Gets or sets the value.
    /// </summary>
    [Parameter]
    public decimal? Value { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the value changes.
    /// </summary>
    [Parameter]
    public EventCallback<decimal?> ValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the expression that identifies the bound value for validation.
    /// </summary>
    [Parameter]
    public Expression<Func<decimal?>>? ValueExpression { get; set; }

    /// <summary>
    /// Gets or sets the minimum allowed value.
    /// </summary>
    [Parameter]
    public decimal? Min { get; set; }

    /// <summary>
    /// Gets or sets the maximum allowed value.
    /// </summary>
    [Parameter]
    public decimal? Max { get; set; }

    /// <summary>
    /// Gets or sets the step increment for the numeric input.
    /// </summary>
    [Parameter]
    public decimal? Step { get; set; }

    /// <summary>
    /// Gets or sets the size of the numeric input.
    /// </summary>
    [Parameter]
    public CssValue<InputSizeBuilder>? InputSize { get; set; } = InputSizes.Default;

    /// <summary>
    /// Gets or sets whether the input should be rendered as plain text.
    /// </summary>
    [Parameter]
    public bool PlainText { get; set; }

    /// <summary>
    /// Gets or sets whether the input should use floating label styling.
    /// </summary>
    [Parameter]
    public bool FloatingLabel { get; set; }

    /// <summary>
    /// Gets or sets the label text for the input.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the input value changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked during input.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnInput { get; set; }

    [Parameter]
    public bool AutoSave { get; set; }

    [Parameter]
    public int AutoSaveDelay { get; set; } = 750;

    [Parameter]
    public bool AutoSaveOnBlur { get; set; } = true;

    [Parameter]
    public bool AutoSaveOnEnter { get; set; }

    [Parameter]
    public bool ShowAutoSaveStatus { get; set; } = true;

    [Parameter]
    public Func<decimal?, CancellationToken, ValueTask>? OnAutoSave { get; set; }

    [Parameter]
    public EventCallback<AutoSaveState> AutoSaveStateChanged { get; set; }

    [Parameter]
    public string? AutoSaveStatusClass { get; set; }

    [Parameter]
    public string? AutoSaveSavingClass { get; set; }

    [Parameter]
    public string? AutoSaveSavedClass { get; set; }

    [Parameter]
    public string? AutoSaveFailedClass { get; set; }

    /// <summary>
    /// Gets or sets the parent validation context.
    /// </summary>
    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    public object? ValidationValue => Value;
    private bool UsesAutoSaveStatusSlot => AutoSave && OnAutoSave is not null && ShowAutoSaveStatus;

    private string ResolvedInputClass => UsesAutoSaveStatusSlot
        ? AppendToClass(Class, "pe-8")
        : Class ?? string.Empty;

    private string AutoSaveStatusOverlayClass
    {
        get
        {
            const string overlayClass = "absolute end-2.5 top-1/2 -translate-y-1/2";

            return string.IsNullOrWhiteSpace(AutoSaveStatusClass)
                ? overlayClass
                : $"{overlayClass} {AutoSaveStatusClass}";
        }
    }

    public string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error)
            return "is-invalid";

        if (ParentValidation?.Status == ValidationStatus.Success)
            return "is-valid";

        return null;
    }

    public string? GetColorClass()
    {
        return null;
    }

    public string? GetSizeClass()
    {
        var sizeClass = InputSize?.ToString();
        return string.IsNullOrWhiteSpace(sizeClass) ? null : sizeClass;
    }

    private string? GetNumericValueString()
    {
        return Value?.ToString(CultureInfo.InvariantCulture);
    }

    private async Task HandleValueChanged(string? value)
    {
        decimal? next = string.IsNullOrWhiteSpace(value)
            ? null
            : decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var parsed)
                ? parsed
                : null;

        var valueChanged = !Nullable.Equals(Value, next);
        Value = next;

        if (valueChanged)
        {
            await ValueChanged.InvokeIfHasDelegate(Value);
            await _autoSave.NotifyValueChanged(Value, AutoSave, AutoSaveDelay, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);
            InvalidateRender();
            Refresh();
        }
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        await OnInput.InvokeIfHasDelegate(e);
        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(Value);
        }
    }

    private async Task HandleInputBlur(FocusEventArgs e)
    {
        if (AutoSaveOnBlur)
            await _autoSave.Flush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnBlur.InvokeIfHasDelegate(e);
    }

    private async Task HandleInputKeyDown(KeyboardEventArgs e)
    {
        if (AutoSaveOnEnter && string.Equals(e.Key, "Enter", StringComparison.Ordinal))
            await _autoSave.Flush(Value, AutoSave, OnAutoSave, AutoSaveStateChanged, RefreshOffThread);

        await OnKeyDown.InvokeIfHasDelegate(e);
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        await OnChange.InvokeIfHasDelegate(e);
        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(Value);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null && ValueExpression is not null)
        {
            await ParentValidation.InitializeInputExpression(ValueExpression);
            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        _ = RefreshOffThread();
    }

    private Dictionary<string, object> BuildInputAttributes()
    {
        var attributes = new Dictionary<string, object>();

        // Add NumericInput-specific attributes
        if (Min.HasValue)
            attributes["min"] = Min.Value.ToString(CultureInfo.InvariantCulture);

        if (Max.HasValue)
            attributes["max"] = Max.Value.ToString(CultureInfo.InvariantCulture);

        if (Step.HasValue)
            attributes["step"] = Step.Value.ToString(CultureInfo.InvariantCulture);

        return attributes;
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();

        if (UsesAutoSaveStatusSlot)
            attributes["class"] = "relative";

        return attributes;
    }

    public override async ValueTask DisposeAsync()
    {
        await base.DisposeAsync();
        await _autoSave.DisposeAsync();

        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
        }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Min);
        hc.Add(Max);
        hc.Add(Step);
        AddIf(ref hc, InputSize);
        hc.Add(PlainText);
        hc.Add(FloatingLabel);
        hc.Add(Label);
        hc.Add(AutoSave);
        hc.Add(AutoSaveDelay);
        hc.Add(AutoSaveOnBlur);
        hc.Add(AutoSaveOnEnter);
        hc.Add(ShowAutoSaveStatus);
        hc.Add(_autoSave.State);
        hc.Add(OnAutoSave is not null);
        hc.Add(AutoSaveStatusClass);
        hc.Add(AutoSaveSavingClass);
        hc.Add(AutoSaveSavedClass);
        hc.Add(AutoSaveFailedClass);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
    }
}
