@using System.Globalization
@using System.Linq.Expressions
@using Microsoft.JSInterop
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements ISlider

@inject ISliderInterop SliderInterop

@{
	double[] resolvedValues = GetResolvedValues();
}

<div @ref="ElementRef" @attributes="BuildWrapperAttributes()">
	<div @ref="_trackRef"
	     @attributes="BuildTrackAttributes()"
	     @onpointerdown="HandleTrackPointerDown"
	     @onpointerdown:preventDefault="true">
		<div @attributes="BuildRangeAttributes(resolvedValues)"></div>
	</div>
	@for (int index = 0; index < resolvedValues.Length; index++)
	{
		int thumbIndex = index;
		<button @attributes="BuildThumbAttributes(thumbIndex, resolvedValues[thumbIndex])"
		        @onfocus="@(() => HandleThumbFocus(thumbIndex))"
		        @onblur="@(() => HandleThumbBlur(thumbIndex))"
		        @onkeydown="@(e => HandleThumbKeyDown(thumbIndex, e))"
		        @onkeydown:preventDefault="true"
		        @onpointerdown="@(e => HandleThumbPointerDown(thumbIndex, e))"
		        @onpointerdown:stopPropagation="true">
		</button>
	}
	@for (int index = 0; index < resolvedValues.Length; index++)
	{
		<input @attributes="BuildHiddenInputAttributes(index, resolvedValues[index])" />
	}
</div>

@code {
	[Parameter]
	public double SliderValue { get; set; }

	[Parameter]
	public Expression<Func<double>>? SliderValueExpression { get; set; }

	[Parameter]
	public double[]? Values { get; set; }

	[Parameter]
	public EventCallback<double[]> ValuesChanged { get; set; }

	[Parameter]
	public Expression<Func<double[]?>>? ValuesExpression { get; set; }

	[Parameter]
	public double Min { get; set; }

	[Parameter]
	public double Max { get; set; } = 100;

	[Parameter]
	public double Step { get; set; } = 1;

	[Parameter]
	public EventCallback<double> SliderValueChanged { get; set; }

	[Parameter]
	public CssValue<SizeBuilder>? Size { get; set; } = Quark.Size.Default;

	[Parameter]
	public bool PlainText { get; set; }

	[Parameter]
	public bool FloatingLabel { get; set; }

	[Parameter]
	public string? Label { get; set; }

	[Parameter]
	public EventCallback<ChangeEventArgs> OnChange { get; set; }

	[Parameter]
	public EventCallback<ChangeEventArgs> OnInput { get; set; }

	[Parameter]
	public string Orientation { get; set; } = "horizontal";

	[CascadingParameter(Name = nameof(ParentValidation))]
	public Validation? ParentValidation { get; set; }

	[CascadingParameter(Name = "DirectionProviderDir")]
	private string? DirectionProviderDir { get; set; }

	private readonly string _hiddenInputClass = "sr-only";
	private ElementReference _trackRef;
	private DotNetObjectReference<Slider>? _dotNetRef;
	private int _focusedThumbIndex = -1;
	private int _draggingThumbIndex = -1;
	private bool _isRtl;

	private bool UsesValuesApi => Values is not null || ValuesChanged.HasDelegate || ValuesExpression is not null;
	private bool IsVertical => string.Equals(Orientation, "vertical", StringComparison.OrdinalIgnoreCase);
	private string OrientationValue => IsVertical ? "vertical" : "horizontal";
	private bool IsHorizontalRtl => !IsVertical && ResolveIsRtl();
	private bool IsInteractive => !Disabled && !ReadOnly;
	public object? ValidationValue => UsesValuesApi ? GetResolvedValues() : SliderValue;

	public string? GetColorClass() => null;

	private bool ResolveIsRtl()
	{
		if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
			return true;

		if (string.Equals(DirectionProviderDir, "ltr", StringComparison.OrdinalIgnoreCase))
			return false;

		if (Attributes is not null &&
			Attributes.TryGetValue("dir", out var dirValue))
		{
			string? direction = dirValue?.ToString();

			if (string.Equals(direction, "rtl", StringComparison.OrdinalIgnoreCase))
				return true;

			if (string.Equals(direction, "ltr", StringComparison.OrdinalIgnoreCase))
				return false;
		}

		return _isRtl;
	}

	public string? GetSizeClass()
	{
		if (Size == Quark.Size.Default)
			return null;

		string? token = null;
		_ = Size?.TryGetThemeToken(out token);
		string? sizeValue = token ?? Size?.ToString();

		return sizeValue?.ToLowerInvariant() switch
		{
			"sm" or "xs" => "h-6",
			"lg" => "h-10",
			_ => null
		};
	}

	public string? GetValidationClass()
	{
		if (ParentValidation?.Status == ValidationStatus.Error)
			return "is-invalid";

		if (ParentValidation?.Status == ValidationStatus.Success)
			return "is-valid";

		return null;
	}

	private double[] GetResolvedValues()
	{
		if (UsesValuesApi)
		{
			if (Values is { Length: > 0 })
				return NormalizeValues(Values, allowMultiple: true);

			return NormalizeValues(Max > Min ? [Min, Max] : [Min], allowMultiple: true);
		}

		return NormalizeValues([SliderValue], allowMultiple: false);
	}

	private double[] NormalizeValues(IReadOnlyList<double> source, bool allowMultiple)
	{
		if (source.Count == 0)
			return allowMultiple && Max > Min ? [NormalizeValue(Min), NormalizeValue(Max)] : [NormalizeValue(Min)];

		int length = allowMultiple ? source.Count : 1;
		var normalized = new double[length];

		for (int i = 0; i < length; i++)
		{
			normalized[i] = NormalizeValue(source[i]);
		}

		Array.Sort(normalized);
		return normalized;
	}

	private double NormalizeValue(double value)
	{
		double clamped = Math.Clamp(value, Min, Max);

		if (Step <= 0)
			return clamped;

		double steps = Math.Round((clamped - Min) / Step, MidpointRounding.AwayFromZero);
		double snapped = Min + (steps * Step);

		return Math.Clamp(snapped, Min, Max);
	}

	private double ValueToPercent(double value)
	{
		if (Max <= Min)
			return 0d;

		return Math.Clamp(((value - Min) / (Max - Min)) * 100d, 0d, 100d);
	}

	private int FindNearestThumbIndex(IReadOnlyList<double> values, double pointerValue)
	{
		int nearestIndex = 0;
		double nearestDistance = double.MaxValue;

		for (int i = 0; i < values.Count; i++)
		{
			double distance = Math.Abs(values[i] - pointerValue);

			if (distance < nearestDistance)
			{
				nearestDistance = distance;
				nearestIndex = i;
			}
		}

		return nearestIndex;
	}

	private double ConstrainThumbValue(IReadOnlyList<double> values, int index, double nextValue)
	{
		double normalized = NormalizeValue(nextValue);
		double minLimit = index > 0 ? values[index - 1] : Min;
		double maxLimit = index < values.Count - 1 ? values[index + 1] : Max;

		return Math.Clamp(normalized, minLimit, maxLimit);
	}

	private static bool AreValuesEqual(IReadOnlyList<double> left, IReadOnlyList<double> right)
	{
		if (left.Count != right.Count)
			return false;

		for (int i = 0; i < left.Count; i++)
		{
			if (!left[i].Equals(right[i]))
				return false;
		}

		return true;
	}

	private ChangeEventArgs CreateChangeEventArgs(double value)
	{
		return new ChangeEventArgs
		{
			Value = value.ToString(CultureInfo.InvariantCulture)
		};
	}

	private double GetKeyboardStep(bool isLargeStep)
	{
		if (Step > 0)
			return isLargeStep ? Step * 10d : Step;

		double range = Max - Min;
		double fallback = range > 0 ? range / 100d : 1d;
		return isLargeStep ? fallback * 10d : fallback;
	}

	private async Task<double> UpdateValueAsync(int index, double nextValue, bool notifyInput, bool notifyChange, bool markTouched)
	{
		double[] currentValues = GetResolvedValues();

		if (index < 0 || index >= currentValues.Length)
			return Min;

		double constrainedValue = ConstrainThumbValue(currentValues, index, nextValue);
		bool valueChanged = false;

		if (UsesValuesApi)
		{
			double[] updatedValues = (double[]) currentValues.Clone();
			updatedValues[index] = constrainedValue;

			if (!AreValuesEqual(currentValues, updatedValues))
			{
				Values = updatedValues;
				await ValuesChanged.InvokeIfHasDelegate(updatedValues);
				valueChanged = true;
			}
		}
		else if (!SliderValue.Equals(constrainedValue))
		{
			SliderValue = constrainedValue;
			await SliderValueChanged.InvokeAsync(SliderValue);
			valueChanged = true;
		}

		if (ParentValidation is not null && (valueChanged || markTouched))
		{
			if (markTouched)
				ParentValidation.MarkTouched();

			await ParentValidation.NotifyInputChanged(ValidationValue);
		}

		if (notifyInput && valueChanged)
			await OnInput.InvokeIfHasDelegate(CreateChangeEventArgs(constrainedValue));

		if (notifyChange && (valueChanged || markTouched))
			await OnChange.InvokeIfHasDelegate(CreateChangeEventArgs(constrainedValue));

		if (valueChanged)
			Refresh();

		return constrainedValue;
	}

	private async Task<double> GetPointerValueAsync(PointerEventArgs e)
	{
		return await SliderInterop.GetValueFromPointer(_trackRef, e.ClientX, e.ClientY, Min, Max, OrientationValue);
	}

	private void EnsureDotNetReference()
	{
		_dotNetRef ??= DotNetObjectReference.Create(this);
	}

	private async Task StartDragAsync(int index, PointerEventArgs e)
	{
		EnsureDotNetReference();

		double initialValue = await SliderInterop.StartDrag(_trackRef, e.PointerId, e.ClientX, e.ClientY, Min, Max, OrientationValue, _dotNetRef!, index);
		await UpdateValueAsync(index, initialValue, notifyInput: true, notifyChange: false, markTouched: false);
	}

	private string GetTrackThicknessClass()
	{
		if (Size == Quark.Size.Default)
			return IsVertical ? "w-1.5" : "h-1.5";

		string? token = null;
		_ = Size?.TryGetThemeToken(out token);
		string? sizeValue = token ?? Size?.ToString();

		return sizeValue?.ToLowerInvariant() switch
		{
			"sm" or "xs" => IsVertical ? "w-1" : "h-1",
			"lg" => IsVertical ? "w-2" : "h-2",
			_ => IsVertical ? "w-1.5" : "h-1.5"
		};
	}

	private string GetThumbSizeClass()
	{
		if (Size == Quark.Size.Default)
			return "size-4";

		string? token = null;
		_ = Size?.TryGetThemeToken(out token);
		string? sizeValue = token ?? Size?.ToString();

		return sizeValue?.ToLowerInvariant() switch
		{
			"sm" or "xs" => "size-3",
			"lg" => "size-5",
			_ => "size-4"
		};
	}

	private Dictionary<string, object> BuildWrapperAttributes()
	{
		var attributes = new Dictionary<string, object>();

		if (Attributes is not null)
		{
			if (Attributes.TryGetValue("class", out var @class))
				attributes["class"] = @class;

			if (Attributes.TryGetValue("style", out var style))
				attributes["style"] = style;
		}

		BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
		{
			BuildOwnedClassAndStyle(ref sty, ref cls);
			AppendClass(ref cls, "q-slider relative flex w-full touch-none items-center select-none data-[disabled]:opacity-50 data-[orientation=vertical]:h-full data-[orientation=vertical]:min-h-40 data-[orientation=vertical]:w-auto data-[orientation=vertical]:flex-col");

			if (Disabled || ReadOnly)
				AppendClass(ref cls, "cursor-not-allowed");

			string? sizeClass = GetSizeClass();

			if (sizeClass is not null)
				AppendClass(ref cls, sizeClass);
		});

		attributes["data-slot"] = "slider";
		attributes["data-orientation"] = OrientationValue;

		if (Disabled)
			attributes["data-disabled"] = "true";

		return attributes;
	}

	private Dictionary<string, object> BuildTrackAttributes()
	{
		var attributes = new Dictionary<string, object>
		{
			["data-slot"] = "slider-track",
			["data-orientation"] = OrientationValue
		};

		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "relative grow overflow-hidden rounded-full bg-muted data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full");
			AppendClass(ref cls, GetTrackThicknessClass());
		});

		return attributes;
	}

	private Dictionary<string, object> BuildRangeAttributes(IReadOnlyList<double> values)
	{
		double startPercent = values.Count > 1 ? ValueToPercent(values[0]) : 0d;
		double endPercent = ValueToPercent(values[^1]);
		double sizePercent = Math.Max(0d, endPercent - startPercent);

		var attributes = new Dictionary<string, object>
		{
			["data-slot"] = "slider-range",
			["data-orientation"] = OrientationValue
		};

		BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
		{
			AppendClass(ref cls, "absolute bg-primary data-[orientation=horizontal]:h-full data-[orientation=vertical]:w-full");

			if (IsVertical)
			{
				AppendStyleDecl(ref sty, $"bottom: {startPercent.ToString("F2", CultureInfo.InvariantCulture)}%");
				AppendStyleDecl(ref sty, $"height: {sizePercent.ToString("F2", CultureInfo.InvariantCulture)}%");
			}
			else
			{
				if (IsHorizontalRtl)
					AppendStyleDecl(ref sty, $"right: {startPercent.ToString("F2", CultureInfo.InvariantCulture)}%");
				else
					AppendStyleDecl(ref sty, $"left: {startPercent.ToString("F2", CultureInfo.InvariantCulture)}%");

				AppendStyleDecl(ref sty, $"width: {sizePercent.ToString("F2", CultureInfo.InvariantCulture)}%");
			}
		});

		return attributes;
	}

	private Dictionary<string, object> BuildThumbAttributes(int index, double value)
	{
		double percent = ValueToPercent(value);
		string percentText = percent.ToString("F2", CultureInfo.InvariantCulture) + "%";
		bool isActive = _focusedThumbIndex == index || _draggingThumbIndex == index;

		var attributes = new Dictionary<string, object>
		{
			["type"] = "button",
			["data-slot"] = "slider-thumb",
			["data-orientation"] = OrientationValue,
			["role"] = "slider",
			["tabindex"] = Disabled ? -1 : 0,
			["aria-valuemin"] = Min.ToString(CultureInfo.InvariantCulture),
			["aria-valuemax"] = Max.ToString(CultureInfo.InvariantCulture),
			["aria-valuenow"] = value.ToString(CultureInfo.InvariantCulture),
			["aria-orientation"] = OrientationValue
		};

		if (Disabled)
		{
			attributes["disabled"] = true;
			attributes["aria-disabled"] = "true";
		}

		if (ReadOnly)
			attributes["aria-readonly"] = "true";

		if (Required)
			attributes["aria-required"] = "true";

		if (AutoFocus && index == 0)
			attributes["autofocus"] = true;

		if (index == 0)
		{
			if (Id is not null)
				attributes["id"] = Id;

			ApplyFieldControlAttributes(attributes, ParentValidation?.Status == ValidationStatus.Error);
		}
		else if (Id is not null)
		{
			attributes["id"] = $"{Id}-{index}";
		}

		if (Attributes is not null && index == 0)
		{
			foreach (KeyValuePair<string, object> attribute in Attributes)
			{
				if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
				    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase) ||
				    attribute.Key.Equals("id", StringComparison.OrdinalIgnoreCase))
				{
					continue;
				}

				attributes[attribute.Key] = attribute.Value;
			}
		}

		BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
		{
			AppendClass(ref cls, "absolute block shrink-0 rounded-full border border-primary bg-white shadow-sm ring-ring/50 transition-[color,box-shadow] hover:ring-4 focus-visible:ring-4 focus-visible:outline-hidden disabled:pointer-events-none disabled:opacity-50");
			AppendClass(ref cls, GetThumbSizeClass());

			if (isActive)
				AppendClass(ref cls, "ring-4");

			if (IsVertical)
			{
				AppendStyleDecl(ref sty, "left: 50%");
				AppendStyleDecl(ref sty, $"bottom: {percentText}");
				AppendStyleDecl(ref sty, "transform: translate(-50%, 50%)");
			}
			else
			{
				if (IsHorizontalRtl)
					AppendStyleDecl(ref sty, $"right: {percentText}");
				else
					AppendStyleDecl(ref sty, $"left: {percentText}");

				AppendStyleDecl(ref sty, "top: 50%");
				AppendStyleDecl(ref sty, IsHorizontalRtl ? "transform: translate(50%, -50%)" : "transform: translate(-50%, -50%)");
			}
		});

		return attributes;
	}

	private Dictionary<string, object> BuildHiddenInputAttributes(int index, double value)
	{
		var attributes = new Dictionary<string, object>
		{
			["type"] = "hidden",
			["class"] = _hiddenInputClass,
			["value"] = value.ToString(CultureInfo.InvariantCulture)
		};

		if (!string.IsNullOrWhiteSpace(Name))
			attributes["name"] = Name;

		if (Disabled)
			attributes["disabled"] = true;

		if (index == 0 && Id is not null)
			attributes["id"] = $"{Id}-value";
		else if (Id is not null)
			attributes["id"] = $"{Id}-value-{index}";

		return attributes;
	}

	private void HandleThumbFocus(int index)
	{
		if (_focusedThumbIndex == index)
			return;

		_focusedThumbIndex = index;
		Refresh();
	}

	private void HandleThumbBlur(int index)
	{
		if (_draggingThumbIndex == index)
			return;

		if (_focusedThumbIndex != index)
			return;

		_focusedThumbIndex = -1;
		Refresh();
	}

	private async Task HandleThumbKeyDown(int index, KeyboardEventArgs e)
	{
		if (!IsInteractive)
			return;

		double currentValue = GetResolvedValues()[index];
		double nextValue;

		switch (e.Key)
		{
			case "Home":
				nextValue = Min;
				break;
			case "End":
				nextValue = Max;
				break;
			case "PageUp":
				nextValue = currentValue + GetKeyboardStep(isLargeStep: true);
				break;
			case "PageDown":
				nextValue = currentValue - GetKeyboardStep(isLargeStep: true);
				break;
			case "ArrowRight":
				nextValue = IsHorizontalRtl
					? currentValue - GetKeyboardStep(isLargeStep: false)
					: currentValue + GetKeyboardStep(isLargeStep: false);
				break;
			case "ArrowUp":
				nextValue = currentValue + GetKeyboardStep(isLargeStep: false);
				break;
			case "ArrowLeft":
				nextValue = IsHorizontalRtl
					? currentValue + GetKeyboardStep(isLargeStep: false)
					: currentValue - GetKeyboardStep(isLargeStep: false);
				break;
			case "ArrowDown":
				nextValue = currentValue - GetKeyboardStep(isLargeStep: false);
				break;
			default:
				return;
		}

		_focusedThumbIndex = index;
		await UpdateValueAsync(index, nextValue, notifyInput: true, notifyChange: true, markTouched: true);
	}

	private async Task HandleTrackPointerDown(PointerEventArgs e)
	{
		if (!IsInteractive)
			return;

		double pointerValue = await GetPointerValueAsync(e);
		int index = FindNearestThumbIndex(GetResolvedValues(), pointerValue);

		_focusedThumbIndex = index;
		_draggingThumbIndex = index;
		Refresh();

		await UpdateValueAsync(index, pointerValue, notifyInput: true, notifyChange: false, markTouched: false);
		await StartDragAsync(index, e);
	}

	private async Task HandleThumbPointerDown(int index, PointerEventArgs e)
	{
		if (!IsInteractive)
			return;

		_focusedThumbIndex = index;
		_draggingThumbIndex = index;
		Refresh();

		await StartDragAsync(index, e);
	}

	[JSInvokable]
	public async Task HandlePointerDragMove(int index, double value)
	{
		if (index < 0)
			return;

		_draggingThumbIndex = index;
		_focusedThumbIndex = index;
		await UpdateValueAsync(index, value, notifyInput: true, notifyChange: false, markTouched: false);
	}

	[JSInvokable]
	public async Task HandlePointerDragEnd(int index, double value)
	{
		if (index < 0)
			return;

		await UpdateValueAsync(index, value, notifyInput: false, notifyChange: true, markTouched: true);
		_draggingThumbIndex = -1;
		_focusedThumbIndex = index;
		Refresh();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			await SliderInterop.Initialize();

			if (ParentValidation is not null)
			{
				if (ValuesExpression is not null)
					await ParentValidation.InitializeInputExpression(ValuesExpression);
				else if (SliderValueExpression is not null)
					await ParentValidation.InitializeInputExpression(SliderValueExpression);
			}

		}

		bool resolvedIsRtl;

		if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
		{
			resolvedIsRtl = true;
		}
		else if (string.Equals(DirectionProviderDir, "ltr", StringComparison.OrdinalIgnoreCase))
		{
			resolvedIsRtl = false;
		}
		else if (Attributes is not null &&
			Attributes.TryGetValue("dir", out var dirValue) &&
			(dirValue is not null))
		{
			resolvedIsRtl = string.Equals(dirValue.ToString(), "rtl", StringComparison.OrdinalIgnoreCase);
		}
		else
		{
			resolvedIsRtl = await SliderInterop.IsDirectionRtl(_trackRef);
		}

		if (_isRtl != resolvedIsRtl)
		{
			_isRtl = resolvedIsRtl;
			Refresh();
		}

		await base.OnAfterRenderAsync(firstRender);
	}

	protected override void OnParametersSet()
	{
		double[] values = GetResolvedValues();

		if (_focusedThumbIndex >= values.Length)
			_focusedThumbIndex = values.Length - 1;

		if (_draggingThumbIndex >= values.Length)
			_draggingThumbIndex = values.Length - 1;

		base.OnParametersSet();
	}

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
		hc.Add(SliderValue);
		hc.Add(Min);
		hc.Add(Max);
		hc.Add(Step);
		hc.Add(OrientationValue);

		double[] values = GetResolvedValues();
		hc.Add(values.Length);

		for (int i = 0; i < values.Length; i++)
		{
			hc.Add(values[i]);
		}

		AddIf(ref hc, Size);
		hc.Add(PlainText);
		hc.Add(FloatingLabel);
		hc.Add(Label);
		hc.Add(Placeholder);
		hc.Add(Disabled);
		hc.Add(ReadOnly);
		hc.Add(Required);
		hc.Add(_isRtl);
		hc.Add(DirectionProviderDir);
		hc.Add(_focusedThumbIndex);
		hc.Add(_draggingThumbIndex);
	}

	protected override async Task OnDisposeAsync()
	{
		await SliderInterop.StopDrag();
		_dotNetRef?.Dispose();
	}
}
