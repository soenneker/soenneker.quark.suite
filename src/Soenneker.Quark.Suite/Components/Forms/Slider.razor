@using System.Globalization
@using System.Linq.Expressions
@using Microsoft.JSInterop
@using Soenneker.Bradix
@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Blazor.Utils.Ids

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements ISlider

@{
	var resolvedValues = GetResolvedValues();
}

<BradixSlider Values="resolvedValues"
              Min="@Min"
              Max="@Max"
              Step="@Step"
              Name="@Name"
              Disabled="@Disabled"
              Orientation="@Orientation"
              Dir="@(ResolveIsRtl() ? "rtl" : "ltr")"
              OnValuesChange="HandleBradixValuesChange"
              OnValueCommit="HandleBradixValueCommit"
              @attributes="BuildWrapperAttributes()">
	<BradixSliderTrack @attributes="BuildTrackAttributes()">
		<BradixSliderRange @attributes="BuildRangeAttributes(resolvedValues)" />
	</BradixSliderTrack>
	@for (var index = 0; index < resolvedValues.Length; index++)
	{
		var thumbIndex = index;
		<BradixSliderThumb AriaLabel="@ResolveThumbLabel(thumbIndex, resolvedValues.Length)"
		                   @attributes="BuildThumbAttributes(thumbIndex, resolvedValues[thumbIndex])" />
	}
</BradixSlider>

@code {
	[Parameter]
	public double SliderValue { get; set; }

	[Parameter]
	public Expression<Func<double>>? SliderValueExpression { get; set; }

	[Parameter]
	public double[]? Values { get; set; }

	[Parameter]
	public EventCallback<double[]> ValuesChanged { get; set; }

	[Parameter]
	public Expression<Func<double[]?>>? ValuesExpression { get; set; }

	[Parameter]
	public double Min { get; set; }

	[Parameter]
	public double Max { get; set; } = 100;

	[Parameter]
	public double Step { get; set; } = 1;

	[Parameter]
	public EventCallback<double> SliderValueChanged { get; set; }

	[Parameter]
	public CssValue<SliderSizeBuilder>? SliderSize { get; set; } = SliderSizes.Default;

	[Parameter]
	public bool PlainText { get; set; }

	[Parameter]
	public bool FloatingLabel { get; set; }

	[Parameter]
	public string? Label { get; set; }

	[Parameter]
	public EventCallback<ChangeEventArgs> OnChange { get; set; }

	[Parameter]
	public EventCallback<ChangeEventArgs> OnInput { get; set; }

	[Parameter]
	public Orientation Orientation { get; set; } = Orientation.Horizontal;

	protected override void ApplyDefaultParameters()
	{
		base.ApplyDefaultParameters();
		DataSlot ??= "slider";
		Position ??= Quark.Position.Relative;
		Display ??= Quark.Display.Flex;
		Width ??= Quark.Width.IsFull;
		ItemsAlign ??= Items.Center;
		UserSelect ??= Quark.UserSelect.None;
	}

	[CascadingParameter(Name = nameof(ParentValidation))]
	public Validation? ParentValidation { get; set; }

	[CascadingParameter(Name = "DirectionProviderDir")]
	private string? DirectionProviderDir { get; set; }

	private const string ThumbSizeClass = "size-3";
	private double[] _valuesBeforeSlideStart = [];
	private int _focusedThumbIndex = -1;
	private int _draggingThumbIndex = -1;

	private bool UsesValuesApi => Values is not null || ValuesChanged.HasDelegate || ValuesExpression is not null;
	private bool IsVertical => Orientation == Orientation.Vertical;
	private string OrientationValue => Orientation.Value;
	private bool IsInteractive => !Disabled && !ReadOnly;
	public object? ValidationValue => UsesValuesApi ? GetResolvedValues() : SliderValue;

	private bool ResolveIsRtl()
	{
		if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
			return true;

		if (string.Equals(DirectionProviderDir, "ltr", StringComparison.OrdinalIgnoreCase))
			return false;

		if (Attributes is not null &&
			Attributes.TryGetValue("dir", out var dirValue))
		{
			var direction = dirValue?.ToString();

			if (string.Equals(direction, "rtl", StringComparison.OrdinalIgnoreCase))
				return true;

			if (string.Equals(direction, "ltr", StringComparison.OrdinalIgnoreCase))
				return false;
		}

		return false;
	}

	private double[] GetResolvedValues()
	{
		if (UsesValuesApi)
		{
			if (Values is { Length: > 0 })
				return NormalizeValues(Values, allowMultiple: true);

			return NormalizeValues(Max > Min ? [Min, Max] : [Min], allowMultiple: true);
		}

		return NormalizeValues([SliderValue], allowMultiple: false);
	}

	private double[] NormalizeValues(IReadOnlyList<double> source, bool allowMultiple)
	{
		if (source.Count == 0)
			return allowMultiple && Max > Min ? [NormalizeValue(Min), NormalizeValue(Max)] : [NormalizeValue(Min)];

		var length = allowMultiple ? source.Count : 1;
		var normalized = new double[length];

		for (var i = 0; i < length; i++)
		{
			normalized[i] = NormalizeValue(source[i]);
		}

		Array.Sort(normalized);
		return normalized;
	}

	private double NormalizeValue(double value)
	{
		var clamped = Math.Clamp(value, Min, Max);

		if (Step <= 0)
			return clamped;

		var steps = Math.Round((clamped - Min) / Step, MidpointRounding.AwayFromZero);
		var snapped = Min + (steps * Step);

		return Math.Clamp(snapped, Min, Max);
	}

	private double ValueToPercent(double value)
	{
		if (Max <= Min)
			return 0d;

		return Math.Clamp(((value - Min) / (Max - Min)) * 100d, 0d, 100d);
	}

	private int FindNearestThumbIndex(IReadOnlyList<double> values, double pointerValue)
	{
		var nearestIndex = 0;
		var nearestDistance = double.MaxValue;

		for (var i = 0; i < values.Count; i++)
		{
			var distance = Math.Abs(values[i] - pointerValue);

			if (distance < nearestDistance)
			{
				nearestDistance = distance;
				nearestIndex = i;
			}
		}

		return nearestIndex;
	}

	private double ConstrainThumbValue(IReadOnlyList<double> values, int index, double nextValue)
	{
		var normalized = NormalizeValue(nextValue);
		var minLimit = index > 0 ? values[index - 1] : Min;
		var maxLimit = index < values.Count - 1 ? values[index + 1] : Max;

		return Math.Clamp(normalized, minLimit, maxLimit);
	}

	private static bool AreValuesEqual(IReadOnlyList<double> left, IReadOnlyList<double> right)
	{
		if (left.Count != right.Count)
			return false;

		for (var i = 0; i < left.Count; i++)
		{
			if (!left[i].Equals(right[i]))
				return false;
		}

		return true;
	}

	private ChangeEventArgs CreateChangeEventArgs(double value)
	{
		return new ChangeEventArgs
		{
			Value = FormatSliderNumber(value)
		};
	}

	private static string FormatSliderNumber(double value)
	{
		return value.ToString("G15", CultureInfo.InvariantCulture);
	}

	private async Task<double> UpdateValue(int index, double nextValue, bool notifyInput, bool notifyChange, bool markTouched)
	{
		var currentValues = GetResolvedValues();

		if (index < 0 || index >= currentValues.Length)
			return Min;

		var constrainedValue = ConstrainThumbValue(currentValues, index, nextValue);
		var valueChanged = false;

		if (UsesValuesApi)
		{
			var updatedValues = (double[]) currentValues.Clone();
			updatedValues[index] = constrainedValue;

			if (!AreValuesEqual(currentValues, updatedValues))
			{
				Values = updatedValues;
				await ValuesChanged.InvokeIfHasDelegate(updatedValues);
				valueChanged = true;
			}
		}
		else if (!SliderValue.Equals(constrainedValue))
		{
			SliderValue = constrainedValue;
			await SliderValueChanged.InvokeAsync(SliderValue);
			valueChanged = true;
		}

		if (ParentValidation is not null && (valueChanged || markTouched))
		{
			if (markTouched)
				ParentValidation.MarkTouched();

			await ParentValidation.NotifyInputChanged(ValidationValue);
		}

		if (notifyInput && valueChanged)
			await OnInput.InvokeIfHasDelegate(CreateChangeEventArgs(constrainedValue));

		if (notifyChange && (valueChanged || markTouched))
			await OnChange.InvokeIfHasDelegate(CreateChangeEventArgs(constrainedValue));

		if (valueChanged)
			Refresh();

		return constrainedValue;
	}

	private async Task HandleBradixValuesChange(IReadOnlyList<double> values)
	{
		var normalized = NormalizeValues(values, UsesValuesApi);

		if (UsesValuesApi)
		{
			if (!AreValuesEqual(GetResolvedValues(), normalized))
			{
				Values = normalized;
				await ValuesChanged.InvokeIfHasDelegate(normalized);
			}
		}
		else
		{
			var nextValue = normalized.Length > 0 ? normalized[0] : Min;

			if (!SliderValue.Equals(nextValue))
			{
				SliderValue = nextValue;
				await SliderValueChanged.InvokeAsync(SliderValue);
			}
		}

		if (ParentValidation is not null)
			await ParentValidation.NotifyInputChanged(ValidationValue);

		if (normalized.Length > 0)
			await OnInput.InvokeIfHasDelegate(CreateChangeEventArgs(normalized[0]));

		Refresh();
	}

	private async Task HandleBradixValueCommit(IReadOnlyList<double> values)
	{
		var normalized = NormalizeValues(values, UsesValuesApi);

		if (ParentValidation is not null)
		{
			ParentValidation.MarkTouched();
			await ParentValidation.NotifyInputChanged(ValidationValue);
		}

		if (normalized.Length > 0)
			await OnChange.InvokeIfHasDelegate(CreateChangeEventArgs(normalized[0]));
	}

	private double GetValueFromFractions(double xFraction, double yFraction)
	{
		var range = Max - Min;

		if (range <= 0)
			return Min;

		if (IsVertical)
			return Max - (Math.Clamp(yFraction, 0d, 1d) * range);

		var clampedX = Math.Clamp(xFraction, 0d, 1d);
		return ResolveIsRtl()
			? Max - (clampedX * range)
			: Min + (clampedX * range);
	}

	private async Task RestoreValues()
	{
		if (_valuesBeforeSlideStart.Length == 0)
			return;

		if (UsesValuesApi)
		{
			var restoredValues = (double[]) _valuesBeforeSlideStart.Clone();
			Values = restoredValues;
			await ValuesChanged.InvokeIfHasDelegate(restoredValues);

			if (ParentValidation is not null)
				await ParentValidation.NotifyInputChanged(ValidationValue);
		}
		else
		{
			var restoredValue = _valuesBeforeSlideStart[0];

			if (!SliderValue.Equals(restoredValue))
			{
				SliderValue = restoredValue;
				await SliderValueChanged.InvokeAsync(SliderValue);
			}

			if (ParentValidation is not null)
				await ParentValidation.NotifyInputChanged(ValidationValue);
		}

		Refresh();
	}

	private Dictionary<string, object> BuildWrapperAttributes()
	{
		var attributes = new Dictionary<string, object>();

		if (Attributes is not null)
		{
			if (Attributes.TryGetValue("class", out var @class))
				attributes["class"] = @class;

			if (Attributes.TryGetValue("style", out var style))
				attributes["style"] = style;
		}

		BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
		{
			AppendClass(ref cls, "touch-none data-disabled:opacity-50 data-[orientation=vertical]:h-full data-[orientation=vertical]:min-h-40 data-[orientation=vertical]:w-auto data-[orientation=vertical]:flex-col");

			BuildOwnedClassAndStyle(ref sty, ref cls);

			if (!IsVertical)
				AppendStyleDecl(ref sty, "--radix-slider-thumb-transform: translateX(-50%)");
		});

		attributes["data-slot"] = DataSlot!;

		if (CurrentFieldContext is not null && !attributes.ContainsKey("id"))
			attributes["id"] = CurrentFieldContext.ControlId;
		else if (Id is not null)
			attributes["id"] = Id;

		if (!string.IsNullOrWhiteSpace(AriaLabel))
			attributes["aria-label"] = AriaLabel!;

		if (!string.IsNullOrWhiteSpace(AriaLabelledBy))
			attributes["aria-labelledby"] = AriaLabelledBy!;

		var describedBy = CurrentFieldContext?.BuildDescribedBy(attributes.TryGetValue("aria-describedby", out var existingDescribedBy)
			? existingDescribedBy?.ToString()
			: null, ParentValidation?.Status == ValidationStatus.Error);

		if (!string.IsNullOrWhiteSpace(describedBy))
			attributes["aria-describedby"] = describedBy;

		if (ParentValidation?.Status == ValidationStatus.Error || CurrentFieldContext?.IsInvalid == true)
			attributes["aria-invalid"] = "true";

		if (ReadOnly)
			attributes["aria-readonly"] = "true";

		return attributes;
	}

	private Dictionary<string, object> BuildTrackAttributes()
	{
		var attributes = new Dictionary<string, object>
		{
			["data-slot"] = "slider-track"
		};

		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "relative grow overflow-hidden rounded-full bg-muted data-[orientation=horizontal]:h-1 data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-1");
		});

		return attributes;
	}

	private Dictionary<string, object> BuildRangeAttributes(IReadOnlyList<double> values)
	{
		var startPercent = values.Count > 1 ? ValueToPercent(values[0]) : 0d;
		var endPercent = ValueToPercent(values[^1]);
		var sizePercent = Math.Max(0d, endPercent - startPercent);

		var attributes = new Dictionary<string, object>
		{
			["data-slot"] = "slider-range"
		};

		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "absolute bg-primary select-none data-[orientation=horizontal]:h-full data-[orientation=vertical]:w-full");
		});

		return attributes;
	}

	private Dictionary<string, object> BuildThumbAttributes(int index, double value)
	{
		var attributes = new Dictionary<string, object>
		{
			["data-slot"] = "slider-thumb"
		};

		if (AutoFocus && index == 0)
			attributes["autofocus"] = true;

		if (index > 0 && Id is not null)
		{
			attributes["id"] = BlazorIdGenerator.Child(Id, index.ToString(CultureInfo.InvariantCulture));
		}

		if (Attributes is not null && index == 0)
		{
			foreach (var attribute in Attributes)
			{
				if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) ||
				    attribute.Key.Equals("style", StringComparison.OrdinalIgnoreCase) ||
				    attribute.Key.Equals("id", StringComparison.OrdinalIgnoreCase))
				{
					continue;
				}

				attributes[attribute.Key] = attribute.Value;
			}
		}

		BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
		{
			AppendClass(ref cls, "relative block");
			AppendClass(ref cls, ThumbSizeClass);
			AppendClass(ref cls, "shrink-0 rounded-full border border-ring bg-white ring-ring/50 transition-[color,box-shadow] select-none after:absolute after:-inset-2 hover:ring-3 focus-visible:ring-3 focus-visible:outline-hidden active:ring-3 disabled:pointer-events-none disabled:opacity-50");
		});

		return attributes;
	}

	private string? ResolveThumbLabel(int index, int totalValues)
	{
		if (!string.IsNullOrWhiteSpace(AriaLabel) || !string.IsNullOrWhiteSpace(AriaLabelledBy))
		{
			if (totalValues == 2)
				return index == 0 ? "Minimum" : "Maximum";

			if (totalValues > 2)
				return $"Value {index + 1} of {totalValues}";

			return null;
		}

		if (totalValues > 2)
			return $"Value {index + 1} of {totalValues}";

		if (totalValues == 2)
			return index == 0 ? "Minimum" : "Maximum";

		return null;
	}

	[JSInvokable]
	public async Task HandlePointerStart(double xFraction, double yFraction, int thumbIndex)
	{
		if (!IsInteractive)
			return;

		_valuesBeforeSlideStart = GetResolvedValues();

		var currentValues = GetResolvedValues();
		var index = thumbIndex >= 0
			? thumbIndex
			: FindNearestThumbIndex(currentValues, GetValueFromFractions(xFraction, yFraction));

		_draggingThumbIndex = index;
		_focusedThumbIndex = index;
		Refresh();

		if (thumbIndex < 0)
			await UpdateValue(index, GetValueFromFractions(xFraction, yFraction), notifyInput: true, notifyChange: false, markTouched: false);
	}

	[JSInvokable]
	public async Task HandlePointerMove(double xFraction, double yFraction)
	{
		if (!IsInteractive || _draggingThumbIndex < 0)
			return;

		_focusedThumbIndex = _draggingThumbIndex;
		await UpdateValue(_draggingThumbIndex, GetValueFromFractions(xFraction, yFraction), notifyInput: true, notifyChange: false, markTouched: false);
	}

	[JSInvokable]
	public async Task HandlePointerEnd()
	{
		if (_draggingThumbIndex < 0)
			return;

		var index = _draggingThumbIndex;
		var currentValues = GetResolvedValues();
		var value = index < currentValues.Length ? currentValues[index] : Min;

		await UpdateValue(index, value, notifyInput: false, notifyChange: true, markTouched: true);
		_draggingThumbIndex = -1;
		_focusedThumbIndex = index;
		Refresh();
	}

	[JSInvokable]
	public async Task HandlePointerCancel()
	{
		if (_draggingThumbIndex < 0)
			return;

		await RestoreValues();
		_draggingThumbIndex = -1;
		Refresh();
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			if (ParentValidation is not null)
			{
				if (ValuesExpression is not null)
					await ParentValidation.InitializeInputExpression(ValuesExpression);
				else if (SliderValueExpression is not null)
					await ParentValidation.InitializeInputExpression(SliderValueExpression);
			}

		}

		await base.OnAfterRenderAsync(firstRender);
	}

	protected override void OnParametersSet()
	{
		var values = GetResolvedValues();

		if (_focusedThumbIndex >= values.Length)
			_focusedThumbIndex = values.Length - 1;

		if (_draggingThumbIndex >= values.Length)
			_draggingThumbIndex = values.Length - 1;

		base.OnParametersSet();
	}

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
	    base.ComputeRenderKeyCore(ref hc);
		hc.Add(SliderValue);
		hc.Add(Min);
		hc.Add(Max);
		hc.Add(Step);
		hc.Add(OrientationValue);

		var values = GetResolvedValues();
		hc.Add(values.Length);

		for (var i = 0; i < values.Length; i++)
		{
			hc.Add(values[i]);
		}

		AddIf(ref hc, SliderSize);
		hc.Add(PlainText);
		hc.Add(FloatingLabel);
		hc.Add(Label);
		hc.Add(Placeholder);
		hc.Add(Disabled);
		hc.Add(ReadOnly);
		hc.Add(Required);
		hc.Add(DirectionProviderDir);
		hc.Add(_focusedThumbIndex);
		hc.Add(_draggingThumbIndex);
	}
}
