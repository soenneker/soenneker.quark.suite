@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISortableItem

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    [Parameter]
    public string? ItemId { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Position ??= Quark.Position.Relative;

        if (Disabled)
        {
            PointerEvents ??= Quark.PointerEvents.None;
        }

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sortable-item";
        attributes["data-sortable-item"] = string.Empty;

        if (!attributes.ContainsKey("role"))
            attributes["role"] = Role ?? "listitem";

        if (ItemId.HasContent())
        {
            attributes["data-sortable-id"] = ItemId!;
        }

        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["aria-disabled"] = "true";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (Disabled)
                AppendClass(ref cls, "opacity-60");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ItemId);
        hc.Add(Disabled);
    }
}
