@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISortableHandle

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        UserSelect ??= Quark.UserSelect.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sortable-handle";
        attributes["data-sortable-handle"] = string.Empty;

        if (!attributes.ContainsKey("aria-label") && AriaLabel is null)
        {
            attributes["aria-label"] = "Drag handle";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "shrink-0 cursor-grab touch-none");
        });
    }
}
