@using Microsoft.JSInterop
@using Soenneker.Blazor.Utils.Ids
@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISortableList

@inject ISortableInterop SortableInterop

<div @ref="ElementRef" @attributes="BuildAttributes()">
    <CascadingValue Value="this" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    private readonly string _listId = BlazorIdGenerator.New("quark-sortable");
    private DotNetObjectReference<SortableList>? _dotNetRef;
    private string? _initializationError;
    private string? _lastInitializationKey;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Sort { get; set; } = true;

    [Parameter]
    public int AnimationMs { get; set; } = 150;

    [Parameter]
    public bool ForceFallback { get; set; } = true;

    [Parameter]
    public string? Group { get; set; }

    [Parameter]
    public bool HandleOnly { get; set; }

    [Parameter]
    public string ItemSelector { get; set; } = "[data-sortable-item]";

    [Parameter]
    public string? HandleSelector { get; set; }

    [Parameter]
    public string? FilterSelector { get; set; }

    [Parameter]
    public EventCallback<SortableReorderEventArgs> OnReorder { get; set; }

    [JSInvokable]
    public async Task HandleReorder(SortableReorderEventArgs args)
    {
        if (args.OldIndex < 0 || args.NewIndex < 0)
        {
            return;
        }

        if (OnReorder.HasDelegate)
        {
            await OnReorder.InvokeAsync(args);
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        FlexDirection ??= Quark.FlexDirection.Col;
        Gap ??= Quark.Gap.Is2;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sortable-list";
        attributes["data-sortable-list-id"] = _listId;
        attributes["data-sortable-keyboard"] = "true";

        if (!attributes.ContainsKey("role"))
        {
            attributes["role"] = Role ?? "list";
        }

        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["aria-disabled"] = "true";
        }

        if (_initializationError is not null)
        {
            attributes["data-sortable-init-error"] = _initializationError;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {

            if (Disabled)
            {
                AppendClass(ref cls, "opacity-80");
            }
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await SortableInterop.Initialize();

            _dotNetRef ??= DotNetObjectReference.Create(this);
            var initializationKey = $"{Disabled}|{Sort}|{AnimationMs}|{ForceFallback}|{ItemSelector}|{ResolveHandleSelector()}|{FilterSelector}|{Group}";

            if (firstRender || !string.Equals(_lastInitializationKey, initializationKey, StringComparison.Ordinal))
            {
                await SortableInterop.InitializeList(ElementRef, Disabled, Sort, AnimationMs, ForceFallback, ItemSelector, ResolveHandleSelector(), FilterSelector,
                    Group, _dotNetRef);
                _lastInitializationKey = initializationKey;
            }

            if (_initializationError is not null)
            {
                _initializationError = null;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            _initializationError = ex.GetType().Name;
            await InvokeAsync(StateHasChanged);
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override async ValueTask OnDisposeAsync()
    {
        try
        {
            await SortableInterop.Destroy(ElementRef);
        }
        catch (Exception ex) when (ex is JSDisconnectedException or InvalidOperationException or TaskCanceledException or ObjectDisposedException)
        {
        }

        _dotNetRef?.Dispose();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(Sort);
        hc.Add(AnimationMs);
        hc.Add(ForceFallback);
        hc.Add(Group);
        hc.Add(HandleOnly);
        hc.Add(ItemSelector);
        hc.Add(HandleSelector);
        hc.Add(FilterSelector);
    }

    private string? ResolveHandleSelector()
    {
        if (HandleSelector is not null)
        {
            return HandleSelector;
        }

        return HandleOnly ? "[data-sortable-handle]" : null;
    }
}
