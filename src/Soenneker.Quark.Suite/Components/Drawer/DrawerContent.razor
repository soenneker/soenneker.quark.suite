@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement
@inject IControlsInterop ControlsInterop

<BradixDialogPortal>
    @if (ParentDrawer?.ShowBackdrop == true)
    {
        <BradixDialogOverlay AdditionalAttributes="@OverlayAttributes" />
    }

    <BradixDialogContent Id="@Context?.ContentId" CloseOnEscapeKeyDown="@ShouldCloseOnEscape" CloseOnPointerDownOutside="@ShouldCloseOnOutsideInteraction" CloseOnFocusOutside="@ShouldCloseOnOutsideInteraction" OnOpenAutoFocusDetailed="HandleOpenAutoFocus" OnPointerDownOutside="HandleBackdropPointerDownOutside" AdditionalAttributes="@ContentAttributes">
        <Div Margin="Quark.Margin.OnX.Auto.FromTop.Is4" Height="Quark.Height.Is1" Width='Quark.Width.Token("[100px]")' Shrink="Quark.Shrink.Is0" Rounded="Quark.Rounded.Full" BackgroundColor="Quark.BackgroundColor.Muted" Display='CssValue<DisplayBuilder>.For(Quark.Display.None, Quark.Display.Block.Modifier("group-data-[vaul-drawer-direction=bottom]/drawer-content"))'></Div>
        @ChildContent
    </BradixDialogContent>
</BradixDialogPortal>

@code {
    private bool _triggerRefocusedForOpen;

    [CascadingParameter(Name = "ParentDrawer")]
    private Drawer? ParentDrawer { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    [Parameter]
    public Side? Side { get; set; }

    private Side ResolvedSide => Side ?? ParentDrawer?.DirectionSide ?? Soenneker.Bradix.Side.Bottom;

    private bool ShouldCloseOnOutsideInteraction =>
        ParentDrawer is not null && !ParentDrawer.Static && ParentDrawer.CloseOnBackdropClick;

    private bool ShouldCloseOnEscape =>
        ParentDrawer is not null && !ParentDrawer.Static && ParentDrawer.CloseOnEscape;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    private IReadOnlyDictionary<string, object> OverlayAttributes => BuildOverlayAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "drawer-content";

        Position ??= Quark.Position.Fixed;
        ZIndex ??= Quark.ZIndex.Z50;
        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Auto;
        FlexDirection ??= Quark.FlexDirection.Col;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-vaul-drawer-direction"] = ResolvedSide.Value;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/drawer-content text-sm text-popover-foreground");
            AppendClass(ref cls, "data-[vaul-drawer-direction=bottom]:inset-x-0 data-[vaul-drawer-direction=bottom]:bottom-0 data-[vaul-drawer-direction=bottom]:mt-24 data-[vaul-drawer-direction=bottom]:max-h-[80vh] data-[vaul-drawer-direction=bottom]:rounded-t-xl data-[vaul-drawer-direction=bottom]:border-t");
            AppendClass(ref cls, "data-[vaul-drawer-direction=left]:inset-y-0 data-[vaul-drawer-direction=left]:left-0 data-[vaul-drawer-direction=left]:w-3/4 data-[vaul-drawer-direction=left]:rounded-r-xl data-[vaul-drawer-direction=left]:border-r");
            AppendClass(ref cls, "data-[vaul-drawer-direction=right]:inset-y-0 data-[vaul-drawer-direction=right]:right-0 data-[vaul-drawer-direction=right]:w-3/4 data-[vaul-drawer-direction=right]:rounded-l-xl data-[vaul-drawer-direction=right]:border-l");
            AppendClass(ref cls, "data-[vaul-drawer-direction=top]:inset-x-0 data-[vaul-drawer-direction=top]:top-0 data-[vaul-drawer-direction=top]:mb-24 data-[vaul-drawer-direction=top]:max-h-[80vh] data-[vaul-drawer-direction=top]:rounded-b-xl data-[vaul-drawer-direction=top]:border-b");
            AppendClass(ref cls, "data-[vaul-drawer-direction=left]:sm:max-w-sm data-[vaul-drawer-direction=right]:sm:max-w-sm");
            AppendClass(ref cls, "data-open:animate-in data-open:fade-in-0 data-[vaul-drawer-direction=bottom]:data-open:slide-in-from-bottom-10 data-[vaul-drawer-direction=left]:data-open:slide-in-from-left-10 data-[vaul-drawer-direction=right]:data-open:slide-in-from-right-10 data-[vaul-drawer-direction=top]:data-open:slide-in-from-top-10");
            AppendClass(ref cls, "data-closed:animate-out data-closed:fade-out-0 data-[vaul-drawer-direction=bottom]:data-closed:slide-out-to-bottom-10 data-[vaul-drawer-direction=left]:data-closed:slide-out-to-left-10 data-[vaul-drawer-direction=right]:data-closed:slide-out-to-right-10 data-[vaul-drawer-direction=top]:data-closed:slide-out-to-top-10");
        });
    }

    private Dictionary<string, object> BuildOverlayAttributes()
    {
        var attrs = new Dictionary<string, object>();
        BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "fixed inset-0 z-50 bg-black/10 supports-backdrop-filter:backdrop-blur-xs data-open:animate-in data-open:fade-in-0 data-closed:animate-out data-closed:fade-out-0");

            if (ParentDrawer?.BlurBackdrop == true)
                AppendClass(ref cls, "backdrop-blur");
        });
        attrs["data-slot"] = "drawer-overlay";
        attrs["aria-hidden"] = "true";
        return attrs;
    }

    private Task HandleBackdropPointerDownOutside()
    {
        return ParentDrawer?.OnBackdropClick.InvokeIfHasDelegate() ?? Task.CompletedTask;
    }

    private async Task HandleOpenAutoFocus(BradixAutoFocusEventArgs args)
    {
        args.PreventDefault();

        if (BradixDialog is not null)
            await BradixDialog.FocusTrigger();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (ParentDrawer?.Visible != true)
        {
            _triggerRefocusedForOpen = false;
            return;
        }

        if (_triggerRefocusedForOpen || BradixDialog is null || string.IsNullOrWhiteSpace(BradixDialog.ResolvedTriggerId))
            return;

        _triggerRefocusedForOpen = true;
        await Task.Delay(150);
        await ControlsInterop.FocusElementById(BradixDialog.ResolvedTriggerId);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(ResolvedSide);
        hc.Add(ParentDrawer?.Visible ?? false);
        hc.Add(ParentDrawer?.ShowBackdrop ?? true);
        hc.Add(ParentDrawer?.BlurBackdrop ?? false);
        hc.Add(ParentDrawer?.TrapFocus ?? true);
        hc.Add(ParentDrawer?.CloseOnEscape ?? true);
        hc.Add(ShouldCloseOnEscape);
        hc.Add(ParentDrawer?.CloseOnBackdropClick ?? true);
        hc.Add(ParentDrawer?.Static ?? false);
        hc.Add(Context?.ContentId);
        hc.Add(BradixDialog?.ResolvedTriggerId);
        hc.Add(_triggerRefocusedForOpen);
    }

}
