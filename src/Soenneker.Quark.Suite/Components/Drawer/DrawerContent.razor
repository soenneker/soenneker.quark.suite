@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement

<BradixDialogPortal>
    @if (ParentDrawer?.ShowBackdrop == true)
    {
        <BradixDialogOverlay AdditionalAttributes="@OverlayAttributes" />
    }

    <BradixDialogContent Id="@Context?.ContentId"
                         CloseOnEscapeKeyDown="@(ParentDrawer?.CloseOnEscape ?? true)"
                         CloseOnPointerDownOutside="@ShouldCloseOnOutsideInteraction"
                         CloseOnFocusOutside="@ShouldCloseOnOutsideInteraction"
                         OnPointerDownOutside="HandleBackdropPointerDownOutside"
                         AdditionalAttributes="@ContentAttributes">
        <div class="mx-auto mt-4 hidden h-2 w-[100px] shrink-0 rounded-full bg-muted group-data-[vaul-drawer-direction=bottom]/drawer-content:block"></div>
        @ChildContent
    </BradixDialogContent>
</BradixDialogPortal>

@code {
    [CascadingParameter(Name = "ParentDrawer")]
    private Drawer? ParentDrawer { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [Parameter]
    public string Direction { get; set; } = "bottom";

    private string Side => Direction.ToLowerInvariant() switch
    {
        "left" => "left",
        "top" => "top",
        "right" => "right",
        _ => "bottom"
    };

    private bool ShouldCloseOnOutsideInteraction =>
        ParentDrawer is not null &&
        !ParentDrawer.Static &&
        ParentDrawer.CloseOnBackdropClick;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    private IReadOnlyDictionary<string, object> OverlayAttributes => BuildOverlayAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "drawer-content";
        attributes["data-direction"] = Side;
        attributes["data-vaul-drawer-direction"] = Side;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/drawer-content fixed z-50 flex h-auto flex-col bg-background");
            AppendClass(ref cls, "data-[vaul-drawer-direction=top]:inset-x-0 data-[vaul-drawer-direction=top]:top-0 data-[vaul-drawer-direction=top]:mb-24 data-[vaul-drawer-direction=top]:max-h-[80vh] data-[vaul-drawer-direction=top]:rounded-b-lg data-[vaul-drawer-direction=top]:border-b");
            AppendClass(ref cls, "data-[vaul-drawer-direction=bottom]:inset-x-0 data-[vaul-drawer-direction=bottom]:bottom-0 data-[vaul-drawer-direction=bottom]:mt-24 data-[vaul-drawer-direction=bottom]:max-h-[80vh] data-[vaul-drawer-direction=bottom]:rounded-t-lg data-[vaul-drawer-direction=bottom]:border-t");
            AppendClass(ref cls, "data-[vaul-drawer-direction=right]:inset-y-0 data-[vaul-drawer-direction=right]:right-0 data-[vaul-drawer-direction=right]:w-3/4 data-[vaul-drawer-direction=right]:border-l data-[vaul-drawer-direction=right]:sm:max-w-sm");
            AppendClass(ref cls, "data-[vaul-drawer-direction=left]:inset-y-0 data-[vaul-drawer-direction=left]:left-0 data-[vaul-drawer-direction=left]:w-3/4 data-[vaul-drawer-direction=left]:border-r data-[vaul-drawer-direction=left]:sm:max-w-sm");
            AppendClass(ref cls, "data-[state=closed]:pointer-events-none data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:duration-300 data-[state=open]:duration-500");
            AppendClass(ref cls, "data-[vaul-drawer-direction=bottom]:data-[state=closed]:slide-out-to-bottom data-[vaul-drawer-direction=bottom]:data-[state=open]:slide-in-from-bottom");
            AppendClass(ref cls, "data-[vaul-drawer-direction=top]:data-[state=closed]:slide-out-to-top data-[vaul-drawer-direction=top]:data-[state=open]:slide-in-from-top");
            AppendClass(ref cls, "data-[vaul-drawer-direction=right]:data-[state=closed]:slide-out-to-right data-[vaul-drawer-direction=right]:data-[state=open]:slide-in-from-right");
            AppendClass(ref cls, "data-[vaul-drawer-direction=left]:data-[state=closed]:slide-out-to-left data-[vaul-drawer-direction=left]:data-[state=open]:slide-in-from-left");
        });
    }

    private Dictionary<string, object> BuildOverlayAttributes()
    {
        var attrs = new Dictionary<string, object>();
        BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "fixed inset-0 z-50 bg-black/50 data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:pointer-events-none");
        });
        attrs["data-state"] = ParentDrawer?.Visible == true ? "open" : "closed";
        attrs["data-slot"] = "drawer-overlay";
        attrs["aria-hidden"] = "true";
        return attrs;
    }

    private Task HandleBackdropPointerDownOutside()
    {
        return ParentDrawer?.OnBackdropClick.InvokeIfHasDelegate() ?? Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Direction);
        hc.Add(ParentDrawer?.Visible ?? false);
        hc.Add(ParentDrawer?.ShowBackdrop ?? true);
        hc.Add(ParentDrawer?.TrapFocus ?? true);
        hc.Add(ParentDrawer?.CloseOnEscape ?? true);
        hc.Add(ParentDrawer?.CloseOnBackdropClick ?? true);
        hc.Add(ParentDrawer?.Static ?? false);
        hc.Add(Context?.ContentId);
    }
}
