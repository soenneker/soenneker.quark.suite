@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement

@if (ParentDrawer?.Visible == true)
{
    @if (Portal)
    {
        <OverlayPortalPublisher Id="@_portalId" UsePortal="true">
            <OverlayPortalShell CascadeOwnerName="@nameof(ParentDrawer)" Owner="ParentDrawer" LabelContext="Context">
                <DrawerContentSurface Direction="@Direction">
                    @ChildContent
                </DrawerContentSurface>
            </OverlayPortalShell>
        </OverlayPortalPublisher>
    }
    else
    {
        <DrawerContentSurface Direction="@Direction">
            @ChildContent
        </DrawerContentSurface>
    }
}

@code {
    [CascadingParameter(Name = nameof(ParentDrawer))]
    private Drawer? ParentDrawer { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private readonly string _portalId = $"q-drawer-portal-{Guid.NewGuid():N}";

    [Parameter]
    public string Direction { get; set; } = "bottom";

    [Parameter]
    public bool Portal { get; set; } = true;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Direction);
        hc.Add(Portal);
        hc.Add(ParentDrawer?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
