@using Soenneker.Bradix
@using Soenneker.Blazor.Utils.Ids

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TriggerElement

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixDialogTrigger Disabled="@Disabled"
                         OnClick="@OnClick"
                         AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixDialogTrigger>
}

@code {
    [CascadingParameter(Name = nameof(ParentDrawer))]
    public Drawer? ParentDrawer { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _elementRef;

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        Display ??= Quark.Display.InlineFlex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Height ??= Quark.Height.Is8;
        Gap ??= Quark.Gap.Token("1.5");
        Padding ??= Quark.Padding.Token("2.5").OnX;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Background;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
        UserSelect ??= Quark.UserSelect.None;

        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "drawer-trigger";
        attributes["data-state"] = ParentDrawer?.Visible == true ? "open" : "closed";
        attributes["aria-haspopup"] = "dialog";
        attributes["aria-expanded"] = ParentDrawer?.Visible == true ? "true" : "false";

        if (Disabled)
            attributes["disabled"] = true;

        if (Context is not null)
            attributes["aria-controls"] = Context.ContentId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/button bg-clip-padding");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50");
            AppendClass(ref cls, "active:not-aria-[haspopup]:translate-y-px");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "border-border hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50");
            AppendClass(ref cls, "has-data-[icon=inline-end]:pr-2 has-data-[icon=inline-start]:pl-2");

            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50 disabled:pointer-events-none disabled:opacity-50");
        });
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("id");
        attributes.Remove("data-state");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("disabled");
        attributes.Remove("onclick");

        return attributes;
    }

    private static string? GetOverlayTriggerId(OverlayLabelContext? context) =>
        context?.ContentId is { } contentId ? BlazorIdGenerator.Child(contentId, "trigger") : null;

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            DataSlot = "drawer-trigger",
            TriggerId = GetOverlayTriggerId(Context),
            ParentDisabled = Disabled,
            IsOpen = ParentDrawer?.Visible == true,
            DataState = ParentDrawer?.Visible == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = Context?.ContentId,
            RegisterElement = elementReference =>
            {
                _elementRef = elementReference;

                if (BradixDialog is not null)
                    BradixDialog.RegisterTrigger(elementReference, GetOverlayTriggerId(Context));
            },
            Toggle = ParentDrawer is null
                ? null
                : async () =>
                {
                    if (ParentDrawer.Visible)
                    {
                        await ParentDrawer.Hide();
                    }
                    else
                    {
                        await ParentDrawer.Show();
                    }
                },
            Open = ParentDrawer is null ? null : async () =>
            {
                await ParentDrawer.Show();
            },
            Close = ParentDrawer is null ? null : () => ParentDrawer.Hide()
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(Disabled);
        hc.Add(ParentDrawer);
        hc.Add(BradixDialog);
        hc.Add(Context);
        hc.Add(ParentDrawer?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
