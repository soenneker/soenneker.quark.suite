@namespace Soenneker.Quark
@inherits Soenneker.Quark.TriggerElement
@using Microsoft.AspNetCore.Components.Web

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <button type="button"
            @onclick="HandleActivate"
            @ref="_elementRef"
            @onkeydown="HandleOverlayDismissKeyDown"
            @onkeydown:preventDefault="_keyPreventDefault"
            @onkeydown:stopPropagation="_keyStopPropagation"
            @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    private bool _keyPreventDefault;
    private bool _keyStopPropagation;

    [CascadingParameter(Name = nameof(ParentDrawer))]
    public Drawer? ParentDrawer { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _elementRef;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "drawer-trigger";
        attributes["data-state"] = ParentDrawer?.Visible == true ? "open" : "closed";
        attributes["aria-haspopup"] = "dialog";
        attributes["aria-expanded"] = ParentDrawer?.Visible == true ? "true" : "false";

        if (Context is not null)
            attributes["id"] = Context.TriggerId;

        if (Disabled)
            attributes["disabled"] = true;

        if (Context is not null && ParentDrawer?.Visible == true)
            attributes["aria-controls"] = Context.ContentId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-drawer-trigger");
            AppendClass(ref cls, "inline-flex cursor-pointer");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = Context?.TriggerId,
            IsOpen = ParentDrawer?.Visible == true,
            DataState = ParentDrawer?.Visible == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = ParentDrawer?.Visible == true ? Context?.ContentId : null,
            OnKeyDown = ParentDrawer is null || Context is null
                ? null
                : e => OverlayTriggerKeyDown.HandleDismissWhenOpen(e, ParentDrawer.Visible, () => ParentDrawer.Hide()),
            RegisterElement = elementReference => _elementRef = elementReference,
            Toggle = ParentDrawer is null
                ? null
                : async () =>
                {
                    if (ParentDrawer.Visible)
                    {
                        await ParentDrawer.Hide();
                    }
                    else
                    {
                        ParentDrawer.SetRestoreFocusTarget(_elementRef);
                        await ParentDrawer.Show();
                    }
                },
            Open = ParentDrawer is null ? null : async () =>
            {
                ParentDrawer.SetRestoreFocusTarget(_elementRef);
                await ParentDrawer.Show();
            },
            Close = ParentDrawer is null ? null : () => ParentDrawer.Hide()
        };
    }

    private async Task HandleOverlayDismissKeyDown(KeyboardEventArgs e)
    {
        _keyPreventDefault = false;
        _keyStopPropagation = false;

        if (Disabled || ParentDrawer is null || Context is null)
            return;

        if ((e.Key == "Escape" || e.Key == "Enter" || e.Key == " ") && ParentDrawer.Visible)
        {
            _keyPreventDefault = true;

            if (e.Key == "Escape")
                _keyStopPropagation = true;

            await ParentDrawer.Hide();
        }
    }

    private async Task HandleActivate(MouseEventArgs args)
    {
        if (!Disabled && ParentDrawer is not null)
        {
            if (ParentDrawer.Visible)
                await ParentDrawer.Hide();
            else
            {
                ParentDrawer.SetRestoreFocusTarget(_elementRef);
                await ParentDrawer.Show();
            }
        }

        await base.HandleClick(args);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(Disabled);
        hc.Add(ParentDrawer?.Visible ?? false);
        hc.Add(Context?.ContentId);
        hc.Add(Context?.TriggerId);
    }
}
