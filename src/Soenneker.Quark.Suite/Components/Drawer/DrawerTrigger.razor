@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement

@if (AsChild)
{
    <span @onclick="HandleActivate"
          @ref="_elementRef"
          @attributes="BuildWrapperAttributes()">
        <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
            @ChildContent
        </CascadingValue>
    </span>
}
else
{
    <button @onclick="HandleActivate"
            @ref="_elementRef"
            @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [CascadingParameter(Name = "ParentDrawer")]
    private Drawer? ParentDrawer { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _elementRef;

    private async Task HandleActivate(MouseEventArgs e)
    {
        if (ParentDrawer is not null)
        {
            ParentDrawer.SetRestoreFocusTarget(_elementRef);
            await ParentDrawer.Show();
        }

        await base.HandleClick(e);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["type"] = "button";
        attributes["data-slot"] = "drawer-trigger";
        attributes["aria-haspopup"] = "dialog";
        attributes["aria-expanded"] = ParentDrawer?.Visible == true ? "true" : "false";

        if (Context is not null)
            attributes["aria-controls"] = Context.ContentId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-drawer-trigger");
            AppendClass(ref cls, "inline-flex cursor-pointer");
        });
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            IsOpen = ParentDrawer?.Visible == true,
            DataState = ParentDrawer?.Visible == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = Context?.ContentId,
            Toggle = ParentDrawer is null
                ? null
                : async () =>
                {
                    if (ParentDrawer.Visible)
                    {
                        await ParentDrawer.Hide();
                    }
                    else
                    {
                        ParentDrawer.SetRestoreFocusTarget(_elementRef);
                        await ParentDrawer.Show();
                    }
                },
            Open = ParentDrawer is null ? null : async () =>
            {
                ParentDrawer.SetRestoreFocusTarget(_elementRef);
                await ParentDrawer.Show();
            },
            Close = ParentDrawer is null ? null : () => ParentDrawer.Hide()
        };
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        attributes["data-slot"] = "drawer-trigger-wrapper";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-drawer-trigger-wrapper inline-flex");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(ParentDrawer?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
