@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

<BradixDialogTitle Id="@Context?.TitleId" AdditionalAttributes="@TitleAttributes">
    @ChildContent
</BradixDialogTitle>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private IReadOnlyDictionary<string, object> TitleAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        TextColor ??= Quark.TextColor.Foreground;
        TextSize ??= Quark.TextSize.Base;
        FontWeight ??= Quark.FontWeight.Medium;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "drawer-title";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "cn-font-heading");
        });

    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.TitleId);
    }
}
