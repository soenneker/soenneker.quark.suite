@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Button Variant="ButtonVariant.Ghost" Size="ButtonSize.Icon" OnClick="HandleClick" @attributes="BuildAttributes()">
    @ChildContent
</Button>

@code {
    [CascadingParameter(Name = "ParentDrawer")]
    private Drawer? ParentDrawer { get; set; }

    protected override async Task HandleClick(MouseEventArgs e)
    {
        await (ParentDrawer?.Hide() ?? Task.CompletedTask);
        await base.HandleClick(e);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "drawer-close";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-drawer-close");
        });
    }
}
