@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (AsChild && AutoClose)
{
    <BradixDialogClose AsChild="true" AriaLabel="@((string?) null)" OnClick="HandleBradixCloseClick">
        <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
            @ChildContent
        </CascadingValue>
    </BradixDialogClose>
}
else if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else if (AutoClose)
{
    <BradixDialogClose OnClick="HandleBradixCloseClick" AdditionalAttributes="@CloseAttributes">
        @ChildContent
    </BradixDialogClose>
}
else
{
    <button type="button" @onclick="HandleNonAutoCloseClick" @attributes="CloseAttributes">
        @ChildContent
    </button>
}

@code {

    [CascadingParameter(Name = "ParentDrawer")]
    private Drawer? ParentDrawer { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public bool AutoClose { get; set; } = true;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private IReadOnlyDictionary<string, object> CloseAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        SetDefaultDataSlot("drawer-close");
    }

    private async Task HandleBradixCloseClick(MouseEventArgs e)
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);
    }

    private async Task HandleNonAutoCloseClick(MouseEventArgs e)
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            DataSlot = "drawer-close",
            OnClick = AutoClose ? null : () => OnClick.InvokeAsync()
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(AutoClose);
        hc.Add(OnClick.HasDelegate);
    }

}
