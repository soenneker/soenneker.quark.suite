@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

<BradixTabsList Loop="@(ParentTabs?.Loop ?? true)"
                AdditionalAttributes="@ListAttributes">
    @ChildContent
</BradixTabsList>

@code {
    [CascadingParameter(Name = nameof(ParentTabs))]
    private Tabs? ParentTabs { get; set; }

    private IReadOnlyDictionary<string, object> ListAttributes => BuildListAttributes();

    private IReadOnlyDictionary<string, object> BuildListAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("aria-orientation");
        attributes.Remove("tabindex");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        Width ??= Quark.Width.IsFit;
        TextColor ??= Quark.TextColor.MutedForeground;

        if (ParentTabs?.TabsListVariant == TabsListVariant.Line)
            Rounded ??= Quark.Rounded.None;
        else
            Rounded ??= Quark.Rounded.Lg;

        if (ParentTabs?.TabsListVariant == TabsListVariant.Default)
            BackgroundColor ??= Quark.BackgroundColor.Muted;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tabs-list";
        attributes["data-variant"] = ParentTabs?.TabsListVariant?.Value ?? TabsListVariant.Default.Value;
        attributes["aria-orientation"] = ParentTabs?.Vertical == true ? "vertical" : "horizontal";
        attributes[ParentTabs?.Vertical == true ? "data-vertical" : "data-horizontal"] = string.Empty;
        attributes["tabindex"] = -1;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/tabs-list inline-flex w-fit items-center justify-center rounded-lg p-[3px] text-muted-foreground data-[variant=line]:rounded-none");
            AppendClass(ref cls, "group-data-horizontal/tabs:h-8 group-data-vertical/tabs:h-fit group-data-vertical/tabs:flex-col");
            if (ParentTabs?.TabsListVariant == TabsListVariant.Default)
                AppendClass(ref cls, "bg-muted");
            if (ParentTabs?.TabsListVariant != TabsListVariant.Default)
                AppendClass(ref cls, "gap-1 bg-transparent");

            if (ParentTabs?.Justified == true)
                AppendClass(ref cls, "w-full [&>[data-slot=tabs-trigger]]:flex-1");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ParentTabs?.Vertical);
        hc.Add(ParentTabs?.Justified);
        hc.Add(ParentTabs?.TabsListVariant);
    }
}
