@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<button @onclick="HandleClick" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @ref="_buttonRef" @attributes="BuildAttributes()">
    @ChildContent
</button>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [CascadingParameter(Name = nameof(ParentTabs))]
    private Tabs? ParentTabs { get; set; }

    private ElementReference _buttonRef;
    private bool _preventDefaultKeys;

    private bool IsActive => ParentTabs?.IsTabSelected(Value) == true;

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender && ParentTabs is not null)
            ParentTabs.RegisterTrigger(this);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["type"] = "button";
        attributes["data-slot"] = "tabs-trigger";
        attributes["data-state"] = IsActive ? "active" : "inactive";
        attributes["role"] = "tab";

        var triggerId = ParentTabs?.GetTriggerId(Value);
        if (triggerId is not null)
            attributes["id"] = triggerId;

        var contentId = ParentTabs?.GetContentId(Value);
        if (contentId is not null)
            attributes["aria-controls"] = contentId;

        attributes["aria-selected"] = IsActive ? "true" : "false";
        attributes["tabindex"] = IsActive ? 0 : -1;

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            attributes["disabled"] = true;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-tabs-trigger");
            AppendClass(ref cls, Tabs.TabsTriggerBaseClass);
        });
    }

    protected override async Task HandleClick(MouseEventArgs args)
    {
        if (!Disabled && ParentTabs is not null && Value.HasContent())
            await ParentTabs.SelectTab(Value!);

        await base.HandleClick(args);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        _preventDefaultKeys = args.Key switch
        {
            "Home" or "End" => true,
            "ArrowLeft" or "ArrowRight" when ParentTabs?.Vertical != true => true,
            "ArrowUp" or "ArrowDown" when ParentTabs?.Vertical == true => true,
            _ => false
        };

        if (_preventDefaultKeys && ParentTabs is not null)
            await ParentTabs.HandleExplicitKeyNavigationAsync(this, args.Key);
    }

    internal async Task FocusAsync()
    {
        await _buttonRef.FocusAsync();
    }

    public override void Dispose()
    {
        ParentTabs?.UnregisterTrigger(this);
        base.Dispose();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(ParentTabs?.ResolvedSelectedTab);
    }
}
