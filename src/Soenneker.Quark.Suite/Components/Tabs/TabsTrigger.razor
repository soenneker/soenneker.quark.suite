@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

<BradixTabsTrigger Value="@ResolvedValue"
                   Disabled="@Disabled"
                   OnMouseDown="HandleBradixMouseDown"
                   OnFocus="HandleBradixFocus"
                   OnKeyDown="HandleBradixKeyDown"
                   AdditionalAttributes="@TriggerAttributes">
    @ChildContent
</BradixTabsTrigger>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [CascadingParameter(Name = nameof(ParentTabs))]
    private Tabs? ParentTabs { get; set; }

    private string ResolvedValue => Value ?? string.Empty;

    private IReadOnlyDictionary<string, object> TriggerAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes());
            attributes.Remove("type");
            attributes.Remove("role");
            attributes.Remove("id");
            attributes.Remove("aria-controls");
            attributes.Remove("aria-selected");
            attributes.Remove("tabindex");
            attributes.Remove("data-state");
            attributes.Remove("disabled");
            attributes.Remove("onfocus");
            attributes.Remove("onkeydown");

            return attributes;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "tabs-trigger";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-tabs-trigger");
            AppendClass(ref cls, Tabs.TabsTriggerBaseClass);
        });
    }

    private Task HandleBradixMouseDown(MouseEventArgs args)
    {
        return base.HandleClick(args);
    }

    private Task HandleBradixFocus(FocusEventArgs args)
    {
        return Task.CompletedTask;
    }

    private Task HandleBradixKeyDown(KeyboardEventArgs args)
    {
        return Task.CompletedTask;
    }

    internal Task FocusAsync()
    {
        return Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(ParentTabs?.Loop);
    }
}
