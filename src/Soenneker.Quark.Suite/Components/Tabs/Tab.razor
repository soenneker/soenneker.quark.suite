@using Soenneker.Bradix

@namespace Soenneker.Quark

@inherits Soenneker.Quark.Element
@implements ITab

<BradixTabsTrigger Value="@ResolvedValue"
                   Disabled="@Disabled"
                   OnMouseDown="HandleClick"
                   AdditionalAttributes="@TriggerAttributes">
    @if (Icon is not null)
    {
        <span data-icon="inline-start">
            <Icon Name="@Icon.Value" />
        </span>
    }
    @if (Title.HasContent())
    {
        @Title
    }
    else
    {
        @ChildContent
    }
</BradixTabsTrigger>

@code {
    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public LucideIcon? Icon { get; set; }

    [Parameter]
    public string? Target { get; set; }

    [Parameter]
    public bool Active { get; set; }

    /// <summary>Radix <c>forceMount</c>: keep panel content mounted when this tab is inactive.</summary>
    [Parameter]
    public bool ForceMount { get; set; }

    [CascadingParameter(Name = nameof(ParentTabs))]
    public Tabs? ParentTabs { get; set; }

    private string ResolvedValue => Name ?? string.Empty;
    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender && ParentTabs is not null)
            ParentTabs.RegisterTab(this);
    }

    public override void Dispose()
    {
        ParentTabs?.UnregisterTab(this);
        base.Dispose();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.InlineFlex;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "tabs-trigger";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, Tabs.TabsTriggerBaseClass);
        });
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("type");
        attributes.Remove("role");
        attributes.Remove("id");
        attributes.Remove("aria-controls");
        attributes.Remove("aria-selected");
        attributes.Remove("tabindex");
        attributes.Remove("data-state");
        attributes.Remove("disabled");
        attributes.Remove("data-disabled");
        attributes.Remove("aria-disabled");
        attributes.Remove("onfocus");
        attributes.Remove("onkeydown");
        attributes.Remove("onmousedown");

        if (Target.HasContent())
            attributes["data-target"] = Target!;

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Name);
        hc.Add(Icon);
        hc.Add(Target);
        hc.Add(Disabled);
        if (ParentTabs?.ResolvedSelectedTab is not null)
            hc.Add(ParentTabs.ResolvedSelectedTab);
        hc.Add(ForceMount);
    }
}
