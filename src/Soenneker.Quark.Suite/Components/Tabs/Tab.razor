@namespace Soenneker.Quark

@inherits Soenneker.Quark.Element
@implements ITab

<button @onclick="HandleClick"
        @onfocus="HandleFocusAsync"
        @onkeydown="HandleKeyDown"
        @onkeydown:preventDefault="_preventDefaultKeys"
        @ref="_buttonRef"
        @attributes="BuildAttributes()">
    @if (Icon is not null)
    {
        <Icon Name="@Icon.Value" />
    }
    @if (Title.HasContent())
    {
        @Title
    }
    else
    {
        @ChildContent
    }
</button>

@code {
    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public LucideIcon? Icon { get; set; }

    [Parameter]
    public string? Target { get; set; }

    [Parameter]
    public bool Active { get; set; }

    /// <summary>Radix <c>forceMount</c>: keep panel content mounted when this tab is inactive.</summary>
    [Parameter]
    public bool ForceMount { get; set; }

    [CascadingParameter(Name = nameof(ParentTabs))]
    public Tabs? ParentTabs { get; set; }

    private ElementReference _buttonRef;
    private bool _preventDefaultKeys;

    private bool IsActive => string.Equals(ParentTabs?.ResolvedSelectedTab, Name, StringComparison.Ordinal);

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        ParentTabs?.RegisterTab(this);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["type"] = "button";
        attributes["data-slot"] = "tabs-trigger";
        attributes["data-state"] = IsActive ? "active" : "inactive";
        attributes["role"] = "tab";

        if (Name.HasContent())
            attributes["id"] = $"tab-trigger-{Name}";

        var targetId = Target ?? (Name.HasContent() ? $"tab-content-{Name}" : null);
        if (targetId is not null)
            attributes["aria-controls"] = targetId;

        attributes["aria-selected"] = IsActive ? "true" : "false";
        attributes["tabindex"] = ParentTabs?.GetTriggerTabIndex(Name, IsActive) ?? (IsActive ? 0 : -1);

        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["aria-disabled"] = "true";
            attributes["disabled"] = true;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-tab q-tabs-trigger");
            AppendClass(ref cls, Tabs.TabsTriggerBaseClass);
        });
    }

    protected override async Task HandleClick(MouseEventArgs args)
    {
        if (!Disabled && ParentTabs != null && Name.HasContent())
            await ParentTabs.SelectTab(Name!);

        await base.HandleClick(args);
    }

    private async Task HandleFocusAsync(FocusEventArgs args)
    {
        if (ParentTabs is null || !Name.HasContent())
            return;

        ParentTabs.NotifyManualRovingFocus(Name!);

        if (Disabled)
            return;

        if (!ParentTabs.IsAutomaticActivation)
            return;

        if (!IsActive)
            await ParentTabs.SelectTab(Name!);
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key is " " or "Enter")
        {
            if (!Disabled && ParentTabs is not null && Name.HasContent())
                await ParentTabs.SelectTab(Name!);

            _preventDefaultKeys = true;
            return;
        }

        _preventDefaultKeys = args.Key switch
        {
            "Home" or "End" => true,
            "ArrowLeft" or "ArrowRight" when ParentTabs?.Vertical != true => true,
            "ArrowUp" or "ArrowDown" when ParentTabs?.Vertical == true => true,
            _ => false
        };

        if (_preventDefaultKeys && ParentTabs is not null)
            await ParentTabs.HandleKeyNavigationAsync(this, args.Key);
    }

    internal async Task FocusAsync()
    {
        await _buttonRef.FocusAsync();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Name);
        hc.Add(Icon);
        hc.Add(Target);
        hc.Add(Disabled);
        if (ParentTabs?.ResolvedSelectedTab is not null)
            hc.Add(ParentTabs.ResolvedSelectedTab);
        hc.Add(ParentTabs?.ActivationMode);
        hc.Add(ForceMount);
    }
}
