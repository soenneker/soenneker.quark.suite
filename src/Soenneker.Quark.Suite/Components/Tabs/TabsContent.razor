@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @if (IsActive || ForceMount)
    {
        @ChildContent
    }
</div>

@code {
    [Parameter]
    public string? Value { get; set; }

    /// <summary>Radix <c>forceMount</c>: keep panel content in the tree even when inactive (e.g. animations).</summary>
    [Parameter]
    public bool ForceMount { get; set; }

    [CascadingParameter(Name = nameof(ParentTabs))]
    private Tabs? ParentTabs { get; set; }

    private bool IsActive => ParentTabs?.IsTabSelected(Value) == true;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tabs-content";
        attributes["data-state"] = IsActive ? "active" : "inactive";
        attributes["data-orientation"] = ParentTabs?.Vertical == true ? "vertical" : "horizontal";
        attributes["role"] = "tabpanel";
        attributes["tabindex"] = IsActive ? 0 : -1;

        if (!IsActive)
            attributes["hidden"] = true;

        var contentId = ParentTabs?.GetContentId(Value);
        if (contentId is not null)
            attributes["id"] = contentId;

        var triggerId = ParentTabs?.GetTriggerId(Value);
        if (triggerId is not null)
            attributes["aria-labelledby"] = triggerId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-tabs-content flex-1 text-sm outline-none");
            if (ParentTabs?.Vertical == true)
                AppendClass(ref cls, "min-w-0");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(IsActive);
        hc.Add(ParentTabs?.Vertical);
        hc.Add(ParentTabs?.ActivationMode);
        hc.Add(ForceMount);
    }
}
