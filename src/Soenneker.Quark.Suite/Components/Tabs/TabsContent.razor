@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element

<BradixTabsContent Value="@ResolvedValue"
                   ForceMount="@ForceMount"
                   AdditionalAttributes="@ContentAttributes">
    @ChildContent
</BradixTabsContent>

@code {
    [Parameter]
    public string? Value { get; set; }

    /// <summary>Radix <c>forceMount</c>: keep panel content in the tree even when inactive (e.g. animations).</summary>
    [Parameter]
    public bool ForceMount { get; set; }

    [CascadingParameter(Name = nameof(ParentTabs))]
    private Tabs? ParentTabs { get; set; }

    private string ResolvedValue => Value ?? string.Empty;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("role");
        attributes.Remove("tabindex");
        attributes.Remove("hidden");
        attributes.Remove("id");
        attributes.Remove("aria-labelledby");
        attributes.Remove("data-state");
        attributes.Remove("data-orientation");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Flex ??= Quark.Flex.Is1;
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tabs-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "outline-none");
            if (ParentTabs?.Vertical == true)
                AppendClass(ref cls, "min-w-0");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(ParentTabs?.Vertical);
        hc.Add(ForceMount);
    }
}
