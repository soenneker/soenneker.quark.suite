@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ITabs

<CascadingValue Name="ParentTabs" Value="this">
    <div @attributes="BuildAttributes()">
        @if (Composed)
        {
            @ChildContent
        }
        else if (Vertical)
        {
            <div class="grid grid-cols-[auto_1fr] gap-4">
                <div role="tablist" class="group/tabs-list shrink-0" @attributes="BuildTabsListAttributes()">
                    @ChildContent
                </div>
                <div class="min-w-0 flex-1">
                    @foreach (var tab in _tabs)
                    {
                        <div @attributes="BuildTabContentAttributes(tab)">
                            @if (string.Equals(tab.Name, ResolvedSelectedTab, StringComparison.Ordinal) || tab.ForceMount)
                            {
                                @tab.ChildContent
                            }
                        </div>
                    }
                </div>
            </div>
        }
        else
        {
            <div role="tablist" class="group/tabs-list w-fit" @attributes="BuildTabsListAttributes()">
                @ChildContent
            </div>
            @foreach (var tab in _tabs)
            {
                <div @attributes="BuildTabContentAttributes(tab)">
                    @if (string.Equals(tab.Name, ResolvedSelectedTab, StringComparison.Ordinal) || tab.ForceMount)
                    {
                        @tab.ChildContent
                    }
                </div>
            }
        }
    </div>
</CascadingValue>

@code {
    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    [Parameter]
    public bool Pills { get; set; }

    [Parameter]
    public bool Vertical { get; set; }

    [Parameter]
    public bool Justified { get; set; }

    [Parameter]
    public bool Composed { get; set; }

    /// <summary>Radix <c>activationMode</c>; default <see cref="TabsActivationMode.Automatic"/> (select on focus).</summary>
    [Parameter]
    public TabsActivationMode ActivationMode { get; set; } = TabsActivationMode.Automatic;

    /// <summary>Radix <c>loop</c>; when <c>false</c>, arrow navigation does not wrap at the ends.</summary>
    [Parameter]
    public bool Loop { get; set; } = true;

    /// <summary>HTML <c>dir</c> on the tabs root; falls back to <c>DirectionProviderDir</c>.</summary>
    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public string? SelectedTab { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectedTabChanged { get; set; }

    [Parameter]
    public TabsListVariant TabsListVariant { get; set; } = TabsListVariant.Default;

    /// <summary>Accessible name for the tab list (APG). Ignored if <see cref="TabListAriaLabelledBy"/> is set.</summary>
    [Parameter]
    public string? TabListAriaLabel { get; set; }

    /// <summary>ID(s) of element(s) that label the tab list. Takes precedence over <see cref="TabListAriaLabel"/>.</summary>
    [Parameter]
    public string? TabListAriaLabelledBy { get; set; }

    private readonly List<Tab> _tabs = [];
    private readonly List<TabsTrigger> _explicitTriggers = [];

    /// <summary>Manual activation: which trigger has keyboard roving focus (Radix roving tabindex).</summary>
    private string? _manualRovingFocusValue;

    internal string? ResolvedSelectedTab => GetResolvedSelectedTab();

    /// <summary>
    /// Clears tab and explicit trigger order before children re-register in DOM order each render.
    /// </summary>
    protected override void OnParametersSet()
    {
        _tabs.Clear();
        _explicitTriggers.Clear();
        base.OnParametersSet();
    }

    internal const string TabsTriggerBaseClass =
        "relative inline-flex h-[calc(100%-1px)] flex-1 items-center justify-center gap-1.5 rounded-md border border-transparent px-2 py-1 text-sm font-medium whitespace-nowrap text-foreground/60 transition-all " +
        "group-data-[orientation=vertical]/tabs:w-full group-data-[orientation=vertical]/tabs:justify-start hover:text-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:outline-1 focus-visible:outline-ring " +
        "disabled:pointer-events-none disabled:opacity-50 group-data-[variant=default]/tabs-list:data-[state=active]:shadow-sm group-data-[variant=line]/tabs-list:data-[state=active]:shadow-none dark:text-muted-foreground dark:hover:text-foreground " +
        "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 " +
        "group-data-[variant=line]/tabs-list:bg-transparent group-data-[variant=line]/tabs-list:data-[state=active]:bg-transparent dark:group-data-[variant=line]/tabs-list:data-[state=active]:border-transparent dark:group-data-[variant=line]/tabs-list:data-[state=active]:bg-transparent " +
        "data-[state=active]:bg-background data-[state=active]:text-foreground dark:data-[state=active]:border-input dark:data-[state=active]:bg-input/30 dark:data-[state=active]:text-foreground " +
        "after:absolute after:bg-foreground after:opacity-0 after:transition-opacity group-data-[orientation=horizontal]/tabs:after:inset-x-0 group-data-[orientation=horizontal]/tabs:after:bottom-[-5px] group-data-[orientation=horizontal]/tabs:after:h-0.5 group-data-[orientation=vertical]/tabs:after:inset-y-0 group-data-[orientation=vertical]/tabs:after:-right-1 group-data-[orientation=vertical]/tabs:after:w-0.5 group-data-[variant=line]/tabs-list:data-[state=active]:after:opacity-100";

    public void RegisterTab(Tab tab)
    {
        if (_tabs.Contains(tab))
            return;

        _tabs.Add(tab);
    }

    internal void RegisterTrigger(TabsTrigger trigger)
    {
        if (_explicitTriggers.Contains(trigger))
            return;

        _explicitTriggers.Add(trigger);
    }

    private string? GetResolvedSelectedTab()
    {
        if (SelectedTab.HasContent())
        {
            if (Composed)
            {
                var matchingTrigger = _explicitTriggers.FirstOrDefault(t => !t.Disabled && string.Equals(t.Value, SelectedTab, StringComparison.Ordinal));
                if (matchingTrigger is not null)
                    return matchingTrigger.Value;

                return SelectedTab;
            }

            var matchingTab = _tabs.FirstOrDefault(t => !t.Disabled && string.Equals(t.Name, SelectedTab, StringComparison.Ordinal));
            if (matchingTab is not null)
                return matchingTab.Name;
        }

        if (Composed)
            return _explicitTriggers.FirstOrDefault(t => !t.Disabled && t.Value.HasContent())?.Value;

        return _tabs.FirstOrDefault(t => !t.Disabled && t.Name.HasContent())?.Name;
    }

    private bool IsHorizontalRtl()
    {
        if (Vertical)
            return false;

        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    internal bool IsAutomaticActivation =>
        string.Equals(ActivationMode?.Value, TabsActivationMode.Automatic.Value, StringComparison.Ordinal);

    internal void NotifyManualRovingFocus(string? value)
    {
        if (IsAutomaticActivation || !value.HasContent())
            return;

        if (string.Equals(_manualRovingFocusValue, value, StringComparison.Ordinal))
            return;

        _manualRovingFocusValue = value;
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>Radix: in manual mode, tabindex 0 follows roving focus; otherwise selected tab.</summary>
    internal int GetTriggerTabIndex(string? value, bool isSelected)
    {
        if (!value.HasContent())
            return -1;

        if (IsAutomaticActivation)
            return isSelected ? 0 : -1;

        if (_manualRovingFocusValue.HasContent())
            return string.Equals(_manualRovingFocusValue, value, StringComparison.Ordinal) ? 0 : -1;

        return isSelected ? 0 : -1;
    }

    internal async Task HandleKeyNavigationAsync(Tab currentTab, string key)
    {
        if (_tabs.Count == 0)
            return;

        var enabledTabs = _tabs.Where(t => !t.Disabled && t.Name.HasContent()).ToList();
        if (enabledTabs.Count == 0)
            return;

        var currentIndex = enabledTabs.FindIndex(t => ReferenceEquals(t, currentTab));
        if (currentIndex < 0)
            return;

        var nextIndex = ResolveNextIndex(enabledTabs.Count, currentIndex, key);
        if (nextIndex < 0)
            return;

        var targetTab = enabledTabs[nextIndex];
        if (!targetTab.Name.HasContent())
            return;

        // Radix: arrow keys only move roving focus; automatic mode selects via trigger @onfocus.
        await targetTab.FocusAsync();
    }

    internal async Task HandleExplicitKeyNavigationAsync(TabsTrigger currentTrigger, string key)
    {
        if (_explicitTriggers.Count == 0)
            return;

        var enabledTriggers = _explicitTriggers.Where(t => !t.Disabled && t.Value.HasContent()).ToList();
        if (enabledTriggers.Count == 0)
            return;

        var currentIndex = enabledTriggers.FindIndex(t => ReferenceEquals(t, currentTrigger));
        if (currentIndex < 0)
            return;

        var nextIndex = ResolveNextIndex(enabledTriggers.Count, currentIndex, key);
        if (nextIndex < 0)
            return;

        var targetTrigger = enabledTriggers[nextIndex];
        if (!targetTrigger.Value.HasContent())
            return;

        await targetTrigger.FocusAsync();
    }

    private int ResolveNextIndex(int count, int currentIndex, string key)
    {
        return key switch
        {
            "Home" => 0,
            "End" => count - 1,
            "ArrowRight" when !Vertical && IsHorizontalRtl() => MoveTabIndexPrev(currentIndex, count),
            "ArrowLeft" when !Vertical && IsHorizontalRtl() => MoveTabIndexNext(currentIndex, count),
            "ArrowRight" when !Vertical => MoveTabIndexNext(currentIndex, count),
            "ArrowLeft" when !Vertical => MoveTabIndexPrev(currentIndex, count),
            "ArrowDown" when Vertical => MoveTabIndexNext(currentIndex, count),
            "ArrowUp" when Vertical => MoveTabIndexPrev(currentIndex, count),
            _ => -1
        };
    }

    private int MoveTabIndexNext(int currentIndex, int count)
    {
        if (currentIndex >= count - 1)
            return Loop ? 0 : -1;

        return currentIndex + 1;
    }

    private int MoveTabIndexPrev(int currentIndex, int count)
    {
        if (currentIndex <= 0)
            return Loop ? count - 1 : -1;

        return currentIndex - 1;
    }

    public async Task SelectTab(string tabName)
    {
        if (SelectedTab == tabName)
            return;

        SelectedTab = tabName;

        if (!IsAutomaticActivation && tabName.HasContent())
            _manualRovingFocusValue = tabName;

        if (OnSelectedTabChanged.HasDelegate)
            await OnSelectedTabChanged.InvokeAsync(tabName);

        InvalidateRender();
        Refresh();
    }

    internal bool IsTabSelected(string? value)
    {
        return string.Equals(ResolvedSelectedTab, value, StringComparison.Ordinal);
    }

    internal string? GetTriggerId(string? value)
    {
        return value.HasContent() ? $"tab-trigger-{value}" : null;
    }

    internal string? GetContentId(string? value)
    {
        return value.HasContent() ? $"tab-content-{value}" : null;
    }

    private Dictionary<string, object> BuildTabsListAttributes()
    {
        var attrs = new Dictionary<string, object>
        {
            ["data-slot"] = "tabs-list",
            ["data-variant"] = TabsListVariant?.Value ?? Soenneker.Quark.TabsListVariant.Default.Value,
            ["aria-orientation"] = Vertical ? "vertical" : "horizontal",
            ["tabindex"] = -1
        };

        if (TabListAriaLabelledBy.HasContent())
            attrs["aria-labelledby"] = TabListAriaLabelledBy!;
        else if (TabListAriaLabel.HasContent())
            attrs["aria-label"] = TabListAriaLabel!;

        BuildClassAttribute(attrs, (ref cls) =>
        {
            AppendClass(ref cls, "q-tabs-list inline-flex w-fit items-center justify-center rounded-lg p-[3px] text-muted-foreground");
            AppendClass(ref cls, Vertical ? "h-fit flex-col" : "h-9");

            if (TabsListVariant == TabsListVariant.Default)
                AppendClass(ref cls, "bg-muted");
            else
                AppendClass(ref cls, "gap-1 rounded-none bg-transparent");

            if (Justified)
                AppendClass(ref cls, "w-full [&>[data-slot=tabs-trigger]]:flex-1");
        });

        return attrs;
    }

    private Dictionary<string, object> BuildTabContentAttributes(Tab tab)
    {
        var attributes = new Dictionary<string, object>();
        var isActive = string.Equals(tab.Name, ResolvedSelectedTab, StringComparison.Ordinal);

        attributes["data-slot"] = "tabs-content";
        attributes["data-state"] = isActive ? "active" : "inactive";
        attributes["data-orientation"] = Vertical ? "vertical" : "horizontal";
        attributes["role"] = "tabpanel";
        attributes["tabindex"] = isActive ? 0 : -1;
        attributes["aria-hidden"] = isActive ? "false" : "true";

        if (!isActive)
        {
            attributes["hidden"] = true;
            attributes["inert"] = true;
        }

        if (tab.Name.HasContent())
        {
            attributes["id"] = $"tab-content-{tab.Name}";
            attributes["aria-labelledby"] = $"tab-trigger-{tab.Name}";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-tabs-content flex-1 outline-none");
            if (Vertical)
                AppendClass(ref cls, "min-w-0");
        });

        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "tabs";
        attributes["data-orientation"] = Vertical ? "vertical" : "horizontal";

        var resolvedDir = Dir.HasContent() ? Dir : DirectionProviderDir;
        if (resolvedDir.HasContent())
            attributes["dir"] = resolvedDir!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-tabs group/tabs flex gap-2 data-[orientation=horizontal]:flex-col");
            AppendClass(ref cls, Vertical ? "flex-row" : "flex-col");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Pills);
        hc.Add(Vertical);
        hc.Add(Justified);
        hc.Add(Composed);
        hc.Add(ActivationMode);
        hc.Add(Loop);
        hc.Add(Dir);
        hc.Add(DirectionProviderDir);
        hc.Add(_manualRovingFocusValue);
        hc.Add(TabsListVariant);
        hc.Add(TabListAriaLabel);
        hc.Add(TabListAriaLabelledBy);
        if (SelectedTab is not null)
            hc.Add(SelectedTab);
        if (ResolvedSelectedTab is not null)
            hc.Add(ResolvedSelectedTab);
        hc.Add(_tabs.Count);
        hc.Add(_explicitTriggers.Count);
    }
}
