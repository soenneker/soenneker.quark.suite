@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element
@implements ITabs

<CascadingValue Name="ParentTabs" Value="this">
    <BradixTabs Value="@SelectedTab" Orientation="@ResolvedOrientation" Dir="@ResolvedDir" ActivationMode="@ActivationMode" ValueChanged="HandleBradixValueChanged" AdditionalAttributes="@RootAttributes">
        @ChildContent
    </BradixTabs>
</CascadingValue>

@code {

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    /// <summary>
    /// Legacy compatibility alias for the shadcn default tab-list style. shadcn v4 does not expose a separate pills variant.
    /// </summary>
    [Parameter]
    public bool Pills { get; set; }

    [Parameter]
    public bool Vertical { get; set; }

    [Parameter]
    public bool Justified { get; set; }

    /// <summary>Radix <c>activationMode</c>; default <see cref="TabsActivationMode.Automatic"/> (select on focus).</summary>
    [Parameter]
    public TabsActivationMode ActivationMode { get; set; } = TabsActivationMode.Automatic;

    /// <summary>Radix <c>loop</c>; when <c>false</c>, arrow navigation does not wrap at the ends.</summary>
    [Parameter]
    public bool Loop { get; set; } = true;

    /// <summary>HTML <c>dir</c> on the tabs root; falls back to <c>DirectionProviderDir</c>.</summary>
    [Parameter]
    public string? Dir { get; set; }

    [Parameter]
    public string? SelectedTab { get; set; }

    [Parameter]
    public EventCallback<string> OnSelectedTabChanged { get; set; }

    [Parameter]
    public TabsListVariant TabsListVariant { get; set; } = TabsListVariant.Default;

    internal string? ResolvedDir => Dir.HasContent() ? Dir : DirectionProviderDir;
    private Orientation ResolvedOrientation => Vertical ? Orientation.Vertical : Orientation.Horizontal;
    private IReadOnlyDictionary<string, object> RootAttributes => BuildRootAttributes();

    internal string TabsTriggerBaseClass => BuildTabsTriggerBaseClass();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "tabs";
        Display ??= Quark.Display.Flex;
        FlexDirection ??= Vertical ? Quark.FlexDirection.Row : Quark.FlexDirection.Col;
        Gap ??= Quark.Gap.Is2;
    }

    public async Task SelectTab(string tabName)
    {
        if (SelectedTab == tabName)
            return;

        SelectedTab = tabName;

        if (OnSelectedTabChanged.HasDelegate)
            await OnSelectedTabChanged.InvokeAsync(tabName);

        InvalidateRender();
        Refresh();
    }

    private IReadOnlyDictionary<string, object> BuildRootAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-orientation");
        attributes.Remove("dir");
        return attributes;
    }

    private async Task HandleBradixValueChanged(string? value)
    {
        if (string.Equals(SelectedTab, value, StringComparison.Ordinal))
            return;

        SelectedTab = value;

        if (value is not null && OnSelectedTabChanged.HasDelegate)
            await OnSelectedTabChanged.InvokeAsync(value);

        InvalidateRender();
        Refresh();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-orientation"] = Vertical ? "vertical" : "horizontal";

        if (ResolvedDir.HasContent())
            attributes["dir"] = ResolvedDir!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/tabs data-horizontal:flex-col");
        });
    }

    private string BuildTabsTriggerBaseClass()
    {
        var iconPaddingClass = string.Equals(ResolvedDir, "rtl", StringComparison.OrdinalIgnoreCase)
            ? "has-data-[icon=inline-end]:pe-1 has-data-[icon=inline-start]:ps-1"
            : "has-data-[icon=inline-end]:pr-1 has-data-[icon=inline-start]:pl-1";

        var verticalIndicatorClass = string.Equals(ResolvedDir, "rtl", StringComparison.OrdinalIgnoreCase)
            ? "group-data-vertical/tabs:after:-end-1"
            : "group-data-vertical/tabs:after:-right-1";

        return "relative inline-flex h-[calc(100%-1px)] flex-1 items-center justify-center gap-1.5 rounded-md border border-transparent px-1.5 py-0.5 text-sm font-medium whitespace-nowrap text-foreground/60 transition-all " +
               "group-data-vertical/tabs:w-full group-data-vertical/tabs:justify-start hover:text-foreground focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:outline-1 focus-visible:outline-ring " +
               $"disabled:pointer-events-none disabled:opacity-50 {iconPaddingClass} dark:text-muted-foreground dark:hover:text-foreground " +
               "group-data-[variant=default]/tabs-list:data-active:shadow-sm group-data-[variant=line]/tabs-list:data-active:shadow-none [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 " +
               "group-data-[variant=line]/tabs-list:bg-transparent group-data-[variant=line]/tabs-list:data-active:bg-transparent dark:group-data-[variant=line]/tabs-list:data-active:border-transparent dark:group-data-[variant=line]/tabs-list:data-active:bg-transparent " +
               "data-active:bg-background data-active:text-foreground dark:data-active:border-input dark:data-active:bg-input/30 dark:data-active:text-foreground " +
               $"after:absolute after:bg-foreground after:opacity-0 after:transition-opacity group-data-horizontal/tabs:after:inset-x-0 group-data-horizontal/tabs:after:bottom-[-5px] group-data-horizontal/tabs:after:h-0.5 group-data-vertical/tabs:after:inset-y-0 {verticalIndicatorClass} group-data-vertical/tabs:after:w-0.5 group-data-[variant=line]/tabs-list:data-active:after:opacity-100";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Pills);
        hc.Add(Vertical);
        hc.Add(Justified);
        hc.Add(ActivationMode);
        hc.Add(Loop);
        hc.Add(Dir);
        hc.Add(DirectionProviderDir);
        hc.Add(TabsListVariant);
        if (SelectedTab is not null)
            hc.Add(SelectedTab);
    }

}
