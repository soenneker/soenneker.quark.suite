@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Span Attributes="@BuildAttributes()">
    @if (Pulse)
    {
        <Span DataSlot="pill-indicator-pulse"
              Position="Quark.Position.Absolute"
              Inset="Quark.Inset.Is0"
              Rounded="Quark.Rounded.Full"
              BackgroundColor="@GetBackgroundColor()"
              Animation="Quark.Animation.Ping"
              Opacity="Quark.Opacity.Is75"></Span>
    }
</Span>

@code {
    [Parameter]
    public PillIndicatorVariant Variant { get; set; } = PillIndicatorVariant.Success;

    [Parameter]
    public bool Pulse { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "pill-indicator";
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.InlineFlex;
        Size ??= Quark.Size.Is2;
        Shrink ??= Quark.Shrink.Is0;
        Rounded ??= Quark.Rounded.Full;
        BackgroundColor ??= GetBackgroundColor();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-variant"] = GetVariantValue();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(Pulse);
    }

    private string GetVariantValue()
    {
        if (ReferenceEquals(Variant, PillIndicatorVariant.Error))
            return "error";
        if (ReferenceEquals(Variant, PillIndicatorVariant.Warning))
            return "warning";
        if (ReferenceEquals(Variant, PillIndicatorVariant.Info))
            return "info";
        if (ReferenceEquals(Variant, PillIndicatorVariant.Neutral))
            return "neutral";

        return "success";
    }

    private CssValue<BackgroundColorBuilder> GetBackgroundColor()
    {
        if (ReferenceEquals(Variant, PillIndicatorVariant.Error))
            return Quark.BackgroundColor.Utility("bg-red-500");
        if (ReferenceEquals(Variant, PillIndicatorVariant.Warning))
            return Quark.BackgroundColor.Utility("bg-amber-500");
        if (ReferenceEquals(Variant, PillIndicatorVariant.Info))
            return Quark.BackgroundColor.Utility("bg-blue-500");
        if (ReferenceEquals(Variant, PillIndicatorVariant.Neutral))
            return Quark.BackgroundColor.Utility("bg-muted-foreground");

        return Quark.BackgroundColor.Utility("bg-green-500");
    }
}
