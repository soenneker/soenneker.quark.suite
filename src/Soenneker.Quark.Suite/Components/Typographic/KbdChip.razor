@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IKbdChip

<kbd @attributes="BuildAttributes()">@ChildContent</kbd>

@code {

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "kbd-chip";

        Display ??= Quark.Display.InlineFlex;
        Rounded ??= Quark.Rounded.Default;
        Border ??= Quark.Border.Is1;
        TextSize ??= Quark.TextSize.Xs;
        FontFamily ??= Quark.FontFamily.Mono;
        BackgroundColor ??= Quark.BackgroundColor.Muted;
        TextColor ??= Quark.TextColor.Foreground;
        ItemsAlign ??= Items.Center;
        Padding ??= Quark.Padding.OnX.Is1_5.OnY.Token("0.5");
    }

}
