@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IKbdChip

<kbd @attributes="BuildAttributes()">@ChildContent</kbd>

@code {

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        Rounded ??= Quark.Rounded.Default;
        Border ??= Quark.Border.Is1;
        TextSize ??= Quark.TextSize.Xs;
        FontFamily ??= Quark.FontFamily.Mono;
        BackgroundColor ??= Quark.BackgroundColor.Muted;
        TextColor ??= Quark.TextColor.Foreground;
        ItemsAlign ??= Quark.Items.Center;
        Padding ??= Quark.Padding.Token("1.5").OnX.Token("0.5").OnY;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "kbd-chip";
    }

}