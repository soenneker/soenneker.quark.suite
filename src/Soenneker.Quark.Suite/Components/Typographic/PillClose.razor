@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<button type="button" @onclick="OnClick" @attributes="BuildAttributes()">
    <Icon Name="LucideIcon.X" Size="Quark.Size.Is3" aria-hidden="true" />
    <Span ScreenReader="Quark.ScreenReader.Only">@Label</Span>
</button>

@code {
    [Parameter]
    public string Label { get; set; } = "Remove";

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "pill-close";
        Display ??= Quark.Display.InlineFlex;
        Size ??= Quark.Size.Is5;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Full;
        TextColor ??= Quark.TextColor.MutedForeground.OnHover.Foreground;
        BackgroundColor ??= Quark.BackgroundColor.OnHover.Muted;
        Transition ??= Quark.Transition.Colors;
        OutlineStyle ??= Quark.OutlineStyle.None;
        Ring ??= Quark.Ring.Is2.OnFocusVisible;
        RingColor ??= Quark.RingColor.Ring.OnFocusVisible;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(OnClick.HasDelegate);
    }
}
