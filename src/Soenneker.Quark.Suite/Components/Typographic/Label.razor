@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.TypographyElement
@implements ILabel

<BradixLabel For="@For"
             OnMouseDown="@OnMouseDown"
             AdditionalAttributes="@BuildAttributes()">
    @ChildContent
</BradixLabel>

@code {
    [CascadingParameter(Name = SlotAttributes.Name)]
    private IReadOnlyDictionary<string, object>? SlotAttributeOverrides { get; set; }

    /// <summary>
    /// Gets or sets the for attribute, which associates the label with a form control.
    /// </summary>
    [Parameter]
    public string? For { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnMouseDown { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        FontWeight ??= Quark.FontWeight.Medium;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        TextSize ??= Quark.TextSize.Sm;
        Leading ??= Quark.Leading.None;
        UserSelect ??= Quark.UserSelect.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "label";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:cursor-not-allowed peer-disabled:opacity-50");
        });

        SlotAttributes.MergeInto(attributes, SlotAttributeOverrides);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(For);
        hc.Add(OnMouseDown.HasDelegate);
        hc.Add(SlotAttributeOverrides?.Count ?? 0);
    }
}
