@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements ILabel

<label @attributes="BuildAttributes()">@ChildContent</label>

@code {
    [CascadingParameter(Name = SlotAttributes.Name)]
    private IReadOnlyDictionary<string, object>? SlotAttributeOverrides { get; set; }

    /// <summary>
    /// Gets or sets the for attribute, which associates the label with a form control.
    /// </summary>
    [Parameter]
    public string? For { get; set; }


    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "label";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-label");
            AppendClass(ref cls, "flex items-center gap-2 text-sm leading-none font-medium select-none group-data-[disabled=true]:pointer-events-none group-data-[disabled=true]:opacity-50 peer-disabled:cursor-not-allowed peer-disabled:opacity-50");
        });

        if (For.HasContent())
            attributes["for"] = For;

        SlotAttributes.MergeInto(attributes, SlotAttributeOverrides);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(For);
        hc.Add(SlotAttributeOverrides?.Count ?? 0);
    }
}