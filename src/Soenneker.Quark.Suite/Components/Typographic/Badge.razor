@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IBadge

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <span @attributes="BuildAttributes()">@ChildContent</span>
}

@code {
    private const string _shadcnBadgeBase =
        "group/badge inline-flex h-5 w-fit shrink-0 items-center justify-center gap-1 overflow-hidden rounded-4xl border px-2 py-0.5 text-xs font-medium whitespace-nowrap transition-all focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 has-data-[icon=inline-end]:pe-1.5 has-data-[icon=inline-start]:ps-1.5 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&>svg]:pointer-events-none [&>svg]:size-3!";

    /// <summary>
    /// Gets or sets the visual style variant (shadcn/ui).
    /// </summary>
    [Parameter]
    public BadgeVariant Variant { get; set; } = BadgeVariant.Default;

    [Parameter]
    public bool AsChild { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        SetDefaultDataSlot("badge");
        attributes["data-variant"] = GetDataVariant(Variant);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, _shadcnBadgeBase);
            AppendClass(ref cls, GetBadgeVariantClass(Variant));
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(AsChild);
    }

    private static string GetDataVariant(BadgeVariant? variant)
    {
        if (ReferenceEquals(variant, BadgeVariant.Secondary))
            return "secondary";

        if (ReferenceEquals(variant, BadgeVariant.Destructive))
            return "destructive";

        if (ReferenceEquals(variant, BadgeVariant.Outline))
            return "outline";

        if (ReferenceEquals(variant, BadgeVariant.Ghost))
            return "ghost";

        if (ReferenceEquals(variant, BadgeVariant.Link))
            return "link";

        return "default";
    }

    private string GetBadgeVariantClass(BadgeVariant? variant)
    {
        if (ReferenceEquals(variant, BadgeVariant.Secondary))
            return "border-transparent bg-secondary text-secondary-foreground [a]:hover:bg-secondary/80";

        if (ReferenceEquals(variant, BadgeVariant.Destructive))
            return "border-transparent bg-destructive/10 text-destructive focus-visible:ring-destructive/20 dark:bg-destructive/20 dark:focus-visible:ring-destructive/40 [a]:hover:bg-destructive/20";

        if (ReferenceEquals(variant, BadgeVariant.Outline))
            return "border-border text-foreground [a]:hover:bg-muted [a]:hover:text-muted-foreground";

        if (ReferenceEquals(variant, BadgeVariant.Ghost))
            return "border-transparent hover:bg-muted hover:text-muted-foreground dark:hover:bg-muted/50";

        if (ReferenceEquals(variant, BadgeVariant.Link))
            return "border-transparent text-primary underline-offset-4 [a]:hover:underline";

        return "border-transparent bg-primary text-primary-foreground [a]:hover:bg-primary/80";
    }
}
