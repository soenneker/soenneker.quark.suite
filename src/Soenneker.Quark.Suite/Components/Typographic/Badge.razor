@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IBadge

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <span @attributes="BuildAttributes()">@ChildContent</span>
}

@code {
    private const string _shadcnBadgeBase =
        "group/badge inline-flex h-5 w-fit shrink-0 items-center justify-center gap-1 overflow-hidden rounded-4xl border px-2 py-0.5 text-xs font-medium whitespace-nowrap transition-all focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 has-data-[icon=inline-end]:pr-1.5 has-data-[icon=inline-start]:pl-1.5 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&>svg]:pointer-events-none [&>svg]:size-3!";

    /// <summary>
    /// Gets or sets the visual style variant (shadcn/ui).
    /// </summary>
    [Parameter]
    public BadgeVariant Variant { get; set; } = BadgeVariant.Default;

    [Parameter]
    public bool AsChild { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-variant"] = GetDataVariant(Variant);

        QuarkPresetContext? preset = BuildPresetContext();
        bool hasBackgroundColor = BackgroundColor is not null || preset?.BackgroundColor is not null;
        bool hasTextColor = TextColor is not null || preset?.TextColor is not null;
        bool hasBorderColor = BorderColor is not null || preset?.BorderColor is not null;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, _shadcnBadgeBase);
            AppendClass(ref cls, GetBadgeVariantClass(Variant, hasBackgroundColor, hasTextColor, hasBorderColor));
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "badge";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(AsChild);
    }

    private static string GetDataVariant(BadgeVariant? variant)
    {
        if (ReferenceEquals(variant, BadgeVariant.Secondary))
            return "secondary";

        if (ReferenceEquals(variant, BadgeVariant.Destructive))
            return "destructive";

        if (ReferenceEquals(variant, BadgeVariant.Outline))
            return "outline";

        if (ReferenceEquals(variant, BadgeVariant.Ghost))
            return "ghost";

        if (ReferenceEquals(variant, BadgeVariant.Link))
            return "link";

        return "default";
    }

    private static string GetBadgeVariantClass(BadgeVariant? variant, bool hasBackgroundColor, bool hasTextColor, bool hasBorderColor)
    {
        if (ReferenceEquals(variant, BadgeVariant.Secondary))
            return BuildVariantClass("border-transparent", "bg-secondary [a]:hover:bg-secondary/80", "text-secondary-foreground", null,
                hasBackgroundColor, hasTextColor, hasBorderColor);

        if (ReferenceEquals(variant, BadgeVariant.Destructive))
            return BuildVariantClass("border-transparent", "bg-destructive/10 dark:bg-destructive/20 [a]:hover:bg-destructive/20", "text-destructive",
                "focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40", hasBackgroundColor, hasTextColor, hasBorderColor);

        if (ReferenceEquals(variant, BadgeVariant.Outline))
            return BuildVariantClass("border-border", "[a]:hover:bg-muted", "text-foreground [a]:hover:text-muted-foreground", null,
                hasBackgroundColor, hasTextColor, hasBorderColor);

        if (ReferenceEquals(variant, BadgeVariant.Ghost))
            return BuildVariantClass("border-transparent", "hover:bg-muted dark:hover:bg-muted/50", "hover:text-muted-foreground", null,
                hasBackgroundColor, hasTextColor, hasBorderColor);

        if (ReferenceEquals(variant, BadgeVariant.Link))
            return BuildVariantClass("border-transparent", null, "text-primary", "underline-offset-4 [a]:hover:underline", hasBackgroundColor,
                hasTextColor, hasBorderColor);

        return BuildVariantClass("border-transparent", "bg-primary [a]:hover:bg-primary/80", "text-primary-foreground", null, hasBackgroundColor,
            hasTextColor, hasBorderColor);
    }

    private static string BuildVariantClass(string? borderClasses, string? backgroundClasses, string? textClasses, string? otherClasses,
        bool hasBackgroundColor, bool hasTextColor, bool hasBorderColor)
    {
        var classes = new List<string>(4);

        if (!hasBorderColor && borderClasses is not null)
            classes.Add(borderClasses);

        if (!hasBackgroundColor && backgroundClasses is not null)
            classes.Add(backgroundClasses);

        if (!hasTextColor && textClasses is not null)
            classes.Add(textClasses);

        if (otherClasses is not null)
            classes.Add(otherClasses);

        return string.Join(' ', classes);
    }
}
