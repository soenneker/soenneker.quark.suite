@using System.Runtime.CompilerServices

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IBadge

<span @attributes="BuildAttributes()">@ChildContent</span>

@code {
    private const string _shadcnBadgeBase =
        "inline-flex h-5 items-center justify-center rounded-4xl border border-transparent px-2 py-0.5 text-xs font-medium w-fit whitespace-nowrap shrink-0 [&>svg]:size-3 gap-1 [&>svg]:pointer-events-none focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px] aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 aria-invalid:border-destructive transition-[color,box-shadow] overflow-hidden";

    /// <summary>
    /// Gets or sets the visual style variant (shadcn/ui).
    /// </summary>
    [Parameter]
    public BadgeVariant Variant { get; set; } = BadgeVariant.Default;

    [MethodImpl(MethodImplOptions.AggressiveInlining)]
    private static string GetShadcnVariantClass(BadgeVariant variant)
        => variant?.Value switch
        {
            BadgeVariant.SecondaryValue => "bg-secondary text-secondary-foreground [a&]:hover:bg-secondary/90",
            BadgeVariant.DestructiveValue => "bg-destructive text-white [a&]:hover:bg-destructive/90 focus-visible:ring-destructive/20 dark:focus-visible:ring-destructive/40 dark:bg-destructive/60",
            BadgeVariant.OutlineValue => "border-border text-foreground [a&]:hover:bg-accent [a&]:hover:text-accent-foreground",
            BadgeVariant.GhostValue => "[a&]:hover:bg-accent [a&]:hover:text-accent-foreground",
            BadgeVariant.LinkValue => "text-primary underline-offset-4 [a&]:hover:underline",
            _ => "bg-primary text-primary-foreground [a&]:hover:bg-primary/90",
        };

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "badge";
        attributes["data-variant"] = Variant?.Value ?? BadgeVariant.Default.Value;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-badge");
            AppendClass(ref cls, _shadcnBadgeBase);
            AppendClass(ref cls, GetShadcnVariantClass(Variant));
        });
    }

    protected override void ApplyBackgroundColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls)
    {
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
    }
}