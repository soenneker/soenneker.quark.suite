@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IBadge

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <span @attributes="BuildAttributes()">@ChildContent</span>
}

@code {
    private const string _shadcnBadgeBase =
        "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&>svg]:pointer-events-none [&>svg]:size-3";

    /// <summary>
    /// Gets or sets the visual style variant (shadcn/ui).
    /// </summary>
    [Parameter]
    public BadgeVariant Variant { get; set; } = BadgeVariant.Default;

    [Parameter]
    public bool AsChild { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "badge";
        attributes["data-variant"] = GetDataVariant(Variant);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, _shadcnBadgeBase);
            AppendClass(ref cls, GetBadgeVariantClass(Variant));
        });
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.InlineFlex;
        Width ??= Quark.Width.IsFit;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is1;
        Overflow ??= Quark.Overflow.Hidden;
        Rounded ??= Quark.Rounded.Full;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Transparent;
        Padding ??= Quark.Padding.Is2.OnX.Token("0.5").OnY;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.Token("transition-[color,box-shadow]");
        TextSize ??= Quark.TextSize.Xs;
        FontWeight ??= Quark.FontWeight.Medium;

        ApplyVariantDefaults();

    }

    private void ApplyVariantDefaults()
    {
        if (ReferenceEquals(Variant, BadgeVariant.Secondary))
        {
            BackgroundColor ??= Quark.BackgroundColor.Secondary;
            TextColor ??= Quark.TextColor.SecondaryForeground;
            return;
        }

        if (ReferenceEquals(Variant, BadgeVariant.Destructive))
        {
            BackgroundColor ??= Quark.BackgroundColor.Destructive;
            TextColor ??= Quark.TextColor.White;
            return;
        }

        if (ReferenceEquals(Variant, BadgeVariant.Outline))
        {
            BorderColor ??= Quark.BorderColor.Border;
            TextColor ??= Quark.TextColor.Foreground;
            return;
        }

        if (ReferenceEquals(Variant, BadgeVariant.Ghost))
            return;

        BackgroundColor ??= Quark.BackgroundColor.Primary;
        TextColor ??= Quark.TextColor.PrimaryForeground;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(AsChild);
    }

    private static string GetDataVariant(BadgeVariant? variant)
    {
        if (ReferenceEquals(variant, BadgeVariant.Secondary))
            return "secondary";

        if (ReferenceEquals(variant, BadgeVariant.Destructive))
            return "destructive";

        if (ReferenceEquals(variant, BadgeVariant.Outline))
            return "outline";

        if (ReferenceEquals(variant, BadgeVariant.Ghost))
            return "ghost";

        if (ReferenceEquals(variant, BadgeVariant.Link))
            return "link";

        return "default";
    }

    private static string GetBadgeVariantClass(BadgeVariant? variant)
    {
        if (ReferenceEquals(variant, BadgeVariant.Secondary))
            return "[a&]:hover:bg-secondary/90";

        if (ReferenceEquals(variant, BadgeVariant.Destructive))
            return "focus-visible:ring-destructive/20 dark:bg-destructive/60 dark:focus-visible:ring-destructive/40 [a&]:hover:bg-destructive/90";

        if (ReferenceEquals(variant, BadgeVariant.Outline))
            return "[a&]:hover:bg-accent [a&]:hover:text-accent-foreground";

        if (ReferenceEquals(variant, BadgeVariant.Ghost))
            return "[a&]:hover:bg-accent [a&]:hover:text-accent-foreground";

        if (ReferenceEquals(variant, BadgeVariant.Link))
            return "text-primary underline-offset-4 [a&]:hover:underline";

        return "[a&]:hover:bg-primary/90";
    }
}
