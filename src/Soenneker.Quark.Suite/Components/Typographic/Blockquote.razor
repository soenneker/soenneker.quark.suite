@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IBlockquote

<blockquote @attributes="BuildAttributes()">@ChildContent</blockquote>

@code {
    /// <summary>
    /// Gets or sets the cite attribute for the blockquote.
    /// </summary>
    [Parameter]
    public string? Cite { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        FontStyle ??= Quark.FontStyle.Italic;
        Margin ??= Quark.Margin.Token("6").FromTop;
        Border ??= Quark.Border.Is2.FromLeft;
        Padding ??= Quark.Padding.Is6.FromLeft;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "blockquote";

        if (Cite.HasContent())
            attributes["cite"] = Cite;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Cite);
    }
}
