@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Span Attributes="@BuildAttributes()">
    <Icon Name="@IconName" Size="Quark.Size.Is3" aria-hidden="true" />
    @ChildContent
</Span>

@code {
    [Parameter]
    public PillDeltaDirection Direction { get; set; } = PillDeltaDirection.Up;

    private LucideIcon IconName => Direction == PillDeltaDirection.Down ? LucideIcon.ArrowDown : LucideIcon.ArrowUp;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "pill-delta";
        Display ??= Quark.Display.InlineFlex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Quark.Items.Center;
        Gap ??= Quark.Gap.Is0_5;
        FontWeight ??= Quark.FontWeight.Semibold;
        TextColor ??= GetTextColor();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-direction"] = Direction == PillDeltaDirection.Down ? "down" : "up";

    }

    private CssValue<TextColorBuilder> GetTextColor()
    {
        return Direction == PillDeltaDirection.Down
            ? Quark.TextColor.Utility("text-red-600").OnDark.Utility("text-red-400")
            : Quark.TextColor.Utility("text-green-600").OnDark.Utility("text-green-400");
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Direction);
    }
}
