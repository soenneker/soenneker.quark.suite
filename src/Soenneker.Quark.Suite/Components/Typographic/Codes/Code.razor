@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements ICode

<code @attributes="BuildAttributes()">@ChildContent</code>

@code {
    /// <summary>
    /// Gets or sets the programming language for syntax highlighting.
    /// </summary>
    [Parameter]
    public string? Language { get; set; }

    /// <summary>
    /// Gets or sets whether the code should be displayed inline.
    /// </summary>
    [Parameter]
    public bool Inline { get; set; } = true;

    /// <summary>
    /// Gets or sets whether syntax highlighting should be applied.
    /// </summary>
    [Parameter]
    public bool Highlight { get; set; } = true;

    /// <summary>
    /// Gets or sets the syntax highlighting theme.
    /// </summary>
    [Parameter]
    public string? Theme { get; set; } = "default";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        if (!Inline)
            return;

        BackgroundColor ??= Quark.BackgroundColor.Muted;
        Rounded ??= Quark.Rounded.Default;
        FontFamily ??= Quark.FontFamily.Mono;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Semibold;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "code";

        if (Language.HasContent())
            attributes["data-language"] = Language;

        // Add default styling if no custom class
        if (!Class.HasContent())
        {
            BuildClassAttribute(attributes, (ref cls) =>
            {
                if (Inline)
                {
                    AppendClass(ref cls, "relative px-[0.3rem] py-[0.2rem]");
                }
            });
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Language);
        hc.Add(Inline);
        hc.Add(Highlight);
        hc.Add(Theme);
    }
}
