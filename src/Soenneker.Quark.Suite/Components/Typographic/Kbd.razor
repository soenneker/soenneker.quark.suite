@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

<kbd @attributes="BuildAttributes()">@ChildContent</kbd>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "kbd";

        Display ??= Quark.Display.InlineFlex;
        Height ??= Quark.Height.Is5;
        Width ??= Quark.Width.IsFit;
        MinWidth ??= Quark.MinWidth.Is5;
        Gap ??= Quark.Gap.Is1;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.OnX.Is1;
        TextSize ??= Quark.TextSize.Xs;
        FontFamily ??= Quark.FontFamily.Sans;
        FontWeight ??= Quark.FontWeight.Medium;
        BackgroundColor ??= Quark.BackgroundColor.Muted;
        TextColor ??= Quark.TextColor.MutedForeground;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        PointerEvents ??= Quark.PointerEvents.None;
        UserSelect ??= Quark.UserSelect.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "in-data-[slot=tooltip-content]:bg-background/20 in-data-[slot=tooltip-content]:text-background dark:in-data-[slot=tooltip-content]:bg-background/10");
            AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-3");
        });
    }
}