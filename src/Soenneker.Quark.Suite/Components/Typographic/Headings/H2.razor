@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IH2

<h2 @attributes="BuildAttributes()">@ChildContent</h2>

@code{
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "h2";

        TextSize ??= Quark.TextSize.ThreeXl;
        FontWeight ??= Quark.FontWeight.Semibold;
        Tracking ??= Quark.Tracking.Tight;
        ScrollMargin ??= "scroll-m-20";
        Border ??= Quark.Border.FromBottom.Default;
        Padding ??= Quark.Padding.FromBottom.Is2;
        Transition ??= Quark.Transition.Token("transition-colors");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "first:mt-0");
        });
    }
}