@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IH2

<h2 @attributes="BuildAttributes()">@ChildContent</h2>

@code{
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "h2";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "first:mt-0");
        });

        BuildTypographyDefaultAttributes(attributes, Quark.TextSize.ThreeXl, Quark.FontWeight.Semibold, Quark.Tracking.Tight, "scroll-m-20", border: Quark.Border.FromBottom.Default,
            padding: Quark.Padding.FromBottom.Is2, transition: Quark.Transition.Token("transition-colors"));
    }
}
