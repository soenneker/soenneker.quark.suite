@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IHeading

@{
    var level = GetHeadingLevel(Scale);
    var attrs = BuildAttributes();
}

@if (level == 1)
{
    <h1 @attributes="attrs">@ChildContent</h1>
}
else if (level == 2)
{
    <h2 @attributes="attrs">@ChildContent</h2>
}
else if (level == 3)
{
    <h3 @attributes="attrs">@ChildContent</h3>
}
else if (level == 4)
{
    <h4 @attributes="attrs">@ChildContent</h4>
}
else if (level == 5)
{
    <h5 @attributes="attrs">@ChildContent</h5>
}
else
{
    <h6 @attributes="attrs">@ChildContent</h6>
}

@code {

    [Parameter]
    public CssValue<ScaleBuilder>? Scale { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "heading";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
        {
            AddCss(ref sty, ref cls, Scale);
        });

        var headingLevel = GetHeadingLevel(Scale);

        switch (headingLevel)
        {
            case 1:
                BuildTypographyDefaultAttributes(attributes, Quark.TextSize.FourXl, Quark.FontWeight.Bold, Quark.Tracking.Tight);
                break;
            case 2:
                BuildTypographyDefaultAttributes(attributes, Quark.TextSize.ThreeXl, Quark.FontWeight.Bold, Quark.Tracking.Tight);
                break;
            case 3:
                BuildTypographyDefaultAttributes(attributes, Quark.TextSize.TwoXl, Quark.FontWeight.Semibold, Quark.Tracking.Tight);
                break;
            case 4:
                BuildTypographyDefaultAttributes(attributes, Quark.TextSize.Xl, Quark.FontWeight.Semibold);
                break;
            case 5:
                BuildTypographyDefaultAttributes(attributes, Quark.TextSize.Lg, Quark.FontWeight.Medium);
                break;
            default:
                BuildTypographyDefaultAttributes(attributes, Quark.TextSize.Base, Quark.FontWeight.Medium);
                break;
        }
    }

    

    private static int GetHeadingLevel(CssValue<ScaleBuilder>? scale)
    {
        const int fallback = 3;
        var s = scale?.ToString();

        if (s.IsNullOrWhiteSpace())
            return fallback;

        if (s.Length >= 7 && s.AsSpan().StartsWith("scale-"))
        {
            var d = s[^1] - '0';

            if ((uint)(d - 1) <= 5)
                return d; // 1..6
        }

        return fallback;
    }
    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        AddIf(ref hc, Scale);
    }
}
