@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements ICodeChip

<code @attributes="BuildAttributes()">@ChildContent</code>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Quark.Items.Center;
        Rounded ??= Quark.Rounded.Default;
        Border ??= Quark.Border.Is1;
        Padding ??= Quark.Padding.Is2.OnX.Token("0.5").OnY;
        TextSize ??= Quark.TextSize.Xs;
        FontFamily ??= Quark.FontFamily.Mono;
        BackgroundColor ??= Quark.BackgroundColor.Muted;
        TextColor ??= Quark.TextColor.MutedForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "code-chip";

        BuildClassAttribute(attributes, (ref cls) => 
        {
        });
    }
}
