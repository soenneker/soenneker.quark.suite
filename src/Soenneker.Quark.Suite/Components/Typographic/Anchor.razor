@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IAnchor

<a @onclick="HandleClick"
   @onclick:preventDefault="PreventDefault"
   @attributes="BuildAttributes()">
    @ChildContent
</a>

@code {

    /// <summary>
    /// Gets or sets the URL to navigate to.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    /// <summary>
    /// Gets or sets the target attribute for the link.
    /// </summary>
    [Parameter]
    public Target? Target { get; set; }

    /// <summary>
    /// Gets or sets whether the default browser navigation behavior should be prevented.
    /// Useful when navigation is coordinated manually from an OnClick handler.
    /// </summary>
    [Parameter]
    public bool PreventDefault { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-anchor");
        });

        if (To.HasContent())
            attributes["href"] = To!;

        if (Target is not null)
            attributes["target"] = Target.Value;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(To);
        hc.Add(Target);
        hc.Add(PreventDefault);
    }
}