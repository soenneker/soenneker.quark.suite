@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IAnchor

<a @onclick="HandleClick"
   @onclick:preventDefault="PreventDefault"
   @attributes="BuildAttributes()">
    @ChildContent
</a>

@code {
    [CascadingParameter(Name = SlotAttributes.Name)]
    private IReadOnlyDictionary<string, object>? SlotAttributeOverrides { get; set; }

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>
    /// Gets or sets the URL to navigate to.
    /// </summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>
    /// Gets or sets the target attribute for the link.
    /// </summary>
    [Parameter]
    public Target? Target { get; set; }

    /// <summary>
    /// Gets or sets whether the default browser navigation behavior should be prevented.
    /// Useful when navigation is coordinated manually from an OnClick handler.
    /// </summary>
    [Parameter]
    public bool PreventDefault { get; set; }

    /// <summary>
    /// Gets or sets Blazor enhanced navigation for this link.
    /// When set, renders the <c>data-enhance-nav</c> attribute.
    /// </summary>
    [Parameter]
    public bool? EnhanceNav { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "anchor";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (Href.HasContent())
            attributes["href"] = Href!;

        if (Target is not null)
            attributes["target"] = Target.Value;

        if (EnhanceNav is not null)
            attributes["data-enhance-nav"] = EnhanceNav.Value ? "true" : "false";

        SlotAttributes.MergeInto(attributes, SlotAttributeOverrides);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Href);
        hc.Add(Target);
        hc.Add(PreventDefault);
        hc.Add(EnhanceNav);
        hc.Add(OnClick.HasDelegate);
        hc.Add(SlotAttributeOverrides?.Count ?? 0);
    }

    private Task HandleClick(MouseEventArgs args)
    {
        return OnClick.HasDelegate ? OnClick.InvokeAsync(args) : Task.CompletedTask;
    }
}
