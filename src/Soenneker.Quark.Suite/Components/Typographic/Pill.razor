@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IPill

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <Span Attributes="@BuildAttributes()">@ChildContent</Span>
}

@code {
    private const string _shadcnPillStateClass =
        "group/pill focus-visible:ring-[3px] focus-visible:ring-ring/50 has-data-[slot=pill-close]:pr-1 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&>svg]:pointer-events-none [&>svg]:size-3.5 [&>svg]:shrink-0";

    [Parameter]
    public bool AsChild { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "pill";

        Display ??= Quark.Display.InlineFlex;
        Height ??= Quark.Height.Is7;
        Width ??= Quark.Width.IsFit;
        MaxWidth ??= Quark.MaxWidth.IsFull;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is1_5;
        Overflow ??= Quark.Overflow.Hidden;
        Rounded ??= Quark.Rounded.Full;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Transparent.OnFocusVisible.Ring;
        BackgroundColor ??= Quark.BackgroundColor.Background.OnHover.Utility("bg-muted/50");
        Padding ??= Quark.Padding.OnX.Is2_5.OnY.Is1;
        TextSize ??= Quark.TextSize.Xs;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Shadow ??= Quark.Shadow.Xs;
        Transition ??= Quark.Transition.All;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, _shadcnPillStateClass);
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
    }
}
