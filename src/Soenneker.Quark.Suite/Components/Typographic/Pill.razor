@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IPill

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <span @attributes="BuildAttributes()">@ChildContent</span>
}

@code {
    private const string _shadcnPillBase =
        "group/pill inline-flex h-7 w-fit max-w-full shrink-0 items-center justify-center gap-1.5 overflow-hidden rounded-full border bg-background px-2.5 py-1 text-xs font-medium whitespace-nowrap shadow-xs transition-all hover:bg-muted/50 focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 has-data-[slot=pill-close]:pr-1 aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40 [&>svg]:pointer-events-none [&>svg]:size-3.5 [&>svg]:shrink-0";

    [Parameter]
    public bool AsChild { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "pill";

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Full;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Transparent;
        Padding ??= Quark.Padding.OnX.Is2_5.OnY.Token("0.5");
        TextSize ??= Quark.TextSize.Xs;
        FontWeight ??= Quark.FontWeight.Semibold;
        Width ??= Quark.Width.IsFit;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Shrink ??= Quark.Shrink.Is0;
        Transition ??= Quark.Transition.Token("transition-[color,shadow]");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, _shadcnPillBase);
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
    }
}
