@* Tailwind @source: skeleton size classes for library build — h-4 h-8 h-12 w-[100px] w-[150px] w-[200px] w-[250px] w-20 w-24 w-2/3 w-1/2 w-3/4 w-full flex-1 size-10 rounded-full aspect-video *@
@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISkeleton

<div @attributes="BuildAttributes()"></div>

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "skeleton";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-skeleton");
            AppendClass(ref cls, "animate-pulse rounded-md bg-muted");
        });
    }
}
