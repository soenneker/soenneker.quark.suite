@* Tailwind @source: skeleton size classes for library build — h-4 h-8 h-12 h-[125px] w-[100px] w-[150px] w-[200px] w-[250px] w-20 w-24 w-2/3 w-1/2 w-3/4 w-full flex-1 size-10 rounded-full rounded-xl aspect-video *@
@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISkeleton

<div @attributes="BuildAttributes()"></div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        if (!HasExplicitRoundedClass(Class))
            Rounded ??= Quark.Rounded.Md;

        BackgroundColor ??= Quark.BackgroundColor.Accent;
        Animation ??= Quark.Animation.Pulse;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "skeleton";

    }

    private static bool HasExplicitRoundedClass(string? className)
    {
        if (string.IsNullOrWhiteSpace(className))
            return false;

        return className.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Any(token => token == "rounded" || token.StartsWith("rounded-", StringComparison.Ordinal));
    }
}
