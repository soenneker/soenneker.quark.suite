@* Tailwind @source: skeleton size classes for library build — h-4 h-8 h-12 w-[100px] w-[150px] w-[200px] w-[250px] w-20 w-24 w-2/3 w-1/2 w-3/4 w-full flex-1 size-10 rounded-full aspect-video *@
@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISkeleton

<div @attributes="BuildAttributes()"></div>

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "skeleton";

        // shadcn/ui skeleton base - new-york-v4 ui/skeleton.tsx: animate-pulse rounded-md bg-muted
        // Add min-h-4 so the div has visible height when no Class/dimensions are passed (empty div collapses to 0).
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-skeleton");
            AppendClass(ref cls, "rounded-md bg-muted animate-pulse min-h-4");
        });
    }
}
