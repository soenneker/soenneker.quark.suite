@namespace Soenneker.Quark

@inherits Soenneker.Quark.Element
@implements IProgress
@using Soenneker.Bradix

<BradixProgress Value="@ResolvedBradixValue"
                Max="@Max"
                AdditionalAttributes="@BuildAttributes()">
    <BradixProgressIndicator AdditionalAttributes="@IndicatorAttributes" />
</BradixProgress>

@code {
    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    /// <summary>
    /// Gets or sets the current progress value (0–100).
    /// </summary>
    [Parameter]
    public int ProgressValue { get; set; }

    /// <summary>
    /// Gets or sets whether the progress should render as an indeterminate loading state.
    /// </summary>
    [Parameter]
    public bool Indeterminate { get; set; }

    /// <summary>
    /// Gets or sets the ARIA value text announced for indeterminate progress.
    /// </summary>
    [Parameter]
    public string? AriaValueText { get; set; }

    /// <summary>
    /// Gets or sets the maximum value for ARIA semantics.
    /// </summary>
    [Parameter]
    public int Max { get; set; } = 100;

    private int EffectiveMax => Max > 0 ? Max : 100;

    private double? ResolvedBradixValue => Indeterminate ? null : GetClampedValue();

    private IReadOnlyDictionary<string, object> IndicatorAttributes => BuildIndicatorAttributes();

    private int GetClampedValue()
    {
        var val = ProgressValue;
        if (val < 0) val = 0;
        if (val > EffectiveMax) val = EffectiveMax;
        return val;
    }

    private bool IsRtl()
    {
        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    private string GetIndicatorStyle()
    {
        if (Indeterminate)
            return "transform: translateX(0%);";

        var pct = GetClampedValue() * 100.0 / EffectiveMax;
        var offset = 100 - pct;
        if (Math.Abs(offset) < 0.0001)
            offset = 0;

        var translate = offset == 0 ? 0 : IsRtl() ? offset : -offset;
        return $"transform: translateX({translate:F0}%);";
    }

    private string GetIndicatorClass()
    {
        return "h-full w-full flex-1 bg-primary transition-all";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "progress";

        if (Indeterminate && AriaValueText.HasContent() && !attributes.ContainsKey("aria-valuetext"))
            attributes["aria-valuetext"] = AriaValueText!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "relative h-2 w-full overflow-hidden rounded-full bg-primary/20");
        });

    }

    private IReadOnlyDictionary<string, object> BuildIndicatorAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "progress-indicator",
            ["class"] = GetIndicatorClass(),
            ["style"] = GetIndicatorStyle()
        };

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ProgressValue);
        hc.Add(Max);
        hc.Add(Indeterminate);
        hc.Add(AriaValueText);
    }
}
