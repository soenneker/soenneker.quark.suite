@namespace Soenneker.Quark

@inherits Soenneker.Quark.Element
@implements IProgress

<div @attributes="BuildAttributes()"
     role="progressbar"
     aria-valuemin="0"
     aria-valuemax="@Max"
     aria-valuenow="@GetAriaValueNow()"
     aria-valuetext="@GetAriaValueText()">
    <div data-slot="progress-indicator"
         class="@GetIndicatorClass()"
         style="@GetIndicatorStyle()"></div>
</div>

@code {
    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    /// <summary>
    /// Gets or sets the current progress value (0–100).
    /// </summary>
    [Parameter]
    public int ProgressValue { get; set; }

    /// <summary>
    /// Gets or sets whether the progress should render as an indeterminate loading state.
    /// </summary>
    [Parameter]
    public bool Indeterminate { get; set; }

    /// <summary>
    /// Gets or sets the ARIA value text announced for indeterminate progress.
    /// </summary>
    [Parameter]
    public string? AriaValueText { get; set; }

    /// <summary>
    /// Gets or sets the maximum value for ARIA semantics.
    /// </summary>
    [Parameter]
    public int Max { get; set; } = 100;

    private int GetClampedValue()
    {
        var val = ProgressValue;
        if (val < 0) val = 0;
        if (val > Max) val = Max;
        return val;
    }

    private bool IsRtl()
    {
        if (string.Equals(DirectionProviderDir, "rtl", StringComparison.OrdinalIgnoreCase))
            return true;

        if (Attributes is not null &&
            Attributes.TryGetValue("dir", out var dirValue) &&
            string.Equals(dirValue?.ToString(), "rtl", StringComparison.OrdinalIgnoreCase))
        {
            return true;
        }

        return false;
    }

    private string GetIndicatorStyle()
    {
        if (Indeterminate)
            return "transform: translateX(0%);";

        var pct = Max > 0 ? (GetClampedValue() * 100.0 / Max) : 0;
        var offset = 100 - pct;
        var translate = IsRtl() ? offset : -offset;
        return $"transform: translateX({translate:F0}%);";
    }

    private string GetIndicatorClass()
    {
        return "size-full flex-1 bg-primary transition-all";
    }

    private string? GetAriaValueNow()
    {
        return Indeterminate ? null : GetClampedValue().ToString();
    }

    private string? GetAriaValueText()
    {
        if (!Indeterminate)
            return null;

        return AriaValueText.HasContent() ? AriaValueText : "Loading";
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "progress";
        attributes["data-state"] = Indeterminate ? "indeterminate" : "determinate";
        attributes["data-max"] = Max;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "relative flex h-1 items-center overflow-x-hidden rounded-full bg-muted");
        });

    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ProgressValue);
        hc.Add(Max);
        hc.Add(Indeterminate);
        hc.Add(AriaValueText);
    }
}
