@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISeparator

<BradixSeparator Orientation="@ResolvedOrientation"
                 Decorative="@Decorative"
                 AdditionalAttributes="@SeparatorAttributes" />

@code {
    /// <summary>
    /// Gets or sets the separator orientation.
    /// </summary>
    [Parameter]
    public SeparatorOrientation Orientation { get; set; } = SeparatorOrientation.Horizontal;

    /// <summary>
    /// Gets or sets whether the separator is purely decorative.
    /// </summary>
    [Parameter]
    public bool Decorative { get; set; } = true;

    private Orientation ResolvedOrientation =>
        Orientation == SeparatorOrientation.Vertical ? Soenneker.Bradix.Orientation.Vertical : Soenneker.Bradix.Orientation.Horizontal;

    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildSeparatorAttributes();

    private IReadOnlyDictionary<string, object> BuildSeparatorAttributes()
    {
        return BuildAttributes();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Shrink ??= Quark.Shrink.Is0;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "separator";
        attributes["data-orientation"] = Orientation == SeparatorOrientation.Vertical ? "vertical" : "horizontal";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
        hc.Add(Decorative);
    }
}
