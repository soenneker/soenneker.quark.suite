@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISeparator

<div @attributes="SeparatorAttributes"></div>

@code {
    /// <summary>
    /// Gets or sets the separator orientation.
    /// </summary>
    [Parameter]
    public SeparatorOrientation Orientation { get; set; } = SeparatorOrientation.Horizontal;

    /// <summary>
    /// Gets or sets whether the separator is purely decorative.
    /// </summary>
    [Parameter]
    public bool Decorative { get; set; } = true;

    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildSeparatorAttributes();

    private IReadOnlyDictionary<string, object> BuildSeparatorAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        if (Decorative)
        {
            attributes["role"] = "none";
            attributes["aria-hidden"] = "true";
        }
        else
        {
            attributes["role"] = "separator";
            if (Orientation == SeparatorOrientation.Vertical)
                attributes["aria-orientation"] = "vertical";
        }

        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var orientation = Orientation == SeparatorOrientation.Vertical ? "vertical" : "horizontal";

        attributes["data-slot"] = "separator";
        attributes["data-orientation"] = orientation;

        if (Orientation == SeparatorOrientation.Vertical)
            attributes["data-vertical"] = string.Empty;
        else
            attributes["data-horizontal"] = string.Empty;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "shrink-0 bg-border data-horizontal:h-px data-horizontal:w-full data-vertical:h-full data-vertical:w-px data-vertical:self-stretch");
            AppendClass(ref cls, "data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
        hc.Add(Decorative);
    }
}
