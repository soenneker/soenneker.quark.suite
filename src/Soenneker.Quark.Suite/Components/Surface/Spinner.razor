@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISpinner
@using Soenneker.Quark.Gen.Lucide.Abstractions

<svg @attributes="BuildAttributes()"
     xmlns="http://www.w3.org/2000/svg"
     viewBox="0 0 24 24"
     fill="none"
     stroke="currentColor"
     stroke-width="2"
     stroke-linecap="round"
     stroke-linejoin="round">
    @if (Name == LucideIcon.Loader)
    {
        <path d="M12 2v4" />
        <path d="m16.2 7.8 2.9-2.9" />
        <path d="M18 12h4" />
        <path d="m16.2 16.2 2.9 2.9" />
        <path d="M12 18v4" />
        <path d="m4.9 19.1 2.9-2.9" />
        <path d="M2 12h4" />
        <path d="m4.9 4.9 2.9 2.9" />
    }
    else
    {
        <path d="M21 12a9 9 0 1 1-6.219-8.56" />
    }
</svg>

@code {
    [Parameter]
    public LucideIcon Name { get; set; } = LucideIcon.LoaderCircle;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        if (!HasExplicitSizeClass())
            BoxSize ??= Size.Is4;

        Animation ??= Quark.Animation.Spin;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["role"] = "status";
        attributes["aria-label"] = "Loading";
        attributes["class"] = $"{GetLucideClass()} {attributes.GetValueOrDefault("class")}".Trim();

    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Name);
    }

    private string GetLucideClass() => Name == LucideIcon.Loader ? "lucide lucide-loader" : "lucide lucide-loader-circle";

    private bool HasExplicitSizeClass()
    {
        if (ClassHasExplicitSize(Class))
            return true;

        if (Attributes is null)
            return false;

        foreach (var attribute in Attributes)
        {
            if (attribute.Key.Equals("class", StringComparison.OrdinalIgnoreCase) &&
                ClassHasExplicitSize(attribute.Value?.ToString()))
            {
                return true;
            }
        }

        return false;
    }

    private static bool ClassHasExplicitSize(string? className)
    {
        if (string.IsNullOrWhiteSpace(className))
            return false;

        return className.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Any(IsExplicitSizeToken);
    }

    private static bool IsExplicitSizeToken(string token)
    {
        var separator = token.LastIndexOf(':');
        var utility = separator >= 0 ? token[(separator + 1)..] : token;

        return utility.StartsWith("size-", StringComparison.Ordinal) ||
               utility.StartsWith("w-", StringComparison.Ordinal) ||
               utility.StartsWith("h-", StringComparison.Ordinal);
    }
}
