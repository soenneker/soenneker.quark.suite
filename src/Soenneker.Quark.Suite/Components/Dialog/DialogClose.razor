@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@using ButtonSizeType = Soenneker.Quark.ButtonSize
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <Button Type="ButtonType.Button"
            Variant="@Variant"
            ButtonSize="@ButtonSize"
            OnClick="HandleCloseButtonClick"
            @attributes="BuildAttributes()">
        @ChildContent
    </Button>
}

@code {
    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public bool AutoClose { get; set; } = true;

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Outline;

    [Parameter]
    public ButtonSize ButtonSize { get; set; } = ButtonSizeType.Default;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-close";
    }

    private async Task HandleCloseClick()
    {
        await OnClose.InvokeIfHasDelegate();

        if (AutoClose && ParentDialog is not null)
            await ParentDialog.Hide();
    }

    private async Task HandleCloseButtonClick(MouseEventArgs _)
    {
        await HandleCloseClick();
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            DataSlot = null,
            OnClick = HandleCloseClick
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(AutoClose);
        hc.Add(Variant);
        hc.Add(ButtonSize);
    }
}
