@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement
@implements IDialogContent

<BradixDialogPortal>
    @if (ParentDialog?.ShowBackdrop == true)
    {
        <BradixDialogOverlay AdditionalAttributes="@OverlayAttributes" />
    }

    <BradixDialogContent Id="@Context?.ContentId"
                         CloseOnEscapeKeyDown="@(ParentDialog?.CloseOnEscape ?? true)"
                         CloseOnPointerDownOutside="@ShouldCloseOnOutsideInteraction"
                         CloseOnFocusOutside="@ShouldCloseOnOutsideInteraction"
                         OnPointerDownOutside="HandleBackdropPointerDownOutside"
                         AdditionalAttributes="@ContentAttributes">
        @ChildContent
        @if (ShowCloseButton)
        {
            <DialogCloseButton />
        }
    </BradixDialogContent>
</BradixDialogPortal>

@code {
    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [Parameter]
    public bool Centered { get; set; }

    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    private bool ShouldCloseOnOutsideInteraction =>
        ParentDialog is not null &&
        !ParentDialog.Static &&
        ParentDialog.CloseOnBackdropClick;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    private IReadOnlyDictionary<string, object> OverlayAttributes => BuildOverlayAttributes();

    private Task HandleBackdropPointerDownOutside()
    {
        return ParentDialog?.OnBackdropClick.InvokeIfHasDelegate() ?? Task.CompletedTask;
    }

    private async Task HandleOverlayClick()
    {
        if (!ShouldCloseOnOutsideInteraction || ParentDialog is null)
            return;

        await ParentDialog.OnBackdropClick.InvokeIfHasDelegate();
        await ParentDialog.Hide();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Fixed;
        Display ??= Quark.Display.Grid;
        ZIndex ??= "z-50";
        MaxWidth ??= "max-w-[calc(100%-2rem)]";
        Width ??= Quark.Width.IsFull;
        Gap ??= Quark.Gap.Is4;
        Rounded ??= Quark.Rounded.Xl;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is4;
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-sm text-popover-foreground ring-1 ring-foreground/10 duration-100 data-open:animate-in data-open:fade-in-0 data-open:zoom-in-95 data-closed:animate-out data-closed:fade-out-0 data-closed:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95 data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 sm:max-w-sm");

            if (ParentDialog?.Scrollable == true)
                AppendClass(ref cls, "max-h-[90vh] overflow-y-auto");

            if (ParentDialog?.DialogSize != null && ParentDialog.DialogSize.Value.HasContent())
            {
                var size = ParentDialog.DialogSize.Value.ToLowerInvariant();
                if (size == "sm")
                    AppendClass(ref cls, "sm:max-w-sm");
                else if (size == "lg")
                    AppendClass(ref cls, "sm:max-w-2xl");
                else if (size == "xl")
                    AppendClass(ref cls, "sm:max-w-4xl");
            }
        });

        attributes["data-slot"] = "dialog-content";
    }

    private Dictionary<string, object> BuildOverlayAttributes()
    {
        var attributes = new Dictionary<string, object>();

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "fixed inset-0 isolate z-50 bg-black/10 duration-100 supports-backdrop-filter:backdrop-blur-xs data-open:animate-in data-open:fade-in-0 data-closed:animate-out data-closed:fade-out-0 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=closed]:animate-out data-[state=closed]:fade-out-0");

            if (ParentDialog?.BlurBackdrop == true)
                AppendClass(ref cls, "backdrop-blur");
        });

        attributes["data-slot"] = "dialog-overlay";
        attributes["data-state"] = ParentDialog?.Visible == true ? "open" : "closed";
        attributes["aria-hidden"] = "true";

        if (ShouldCloseOnOutsideInteraction)
            attributes["onclick"] = EventCallback.Factory.Create(this, HandleOverlayClick);

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ShowCloseButton);
        hc.Add(Centered);
        hc.Add(ParentDialog?.Visible ?? false);
        hc.Add(ParentDialog?.ShowBackdrop ?? true);
        hc.Add(ParentDialog?.BlurBackdrop ?? false);
        hc.Add(ParentDialog?.Centered ?? false);
        hc.Add(ParentDialog?.Scrollable ?? false);
        hc.Add(ParentDialog?.DialogSize);
        hc.Add(ParentDialog?.Static ?? false);
        hc.Add(ParentDialog?.TrapFocus ?? true);
        hc.Add(ParentDialog?.CloseOnEscape ?? true);
        hc.Add(ParentDialog?.CloseOnBackdropClick ?? true);
        hc.Add(Context?.ContentId);
    }
}
