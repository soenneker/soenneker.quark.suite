@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement
@implements IDialogContent

@if (ParentDialog?.Visible == true)
{
    @if (Portal)
    {
        <OverlayPortalPublisher Id="@_portalId" UsePortal="true">
            <OverlayPortalShell CascadeOwnerName="@nameof(ParentDialog)" Owner="ParentDialog" LabelContext="Context">
                <DialogContentSurface Centered="@Centered" ShowCloseButton="@ShowCloseButton">
                    @ChildContent
                </DialogContentSurface>
            </OverlayPortalShell>
        </OverlayPortalPublisher>
    }
    else
    {
        <DialogContentSurface Centered="@Centered" ShowCloseButton="@ShowCloseButton">
            @ChildContent
        </DialogContentSurface>
    }
}

@code {
    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private readonly string _portalId = $"q-dialog-portal-{Guid.NewGuid():N}";

    [Parameter]
    public bool Centered { get; set; }

    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    /// <summary>
    /// When <c>true</c> (default), dialog chrome renders in <see cref="QuarkOverlayPortalHost"/> (layout-level portal).
    /// Set <c>false</c> to render inline (e.g. hosts without the portal host).
    /// </summary>
    [Parameter]
    public bool Portal { get; set; } = true;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Centered);
        hc.Add(ShowCloseButton);
        hc.Add(Portal);
        hc.Add(ParentDialog?.Visible ?? false);
        hc.Add(ParentDialog?.ShowBackdrop ?? true);
        hc.Add(ParentDialog?.Centered ?? false);
        hc.Add(ParentDialog?.Scrollable ?? false);
        hc.Add(ParentDialog?.DialogSize);
        hc.Add(ParentDialog?.Static ?? false);
        hc.Add(ParentDialog?.TrapFocus ?? true);
        hc.Add(ParentDialog?.CloseOnBackdropClick ?? true);
        hc.Add(Context?.HasTitle);
        hc.Add(Context?.HasDescription);
        hc.Add(Context?.ContentId);
        hc.Add(Context?.TitleId);
        hc.Add(Context?.DescriptionId);
    }
}
