@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDialogCloseButton

@if (AutoClose)
{
    <BradixDialogClose OnClick="HandleCloseClick" AdditionalAttributes="@CloseAttributes">
        @if (ChildContent == null)
        {
            <Svg BoxSize="Quark.Size.Is4" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></Svg>
            <Span ScreenReader="Quark.ScreenReader.Only">Close</Span>
        }
        else
        {
            @ChildContent
        }
    </BradixDialogClose>
}
else
{
    <button type="button" @onclick="HandleClick" @attributes="BuildAttributes()">
        @if (ChildContent == null)
        {
            <Svg BoxSize="Quark.Size.Is4" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></Svg>
            <Span ScreenReader="Quark.ScreenReader.Only">Close</Span>
        }
        else
        {
            @ChildContent
        }
    </button>
}

@code {
    /// <summary>
    /// Gets or sets whether the dialog should automatically close When the button is clicked.
    /// </summary>
    [Parameter]
    public bool AutoClose { get; set; } = true;

    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    private IReadOnlyDictionary<string, object> CloseAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Absolute;
        Opacity ??= "opacity-70";
        Transition ??= Quark.Transition.Opacity;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "top-4 right-4 rounded-xs ring-offset-background hover:opacity-100 focus:ring-2 focus:ring-ring focus:ring-offset-2 focus:outline-hidden disabled:pointer-events-none data-[state=open]:bg-accent data-[state=open]:text-muted-foreground");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });

        attributes["data-slot"] = "dialog-close";

        if (!attributes.ContainsKey("aria-label"))
            attributes["aria-label"] = "Close";
    }

    protected override async Task HandleClick(MouseEventArgs e)
    {
        await base.HandleClick(e);

        if (AutoClose && ParentDialog != null)
        {
            await ParentDialog.Hide();
        }
    }

    private Task HandleCloseClick(MouseEventArgs e)
    {
        return base.HandleClick(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AutoClose);
        hc.Add(BradixDialog?.CurrentOpen);
    }
}
