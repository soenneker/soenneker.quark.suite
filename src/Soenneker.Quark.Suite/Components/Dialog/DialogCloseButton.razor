@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDialogCloseButton

@if (AutoClose)
{
    <BradixDialogClose AriaLabel="@((string?)null)" OnClick="HandleCloseClick" AdditionalAttributes="@CloseAttributes">
        @if (ChildContent == null)
        {
            <Svg Size="Quark.Size.Is4" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></Svg>
            <Span ScreenReader="Quark.ScreenReader.Only">Close</Span>
        }
        else
        {
            @ChildContent
        }
    </BradixDialogClose>
}
else
{
    <button type="button" @onclick="HandleClick" @attributes="BuildAttributes()">
        @if (ChildContent == null)
        {
            <Svg Size="Quark.Size.Is4" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></Svg>
            <Span ScreenReader="Quark.ScreenReader.Only">Close</Span>
        }
        else
        {
            @ChildContent
        }
    </button>
}

@code {
    /// <summary>
    /// Gets or sets whether the dialog should automatically close When the button is clicked.
    /// </summary>
    [Parameter]
    public bool AutoClose { get; set; } = true;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    private IReadOnlyDictionary<string, object> CloseAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "dialog-close";

        Position ??= Quark.Position.Absolute;
        Top ??= Quark.Top.Is2;
        Right ??= Quark.Right.Is2;
        Size ??= Quark.Size.Is7;
        Display ??= Quark.Display.InlineFlex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Transparent.OnFocusVisible.Ring;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
        UserSelect ??= Quark.UserSelect.None;
        RingColor ??= Quark.RingColor.OnFocusVisible.Token("ring/50");
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "bg-clip-padding focus-visible:ring-3 active:not-aria-[haspopup]:translate-y-px aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:hover:bg-muted/50 rounded-[min(var(--radius-md),12px)] in-data-[slot=button-group]:rounded-lg");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });

        attributes["data-variant"] = "ghost";
        attributes["data-size"] = "icon-sm";

    }

    private async Task HandleClick(MouseEventArgs e)
    {
        if (OnClick.HasDelegate)
            await OnClick.InvokeAsync(e);

        if (AutoClose && ParentDialog != null)
        {
            await ParentDialog.Hide();
        }
    }

    private Task HandleCloseClick(MouseEventArgs e)
    {
        return OnClick.HasDelegate ? OnClick.InvokeAsync(e) : Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AutoClose);
        hc.Add(OnClick.HasDelegate);
        hc.Add(BradixDialog?.CurrentOpen);
    }
}
