@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDialogCloseButton

@if (AutoClose)
{
    <BradixDialogClose OnClick="HandleCloseClick" AdditionalAttributes="@CloseAttributes">
        @if (ChildContent == null)
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="size-4"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            <span class="sr-only">Close</span>
        }
        else
        {
            @ChildContent
        }
    </BradixDialogClose>
}
else
{
    <button type="button" @onclick="HandleClick" @attributes="BuildAttributes()">
        @if (ChildContent == null)
        {
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="size-4"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            <span class="sr-only">Close</span>
        }
        else
        {
            @ChildContent
        }
    </button>
}

@code {
    /// <summary>
    /// Gets or sets whether the dialog should automatically close When the button is clicked.
    /// </summary>
    [Parameter]
    public bool AutoClose { get; set; } = true;

    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    private IReadOnlyDictionary<string, object> CloseAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Absolute;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        // shadcn Dialog close button - new-york-v4 ui/dialog.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "top-4 right-4 inline-flex size-7 items-center justify-center rounded-md text-muted-foreground opacity-70 transition-opacity hover:opacity-100 hover:text-foreground focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
        attributes["data-slot"] = "dialog-close";
        attributes["data-state"] = BradixDialog?.CurrentOpen == true ? "open" : "closed";

        if (!attributes.ContainsKey("aria-label"))
            attributes["aria-label"] = "Close";
    }

    protected override async Task HandleClick(MouseEventArgs e)
    {
        await base.HandleClick(e);

        if (AutoClose && ParentDialog != null)
        {
            await ParentDialog.Hide();
        }
    }

    private Task HandleCloseClick(MouseEventArgs e)
    {
        return base.HandleClick(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AutoClose);
    }
}
