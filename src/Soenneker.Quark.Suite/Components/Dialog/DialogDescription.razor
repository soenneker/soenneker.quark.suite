@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

<BradixDialogDescription Id="@BradixDialog?.DescriptionId" AdditionalAttributes="@DescriptionAttributes">
    @ChildContent
</BradixDialogDescription>

@code {
    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    private IReadOnlyDictionary<string, object> DescriptionAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-description";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dialog-description");
            AppendClass(ref cls, "text-sm text-muted-foreground");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(BradixDialog?.DescriptionId);
    }
}
