@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

<BradixDialogDescription Id="@Context?.DescriptionId" AdditionalAttributes="@DescriptionAttributes">
    @ChildContent
</BradixDialogDescription>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private IReadOnlyDictionary<string, object> DescriptionAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-description";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "text-sm text-muted-foreground");
            AppendClass(ref cls, "*:[a]:underline *:[a]:underline-offset-3 *:[a]:hover:text-foreground");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.DescriptionId);
    }
}
