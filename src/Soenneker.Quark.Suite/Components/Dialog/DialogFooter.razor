@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IDialogFooter

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        FlexDirection ??= Quark.FlexDirection.ColReverse;
        Gap ??= Quark.Gap.Is2;
        Margin ??= Quark.Margin.Token("-6").OnX.Token("-6").FromBottom;
        Border ??= Quark.Border.Default.FromTop;
        BackgroundColor ??= Quark.BackgroundColor.Token("muted/50");
        Padding ??= Quark.Padding.Is6.OnX.Is4.OnY;
        Rounded ??= Quark.Rounded.Bottom.Xl;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-footer";
        // shadcn DialogFooter - base ui/dialog.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "sm:flex-row sm:justify-end");
        });
    }
}
