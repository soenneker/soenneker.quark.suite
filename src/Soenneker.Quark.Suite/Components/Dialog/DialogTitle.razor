@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IDialogTitle

<BradixDialogTitle Id="@BradixDialog?.TitleId" AdditionalAttributes="@TitleAttributes">
    @ChildContent
</BradixDialogTitle>

@code {
    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    /// <summary>
    /// Backward-compatibility parameter; shadcn title styles are fixed.
    /// </summary>
    [Parameter]
    public CssValue<ScaleBuilder>? Scale { get; set; } = Quark.Scale.Is5;

    private IReadOnlyDictionary<string, object> TitleAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-title";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dialog-title");
            AppendClass(ref cls, "text-lg leading-none font-semibold");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        AddIf(ref hc, Scale);
        hc.Add(BradixDialog?.TitleId);
    }
}
