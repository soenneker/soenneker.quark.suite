@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IDialogTitle
@implements IDisposable

<h2 @attributes="BuildAttributes()">
    @ChildContent
</h2>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private OverlayLabelContext? _registeredContext;
    private IDisposable? _titleRegistration;

    /// <summary>
    /// Backward-compatibility parameter; shadcn title styles are fixed.
    /// </summary>
    [Parameter]
    public CssValue<ScaleBuilder>? Scale { get; set; } = Quark.Scale.Is5;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ReferenceEquals(_registeredContext, Context))
            return;

        _titleRegistration?.Dispose();
        _registeredContext = Context;
        _titleRegistration = Context?.RegisterTitle();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-title";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dialog-title");
            AppendClass(ref cls, "text-lg leading-none font-semibold");
        });

        if (!attributes.ContainsKey("id") && Context is not null)
            attributes["id"] = Context.TitleId;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        AddIf(ref hc, Scale);
        hc.Add(Context?.TitleId);
    }

    public override void Dispose()
    {
        _titleRegistration?.Dispose();
        base.Dispose();
    }
}
