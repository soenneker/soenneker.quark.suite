@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IDialogTitle

<BradixDialogTitle Id="@Context?.TitleId" AdditionalAttributes="@TitleAttributes">
    @ChildContent
</BradixDialogTitle>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    /// <summary>
    /// Backward-compatibility parameter; shadcn title styles are fixed.
    /// </summary>
    [Parameter]
    public CssValue<ScaleBuilder>? Scale { get; set; } = Quark.Scale.Scale105;

    private IReadOnlyDictionary<string, object> TitleAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        TextSize ??= Quark.TextSize.Base;
        Leading ??= Quark.Leading.None;
        FontWeight ??= Quark.FontWeight.Medium;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-title";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "cn-font-heading");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        AddIf(ref hc, Scale);
        hc.Add(Context?.TitleId);
    }
}
