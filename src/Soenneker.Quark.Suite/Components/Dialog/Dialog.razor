@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements IDialog
@implements IDisposable

@if (Visible)
{
    <CascadingValue Name="ParentDialog" Value="@this">
        <CascadingValue Value="_context" IsFixed="false">
            <div @onkeydown="HandleKeyDown" @onclick="HandleBackdropClick" @attributes="BuildAttributes()">
                @if (ShowBackdrop)
                {
                    <div class="fixed inset-0 z-50 bg-black/50 data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:animate-in data-[state=open]:fade-in-0" data-slot="dialog-overlay" data-state="@(Visible ? "open" : "closed")" aria-hidden="true"></div>
                }
                <div @ref="_dialogRef" @attributes="BuildDialogAttributes()" @onclick:stopPropagation="true">
                    @ChildContent
                </div>
            </div>
        </CascadingValue>
    </CascadingValue>
}

@code {
    /// <summary>
    /// Gets or sets whether the dialog should be centered vertically.
    /// </summary>
    [Parameter]
    public bool Centered { get; set; }

    /// <summary>
    /// Gets or sets whether the dialog content should be scrollable.
    /// </summary>
    [Parameter]
    public bool Scrollable { get; set; }

    /// <summary>
    /// Gets or sets the size of the dialog.
    /// </summary>
    [Parameter]
    public DialogSize? DialogSize { get; set; }

    /// <summary>
    /// Gets or sets whether the dialog backdrop is static (doesn't close on click).
    /// </summary>
    [Parameter]
    public bool Static { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the backdrop is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnBackdropClick { get; set; }

    private readonly OverlayLabelContext _context = new("dialog");
    private ElementReference _dialogRef;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "dialog";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dialog");
            AppendClass(ref cls, "fixed inset-0 z-50");
            if (!Visible)
                AppendClass(ref cls, "pointer-events-none invisible");
        });

        if (Visible)
            BuildStyleAttribute(attributes, (ref sty) => AppendStyleDecl(ref sty, "display: flex"));

        attributes["tabindex"] = -1;
        attributes["data-state"] = Visible ? "open" : "closed";

        if (Static)
            attributes["data-backdrop"] = "static";
    }

    private Dictionary<string, object> BuildDialogAttributes()
    {
        var attributes = new Dictionary<string, object>();

        attributes["data-slot"] = "dialog-content";
        attributes["id"] = _context.ContentId;
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dialog-panel");
            AppendClass(ref cls, "fixed top-[50%] left-[50%] z-50 grid w-full max-w-[calc(100%-2rem)] translate-x-[-50%] translate-y-[-50%] gap-4 rounded-lg border bg-background p-6 shadow-lg duration-200 outline-none sm:max-w-lg");
            AppendClass(ref cls, "data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95");
            if (Scrollable)
                AppendClass(ref cls, "max-h-[90vh] overflow-y-auto");
            if (DialogSize != null && !string.IsNullOrEmpty(DialogSize.Value))
            {
                var size = DialogSize.Value.ToLowerInvariant();
                if (size == "sm") AppendClass(ref cls, "sm:max-w-sm");
                else if (size == "lg") AppendClass(ref cls, "sm:max-w-2xl");
                else if (size == "xl") AppendClass(ref cls, "sm:max-w-4xl");
            }
        });

        attributes["role"] = "dialog";
        attributes["aria-modal"] = "true";
        attributes["tabindex"] = -1;
        attributes["data-state"] = Visible ? "open" : "closed";

        if (_context.HasTitle)
            attributes["aria-labelledby"] = _context.TitleId;

        if (_context.HasDescription)
            attributes["aria-describedby"] = _context.DescriptionId;

        return attributes;
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _context.StateChanged += OnContextStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Visible)
            SetOverlayContentElement(_dialogRef);

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnContextStateChanged()
    {
        await RefreshOffThread();
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (!Static && e.Key == "Escape")
        {
            await Hide();
        }
    }

    private async Task HandleBackdropClick(MouseEventArgs args)
    {
        if (!Static)
        {
            await OnBackdropClick.InvokeIfHasDelegate();
            await Hide();
        }
    }

    /// <summary>
    /// Shows the dialog.
    /// </summary>
    public async Task Show()
    {
        if (!Visible)
        {
            Visible = true;

            await VisibleChanged.InvokeAsync(Visible);
            await OnShow.InvokeIfHasDelegate();
            await RefreshOffThread();
        }
    }

    /// <summary>
    /// Hides the dialog.
    /// </summary>
    public async Task Hide()
    {
        if (Visible)
        {
            Visible = false;

            await VisibleChanged.InvokeAsync(Visible);
            await OnHide.InvokeIfHasDelegate();
            await RefreshOffThread();
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Centered);
        hc.Add(Scrollable);
        hc.Add(DialogSize);
        hc.Add(Static);
        hc.Add(Visible);
        hc.Add(_context.ContentId);
        hc.Add(_context.HasTitle);
        hc.Add(_context.HasDescription);
        hc.Add(_context.TitleId);
        hc.Add(_context.DescriptionId);
    }

    public override void Dispose()
    {
        _context.StateChanged -= OnContextStateChanged;
        base.Dispose();
    }
}