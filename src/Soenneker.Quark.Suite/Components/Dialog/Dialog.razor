@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements IDialog

<BradixDialog Open="@Visible"
              OpenChanged="HandleOpenChanged"
              Modal="@TrapFocus">
    <CascadingValue Name="ParentDialog" Value="@this">
        @ChildContent
    </CascadingValue>
</BradixDialog>

@code {
    /// <summary>
    /// Gets or sets whether the dialog should be centered vertically.
    /// </summary>
    [Parameter]
    public bool Centered { get; set; }

    /// <summary>
    /// Gets or sets whether the dialog content should be scrollable.
    /// </summary>
    [Parameter]
    public bool Scrollable { get; set; }

    /// <summary>
    /// Gets or sets the size of the dialog.
    /// </summary>
    [Parameter]
    public DialogSize? DialogSize { get; set; }

    /// <summary>
    /// Gets or sets whether the dialog backdrop is static (doesn't close on click).
    /// </summary>
    [Parameter]
    public bool Static { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the backdrop is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnBackdropClick { get; set; }

    /// <summary>
    /// Shows the dialog.
    /// </summary>
    public async Task Show()
    {
        await SetVisibleAsync(true);
    }

    /// <summary>
    /// Hides the dialog.
    /// </summary>
    public async Task Hide()
    {
        await SetVisibleAsync(false);
    }

    private Task HandleOpenChanged(bool open)
    {
        return SetVisibleAsync(open);
    }

    private async Task SetVisibleAsync(bool visible)
    {
        if (Visible == visible)
            return;

        Visible = visible;

        if (VisibleChanged.HasDelegate)
            await VisibleChanged.InvokeAsync(Visible);

        if (visible)
            await OnShow.InvokeIfHasDelegate();
        else
            await OnHide.InvokeIfHasDelegate();

        await RefreshOffThread();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Centered);
        hc.Add(Scrollable);
        hc.Add(DialogSize);
        hc.Add(Static);
        hc.Add(Visible);
    }

}