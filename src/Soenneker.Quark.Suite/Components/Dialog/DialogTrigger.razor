@namespace Soenneker.Quark
@inherits Soenneker.Quark.TriggerElement

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <button type="button" @ref="_elementRef" @onclick="HandleActivate" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _elementRef;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "dialog-trigger";
        attributes["aria-haspopup"] = "dialog";
        attributes["aria-expanded"] = ParentDialog?.Visible == true ? "true" : "false";

        if (Disabled)
            attributes["disabled"] = true;

        if (Context is not null)
            attributes["aria-controls"] = Context.ContentId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-dialog-trigger");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            IsOpen = ParentDialog?.Visible == true,
            DataState = ParentDialog?.Visible == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = Context?.ContentId,
            RegisterElement = elementReference => _elementRef = elementReference,
            Toggle = ParentDialog is null
                ? null
                : async () =>
                {
                    if (ParentDialog.Visible)
                    {
                        await ParentDialog.Hide();
                    }
                    else
                    {
                        ParentDialog.SetRestoreFocusTarget(_elementRef);
                        await ParentDialog.Show();
                    }
                },
            Open = ParentDialog is null ? null : async () =>
            {
                ParentDialog.SetRestoreFocusTarget(_elementRef);
                await ParentDialog.Show();
            },
            Close = ParentDialog is null ? null : () => ParentDialog.Hide()
        };
    }

    private async Task HandleActivate(MouseEventArgs args)
    {
        if (!Disabled && ParentDialog is not null)
        {
            ParentDialog.SetRestoreFocusTarget(_elementRef);
            await ParentDialog.Show();
        }

        await base.HandleClick(args);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(Disabled);
        hc.Add(ParentDialog?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
