@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TriggerElement

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixDialogTrigger Disabled="@Disabled"
                         OnClick="@OnClick"
                         AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixDialogTrigger>
}

@code {
    [CascadingParameter(Name = nameof(ParentDialog))]
    public Dialog? ParentDialog { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "dialog-trigger";
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("id");
        attributes.Remove("onclick");

        return attributes;
    }

    private static string? GetOverlayTriggerId(OverlayLabelContext? context) =>
        context?.ContentId is { } contentId ? BlazorIdGenerator.Child(contentId, "trigger") : null;

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            DataSlot = "dialog-trigger",
            TriggerId = GetOverlayTriggerId(Context),
            ParentDisabled = Disabled,
            IsOpen = ParentDialog?.Visible == true,
            DataState = ParentDialog?.Visible == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = Context?.ContentId,
            RegisterElement = elementReference =>
            {
                if (BradixDialog is not null)
                    BradixDialog.RegisterTrigger(elementReference, GetOverlayTriggerId(Context));
            },
            Toggle = ParentDialog is null
                ? null
                : async () =>
                {
                    if (ParentDialog.Visible)
                    {
                        await ParentDialog.Hide();
                    }
                    else
                    {
                        await ParentDialog.Show();
                    }
                },
            Open = ParentDialog is null ? null : () => ParentDialog.Show(),
            Close = ParentDialog is null ? null : () => ParentDialog.Hide()
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(Disabled);
        hc.Add(ParentDialog);
        hc.Add(BradixDialog);
        hc.Add(Context);
        hc.Add(ParentDialog?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
