@namespace Soenneker.Quark
@inherits Element

<th @onclick="HandleClick" @attributes="BuildAttributes()">
	@ChildContent @(Sortable ? GetSortIndicator() : string.Empty)
</th>

@code {
	[CascadingParameter(Name = nameof(DataTable))]
	private IDataTable? DataTable { get; set; }

	/// <summary>
	/// Gets or sets whether the column is sortable.
	/// </summary>
	[Parameter]
	public bool Sortable { get; set; }

	/// <summary>
	/// Gets or sets whether the column is searchable.
	/// </summary>
	[Parameter]
	public bool Searchable { get; set; }

	/// <summary>
	/// Gets or sets the text alignment for the column.
	/// </summary>
	[Parameter]
	public string HeaderAlign { get; set; } = string.Empty;

	/// <summary>
	/// Gets or sets the data attribute value.
	/// </summary>
	[Parameter]
	public string? Data { get; set; }

	[Parameter]
	public string? Name { get; set; }

	private int _columnIndex = -1;

	protected override void OnInitialized()
	{
		// Register this column with the parent table to get its position
		if (DataTable != null)
		{
			_columnIndex = DataTable.RegisterColumn(this);
		}
	}

	private async Task HandleClick(MouseEventArgs e)
	{
		if (!Sortable || DataTable == null)
			return;

		await DataTable.HandleColumnSort(_columnIndex);
	}

	private string GetSortClass()
	{
		if (DataTable == null)
			return string.Empty;

		return DataTable.GetSortClassByIndex(_columnIndex);
	}

	private string GetSortIndicator()
	{
		if (DataTable == null)
			return " ↕";

		return DataTable.GetSortIndicatorByIndex(_columnIndex);
	}

	private string GetAlignStyle()
	{
		if (HeaderAlign.IsNullOrWhiteSpace())
			return string.Empty;

		var align = HeaderAlign.ToLowerInvariantFast();

		return align switch
		{
			"left" => "text-align: left;",
			"center" => "text-align: center;",
			"right" => "text-align: right;",
			_ => string.Empty
		};
	}

	protected override void ApplyDefaultParameters()
	{
		base.ApplyDefaultParameters();
		DataSlot ??= "table-head";
		Height ??= Quark.Height.Is10;
		Padding ??= Quark.Padding.OnX.Is2;
		TextAlign ??= Quark.TextAlign.Left;
		VerticalAlign ??= Quark.VerticalAlign.Middle;
		FontWeight ??= Quark.FontWeight.Medium;
		Whitespace ??= Quark.Whitespace.Nowrap;
		TextColor ??= Quark.TextColor.Foreground;

	}

	protected override void BuildAttributesCore(Dictionary<string, object> attributes)
	{
		base.BuildAttributesCore(attributes);


		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "[&:has([role=checkbox])]:pr-0");
			if (Sortable)
			{
				var sortClass = GetSortClass();
				if (sortClass.HasContent())
					AppendClass(ref cls, sortClass);
			}
		});

		var alignStyle = GetAlignStyle();
		if (Sortable || alignStyle.HasContent())
		{
			BuildStyleAttribute(attributes, (ref sty) =>
			{
				if (Sortable)
					AppendStyleDecl(ref sty, "cursor:pointer;");
				
				if (alignStyle.HasContent())
					AppendStyleDecl(ref sty, alignStyle);
			});
		}
	}

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
		base.ComputeRenderKeyCore(ref hc);
		hc.Add(Sortable);
		hc.Add(Searchable);
		hc.Add(HeaderAlign);
		hc.Add(Data);
		hc.Add(Name);
		hc.Add(_columnIndex);
	}
}