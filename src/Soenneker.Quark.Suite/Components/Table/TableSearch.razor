@using Soenneker.Utils.Debounce

@namespace Soenneker.Quark
@inherits CancellableElement

<div @attributes="BuildAttributes()">
	<input type="text"
	       data-slot="table-search-input"
	       aria-label="@(AriaLabel ?? "Search table")"
	       value="@SearchTerm"
	       @oninput="OnSearchInputHandler"
	       placeholder="@Placeholder"
	       class="flex h-8 w-full min-w-0 rounded-lg border border-input bg-transparent px-2.5 py-1 text-base transition-colors outline-none placeholder:text-muted-foreground disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-50 md:text-sm focus-visible:border-ring focus-visible:ring-ring/50 focus-visible:ring-[3px]" />
</div>

@code {
	// shadcn input in table toolbar - new-york-v4 ui/input.tsx
	protected override void BuildAttributesCore(Dictionary<string, object> attributes)
	{
		attributes["data-slot"] = "table-search";
		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "flex w-full items-center gap-2 sm:max-w-sm");
		});
	}

	[CascadingParameter(Name = "Table")]
	private ITable? Table { get; set; }

	[Parameter]
	public string SearchTerm { get; set; } = string.Empty;

	[Parameter]
	public EventCallback<string> SearchTermChanged { get; set; }

	[Parameter]
	public EventCallback<string> OnSearch { get; set; }

	[Parameter]
	public string Placeholder { get; set; } = "Search...";

	public int DebounceMs { get; set; } = 300;

	private readonly Debouncer _debouncer = new();

	private Task OnSearchInputHandler(ChangeEventArgs e)
	{
		var newSearchTerm = e.Value?.ToString() ?? string.Empty;

		// Update the SearchTerm immediately for binding
		if (SearchTerm != newSearchTerm)
		{
			SearchTerm = newSearchTerm;
		}

		_debouncer.Debounce(DebounceMs, async _ =>
		{
			// First, notify the parent Table if available
			if (Table != null)
			{
				await Table.HandleSearch(newSearchTerm);
			}

			// Then, invoke the OnSearch callback if provided
			if (OnSearch.HasDelegate)
				await OnSearch.InvokeAsync(newSearchTerm);
		}, false, CancellationToken);

		if (SearchTermChanged.HasDelegate)
			return SearchTermChanged.InvokeAsync(newSearchTerm);

		return Task.CompletedTask;
	}

	public override async ValueTask DisposeAsync()
	{
		await base.DisposeAsync();

		await _debouncer.DisposeAsync();
	}

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
		base.ComputeRenderKeyCore(ref hc);
		hc.Add(SearchTerm);
		hc.Add(Placeholder);
		hc.Add(AriaLabel);
		hc.Add(DebounceMs);
	}
}
