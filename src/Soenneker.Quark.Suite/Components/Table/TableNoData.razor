
@namespace Soenneker.Quark
@inherits Element

@if (Table?.HasLoadedOnce == true)
{
    <div @attributes="BuildAttributes()">
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else
        {
            <div class="flex max-w-md flex-col items-center gap-4 text-center" data-slot="table-empty-content">
                <div class="text-muted-foreground opacity-60" data-slot="table-empty-icon">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3 3H21V21H3V3ZM5 5V19H19V5H5ZM7 7H17V9H7V7ZM7 11H17V13H7V11ZM7 15H13V17H7V15Z" fill="currentColor" />
                    </svg>
                </div>
                <div class="flex flex-col gap-1" data-slot="table-empty-text">
                    <H4>No data available</H4>
                    <Paragraph>There are no records to display at this time.</Paragraph>
                </div>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter(Name = "Table")]
    public ITable? Table { get; set; }

    // shadcn Empty state - new-york-v4 ui/empty.tsx
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        TextColor ??= Quark.TextColor.MutedForeground;
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Card;
        Padding ??= Quark.Padding.Is4.OnX.Token("12").OnY;
        TextAlign ??= Quark.TextAlign.Center;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "table-empty";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "[&>*]:mx-auto");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        if (Table is not null)
            hc.Add(Table.HasLoadedOnce);
    }
} 
