
@namespace Soenneker.Quark
@inherits Element

@if (Table?.HasLoadedOnce == true)
{
    <div @attributes="BuildAttributes()">
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else
        {
            <Div DataSlot="table-empty-content" Display="Quark.Display.Flex" MaxWidth="Quark.MaxWidth.IsMd" FlexDirection="Quark.FlexDirection.Col" ItemsAlign="Items.Center" Gap="Quark.Gap.Is4" TextAlign="Quark.TextAlign.Center">
                <Div DataSlot="table-empty-icon" TextColor="Quark.TextColor.MutedForeground" Opacity="Quark.Opacity.Is60">
                    <Icon Name="LucideIcon.TableProperties" Size="Quark.Size.Is12" aria-hidden="true" />
                </Div>
                <Div DataSlot="table-empty-text" Display="Quark.Display.Flex" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is1">
                    <H4>No data available</H4>
                    <Paragraph>There are no records to display at this time.</Paragraph>
                </Div>
            </Div>
        }
    </div>
}

@code {
    [CascadingParameter(Name = "Table")]
    public ITable? Table { get; set; }

    // shadcn Empty state - new-york-v4 ui/empty.tsx
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "table-empty";
        TextColor ??= Quark.TextColor.MutedForeground;
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Card;
        Padding ??= Quark.Padding.OnX.Is4.OnY.Token("12");
        TextAlign ??= Quark.TextAlign.Center;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "[&>*]:mx-auto");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        if (Table is not null)
            hc.Add(Table.HasLoadedOnce);
    }
} 
