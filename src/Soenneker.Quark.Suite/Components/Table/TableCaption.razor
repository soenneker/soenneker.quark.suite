@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

<caption @attributes="BuildAttributes()">
    @ChildContent
</caption>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "table-caption";
        TextColor ??= Quark.TextColor.MutedForeground;
        TextSize ??= Quark.TextSize.Sm;
        Margin ??= Quark.Margin.Is4.FromTop;

    }
}