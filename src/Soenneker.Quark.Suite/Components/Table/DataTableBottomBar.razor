
@namespace Soenneker.Quark
@inherits Element

<Div Width="Quark.Width.IsFull">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</Div>

@code {
    [Parameter]
    public string LayoutClass { get; set; } = string.Empty;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "datatable-bottom-bar";
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Between;
        Gap ??= Quark.Gap.Is3;
        FlexWrap ??= Quark.FlexWrap.Wrap;
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Is1;
        BackgroundColor ??= Quark.BackgroundColor.Card;
        Padding ??= Quark.Padding.OnY.Is2.OnX.Is3;

    }

    // shadcn table footer bar - new-york-v4 ui/table.tsx
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (LayoutClass.HasContent())
                AppendClass(ref cls, LayoutClass);
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(LayoutClass);
    }
}
