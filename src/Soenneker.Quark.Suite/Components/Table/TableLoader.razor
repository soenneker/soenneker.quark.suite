@namespace Soenneker.Quark
@inherits Element

@if (IsLoading)
{
    <div @attributes="BuildAttributes()">
        <Div data-slot="table-loader-overlay"
             Position="Quark.Position.Absolute"
             Inset="Quark.Inset.Is0"
             Display="Quark.Display.Flex"
             ItemsAlign="Items.Center"
             Justify="Quark.Justify.Center"
             Class="bg-background/70 backdrop-blur-[2px]">
            <Div data-slot="table-loader-content"
                 Display="Quark.Display.Flex"
                 MinWidth='Quark.MinWidth.Token("[120px]")'
                 ItemsAlign="Items.Center"
                 Justify="Quark.Justify.Center"
                 Rounded="Quark.Rounded.Lg"
                 Border="Quark.Border.Default"
                 BackgroundColor="Quark.BackgroundColor.Card"
                 Padding="Quark.Padding.Is6"
                 Shadow="Quark.Shadow.Sm"
                 Class="min-h-20"
                 role="status"
                 aria-live="polite"
                 aria-label="@Label">
                <Div data-slot="table-loader-default" Display="Quark.Display.Flex" ItemsAlign="Items.Center" Gap="Quark.Gap.Is2" TextColor="Quark.TextColor.MutedForeground">
                    <Div data-slot="table-spinner" Height="Quark.Height.Is8" Width='Quark.Width.Token("8")' Animation="Quark.Animation.Spin" Rounded="Quark.Rounded.Full" Border="Quark.Border.Is2" BorderColor="Quark.BorderColor.Border" Class="border-t-primary"></Div>
                    <Span TextSize="Quark.TextSize.Sm">Loading...</Span>
                </Div>
                @ChildContent
            </Div>
        </Div>
    </div>
}

@code {
	[CascadingParameter(Name = nameof(IsLoading))]
	public bool IsLoading { get; set; }

	private bool _lastIsLoading;

	protected override bool ShouldRender()
	{
		if (QuarkOptions.AlwaysRender)
			return true;

		if (IsLoading != _lastIsLoading)
		{
			_lastIsLoading = IsLoading;
			return true;
		}

		return base.ShouldRender();
	}

	// shadcn Skeleton/Spinner overlay - new-york-v4 ui/skeleton.tsx + spinner
	[Parameter]
	public string Label { get; set; } = "Loading table data";

	protected override void ApplyDefaultParameters()
	{
		base.ApplyDefaultParameters();
		Position ??= Quark.Position.Absolute;
		Inset ??= Quark.Inset.Is0;

	}

	protected override void BuildAttributesCore(Dictionary<string, object> attributes)
	{
		base.BuildAttributesCore(attributes);

		attributes["data-slot"] = "table-loader";
		BuildClassAttribute(attributes, (ref cls) =>
		{
			if (IsLoading)
				AppendClass(ref cls, "z-10");
		});
	}

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
		base.ComputeRenderKeyCore(ref hc);
		hc.Add(IsLoading);
		hc.Add(Label);
	}
}
