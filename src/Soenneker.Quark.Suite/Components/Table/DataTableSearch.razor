@using Soenneker.Utils.Debounce

@namespace Soenneker.Quark
@inherits CancellableElement

<div @attributes="BuildAttributes()">
	<Input Type="text"
	       Value="@SearchTerm"
	       OnInput="OnSearchInputHandler"
	       Placeholder="@Placeholder"
	       Height="Quark.Height.Is8"
	       Width="Quark.Width.IsFull"
	       MinWidth="Quark.MinWidth.Is0"
	       Rounded="Quark.Rounded.Lg"
	       Border="Quark.Border.Default"
	       BorderColor="Quark.BorderColor.Input.OnFocusVisible.Ring"
	       BackgroundColor="Quark.BackgroundColor.Transparent"
	       Padding="Quark.Padding.OnX.Is2_5.OnY.Is1"
	       TextSize="Quark.TextSize.Base.OnMd.Sm"
	       TextColor='Quark.TextColor.MutedForeground.Modifier("placeholder")'
	       RingColor="Quark.RingColor.OnFocusVisible.Ring50"
	       PointerEvents="Quark.PointerEvents.None.OnDisabled"
	       Cursor="Quark.Cursor.NotAllowed.OnDisabled"
	       Opacity="Quark.Opacity.Is50.OnDisabled"
	       Transition="Quark.Transition.Colors"
	       OutlineStyle="Quark.OutlineStyle.None"
	       Attributes="BuildInputAttributes()" />
</div>

@code {
	// shadcn input in table toolbar - new-york-v4 ui/input.tsx
	protected override void ApplyDefaultParameters()
	{
		base.ApplyDefaultParameters();
		DataSlot ??= "data-table-search";
		Display ??= Quark.Display.Flex;
		Width ??= Quark.Width.IsFull;
		ItemsAlign ??= Items.Center;
		Gap ??= Quark.Gap.Is2;

	}

	protected override void BuildAttributesCore(Dictionary<string, object> attributes)
	{
		base.BuildAttributesCore(attributes);

		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "sm:max-w-sm");
		});
	}

	private Dictionary<string, object> BuildInputAttributes()
	{
		var attributes = new Dictionary<string, object>
		{
			["data-slot"] = "data-table-search-input",
			["aria-label"] = AriaLabel ?? "Search table"
		};

		BuildClassAttribute(attributes, (ref cls) =>
		{
			AppendClass(ref cls, "focus-visible:ring-[3px]");
		});

		return attributes;
	}

	[CascadingParameter(Name = "DataTable")]
	private IDataTable? DataTable { get; set; }

	[Parameter]
	public string SearchTerm { get; set; } = string.Empty;

	[Parameter]
	public EventCallback<string> SearchTermChanged { get; set; }

	[Parameter]
	public EventCallback<string> OnSearch { get; set; }

	[Parameter]
	public string Placeholder { get; set; } = "Search...";

	public int DebounceMs { get; set; } = 300;

	private readonly Debouncer _debouncer = new();

	private Task OnSearchInputHandler(ChangeEventArgs e)
	{
		var newSearchTerm = e.Value?.ToString() ?? string.Empty;

		// Update the SearchTerm immediately for binding
		if (SearchTerm != newSearchTerm)
		{
			SearchTerm = newSearchTerm;
		}

		_debouncer.Debounce(DebounceMs, async _ =>
		{
			// First, notify the parent DataTable if available
			if (DataTable != null)
			{
				await DataTable.HandleSearch(newSearchTerm);
			}

			// Then, invoke the OnSearch callback if provided
			if (OnSearch.HasDelegate)
				await OnSearch.InvokeAsync(newSearchTerm);
		}, false, CancellationToken);

		if (SearchTermChanged.HasDelegate)
			return SearchTermChanged.InvokeAsync(newSearchTerm);

		return Task.CompletedTask;
	}

	public override async ValueTask DisposeAsync()
	{
		await base.DisposeAsync();

		await _debouncer.DisposeAsync();
	}

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
		base.ComputeRenderKeyCore(ref hc);
		hc.Add(SearchTerm);
		hc.Add(Placeholder);
		hc.Add(AriaLabel);
		hc.Add(DebounceMs);
	}
}
