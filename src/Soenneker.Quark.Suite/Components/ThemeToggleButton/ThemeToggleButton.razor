@namespace Soenneker.Quark

<Button Type="ButtonType.Button"
        Variant="ButtonVariant.Ghost"
        Size="ButtonSize.Icon"
        data-slot="button"
        Class="group/toggle extend-touch-target size-8"
        OnClick="@(_ => HandleClick())"
        aria-label="@AriaLabel">
    <Svg BoxSize='Quark.Size.Token("4.5")' NativeWidth="24" NativeHeight="24" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round" aria-hidden="true">
        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
        <path d="M12 12m-9 0a9 9 0 1 0 18 0a9 9 0 1 0 -18 0" />
        <path d="M12 3l0 18" />
        <path d="M12 9l4.65 -4.65" />
        <path d="M12 14.3l7.37 -7.37" />
        <path d="M12 19.6l8.85 -8.85" />
    </Svg>
    <Span ScreenReader="Quark.ScreenReader.Only">@AriaLabel</Span>
</Button>

@code {
    [Parameter]
    public bool IsDark { get; set; }

    [Parameter]
    public string AriaLabel { get; set; } = "Toggle theme";

    [Parameter]
    public EventCallback OnClick { get; set; }

    private Task HandleClick()
    {
        return OnClick.InvokeAsync();
    }
}
