@namespace Soenneker.Quark

<Button Type="@ButtonType.Button"
        Variant="ButtonVariant.Ghost"
        ButtonSize="ButtonSize.Icon"
        DataSlot="button"
        data-state="@ThemeState"
        Size="Quark.Size.Is8"
        Class="group/toggle extend-touch-target relative overflow-hidden"
        OnClick="@(_ => HandleClick())"
        aria-label="@AriaLabel">
    <Span Class="relative grid size-4.5 place-items-center overflow-hidden" aria-hidden="true">
        <Span Class="@SunClass">
            <Icon Name="LucideIcon.Sun" Class="size-4.5" />
        </Span>
        <Span Class="@MoonClass">
            <Icon Name="LucideIcon.Moon" Class="size-4.5" />
        </Span>
    </Span>
    <Span ScreenReader="Quark.ScreenReader.Only">@AriaLabel</Span>
</Button>

@code {
    [Parameter]
    public bool IsDark { get; set; }

    [Parameter]
    public string AriaLabel { get; set; } = "Toggle theme";

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string ThemeState => IsDark ? "dark" : "light";

    private string SunClass => GetIconClass(!IsDark, "-rotate-90");

    private string MoonClass => GetIconClass(IsDark, "rotate-90");

    private Task HandleClick()
    {
        return OnClick.InvokeAsync();
    }

    private static string GetIconClass(bool active, string inactiveRotation)
    {
        const string baseClass = "absolute inset-0 grid place-items-center transition-all duration-300 ease-out";

        return active
            ? $"{baseClass} rotate-0 scale-100 opacity-100"
            : $"{baseClass} {inactiveRotation} scale-0 opacity-0";
    }
}
