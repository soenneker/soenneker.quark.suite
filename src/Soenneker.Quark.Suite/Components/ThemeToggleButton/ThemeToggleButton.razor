@namespace Soenneker.Quark

<Button Type="@ButtonType.Button"
        Variant="ButtonVariant.Ghost"
        Size="ButtonSize.Icon"
        @onclick="HandleClick"
        class="hidden lg:flex"
        aria-label="@AriaLabel">
    @if (IsDark)
    {
        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 3a6 6 0 1 0 9 9 9 9 0 1 1-9-9z" />
        </svg>
    }
    else
    {
        <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2" />
            <path d="M12 20v2" />
            <path d="m4.93 4.93 1.41 1.41" />
            <path d="m17.66 17.66 1.41 1.41" />
            <path d="M2 12h2" />
            <path d="M20 12h2" />
            <path d="m6.34 17.66-1.41 1.41" />
            <path d="m19.07 4.93-1.41 1.41" />
        </svg>
    }
</Button>

@code {
    [Parameter]
    public bool IsDark { get; set; }

    [Parameter]
    public string AriaLabel { get; set; } = "Toggle theme";

    [Parameter]
    public EventCallback OnClick { get; set; }

    private Task HandleClick()
    {
        return OnClick.InvokeAsync();
    }
}
