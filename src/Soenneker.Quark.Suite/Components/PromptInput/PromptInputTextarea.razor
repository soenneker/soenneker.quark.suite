@namespace Soenneker.Quark
@using System.Linq
@using Microsoft.JSInterop
@inherits Soenneker.Quark.Component
@implements IAsyncDisposable
@inject IPromptInputInterop PromptInputInterop

<textarea @ref="_element"
          @attributes="TextareaAttributes"
          value="@Value"
          placeholder="@Placeholder"
          rows="@Rows"
          @oninput="HandleInput"
          @onkeydown="HandleKeyDown"></textarea>

@code {
    private ElementReference _element;
    private bool _registered;

    [CascadingParameter]
    public PromptInput? PromptInput { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "How can I help you today?";

    [Parameter]
    public int? Rows { get; set; } = 2;

    private IReadOnlyDictionary<string, object> TextareaAttributes
    {
        get
        {
            var attributes = new Dictionary<string, object>(BuildAttributes());
            attributes.TryGetValue("class", out var existingClass);
            attributes["aria-label"] = "Message input";
            attributes["data-slot"] = DataSlot ?? "prompt-input-textarea";
            attributes["class"] = string.Join(" ", new[]
            {
                "field-sizing-content min-h-14 max-h-40 w-full resize-none border-0 bg-transparent px-4 py-4 text-sm leading-6 font-normal text-primary shadow-none outline-none placeholder:text-muted-foreground focus-visible:ring-0 focus-visible:ring-offset-0 dark:bg-transparent",
                existingClass?.ToString()
            }.Where(x => !string.IsNullOrWhiteSpace(x)));

            return attributes;
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey && PromptInput is not null)
            await PromptInput.Submit(Value);
    }

    private async Task HandleInput(ChangeEventArgs args)
    {
        var value = args.Value?.ToString();
        Value = value;
        PromptInput?.SetValue(value);
        await ValueChanged.InvokeAsync(value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        await PromptInputInterop.RegisterTextarea(_element);
        _registered = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Placeholder);
        hc.Add(Rows);
    }

    protected override async ValueTask OnDisposeAsync()
    {
        if (!_registered)
            return;

        try
        {
            await PromptInputInterop.UnregisterTextarea(_element);
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
