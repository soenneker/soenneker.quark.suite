@namespace Soenneker.Quark
@inherits Soenneker.Quark.Component

@if (PromptInput is not null && PromptInput.Attachments.Count > 0)
{
    <Attachments Variant="@Variant" @attributes="BuildAttributes()">
        @foreach (PromptInputAttachmentInfo attachment in PromptInput.Attachments)
        {
            if (AttachmentTemplate is not null)
            {
                @AttachmentTemplate(attachment)
            }
            else
            {
                <Attachment Name="@attachment.Name" Description="@attachment.Description" Variant="@AttachmentVariant">
                    <Button Type="ButtonType.Button"
                            Size="ButtonSize.IconXs"
                            Variant="ButtonVariant.Ghost"
                            aria-label="@($"Remove {attachment.Name}")"
                            OnClick="@(() => PromptInput.RemoveAttachment(attachment.Id))">
                        <Icon Name="LucideIcon.X" />
                    </Button>
                </Attachment>
            }
        }
    </Attachments>
}

@code {
    [CascadingParameter]
    public PromptInput? PromptInput { get; set; }

    [CascadingParameter(Name = "PromptInputAttachmentsVersion")]
    public int AttachmentsVersion { get; set; }

    [Parameter]
    public string Variant { get; set; } = "inline";

    [Parameter]
    public string AttachmentVariant { get; set; } = "inline";

    [Parameter]
    public RenderFragment<PromptInputAttachmentInfo>? AttachmentTemplate { get; set; }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AttachmentsVersion);
        hc.Add(Variant);
        hc.Add(AttachmentVariant);
        hc.Add(PromptInput?.Attachments.Count);
    }
}
