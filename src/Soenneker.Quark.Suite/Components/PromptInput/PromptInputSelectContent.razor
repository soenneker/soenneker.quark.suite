@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix

<SelectContent ContentPosition="@ContentPosition"
               Side="@Side"
               SideOffset="@SideOffset"
               Align="@Align"
               @attributes="BuildAttributes()">
    @ChildContent
</SelectContent>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "prompt-input-select-content";
    }

    [Parameter]
    public SelectPosition ContentPosition { get; set; } = SelectPosition.Popper;

    [Parameter]
    public Side Side { get; set; } = Side.Top;

    [Parameter]
    public int SideOffset { get; set; } = 8;

    [Parameter]
    public Alignment Align { get; set; } = Alignment.Start;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ContentPosition);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(Align);
    }
}