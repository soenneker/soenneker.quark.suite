@namespace Soenneker.Quark

<SelectContent ContentPosition="@ContentPosition"
               Side="@Side"
               SideOffset="@SideOffset"
               PlacementAlign="@PlacementAlign"
               data-slot="prompt-input-select-content"
               @attributes="Attributes">
    @ChildContent
</SelectContent>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string ContentPosition { get; set; } = "popper";

    [Parameter]
    public string Side { get; set; } = "top";

    [Parameter]
    public int SideOffset { get; set; } = 8;

    [Parameter]
    public string PlacementAlign { get; set; } = "start";

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? Attributes { get; set; }
}
