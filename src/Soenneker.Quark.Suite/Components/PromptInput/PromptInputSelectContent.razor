@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<SelectContent ContentPosition="@ContentPosition"
               Side="@Side"
               SideOffset="@SideOffset"
               PlacementAlign="@PlacementAlign"
               @attributes="BuildAttributes()">
    @ChildContent
</SelectContent>

@code {
    [Parameter]
    public string ContentPosition { get; set; } = "popper";

    [Parameter]
    public string Side { get; set; } = "top";

    [Parameter]
    public int SideOffset { get; set; } = 8;

    [Parameter]
    public string PlacementAlign { get; set; } = "start";

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "prompt-input-select-content";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ContentPosition);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(PlacementAlign);
    }
}
