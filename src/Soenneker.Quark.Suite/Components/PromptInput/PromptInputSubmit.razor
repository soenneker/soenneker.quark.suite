@namespace Soenneker.Quark

<div data-slot="prompt-input-button">
    <Button Type="ButtonType.Submit" Size="@Size" Variant="@Variant" Disabled="@Disabled" Loading="@Loading" aria-label="@Label" data-slot="prompt-input-submit" @attributes="Attributes">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <Icon Name="@IconName" />
        }
    </Button>
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string Label { get; set; } = "Send message";

    [Parameter]
    public LucideIcon IconName { get; set; } = LucideIcon.ArrowUp;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? Size { get; set; } = ButtonSize.IconSm;

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? Attributes { get; set; }
}
