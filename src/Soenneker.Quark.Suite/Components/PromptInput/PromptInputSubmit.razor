@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div data-slot="prompt-input-button">
    <Button Type="@ButtonType.Submit" ButtonSize="@ButtonSize" Variant="@Variant" Disabled="@Disabled" Loading="@Loading" aria-label="@Label" @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <Icon Name="@IconName" />
        }
    </Button>
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "prompt-input-submit";
    }

    [Parameter]
    public string Label { get; set; } = "Send message";

    [Parameter]
    public LucideIcon IconName { get; set; } = LucideIcon.ArrowUp;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = "icon-sm";

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(IconName);
        AddIf(ref hc, ButtonSize);
        hc.Add(Variant);
        hc.Add(Disabled);
        hc.Add(Loading);
    }
}