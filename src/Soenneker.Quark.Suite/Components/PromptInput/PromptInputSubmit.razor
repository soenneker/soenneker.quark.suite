@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div data-slot="prompt-input-button">
    <Button Type="ButtonType.Submit" Size="@Size" Variant="@Variant" Disabled="@Disabled" Loading="@Loading" aria-label="@Label" @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <Icon Name="@IconName" />
        }
    </Button>
</div>

@code {
    [Parameter]
    public string Label { get; set; } = "Send message";

    [Parameter]
    public LucideIcon IconName { get; set; } = LucideIcon.ArrowUp;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? Size { get; set; } = ButtonSize.IconSm;

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Loading { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "prompt-input-submit";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(IconName);
        AddIf(ref hc, Size);
        hc.Add(Variant);
        hc.Add(Disabled);
        hc.Add(Loading);
    }
}
