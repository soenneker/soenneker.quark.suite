@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CommandItem SearchValue="@SearchValue" Keywords="@Keywords" Disabled="@Disabled" OnSelect="@OnSelect" @attributes="BuildAttributes()">
    @ChildContent
</CommandItem>

@code {
    [Parameter] public string? SearchValue { get; set; }
    [Parameter] public string[]? Keywords { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnSelect { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "prompt-input-command-item";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SearchValue);
        hc.Add(Disabled);
    }
}
