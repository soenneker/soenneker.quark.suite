@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<HoverCardContent ForceMount="@ForceMount"
                  Side="@Side"
                  PlacementAlign="@PlacementAlign"
                  SideOffset="@SideOffset"
                  @attributes="BuildAttributes()">
    @ChildContent
</HoverCardContent>

@code {
    [Parameter] public bool ForceMount { get; set; }
    [Parameter] public string Side { get; set; } = "top";
    [Parameter] public string PlacementAlign { get; set; } = "start";
    [Parameter] public int SideOffset { get; set; } = 8;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "prompt-input-hover-card-content";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ForceMount);
        hc.Add(Side);
        hc.Add(PlacementAlign);
        hc.Add(SideOffset);
    }
}
