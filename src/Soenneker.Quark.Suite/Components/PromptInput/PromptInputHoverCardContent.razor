@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix

<HoverCardContent ForceMount="@ForceMount"
                  Side="@Side"
                  Align="@Align"
                  SideOffset="@SideOffset"
                  @attributes="BuildAttributes()">
    @ChildContent
</HoverCardContent>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "prompt-input-hover-card-content";
    }

    [Parameter] public bool ForceMount { get; set; }
    [Parameter] public Side Side { get; set; } = Side.Top;
    [Parameter] public Alignment Align { get; set; } = Alignment.Start;
    [Parameter] public int SideOffset { get; set; } = 8;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ForceMount);
        hc.Add(Side);
        hc.Add(Align);
        hc.Add(SideOffset);
    }
}