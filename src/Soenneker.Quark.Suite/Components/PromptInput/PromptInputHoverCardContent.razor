@namespace Soenneker.Quark

<HoverCardContent ForceMount="@ForceMount"
                  Side="@Side"
                  PlacementAlign="@PlacementAlign"
                  SideOffset="@SideOffset"
                  data-slot="prompt-input-hover-card-content"
                  @attributes="Attributes">
    @ChildContent
</HoverCardContent>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool ForceMount { get; set; }
    [Parameter] public string Side { get; set; } = "top";
    [Parameter] public string PlacementAlign { get; set; } = "start";
    [Parameter] public int SideOffset { get; set; } = 8;
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? Attributes { get; set; }
}
