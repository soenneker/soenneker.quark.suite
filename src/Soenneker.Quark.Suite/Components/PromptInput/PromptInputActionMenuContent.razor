@namespace Soenneker.Quark

<DropdownMenu Class="@Class"
              RightAligned="@RightAligned"
              Direction="@Direction"
              data-slot="prompt-input-action-menu-content"
              @attributes="Attributes">
    <CascadingValue Value="@PromptInput" IsFixed="false">
        @ChildContent
    </CascadingValue>
</DropdownMenu>

@code {
    [CascadingParameter]
    public PromptInput? PromptInput { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public bool RightAligned { get; set; }

    [Parameter]
    public Direction Direction { get; set; } = Direction.Default;

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? Attributes { get; set; }
}
