@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix

<DropdownMenu Class="@Class"
              RightAligned="@RightAligned"
              Side="@Side"
              @attributes="BuildAttributes()">
    <CascadingValue Value="@PromptInput" IsFixed="false">
        @ChildContent
    </CascadingValue>
</DropdownMenu>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "prompt-input-action-menu-content";
    }

    [CascadingParameter]
    public PromptInput? PromptInput { get; set; }

    [Parameter]
    public bool RightAligned { get; set; }

    [Parameter]
    public Side Side { get; set; } = Side.Bottom;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(RightAligned);
        hc.Add(Side);
    }
}