@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<DropdownMenu Class="@Class"
              RightAligned="@RightAligned"
              Direction="@Direction"
              @attributes="BuildAttributes()">
    <CascadingValue Value="@PromptInput" IsFixed="false">
        @ChildContent
    </CascadingValue>
</DropdownMenu>

@code {
    [CascadingParameter]
    public PromptInput? PromptInput { get; set; }

    [Parameter]
    public bool RightAligned { get; set; }

    [Parameter]
    public Direction Direction { get; set; } = Direction.Default;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "prompt-input-action-menu-content";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(RightAligned);
        hc.Add(Direction);
    }
}
