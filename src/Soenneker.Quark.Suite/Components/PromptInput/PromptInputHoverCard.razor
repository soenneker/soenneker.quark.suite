@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<HoverCard Open="@Open"
           OpenChanged="@OpenChanged"
           DefaultOpen="@DefaultOpen"
           OpenDelay="@OpenDelay"
           CloseDelay="@CloseDelay"
           @attributes="BuildAttributes()">
    @ChildContent
</HoverCard>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "prompt-input-hover-card";
    }

    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public bool DefaultOpen { get; set; }
    [Parameter] public int OpenDelay { get; set; } = 700;
    [Parameter] public int CloseDelay { get; set; } = 300;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(DefaultOpen);
        hc.Add(OpenDelay);
        hc.Add(CloseDelay);
    }
}