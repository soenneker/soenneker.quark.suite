@namespace Soenneker.Quark
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Soenneker.Blazor.Utils.Ids
@inherits Soenneker.Quark.Element
@implements IAsyncDisposable
@inject IPromptInputInterop PromptInputInterop

<PromptInputButton>
    <Button Type="@ButtonType.Button"
            ButtonSize="@ButtonSize"
            Variant="@Variant"
            Disabled="@Disabled"
            aria-label="@Label"
            OnClick="OpenFileDialog"
            @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <Icon Name="@IconName" />
            @if (ShowLabel)
            {
                <span>@Label</span>
            }
        }
    </Button>
    <InputFile id="@_inputId"
               data-slot="prompt-input-file-input"
               data-quark-blazor-input-file="true"
               class="sr-only"
               tabindex="-1"
               accept="@EffectiveAccept"
               multiple="@EffectiveMultiple"
               aria-hidden="true"
               OnChange="HandleFilesSelected" />
</PromptInputButton>

@code {
    private readonly string _inputId = BlazorIdGenerator.New("prompt-input-file");
    private DotNetObjectReference<PromptInputActionAddAttachments>? _dotNetReference;
    private bool _registered;

    [CascadingParameter]
    public PromptInput? PromptInput { get; set; }

    [Parameter]
    public string Label { get; set; } = "Add attachments";

    [Parameter]
    public string? Accept { get; set; }

    [Parameter]
    public bool? Multiple { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool ShowLabel { get; set; }

    [Parameter]
    public LucideIcon IconName { get; set; } = LucideIcon.Paperclip;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = Soenneker.Quark.ButtonSize.IconSm;

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Ghost;

    private bool EffectiveMultiple => Multiple ?? PromptInput?.Multiple == true;

    private string? EffectiveAccept => Accept ?? PromptInput?.Accept;

    private async Task OpenFileDialog()
    {
        if (Disabled || !_registered)
            return;

        await PromptInputInterop.OpenFileDialogById(_inputId);
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs args)
    {
        if (PromptInput is null)
            return;

        PromptInputAttachmentInfo[] attachments;

        if (EffectiveMultiple)
        {
            var browserFiles = args.GetMultipleFiles();
            attachments = new PromptInputAttachmentInfo[browserFiles.Count];

            for (var i = 0; i < browserFiles.Count; i++)
            {
                attachments[i] = CreateAttachment(browserFiles[i]);
            }
        }
        else
        {
            attachments = [CreateAttachment(args.File)];
        }

        await PromptInput.AddAttachments(attachments);
    }

    private static PromptInputAttachmentInfo CreateAttachment(IBrowserFile file)
    {
        var lastModified = file.LastModified.ToUnixTimeMilliseconds();

        return new PromptInputAttachmentInfo
        {
            Id = $"{file.Name}-{file.Size}-{lastModified}",
            Name = file.Name,
            Size = file.Size,
            Type = file.ContentType,
            LastModified = lastModified
        };
    }

    [JSInvokable]
    public async Task AddAttachments(PromptInputAttachmentInfo[] attachments)
    {
        if (PromptInput is null)
            return;

        await PromptInput.AddAttachments(attachments);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        _dotNetReference = DotNetObjectReference.Create(this);
        await PromptInputInterop.RegisterAttachmentsById(_inputId, _dotNetReference, PromptInput?.GlobalDrop == true);
        _registered = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(Accept);
        hc.Add(Multiple);
        hc.Add(Disabled);
        hc.Add(ShowLabel);
        hc.Add(IconName);
        hc.Add(ButtonSize);
        hc.Add(Variant);
        hc.Add(PromptInput?.GlobalDrop);
    }

    public override async ValueTask DisposeAsync()
    {
        if (_registered)
        {
            try
            {
                await PromptInputInterop.UnregisterAttachmentsById(_inputId);
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetReference?.Dispose();
        await base.DisposeAsync();
    }
}
