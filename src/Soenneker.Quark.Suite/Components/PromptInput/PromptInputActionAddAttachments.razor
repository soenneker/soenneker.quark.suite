@namespace Soenneker.Quark
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inherits Soenneker.Quark.Element
@implements IAsyncDisposable
@inject IJSRuntime JSRuntime

<PromptInputButton>
    <Button Type="ButtonType.Button"
            Size="@Size"
            Variant="@Variant"
            Disabled="@Disabled"
            aria-label="@Label"
            OnClick="OpenFileDialog"
            @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <Icon Name="@IconName" />
            @if (ShowLabel)
            {
                <span>@Label</span>
            }
        }
    </Button>
    <InputFile id="@_inputId"
               data-slot="prompt-input-file-input"
               data-quark-blazor-input-file="true"
               class="sr-only"
               tabindex="-1"
               accept="@EffectiveAccept"
               multiple="@EffectiveMultiple"
               aria-hidden="true"
               OnChange="HandleFilesSelected" />
</PromptInputButton>

@code {
    private const string _modulePath = "./_content/Soenneker.Quark.Suite/js/promptinputinterop.js";
    private readonly string _inputId = $"prompt-input-file-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<PromptInputActionAddAttachments>? _dotNetReference;

    [CascadingParameter]
    public PromptInput? PromptInput { get; set; }

    [Parameter]
    public string Label { get; set; } = "Add attachments";

    [Parameter]
    public string? Accept { get; set; }

    [Parameter]
    public bool? Multiple { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool ShowLabel { get; set; }

    [Parameter]
    public LucideIcon IconName { get; set; } = LucideIcon.Paperclip;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? Size { get; set; } = ButtonSize.IconSm;

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Ghost;

    private bool EffectiveMultiple => Multiple ?? PromptInput?.Multiple == true;

    private string? EffectiveAccept => Accept ?? PromptInput?.Accept;

    private async Task OpenFileDialog()
    {
        if (Disabled || _module is null)
            return;

        await _module.InvokeVoidAsync("openFileDialogById", _inputId);
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs args)
    {
        if (PromptInput is null)
            return;

        IReadOnlyList<IBrowserFile> browserFiles = EffectiveMultiple ? args.GetMultipleFiles() : [args.File];
        var attachments = browserFiles.Select(file => new PromptInputAttachmentInfo
        {
            Id = $"{file.Name}-{file.Size}-{file.LastModified.ToUnixTimeMilliseconds()}",
            Name = file.Name,
            Size = file.Size,
            Type = file.ContentType,
            LastModified = file.LastModified.ToUnixTimeMilliseconds()
        }).ToArray();

        await PromptInput.AddAttachments(attachments);
    }

    [JSInvokable]
    public async Task AddAttachments(PromptInputAttachmentInfo[] attachments)
    {
        if (PromptInput is null)
            return;

        await PromptInput.AddAttachments(attachments);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!firstRender)
            return;

        _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", _modulePath);
        _dotNetReference = DotNetObjectReference.Create(this);
        await _module.InvokeVoidAsync("registerAttachmentsById", _inputId, _dotNetReference, PromptInput?.GlobalDrop == true);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(Accept);
        hc.Add(Multiple);
        hc.Add(Disabled);
        hc.Add(ShowLabel);
        hc.Add(IconName);
        AddIf(ref hc, Size);
        hc.Add(Variant);
        hc.Add(PromptInput?.GlobalDrop);
    }

    protected override async ValueTask OnDisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("unregisterAttachmentsById", _inputId);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _dotNetReference?.Dispose();
    }
}
