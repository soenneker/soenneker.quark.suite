@namespace Soenneker.Quark
@typeparam TValue
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    <Select TValue="TValue"
            SelectedValue="@SelectedValue"
            SelectedValueChanged="@SelectedValueChanged"
            DefaultItemText="@DefaultItemText"
            DefaultItemValue="@DefaultItemValue"
            Disabled="@Disabled"
            Required="@Required"
            SelectSize="@SelectSize">
        @ChildContent
    </Select>
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "prompt-input-select";
    }

    [Parameter]
    public TValue? SelectedValue { get; set; }

    [Parameter]
    public EventCallback<TValue?> SelectedValueChanged { get; set; }

    [Parameter]
    public string? DefaultItemText { get; set; }

    [Parameter]
    public TValue? DefaultItemValue { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public CssValue<SelectSizeBuilder>? SelectSize { get; set; }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedValue);
        hc.Add(DefaultItemText);
        hc.Add(DefaultItemValue);
        hc.Add(Disabled);
        hc.Add(Required);
        AddIf(ref hc, SelectSize);
    }
}