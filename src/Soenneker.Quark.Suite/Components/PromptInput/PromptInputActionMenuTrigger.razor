@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<DropdownToggle AsChild>
    <Button Type="@ButtonType.Button"
            ButtonSize="@ButtonSize"
            Variant="@Variant"
            Disabled="@Disabled"
            aria-label="@Label"
            @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            <Icon Name="@IconName" />
        }
    </Button>
</DropdownToggle>

@code {
    [Parameter]
    public string Label { get; set; } = "More actions";

    [Parameter]
    public LucideIcon IconName { get; set; } = LucideIcon.Plus;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = "icon-sm";

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Ghost;

    [Parameter]
    public bool Disabled { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        SetDefaultDataSlot("prompt-input-action-menu-trigger");
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(IconName);
        AddIf(ref hc, ButtonSize);
        hc.Add(Variant);
        hc.Add(Disabled);
    }
}
