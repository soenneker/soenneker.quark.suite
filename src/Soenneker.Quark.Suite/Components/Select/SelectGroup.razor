@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements ISelectGroup

<BradixSelectGroup AdditionalAttributes="@GroupAttributes">
    @if (Label.HasContent())
    {
        <SelectLabel>@Label</SelectLabel>
    }

    @ChildContent
</BradixSelectGroup>

@code {
    /// <summary>
    /// Gets or sets the label for the select group.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    private IReadOnlyDictionary<string, object> GroupAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Padding ??= Quark.Padding.Is1;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select-group";

        if (Disabled)
            attributes["data-disabled"] = "true";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(Disabled);
    }
}
