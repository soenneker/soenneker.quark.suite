@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements ISelectGroup

<optgroup @attributes="BuildAttributes()">
    @ChildContent
</optgroup>

@code {
    /// <summary>
    /// Gets or sets the label for the select group.
    /// </summary>
    [Parameter]
    public string? Label { get; set; }

    protected override void BuildOwnedAttributes(Dictionary<string, object> attributes)
    {
        base.BuildOwnedAttributes(attributes);

        attributes.Remove("name");
        attributes.Remove("value");
        attributes.Remove("readonly");
        attributes.Remove("placeholder");
        attributes.Remove("required");
        attributes.Remove("autofocus");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select-group";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select-group");
        });

        if (Label.HasContent())
            attributes["label"] = Label;

        if (Disabled)
            attributes["disabled"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Label);
        hc.Add(Disabled);
    }
}