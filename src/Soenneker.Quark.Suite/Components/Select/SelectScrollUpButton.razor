@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSelectScrollUpButton AdditionalAttributes="@ButtonAttributes">
    <Svg Size="Quark.Size.Is4" aria-hidden="true" NativeWidth="24" NativeHeight="24" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round">
        <path d="m18 15-6-6-6 6"></path>
    </Svg>
</BradixSelectScrollUpButton>

@code {
    private IReadOnlyDictionary<string, object> ButtonAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        ZIndex ??= "z-10";
        Cursor ??= Quark.Cursor.Default;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is1.OnY;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        SetDefaultDataSlot("select-scroll-up-button");

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-4");
        });
    }
}
