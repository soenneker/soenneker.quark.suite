@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSelectPortal>
    <BradixSelectContent Position="@ContentPosition"
                         ForceMount="@ForceMount"
                         Side="@Side"
                         SideOffset="@SideOffset"
                         Align="@Align"
                         AlignOffset="@AlignOffset"
                         ArrowPadding="@ArrowPadding"
                         AvoidCollisions="@AvoidCollisions"
                         CollisionPadding="@CollisionPadding"
                         CollisionBoundarySelector="@CollisionBoundarySelector"
                         CollisionBoundarySelectors="@CollisionBoundarySelectors"
                         Sticky="@Sticky"
                         HideWhenDetached="@HideWhenDetached"
                         AdditionalAttributes="@ContentAttributes">
        <SelectScrollUpButton />
        <BradixSelectViewport AdditionalAttributes="@ViewportAttributes">
            @ChildContent
        </BradixSelectViewport>
        <SelectScrollDownButton />
    </BradixSelectContent>
</BradixSelectPortal>

@code {
    [Parameter]
    public Side Side { get; set; } = Side.Bottom;

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public int SideOffset { get; set; }

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public Alignment Align { get; set; } = Alignment.Center;

    [Parameter]
    public SelectPosition ContentPosition { get; set; } = SelectPosition.ItemAligned;

    [Parameter]
    public bool UseDefaultMotion { get; set; } = true;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    private IReadOnlyDictionary<string, object> ViewportAttributes => BuildViewportAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "select-content";

        Position ??= Quark.Position.Relative;
        ZIndex ??= Quark.ZIndex.Is50;
        MaxHeight ??= "max-h-(--radix-select-content-available-height)";
        MinWidth ??= Quark.MinWidth.Is36;
        OverflowX ??= Quark.Overflow.X.Hidden;
        OverflowY ??= Quark.Overflow.Y.Auto;
        Rounded ??= Quark.Rounded.Lg;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Shadow ??= Quark.Shadow.Md;
        Ring ??= Quark.Ring.Is1;
        RingColor ??= Quark.RingColor.Utility("ring-foreground/10");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-align-trigger"] = ContentPosition == SelectPosition.ItemAligned ? "true" : "false";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "origin-(--radix-select-content-transform-origin)");

            if (!UseDefaultMotion)
                return;

            AppendClass(ref cls, "duration-[50ms]");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-open:animate-in data-open:fade-in-0 data-open:zoom-in-95 data-closed:animate-out data-closed:fade-out-0 data-closed:zoom-out-95");

            if (ContentPosition == SelectPosition.Popper)
                AppendClass(ref cls, "data-[side=bottom]:translate-y-1 data-[side=left]:-translate-x-1 data-[side=right]:translate-x-1 data-[side=top]:-translate-y-1");
        });
    }

    private IReadOnlyDictionary<string, object> BuildViewportAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-position"] = ContentPosition == SelectPosition.Popper ? "popper" : "item-aligned"
        };

        RenderComponent.BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "data-[position=popper]:h-(--radix-select-trigger-height) data-[position=popper]:w-full data-[position=popper]:min-w-(--radix-select-trigger-width)");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (var selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
        hc.Add(Align);
        hc.Add(ContentPosition);
        hc.Add(UseDefaultMotion);
        hc.Add(ForceMount);
    }
}
