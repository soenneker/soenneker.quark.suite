@using System.Collections.Generic
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSelectPortal>
    <BradixSelectContent Position="@ContentPosition"
                         ForceMount="@ForceMount"
                         Side="@Side"
                         SideOffset="@SideOffset"
                         Align="@Align"
                         AlignOffset="@AlignOffset"
                         ArrowPadding="@ArrowPadding"
                         AvoidCollisions="@AvoidCollisions"
                         CollisionPadding="@CollisionPadding"
                         CollisionBoundarySelector="@CollisionBoundarySelector"
                         CollisionBoundarySelectors="@CollisionBoundarySelectors"
                         Sticky="@Sticky"
                         HideWhenDetached="@HideWhenDetached"
                         AdditionalAttributes="@ContentAttributes">
        <BradixSelectViewport Class="@ViewportClass">
            @ChildContent
        </BradixSelectViewport>
    </BradixSelectContent>
</BradixSelectPortal>

@code {
    [Parameter]
    public Side Side { get; set; } = Side.Bottom;

    [Parameter]
    public bool ForceMount { get; set; }

    [Parameter]
    public int SideOffset { get; set; }

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public Alignment Align { get; set; } = Alignment.Center;

    [Parameter]
    public SelectPosition ContentPosition { get; set; } = SelectPosition.ItemAligned;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    private string ViewportClass =>
        ContentPosition == SelectPosition.Popper
            ? "h-[var(--radix-select-trigger-height)] w-full min-w-[var(--radix-select-trigger-width)] scroll-my-1 p-1"
            : "p-1";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        ZIndex ??= "z-50";
        MaxHeight ??= Quark.Height.Token("(--radix-select-content-available-height)");
        MinWidth ??= Quark.MinWidth.Token("[8rem]");
        OverflowX ??= Quark.Overflow.X.Hidden;
        OverflowY ??= Quark.Overflow.Y.Auto;
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Shadow ??= Quark.Shadow.Md;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "select-content";
        attributes["data-side"] = Side.Value;
        attributes["data-align"] = Align.Value;
        attributes["data-position"] = ContentPosition.Value;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "origin-(--radix-select-content-transform-origin)");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2 data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
            AppendClass(ref cls, "data-[position=popper]:data-[side=bottom]:translate-y-1 data-[position=popper]:data-[side=left]:-translate-x-1 data-[position=popper]:data-[side=right]:translate-x-1 data-[position=popper]:data-[side=top]:-translate-y-1");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (var selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
        hc.Add(Align);
        hc.Add(ContentPosition);
        hc.Add(ForceMount);
    }
}
