@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSelectSeparator AdditionalAttributes="@SeparatorAttributes" />

@code {
    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        PointerEvents ??= Quark.PointerEvents.None;
        Margin ??= Quark.Margin.Token("-1").OnX.Is1.OnY;
        Height ??= Quark.Height.IsPx;
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");

        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "select-separator";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, string.Empty);
        });
    }
}
