@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSelectTrigger AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <BradixSelectIcon Class="pointer-events-none size-4 text-muted-foreground shrink-0">
        <Icon Name="LucideIcon.ChevronDown" aria-hidden="true" />
    </BradixSelectIcon>
</BradixSelectTrigger>

@code {
    [CascadingParameter(Name = "ParentSelectContext")]
    private SelectContext? Context { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "select-trigger";

        Display ??= Quark.Display.Flex;
        if (Context?.FillFieldWidth() == true)
            Width ??= Quark.Width.IsFull;
        else if (!HasTailwindUtility(Class, "w-"))
            Width ??= Quark.Width.IsFit;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Between;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Input.OnFocusVisible.Ring;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        TextSize ??= Quark.TextSize.Sm;
        Gap ??= "gap-1.5";
        Padding ??= Quark.Padding.OnY.Is2.FromRight.Is2.FromLeft.Token("2.5");
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.Colors;
        OutlineStyle ??= Quark.OutlineStyle.None;
        UserSelect ??= Quark.UserSelect.None;
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        Cursor ??= Quark.Cursor.NotAllowed.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }

    private static bool HasTailwindUtility(string? className, string utilityPrefix)
    {
        if (string.IsNullOrWhiteSpace(className))
            return false;

        var remaining = className.AsSpan();
        var prefix = utilityPrefix.AsSpan();

        while (!remaining.IsEmpty)
        {
            remaining = remaining.TrimStart();

            var separator = remaining.IndexOfAny(" \t\r\n".AsSpan());
            var token = separator < 0 ? remaining : remaining[..separator];
            var utility = token[(token.LastIndexOf(':') + 1)..];

            if (utility.StartsWith(prefix, StringComparison.Ordinal))
                return true;

            if (separator < 0)
                break;

            remaining = remaining[(separator + 1)..];
        }

        return false;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-size"] = Context?.Size() ?? "default";

        if (!attributes.ContainsKey("id") && Context is not null && Context.EffectiveTriggerId().HasContent())
            attributes["id"] = Context.EffectiveTriggerId();

        if (Context?.IsInvalid() == true)
            attributes["aria-invalid"] = "true";

        var describedBy = Context?.AriaDescribedBy();
        if (describedBy.HasContent())
            attributes["aria-describedby"] = describedBy!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus-visible:ring-3");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 data-placeholder:text-muted-foreground data-[size=default]:h-8 data-[size=sm]:h-7 data-[size=sm]:rounded-[min(var(--radius-md),10px)]");
            AppendClass(ref cls, "dark:bg-input/30 dark:hover:bg-input/50 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "*:data-[slot=select-value]:line-clamp-1 *:data-[slot=select-value]:flex *:data-[slot=select-value]:items-center *:data-[slot=select-value]:gap-1.5");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.IsInvalid() == true);
        hc.Add(Context?.EffectiveTriggerId());
        hc.Add(Context?.AriaDescribedBy());
    }
}
