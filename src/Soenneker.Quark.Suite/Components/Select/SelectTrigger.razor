@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<button @ref="_triggerRef" type="button" @onclick="OnTriggerClick" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @attributes="BuildAttributes()">
    @ChildContent
    <svg class="pointer-events-none size-4 opacity-50 shrink-0" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"></path>
    </svg>
</button>

@code {
    [CascadingParameter(Name = "ParentSelectContext")]
    private SelectContext? Context { get; set; }

    private ElementReference _triggerRef;
    private bool _preventDefaultKeys;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        Context?.SetTriggerElement(_triggerRef);
        return base.OnAfterRenderAsync(firstRender);
    }

    private async Task OnTriggerClick(MouseEventArgs args)
    {
        if (Context?.IsDisabled() == true)
            return;

        if (Context is not null)
            await Context.ToggleAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;

        if (Context?.IsDisabled() == true || Context is null)
            return;

        if (Context.IsOpen() == true && !e.CtrlKey && !e.MetaKey && !e.AltKey && e.Key.Length == 1 && !char.IsControl(e.Key[0]))
        {
            if (await Context.TryTypeaheadAsync(e.Key))
            {
                _preventDefaultKeys = true;
                return;
            }
        }

        if (Context.IsOpen() == true)
        {
            if (e.Key is "Enter" or " ")
            {
                _preventDefaultKeys = true;
                await Context.SelectActiveItemAsync();
                return;
            }

            if (e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
            {
                _preventDefaultKeys = true;
                await Context.NavigateFromTriggerAsync(e.Key);
                return;
            }

            if (e.Key == "Escape")
            {
                _preventDefaultKeys = true;
                await Context.CloseAsync();
                return;
            }

            return;
        }

        if (e.Key is "ArrowDown" or "Enter" or " ")
        {
            _preventDefaultKeys = true;
            await Context.OpenFirstAsync();
        }
        else if (e.Key == "ArrowUp")
        {
            _preventDefaultKeys = true;
            await Context.OpenLastAsync();
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "select-trigger";
        attributes["data-size"] = Context?.Size() ?? "default";
        attributes["data-state"] = Context?.IsOpen() == true ? "open" : "closed";
        if (Context is not null)
            attributes["id"] = Context.EffectiveTriggerId();
        attributes["role"] = "combobox";
        attributes["aria-haspopup"] = "listbox";
        attributes["aria-autocomplete"] = "none";
        if (Context is not null && Context.IsOpen() == true)
            attributes["aria-controls"] = Context.ContentId;
        attributes["aria-expanded"] = Context?.IsOpen() == true ? "true" : "false";

        if (Context?.IsRequired() == true)
            attributes["aria-required"] = "true";

        if (Context?.IsInvalid() == true)
            attributes["aria-invalid"] = "true";

        var describedBy = Context?.AriaDescribedBy();
        if (describedBy.HasContent())
            attributes["aria-describedby"] = describedBy!;

        if (!Context?.HasValue() ?? true)
            attributes["data-placeholder"] = "true";

        var activeItemId = Context?.ActiveItemId();
        if (activeItemId.HasContent())
            attributes["aria-activedescendant"] = activeItemId!;

        if (Context?.IsDisabled() == true)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select-trigger flex w-fit items-center justify-between gap-2 rounded-md border border-input bg-transparent px-3 py-2 text-sm whitespace-nowrap shadow-xs");
            AppendClass(ref cls, "transition-[color,box-shadow] outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:cursor-not-allowed disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 data-[placeholder]:text-muted-foreground data-[size=default]:h-9 data-[size=sm]:h-8 dark:bg-input/30 dark:hover:bg-input/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
            AppendClass(ref cls, "*:data-[slot=select-value]:line-clamp-1 *:data-[slot=select-value]:flex *:data-[slot=select-value]:items-center *:data-[slot=select-value]:gap-2");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.IsOpen() == true);
        hc.Add(Context?.IsDisabled() == true);
        hc.Add(Context?.IsInvalid() == true);
        hc.Add(Context?.IsRequired() == true);
        hc.Add(Context?.EffectiveTriggerId());
        hc.Add(Context?.AriaDescribedBy());
        hc.Add(Context?.ActiveItemId());
    }
}
