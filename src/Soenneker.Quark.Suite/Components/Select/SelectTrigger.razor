@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixSelectTrigger AdditionalAttributes="@TriggerAttributes">
    @ChildContent
    <BradixSelectIcon Class="pointer-events-none size-4 opacity-50 shrink-0">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"></path>
        </svg>
    </BradixSelectIcon>
</BradixSelectTrigger>

@code {
    [CascadingParameter(Name = "ParentSelectContext")]
    private SelectContext? Context { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        if (Context?.FillFieldWidth() == true)
            Width ??= Quark.Width.IsFull;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        TextSize ??= Quark.TextSize.Sm;
        Gap ??= Quark.Gap.Token("1.5");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "select-trigger";
        attributes["data-size"] = Context?.Size() ?? "default";

        if (!attributes.ContainsKey("id") && Context is not null && Context.EffectiveTriggerId().HasContent())
            attributes["id"] = Context.EffectiveTriggerId();

        if (Context?.IsInvalid() == true)
            attributes["aria-invalid"] = "true";

        var describedBy = Context?.AriaDescribedBy();
        if (describedBy.HasContent())
            attributes["aria-describedby"] = describedBy!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "items-center justify-between bg-transparent py-2 pr-2 pl-2.5 whitespace-nowrap select-none");
            AppendClass(ref cls, "transition-colors outline-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:cursor-not-allowed disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 data-[placeholder]:text-muted-foreground data-[size=default]:h-8 data-[size=sm]:h-7 data-[size=sm]:rounded-[min(var(--radius-md),10px)] dark:bg-input/30 dark:hover:bg-input/50 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
            AppendClass(ref cls, "*:data-[slot=select-value]:line-clamp-1 *:data-[slot=select-value]:flex *:data-[slot=select-value]:items-center *:data-[slot=select-value]:gap-1.5");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.IsInvalid() == true);
        hc.Add(Context?.EffectiveTriggerId());
        hc.Add(Context?.AriaDescribedBy());
    }
}
