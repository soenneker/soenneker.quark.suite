@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

<span @attributes="BuildAttributes()">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        @(DisplayText ?? Placeholder)
    }
</span>

@code {
    [Parameter]
    public string? Placeholder { get; set; }

    [CascadingParameter(Name = "ParentSelectContext")]
    private SelectContext? Context { get; set; }

    private string? DisplayText => Context?.DisplayText();
    private bool HasValue => Context?.HasValue() == true;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "select-value";

        if (!HasValue)
            attributes["data-placeholder"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select-value line-clamp-1 text-left");
            if (!HasValue)
                AppendClass(ref cls, "text-muted-foreground");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(DisplayText);
        hc.Add(Placeholder);
        hc.Add(HasValue);
    }
}
