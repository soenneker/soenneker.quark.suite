@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

@if (ChildContent is null)
{
    <BradixSelectValue Placeholder="@PlaceholderContent" AdditionalAttributes="@ValueAttributes" />
}
else
{
    <BradixSelectValue Placeholder="@PlaceholderContent" AdditionalAttributes="@ValueAttributes">
        @ChildContent
    </BradixSelectValue>
}

@code {
    [Parameter]
    public string? Placeholder { get; set; }

    [CascadingParameter(Name = "ParentSelectContext")]
    private SelectContext? Context { get; set; }

    private string? ResolvedPlaceholder => Context?.DefaultItemText() ?? Placeholder;

    private RenderFragment? PlaceholderContent => ResolvedPlaceholder is null
        ? null
        : builder => builder.AddContent(0, ResolvedPlaceholder);

    private IReadOnlyDictionary<string, object> ValueAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "select-value";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "line-clamp-1 text-left");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Placeholder);
        hc.Add(Context?.DefaultItemText());
    }
}
