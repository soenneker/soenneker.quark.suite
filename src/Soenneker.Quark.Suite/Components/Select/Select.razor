@using System.Linq.Expressions
@using Soenneker.Blazor.Extensions.EventCallback

@inject IPopoverInterop PopoverInterop
@inject ISelectInterop SelectInterop

@namespace Soenneker.Quark
@typeparam TValue
@inherits FormControlElement
@implements IValidationInput
@implements ISelect<TValue>

<CascadingValue Name="ParentSelect" Value="this" IsFixed="false">
    <CascadingValue Name="ParentSelectContext" Value="_context" IsFixed="false">
        <div @attributes="BuildAttributes()">
            @if (Name.HasContent())
            {
                <input type="hidden" name="@Name" value="@SelectedValueString" />
            }

            @ChildContent
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    private const int TypeaheadResetMilliseconds = 500;

    private readonly List<ISelectFocusableItem> _items = [];
    private ISelectFocusableItem? _activeItem;
    private string _typeaheadBuffer = "";
    private DateTime _typeaheadLastUtc;

    /// <summary>
    /// Gets or sets the selected value.
    /// </summary>
    [Parameter]
    public TValue? SelectedValue { get; set; }

    /// <summary>
    /// Gets or sets the expression that identifies the bound selected value.
    /// </summary>
    [Parameter]
    public Expression<Func<TValue>>? SelectedValueExpression { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<TValue?> SelectedValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the selection changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    /// <summary>
    /// Gets or sets the size of the select.
    /// </summary>
    [Parameter]
    public CssValue<SizeBuilder>? Size { get; set; } = Quark.Size.Default;

    /// <summary>
    /// Gets or sets the default item text.
    /// </summary>
    [Parameter]
    public string? DefaultItemText { get; set; }

    /// <summary>
    /// Gets or sets the default item value.
    /// </summary>
    [Parameter]
    public TValue? DefaultItemValue { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// </summary>
    public object? ValidationValue => SelectedValue;
    private readonly Dictionary<string, string?> _registeredItems = new(StringComparer.Ordinal);
    private bool _open;
    private readonly string _selectId = $"select-{Guid.NewGuid():N}";
    private SelectContext _context = null!;

    private string TriggerId => $"{_selectId}-trigger";
    private string ContentId => $"{_selectId}-content";
    private string? SelectedValueString => GetValueString(SelectedValue);
    private bool IsInvalidState => ParentValidation?.Status == ValidationStatus.Error;

    /// <summary>
    /// Clears focusable item order and value→label map before children re-register in DOM order each render.
    /// </summary>
    protected override void OnParametersSet()
    {
        _items.Clear();
        _registeredItems.Clear();
        base.OnParametersSet();
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _context = new SelectContext
        {
            IsOpen = () => _open,
            HasValue = HasValue,
            DisplayText = GetDisplayText,
            Size = GetSizeValue,
            IsDisabled = () => Disabled,
            IsInvalid = () => IsInvalidState || CurrentFieldContext?.IsInvalid == true,
            IsRequired = () => Required,
            EffectiveTriggerId = () => CurrentFieldContext?.ControlId ?? TriggerId,
            AriaDescribedBy = () => BuildSelectAriaDescribedBy(),
            ToggleAsync = ToggleOpen,
            OpenFirstAsync = OpenAndFocusFirstAsync,
            OpenLastAsync = OpenAndFocusLastAsync,
            CloseAsync = CloseFromKeyboardAsync,
            TryTypeaheadAsync = TryHandleTypeaheadAsync,
            SelectActiveItemAsync = ActivateCurrentItemAsync,
            NavigateFromTriggerAsync = NavigateFromTriggerAsync,
            FocusTriggerAsync = FocusTriggerAsync,
            ActiveItemId = () => _activeItem?.ItemId,
            TriggerId = TriggerId,
            ContentId = ContentId
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);

            if (SelectedValueExpression is not null)
                await ParentValidation.InitializeInputExpression(SelectedValueExpression);

            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        await RefreshOffThread();
    }

    internal async Task<bool> TryHandleTypeaheadAsync(string key)
    {
        if (!_open || key.Length != 1)
            return false;

        var c = key[0];
        if (char.IsControl(c))
            return false;

        var now = DateTime.UtcNow;
        if ((now - _typeaheadLastUtc).TotalMilliseconds > TypeaheadResetMilliseconds)
            _typeaheadBuffer = "";

        _typeaheadBuffer += c;
        _typeaheadLastUtc = now;

        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        var match = FindTypeaheadMatch(enabledItems, _typeaheadBuffer);

        if (match is null && _typeaheadBuffer.Length > 1)
        {
            _typeaheadBuffer = key;
            match = FindTypeaheadMatch(enabledItems, _typeaheadBuffer);
        }

        if (match is null)
            return false;

        SetActiveItem(match);
        await match.FocusAsync();
        await ScrollActiveItemIntoViewAsync();
        return true;
    }

    private async Task ScrollActiveItemIntoViewAsync()
    {
        if (_activeItem is null)
            return;

        await SelectInterop.ScrollIntoViewNearestAsync(_activeItem.GetScrollAnchor());
        await PopoverInterop.NudgePosition(ContentId);
    }

    private static ISelectFocusableItem? FindTypeaheadMatch(List<ISelectFocusableItem> enabledItems, string prefix)
    {
        if (prefix.Length == 0)
            return null;

        foreach (var item in enabledItems)
        {
            var text = item.SearchText ?? "";
            if (text.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
                return item;
        }

        return null;
    }

    private async Task ActivateCurrentItemAsync()
    {
        if (!_open || _activeItem is null)
            return;

        await _activeItem.InvokeSelectAsync();
    }

    private async Task NavigateFromTriggerAsync(string key)
    {
        if (!_open)
            return;

        EnsureActiveItem();
        if (_activeItem is null)
            return;

        await HandleItemNavigationAsync(_activeItem, key);
    }

    internal void RegisterItem(string value, string? text)
    {
        _registeredItems[value] = text;
    }

    /// <summary>
    /// Called from each <see cref="SelectItem{TValue}"/> during <c>OnParametersSet</c> (after this component clears the lists).
    /// </summary>
    internal void RegisterFocusableItem(ISelectFocusableItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);

        EnsureActiveItem();
    }

    internal bool IsSelected(TValue? value)
    {
        return EqualityComparer<TValue>.Default.Equals(SelectedValue, value);
    }

    internal async Task SelectItem(TValue? value, string? text)
    {
        var valueChanged = !EqualityComparer<TValue>.Default.Equals(SelectedValue, value);
        SelectedValue = value;

        if (text.HasContent() && value is not null)
            _registeredItems[GetValueString(value)!] = text;

        if (valueChanged)
            await SelectedValueChanged.InvokeAsync(SelectedValue);

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = GetValueString(SelectedValue) });

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(SelectedValue);
        }

        await CloseFromKeyboardAsync();

        if (valueChanged)
        {
            InvalidateRender();
            Refresh();
        }
    }

    private async Task ToggleOpen()
    {
        if (Disabled)
            return;

        _open = !_open;
        if (_open)
            EnsureActiveItem();
        else
        {
            _typeaheadBuffer = "";
            SetActiveItem(null);
        }

        await RefreshOffThread();
    }

    private async Task Close()
    {
        if (!_open)
            return;

        _open = false;
        _typeaheadBuffer = "";
        SetActiveItem(null);
        await RefreshOffThread();
    }

    internal async Task CloseFromKeyboardAsync()
    {
        if (!_open)
            return;

        await Close();
        await FocusTriggerAsync();
    }

    internal async Task HandleItemNavigationAsync(ISelectFocusableItem currentItem, string key)
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
            return;

        var currentIndex = enabledItems.FindIndex(item => ReferenceEquals(item, currentItem));
        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "Home" => 0,
            "End" => enabledItems.Count - 1,
            "ArrowDown" => (currentIndex + 1) % enabledItems.Count,
            "ArrowUp" => (currentIndex - 1 + enabledItems.Count) % enabledItems.Count,
            _ => -1
        };

        if (nextIndex < 0)
            return;

        var nextItem = enabledItems[nextIndex];
        SetActiveItem(nextItem);
        await nextItem.FocusAsync();
        await ScrollActiveItemIntoViewAsync();
    }

    internal void SetActiveItem(ISelectFocusableItem? item)
    {
        if (ReferenceEquals(_activeItem, item))
            return;

        _activeItem?.SetActive(false);
        _activeItem = item;
        _activeItem?.SetActive(true);
        Refresh();
    }

    private void EnsureActiveItem()
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
        {
            SetActiveItem(null);
            return;
        }

        if (_activeItem is not null && enabledItems.Contains(_activeItem))
            return;

        var selectedItem = enabledItems.FirstOrDefault(item => string.Equals(item.Value, SelectedValueString, StringComparison.Ordinal));
        SetActiveItem(selectedItem ?? enabledItems[0]);
    }

    private async Task OpenAndFocusFirstAsync()
    {
        if (!_open)
        {
            _open = true;
            await RefreshOffThread();
        }

        EnsureActiveItem();
        if (_activeItem is not null)
        {
            await _activeItem.FocusAsync();
            await ScrollActiveItemIntoViewAsync();
        }
    }

    private async Task OpenAndFocusLastAsync()
    {
        var enabledItems = _items.Where(i => !i.IsDisabledForNavigation).ToList();
        if (enabledItems.Count == 0)
        {
            if (!_open)
            {
                _open = true;
                await RefreshOffThread();
            }

            return;
        }

        if (!_open)
        {
            _open = true;
            await RefreshOffThread();
        }

        var lastItem = enabledItems[^1];
        SetActiveItem(lastItem);
        await lastItem.FocusAsync();
        await ScrollActiveItemIntoViewAsync();
    }

    private async Task FocusTriggerAsync()
    {
        if (_context.HasTriggerElement)
            await _context.TriggerElement.FocusAsync();
    }

    private bool HasValue()
    {
        return SelectedValue is not null && !string.IsNullOrEmpty(GetValueString(SelectedValue));
    }

    private string? GetDisplayText()
    {
        if (SelectedValue is not null)
        {
            var key = GetValueString(SelectedValue);
            if (key.HasContent() && _registeredItems.TryGetValue(key!, out var label) && label.HasContent())
                return label;
        }

        if (DefaultItemText.HasContent())
            return DefaultItemText;

        return Placeholder;
    }

    private static string? GetValueString(TValue? value)
    {
        return value?.ToString();
    }

    private string GetSizeValue()
    {
        string? themeToken = null;

        if (Size?.TryGetThemeToken(out themeToken) == true && themeToken.HasContent())
            return string.Equals(themeToken, "sm", StringComparison.OrdinalIgnoreCase) ? "sm" : "default";

        var sizeValue = Size?.ToString();

        return string.Equals(sizeValue, "sm", StringComparison.OrdinalIgnoreCase)
            ? "sm"
            : "default";
    }

    private string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error || CurrentFieldContext?.IsInvalid == true)
            return "border-destructive ring-destructive/20 dark:ring-destructive/40";

        return null;
    }

    private string? BuildSelectAriaDescribedBy()
    {
        var effectiveInvalid = IsInvalidState || CurrentFieldContext?.IsInvalid == true;

        return CurrentFieldContext?.BuildDescribedBy(null, effectiveInvalid);
    }

    protected override void BuildOwnedAttributes(Dictionary<string, object> attrs)
    {
        base.BuildOwnedAttributes(attrs);

        attrs.Remove("required");
        attrs.Remove("disabled");
        attrs.Remove("readonly");
        attrs.Remove("placeholder");
        attrs.Remove("autofocus");
        attrs.Remove("name");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select";
        attributes["data-size"] = "default";
        attributes["data-state"] = _open ? "open" : "closed";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select");
            AppendClass(ref cls, "group/select relative w-full max-w-full");

            var validationClass = GetValidationClass();
            if (validationClass != null)
                AppendClass(ref cls, validationClass);
        });
    }

    public override void Dispose()
    {
        base.Dispose();

        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedValue);
        hc.Add(Disabled);
        hc.Add(Required);
        AddIf(ref hc, Size);
        hc.Add(Placeholder);
        hc.Add(DefaultItemText);
        hc.Add(DefaultItemValue);
        hc.Add(_open);
        hc.Add(_items.Count);
    }
}
