@using Soenneker.Bradix
@using System.Globalization
@using System.Linq.Expressions
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@typeparam TValue
@inherits FormControlElement
@implements IValidationInput
@implements ISelect<TValue>

<CascadingValue Name="ParentSelect" Value="this" IsFixed="false">
    <CascadingValue Name="ParentSelectContext" Value="_context" IsFixed="true">
        <div @attributes="BuildAttributes()">
            <BradixSelect Value="@SelectedValueString"
                          Name="@Name"
                          Disabled="@Disabled"
                          Required="@Required"
                          ValueChanged="HandleBradixValueChanged"
                          OpenChanged="HandleBradixOpenChanged">
                @ChildContent
            </BradixSelect>
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    /// <summary>
    /// Gets or sets the selected value.
    /// </summary>
    [Parameter]
    public TValue? SelectedValue { get; set; }

    /// <summary>
    /// Gets or sets the expression that identifies the bound selected value.
    /// </summary>
    [Parameter]
    public Expression<Func<TValue>>? SelectedValueExpression { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<TValue?> SelectedValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the selection changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    /// <summary>
    /// Gets or sets the size of the select.
    /// </summary>
    [Parameter]
    public CssValue<SelectSizeBuilder>? Size { get; set; } = SelectSizes.Default;

    /// <summary>
    /// Gets or sets the default item text.
    /// </summary>
    [Parameter]
    public string? DefaultItemText { get; set; }

    /// <summary>
    /// Gets or sets the default item value.
    /// </summary>
    [Parameter]
    public TValue? DefaultItemValue { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// </summary>
    public object? ValidationValue => SelectedValue;
    private readonly Dictionary<string, TValue?> _registeredItemValues = new(StringComparer.Ordinal);
    private bool _open;
    private SelectContext _context = null!;
    private string? SelectedValueString => GetValueString(SelectedValue);
    private bool IsInvalidState => ParentValidation?.Status == ValidationStatus.Error;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _context = new SelectContext
        {
            Size = GetSizeValue,
            IsInvalid = () => IsInvalidState || CurrentFieldContext?.IsInvalid == true,
            EffectiveTriggerId = () => CurrentFieldContext?.ControlId ?? string.Empty,
            AriaDescribedBy = () => BuildSelectAriaDescribedBy(),
            DefaultItemText = () => DefaultItemText
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);

            if (SelectedValueExpression is not null)
                await ParentValidation.InitializeInputExpression(SelectedValueExpression);

            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        await RefreshOffThread();
    }

    internal void RegisterItemValue(string value, TValue? itemValue)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        _registeredItemValues[value] = itemValue;
    }

    internal void UnregisterItemValue(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        _registeredItemValues.Remove(value);
    }

    private async Task HandleBradixValueChanged(string? value)
    {
        var nextValue = ResolveSelectedValue(value);
        var valueChanged = !EqualityComparer<TValue>.Default.Equals(SelectedValue, nextValue);

        SelectedValue = nextValue;

        if (valueChanged && SelectedValueChanged.HasDelegate)
            await SelectedValueChanged.InvokeAsync(nextValue);

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = value });

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(nextValue);
        }
    }

    private Task HandleBradixOpenChanged(bool open)
    {
        _open = open;
        return Task.CompletedTask;
    }

    private TValue? ResolveSelectedValue(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return DefaultItemValue;

        if (_registeredItemValues.TryGetValue(value, out var registeredValue))
            return registeredValue;

        return BindConverter.TryConvertTo(value, CultureInfo.CurrentCulture, out TValue? convertedValue)
            ? convertedValue
            : DefaultItemValue;
    }

    private static string? GetValueString(TValue? value)
    {
        return value?.ToString();
    }

    private string GetSizeValue()
    {
        var sizeValue = Size?.ToString();

        return string.Equals(sizeValue, "sm", StringComparison.OrdinalIgnoreCase)
            ? "sm"
            : "default";
    }

    private string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error || CurrentFieldContext?.IsInvalid == true)
            return "border-destructive ring-destructive/20 dark:ring-destructive/40";

        return null;
    }

    private string? BuildSelectAriaDescribedBy()
    {
        var effectiveInvalid = IsInvalidState || CurrentFieldContext?.IsInvalid == true;

        return CurrentFieldContext?.BuildDescribedBy(null, effectiveInvalid);
    }

    protected override void BuildOwnedAttributes(Dictionary<string, object> attrs)
    {
        base.BuildOwnedAttributes(attrs);

        attrs.Remove("required");
        attrs.Remove("disabled");
        attrs.Remove("readonly");
        attrs.Remove("placeholder");
        attrs.Remove("autofocus");
        attrs.Remove("name");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select";
        attributes["data-size"] = "default";
        attributes["data-state"] = _open ? "open" : "closed";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/select relative w-full max-w-full");

            var validationClass = GetValidationClass();
            if (validationClass != null)
                AppendClass(ref cls, validationClass);
        });
    }

    public override void Dispose()
    {
        base.Dispose();

        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedValue);
        hc.Add(Disabled);
        hc.Add(Required);
        AddIf(ref hc, Size);
        hc.Add(Placeholder);
        hc.Add(DefaultItemText);
        hc.Add(DefaultItemValue);
        hc.Add(_open);
    }
}
