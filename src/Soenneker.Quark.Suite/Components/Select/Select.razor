@using System.Linq.Expressions
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@typeparam TValue
@inherits FormControlElement
@implements IValidationInput
@implements ISelect<TValue>

<CascadingValue Name="ParentSelect" Value="this" IsFixed="false">
    <CascadingValue Name="ParentSelectContext" Value="_context" IsFixed="false">
        <div @attributes="BuildAttributes()" @onfocusout="HandleFocusOut">
            @if (Name.HasContent())
            {
                <input type="hidden" name="@Name" value="@SelectedValueString" />
            }

            @ChildContent
        </div>
    </CascadingValue>
</CascadingValue>

@code {
    /// <summary>
    /// Gets or sets the selected value.
    /// </summary>
    [Parameter]
    public TValue? SelectedValue { get; set; }

    /// <summary>
    /// Gets or sets the expression that identifies the bound selected value.
    /// </summary>
    [Parameter]
    public Expression<Func<TValue>>? SelectedValueExpression { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the selected value changes.
    /// </summary>
    [Parameter]
    public EventCallback<TValue?> SelectedValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked When the selection changes.
    /// </summary>
    [Parameter]
    public EventCallback<ChangeEventArgs> OnChange { get; set; }

    /// <summary>
    /// Gets or sets the size of the select.
    /// </summary>
    [Parameter]
    public CssValue<SizeBuilder>? Size { get; set; } = Quark.Size.Default;

    /// <summary>
    /// Gets or sets whether multiple items can be selected.
    /// </summary>
    [Parameter]
    public bool Multiple { get; set; }

    /// <summary>
    /// Gets or sets the default item text.
    /// </summary>
    [Parameter]
    public string? DefaultItemText { get; set; }

    /// <summary>
    /// Gets or sets the default item value.
    /// </summary>
    [Parameter]
    public TValue? DefaultItemValue { get; set; }

    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    /// <summary>
    /// Gets the value used for validation.
    /// </summary>
    public object? ValidationValue => SelectedValue;
    private readonly Dictionary<string, string?> _registeredItems = new(StringComparer.Ordinal);
    private bool _open;
    private readonly string _selectId = $"select-{Guid.NewGuid():N}";
    private SelectContext _context = null!;

    private string TriggerId => $"{_selectId}-trigger";
    private string ContentId => $"{_selectId}-content";
    private string? SelectedValueString => GetValueString(SelectedValue);
    private bool IsInvalidState => ParentValidation?.Status == ValidationStatus.Error;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _context = new SelectContext
        {
            IsOpen = () => _open,
            HasValue = HasValue,
            DisplayText = GetDisplayText,
            IsDisabled = () => Disabled,
            IsInvalid = () => IsInvalidState,
            ToggleAsync = ToggleOpen,
            CloseAsync = Close,
            TriggerId = TriggerId,
            ContentId = ContentId
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ParentValidation is not null)
        {
            await ParentValidation.InitializeInput(this);

            if (SelectedValueExpression is not null)
                await ParentValidation.InitializeInputExpression(SelectedValueExpression);

            ParentValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    private async void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        await RefreshOffThread();
    }

    private async Task HandleFocusOut(FocusEventArgs _)
    {
        await Task.Delay(150);
        await Close();
    }

    internal void RegisterItem(string value, string? text)
    {
        _registeredItems[value] = text;
    }

    internal bool IsSelected(TValue? value)
    {
        return EqualityComparer<TValue>.Default.Equals(SelectedValue, value);
    }

    internal async Task SelectItem(TValue? value, string? text)
    {
        var valueChanged = !EqualityComparer<TValue>.Default.Equals(SelectedValue, value);
        SelectedValue = value;

        if (text.HasContent() && value is not null)
            _registeredItems[GetValueString(value)!] = text;

        if (valueChanged)
            await SelectedValueChanged.InvokeAsync(SelectedValue);

        await OnChange.InvokeIfHasDelegate(new ChangeEventArgs { Value = GetValueString(SelectedValue) });

        if (ParentValidation is not null)
        {
            ParentValidation.MarkTouched();
            await ParentValidation.NotifyInputChanged(SelectedValue);
        }

        await Close();

        if (valueChanged)
        {
            InvalidateRender();
            Refresh();
        }
    }

    private async Task ToggleOpen()
    {
        if (Disabled)
            return;

        _open = !_open;
        await RefreshOffThread();
    }

    private async Task Close()
    {
        if (!_open)
            return;

        _open = false;
        await RefreshOffThread();
    }

    private bool HasValue()
    {
        return SelectedValue is not null && !string.IsNullOrEmpty(GetValueString(SelectedValue));
    }

    private string? GetDisplayText()
    {
        if (SelectedValue is not null)
        {
            var key = GetValueString(SelectedValue);
            if (key.HasContent() && _registeredItems.TryGetValue(key!, out var label) && label.HasContent())
                return label;
        }

        if (DefaultItemText.HasContent())
            return DefaultItemText;

        return Placeholder;
    }

    private static string? GetValueString(TValue? value)
    {
        return value?.ToString();
    }

    private string? GetValidationClass()
    {
        if (ParentValidation?.Status == ValidationStatus.Error)
            return "border-destructive ring-destructive/20 dark:ring-destructive/40";

        return null;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select";
        attributes["data-size"] = "default";
        attributes["data-state"] = _open ? "open" : "closed";
        ApplyFieldControlAttributes(attributes, IsInvalidState);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select");
            AppendClass(ref cls, "group/select relative w-full max-w-full");

            var validationClass = GetValidationClass();
            if (validationClass != null)
                AppendClass(ref cls, validationClass);
        });
    }

    public override void Dispose()
    {
        base.Dispose();

        if (ParentValidation is not null)
            ParentValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SelectedValue);
        hc.Add(Disabled);
        hc.Add(Required);
        AddIf(ref hc, Size);
        hc.Add(Multiple);
        hc.Add(Placeholder);
        hc.Add(DefaultItemText);
        hc.Add(DefaultItemValue);
        hc.Add(_open);
    }
}
