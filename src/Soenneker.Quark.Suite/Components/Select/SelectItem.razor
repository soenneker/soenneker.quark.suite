@using Soenneker.Bradix

@namespace Soenneker.Quark
@typeparam TValue
@inherits Soenneker.Quark.FormControlElement
@implements ISelectItem<TValue>

<BradixSelectItem Value="@ResolvedValue"
                  Disabled="@Disabled"
                  TextValue="@Text"
                  AdditionalAttributes="@ItemAttributes">
    <span data-slot="select-item-indicator" class="absolute right-2 flex size-3.5 items-center justify-center">
        <BradixSelectItemIndicator>
            <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"></path>
            </svg>
        </BradixSelectItemIndicator>
    </span>
    <BradixSelectItemText>
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else if (Text.HasContent())
        {
            @Text
        }
    </BradixSelectItemText>
</BradixSelectItem>

@code {
    private string? _registeredValue;

    /// <summary>
    /// Gets or sets the value of the select item.
    /// </summary>
    [Parameter]
    public TValue? ItemValue { get; set; }

    /// <summary>
    /// Gets or sets the display text for the select item.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    [CascadingParameter(Name = "ParentSelect")]
    private Select<TValue>? ParentSelect { get; set; }

    private string ResolvedValue => ItemValue?.ToString() ?? string.Empty;

    private IReadOnlyDictionary<string, object> ItemAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Sm;
        Padding ??= Quark.Padding.Token("8").FromRight.Is2.FromLeft.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        OutlineStyle ??= "outline-hidden";
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (_registeredValue.HasContent() && !string.Equals(_registeredValue, ResolvedValue, StringComparison.Ordinal))
            ParentSelect?.UnregisterItemValue(_registeredValue!);

        if (ResolvedValue.HasContent())
        {
            ParentSelect?.RegisterItemValue(ResolvedValue, ItemValue);
            _registeredValue = ResolvedValue;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select-item";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[highlighted]:bg-accent data-[highlighted]:text-accent-foreground");
            AppendClass(ref cls, "data-[disabled]:pointer-events-none data-[disabled]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
            AppendClass(ref cls, "*:[span]:last:flex *:[span]:last:items-center *:[span]:last:gap-2");
        });

        if (Hidden)
            attributes["hidden"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ItemValue);
        hc.Add(Text);
        hc.Add(Disabled);
    }

    public override void Dispose()
    {
        if (_registeredValue.HasContent())
            ParentSelect?.UnregisterItemValue(_registeredValue!);

        base.Dispose();
    }
}
