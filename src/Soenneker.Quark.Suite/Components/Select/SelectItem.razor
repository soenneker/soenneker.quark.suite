@using Soenneker.Bradix

@namespace Soenneker.Quark
@typeparam TValue
@inherits Soenneker.Quark.FormControlElement
@implements ISelectItem<TValue>

<BradixSelectItem Value="@ResolvedValue"
                  Disabled="@Disabled"
                  TextValue="@Text"
                  AdditionalAttributes="@ItemAttributes">
    <Span DataSlot="select-item-indicator" Position="Quark.Position.Absolute" Right="Quark.Right.Is2" Display="Quark.Display.Flex" Size="Quark.Size.Is4" ItemsAlign="Items.Center" Justify="Quark.Justify.Center">
        <BradixSelectItemIndicator>
            <Svg Size="Quark.Size.Is4" aria-hidden="true" NativeWidth="24" NativeHeight="24" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Current' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round">
                <path d="M20 6 9 17l-5-5"></path>
            </Svg>
        </BradixSelectItemIndicator>
    </Span>
    <BradixSelectItemText>
        @if (ChildContent != null)
        {
            @ChildContent
        }
        else if (Text.HasContent())
        {
            @Text
        }
    </BradixSelectItemText>
</BradixSelectItem>

@code {
    private string? _registeredValue;

    /// <summary>
    /// Gets or sets the value of the select item.
    /// </summary>
    [Parameter]
    public TValue? ItemValue { get; set; }

    /// <summary>
    /// Gets or sets the display text for the select item.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    [CascadingParameter(Name = "ParentSelect")]
    private Select<TValue>? ParentSelect { get; set; }

    private string ResolvedValue => ItemValue?.ToString() ?? string.Empty;

    private IReadOnlyDictionary<string, object> ItemAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "select-item";
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is1_5;
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.FromRight.Is8.FromLeft.Token("1.5").OnY.Is1;
        TextSize ??= Quark.TextSize.Sm;
        BackgroundColor ??= Quark.BackgroundColor.OnFocus.Accent;
        TextColor ??= Quark.TextColor.OnFocus.AccentForeground;
        OutlineStyle ??= Quark.OutlineStyle.Hidden;
        UserSelect ??= Quark.UserSelect.None;
        Cursor ??= Quark.Cursor.Default;

    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (_registeredValue.HasContent() && !string.Equals(_registeredValue, ResolvedValue, StringComparison.Ordinal))
            ParentSelect?.UnregisterItemValue(_registeredValue!);

        if (ResolvedValue.HasContent())
        {
            ParentSelect?.RegisterItemValue(ResolvedValue, ItemValue);
            _registeredValue = ResolvedValue;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "not-data-[variant=destructive]:focus:**:text-accent-foreground data-[highlighted]:bg-accent data-[highlighted]:text-accent-foreground");
            AppendClass(ref cls, "data-disabled:pointer-events-none data-disabled:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "*:[span]:last:flex *:[span]:last:items-center *:[span]:last:gap-2");
        });

        if (Hidden)
            attributes["hidden"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ItemValue);
        hc.Add(Text);
        hc.Add(Disabled);
    }

    public override void Dispose()
    {
        if (_registeredValue.HasContent())
            ParentSelect?.UnregisterItemValue(_registeredValue!);

        base.Dispose();
    }
}
