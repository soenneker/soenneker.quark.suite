@namespace Soenneker.Quark
@typeparam TValue
@inherits Soenneker.Quark.FormControlElement
@implements ISelectItem<TValue>

<div @onclick="HandleItemClick" @attributes="BuildAttributes()" role="option">
    <span data-slot="select-item-indicator" class="absolute right-2 flex size-3.5 items-center justify-center">
        @if (IsSelected)
        {
            <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"></path>
            </svg>
        }
    </span>
    @if (ChildContent != null)
    {
        <span>@ChildContent</span>
    }
    else if (Text.HasContent())
    {
        <span>@Text</span>
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the value of the select item.
    /// </summary>
    [Parameter]
    public TValue? ItemValue { get; set; }

    /// <summary>
    /// Gets or sets the display text for the select item.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    [CascadingParameter(Name = "ParentSelect")]
    private Select<TValue>? ParentSelect { get; set; }

    private bool IsSelected => ParentSelect?.IsSelected(ItemValue) == true;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var itemKey = ItemValue?.ToString();
        if (itemKey.HasContent() && ParentSelect is not null)
            ParentSelect.RegisterItem(itemKey!, Text);
    }

    private async Task HandleItemClick(MouseEventArgs _)
    {
        if (!Disabled && ParentSelect is not null)
            await ParentSelect.SelectItem(ItemValue, Text);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select-item";
        attributes["data-selected"] = IsSelected ? "true" : "false";
        attributes["aria-selected"] = IsSelected ? "true" : "false";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select-item");
            AppendClass(ref cls, "relative flex w-full cursor-default items-center gap-2 rounded-sm py-1.5 pr-8 pl-2 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground hover:bg-accent hover:text-accent-foreground");
            AppendClass(ref cls, "data-[disabled=true]:pointer-events-none data-[disabled=true]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
            AppendClass(ref cls, "*:[span]:last:flex *:[span]:last:items-center *:[span]:last:gap-2");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            attributes["data-disabled"] = "true";
        }

        if (Hidden)
            attributes["hidden"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ItemValue);
        hc.Add(Text);
        hc.Add(Disabled);
        hc.Add(IsSelected);
    }
}