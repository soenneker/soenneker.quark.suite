@namespace Soenneker.Quark
@typeparam TValue
@inherits Soenneker.Quark.FormControlElement
@implements ISelectItem<TValue>
@implements ISelectFocusableItem

<div @onclick="HandleItemClick" @onkeydown="HandleKeyDown" @onkeydown:preventDefault="_preventDefaultKeys" @onkeydown:stopPropagation="_stopPropagation" @onmouseenter="HandleMouseEnter" @attributes="BuildAttributes()" role="option" @ref="_elementRef">
    <span data-slot="select-item-indicator" class="absolute right-2 flex size-3.5 items-center justify-center rtl:right-auto rtl:left-2">
        @if (IsSelected)
        {
            <svg class="size-4" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 6 9 17l-5-5"></path>
            </svg>
        }
    </span>
    @if (ChildContent != null)
    {
        <span>@ChildContent</span>
    }
    else if (Text.HasContent())
    {
        <span>@Text</span>
    }
</div>

@code {
    private ElementReference _elementRef;
    private bool _isActive;
    private bool _preventDefaultKeys;
    private bool _stopPropagation;
    private Select<TValue>? _registeredSelect;

    /// <summary>
    /// Gets or sets the value of the select item.
    /// </summary>
    [Parameter]
    public TValue? ItemValue { get; set; }

    /// <summary>
    /// Gets or sets the display text for the select item.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    [CascadingParameter(Name = "ParentSelect")]
    private Select<TValue>? ParentSelect { get; set; }

    private bool IsSelected => ParentSelect?.IsSelected(ItemValue) == true;
    string? ISelectFocusableItem.Value => ItemValue?.ToString();
    string? ISelectFocusableItem.SearchText => Text.HasContent() ? Text : ItemValue?.ToString();
    string ISelectFocusableItem.ItemId => $"select-item-{Id}";
    bool ISelectFocusableItem.IsDisabledForNavigation => Disabled;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        if (Id.IsNullOrEmpty())
            Id = Guid.NewGuid().ToString("N");
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!ReferenceEquals(_registeredSelect, ParentSelect))
        {
            if (_registeredSelect is not null)
                _registeredSelect.UnregisterFocusableItem(this);

            _registeredSelect = ParentSelect;

            if (_registeredSelect is not null)
                _registeredSelect.RegisterFocusableItem(this);
        }

        var itemKey = ItemValue?.ToString();
        if (itemKey.HasContent() && ParentSelect is not null)
            ParentSelect.RegisterItem(itemKey!, Text);
    }

    private async Task HandleItemClick(MouseEventArgs _)
    {
        if (!Disabled && ParentSelect is not null)
            await ParentSelect.SelectItem(ItemValue, Text);
    }

    private Task HandleMouseEnter(MouseEventArgs _)
    {
        ParentSelect?.SetActiveItem(this);
        return Task.CompletedTask;
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKeys = false;
        _stopPropagation = false;

        if (ParentSelect is null || Disabled)
            return;

        if (!e.CtrlKey && !e.MetaKey && !e.AltKey && e.Key.Length == 1 && !char.IsControl(e.Key[0]))
        {
            if (await ParentSelect.TryHandleTypeaheadAsync(e.Key))
            {
                _preventDefaultKeys = true;
                return;
            }
        }

        if (e.Key is "ArrowDown" or "ArrowUp" or "Home" or "End")
        {
            await ParentSelect.HandleItemNavigationAsync(this, e.Key);
            _preventDefaultKeys = true;
        }
        else if (e.Key is "Enter" or " ")
        {
            await ParentSelect.SelectItem(ItemValue, Text);
            _preventDefaultKeys = true;
        }
        else if (e.Key == "Escape")
        {
            await ParentSelect.CloseFromKeyboardAsync();
            _preventDefaultKeys = true;
            _stopPropagation = true;
        }

        await base.HandleKeyDown(e);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select-item";
        attributes["aria-selected"] = IsSelected ? "true" : "false";
        attributes["id"] = $"select-item-{Id}";
        attributes["tabindex"] = -1;

        if (_isActive)
            attributes["data-highlighted"] = string.Empty;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select-item");
            AppendClass(ref cls, "relative flex w-full cursor-default items-center gap-2 rounded-sm py-1.5 pr-8 pl-2 rtl:pr-2 rtl:pl-8 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground hover:bg-accent hover:text-accent-foreground");
            AppendClass(ref cls, "data-[highlighted]:bg-accent data-[highlighted]:text-accent-foreground");
            AppendClass(ref cls, "data-[disabled=true]:pointer-events-none data-[disabled=true]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 [&_svg:not([class*='text-'])]:text-muted-foreground");
            AppendClass(ref cls, "*:[span]:last:flex *:[span]:last:items-center *:[span]:last:gap-2");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            attributes["data-disabled"] = "true";
        }

        if (Hidden)
            attributes["hidden"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ItemValue);
        hc.Add(Text);
        hc.Add(Disabled);
        hc.Add(IsSelected);
        hc.Add(_isActive);
    }

    async Task ISelectFocusableItem.FocusAsync()
    {
        await _elementRef.FocusAsync();
    }

    async Task ISelectFocusableItem.InvokeSelectAsync()
    {
        if (Disabled || ParentSelect is null)
            return;

        await ParentSelect.SelectItem(ItemValue, Text);
    }

    void ISelectFocusableItem.SetActive(bool active)
    {
        if (_isActive != active)
        {
            _isActive = active;
            Refresh();
        }
    }

    ElementReference ISelectFocusableItem.GetScrollAnchor()
    {
        return _elementRef;
    }

    public override void Dispose()
    {
        if (_registeredSelect is not null)
            _registeredSelect.UnregisterFocusableItem(this);

        base.Dispose();
    }
}
