@namespace Soenneker.Quark
@typeparam TValue
@inherits Soenneker.Quark.FormControlElement
@implements ISelectItem<TValue>

<div @onclick="HandleItemClick" @attributes="BuildAttributes()" role="option">
    @if (ChildContent != null)
    {
        @ChildContent
    }
    else if (Text.HasContent())
    {
        @Text
    }
</div>

@code {
    /// <summary>
    /// Gets or sets the value of the select item.
    /// </summary>
    [Parameter]
    public TValue? ItemValue { get; set; }

    /// <summary>
    /// Gets or sets the display text for the select item.
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    [CascadingParameter(Name = "ParentSelect")]
    private Select<TValue>? ParentSelect { get; set; }

    private bool IsSelected => ParentSelect?.IsSelected(ItemValue) == true;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        var itemKey = ItemValue?.ToString();
        if (itemKey.HasContent() && ParentSelect is not null)
            ParentSelect.RegisterItem(itemKey!, Text);
    }

    private async Task HandleItemClick(MouseEventArgs _)
    {
        if (!Disabled && ParentSelect is not null)
            await ParentSelect.SelectItem(ItemValue, Text);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "select-item";
        attributes["data-selected"] = IsSelected ? "true" : "false";
        attributes["aria-selected"] = IsSelected ? "true" : "false";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-select-item");
            AppendClass(ref cls, "relative flex w-full cursor-default select-none items-center rounded-sm px-2 py-1.5 text-sm outline-none");
            AppendClass(ref cls, "data-[selected=true]:bg-accent data-[selected=true]:text-accent-foreground");
            AppendClass(ref cls, "hover:bg-accent hover:text-accent-foreground");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            attributes["data-disabled"] = "true";
        }

        if (Hidden)
            attributes["hidden"] = true;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ItemValue);
        hc.Add(Text);
        hc.Add(Disabled);
        hc.Add(IsSelected);
    }
}