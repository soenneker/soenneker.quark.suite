@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@* shadcn - new-york-v4 ui/chart.tsx (Recharts wrapper)
   Styled container for charts. Use with ApexCharts.Blazor, ChartJs.Blazor, or custom SVG.
   Applies aspect-video, text-xs, and chart-specific focus/selection styles. *@
<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    /// <summary>
    /// Optional chart ID for CSS variable scoping (e.g. --color-foo).
    /// </summary>
    [Parameter]
    public new string? Id { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "chart";
        if (Id.HasContent())
            attributes["data-chart"] = Id;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-chart");
            AppendClass(ref cls, "flex aspect-video justify-center text-xs");
            AppendClass(ref cls, "[&_.recharts-cartesian-axis-tick_text]:fill-muted-foreground [&_.recharts-cartesian-grid_line[stroke='#ccc']]:stroke-border/50 [&_.recharts-curve.recharts-tooltip-cursor]:stroke-border [&_.recharts-dot[stroke='#fff']]:stroke-transparent [&_.recharts-layer]:outline-hidden [&_.recharts-polar-grid_[stroke='#ccc']]:stroke-border [&_.recharts-radial-bar-background-sector]:fill-muted [&_.recharts-rectangle.recharts-tooltip-cursor]:fill-muted [&_.recharts-reference-line_[stroke='#ccc']]:stroke-border [&_.recharts-sector]:outline-hidden [&_.recharts-sector[stroke='#fff']]:stroke-transparent [&_.recharts-surface]:outline-hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Id);
    }
}
