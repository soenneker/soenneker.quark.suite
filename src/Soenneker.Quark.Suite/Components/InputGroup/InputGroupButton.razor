@namespace Soenneker.Quark
@using ButtonSizeType = Soenneker.Quark.ButtonSize
@inherits Soenneker.Quark.Element
@implements IInputGroupButton

<Button Type="@Type" Variant="@Variant" ButtonSize="@ButtonSize" Attributes="BuildAttributes()">@ChildContent</Button>

@code {
    [Parameter]
    public ButtonSize ButtonSize { get; set; } = ButtonSizeType.Xs;

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Ghost;

    [Parameter]
    public ButtonType Type { get; set; } = ButtonType.Button;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Shadow ??= Quark.Shadow.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "input-group-button";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex items-center gap-2 text-sm");
            AppendClass(ref cls, Button.GetInputGroupButtonSizeClass(ButtonSize?.Value));
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ButtonSize);
        hc.Add(Variant);
        hc.Add(Type);
    }
}
