@namespace Soenneker.Quark
@using ButtonSizeType = Soenneker.Quark.ButtonSize
@inherits Soenneker.Quark.Element
@implements IInputGroupButton

<Button Type="@Type" Variant="@Variant" ButtonSize="@ButtonSize" InputGroupButton="true" Attributes="BuildAttributes()">@ChildContent</Button>

@code {
    [Parameter]
    public CssValue<ButtonSizeBuilder> ButtonSize { get; set; } = ButtonSizeType.Default;

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    [Parameter]
    public ButtonType Type { get; set; } = ButtonType.Button;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Is2;
        Shadow ??= Quark.Shadow.None;
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, Button.GetInputGroupButtonSizeClass(ButtonSize));
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ButtonSize);
        hc.Add(Variant);
        hc.Add(Type);
    }
}
