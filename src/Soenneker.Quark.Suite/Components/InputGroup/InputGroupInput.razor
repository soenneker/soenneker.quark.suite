@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IInputGroupInput

<input @ref="_elementRef"
       value="@Value"
       @oninput="HandleInput"
       @onchange="HandleChange"
       @attributes="BuildAttributes()" />

@code {
    private ElementReference _elementRef;
    private bool _hasPendingNativeTimeValue;
    private string? _pendingNativeTimeValue;
    private bool _suppressNextRender;

    [CascadingParameter]
    internal InputGroupContext? InputGroupContext { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string? Type { get; set; } = "text";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "input-group-control";
        Height ??= Quark.Height.Is8;
        Width ??= Quark.Width.IsFull;
        MinWidth ??= Quark.MinWidth.Is0;
        BorderColor ??= Quark.BorderColor.Input.OnFocusVisible.Ring;
        Padding ??= Quark.Padding.OnX.Is2_5.OnY.Is1;
        TextSize ??= Quark.TextSize.Base.OnMd.Sm;
        Transition ??= Quark.Transition.Token("transition-colors");
        OutlineStyle ??= Quark.OutlineStyle.None;
        Flex ??= Quark.Flex.Is1;
        Rounded ??= Quark.Rounded.None;
        Border ??= Quark.Border.Is0;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Shadow ??= Quark.Shadow.None;
        Ring ??= Quark.Ring.None;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Cursor ??= Quark.Cursor.NotAllowed.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (IsNativeTimeInput())
        {
            TrackPendingNativeTimeValue(e);
            return;
        }

        var value = e.Value?.ToString();
        Value = value;
        await ValueChanged.InvokeIfHasDelegate(value);
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        if (IsNativeTimeInput())
        {
            TrackPendingNativeTimeValue(e);
            return;
        }

        var value = e.Value?.ToString();
        Value = value;
        await ValueChanged.InvokeIfHasDelegate(value);
    }

    private void TrackPendingNativeTimeValue(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        Value = value;
        _pendingNativeTimeValue = value;
        _hasPendingNativeTimeValue = true;
        _suppressNextRender = true;
    }

    private async Task HandleInputBlur(FocusEventArgs e)
    {
        if (_hasPendingNativeTimeValue)
        {
            _hasPendingNativeTimeValue = false;
            var value = _pendingNativeTimeValue;
            _pendingNativeTimeValue = null;
            await ValueChanged.InvokeIfHasDelegate(value);
        }

        await OnBlur.InvokeIfHasDelegate(e);
    }

    protected override bool ShouldRender()
    {
        if (_suppressNextRender)
        {
            _suppressNextRender = false;
            return false;
        }

        return base.ShouldRender();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            InputGroupContext?.RegisterControl(_elementRef);

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var inputType = Type;
        if (!string.IsNullOrWhiteSpace(inputType) && !string.Equals(inputType, "text", StringComparison.OrdinalIgnoreCase))
            attributes["type"] = inputType;

        if (IsNativeTimeInput() || OnBlur.HasDelegate)
            attributes["onblur"] = EventCallback.Factory.Create<FocusEventArgs>(this, HandleInputBlur);

        if (Placeholder is not null)
            attributes["placeholder"] = Placeholder;
        if (Disabled)
            attributes["disabled"] = true;
        if (ReadOnly)
            attributes["readonly"] = true;
        if (Required)
            attributes["required"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "file:inline-flex file:h-6 file:border-0 file:bg-transparent file:text-sm file:font-medium file:text-foreground placeholder:text-muted-foreground");
            AppendClass(ref cls, "focus-visible:ring-0 disabled:bg-transparent aria-invalid:border-destructive aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "dark:bg-transparent dark:disabled:bg-transparent dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
        });
    }

    private bool IsNativeTimeInput() => string.Equals(Type, "time", StringComparison.OrdinalIgnoreCase);

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Type);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
    }
}
