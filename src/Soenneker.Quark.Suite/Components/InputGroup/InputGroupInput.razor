@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IInputGroupInput

<input @ref="_elementRef"
       value="@Value"
       @oninput="HandleInput"
       @onchange="HandleChange"
       @attributes="BuildAttributes()" />

@code {
    private ElementReference _elementRef;

    [CascadingParameter]
    internal InputGroupContext? InputGroupContext { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string? Type { get; set; } = "text";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "input-group-control";
        Height ??= Quark.Height.Is8;
        Width ??= Quark.Width.IsFull;
        MinWidth ??= Quark.MinWidth.Is0;
        BorderColor ??= Quark.BorderColor.Input.OnFocusVisible.Ring;
        Padding ??= Quark.Padding.OnX.Is2_5.OnY.Is1;
        TextSize ??= Quark.TextSize.Base.OnMd.Sm;
        Transition ??= Quark.Transition.Token("transition-colors");
        OutlineStyle ??= Quark.OutlineStyle.None;
        Flex ??= Quark.Flex.Is1;
        Rounded ??= Quark.Rounded.None;
        Border ??= Quark.Border.Is0;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Shadow ??= Quark.Shadow.None;
        Ring ??= Quark.Ring.None;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Cursor ??= Quark.Cursor.NotAllowed.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
        TextColor ??= Quark.TextColor.MutedForeground.Modifier("placeholder");
        FontWeight ??= Quark.FontWeight.Medium.Modifier("file");
        Display ??= Quark.Display.InlineFlex.Modifier("file");
    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        Value = value;
        await ValueChanged.InvokeIfHasDelegate(value);
    }

    private async Task HandleChange(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        Value = value;
        await ValueChanged.InvokeIfHasDelegate(value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            InputGroupContext?.RegisterControl(_elementRef);

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var inputType = Type;
        if (!string.IsNullOrWhiteSpace(inputType) && !string.Equals(inputType, "text", StringComparison.OrdinalIgnoreCase))
            attributes["type"] = inputType;

        if (Placeholder is not null)
            attributes["placeholder"] = Placeholder;
        if (Disabled)
            attributes["disabled"] = true;
        if (ReadOnly)
            attributes["readonly"] = true;
        if (Required)
            attributes["required"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "file:h-6 file:border-0 file:bg-transparent file:text-sm file:text-foreground");
            AppendClass(ref cls, "aria-invalid:border-destructive dark:aria-invalid:border-destructive/50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Type);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
    }
}
