@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IInputGroupInput

<Input Value="@Value"
       ValueChanged="HandleValueChanged"
       Type="@Type"
       Placeholder="@Placeholder"
       Disabled="@Disabled"
       ReadOnly="@ReadOnly"
       Required="@Required"
       Attributes="BuildInnerAttributes()" />

@code {

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string? Type { get; set; } = "text";

    protected override void ApplyDefaultParameters()
    {
        Flex ??= Quark.Flex.Is1;
        Rounded ??= Quark.Rounded.None;
        Border ??= Quark.Border.Is0;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        BoxShadow ??= Quark.BoxShadow.None;
        Ring ??= Quark.Ring.None;

        base.ApplyDefaultParameters();
    }

    private async Task HandleValueChanged(string? value)
    {
        Value = value;
        await ValueChanged.InvokeIfHasDelegate(value);
    }

    private Dictionary<string, object> BuildInnerAttributes()
    {
        var attributes = new Dictionary<string, object>(BuildAttributes());
        attributes["data-slot"] = "input-group-control";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "focus-visible:ring-0 disabled:bg-transparent aria-invalid:ring-0 dark:bg-transparent dark:disabled:bg-transparent");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Value);
        hc.Add(Type);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
    }
}
