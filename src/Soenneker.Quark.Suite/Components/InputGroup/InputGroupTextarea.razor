@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IInputGroupTextarea

<textarea @ref="_elementRef"
          @attributes="BuildAttributes()"
          value="@Value"
          @oninput="HandleInput"></textarea>

@code {
    private ElementReference _elementRef;

    [CascadingParameter]
    internal InputGroupContext? InputGroupContext { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public int? Rows { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        BorderColor ??= Quark.BorderColor.Input;
        Flex ??= Quark.Flex.Is1;
        Resize ??= Quark.Resize.None;
        Rounded ??= Quark.Rounded.None;
        Border ??= Quark.Border.Is0;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        Padding ??= Quark.Padding.Token("2.5").OnX.Is2.OnY;
        Shadow ??= Quark.Shadow.None;
        Ring ??= Quark.Ring.None;
        TextSize ??= Quark.TextSize.Base.OnMd.Sm;
        Transition ??= Quark.Transition.Token("transition-colors");
        OutlineStyle ??= Quark.OutlineStyle.None;

    }

    private async Task HandleInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        Value = value;
        await ValueChanged.InvokeIfHasDelegate(value);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            InputGroupContext?.RegisterControl(_elementRef);

        await base.OnAfterRenderAsync(firstRender);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "input-group-control";

        if (Placeholder is not null)
            attributes["placeholder"] = Placeholder;
        if (Disabled)
            attributes["disabled"] = true;
        if (ReadOnly)
            attributes["readonly"] = true;
        if (Required)
            attributes["required"] = true;
        if (Rows.HasValue)
            attributes["rows"] = Rows.Value;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "field-sizing-content min-h-16 placeholder:text-muted-foreground focus-visible:border-ring focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:cursor-not-allowed disabled:opacity-50 disabled:bg-transparent dark:disabled:bg-transparent");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 aria-invalid:ring-0 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "focus-visible:ring-0 dark:bg-transparent");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Placeholder);
        hc.Add(Disabled);
        hc.Add(ReadOnly);
        hc.Add(Required);
        hc.Add(Rows);
    }
}
