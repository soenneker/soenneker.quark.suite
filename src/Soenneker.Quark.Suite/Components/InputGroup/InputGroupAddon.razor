@namespace Soenneker.Quark
@using Microsoft.JSInterop
@inherits Soenneker.Quark.Element
@implements IInputGroupAddon
@inject IJSRuntime JSRuntime

<div @ref="_elementRef" @onclick="HandleAddonClick" @attributes="BuildAttributes()">@ChildContent</div>

@code {
    private const string _modulePath = "./_content/Soenneker.Quark.Suite/js/inputgroupinterop.js";
    private ElementReference _elementRef;
    private IJSObjectReference? _module;

    [Parameter]
    public InputGroupAddonAlign AddonAlign { get; set; } = InputGroupAddonAlign.InlineStart;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Auto;
        Cursor ??= Quark.Cursor.Text;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Padding ??= Quark.Padding.Token("1.5").OnY;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        TextColor ??= Quark.TextColor.MutedForeground;
        UserSelect ??= Quark.UserSelect.None;

        ApplyAlignDefaults();
    }

    private void ApplyAlignDefaults()
    {
        switch (AddonAlign?.Value)
        {
            case InputGroupAddonAlign.InlineEndValue:
                Padding ??= Quark.Padding.Token("1.5").OnY.Is3.FromRight;
                break;
            case InputGroupAddonAlign.BlockStartValue:
                Width ??= Quark.Width.IsFull;
                Justify ??= Quark.Justify.Start;
                Padding ??= Quark.Padding.Is3.OnX.Is3.FromTop;
                break;
            case InputGroupAddonAlign.BlockEndValue:
                Width ??= Quark.Width.IsFull;
                Justify ??= Quark.Justify.Start;
                Padding ??= Quark.Padding.Is3.OnX.Is3.FromBottom;
                break;
            default:
                Padding ??= Quark.Padding.Token("1.5").OnY.Is3.FromLeft;
                break;
        }
    }

    private static string GetAlignValue(InputGroupAddonAlign align)
        => align?.Value switch
        {
            InputGroupAddonAlign.InlineEndValue => "inline-end",
            InputGroupAddonAlign.BlockStartValue => "block-start",
            InputGroupAddonAlign.BlockEndValue => "block-end",
            _ => "inline-start"
        };

    private static string GetAlignClass(InputGroupAddonAlign align)
        => align?.Value switch
        {
            InputGroupAddonAlign.InlineEndValue => "order-last has-[>button]:mr-[-0.45rem] has-[>kbd]:mr-[-0.35rem]",
            InputGroupAddonAlign.BlockStartValue => "order-first group-has-[>input]/input-group:pt-2.5 [.border-b]:pb-3",
            InputGroupAddonAlign.BlockEndValue => "order-last group-has-[>input]/input-group:pb-2.5 [.border-t]:pt-3",
            _ => "order-first has-[>button]:ml-[-0.45rem] has-[>kbd]:ml-[-0.35rem]"
        };

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["role"] = "group";
        attributes["data-slot"] = "input-group-addon";
        attributes["data-align"] = GetAlignValue(AddonAlign);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group-data-[disabled=true]/input-group:opacity-50 [&>kbd]:rounded-[calc(var(--radius)-5px)] [&>svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, GetAlignClass(AddonAlign));
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(AddonAlign);
    }

    private async Task HandleAddonClick(MouseEventArgs _)
    {
        _module ??= await JSRuntime.InvokeAsync<IJSObjectReference>("import", _modulePath);
        await _module.InvokeVoidAsync("focusInputFromAddon", _elementRef);
    }

    public override async ValueTask DisposeAsync()
    {
        if (_module is not null)
            await _module.DisposeAsync();

        await base.DisposeAsync();
    }
}
