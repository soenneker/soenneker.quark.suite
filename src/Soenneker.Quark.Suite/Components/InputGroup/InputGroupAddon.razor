@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IInputGroupAddon

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    [Parameter]
    public InputGroupAddonAlign Align { get; set; } = InputGroupAddonAlign.InlineStart;

    private static string GetAlignValue(InputGroupAddonAlign align)
        => align?.Value switch
        {
            InputGroupAddonAlign.InlineEndValue => "inline-end",
            InputGroupAddonAlign.BlockStartValue => "block-start",
            InputGroupAddonAlign.BlockEndValue => "block-end",
            _ => "inline-start"
        };

    private static string GetAlignClass(InputGroupAddonAlign align)
        => align?.Value switch
        {
            InputGroupAddonAlign.InlineEndValue => "order-last pr-2 has-[>button]:mr-[-0.3rem] has-[>kbd]:mr-[-0.15rem]",
            InputGroupAddonAlign.BlockStartValue => "order-first w-full justify-start px-2.5 group-has-[>input]/input-group:pt-2 [.border-b]:pb-2 pt-3",
            InputGroupAddonAlign.BlockEndValue => "order-last w-full justify-start px-2.5 pb-2 group-has-[>input]/input-group:pb-2 [.border-t]:pt-2",
            _ => "order-first pl-2 has-[>button]:ml-[-0.3rem] has-[>kbd]:ml-[-0.15rem]"
        };

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["role"] = "group";
        attributes["data-slot"] = "input-group-addon";
        attributes["data-align"] = GetAlignValue(Align);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-input-group-addon");
            AppendClass(ref cls, "flex h-auto cursor-text items-center justify-center gap-2 py-1.5 text-sm font-medium text-muted-foreground select-none group-data-[disabled=true]/input-group:opacity-50 [&>kbd]:rounded-[calc(var(--radius)-5px)] [&>svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, GetAlignClass(Align));
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Align);
    }
}
