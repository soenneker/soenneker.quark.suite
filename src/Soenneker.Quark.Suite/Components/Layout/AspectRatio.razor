@using Soenneker.Bradix

@namespace Soenneker.Quark.Components.Layout
@inherits Soenneker.Quark.Element

<BradixAspectRatio Ratio="@ResolvedRatio"
                   AdditionalAttributes="@AspectRatioAttributes">
    @ChildContent
</BradixAspectRatio>

@code {
    /// <summary>
    /// Aspect ratio as width/height (e.g. 16/9, 4/3, 1).
    /// Matches Radix AspectRatio ratio prop.
    /// </summary>
    [Parameter]
    public double Ratio { get; set; } = 16.0 / 9.0;

    private double ResolvedRatio => Ratio > 0 ? Ratio : 16.0 / 9.0;

    private IReadOnlyDictionary<string, object> AspectRatioAttributes => BuildAspectRatioAttributes();

    private IReadOnlyDictionary<string, object> BuildAspectRatioAttributes()
    {
        return BuildAttributes();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "aspect-ratio";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Ratio);
    }
}
