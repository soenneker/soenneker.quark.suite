@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixScrollAreaScrollbar Orientation="@Orientation"
                          ForceMount="@ForceMount"
                          AdditionalAttributes="@ScrollbarAttributes">
    <BradixScrollAreaThumb ForceMount="@ForceMount" AdditionalAttributes="@ThumbAttributes" />
</BradixScrollAreaScrollbar>

@code {
    private static readonly IReadOnlyDictionary<string, object> ThumbAttributes = new Dictionary<string, object>
    {
        ["data-slot"] = "scroll-area-thumb",
        ["class"] = "relative flex-1 rounded-full bg-border"
    };

    /// <summary>
    /// Gets or sets the orientation: vertical or horizontal.
    /// </summary>
    [Parameter]
    public Orientation Orientation { get; set; } = Orientation.Vertical;

    /// <summary>
    /// Forces the scrollbar and thumb to remain mounted, matching Radix ScrollAreaScrollbar forceMount.
    /// </summary>
    [Parameter]
    public bool ForceMount { get; set; }

    private IReadOnlyDictionary<string, object> ScrollbarAttributes => BuildScrollbarAttributes();
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "scroll-area-scrollbar";

        Display ??= Quark.Display.Flex;
        Padding ??= Quark.Padding.IsPx;
        UserSelect ??= Quark.UserSelect.None;
        Transition ??= Quark.Transition.Colors;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "touch-none");
            AppendClass(ref cls, "data-[orientation=horizontal]:h-2.5 data-[orientation=horizontal]:flex-col data-[orientation=horizontal]:border-t data-[orientation=horizontal]:border-t-transparent");
            AppendClass(ref cls, "data-[orientation=vertical]:h-full data-[orientation=vertical]:w-2.5 data-[orientation=vertical]:border-l data-[orientation=vertical]:border-l-transparent");
        });
    }

    private IReadOnlyDictionary<string, object> BuildScrollbarAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
        hc.Add(ForceMount);
    }
}
