@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixScrollAreaScrollbar Orientation="@ResolvedOrientation"
                          ForceMount="@ForceMount"
                          AdditionalAttributes="@ScrollbarAttributes">
    <BradixScrollAreaThumb ForceMount="@ForceMount" AdditionalAttributes="@ThumbAttributes" />
</BradixScrollAreaScrollbar>

@code {
    /// <summary>
    /// Gets or sets the orientation: vertical or horizontal.
    /// </summary>
    [Parameter]
    public string Orientation { get; set; } = "vertical";

    /// <summary>
    /// Forces the scrollbar and thumb to remain mounted, matching Radix ScrollAreaScrollbar forceMount.
    /// </summary>
    [Parameter]
    public bool ForceMount { get; set; }

    private BradixOrientation ResolvedOrientation =>
        Orientation == "horizontal" ? BradixOrientation.Horizontal : BradixOrientation.Vertical;

    private IReadOnlyDictionary<string, object> ScrollbarAttributes => BuildScrollbarAttributes();
    private IReadOnlyDictionary<string, object> ThumbAttributes => BuildThumbAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Padding ??= Quark.Padding.Token("px");
        UserSelect ??= Quark.UserSelect.None;
        Transition ??= Quark.Transition.Colors;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "scroll-area-scrollbar";
        attributes["data-orientation"] = Orientation;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "touch-none data-[orientation=horizontal]:h-2.5 data-[orientation=horizontal]:flex-col data-[orientation=horizontal]:border-t data-[orientation=horizontal]:border-t-transparent data-[orientation=vertical]:h-full data-[orientation=vertical]:w-2.5 data-[orientation=vertical]:border-l data-[orientation=vertical]:border-l-transparent");
        });
    }

    private IReadOnlyDictionary<string, object> BuildScrollbarAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-orientation");
        attributes.Remove("data-state");
        return attributes;
    }

    private IReadOnlyDictionary<string, object> BuildThumbAttributes()
    {
        return new Dictionary<string, object>
        {
            ["data-slot"] = "scroll-area-thumb",
            ["class"] = "relative flex-1 rounded-full bg-border"
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Orientation);
        hc.Add(ForceMount);
    }
}
