@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IStack

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    [Parameter]
    public StackOrientation Orientation { get; set; } = StackOrientation.Vertical;

    [Parameter]
    public bool Inline { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "stack";

        Display ??= Inline ? Quark.Display.InlineFlex : Quark.Display.Flex;
        FlexDirection ??= Orientation == StackOrientation.Horizontal ? Quark.FlexDirection.Row : Quark.FlexDirection.Col;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);

        hc.Add(Orientation);
        hc.Add(Inline);
    }
}