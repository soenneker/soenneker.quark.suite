@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixScrollArea Dir="@ResolvedDir"
                  AdditionalAttributes="@RootAttributes">
    <BradixScrollAreaViewport AdditionalAttributes="@ViewportAttributes">
        @ChildContent
    </BradixScrollAreaViewport>

    @if (ShowVerticalScrollBar)
    {
        <ScrollBar />
    }

    @if (ShowHorizontalScrollBar)
    {
        <ScrollBar Orientation="horizontal" />
    }

    @if (ShowVerticalScrollBar && ShowHorizontalScrollBar)
    {
        <BradixScrollAreaCorner AdditionalAttributes="@CornerAttributes" />
    }
</BradixScrollArea>

@code {
    [Parameter]
    public bool ShowVerticalScrollBar { get; set; } = true;

    [Parameter]
    public bool ShowHorizontalScrollBar { get; set; }

    [CascadingParameter(Name = "DirectionProviderDir")]
    private string? DirectionProviderDir { get; set; }

    private string? ResolvedDir
    {
        get
        {
            if (Attributes is not null &&
                Attributes.TryGetValue("dir", out var dirValue) &&
                !string.IsNullOrWhiteSpace(dirValue?.ToString()))
            {
                return dirValue.ToString();
            }

            return DirectionProviderDir;
        }
    }

    private IReadOnlyDictionary<string, object> RootAttributes => BuildAttributes();
    private IReadOnlyDictionary<string, object> ViewportAttributes => BuildViewportAttributes();
    private IReadOnlyDictionary<string, object> CornerAttributes => BuildCornerAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes.Remove("dir");
        attributes["data-slot"] = "scroll-area";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-scroll-area");
            AppendClass(ref cls, "relative");
        });
    }

    private IReadOnlyDictionary<string, object> BuildViewportAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "scroll-area-viewport",
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-scroll-area-viewport");
            AppendClass(ref cls, "size-full rounded-[inherit] overflow-auto transition-[color,box-shadow] outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:outline-1");
            AppendClass(ref cls, "[&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]");
        });

        return attributes;
    }

    private IReadOnlyDictionary<string, object> BuildCornerAttributes()
    {
        return new Dictionary<string, object>
        {
            ["data-slot"] = "scroll-area-corner",
            ["class"] = "bg-border/40 size-2.5"
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ShowVerticalScrollBar);
        hc.Add(ShowHorizontalScrollBar);
        hc.Add(DirectionProviderDir);
        hc.Add(ResolvedDir);
    }
}
