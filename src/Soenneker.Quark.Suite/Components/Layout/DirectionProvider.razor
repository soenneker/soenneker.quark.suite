@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Name="DirectionProviderDir" Value="@DirValue">
    <BradixDirectionProvider Dir="@DirValue">
        <div @attributes="BuildAttributes()">
            @ChildContent
        </div>
    </BradixDirectionProvider>
</CascadingValue>

@code {
    /// <summary>
    /// Text direction: "ltr", "rtl", or "auto".
    /// Matches Radix Direction.DirectionProvider dir prop.
    /// </summary>
    [Parameter]
    public string Dir { get; set; } = "ltr";

    private string DirValue => Dir?.ToLowerInvariant() switch
    {
        "rtl" => "rtl",
        "auto" => "auto",
        _ => "ltr"
    };

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "direction-provider";
        attributes["dir"] = DirValue;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "contents");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Dir);
    }
}
