@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@using Soenneker.Bradix
@using System.Text
@using System.Text.RegularExpressions

<BradixOneTimePasswordField Value="@OtpValue"
                            DefaultValue="@DefaultOtpValue"
                            ValueChanged="HandleValueChanged"
                            AutoComplete="@AutoComplete"
                            AutoFocus="@AutoFocus"
                            Disabled="@Disabled"
                            InputMode="@InputMode"
                            Name="@Name"
                            Pattern="@Pattern"
                            ReadOnly="@ReadOnly"
                            Required="@Required"
                            SanitizeValue="Sanitize"
                            ValidationType="none"
                            AdditionalAttributes="@RootAttributes">
    @ChildContent
</BradixOneTimePasswordField>

@code {

    /// <summary>
    /// Gets or sets the OTP value.
    /// </summary>
    [Parameter]
    public string? OtpValue { get; set; }

    /// <summary>
    /// Gets or sets the initial OTP value for uncontrolled usage.
    /// </summary>
    [Parameter]
    public string? DefaultOtpValue { get; set; }

    /// <summary>
    /// Gets or sets the callback when the OTP value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> OtpValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the number of slots.
    /// </summary>
    [Parameter]
    public int Length { get; set; } = 6;

    /// <summary>
    /// Optional regex pattern used to validate entered characters.
    /// </summary>
    [Parameter]
    public string? Pattern { get; set; }

    /// <summary>
    /// Controls the virtual keyboard hint for the hidden input.
    /// </summary>
    [Parameter]
    public string? InputMode { get; set; }

    /// <summary>
    /// Gets or sets the autocomplete attribute for the hidden input.
    /// </summary>
    [Parameter]
    public string AutoComplete { get; set; } = "one-time-code";

    internal string? InputId => Id;

    private IReadOnlyDictionary<string, object> RootAttributes => BuildRootAttributes();

    private string Sanitize(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return string.Empty;

        if (string.IsNullOrWhiteSpace(Pattern))
            return value;

        var builder = new StringBuilder(value.Length);

        foreach (var character in value)
        {
            if (Regex.IsMatch(character.ToString(), Pattern, RegexOptions.CultureInvariant))
                builder.Append(character);
        }

        return builder.ToString();
    }

    private async Task HandleValueChanged(string value)
    {
        var sanitized = Sanitize(value);

        if (sanitized.Length > Length)
            sanitized = sanitized[..Length];

        if (OtpValue is not null)
        {
            OtpValue = sanitized;
            InvalidateRender();
            Refresh();
        }

        await OtpValueChanged.InvokeAsync(sanitized);
    }

    private IReadOnlyDictionary<string, object> BuildRootAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("id");
        attributes.Remove("role");
        attributes.Remove("dir");
        attributes.Remove("data-orientation");
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "input-otp";

        if (attributes.ContainsKey("id"))
            attributes.Remove("id");

        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "cn-input-otp flex items-center gap-2 has-disabled:opacity-50");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(OtpValue);
        hc.Add(DefaultOtpValue);
        hc.Add(Length);
        hc.Add(Pattern);
        hc.Add(InputMode);
        hc.Add(AutoComplete);
        hc.Add(Disabled);
    }
}
