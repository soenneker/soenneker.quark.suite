@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@using Soenneker.Bradix
@using System.Text
@using System.Text.RegularExpressions

<CascadingValue Value="_context" IsFixed="false">
    <div data-input-otp-container="true" style="@ContainerStyle" class="cn-input-otp inline-flex items-center has-disabled:opacity-50">
        @ChildContent
        <div style="position:absolute;inset:0;pointer-events:none">
            <input @ref="_inputRef"
                   value="@CurrentValue"
                   @oninput="HandleInput"
                   @onfocus="HandleOtpFocus"
                   @onblur="HandleOtpBlur"
                   @attributes="BuildAttributes()" />
        </div>
    </div>
</CascadingValue>

@code {
    private InputOtpContext _context = new();
    private ElementReference _inputRef;
    private string _uncontrolledValue = string.Empty;
    private string? _cachedPattern;
    private Regex? _cachedPatternRegex;

    private string CurrentValue => OtpValue ?? _uncontrolledValue;

    /// <summary>
    /// Gets or sets the OTP value.
    /// </summary>
    [Parameter]
    public string? OtpValue { get; set; }

    /// <summary>
    /// Gets or sets the initial OTP value for uncontrolled usage.
    /// </summary>
    [Parameter]
    public string? DefaultOtpValue { get; set; }

    /// <summary>
    /// Gets or sets the callback when the OTP value changes.
    /// </summary>
    [Parameter]
    public EventCallback<string> OtpValueChanged { get; set; }

    /// <summary>
    /// Gets or sets the number of slots.
    /// </summary>
    [Parameter]
    public int Length { get; set; } = 6;

    /// <summary>
    /// Optional regex pattern used to validate entered characters.
    /// </summary>
    [Parameter]
    public string? Pattern { get; set; }

    /// <summary>
    /// Controls the virtual keyboard hint for the hidden input.
    /// </summary>
    [Parameter]
    public string? InputMode { get; set; } = "numeric";

    /// <summary>
    /// Sets the OTP package root height custom property used by the transparent input.
    /// </summary>
    [Parameter]
    public string RootHeight { get; set; } = "32px";

    /// <summary>
    /// Gets or sets the autocomplete attribute for the hidden input.
    /// </summary>
    [Parameter]
    public string AutoComplete { get; set; } = "one-time-code";

    internal string? InputId => Id;

    private string Sanitize(string? value)
    {
        if (string.IsNullOrEmpty(value))
            return string.Empty;

        if (string.IsNullOrWhiteSpace(Pattern))
            return value;

        var regex = GetPatternRegex();
        StringBuilder? builder = null;

        for (var i = 0; i < value.Length; i++)
        {
            var character = value[i];
            if (regex.IsMatch(value.AsSpan(i, 1)))
            {
                builder?.Append(character);
                continue;
            }

            if (builder is null)
            {
                builder = new StringBuilder(value.Length);
                if (i > 0)
                    builder.Append(value, 0, i);
            }
        }

        return builder?.ToString() ?? value;
    }

    private Regex GetPatternRegex()
    {
        if (_cachedPatternRegex is not null && string.Equals(_cachedPattern, Pattern, StringComparison.Ordinal))
            return _cachedPatternRegex;

        _cachedPattern = Pattern;
        _cachedPatternRegex = new Regex(Pattern!, RegexOptions.CultureInvariant);
        return _cachedPatternRegex;
    }

    protected override void OnInitialized()
    {
        _uncontrolledValue = Sanitize(DefaultOtpValue ?? string.Empty);
        SyncContext();
    }

    protected override void OnParametersSet()
    {
        SyncContext();
        base.OnParametersSet();
    }

    private Task HandleInput(ChangeEventArgs args)
    {
        return SetValue(args.Value?.ToString() ?? string.Empty);
    }

    private async Task SetValue(string value)
    {
        var sanitized = Sanitize(value);

        if (sanitized.Length > Length)
            sanitized = sanitized[..Length];

        if (OtpValue is null)
            _uncontrolledValue = sanitized;

        _context = CreateContext(sanitized, focused: true, _context.ActiveIndex);
        await OtpValueChanged.InvokeAsync(sanitized);
    }

    private void HandleOtpFocus(FocusEventArgs _)
    {
        _context = CreateContext(CurrentValue, focused: true, activeIndex: 0);
    }

    private void HandleOtpBlur(FocusEventArgs _)
    {
        _context = CreateContext(CurrentValue, focused: false);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "input-otp";
        Cursor ??= Quark.Cursor.NotAllowed.OnDisabled;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var selectionIndex = CurrentValue.Length < Length ? _context.ActiveIndex : 0;

        attributes["data-input-otp"] = "true";
        attributes["data-input-otp-mss"] = selectionIndex;
        attributes["data-input-otp-mse"] = selectionIndex;
        attributes["type"] = "text";
        attributes["autocomplete"] = AutoComplete;
        attributes["spellcheck"] = "false";
        attributes["maxlength"] = Length;

        if (!string.IsNullOrWhiteSpace(InputMode))
            attributes["inputmode"] = InputMode;

        if (!string.IsNullOrWhiteSpace(Name))
            attributes["name"] = Name;

        if (Disabled)
        {
            attributes["data-disabled"] = "true";
            attributes["disabled"] = true;
        }

        if (ReadOnly)
            attributes["readonly"] = true;

        if (Required)
            attributes["required"] = true;

        attributes["style"] =
            "position:absolute;inset:0;width:100%;height:100%;display:flex;text-align:left;opacity:1;color:transparent;pointer-events:all;background:transparent;caret-color:transparent;border:0 solid transparent;outline:0 solid transparent;box-shadow:none;line-height:1;letter-spacing:-.5em;font-size:var(--root-height);font-family:monospace;font-variant-numeric:tabular-nums";

    }

    private void SyncContext()
    {
        _context = CreateContext(CurrentValue, _context.Focused, _context.ActiveIndex);
    }

    private string ContainerStyle => $"position: relative; display: inline-flex; width: fit-content; cursor: {(Disabled ? "default" : "text")}; user-select: none; pointer-events: none; --root-height: {RootHeight};";

    private InputOtpContext CreateContext(string value, bool focused, int? activeIndex = null)
    {
        return new InputOtpContext
        {
            Value = value,
            Length = Length,
            Focused = focused,
            ActiveIndex = Math.Clamp(activeIndex ?? 0, 0, Math.Max(0, Length - 1))
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(OtpValue);
        hc.Add(DefaultOtpValue);
        hc.Add(Length);
        hc.Add(Pattern);
        hc.Add(InputMode);
        hc.Add(AutoComplete);
        hc.Add(Disabled);
        hc.Add(RootHeight);
    }
}
