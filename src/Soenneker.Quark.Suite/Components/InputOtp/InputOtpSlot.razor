@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix

<BradixOneTimePasswordFieldInput Index="@Index"
                                 AdditionalAttributes="@SlotAttributes" />

@code {
    /// <summary>
    /// Gets or sets the slot index (0-based).
    /// </summary>
    [Parameter]
    public int Index { get; set; }

    private IReadOnlyDictionary<string, object> SlotAttributes => BuildSlotAttributes();

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-index");
        attributes.Remove("data-active");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Token("9");
        Width ??= Quark.Width.Token("9");
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Border ??= Quark.Border.Default.OnY.Default.FromRight;
        BorderColor ??= Quark.BorderColor.Input;
        TextSize ??= Quark.TextSize.Sm;
        Shadow ??= Quark.Shadow.Xs;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;

        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "input-otp-slot";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "first:rounded-l-md first:border-l last:rounded-r-md");
            AppendClass(ref cls, "aria-invalid:border-destructive");
            AppendClass(ref cls, "focus:z-10 focus:border-ring focus:ring-[3px] focus:ring-ring/50 focus:aria-invalid:border-destructive focus:aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "data-[active=true]:z-10 data-[active=true]:border-ring data-[active=true]:ring-[3px] data-[active=true]:ring-ring/50");
            AppendClass(ref cls, "data-[active=true]:aria-invalid:border-destructive data-[active=true]:aria-invalid:ring-destructive/20");
            AppendClass(ref cls, "dark:bg-input/30 dark:data-[active=true]:aria-invalid:ring-destructive/40");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Index);
    }
}
