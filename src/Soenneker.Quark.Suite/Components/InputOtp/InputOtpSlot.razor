@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix

<BradixOneTimePasswordFieldInput Index="@Index"
                                 AdditionalAttributes="@SlotAttributes" />

@code {
    /// <summary>
    /// Gets or sets the slot index (0-based).
    /// </summary>
    [Parameter]
    public int Index { get; set; }

    private IReadOnlyDictionary<string, object> SlotAttributes => BuildSlotAttributes();

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-index");
        attributes.Remove("data-active");
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "input-otp-slot";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-input-otp-slot");
            AppendClass(ref cls, "relative flex h-9 w-9 items-center justify-center border border-input bg-transparent text-center text-sm shadow-xs transition-all outline-none caret-transparent first:rounded-l-md first:border-l last:rounded-r-md");
            AppendClass(ref cls, "dark:bg-input/30");
            AppendClass(ref cls, "data-[active=true]:z-10 data-[active=true]:ring-[3px] data-[active=true]:ring-ring/50");
            AppendClass(ref cls, "aria-invalid:border-destructive data-[active=true]:aria-invalid:ring-destructive/20 data-[active=true]:aria-invalid:border-destructive");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Index);
    }
}
