@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<input type="text"
       inputmode="@(ParentInputOtp?.GetEffectiveInputMode())"
       autocomplete="@(ParentInputOtp?.AutoComplete ?? "one-time-code")"
       spellcheck="false"
       maxlength="@(ParentInputOtp?.Length ?? 6)"
       pattern="@(ParentInputOtp?.Pattern)"
       value="@(ParentInputOtp?.OtpValue ?? "")"
       @oninput="HandleInput"
       @onkeydown="HandleKeyDown"
       @attributes="BuildAttributes()" />

@code {
    [CascadingParameter(Name = "ParentInputOtp")]
    private InputOtp? ParentInputOtp { get; set; }

    private async Task HandleInput(ChangeEventArgs e)
    {
        if (ParentInputOtp == null)
            return;

        var value = e.Value?.ToString() ?? "";
        await ParentInputOtp.SetValue(value);
    }

    protected override async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (ParentInputOtp == null)
            return;

        var value = ParentInputOtp.OtpValue ?? "";

        if (e.Key == "Backspace" && value.Length > 0)
            await ParentInputOtp.SetValue(value[..^1]);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "input-otp-input";

        if (!attributes.ContainsKey("id") && !string.IsNullOrWhiteSpace(ParentInputOtp?.InputId))
            attributes["id"] = ParentInputOtp!.InputId!;

        ApplyFieldControlAttributes(attributes);

        if (ParentInputOtp?.Disabled == true)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-input-otp-input");
            AppendClass(ref cls, "sr-only disabled:cursor-not-allowed");
        });
    }
}
