@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISheetClose

@if (AsChild)
{
    <Span @onclick="HandleWrapperClick" @attributes="BuildWrapperAttributes()">
        @ChildContent
    </Span>
}
else
{
    <button type="button" @onclick="HandleDefaultClick" @attributes="BuildAttributes()">
        @if (ChildContent is null)
        {
            <Svg BoxSize="Quark.Size.Is4" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></Svg>
            <Span ScreenReader="Quark.ScreenReader.Only">Close</Span>
        }
        else
        {
            @ChildContent
        }
    </button>
}

@code {
    [CascadingParameter(Name = nameof(ParentSheet))]
    public Sheet? ParentSheet { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    [Parameter]
    public bool AutoClose { get; set; } = true;

    [Parameter]
    public EventCallback OnClose { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sheet-close";
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "sheet-close-wrapper"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "contents");
        });

        return attributes;
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeIfHasDelegate();

        if (AutoClose && ParentSheet is not null)
            await ParentSheet.Hide();
    }

    private async Task HandleWrapperClick(MouseEventArgs _)
    {
        await HandleClose();
    }

    private async Task HandleDefaultClick(MouseEventArgs e)
    {
        await HandleClose();
        await base.HandleClick(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(AutoClose);
    }
}
