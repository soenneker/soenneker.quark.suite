@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISheetTitle
@implements IDisposable

<h2 @attributes="BuildAttributes()">
    @ChildContent
</h2>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private OverlayLabelContext? _registeredContext;
    private IDisposable? _titleRegistration;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (ReferenceEquals(_registeredContext, Context))
            return;

        _titleRegistration?.Dispose();
        _registeredContext = Context;
        _titleRegistration = Context?.RegisterTitle();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        // shadcn SheetTitle - new-york-v4 ui/sheet.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-sheet-title");
            AppendClass(ref cls, "text-foreground font-semibold");
        });

        attributes["data-slot"] = "sheet-title";

        if (!attributes.ContainsKey("id") && Context is not null)
            attributes["id"] = Context.TitleId;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.TitleId);
    }

    public override void Dispose()
    {
        _titleRegistration?.Dispose();
        base.Dispose();
    }
}
