@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements ISheet

<BradixDialog Open="@Visible"
              OpenChanged="HandleOpenChanged"
              Modal="@TrapFocus">
    <CascadingValue Name="ParentSheet" Value="@this">
        <CascadingValue Value="_context" IsFixed="true">
            @ChildContent
        </CascadingValue>
    </CascadingValue>
</BradixDialog>

@code {
    /// <summary>
    /// Gets or sets the callback invoked when the backdrop is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnBackdropClick { get; set; }

    /// <summary>
    /// When <c>true</c>, Escape and backdrop clicks do not close the sheet (non-dismissible overlay).
    /// </summary>
    [Parameter]
    public bool Static { get; set; }

    private readonly OverlayLabelContext _context = new("sheet");

    /// <summary>
    /// Shows the sheet.
    /// </summary>
    public async Task Show()
    {
        await SetVisibleAsync(true);
    }

    /// <summary>
    /// Hides the sheet.
    /// </summary>
    public async Task Hide()
    {
        await SetVisibleAsync(false);
    }

    private Task HandleOpenChanged(bool open)
    {
        return SetVisibleAsync(open);
    }

    private async Task SetVisibleAsync(bool visible)
    {
        if (Visible == visible)
            return;

        Visible = visible;

        if (VisibleChanged.HasDelegate)
            await VisibleChanged.InvokeAsync(Visible);

        if (visible)
            await OnShow.InvokeIfHasDelegate();
        else
            await OnHide.InvokeIfHasDelegate();

        await RefreshOffThread();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Visible);
        hc.Add(ShowBackdrop);
        hc.Add(Static);
        hc.Add(CloseOnBackdropClick);
        hc.Add(CloseOnEscape);
        hc.Add(_context.ContentId);
        hc.Add(_context.HasTitle);
        hc.Add(_context.HasDescription);
        hc.Add(_context.TitleId);
        hc.Add(_context.DescriptionId);
    }
}
