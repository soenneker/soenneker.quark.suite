@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISheetTrigger

<button type="button" @onclick="HandleActivate" @attributes="BuildAttributes()">
    @ChildContent
</button>

@code {
    [CascadingParameter(Name = nameof(ParentSheet))]
    public Sheet? ParentSheet { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sheet-trigger";

        if (Disabled)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-sheet-trigger");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    private async Task HandleActivate()
    {
        if (!Disabled && ParentSheet is not null)
            await ParentSheet.Show();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Disabled);
    }
}
