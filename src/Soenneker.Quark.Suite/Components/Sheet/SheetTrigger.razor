@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TriggerElement
@implements ISheetTrigger

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixDialogTrigger Disabled="@Disabled"
                         OnClick="HandleActivate"
                         AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixDialogTrigger>
}

@code {
    [CascadingParameter(Name = nameof(ParentSheet))]
    public Sheet? ParentSheet { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _elementRef;

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "sheet-trigger";
        attributes["data-state"] = ParentSheet?.Visible == true ? "open" : "closed";
        attributes["aria-haspopup"] = "dialog";
        attributes["aria-expanded"] = ParentSheet?.Visible == true ? "true" : "false";

        if (Disabled)
            attributes["disabled"] = true;

        if (Context is not null)
            attributes["aria-controls"] = Context.ContentId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-sheet-trigger");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("id");
        attributes.Remove("data-state");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("disabled");
        attributes.Remove("onclick");

        return attributes;
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = Context?.ContentId is not null ? $"{Context.ContentId}-trigger" : null,
            ParentDisabled = Disabled,
            IsOpen = ParentSheet?.Visible == true,
            DataState = ParentSheet?.Visible == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = Context?.ContentId,
            RegisterElement = elementReference =>
            {
                _elementRef = elementReference;

                if (BradixDialog is not null)
                    BradixDialog.RegisterTrigger(elementReference, Context?.ContentId is not null ? $"{Context.ContentId}-trigger" : null);
            },
            Toggle = ParentSheet is null
                ? null
                : async () =>
                {
                    if (ParentSheet.Visible)
                    {
                        await ParentSheet.Hide();
                    }
                    else
                    {
                        await ParentSheet.Show();
                    }
                },
            Open = ParentSheet is null ? null : async () =>
            {
                await ParentSheet.Show();
            },
            Close = ParentSheet is null ? null : () => ParentSheet.Hide()
        };
    }

    private Task HandleActivate(MouseEventArgs args)
    {
        return base.HandleClick(args);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(Disabled);
        hc.Add(ParentSheet?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
