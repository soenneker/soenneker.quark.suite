@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISheetDescription

<BradixDialogDescription Id="@Context?.DescriptionId" AdditionalAttributes="@DescriptionAttributes">
    @ChildContent
</BradixDialogDescription>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private IReadOnlyDictionary<string, object> DescriptionAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        // shadcn SheetDescription - new-york-v4 ui/sheet.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "text-sm text-muted-foreground");
        });

        attributes["data-slot"] = "sheet-description";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.DescriptionId);
    }
}
