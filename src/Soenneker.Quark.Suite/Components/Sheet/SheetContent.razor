@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement
@implements ISheetContent

@if (ParentSheet?.Visible == true)
{
    @if (Portal)
    {
        <OverlayPortalPublisher Id="@_portalId" UsePortal="true">
            <OverlayPortalShell CascadeOwnerName="@nameof(ParentSheet)" Owner="ParentSheet" LabelContext="Context">
                <SheetContentSurface Side="@Side"
                                     ShowCloseButton="@ShowCloseButton"
                                     ContainerClass="@ContainerClass"
                                     ContainerStyle="@ContainerStyle"
                                     OverlayClass="@OverlayClass"
                                     OverlayStyle="@OverlayStyle">
                    @ChildContent
                </SheetContentSurface>
            </OverlayPortalShell>
        </OverlayPortalPublisher>
    }
    else
    {
        <SheetContentSurface Side="@Side"
                             ShowCloseButton="@ShowCloseButton"
                             ContainerClass="@ContainerClass"
                             ContainerStyle="@ContainerStyle"
                             OverlayClass="@OverlayClass"
                             OverlayStyle="@OverlayStyle">
            @ChildContent
        </SheetContentSurface>
    }
}

@code {
    [CascadingParameter(Name = nameof(ParentSheet))]
    public Sheet? ParentSheet { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private readonly string _portalId = $"q-sheet-portal-{Guid.NewGuid():N}";

    [Parameter]
    public string Side { get; set; } = "right";

    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    [Parameter]
    public string? ContainerClass { get; set; }

    [Parameter]
    public string? ContainerStyle { get; set; }

    [Parameter]
    public string? OverlayClass { get; set; }

    [Parameter]
    public string? OverlayStyle { get; set; }

    [Parameter]
    public bool Portal { get; set; } = true;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(ShowCloseButton);
        hc.Add(ContainerClass);
        hc.Add(ContainerStyle);
        hc.Add(OverlayClass);
        hc.Add(OverlayStyle);
        hc.Add(Portal);
        hc.Add(ParentSheet?.Visible ?? false);
        hc.Add(ParentSheet?.ShowBackdrop ?? true);
        hc.Add(ParentSheet?.Static ?? false);
        hc.Add(Context?.ContentId);
    }
}
