@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement
@implements ISheetContent

<BradixDialogPortal>
    @if (ParentSheet?.ShowBackdrop == true)
    {
        <BradixDialogOverlay AdditionalAttributes="@OverlayAttributes" />
    }

    <BradixDialogContent Id="@Context?.ContentId"
                         CloseOnEscapeKeyDown="@(ParentSheet?.CloseOnEscape ?? true)"
                         CloseOnPointerDownOutside="@ShouldCloseOnOutsideInteraction"
                         CloseOnFocusOutside="@ShouldCloseOnOutsideInteraction"
                         OnPointerDownOutside="HandleBackdropPointerDownOutside"
                         AdditionalAttributes="@ContentAttributes">
        @ChildContent
        @if (ShowCloseButton)
        {
            <BradixDialogClose AdditionalAttributes="@CloseButtonAttributes">
                <Svg BoxSize="Quark.Size.Is4" NativeWidth="16" NativeHeight="16" ViewBox="0 0 24 24" Fill="Quark.Fill.None" Stroke='Quark.Stroke.Token("current")' StrokeWidth="Quark.StrokeWidth.Is2" StrokeLineCap="Quark.StrokeLineCap.Round" StrokeLineJoin="Quark.StrokeLineJoin.Round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></Svg>
                <Span ScreenReader="Quark.ScreenReader.Only">Close</Span>
            </BradixDialogClose>
        }
    </BradixDialogContent>
</BradixDialogPortal>

@code {
    [CascadingParameter(Name = nameof(ParentSheet))]
    public Sheet? ParentSheet { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    /// <summary>
    /// Gets or sets which side the sheet slides from.
    /// </summary>
    [Parameter]
    public Side Side { get; set; } = Side.Right;

    /// <summary>
    /// Gets or sets whether a close button should be rendered in the sheet.
    /// </summary>
    [Parameter]
    public bool ShowCloseButton { get; set; } = true;

    [Parameter]
    public string? ContainerClass { get; set; }

    [Parameter]
    public string? ContainerStyle { get; set; }

    [Parameter]
    public string? OverlayClass { get; set; }

    [Parameter]
    public string? OverlayStyle { get; set; }

    private bool ShouldCloseOnOutsideInteraction =>
        ParentSheet is not null &&
        !ParentSheet.Static &&
        ParentSheet.CloseOnBackdropClick;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    private IReadOnlyDictionary<string, object> OverlayAttributes => BuildOverlayAttributes();

    private IReadOnlyDictionary<string, object> CloseButtonAttributes => BuildCloseButtonAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Fixed;
        ZIndex ??= "z-50";
        Display ??= Quark.Display.Flex;
        FlexDirection ??= Quark.FlexDirection.Col;
        Gap ??= Quark.Gap.Is4;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        TextColor ??= Quark.TextColor.PopoverForeground;
        TextSize ??= Quark.TextSize.Sm;
        Shadow ??= Quark.Shadow.Lg;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "bg-clip-padding transition duration-200 ease-in-out");
            AppendClass(ref cls, "data-[side=bottom]:inset-x-0 data-[side=bottom]:bottom-0 data-[side=bottom]:h-auto data-[side=bottom]:border-t");
            AppendClass(ref cls, "data-[side=left]:inset-y-0 data-[side=left]:left-0 data-[side=left]:h-full data-[side=left]:w-3/4 data-[side=left]:border-r");
            AppendClass(ref cls, "data-[side=right]:inset-y-0 data-[side=right]:right-0 data-[side=right]:h-full data-[side=right]:w-3/4 data-[side=right]:border-l");
            AppendClass(ref cls, "data-[side=top]:inset-x-0 data-[side=top]:top-0 data-[side=top]:h-auto data-[side=top]:border-b");
            AppendClass(ref cls, "data-[side=left]:sm:max-w-sm data-[side=right]:sm:max-w-sm");
            AppendClass(ref cls, "data-open:animate-in data-open:fade-in-0 data-[side=bottom]:data-open:slide-in-from-bottom-10 data-[side=left]:data-open:slide-in-from-left-10 data-[side=right]:data-open:slide-in-from-right-10 data-[side=top]:data-open:slide-in-from-top-10");
            AppendClass(ref cls, "data-closed:animate-out data-closed:fade-out-0 data-[side=bottom]:data-closed:slide-out-to-bottom-10 data-[side=left]:data-closed:slide-out-to-left-10 data-[side=right]:data-closed:slide-out-to-right-10 data-[side=top]:data-closed:slide-out-to-top-10");
        });

        if (!attributes.ContainsKey("data-slot"))
            attributes["data-slot"] = "sheet-content";

        if (!attributes.ContainsKey("data-side"))
            attributes["data-side"] = Side.ToString().ToLowerInvariant();

        if (ParentSheet?.Visible == true)
            attributes["data-open"] = string.Empty;
        else
            attributes["data-closed"] = string.Empty;
    }

    private Dictionary<string, object> BuildOverlayAttributes()
    {
        var attributes = new Dictionary<string, object>();

        BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
        {
            AppendClass(ref cls, "fixed inset-0 z-50 bg-black/10 duration-100 supports-backdrop-filter:backdrop-blur-xs data-open:animate-in data-open:fade-in-0 data-closed:animate-out data-closed:fade-out-0");

            if (ParentSheet?.BlurBackdrop == true)
                AppendClass(ref cls, "backdrop-blur");

            if (!string.IsNullOrWhiteSpace(OverlayClass))
                AppendClass(ref cls, OverlayClass!);

            if (!string.IsNullOrWhiteSpace(OverlayStyle))
                AppendStyleDecl(ref sty, OverlayStyle!);
        });

        attributes["data-state"] = ParentSheet?.Visible == true ? "open" : "closed";
        attributes["data-slot"] = "sheet-overlay";
        attributes["aria-hidden"] = "true";

        if (ParentSheet?.Visible == true)
            attributes["data-open"] = string.Empty;
        else
            attributes["data-closed"] = string.Empty;

        return attributes;
    }

    private static IReadOnlyDictionary<string, object> BuildCloseButtonAttributes()
    {
        return new Dictionary<string, object>
        {
            ["data-slot"] = "sheet-close",
            ["class"] = "group/button inline-flex shrink-0 items-center justify-center border border-transparent bg-clip-padding text-sm font-medium whitespace-nowrap transition-all outline-none select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:not-aria-[haspopup]:translate-y-px disabled:pointer-events-none disabled:opacity-50 aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40 [&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4 hover:bg-muted hover:text-foreground aria-expanded:bg-muted aria-expanded:text-foreground dark:hover:bg-muted/50 size-7 rounded-[min(var(--radius-md),12px)] in-data-[slot=button-group]:rounded-lg absolute top-3 right-3"
        };
    }

    private Task HandleBackdropPointerDownOutside()
    {
        return ParentSheet?.OnBackdropClick.InvokeIfHasDelegate() ?? Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Side);
        hc.Add(ShowCloseButton);
        hc.Add(ContainerClass);
        hc.Add(ContainerStyle);
        hc.Add(OverlayClass);
        hc.Add(OverlayStyle);
        hc.Add(ParentSheet?.Visible ?? false);
        hc.Add(ParentSheet?.ShowBackdrop ?? true);
        hc.Add(ParentSheet?.BlurBackdrop ?? false);
        hc.Add(ParentSheet?.TrapFocus ?? true);
        hc.Add(ParentSheet?.CloseOnEscape ?? true);
        hc.Add(ParentSheet?.CloseOnBackdropClick ?? true);
        hc.Add(ParentSheet?.Static ?? false);
        hc.Add(Context?.ContentId);
    }
}
