@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

@if (ShowErrorMessages && ParentValidation?.ShouldShowInvalid == true && HasRenderableMessage(ParentValidation.Messages))
{
	<div @attributes="BuildAttributes()">
		@RenderMessages(ParentValidation.Messages!)
	</div>
}
else if (ShowErrorMessages && _visible && _status == ValidationStatus.Error && HasRenderableMessage(_messages) && ParentValidation == null)
{
	<div @attributes="BuildAttributes()">
		@RenderMessages(_messages!)
	</div>
}

@code {
	[CascadingParameter(Name = nameof(ParentValidation))]
	public Validation? ParentValidation { get; set; }

	[CascadingParameter(Name = nameof(ParentValidations))]
	public Validations? ParentValidations { get; set; }

    [CascadingParameter]
    private FieldContext? FieldContext { get; set; }

	/// <summary>
	/// Gets or sets whether to show validation error messages.
	/// </summary>
	[Parameter]
	public bool ShowErrorMessages { get; set; } = true;

	private bool _visible;
    private ValidationStatus _status = ValidationStatus.None;
    private IReadOnlyCollection<string>? _messages;
    private IDisposable? _registration;
    private FieldContext? _registeredFieldContext;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "field-error";

        Margin ??= Quark.Margin.FromTop.Is1;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Normal;
        TextColor ??= Quark.TextColor.Destructive;
    }

	protected override void OnInitialized()
	{
		if (ParentValidations is not null)
		{
			ParentValidations._statusChanged += OnStatusChanged;
			ParentValidations.ClearingAll += OnClearingAll;
		}
	}

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!ReferenceEquals(_registeredFieldContext, FieldContext))
        {
            _registration?.Dispose();
            _registeredFieldContext = FieldContext;
            _registration = FieldContext?.RegisterError();
        }
    }

    private void OnStatusChanged(ValidationsStatusChangedEventArgs args)
	{
		_status = args.Status;
		_messages = args.Messages;
		_visible = args.Status != ValidationStatus.None;
        _ = RefreshOffThread();
	}

    private void OnClearingAll()
	{
		_visible = false;
		_status = ValidationStatus.None;
		_messages = null;
        _ = RefreshOffThread();
	}

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);


        if (FieldContext is not null && !attributes.ContainsKey("id"))
            attributes["id"] = FieldContext.ErrorId;

        attributes.TryAdd("role", "alert");
    }

    private static RenderFragment RenderMessages(IEnumerable<string> messages)
    {
        return builder =>
        {
            string? single = null;
            List<string>? list = null;

            foreach (var message in messages)
            {
                if (string.IsNullOrWhiteSpace(message) || ContainsMessage(single, list, message))
                    continue;

                if (single is null)
                {
                    single = message;
                    continue;
                }

                list ??= [single];
                list.Add(message);
            }

            if (single is null)
                return;

            if (list is null)
            {
                builder.AddContent(0, single);
                return;
            }

            builder.OpenElement(1, "ul");
            builder.AddAttribute(2, "class", "ml-4 flex list-disc flex-col gap-1");

            for (var i = 0; i < list.Count; i++)
            {
                builder.OpenElement(3 + i * 2, "li");
                builder.AddContent(4 + i * 2, list[i]);
                builder.CloseElement();
            }

            builder.CloseElement();
        };
    }

    private static bool HasRenderableMessage(IEnumerable<string>? messages)
    {
        if (messages is null)
            return false;

        foreach (var message in messages)
        {
            if (!string.IsNullOrWhiteSpace(message))
                return true;
        }

        return false;
    }

    private static bool ContainsMessage(string? single, List<string>? list, string message)
    {
        if (single is null)
            return false;

        if (list is null)
            return string.Equals(single, message, StringComparison.Ordinal);

        for (var i = 0; i < list.Count; i++)
        {
            if (string.Equals(list[i], message, StringComparison.Ordinal))
                return true;
        }

        return false;
    }

    private static int CountMessages(IEnumerable<string>? messages)
    {
        if (messages is null)
            return 0;

        if (messages is IReadOnlyCollection<string> readOnlyCollection)
            return readOnlyCollection.Count;

        if (messages is ICollection<string> collection)
            return collection.Count;

        var count = 0;

        foreach (var _ in messages)
        {
            count++;
        }

        return count;
    }

    public override async ValueTask DisposeAsync()
    {
        _registration?.Dispose();
        await base.DisposeAsync();

        if (ParentValidations is not null)
        {
            ParentValidations._statusChanged -= OnStatusChanged;
            ParentValidations.ClearingAll -= OnClearingAll;
        }
        }

	protected override void ComputeRenderKeyCore(ref HashCode hc)
	{
		base.ComputeRenderKeyCore(ref hc);
		hc.Add(ShowErrorMessages);
		hc.Add(_visible);
		hc.Add(_status);
		if (_messages is not null)
			hc.Add(_messages.Count);
		if (ParentValidation is not null)
		{
			hc.Add(ParentValidation.Status);
            hc.Add(CountMessages(ParentValidation.Messages));
		}
        hc.Add(FieldContext?.ErrorId);
	}
}
