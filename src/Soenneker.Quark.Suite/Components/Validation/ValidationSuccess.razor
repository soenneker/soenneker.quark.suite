@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

@if (_visible && _status == ValidationStatus.Success)
{
    <div @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else if (SuccessText.HasContent())
        {
            @SuccessText
        }
    </div>
}

@code {
    [CascadingParameter(Name = nameof(ParentValidations))]
    public Validations? ParentValidations { get; set; }

    /// <summary>
    /// Gets or sets the success text to display.
    /// </summary>
    [Parameter]
    public string? SuccessText { get; set; }

    private bool _visible;
    private ValidationStatus _status = ValidationStatus.None;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Block;
        Margin ??= Quark.Margin.Is1.FromTop.Is0.FromBottom;
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void OnInitialized()
    {
        if (ParentValidations is not null)
        {
            ParentValidations._statusChanged += OnStatusChanged;
            ParentValidations.ClearingAll += OnClearingAll;
        }
    }

    private async void OnStatusChanged(ValidationsStatusChangedEventArgs args)
    {
        _status = args.Status;
        _visible = args.Status != ValidationStatus.None;
        await RefreshOffThread();
    }

    private async void OnClearingAll()
    {
        _visible = false;
        _status = ValidationStatus.None;
        await RefreshOffThread();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "validation-success";
    }

    

    public override void Dispose()
    {
        if (ParentValidations is not null)
        {
            ParentValidations._statusChanged -= OnStatusChanged;
            ParentValidations.ClearingAll -= OnClearingAll;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SuccessText);
        hc.Add(_visible);
        hc.Add(_status);
    }
}
