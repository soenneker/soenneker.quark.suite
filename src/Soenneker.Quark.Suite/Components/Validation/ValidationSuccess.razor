@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

@if (IsVisible && HasContent)
{
    <div @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else if (SuccessText.HasContent())
        {
            @SuccessText
        }
    </div>
}

@code {
    [CascadingParameter(Name = nameof(ParentValidation))]
    public Validation? ParentValidation { get; set; }

    [CascadingParameter(Name = nameof(ParentValidations))]
    public Validations? ParentValidations { get; set; }

    /// <summary>
    /// Gets or sets the success text to display.
    /// </summary>
    [Parameter]
    public string? SuccessText { get; set; }

    private bool _visible;
    private ValidationStatus _status = ValidationStatus.None;
    private Validation? _subscribedValidation;

    private bool IsVisible => ParentValidation?.Status == ValidationStatus.Success || (_visible && _status == ValidationStatus.Success);
    private bool HasContent => ChildContent is not null || SuccessText.HasContent();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Block;
        Margin ??= Quark.Margin.Is1.FromTop.Is0.FromBottom;
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void OnInitialized()
    {
        if (ParentValidations is not null)
        {
            ParentValidations._statusChanged += OnStatusChanged;
            ParentValidations.ClearingAll += OnClearingAll;
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!ReferenceEquals(_subscribedValidation, ParentValidation))
        {
            if (_subscribedValidation is not null)
                _subscribedValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;

            _subscribedValidation = ParentValidation;

            if (_subscribedValidation is not null)
                _subscribedValidation.ValidationStatusChanged += OnParentValidationStatusChanged;
        }
    }

    private void OnParentValidationStatusChanged(object? sender, ValidationStatusChangedEventArgs e)
    {
        _ = RefreshOffThread();
    }

    private void OnStatusChanged(ValidationsStatusChangedEventArgs args)
    {
        _status = args.Status;
        _visible = args.Status != ValidationStatus.None;
        _ = RefreshOffThread();
    }

    private void OnClearingAll()
    {
        _visible = false;
        _status = ValidationStatus.None;
        _ = RefreshOffThread();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "validation-success";
    }

    

    public override void Dispose()
    {
        if (_subscribedValidation is not null)
            _subscribedValidation.ValidationStatusChanged -= OnParentValidationStatusChanged;

        if (ParentValidations is not null)
        {
            ParentValidations._statusChanged -= OnStatusChanged;
            ParentValidations.ClearingAll -= OnClearingAll;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(SuccessText);
        hc.Add(HasContent);
        hc.Add(IsVisible);
        hc.Add(_status);
        hc.Add(ParentValidation?.Status);
    }
}
