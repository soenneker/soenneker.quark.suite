@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IUnorderedList

<ul @attributes="BuildAttributes()" >
    @ChildContent
</ul>

@code {
    /// <summary>
    /// Gets or sets the list variant style.
    /// </summary>
    [Parameter]
    public CssValue<ListVariantBuilder>? ListVariant { get; set; }

    /// <summary>
    /// Gets or sets the list style type.
    /// </summary>
    [Parameter]
    public CssValue<ListStyleTypeBuilder>? ListStyleType { get; set; }

    // shadcn-style list - new-york-v4
    protected override void BuildAttributesCore(Dictionary<string, object> attrs)
    {
        base.BuildAttributesCore(attrs);
        attrs["data-slot"] = "unordered-list";

        if (ListVariant is null or { IsEmpty: true })
            AppendClassAttribute(attrs, "my-6 ml-6 [&>li]:mt-2");

        if ((ListVariant is null or { IsEmpty: true }) && (ListStyleType is null or { IsEmpty: true }))
            AppendClassAttribute(attrs, "list-disc");

        if (ListVariant is { IsEmpty: false })
        {
            var cls = ListVariant.Value.ToString();
            if (cls.Length > 0)
            {
                AppendClassAttribute(attrs, cls);
            }
        }
        
        if (ListStyleType is { IsEmpty: false })
        {
            var cls = ListStyleType.Value.ToString();
            if (cls.Length > 0)
            {
                AppendListStyleType(attrs, cls);
            }
        }
    }

    private static void AppendListStyleType(Dictionary<string, object> attrs, string value)
    {
        const string arbitraryPrefix = "list-[";

        if (value.StartsWith(arbitraryPrefix, StringComparison.Ordinal) && value.EndsWith(']'))
        {
            var listStyleType = value[arbitraryPrefix.Length..^1];
            AppendStyleDeclAttr(attrs, $"list-style-type: {listStyleType}");
            return;
        }

        AppendClassAttribute(attrs, value);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        AddIf(ref hc, ListVariant);
        AddIf(ref hc, ListStyleType);
    }
}
