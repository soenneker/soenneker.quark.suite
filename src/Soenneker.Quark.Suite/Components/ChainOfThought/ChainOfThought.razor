@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Collapsible Open="@Open" DefaultOpen="@DefaultOpen" OpenChanged="@OpenChanged" Attributes="@BuildAttributes()">
    @ChildContent
</Collapsible>

@code {
    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; } = true;

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool AutoCloseOnAllComplete { get; set; } = true;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "chain-of-thought";

        Width ??= Quark.Width.IsFull;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "not-prose"));
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(DefaultOpen);
        hc.Add(AutoCloseOnAllComplete);
    }
}
