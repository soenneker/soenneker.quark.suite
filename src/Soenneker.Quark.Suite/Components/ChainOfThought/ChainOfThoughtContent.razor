@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CollapsibleContent Attributes="@BuildAttributes()">
    @ChildContent
</CollapsibleContent>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "chain-of-thought-content";

        Margin ??= Quark.Margin.FromTop.Is2.FromLeft.Is2;
        Padding ??= Quark.Padding.FromLeft.Is3;
        Border ??= Quark.Border.FromLeft.Default;
    }
}
