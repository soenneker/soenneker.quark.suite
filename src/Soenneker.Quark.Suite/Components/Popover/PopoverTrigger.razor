@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

@if (AsChild)
{
    <span @ref="_triggerRef" @onclick="HandleTriggerClick" @attributes="BuildWrapperAttributes()">
        <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
            @ChildContent
        </CascadingValue>
    </span>
}
else
{
    <button @ref="_triggerRef" @onclick="HandleTriggerClick" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [CascadingParameter]
    private PopoverContext? Context { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _triggerRef;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        Context?.SetTriggerElement(_triggerRef);
        return base.OnAfterRenderAsync(firstRender);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["type"] = "button";
        attributes["data-slot"] = "popover-trigger";

        if (Context is not null)
        {
            attributes["id"] = Context.TriggerId;
            attributes["aria-haspopup"] = "dialog";
            attributes["aria-expanded"] = Context.IsOpen ? "true" : "false";
            attributes["aria-controls"] = Context.ContentId;
        }

        if (Disabled)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-popover-trigger");
            AppendClass(ref cls, "inline-flex max-w-full items-center justify-center gap-2 rounded-md text-sm font-medium transition-[color,box-shadow]");
            AppendClass(ref cls, "focus-visible:ring-ring/50 outline-none focus-visible:ring-[3px]");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
        });
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = Context?.TriggerId,
            IsOpen = Context?.IsOpen == true,
            DataState = Context?.IsOpen == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = Context?.ContentId,
            Toggle = Context is null ? null : () => Context.Toggle(),
            Open = Context is null ? null : () => Context.Open(),
            Close = Context is null ? null : () => Context.Close()
        };
    }

    private Dictionary<string, object> BuildWrapperAttributes()
    {
        var attributes = new Dictionary<string, object>();
        attributes["data-slot"] = "popover-trigger-wrapper";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-popover-trigger-wrapper inline-flex max-w-full");
        });

        return attributes;
    }

    private async Task HandleTriggerClick(MouseEventArgs e)
    {
        if (Disabled)
            return;

        Context?.SetTriggerElement(_triggerRef);

        if (Context is not null)
            await Context.Toggle();

        await HandleClick(e);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(Context?.IsOpen);
    }
}
