@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixPopoverTrigger Id="@BradixPopover?.DefaultTriggerId"
                          Disabled="@Disabled"
                          OnClick="@OnClick"
                          AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixPopoverTrigger>
}

@code {
    [CascadingParameter]
    private PopoverContext? Context { get; set; }

    [CascadingParameter]
    private BradixPopover? BradixPopover { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "popover-trigger";

        if (BradixPopover is not null)
        {
            attributes["id"] = BradixPopover.DefaultTriggerId;
            attributes["data-state"] = BradixPopover.CurrentOpen ? "open" : "closed";
            attributes["aria-haspopup"] = "dialog";
            attributes["aria-expanded"] = BradixPopover.CurrentOpen ? "true" : "false";
            attributes["aria-controls"] = BradixPopover.ContentId;
        }

        if (Disabled)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-popover-trigger");
            AppendClass(ref cls, "inline-flex max-w-full items-center justify-center gap-2 rounded-md text-sm font-medium transition-[color,box-shadow]");
            AppendClass(ref cls, "focus-visible:ring-ring/50 outline-none focus-visible:ring-[3px]");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
        });
    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("id");
        attributes.Remove("data-state");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("disabled");
        attributes.Remove("onclick");

        return attributes;
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = BradixPopover?.DefaultTriggerId,
            ParentDisabled = Disabled,
            IsOpen = BradixPopover?.CurrentOpen == true,
            DataState = BradixPopover?.CurrentOpen == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = BradixPopover?.ContentId,
            Toggle = BradixPopover is null || Disabled ? null : () => BradixPopover.ToggleOpen(),
            Open = BradixPopover is null || Disabled ? null : () => BradixPopover.SetOpen(true),
            Close = BradixPopover is null ? null : () => BradixPopover.SetOpen(false),
            RegisterElement = BradixPopover is null
                ? null
                : elementReference => BradixPopover.RegisterTrigger(elementReference, BradixPopover.DefaultTriggerId)
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Disabled);
        hc.Add(BradixPopover?.CurrentOpen);
        hc.Add(AsChild);
        hc.Add(BradixPopover?.DefaultTriggerId);
        hc.Add(BradixPopover?.ContentId);
    }
}
