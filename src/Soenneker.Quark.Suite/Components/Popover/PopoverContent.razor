@using Soenneker.Bradix
@using System.Collections.Generic

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
<BradixPopoverPortal>
    <BradixPopoverContent Id="@ResolvedContentId"
                          Side="@ResolvedSide"
                          Align="@ResolvedAlign"
                          SideOffset="@SideOffset"
                          AlignOffset="@AlignOffset"
                          ArrowPadding="@ArrowPadding"
                          AvoidCollisions="@AvoidCollisions"
                          CollisionPadding="@CollisionPadding"
                          CollisionBoundarySelector="@CollisionBoundarySelector"
                          CollisionBoundarySelectors="@CollisionBoundarySelectors"
                          Sticky="@Sticky"
                          HideWhenDetached="@HideWhenDetached"
                          CloseOnEscapeKeyDown="@CloseOnEscape"
                          AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixPopoverContent>
</BradixPopoverPortal>

@code {
    [CascadingParameter]
    private PopoverContext? Context { get; set; }

    [CascadingParameter]
    private BradixPopover? BradixPopover { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public string PlacementAlign { get; set; } = "center";

    [Parameter]
    public string Slot { get; set; } = "popover-content";

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    [Parameter]
    public int SideOffset { get; set; } = 4;

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    private string? ResolvedContentId => string.IsNullOrWhiteSpace(Id) ? BradixPopover?.ContentId : Id;

    private BradixSide ResolvedSide =>
        Side.ToLowerInvariant() switch
        {
            "top" => BradixSide.Top,
            "right" => BradixSide.Right,
            "left" => BradixSide.Left,
            _ => BradixSide.Bottom
        };

    private BradixAlignment ResolvedAlign =>
        PlacementAlign.ToLowerInvariant() switch
        {
            "start" => BradixAlignment.Start,
            "end" => BradixAlignment.End,
            _ => BradixAlignment.Center
        };

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("id");
        attributes.Remove("aria-hidden");
        attributes.Remove("data-state");
        attributes.Remove("data-side");
        attributes.Remove("data-align");
        attributes.Remove("onmouseenter");
        attributes.Remove("onmouseleave");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        BackgroundColor ??= Quark.BackgroundColor.Popover;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Width ??= Quark.Width.Token("72");
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Default;
        Padding ??= Quark.Padding.Is4;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = Slot;
        attributes["data-side"] = Side;
        attributes["data-align"] = PlacementAlign;

        if (Context is not null)
        {
            if (!attributes.ContainsKey("aria-labelledby") && !attributes.ContainsKey("aria-label"))
                attributes["aria-labelledby"] = Context.TitleId;

            if (!attributes.ContainsKey("aria-describedby"))
                attributes["aria-describedby"] = Context.DescriptionId;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "z-50 origin-(--radix-popover-content-transform-origin) shadow-md outline-hidden data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2 data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Side);
        hc.Add(PlacementAlign);
        hc.Add(Slot);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (string selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
        hc.Add(DisableAutoOpen);
        hc.Add(CloseOnEscape);
        hc.Add(Context?.Modal ?? false);
        hc.Add(BradixPopover?.CurrentOpen);
        hc.Add(ResolvedContentId);
        hc.Add(Context?.TitleId);
        hc.Add(Context?.DescriptionId);
    }
}
