@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @onkeydown="HandleKeyDown" @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    [CascadingParameter]
    private PopoverContext? Context { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public string Align { get; set; } = "center";

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    private bool IsOpen => Context?.IsOpen ?? Open;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "popover-content";
        attributes["data-state"] = IsOpen ? "open" : "closed";
        attributes["data-side"] = Side;
        attributes["data-align"] = Align;

        if (Context is not null)
        {
            attributes["id"] = Context.ContentId;
            attributes["tabindex"] = -1;
            attributes["role"] = "dialog";
            attributes["aria-labelledby"] = Context.TriggerId;
        }

        attributes["aria-hidden"] = IsOpen ? "false" : "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-popover-content");
            AppendClass(ref cls, "bg-popover text-popover-foreground data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2 z-50 w-72 origin-(--radix-popover-content-transform-origin) rounded-md border p-4 shadow-md outline-hidden");
            AppendClass(ref cls, "absolute top-full mt-1");
            AppendClass(ref cls, "data-[state=closed]:hidden data-[state=open]:block");
            AppendClass(ref cls, "data-[align=start]:left-0 data-[align=center]:left-1/2 data-[align=center]:-translate-x-1/2 data-[align=end]:right-0");
        });
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (CloseOnEscape && e.Key == "Escape" && Context is not null)
            await Context.Close();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(IsOpen);
        hc.Add(Side);
        hc.Add(Align);
        hc.Add(DisableAutoOpen);
        hc.Add(CloseOnEscape);
    }
}
