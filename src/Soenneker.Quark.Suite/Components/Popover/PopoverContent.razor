@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAsyncDisposable

<BradixPopoverPortal>
    <BradixPopoverContent Id="@ResolvedContentId"
                          Side="@ResolvedSide"
                          Align="@ResolvedAlign"
                          SideOffset="@SideOffset"
                          CloseOnEscapeKeyDown="@CloseOnEscape"
                          AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixPopoverContent>
</BradixPopoverPortal>

@code {
    [CascadingParameter]
    private PopoverContext? Context { get; set; }

    [CascadingParameter]
    private BradixPopover? BradixPopover { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    [Parameter]
    public string Side { get; set; } = "bottom";

    [Parameter]
    public string Align { get; set; } = "center";

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    [Parameter]
    public int SideOffset { get; set; } = 4;

    private PopoverContext? _subscribedContext;
    private string? ResolvedContentId => Context?.ContentId ?? BradixPopover?.ContentId;

    private BradixSide ResolvedSide =>
        Side.ToLowerInvariant() switch
        {
            "top" => BradixSide.Top,
            "right" => BradixSide.Right,
            "left" => BradixSide.Left,
            _ => BradixSide.Bottom
        };

    private BradixAlignment ResolvedAlign =>
        Align.ToLowerInvariant() switch
        {
            "start" => BradixAlignment.Start,
            "end" => BradixAlignment.End,
            _ => BradixAlignment.Center
        };

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!ReferenceEquals(_subscribedContext, Context))
        {
            if (_subscribedContext is not null)
                _subscribedContext.StateChanged -= OnContextStateChanged;

            _subscribedContext = Context;

            if (_subscribedContext is not null)
                _subscribedContext.StateChanged += OnContextStateChanged;
        }
    }

    private async void OnContextStateChanged()
    {
        await RefreshOffThread();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "popover-content";
        attributes["data-side"] = Side;
        attributes["data-align"] = Align;

        if (Context is not null)
        {
            if (Context.HasTitle)
            {
                attributes["aria-labelledby"] = Context.TitleId;
                attributes.Remove("aria-label");
            }

            if (Context.HasDescription)
                attributes["aria-describedby"] = Context.DescriptionId;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-popover-content");
            AppendClass(ref cls, "bg-popover text-popover-foreground data-[state=open]:animate-in data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=open]:fade-in-0 data-[state=closed]:zoom-out-95 data-[state=open]:zoom-in-95 data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2 z-50 w-72 origin-(--radix-popover-content-transform-origin) rounded-md border p-4 shadow-md outline-hidden");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Side);
        hc.Add(Align);
        hc.Add(SideOffset);
        hc.Add(DisableAutoOpen);
        hc.Add(CloseOnEscape);
        hc.Add(Context?.Modal ?? false);
        hc.Add(BradixPopover?.CurrentOpen);
        hc.Add(Context?.HasTitle);
        hc.Add(Context?.HasDescription);
        hc.Add(Context?.TitleId);
        hc.Add(Context?.DescriptionId);
    }

    public override async ValueTask DisposeAsync()
    {
        if (_subscribedContext is not null)
        {
            _subscribedContext.StateChanged -= OnContextStateChanged;
            _subscribedContext = null;
        }
        await base.DisposeAsync();
    }
}
