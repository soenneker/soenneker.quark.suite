@using Soenneker.Bradix
@using System.Collections.Generic

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
<BradixPopoverPortal>
    <BradixPopoverContent Id="@ResolvedContentId"
                          Side="@Side"
                          Align="@Align"
                          SideOffset="@SideOffset"
                          AlignOffset="@AlignOffset"
                          ArrowPadding="@ArrowPadding"
                          AvoidCollisions="@AvoidCollisions"
                          CollisionPadding="@CollisionPadding"
                          CollisionBoundarySelector="@CollisionBoundarySelector"
                          CollisionBoundarySelectors="@CollisionBoundarySelectors"
                          Sticky="@Sticky"
                          HideWhenDetached="@HideWhenDetached"
                          CloseOnEscapeKeyDown="@CloseOnEscape"
                          AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixPopoverContent>
</BradixPopoverPortal>

@code {
    [CascadingParameter]
    private PopoverContext? Context { get; set; }

    [CascadingParameter]
    private BradixPopover? BradixPopover { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    [Parameter]
    public Side Side { get; set; } = Side.Bottom;

    [Parameter]
    public Alignment Align { get; set; } = Alignment.Center;

    [Parameter]
    public string Slot { get; set; } = "popover-content";

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    [Parameter]
    public int SideOffset { get; set; } = 4;

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    private string? ResolvedContentId => string.IsNullOrWhiteSpace(Id) ? BradixPopover?.ContentId : Id;

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        return BuildAttributes();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        ZIndex ??= "z-50";
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Border ??= Quark.Border.Default;
        Width ??= Quark.Width.Token("72");
        Rounded ??= Quark.Rounded.Md;
        Padding ??= Quark.Padding.Is4;
        OutlineStyle ??= "outline-hidden";
        Shadow ??= Quark.Shadow.Md;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = Slot;

        if (Context is not null)
        {
            if (!attributes.ContainsKey("aria-labelledby") && !attributes.ContainsKey("aria-label"))
                attributes["aria-labelledby"] = Context.TitleId;

            if (!attributes.ContainsKey("aria-describedby"))
                attributes["aria-describedby"] = Context.DescriptionId;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "origin-(--radix-popover-content-transform-origin)");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(Side);
        hc.Add(Align);
        hc.Add(Slot);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (var selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
        hc.Add(DisableAutoOpen);
        hc.Add(CloseOnEscape);
        hc.Add(Context?.Modal ?? false);
        hc.Add(BradixPopover?.CurrentOpen);
        hc.Add(ResolvedContentId);
        hc.Add(Context?.TitleId);
        hc.Add(Context?.DescriptionId);
    }
}
