@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixToastDescription AdditionalAttributes="@DescriptionAttributes">
    @ChildContent
</BradixToastDescription>

@code {
    private IReadOnlyDictionary<string, object> DescriptionAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "text-sm opacity-90");
        });

        attributes["data-slot"] = "toast-description";
    }
}
