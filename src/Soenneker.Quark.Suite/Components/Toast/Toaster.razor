@implements IDisposable
@inject IToastUtil Toasts

@namespace Soenneker.Quark

<ToastProvider>
    @foreach (ToastEntry toast in Toasts.Toasts)
    {
        <Toast @key="toast.Id"
               Open="@toast.Open"
               OpenChanged="@(open => HandleOpenChanged(toast.Id, open))"
               Variant="@toast.Variant"
               Duration="@toast.Duration">
            <div class="grid gap-1">
                @if (!string.IsNullOrWhiteSpace(toast.Title))
                {
                    <ToastTitle>@toast.Title</ToastTitle>
                }
                @if (!string.IsNullOrWhiteSpace(toast.Description))
                {
                    <ToastDescription>@toast.Description</ToastDescription>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(toast.ActionLabel))
            {
                <ToastAction AltText="@GetActionAltText(toast)" OnClick="@(_ => HandleAction(toast))">
                    @toast.ActionLabel
                </ToastAction>
            }
            <ToastClose />
        </Toast>
    }
    <ToastViewport />
</ToastProvider>

@code {
    protected override void OnInitialized()
    {
        Toasts.Changed += HandleToastsChanged;
    }

    public void Dispose()
    {
        Toasts.Changed -= HandleToastsChanged;
    }

    private void HandleToastsChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task HandleOpenChanged(string id, bool open)
    {
        if (open)
            return;

        await Toasts.Dismiss(id);
        _ = RemoveAfterExit(id);
    }

    private async Task HandleAction(ToastEntry toast)
    {
        if (toast.Action is not null)
            await toast.Action();
    }

    private async Task RemoveAfterExit(string id)
    {
        await Task.Delay(1000);
        await Toasts.Remove(id);
    }

    private static string GetActionAltText(ToastEntry toast)
    {
        return string.IsNullOrWhiteSpace(toast.ActionAltText) ? toast.ActionLabel! : toast.ActionAltText!;
    }
}
