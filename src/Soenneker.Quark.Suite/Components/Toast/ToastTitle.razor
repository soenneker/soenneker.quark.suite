@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixToastTitle AdditionalAttributes="@TitleAttributes">
    @ChildContent
</BradixToastTitle>

@code {
    private IReadOnlyDictionary<string, object> TitleAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "text-sm font-semibold [&+div]:text-xs");
        });

        attributes["data-slot"] = "toast-title";
    }
}
