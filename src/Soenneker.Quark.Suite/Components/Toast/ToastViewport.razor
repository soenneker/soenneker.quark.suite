@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixToastViewport Hotkey="@Hotkey"
                     Label="@Label"
                     AdditionalAttributes="@ViewportAttributes" />

@code {
    private static readonly IReadOnlyList<string> _defaultHotkey = ["F8"];

    [Parameter]
    public IReadOnlyList<string> Hotkey { get; set; } = _defaultHotkey;

    [Parameter]
    public string Label { get; set; } = "Notifications ({hotkey})";

    private IReadOnlyDictionary<string, object> ViewportAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Fixed;
        ZIndex ??= "z-[100]";
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        FlexDirection ??= Quark.FlexDirection.ColReverse;
        Padding ??= Quark.Padding.Is4;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "top-0 max-h-screen sm:bottom-0 sm:right-0 sm:top-auto sm:flex-col md:max-w-[420px]");
        });

        attributes["data-slot"] = "toast-viewport";
    }
}
