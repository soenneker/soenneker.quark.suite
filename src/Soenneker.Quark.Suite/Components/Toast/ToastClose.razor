@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixToastClose Disabled="@Disabled"
                  OnClick="@OnClick"
                  AdditionalAttributes="@CloseAttributes">
    @if (ChildContent is null)
    {
        <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
        </svg>
    }
    else
    {
        @ChildContent
    }
</BradixToastClose>

@code {
    [Parameter]
    public bool Disabled { get; set; }

    private IReadOnlyDictionary<string, object> CloseAttributes => BuildAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "absolute right-1 top-1 rounded-md p-1 text-foreground/50 opacity-0 transition-opacity hover:text-foreground focus:opacity-100 focus:outline-none focus:ring-1");
            AppendClass(ref cls, "group-hover:opacity-100 group-[.destructive]:text-red-300 group-[.destructive]:hover:text-red-50 group-[.destructive]:focus:ring-red-400 group-[.destructive]:focus:ring-offset-red-600");
        });

        attributes["data-slot"] = "toast-close";
        attributes["toast-close"] = string.Empty;
    }
}
