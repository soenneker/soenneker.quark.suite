@namespace Soenneker.Quark

@inherits Soenneker.Quark.Element

<li @attributes="BuildAttributes()">
    <Div Class="@ContentGridClass">
        @if (TimelineAlignment == TimelineAlign.Left)
        {
            @IconColumn
            <Div Class="@ContentWrapperClass">@ContentBody</Div>
        }
        else if (TimelineAlignment == TimelineAlign.Right)
        {
            <Div Class="@ContentWrapperEndClass" data-timeline-end>@ContentBody</Div>
            @IconColumn
        }
        else if (IsReversed)
        {
            <Div Class="@ContentWrapperEndClass" data-timeline-end>@ContentBody</Div>
            @IconColumn
            @DateColumn
        }
        else
        {
            @DateColumn
            @IconColumn
            <Div Class="@ContentWrapperClass">@ContentBody</Div>
        }
    </Div>
</li>

@code {
    private int _itemIndex;

    [CascadingParameter]
    public Timeline? ParentTimeline { get; set; }

    [Parameter]
    public TimelineColor IconColor { get; set; } = TimelineColor.Primary;

    [Parameter]
    public TimelineStatus Status { get; set; } = TimelineStatus.Completed;

    [Parameter]
    public TimelineColor? ConnectorColor { get; set; }

    [Parameter]
    public bool ShowConnector { get; set; } = true;

    [Parameter]
    public TimelineSize IconSize { get; set; } = TimelineSize.Medium;

    [Parameter]
    public TimelineIconVariant IconVariant { get; set; } = TimelineIconVariant.Solid;

    [Parameter]
    public TimelineConnectorStyle ConnectorStyle { get; set; } = TimelineConnectorStyle.Solid;

    [Parameter]
    public bool Loading { get; set; }

    [Parameter]
    public bool IsCollapsible { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; } = true;

    [Parameter]
    public RenderFragment? DetailContent { get; set; }

    [Parameter]
    public string? ConnectorClass { get; set; }

    [Parameter]
    public RenderFragment? IconContent { get; set; }

    [Parameter]
    public RenderFragment? Marker { get; set; }

    [Parameter]
    public RenderFragment? TimeContent { get; set; }

    [Parameter]
    public string? Time { get; set; }

    [Parameter]
    public string? Description { get; set; }

    private TimelineAlign TimelineAlignment => ParentTimeline?.TimelineAlignment ?? TimelineAlign.Center;

    private TimelineSize TimelineSize => ParentTimeline?.TimelineSize ?? Quark.TimelineSize.Medium;

    private bool IsReversed => TimelineAlignment == TimelineAlign.Alternate && _itemIndex % 2 != 0;

    private bool UseShorthand => ChildContent == null && Title.HasContent();

    protected override void OnParametersSet()
    {
        _itemIndex = ParentTimeline?.RegisterItem() ?? 0;
        base.OnParametersSet();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "timeline-item";
        attributes["data-status"] = Status?.Value ?? TimelineStatus.Completed.Value;

        if (Status == TimelineStatus.InProgress)
            attributes["aria-current"] = "step";
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Width ??= Quark.Width.IsFull;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(IconColor);
        hc.Add(Status);
        hc.Add(ConnectorColor);
        hc.Add(ShowConnector);
        hc.Add(IconSize);
        hc.Add(IconVariant);
        hc.Add(ConnectorStyle);
        hc.Add(Loading);
        hc.Add(IsCollapsible);
        hc.Add(DefaultOpen);
        hc.Add(DetailContent is not null);
        hc.Add(ConnectorClass);
        hc.Add(IconContent is not null);
        hc.Add(Marker is not null);
        hc.Add(TimeContent is not null);
        hc.Add(Title);
        hc.Add(Time);
        hc.Add(Description);
        hc.Add(_itemIndex);
    }

    private string ContentGridClass => ResolveContentGridClass();

    private string ResolveContentGridClass()
    {
        if (ReferenceEquals(TimelineAlignment, TimelineAlign.Left))
            return "grid grid-cols-[auto_1fr] gap-4 items-start";

        if (ReferenceEquals(TimelineAlignment, TimelineAlign.Right))
            return "grid grid-cols-[1fr_auto] gap-4 items-start";

        return "grid grid-cols-[1fr_auto_1fr] gap-4 items-start";
    }

    private string IconMinHeightClass => ResolveIconMinHeightClass();

    private string ContentWrapperClass => $"grid items-center {IconMinHeightClass}";

    private string ContentWrapperEndClass => $"grid items-center justify-items-end {IconMinHeightClass}";

    private string DateColumnClass => $"flex flex-col justify-center {IconMinHeightClass}";

    private string ConnectorGapClass => ResolveConnectorGapClass();

    private string ComputedConnectorClass => $"flex-1 min-h-16 {ConnectorGapClass}{(ConnectorClass.HasContent() ? $" {ConnectorClass}" : null)}";

    private RenderFragment? EffectiveIconContent => IconContent ?? Marker;

    private RenderFragment IconColumn => @<Div Display="Quark.Display.Flex" FlexDirection="Quark.FlexDirection.Col" ItemsAlign="Quark.Items.Center" SelfAlign="Quark.Self.Stretch">
        <Div Position="Quark.Position.Relative" ZIndex="Quark.ZIndex.Z1">
            @if (EffectiveIconContent != null)
            {
                @EffectiveIconContent
            }
            else
            {
                <TimelineIcon Color="@IconColor" TimelineSize="@IconSize" Status="@Status" Variant="@IconVariant" Loading="@Loading" />
            }
        </Div>
        @if (ShowConnector)
        {
            <TimelineConnector Status="@Status" Color="@ConnectorColor" ConnectorStyle="@ConnectorStyle" Class="@ComputedConnectorClass" />
        }
    </Div>;

    private RenderFragment DateColumn => @<Div Class="@DateColumnClass">
        @if (TimeContent != null)
        {
            @TimeContent
        }
        else if (UseShorthand && Time.HasContent())
        {
            <TimelineTime Class="text-right pr-4">@Time</TimelineTime>
        }
    </Div>;

    private RenderFragment ContentBody => @<Div>
        @if (UseShorthand)
        {
            <TimelineContent>
                <TimelineHeader>
                    <TimelineTitle>@Title</TimelineTitle>
                </TimelineHeader>
                @if (Description.HasContent())
                {
                    <TimelineDescription>@Description</TimelineDescription>
                }
            </TimelineContent>
        }
        else if (IsCollapsible && DetailContent != null)
        {
            <Collapsible DefaultOpen="@DefaultOpen">
                <CollapsibleTrigger Class="group flex w-full items-center gap-2 cursor-pointer">
                    <Div Flex="Quark.Flex.Is1">
                        @ChildContent
                    </Div>
                    <Icon Name="LucideIcon.ChevronDown" Class="transition-transform duration-200 group-data-[state=open]:rotate-180" />
                </CollapsibleTrigger>
                <CollapsibleContent>
                    @DetailContent
                </CollapsibleContent>
            </Collapsible>
        }
        else
        {
            @ChildContent
        }
    </Div>;

    private string ResolveIconMinHeightClass()
    {
        if (ReferenceEquals(Size, TimelineSize.Small))
            return "min-h-8";

        if (ReferenceEquals(Size, TimelineSize.Large))
            return "min-h-12";

        return "min-h-10";
    }

    private string ResolveConnectorGapClass()
    {
        if (ReferenceEquals(Size, TimelineSize.Small))
            return "-mb-2";

        if (ReferenceEquals(Size, TimelineSize.Large))
            return "-mb-6";

        return "-mb-4";
    }
}
