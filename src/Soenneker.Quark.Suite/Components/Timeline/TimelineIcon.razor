@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @if (ChildContent != null)
    {
        <div class="@IconInnerClass">
            @ChildContent
        </div>
    }
    else
    {
        <div class="@DotClass"></div>
    }
</div>

@code {
    [CascadingParameter]
    public Timeline? ParentTimeline { get; set; }

    [Parameter]
    public TimelineColor Color { get; set; } = TimelineColor.Primary;

    [Parameter]
    public TimelineStatus Status { get; set; } = TimelineStatus.Completed;

    [Parameter]
    public TimelineSize? Size { get; set; }

    [Parameter]
    public TimelineIconVariant Variant { get; set; } = TimelineIconVariant.Solid;

    [Parameter]
    public bool Loading { get; set; }

    private TimelineSize ComputedSize => Size ?? ParentTimeline?.Size ?? TimelineSize.Medium;

    private TimelineColor EffectiveColor => Status == TimelineStatus.Pending ? TimelineColor.Muted : Color;

    private bool IsConnected => ParentTimeline?.ConnectorFit == TimelineConnectorFit.Connected;

    private string IconInnerClass => ComputedSize?.Value switch
    {
        TimelineSize.SmallValue => "h-4 w-4",
        TimelineSize.LargeValue => "h-6 w-6",
        _ => "h-5 w-5"
    };

    private string DotClass => ComputedSize?.Value switch
    {
        TimelineSize.SmallValue => "h-4 w-4 rounded-full",
        TimelineSize.LargeValue => "h-6 w-6 rounded-full",
        _ => "h-5 w-5 rounded-full"
    };

    protected override void ApplyDefaultParameters()
    {
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        BoxSize ??= ComputedSize?.Value switch
        {
            TimelineSize.SmallValue => Quark.Size.Is8,
            TimelineSize.LargeValue => Quark.Size.Token("12"),
            _ => Quark.Size.Token("10")
        };
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Full;
        BackgroundColor ??= ResolveBackgroundColor();
        TextColor ??= ResolveTextColor();
        BoxShadow ??= Quark.BoxShadow.Sm;

        if (Variant?.Value == TimelineIconVariant.OutlineValue)
        {
            Border ??= Quark.Border.Is2;
            BorderColor ??= ResolveBorderColor();
        }

        base.ApplyDefaultParameters();
    }

    private BackgroundColorBuilder ResolveBackgroundColor()
    {
        if (Variant?.Value == TimelineIconVariant.OutlineValue)
            return Quark.BackgroundColor.Background;

        return EffectiveColor?.Value switch
        {
            TimelineColor.SecondaryValue => Quark.BackgroundColor.Secondary,
            TimelineColor.MutedValue => Quark.BackgroundColor.Muted,
            TimelineColor.AccentValue => Quark.BackgroundColor.Accent,
            TimelineColor.DestructiveValue => Quark.BackgroundColor.Destructive,
            _ => Quark.BackgroundColor.Primary
        };
    }

    private TextColorBuilder ResolveTextColor()
    {
        if (Variant?.Value == TimelineIconVariant.OutlineValue)
        {
            return EffectiveColor?.Value switch
            {
                TimelineColor.SecondaryValue => Quark.TextColor.Secondary,
                TimelineColor.MutedValue => Quark.TextColor.MutedForeground,
                TimelineColor.AccentValue => Quark.TextColor.Accent,
                TimelineColor.DestructiveValue => Quark.TextColor.Destructive,
                _ => Quark.TextColor.Primary
            };
        }

        return EffectiveColor?.Value switch
        {
            TimelineColor.SecondaryValue => Quark.TextColor.SecondaryForeground,
            TimelineColor.MutedValue => Quark.TextColor.MutedForeground,
            TimelineColor.AccentValue => Quark.TextColor.AccentForeground,
            TimelineColor.DestructiveValue => Quark.TextColor.DestructiveForeground,
            _ => Quark.TextColor.PrimaryForeground
        };
    }

    private BorderColorBuilder ResolveBorderColor()
    {
        return EffectiveColor?.Value switch
        {
            TimelineColor.SecondaryValue => Quark.BorderColor.Secondary,
            TimelineColor.MutedValue => Quark.BorderColor.Muted,
            TimelineColor.AccentValue => Quark.BorderColor.Accent,
            TimelineColor.DestructiveValue => Quark.BorderColor.Destructive,
            _ => Quark.BorderColor.Primary
        };
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (!attributes.ContainsKey("data-slot"))
            attributes["data-slot"] = "timeline-icon";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (!IsConnected)
                AppendClass(ref cls, "ring-8 ring-background");

            if (Loading)
                AppendClass(ref cls, "animate-pulse");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Color);
        hc.Add(Status);
        hc.Add(Size);
        hc.Add(Variant);
        hc.Add(Loading);
        hc.Add(ParentTimeline?.ConnectorFit);
        hc.Add(ChildContent is not null);
    }
}
