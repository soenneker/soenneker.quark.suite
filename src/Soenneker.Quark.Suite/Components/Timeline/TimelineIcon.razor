@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @if (ChildContent != null)
    {
        <div class="@IconInnerClass">
            @ChildContent
        </div>
    }
    else
    {
        <div class="@DotClass"></div>
    }
</div>

@code {
    [CascadingParameter]
    public Timeline? ParentTimeline { get; set; }

    [Parameter]
    public TimelineColor Color { get; set; } = TimelineColor.Primary;

    [Parameter]
    public TimelineStatus Status { get; set; } = TimelineStatus.Completed;

    [Parameter]
    public TimelineSize? Size { get; set; }

    [Parameter]
    public TimelineIconVariant Variant { get; set; } = TimelineIconVariant.Solid;

    [Parameter]
    public bool Loading { get; set; }

    private TimelineSize ComputedSize => Size ?? ParentTimeline?.Size ?? TimelineSize.Medium;

    private TimelineColor EffectiveColor => Status == TimelineStatus.Pending ? TimelineColor.Muted : Color;

    private bool IsConnected => ReferenceEquals(ParentTimeline?.ConnectorFit, TimelineConnectorFit.Connected);

    private string IconInnerClass => ResolveIconInnerClass();

    private string DotClass => ResolveDotClass();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Flex;
        BoxSize ??= ResolveBoxSize();
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Full;
        BackgroundColor ??= ResolveBackgroundColor();
        TextColor ??= ResolveTextColor();
        Shadow ??= Quark.Shadow.Sm;

        if (ReferenceEquals(Variant, TimelineIconVariant.Outline))
        {
            Border ??= Quark.Border.Is2;
            BorderColor ??= ResolveBorderColor();
        }

    }

    private BackgroundColorBuilder ResolveBackgroundColor()
    {
        if (ReferenceEquals(Variant, TimelineIconVariant.Outline))
            return Quark.BackgroundColor.Background;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Secondary))
            return Quark.BackgroundColor.Secondary;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Muted))
            return Quark.BackgroundColor.Muted;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Accent))
            return Quark.BackgroundColor.Accent;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Destructive))
            return Quark.BackgroundColor.Destructive;

        return Quark.BackgroundColor.Primary;
    }

    private TextColorBuilder ResolveTextColor()
    {
        if (ReferenceEquals(Variant, TimelineIconVariant.Outline))
        {
            if (ReferenceEquals(EffectiveColor, TimelineColor.Secondary))
                return Quark.TextColor.Secondary;

            if (ReferenceEquals(EffectiveColor, TimelineColor.Muted))
                return Quark.TextColor.MutedForeground;

            if (ReferenceEquals(EffectiveColor, TimelineColor.Accent))
                return Quark.TextColor.Accent;

            if (ReferenceEquals(EffectiveColor, TimelineColor.Destructive))
                return Quark.TextColor.Destructive;

            return Quark.TextColor.Primary;
        }

        if (ReferenceEquals(EffectiveColor, TimelineColor.Secondary))
            return Quark.TextColor.SecondaryForeground;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Muted))
            return Quark.TextColor.MutedForeground;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Accent))
            return Quark.TextColor.AccentForeground;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Destructive))
            return Quark.TextColor.DestructiveForeground;

        return Quark.TextColor.PrimaryForeground;
    }

    private BorderColorBuilder ResolveBorderColor()
    {
        if (ReferenceEquals(EffectiveColor, TimelineColor.Secondary))
            return Quark.BorderColor.Secondary;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Muted))
            return Quark.BorderColor.Muted;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Accent))
            return Quark.BorderColor.Accent;

        if (ReferenceEquals(EffectiveColor, TimelineColor.Destructive))
            return Quark.BorderColor.Destructive;

        return Quark.BorderColor.Primary;
    }

    private string ResolveIconInnerClass()
    {
        if (ReferenceEquals(ComputedSize, TimelineSize.Small))
            return "flex h-4 w-4 items-center justify-center";

        if (ReferenceEquals(ComputedSize, TimelineSize.Large))
            return "flex h-6 w-6 items-center justify-center";

        return "flex h-5 w-5 items-center justify-center";
    }

    private string ResolveDotClass()
    {
        if (ReferenceEquals(ComputedSize, TimelineSize.Small))
            return "h-4 w-4 rounded-full";

        if (ReferenceEquals(ComputedSize, TimelineSize.Large))
            return "h-6 w-6 rounded-full";

        return "h-5 w-5 rounded-full";
    }

    private SizeBuilder ResolveBoxSize()
    {
        if (ReferenceEquals(ComputedSize, TimelineSize.Small))
            return Quark.Size.Is8;

        if (ReferenceEquals(ComputedSize, TimelineSize.Large))
            return Quark.Size.Token("12");

        return Quark.Size.Token("10");
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        if (!attributes.ContainsKey("data-slot"))
            attributes["data-slot"] = "timeline-icon";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (!IsConnected)
                AppendClass(ref cls, "ring-8 ring-background");

            if (Loading)
                AppendClass(ref cls, "animate-pulse");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Color);
        hc.Add(Status);
        hc.Add(Size);
        hc.Add(Variant);
        hc.Add(Loading);
        hc.Add(ParentTimeline?.ConnectorFit);
        hc.Add(ChildContent is not null);
    }
}
