@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Value="this" IsFixed="true">
    <ol @attributes="BuildAttributes()">
        @if (ChildContent != null)
        {
            @ChildContent
        }
    </ol>
</CascadingValue>

@code {
    private int _itemCounter;

    [Parameter]
    public TimelineAlign TimelineAlignment { get; set; } = TimelineAlign.Center;

    [Parameter]
    public TimelineSize Size { get; set; } = TimelineSize.Medium;

    [Parameter]
    public TimelineConnectorFit ConnectorFit { get; set; } = TimelineConnectorFit.Spaced;

    internal int RegisterItem() => _itemCounter++;

    protected override void OnParametersSet()
    {
        _itemCounter = 0;
        base.OnParametersSet();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Relative;
        Flex ??= "flex flex-col";
        Gap ??= Size?.Value switch
        {
            TimelineSize.SmallValue => Quark.Gap.Is2,
            TimelineSize.LargeValue => Quark.Gap.Token("6"),
            _ => Quark.Gap.Is4
        };
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "timeline";
        attributes["data-align"] = TimelineAlignment?.Value ?? TimelineAlign.Center.Value;
        attributes["aria-label"] = AriaLabel ?? "Timeline";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(TimelineAlignment);
        hc.Add(Size);
        hc.Add(ConnectorFit);
    }
}
