@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Value="this" IsFixed="true">
    <ol @attributes="BuildAttributes()">
        @if (ChildContent != null)
        {
            @ChildContent
        }
    </ol>
</CascadingValue>

@code {
    private readonly List<TimelineItem> _items = [];

    [Parameter]
    public TimelineAlign Align { get; set; } = TimelineAlign.Center;

    [Parameter]
    public TimelineSize Size { get; set; } = TimelineSize.Medium;

    [Parameter]
    public TimelineConnectorFit ConnectorFit { get; set; } = TimelineConnectorFit.Spaced;

    /// <summary>
    /// Called from each <see cref="TimelineItem"/> during <c>OnParametersSet</c> (after this component clears the list).
    /// Returns the zero-based index among sibling items for alternate layout parity.
    /// </summary>
    internal int RegisterItem(TimelineItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);

        return _items.IndexOf(item);
    }

    protected override void OnParametersSet()
    {
        _items.Clear();
        base.OnParametersSet();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "timeline";
        attributes["data-align"] = Align?.Value ?? TimelineAlign.Center.Value;
        attributes["aria-label"] = AriaLabel ?? "Timeline";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-timeline");
            AppendClass(ref cls, "relative flex flex-col");
            AppendClass(ref cls, Size?.Value switch
            {
                TimelineSize.SmallValue => "gap-2",
                TimelineSize.LargeValue => "gap-6",
                _ => "gap-4"
            });
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Align);
        hc.Add(Size);
        hc.Add(ConnectorFit);
    }
}
