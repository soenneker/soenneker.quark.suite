@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Value="this" IsFixed="true">
    <div @attributes="BuildAttributes()">
        @if (ChildContent != null)
        {
            @ChildContent
        }
    </div>
</CascadingValue>

@code {
    [Parameter]
    public int DefaultValue { get; set; } = 1;

    [Parameter]
    public int? Value { get; set; }

    [Parameter]
    public EventCallback<int> ValueChanged { get; set; }

    [Parameter]
    public string Orientation { get; set; } = "vertical";

    internal int ActiveStep => Value ?? DefaultValue;

    internal async Task SetActiveStep(int step)
    {
        if (Value is null)
            DefaultValue = step;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(step);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "timeline";

        Display ??= Quark.Display.Flex;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["aria-label"] = AriaLabel ?? "Timeline";
        attributes["data-orientation"] = NormalizeOrientation();

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/timeline");
            AppendClass(ref cls, "data-[orientation=horizontal]:w-full data-[orientation=horizontal]:flex-row data-[orientation=vertical]:flex-col");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(DefaultValue);
        hc.Add(Value);
        hc.Add(Orientation);
    }

    private string NormalizeOrientation()
    {
        return string.Equals(Orientation, "horizontal", StringComparison.OrdinalIgnoreCase)
            ? "horizontal"
            : "vertical";
    }
}
