@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<TimelineIcon TimelineSize="@ComputedSize" @attributes="BuildAttributes()">
    @ChildContent
</TimelineIcon>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "timeline-marker";
    }

    [CascadingParameter]
    public Timeline? ParentTimeline { get; set; }

    [Parameter]
    public TimelineSize? TimelineSize { get; set; }

    private TimelineSize ComputedSize => TimelineSize ?? ParentTimeline?.TimelineSize ?? Quark.TimelineSize.Medium;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(TimelineSize);
    }
}