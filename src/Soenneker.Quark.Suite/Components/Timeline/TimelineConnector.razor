@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()"></div>

@code {
    [Parameter]
    public TimelineStatus Status { get; set; } = TimelineStatus.Completed;

    [Parameter]
    public TimelineColor? Color { get; set; }

    [Parameter]
    public TimelineConnectorStyle ConnectorStyle { get; set; } = TimelineConnectorStyle.Solid;

    protected override void ApplyDefaultParameters()
    {
        Width ??= Quark.Width.Token("0.5");

        if (ConnectorStyle == TimelineConnectorStyle.Solid)
        {
            BackgroundColorBuilder? backgroundColor = ResolveBackgroundColor();

            if (backgroundColor is not null)
                BackgroundColor ??= backgroundColor;
        }
        else
        {
            Border ??= Quark.Border.Is2.FromLeft;
            BorderColor ??= ResolveBorderColor();
        }

        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "timeline-connector";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (ConnectorStyle != TimelineConnectorStyle.Solid)
            {
                var borderStyleClass = ConnectorStyle?.Value switch
                {
                    TimelineConnectorStyle.DashedValue => "border-dashed",
                    TimelineConnectorStyle.DottedValue => "border-dotted",
                    _ => null
                };

                if (borderStyleClass != null)
                    AppendClass(ref cls, borderStyleClass);
            }

            if (ConnectorStyle == TimelineConnectorStyle.Solid && Color is null && Status?.Value == TimelineStatus.InProgressValue)
                AppendClass(ref cls, "bg-linear-to-b from-primary to-muted");
        });
    }

    private BackgroundColorBuilder? ResolveBackgroundColor()
    {
        return Color?.Value switch
        {
            TimelineColor.PrimaryValue => Quark.BackgroundColor.Primary,
            TimelineColor.SecondaryValue => Quark.BackgroundColor.Secondary,
            TimelineColor.MutedValue => Quark.BackgroundColor.Muted,
            TimelineColor.AccentValue => Quark.BackgroundColor.Accent,
            TimelineColor.DestructiveValue => Quark.BackgroundColor.Destructive,
            _ => Status?.Value switch
            {
                TimelineStatus.InProgressValue => null,
                TimelineStatus.PendingValue => Quark.BackgroundColor.Muted,
                _ => Quark.BackgroundColor.Primary
            }
        };
    }

    private BorderColorBuilder ResolveBorderColor()
    {
        return Color?.Value switch
        {
            TimelineColor.PrimaryValue => Quark.BorderColor.Primary,
            TimelineColor.SecondaryValue => Quark.BorderColor.Secondary,
            TimelineColor.MutedValue => Quark.BorderColor.Muted,
            TimelineColor.AccentValue => Quark.BorderColor.Accent,
            TimelineColor.DestructiveValue => Quark.BorderColor.Destructive,
            _ => Status?.Value switch
            {
                TimelineStatus.PendingValue => Quark.BorderColor.Muted,
                _ => Quark.BorderColor.Primary
            }
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Status);
        hc.Add(Color);
        hc.Add(ConnectorStyle);
    }
}
