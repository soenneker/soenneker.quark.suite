@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()"></div>

@code {
    [Parameter]
    public TimelineStatus Status { get; set; } = TimelineStatus.Completed;

    [Parameter]
    public TimelineColor? Color { get; set; }

    [Parameter]
    public TimelineConnectorStyle ConnectorStyle { get; set; } = TimelineConnectorStyle.Solid;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Width ??= Quark.Width.Token("0.5");

        if (ReferenceEquals(ConnectorStyle, TimelineConnectorStyle.Solid))
        {
            var backgroundColor = ResolveBackgroundColor();

            if (backgroundColor is not null)
                BackgroundColor ??= backgroundColor;
        }
        else
        {
            Border ??= Quark.Border.Is2.FromLeft;
            BorderColor ??= ResolveBorderColor();
        }

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "timeline-connector";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (!ReferenceEquals(ConnectorStyle, TimelineConnectorStyle.Solid))
            {
                var borderStyleClass = ResolveBorderStyleClass();

                if (borderStyleClass != null)
                    AppendClass(ref cls, borderStyleClass);
            }

            if (ReferenceEquals(ConnectorStyle, TimelineConnectorStyle.Solid) && Color is null && ReferenceEquals(Status, TimelineStatus.InProgress))
                AppendClass(ref cls, "bg-linear-to-b from-primary to-muted");
        });
    }

    private BackgroundColorBuilder? ResolveBackgroundColor()
    {
        if (ReferenceEquals(Color, TimelineColor.Primary))
            return Quark.BackgroundColor.Primary;

        if (ReferenceEquals(Color, TimelineColor.Secondary))
            return Quark.BackgroundColor.Secondary;

        if (ReferenceEquals(Color, TimelineColor.Muted))
            return Quark.BackgroundColor.Muted;

        if (ReferenceEquals(Color, TimelineColor.Accent))
            return Quark.BackgroundColor.Accent;

        if (ReferenceEquals(Color, TimelineColor.Destructive))
            return Quark.BackgroundColor.Destructive;

        if (ReferenceEquals(Status, TimelineStatus.InProgress))
            return null;

        return ReferenceEquals(Status, TimelineStatus.Pending)
            ? Quark.BackgroundColor.Muted
            : Quark.BackgroundColor.Primary;
    }

    private BorderColorBuilder ResolveBorderColor()
    {
        if (ReferenceEquals(Color, TimelineColor.Primary))
            return Quark.BorderColor.Primary;

        if (ReferenceEquals(Color, TimelineColor.Secondary))
            return Quark.BorderColor.Secondary;

        if (ReferenceEquals(Color, TimelineColor.Muted))
            return Quark.BorderColor.Muted;

        if (ReferenceEquals(Color, TimelineColor.Accent))
            return Quark.BorderColor.Accent;

        if (ReferenceEquals(Color, TimelineColor.Destructive))
            return Quark.BorderColor.Destructive;

        return ReferenceEquals(Status, TimelineStatus.Pending)
            ? Quark.BorderColor.Muted
            : Quark.BorderColor.Primary;
    }

    private string? ResolveBorderStyleClass()
    {
        if (ReferenceEquals(ConnectorStyle, TimelineConnectorStyle.Dashed))
            return "border-dashed";

        if (ReferenceEquals(ConnectorStyle, TimelineConnectorStyle.Dotted))
            return "border-dotted";

        return null;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Status);
        hc.Add(Color);
        hc.Add(ConnectorStyle);
    }
}
