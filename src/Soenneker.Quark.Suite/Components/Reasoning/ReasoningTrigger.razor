@namespace Soenneker.Quark

<CollapsibleTrigger Display="Quark.Display.Flex"
                    Cursor="Quark.Cursor.Pointer"
                    ItemsAlign="Quark.Items.Center"
                    Gap='Quark.Gap.Token("1.25")'
                    TextColor="Quark.TextColor.MutedForeground"
                    Transition="Quark.Transition.Colors"
                    Class="@TriggerClass"
                    Attributes="@TriggerAttributes">
    <Icon Name="LucideIcon.Brain" Size="Quark.Size.Is4" aria-hidden="true" />
    <Span TextSize="Quark.TextSize.Sm" Leading="Quark.Leading.Is6" Class="@LabelClass">@(ChildContent ?? DefaultLabel)</Span>
    <Icon Name="LucideIcon.ChevronDown"
          Margin='Quark.Margin.Token("0.5").FromLeft'
          Size="Quark.Size.Is4"
          Opacity="Quark.Opacity.Is0"
          Transition="Quark.Transition.All"
          Class="group-hover:opacity-100 group-data-[state=open]:rotate-180 group-data-[state=open]:group-data-[streaming=false]:opacity-100"
          aria-hidden="true" />
</CollapsibleTrigger>

@code {
    [CascadingParameter]
    private ReasoningContext? ReasoningContext { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private string TriggerClass => string.Join(" ", new[]
    {
        "group hover:text-foreground",
        Class
    }.Where(x => !string.IsNullOrWhiteSpace(x)));

    private string LabelClass => "group-data-[streaming=true]:shimmer group-data-[streaming=true]:shimmer-repeat-delay-0 group-data-[streaming=true]:shimmer-spread-50 group-data-[streaming=true]:not-dark:shimmer-invert";

    private RenderFragment DefaultLabel => builder => builder.AddContent(0, ReasoningContext?.Label ?? "Thinking...");

    private IReadOnlyDictionary<string, object> TriggerAttributes => new Dictionary<string, object>
    {
        ["data-slot"] = "reasoning-trigger",
        ["data-streaming"] = ReasoningContext?.IsStreaming == true ? "true" : "false"
    };
}
