@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CollapsibleTrigger Attributes="@BuildTriggerAttributes()">
    <Icon Name="LucideIcon.Brain" Size="Quark.Size.Is4" aria-hidden="true" />
    <Span TextSize="Quark.TextSize.Sm" Leading="Quark.Leading.Is6" Class="@LabelClass">@(ChildContent ?? DefaultLabel)</Span>
    <Icon Name="LucideIcon.ChevronDown"
          Margin='Quark.Margin.FromLeft.Is0_5'
          Size="Quark.Size.Is4"
          Opacity='CssValue<OpacityBuilder>.For(Quark.Opacity.Is0, Quark.Opacity.Is100.OnGroupHover, Quark.Opacity.Is100.Modifier("group-data-[state=open]").Modifier("group-data-[streaming=false]"))'
          Rotate='Quark.Rotate.Is180.Modifier("group-data-[state=open]")'
          Transition="Quark.Transition.All"
          aria-hidden="true" />
</CollapsibleTrigger>

@code {
    [CascadingParameter]
    private ReasoningContext? ReasoningContext { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "reasoning-trigger";

        Display ??= Quark.Display.Flex;
        Cursor ??= Quark.Cursor.Pointer;
        ItemsAlign ??= Quark.Items.Center;
        Gap ??= Quark.Gap.Is1_25;
        TextColor ??= Quark.TextColor.MutedForeground;
        Transition ??= Quark.Transition.Colors;
    }

    private string LabelClass => "group-data-[streaming=true]:shimmer group-data-[streaming=true]:shimmer-repeat-delay-0 group-data-[streaming=true]:shimmer-spread-50 group-data-[streaming=true]:not-dark:shimmer-invert";

    private RenderFragment DefaultLabel => builder => builder.AddContent(0, ReasoningContext?.Label ?? "Thinking...");

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        var attributes = BuildAttributes();
        attributes["data-streaming"] = ReasoningContext?.IsStreaming == true ? "true" : "false";
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "group hover:text-foreground"));
    }
}
