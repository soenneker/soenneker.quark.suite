@namespace Soenneker.Quark
@inherits Soenneker.Quark.Component

<CascadingValue Value="@Context" IsFixed="false">
    <Collapsible Open="@ResolvedOpen" DefaultOpen="@ResolvedDefaultOpen" OpenChanged="@HandleOpenChanged" Attributes="@BuildRootAttributes()">
        @ChildContent
    </Collapsible>
</CascadingValue>

@code {
    private bool _initialized;
    private bool _open;
    private DateTimeOffset? _startedAt;
    private string? _durationLabel;
    private bool _hasStreamed;

    [Parameter]
    public bool IsStreaming { get; set; }

    [Parameter]
    public bool? Open { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    private bool ResolvedDefaultOpen => DefaultOpen || IsStreaming;

    private bool ResolvedOpen => IsStreaming || (Open ?? _open);

    private ReasoningContext Context => new(IsStreaming, Label);

    private string Label
    {
        get
        {
            if (!_hasStreamed || IsStreaming)
                return "Thinking...";

            if (_durationLabel is { } duration)
                return $"Thought for {duration} {(duration == "1" ? "second" : "seconds")}";

            return "Thought for a few seconds";
        }
    }

    protected override void OnParametersSet()
    {
        if (!_initialized)
        {
            _open = DefaultOpen || IsStreaming;
            _initialized = true;
        }

        if (IsStreaming)
        {
            _hasStreamed = true;
            _startedAt ??= DateTimeOffset.UtcNow;
            _durationLabel = null;
            _open = true;
        }
        else if (_startedAt is not null)
        {
            var seconds = Math.Max(1, (int)Math.Round((DateTimeOffset.UtcNow - _startedAt.Value).TotalSeconds));
            _durationLabel = seconds.ToString();
            _startedAt = null;
            if (Open is null)
                _open = false;
        }

        base.OnParametersSet();
    }

    private async Task HandleOpenChanged(bool open)
    {
        var nextOpen = IsStreaming || open;
        if (Open is null)
            _open = nextOpen;

        await OpenChanged.InvokeAsync(nextOpen);
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "reasoning";

        Width ??= Quark.Width.IsFull;
    }

    private IReadOnlyDictionary<string, object> BuildRootAttributes()
    {
        var attributes = BuildAttributes();
        attributes["data-streaming"] = IsStreaming ? "true" : "false";
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "not-prose"));
    }
}