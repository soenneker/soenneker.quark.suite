@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Div @attributes="BuildAttributes()">
    @if (Label.HasContent())
    {
        <Div FontWeight="Quark.FontWeight.Medium">@Label</Div>
    }
    <Div Display="Quark.Display.Flex" ItemsAlign="Quark.Items.Center" Gap="Quark.Gap.Is2">
        @if (Color.HasContent())
        {
            <Span Size='Quark.Size.Token("2.5")' Shrink="Quark.Shrink.Is0" Rounded='Quark.Rounded.Token("[2px]")' style="@($"background: {Color};")"></Span>
        }
        <Span TextColor="Quark.TextColor.MutedForeground">@Name</Span>
        <Span Margin="Quark.Margin.Auto.FromLeft" FontFamily="Quark.FontFamily.Mono" FontWeight="Quark.FontWeight.Medium" FontVariantNumeric="Quark.FontVariantNumeric.TabularNums" TextColor="Quark.TextColor.Foreground">@Value</Span>
    </Div>
</Div>

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public string? Name { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? Color { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        ZIndex ??= "z-50";
        MinWidth ??= Quark.MinWidth.Token("[8rem]");
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Background;
        Padding ??= Quark.Padding.Is2;
        TextColor ??= Quark.TextColor.Foreground;
        Shadow ??= Quark.Shadow.Xs;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "chart-tooltip-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "grid gap-1.5 text-xs");
        });
    }
}
