@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    private readonly string _chartId = $"chart-{Guid.NewGuid():N}";

    [Parameter]
    public string? ChartId { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Justify ??= Quark.Justify.Center;
        TextSize ??= Quark.TextSize.Xs;
        Width ??= Quark.Width.IsFull;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "chart";
        attributes["data-chart"] = ChartId ?? _chartId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "relative aspect-auto h-[250px] overflow-visible");
            AppendClass(ref cls, "[&_.quark-chart-axis-text]:fill-muted-foreground [&_.quark-chart-grid-line]:stroke-border/50");
            AppendClass(ref cls, "[&_.quark-chart-tooltip-cursor]:fill-muted");
        });
    }
}
