@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<FeedbackBarAction AsChild="true" Tooltip="@Tooltip" TooltipSide="@TooltipSide" Class="@ActionClass">
    <div data-slot="feedback-bar-close">@ChildContent</div>
</FeedbackBarAction>

@code {
    [Parameter]
    public string? Tooltip { get; set; }

    [Parameter]
    public Soenneker.Bradix.Side TooltipSide { get; set; } = Soenneker.Bradix.Side.Top;

    private string ActionClass => CombineClass("flex h-full items-center justify-center border-l px-2", Class);

    private static string CombineClass(string first, string? second)
    {
        return string.IsNullOrWhiteSpace(second) ? first : $"{first} {second}";
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "feedback-bar-close";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Tooltip);
        hc.Add(TooltipSide);
    }
}
