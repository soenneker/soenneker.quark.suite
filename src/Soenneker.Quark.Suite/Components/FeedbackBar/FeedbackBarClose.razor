@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (Tooltip.HasContent())
{
    <div @attributes="BuildAttributes()">
        <TooltipProvider DelayDuration="200">
            <Tooltip>
                <TooltipTrigger AsChild="true">
                    @ChildContent
                </TooltipTrigger>
                <TooltipContent Side="@TooltipSide" Class="rounded-full">
                    @Tooltip
                </TooltipContent>
            </Tooltip>
        </TooltipProvider>
    </div>
}
else
{
    <div @attributes="BuildAttributes()">@ChildContent</div>
}

@code {
    [Parameter]
    public string? Tooltip { get; set; }

    [Parameter]
    public Soenneker.Bradix.Side TooltipSide { get; set; } = Soenneker.Bradix.Side.Top;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "feedback-bar-close";

        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.IsFull;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Border ??= Quark.Border.FromLeft.Default;
        Padding ??= Quark.Padding.OnX.Is2;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Tooltip);
        hc.Add(TooltipSide);
    }
}
