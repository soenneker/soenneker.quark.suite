@using System.Threading

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<CascadingValue Value="_context" IsFixed="true">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public int OpenDelay { get; set; } = 700;

    [Parameter]
    public int CloseDelay { get; set; } = 300;

    private bool _open;
    private HoverCardContext _context = null!;
    private CancellationTokenSource? _pendingTransitionCts;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        _open = OpenChanged.HasDelegate ? Open : DefaultOpen;
        _context = new HoverCardContext(() => _open, RequestOpenAsync, RequestOpenImmediateAsync, RequestCloseAsync, RequestCloseImmediateAsync);
    }

    protected override void OnParametersSet()
    {
        if (OpenChanged.HasDelegate)
            _open = Open;

        base.OnParametersSet();
    }

    private async Task RequestOpenAsync()
    {
        await ScheduleOpenStateAsync(true, OpenDelay);
    }

    private async Task RequestCloseAsync()
    {
        await ScheduleOpenStateAsync(false, CloseDelay);
    }

    private Task RequestCloseImmediateAsync()
    {
        _pendingTransitionCts?.Cancel();
        _pendingTransitionCts?.Dispose();
        _pendingTransitionCts = null;
        return SetOpenAsync(false);
    }

    private Task RequestOpenImmediateAsync()
    {
        _pendingTransitionCts?.Cancel();
        _pendingTransitionCts?.Dispose();
        _pendingTransitionCts = null;
        return SetOpenAsync(true);
    }

    private async Task ScheduleOpenStateAsync(bool open, int delay)
    {
        _pendingTransitionCts?.Cancel();
        _pendingTransitionCts?.Dispose();
        _pendingTransitionCts = null;

        if (_open == open)
            return;

        if (delay <= 0)
        {
            await SetOpenAsync(open);
            return;
        }

        var cts = new CancellationTokenSource();
        _pendingTransitionCts = cts;

        try
        {
            await Task.Delay(delay, cts.Token);
            await SetOpenAsync(open);
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            if (ReferenceEquals(_pendingTransitionCts, cts))
            {
                _pendingTransitionCts.Dispose();
                _pendingTransitionCts = null;
            }
            else
            {
                cts.Dispose();
            }
        }
    }

    private async Task SetOpenAsync(bool open)
    {
        if (_open == open)
            return;

        _open = open;

        if (OpenChanged.HasDelegate)
            await OpenChanged.InvokeAsync(open);

        await RefreshOffThread();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "hover-card";
        attributes["data-state"] = _open ? "open" : "closed";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-hover-card");
            AppendClass(ref cls, "group/hover-card relative");
        });
    }

    public override void Dispose()
    {
        _pendingTransitionCts?.Cancel();
        _pendingTransitionCts?.Dispose();
        _pendingTransitionCts = null;
        base.Dispose();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(_open);
        hc.Add(OpenDelay);
        hc.Add(CloseDelay);
    }
}
