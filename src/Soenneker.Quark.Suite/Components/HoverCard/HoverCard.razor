@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixHoverCard Open="@(OpenChanged.HasDelegate ? Open : (bool?)null)"
                 DefaultOpen="@DefaultOpen"
                 OpenChanged="@OpenChanged"
                 OpenDelay="@OpenDelay"
                 CloseDelay="@CloseDelay">
    @ChildContent
</BradixHoverCard>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "hover-card";
    }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public EventCallback<bool> OpenChanged { get; set; }

    [Parameter]
    public bool DefaultOpen { get; set; }

    [Parameter]
    public int OpenDelay { get; set; } = 700;

    [Parameter]
    public int CloseDelay { get; set; } = 300;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Open);
        hc.Add(OpenDelay);
        hc.Add(CloseDelay);
    }
}