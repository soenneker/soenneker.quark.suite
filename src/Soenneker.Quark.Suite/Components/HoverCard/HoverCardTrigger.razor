@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <button @onmouseenter="HandleMouseEnter"
            @onmouseleave="HandleMouseLeave"
            @onfocusin="HandleFocusIn"
            @onfocusout="HandleFocusOut"
            @onclick="HandleClick"
            @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    [CascadingParameter]
    private HoverCardContext? Context { get; set; }

    [CascadingParameter(Name = "TriggerContext")]
    private TriggerContext? ParentTriggerContext { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["type"] = "button";
        attributes["data-slot"] = "hover-card-trigger";

        if (Context is not null)
            attributes["data-state"] = Context.IsOpen ? "open" : "closed";

        if (ParentTriggerContext?.TriggerId is not null)
            attributes["id"] = ParentTriggerContext.TriggerId;
        else if (Context?.TriggerId is not null)
            attributes["id"] = Context.TriggerId;

        var describedBy = BuildAriaDescribedBy();
        if (describedBy is not null)
            attributes["aria-describedby"] = describedBy;

        if (ParentTriggerContext?.AriaHasPopup is not null)
            attributes["aria-haspopup"] = ParentTriggerContext.AriaHasPopup;

        if (ParentTriggerContext?.AriaControls is not null)
        {
            attributes["aria-expanded"] = ParentTriggerContext.IsOpen ? "true" : "false";
            attributes["aria-controls"] = ParentTriggerContext.AriaControls;
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-hover-card-trigger");
            AppendClass(ref cls, "inline-flex max-w-full items-center justify-center gap-2 rounded-md text-sm font-medium transition-[color,box-shadow]");
            AppendClass(ref cls, "focus-visible:ring-ring/50 outline-none focus-visible:ring-[3px]");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
        });
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = ParentTriggerContext?.TriggerId ?? Context?.TriggerId,
            IsOpen = ParentTriggerContext?.AriaControls is not null ? ParentTriggerContext.IsOpen : Context?.IsOpen == true,
            DataState = Context?.IsOpen == true ? "open" : "closed",
            AriaHasPopup = ParentTriggerContext?.AriaHasPopup,
            AriaControls = ParentTriggerContext?.AriaControls,
            AriaDescribedBy = BuildAriaDescribedBy(),
            Toggle = ParentTriggerContext?.Toggle,
            Open = Context is null ? null : () => Context.Open(),
            Close = Context is null ? null : () => Context.Close(),
            OnMouseEnter = Context is null ? null : () => Context.Open(),
            OnMouseLeave = Context is null ? null : () => Context.Close(),
            OnFocusIn = Context is null ? null : () => Context.Open(),
            OnFocusOut = Context is null ? null : () => Context.Close()
        };
    }

    private string? BuildAriaDescribedBy()
    {
        var hoverCardId = Context?.IsOpen == true ? Context.ContentId : null;
        var parentDescribedBy = ParentTriggerContext?.AriaDescribedBy;

        if (parentDescribedBy is null)
            return hoverCardId;

        if (hoverCardId is null)
            return parentDescribedBy;

        return $"{parentDescribedBy} {hoverCardId}";
    }

    protected override Task HandleClick(MouseEventArgs e)
    {
        return ParentTriggerContext?.Toggle?.Invoke() ?? Task.CompletedTask;
    }

    private Task HandleMouseEnter(MouseEventArgs e)
    {
        return Context?.Open() ?? Task.CompletedTask;
    }

    private Task HandleMouseLeave(MouseEventArgs e)
    {
        return Context?.Close() ?? Task.CompletedTask;
    }

    private Task HandleFocusIn(FocusEventArgs e)
    {
        return Context?.Open() ?? Task.CompletedTask;
    }

    private Task HandleFocusOut(FocusEventArgs e)
    {
        return Context?.Close() ?? Task.CompletedTask;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.IsOpen);
        hc.Add(Context?.ContentId);
        hc.Add(AsChild);
        hc.Add(ParentTriggerContext?.TriggerId);
        hc.Add(ParentTriggerContext?.AriaHasPopup);
        hc.Add(ParentTriggerContext?.AriaControls);
        hc.Add(ParentTriggerContext?.AriaDescribedBy);
        hc.Add(ParentTriggerContext?.IsOpen);
    }
}
