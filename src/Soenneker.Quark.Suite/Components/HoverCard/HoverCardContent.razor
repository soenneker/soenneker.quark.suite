@using Soenneker.Bradix
@using System.Collections.Generic

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<BradixHoverCardPortal>
    <BradixHoverCardContent ForceMount="@ForceMount"
                            Side="@ResolvedSide"
                            Align="@ResolvedAlign"
                            SideOffset="@SideOffset"
                            AlignOffset="@AlignOffset"
                            ArrowPadding="@ArrowPadding"
                            AvoidCollisions="@AvoidCollisions"
                            CollisionPadding="@CollisionPadding"
                            CollisionBoundarySelector="@CollisionBoundarySelector"
                            CollisionBoundarySelectors="@CollisionBoundarySelectors"
                            Sticky="@Sticky"
                            HideWhenDetached="@HideWhenDetached"
                            AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixHoverCardContent>
</BradixHoverCardPortal>

@code {
    [CascadingParameter]
    private BradixHoverCard? HoverCard { get; set; }

    [Parameter]
    public bool Open { get; set; }

    [Parameter]
    public bool ForceMount { get; set; }

    /// <summary>
    /// Gets or sets side placement: top, right, bottom, or left.
    /// </summary>
    [Parameter]
    public string Side { get; set; } = "bottom";

    /// <summary>
    /// Gets or sets horizontal alignment: start, center, or end.
    /// </summary>
    [Parameter]
    public string PlacementAlign { get; set; } = "center";

    /// <summary>
    /// Gets or sets offset in pixels from the trigger.
    /// </summary>
    [Parameter]
    public int SideOffset { get; set; } = 4;

    [Parameter]
    public double AlignOffset { get; set; }

    [Parameter]
    public double ArrowPadding { get; set; }

    [Parameter]
    public bool AvoidCollisions { get; set; } = true;

    [Parameter]
    public double CollisionPadding { get; set; }

    [Parameter]
    public string? CollisionBoundarySelector { get; set; }

    [Parameter]
    public IReadOnlyList<string>? CollisionBoundarySelectors { get; set; }

    [Parameter]
    public string Sticky { get; set; } = "partial";

    [Parameter]
    public bool HideWhenDetached { get; set; }

    [Parameter]
    public bool DisableAutoOpen { get; set; }

    private bool IsOpen => HoverCard?.CurrentOpen ?? Open;
    private BradixSide ResolvedSide => Side switch
    {
        "top" => BradixSide.Top,
        "right" => BradixSide.Right,
        "left" => BradixSide.Left,
        _ => BradixSide.Bottom
    };
    private BradixAlignment ResolvedAlign => PlacementAlign switch
    {
        "start" => BradixAlignment.Start,
        "end" => BradixAlignment.End,
        _ => BradixAlignment.Center
    };
    private IReadOnlyDictionary<string, object> ContentAttributes => BuildContentAttributes();

    private IReadOnlyDictionary<string, object> BuildContentAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("id");
        attributes.Remove("tabindex");
        attributes.Remove("data-state");
        attributes.Remove("data-side");
        attributes.Remove("data-align");
        attributes.Remove("onmouseenter");
        attributes.Remove("onmouseleave");
        return attributes;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Width ??= Quark.Width.Token("64");
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Default;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is4;
        TextColor ??= Quark.TextColor.PopoverForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "hover-card-content";
        attributes["data-state"] = IsOpen ? "open" : "closed";
        attributes["data-side"] = Side;
        attributes["data-align"] = PlacementAlign;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "z-50 origin-(--radix-hover-card-content-transform-origin) shadow-md outline-hidden");
            AppendClass(ref cls, "data-[side=bottom]:slide-in-from-top-2 data-[side=left]:slide-in-from-right-2 data-[side=right]:slide-in-from-left-2 data-[side=top]:slide-in-from-bottom-2");
            AppendClass(ref cls, "data-[state=closed]:animate-out data-[state=closed]:fade-out-0 data-[state=closed]:zoom-out-95 data-[state=open]:animate-in data-[state=open]:fade-in-0 data-[state=open]:zoom-in-95");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(IsOpen);
        hc.Add(Side);
        hc.Add(PlacementAlign);
        hc.Add(SideOffset);
        hc.Add(AlignOffset);
        hc.Add(ArrowPadding);
        hc.Add(AvoidCollisions);
        hc.Add(CollisionPadding);
        hc.Add(CollisionBoundarySelector);
        if (CollisionBoundarySelectors is not null)
        {
            foreach (string selector in CollisionBoundarySelectors)
                hc.Add(selector);
        }
        hc.Add(Sticky);
        hc.Add(HideWhenDetached);
        hc.Add(DisableAutoOpen);
        hc.Add(ForceMount);
    }
}
