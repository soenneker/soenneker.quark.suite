@namespace Soenneker.Quark
@inherits Soenneker.Quark.Component

<Button Variant="ButtonVariant.Ghost" ButtonSize="@ButtonSize" OnClick="@HandleClick" Attributes="@BuildAttributes()">
    @ChildContent
</Button>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "suggestion";
    }

    [CascadingParameter]
    internal Suggestions? ParentSuggestions { get; set; }

    [Parameter]
    public string Variant { get; set; } = "filled";

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = Soenneker.Quark.ButtonSize.Sm;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    private async Task HandleClick(MouseEventArgs args)
    {
        await OnClick.InvokeAsync(args);
        await (ParentSuggestions?.Select(Value) ?? Task.CompletedTask);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, GetVariantClass()));
    }

    private string GetVariantClass()
    {
        const string baseClass = "h-8 gap-1.5 rounded-full px-4 text-sm font-normal shadow-none outline-0 transition-all duration-150 focus-visible:ring-2 focus-visible:ring-ring active:scale-[.99]";

        ReadOnlySpan<char> variant = Variant.AsSpan().Trim();

        if (variant.Equals("outline", StringComparison.OrdinalIgnoreCase))
            return $"{baseClass} border border-input bg-transparent text-primary hover:bg-muted";

        return variant.Equals("ghost", StringComparison.OrdinalIgnoreCase)
            ? $"{baseClass} border-none bg-transparent text-muted-foreground hover:bg-muted hover:text-primary"
            : $"{baseClass} border-none bg-muted text-primary hover:bg-border";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(Value);
        hc.Add(ButtonSize);
    }
}
