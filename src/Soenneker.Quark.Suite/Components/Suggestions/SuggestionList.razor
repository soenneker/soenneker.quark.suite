@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@using Soenneker.Bradix

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    [Parameter]
    public Orientation Orientation { get; set; } = Orientation.Horizontal;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        Gap ??= Quark.Gap.Is2;

        if (Orientation == Orientation.Vertical)
        {
            FlexDirection ??= Quark.FlexDirection.Col;
            ItemsAlign ??= Quark.Items.Start;
        }
        else
        {
            FlexDirection ??= Quark.FlexDirection.Row;
            FlexWrap ??= Quark.FlexWrap.Wrap;
            ItemsAlign ??= Quark.Items.Center;
            Justify ??= Quark.Justify.Center;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "suggestion-list";
        attributes["role"] = "group";
        attributes["aria-label"] = "Suggestions";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "animate-in duration-150 fade-in-0");
        });
    }
}
