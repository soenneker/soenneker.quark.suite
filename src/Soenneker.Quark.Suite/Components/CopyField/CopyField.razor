@namespace Soenneker.Quark

<div @attributes="BuildRootAttributes()">
    <span @attributes="BuildTextAttributes()">@DisplayText</span>
    <CopyButton Text="@CurrentCopyText"
                Variant="@CopyButtonVariant"
                ButtonSize="@CopyButtonSize"
                Disabled="@CopyDisabled"
                IdleIcon="@IdleIcon"
                DoneIcon="@DoneIcon"
                ErrorIcon="@ErrorIcon"
                CopyLabel="@CopyLabel"
                DoneLabel="@DoneLabel"
                ErrorLabel="@ErrorLabel"
                ResetDelay="@ResetDelay"
                Class="@ResolvedCopyButtonClass"
                Attributes="@CopyButtonAttributes"
                OnCopySuccess="@OnCopySuccess"
                OnCopyError="@OnCopyError" />
</div>

@code {
    /// <summary>
    /// Gets or sets the root id.
    /// </summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>
    /// Gets or sets the displayed value.
    /// </summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>
    /// Optional text copied instead of <see cref="Value"/>.
    /// </summary>
    [Parameter]
    public string? CopyText { get; set; }

    /// <summary>
    /// Gets or sets the placeholder text.
    /// </summary>
    [Parameter]
    public string? Placeholder { get; set; }

    /// <summary>
    /// Indicates whether the field and copy button are disabled.
    /// </summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Additional root field classes.
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Additional root field styles.
    /// </summary>
    [Parameter]
    public string? Style { get; set; }

    /// <summary>
    /// Additional text classes.
    /// </summary>
    [Parameter]
    public string? TextClass { get; set; }

    /// <summary>
    /// Additional copy button classes.
    /// </summary>
    [Parameter]
    public string? CopyButtonClass { get; set; }

    /// <summary>
    /// Accessible field label.
    /// </summary>
    [Parameter]
    public string? AriaLabel { get; set; }

    /// <summary>
    /// Element id that labels the field.
    /// </summary>
    [Parameter]
    public string? AriaLabelledBy { get; set; }

    /// <summary>
    /// Element id that describes the field.
    /// </summary>
    [Parameter]
    public string? AriaDescribedBy { get; set; }

    /// <summary>
    /// Idle copy icon.
    /// </summary>
    [Parameter]
    public LucideIcon IdleIcon { get; set; } = LucideIcon.Copy;

    /// <summary>
    /// Successful copy icon.
    /// </summary>
    [Parameter]
    public LucideIcon DoneIcon { get; set; } = LucideIcon.Check;

    /// <summary>
    /// Failed copy icon.
    /// </summary>
    [Parameter]
    public LucideIcon ErrorIcon { get; set; } = LucideIcon.X;

    /// <summary>
    /// Copy button variant.
    /// </summary>
    [Parameter]
    public ButtonVariant CopyButtonVariant { get; set; } = ButtonVariant.Ghost;

    /// <summary>
    /// Copy button size.
    /// </summary>
    [Parameter]
    public CssValue<ButtonSizeBuilder>? CopyButtonSize { get; set; } = ButtonSize.IconXs;

    /// <summary>
    /// Button label used for accessible names and tooltips.
    /// </summary>
    [Parameter]
    public string CopyLabel { get; set; } = "Copy";

    /// <summary>
    /// Label used after a successful copy.
    /// </summary>
    [Parameter]
    public string DoneLabel { get; set; } = "Copied";

    /// <summary>
    /// Label used after a failed copy.
    /// </summary>
    [Parameter]
    public string ErrorLabel { get; set; } = "Copy failed";

    /// <summary>
    /// How long the success or error state remains visible.
    /// </summary>
    [Parameter]
    public int ResetDelay { get; set; } = 1600;

    /// <summary>
    /// Indicates whether the copy button should be disabled when no copy text is available.
    /// </summary>
    [Parameter]
    public bool DisableCopyWhenEmpty { get; set; } = true;

    /// <summary>
    /// Additional attributes applied to the root field.
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? Attributes { get; set; }

    /// <summary>
    /// Additional attributes applied to the display text.
    /// </summary>
    [Parameter]
    public IReadOnlyDictionary<string, object>? TextAttributes { get; set; }

    /// <summary>
    /// Additional attributes applied to the copy button.
    /// </summary>
    [Parameter]
    public IReadOnlyDictionary<string, object>? CopyButtonAttributes { get; set; }

    /// <summary>
    /// Raised after text is copied successfully.
    /// </summary>
    [Parameter]
    public EventCallback<string> OnCopySuccess { get; set; }

    /// <summary>
    /// Raised when copying fails.
    /// </summary>
    [Parameter]
    public EventCallback<Exception?> OnCopyError { get; set; }

    private string? CurrentCopyText => CopyText ?? Value;

    private string DisplayText => Value ?? Placeholder ?? string.Empty;

    private bool CopyDisabled => Disabled || (DisableCopyWhenEmpty && string.IsNullOrEmpty(CurrentCopyText));

    private string ResolvedRootClass => AppendClass("inline-flex h-8 w-full min-w-0 cursor-default select-none items-center gap-1 rounded-lg border border-transparent bg-input/60 px-2 py-1 shadow-none dark:bg-input/40", Class);

    private string ResolvedTextClass => AppendClass("min-w-0 flex-1 truncate font-mono text-[13px] leading-none text-foreground/80", TextClass);

    private string ResolvedCopyButtonClass => AppendClass("size-6! p-0! text-muted-foreground hover:bg-transparent hover:text-foreground active:translate-y-0", CopyButtonClass);

    private Dictionary<string, object> BuildRootAttributes()
    {
        var attributes = CopyAttributes(Attributes);

        attributes["data-slot"] = "copy-field";

        if (!string.IsNullOrWhiteSpace(Id))
            attributes["id"] = Id!;

        if (Disabled)
            attributes["aria-disabled"] = "true";

        if (!string.IsNullOrWhiteSpace(AriaLabel))
            attributes["aria-label"] = AriaLabel!;

        if (!string.IsNullOrWhiteSpace(AriaLabelledBy))
            attributes["aria-labelledby"] = AriaLabelledBy!;

        if (!string.IsNullOrWhiteSpace(AriaDescribedBy))
            attributes["aria-describedby"] = AriaDescribedBy!;

        MergeAttribute(attributes, "class", ResolvedRootClass);
        MergeAttribute(attributes, "style", Style);

        return attributes;
    }

    private Dictionary<string, object> BuildTextAttributes()
    {
        var attributes = CopyAttributes(TextAttributes);
        MergeAttribute(attributes, "class", ResolvedTextClass);

        return attributes;
    }

    private static string AppendClass(string defaultClass, string? additionalClass)
    {
        if (string.IsNullOrWhiteSpace(additionalClass))
            return defaultClass;

        return $"{defaultClass} {additionalClass}";
    }

    private static Dictionary<string, object> CopyAttributes(IReadOnlyDictionary<string, object>? source)
    {
        var attributes = new Dictionary<string, object>(StringComparer.OrdinalIgnoreCase);

        if (source is null)
            return attributes;

        foreach ((var key, var value) in source)
        {
            attributes[key] = value;
        }

        return attributes;
    }

    private static void MergeAttribute(Dictionary<string, object> attributes, string name, string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return;

        if (attributes.TryGetValue(name, out var existing) && !string.IsNullOrWhiteSpace(existing?.ToString()))
        {
            var separator = name.Equals("style", StringComparison.OrdinalIgnoreCase)
                ? "; "
                : " ";

            attributes[name] = $"{existing}{separator}{value}";
        }
        else
        {
            attributes[name] = value;
        }
    }
}
