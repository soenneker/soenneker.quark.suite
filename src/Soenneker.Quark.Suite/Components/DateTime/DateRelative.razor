@namespace Soenneker.Quark
@inherits DateTimeComponentBase
@implements IDateRelative

<time @attributes="BuildAttributes()">@RenderContent()</time>

@code {
    /// <summary>
    /// Gets or sets the date/time value to render relative to now.
    /// </summary>
    [Parameter]
    public DateTimeOffset? Value { get; set; }

    /// <summary>
    /// Gets or sets how the relative date/time value is displayed.
    /// </summary>
    [Parameter]
    public DateRelativeFormatStyle FormatStyle { get; set; } = DateRelativeFormatStyle.Long;

    protected override QuarkDateTimeUpdateKind UpdateKind => QuarkDateTimeUpdateKind.Relative;

    protected override DateRelativeFormatStyle DateRelativeFormatStyleCore => FormatStyle;

    protected override DateTimeOffset? GetEffectiveValue(DateTimeOffset now)
    {
        return Value;
    }

    protected override string FormatValue(DateTimeOffset? value, DateTimeOffset now, QuarkDateTimeFormatOptions options)
    {
        return value.HasValue ? Formatter.FormatRelative(value.Value, now, options) : options.NullText ?? string.Empty;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "date-relative";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(FormatStyle);
    }
}
