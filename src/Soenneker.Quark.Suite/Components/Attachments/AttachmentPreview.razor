@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "attachment-preview";
        Position ??= Quark.Position.Absolute;
        Inset ??= Quark.Inset.Is0;
        Display ??= Quark.Display.Flex;
        Size ??= Quark.Size.IsFull;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Overflow ??= Quark.Overflow.Hidden;
        Rounded ??= Quark.Rounded.Token("[inherit]");
        Border ??= Quark.Border.Is0;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
        TextColor ??= Quark.TextColor.MutedForeground;

    }
}