@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<button type="@Type.Value" disabled="@Disabled" @attributes="BuildAttributes()">
    @if (ChildContent is not null)
    {
        @ChildContent
    }
    else
    {
        <Icon Name="LucideIcon.X" Size="Quark.Size.Is3" aria-hidden="true" />
    }
</button>

@code {
    [Parameter]
    public ButtonType Type { get; set; } = ButtonType.Button;

    [Parameter]
    public CssValue<ButtonSizeBuilder>? ButtonSize { get; set; } = Soenneker.Quark.ButtonSize.Sm;

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Ghost;

    [Parameter]
    public bool Disabled { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "attachment-remove";
        Position ??= Quark.Position.Absolute;
        Top ??= Quark.Top.Is1;
        Right ??= Quark.Right.Is1;
        ZIndex ??= Quark.ZIndex.Is10;
        Display ??= Quark.Display.Flex;
        Size ??= Quark.Size.Is4_5;
        Cursor ??= Quark.Cursor.Pointer.OnDisabled.NotAllowed;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Full;
        BackgroundColor ??= Quark.BackgroundColor.Secondary;
        TextColor ??= Quark.TextColor.MutedForeground;
        Opacity ??= Quark.Opacity.Is100;
        Transition ??= Quark.Transition.All;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes.TryAdd("aria-label", "Remove attachment");

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "hover:bg-border hover:text-primary active:scale-[.97] disabled:opacity-50 sm:opacity-0 group-hover:opacity-100");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Type);
        hc.Add(ButtonSize);
        hc.Add(Variant);
        hc.Add(Disabled);
    }
}
