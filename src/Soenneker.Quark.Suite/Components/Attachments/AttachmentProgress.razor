@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">
    <div class="h-full bg-foreground transition-[width] duration-200 dark:bg-primary" style="width:@ClampedValue%"></div>
</div>

@code {
    [Parameter]
    public int Value { get; set; }

    private int ClampedValue => Math.Clamp(Value, 0, 100);

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "attachment-progress";
        attributes.TryAdd("role", "progressbar");
        attributes["aria-valuemin"] = "0";
        attributes["aria-valuemax"] = "100";
        attributes["aria-valuenow"] = ClampedValue;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "pointer-events-none absolute inset-x-0 bottom-0 h-0.5 bg-border/90");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
    }
}
