@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Div @attributes="BuildAttributes()">
    <Div Height="Quark.Height.IsFull"
         BackgroundColor="Quark.BackgroundColor.Foreground.OnDark.Primary"
         Transition='Quark.Transition.Token("transition-[width]")'
         Duration="Quark.Duration.Is200"
         Style="@ProgressStyle"></Div>
</Div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "attachment-progress";
        PointerEvents ??= Quark.PointerEvents.None;
        Position ??= Quark.Position.Absolute;
        Left ??= Quark.Left.Is0;
        Right ??= Quark.Right.Is0;
        Bottom ??= Quark.Bottom.Is0;
        Height ??= Quark.Height.Token("0.5");
        BackgroundColor ??= Quark.BackgroundColor.Token("border/90");
    }

    [Parameter]
    public int Value { get; set; }

    private int ClampedValue => Math.Clamp(Value, 0, 100);
    private string ProgressStyle => $"width:{ClampedValue}%";

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes.TryAdd("role", "progressbar");
        attributes["aria-valuemin"] = "0";
        attributes["aria-valuemax"] = "100";
        attributes["aria-valuenow"] = ClampedValue;

    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
    }
}
