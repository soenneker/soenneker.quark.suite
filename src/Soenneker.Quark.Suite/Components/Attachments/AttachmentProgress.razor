@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<Div @attributes="BuildAttributes()">
    <Div Height="Quark.Height.IsFull"
         BackgroundColor='Quark.BackgroundColor.Utility("foreground")'
         Transition='Quark.Transition.Token("transition-[width]")'
         Duration="Quark.Duration.Is200"
         Class="dark:bg-primary"
         Style="@ProgressStyle"></Div>
</Div>

@code {
    [Parameter]
    public int Value { get; set; }

    private int ClampedValue => Math.Clamp(Value, 0, 100);
    private string ProgressStyle => $"width:{ClampedValue}%";

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "attachment-progress";
        attributes.TryAdd("role", "progressbar");
        attributes["aria-valuemin"] = "0";
        attributes["aria-valuemax"] = "100";
        attributes["aria-valuenow"] = ClampedValue;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "pointer-events-none absolute inset-x-0 bottom-0 h-0.5 bg-border/90");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
    }
}
