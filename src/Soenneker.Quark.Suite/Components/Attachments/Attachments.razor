@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    [Parameter]
    public string Variant { get; set; } = "list";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "attachments";
        attributes["data-variant"] = Variant;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex w-full max-w-full min-w-0 flex-wrap items-end justify-center gap-2.5 overflow-x-auto overscroll-x-contain pb-0.5 [scrollbar-color:var(--scrollbar-thumb)_transparent] [scrollbar-width:thin] [&::-webkit-scrollbar-thumb]:border-transparent [&::-webkit-scrollbar-track]:bg-transparent");
            AppendClass(ref cls, "data-[variant=list]:flex-row data-[variant=list]:flex-wrap");
            AppendClass(ref cls, "data-[variant=inline]:flex data-[variant=inline]:flex-wrap data-[variant=inline]:gap-2");
            AppendClass(ref cls, "data-[variant=grid]:grid data-[variant=grid]:grid-cols-2 data-[variant=grid]:gap-2");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
    }
}
