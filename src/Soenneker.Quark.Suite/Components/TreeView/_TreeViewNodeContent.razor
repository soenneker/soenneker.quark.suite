@typeparam TNode
@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div data-slot="tree-view-node-title" class="inline-flex items-center gap-1">
    @if (SelectionMode == TreeViewSelectionMode.Multiple)
    {
        <div data-slot="tree-view-node-check">
            <Check TValue="bool" Checked="@Checked" CheckedChanged="@OnCheckedChanged" Disabled="@NodeState.Disabled" />
        </div>
    }
    <span @attributes="BuildAttributes()" @onclick="ToggleClicked" style="@GetCurrentStyle()">
        @ChildContent
    </span>
</div>

@code {
    /// <summary>
    /// Gets or sets the state of the tree view node.
    /// </summary>
    [Parameter] public TreeViewNodeState<TNode> NodeState { get; set; } = null!;
    /// <summary>
    /// Gets or sets the selection mode for the tree view.
    /// </summary>
    [Parameter] public TreeViewSelectionMode SelectionMode { get; set; } = TreeViewSelectionMode.Single;
    /// <summary>
    /// Gets or sets the action to apply styling to selected nodes.
    /// </summary>
    [Parameter] public Action<TNode, NodeStyling>? SelectedNodeStyling { get; set; }
    /// <summary>
    /// Gets or sets the action to apply styling to disabled nodes.
    /// </summary>
    [Parameter] public Action<TNode, NodeStyling>? DisabledNodeStyling { get; set; }
    /// <summary>
    /// Gets or sets the action to apply styling to nodes.
    /// </summary>
    [Parameter] public Action<TNode, NodeStyling>? NodeStyling { get; set; }
    /// <summary>
    /// Gets or sets the callback invoked When the node title is clicked.
    /// </summary>
    [Parameter] public EventCallback OnTitleClicked { get; set; }

    [CascadingParameter(Name = nameof(ParentTreeView))] public TreeView<TNode>? ParentTreeView { get; set; }
    [CascadingParameter(Name = nameof(ParentTreeViewState))] public TreeViewState<TNode> ParentTreeViewState { get; set; } = null!;

    private readonly NodeStyling _selectedNodeStyling = new() { Background = Quark.BackgroundColor.Primary, TextColor = Quark.TextColor.White };
    private readonly NodeStyling _disabledNodeStyling = new() { Background = Quark.BackgroundColor.Muted, TextColor = Quark.TextColor.MutedForeground };
    private readonly NodeStyling _nodeStyling = new();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Cursor ??= Quark.Cursor.Pointer;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "tree-view-node-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            if (NodeState?.Disabled ?? false)
                AppendClass(ref cls, "pointer-events-none opacity-60");
        });
    }

    protected override Task OnParametersSetAsync()
    {
        if (Selected)
            SelectedNodeStyling?.Invoke(NodeState.Node, _selectedNodeStyling);
        else if (NodeState.Disabled)
            DisabledNodeStyling?.Invoke(NodeState.Node, _disabledNodeStyling);
        else
            NodeStyling?.Invoke(NodeState.Node, _nodeStyling);

        return base.OnParametersSetAsync();
    }

    private string GetCurrentStyle()
    {
        if (Selected)
            return _selectedNodeStyling.Style;
        if (NodeState.Disabled)
            return _disabledNodeStyling.Style;
        return _nodeStyling.Style;
    }

    private bool Selected => SelectionMode == TreeViewSelectionMode.Single && ParentTreeViewState.SelectedNode is not null && EqualityComparer<TNode>.Default.Equals(ParentTreeViewState.SelectedNode, NodeState.Node);
    private bool Checked => SelectionMode == TreeViewSelectionMode.Multiple && ParentTreeViewState.SelectedNodes is not null && ParentTreeViewState.SelectedNodes.Contains(NodeState.Node);

    private async Task ToggleClicked()
    {
        // Always handle expansion first (if ToggleOnNodeClick is enabled)
        await OnTitleClicked.InvokeAsync();
        
        // Then handle selection (only if not disabled and not multiple selection mode)
        if (!NodeState.Disabled && SelectionMode != TreeViewSelectionMode.Multiple)
        {
            if (ParentTreeView is not null)
                await ParentTreeView.SelectNode(NodeState.Node);
        }
    }

    private Task OnCheckedChanged(bool value)
    {
        if (ParentTreeView is null || NodeState.Disabled)
            return Task.CompletedTask;

        return ParentTreeView.ToggleCheckNode(NodeState.Node);
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(NodeState);
        hc.Add(SelectionMode);
        hc.Add(SelectedNodeStyling);
        hc.Add(DisabledNodeStyling);
        hc.Add(NodeStyling);
        hc.Add(ParentTreeViewState.SelectedNode);

        if (ParentTreeViewState.SelectedNodes is not null)
        {
            hc.Add(ParentTreeViewState.SelectedNodes.Count);
            foreach (var node in ParentTreeViewState.SelectedNodes)
            {
                hc.Add(node);
            }
        }
    }
}
