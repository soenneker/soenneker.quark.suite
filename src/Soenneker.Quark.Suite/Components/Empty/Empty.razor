@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IEmpty

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "empty";

        // shadcn/ui empty base - exact copy from new-york-v4 ui/empty.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-empty");
            AppendClass(ref cls, "flex w-full min-w-0 flex-col items-center justify-center gap-4 rounded-xl border border-dashed p-6 py-10 text-center text-balance flex-none");
        });
    }
}
