@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IEmptyMedia

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    /// <summary>
    /// Gets or sets the visual style variant.
    /// </summary>
    [Parameter]
    public EmptyMediaVariant Variant { get; set; } = EmptyMediaVariant.Default;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Margin ??= Quark.Margin.Is2.FromBottom;

        if (ReferenceEquals(Variant, EmptyMediaVariant.Icon))
        {
            BoxSize ??= Size.Is8;
            Rounded ??= Quark.Rounded.Lg;
            BackgroundColor ??= Quark.BackgroundColor.Muted;
            TextColor ??= Quark.TextColor.Foreground;
        }
        else
        {
            BackgroundColor ??= Quark.BackgroundColor.Transparent;
        }

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "empty-icon";
        attributes["data-variant"] = ReferenceEquals(Variant, EmptyMediaVariant.Icon) ? "icon" : "default";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0");

            if (ReferenceEquals(Variant, EmptyMediaVariant.Icon))
                AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
    }
}
