@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IEmptyMedia

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    /// <summary>
    /// Gets or sets the visual style variant.
    /// </summary>
    [Parameter]
    public EmptyMediaVariant Variant { get; set; } = EmptyMediaVariant.Default;

    private static string GetVariantClass(EmptyMediaVariant? variant)
        => (variant?.Value ?? EmptyMediaVariant.DefaultValue) switch
        {
            EmptyMediaVariant.IconValue => "flex size-8 shrink-0 items-center justify-center rounded-lg bg-muted text-foreground [&_svg:not([class*='size-'])]:size-4",
            _ => "bg-transparent"
        };

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Margin ??= Quark.Margin.Is2.FromBottom;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "empty-icon";
        attributes["data-variant"] = Variant?.Value ?? EmptyMediaVariant.Default.Value;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0");
            AppendClass(ref cls, GetVariantClass(Variant));
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
    }
}
