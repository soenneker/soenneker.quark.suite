@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IItemMedia

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    [Parameter]
    public ItemMediaVariant Variant { get; set; } = ItemMediaVariant.Default;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        Shrink ??= Quark.Shrink.Is0;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;

        ApplyVariantDefaults();

    }

    private void ApplyVariantDefaults()
    {
        if (ReferenceEquals(Variant, ItemMediaVariant.Icon))
        {
            BoxSize ??= Size.Is8;
            Rounded ??= Quark.Rounded.Sm;
            Border ??= Quark.Border.Default;
            BackgroundColor ??= Quark.BackgroundColor.Muted;
            return;
        }

        if (ReferenceEquals(Variant, ItemMediaVariant.Image))
        {
            BoxSize ??= Size.Is10;
            Rounded ??= Quark.Rounded.Sm;
            Overflow ??= Quark.Overflow.Hidden;
            return;
        }

        BackgroundColor ??= Quark.BackgroundColor.Transparent;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "item-media";
        attributes["data-variant"] = GetDataVariant(Variant);

        // shadcn/ui item-media base - exact copy from new-york-v4 ui/item.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group-has-[[data-slot=item-description]]/item:translate-y-0.5 group-has-[[data-slot=item-description]]/item:self-start [&_svg]:pointer-events-none");

            if (ReferenceEquals(Variant, ItemMediaVariant.Icon))
                AppendClass(ref cls, "[&_svg:not([class*='size-'])]:size-4");
            else if (ReferenceEquals(Variant, ItemMediaVariant.Image))
                AppendClass(ref cls, "[&_img]:size-full [&_img]:object-cover");
        });
    }

    private static string GetDataVariant(ItemMediaVariant? variant)
    {
        if (ReferenceEquals(variant, ItemMediaVariant.Icon))
            return "icon";

        if (ReferenceEquals(variant, ItemMediaVariant.Image))
            return "image";

        return "default";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
    }
}
