@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IItemMedia

<div @attributes="BuildAttributes()">@ChildContent</div>

@code {
    [Parameter]
    public ItemMediaVariant Variant { get; set; } = ItemMediaVariant.Default;

    private static string GetVariantClass(ItemMediaVariant? variant)
        => (variant?.Value ?? ItemMediaVariant.DefaultValue) switch
        {
            ItemMediaVariant.IconValue => "size-8 rounded-sm border bg-muted [&_svg:not([class*='size-'])]:size-4",
            ItemMediaVariant.ImageValue => "size-10 rounded-sm overflow-hidden [&_img]:size-full [&_img]:object-cover",
            _ => "bg-transparent"
        };

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "item-media";
        attributes["data-variant"] = Variant?.Value ?? ItemMediaVariant.Default.Value;

        // shadcn/ui item-media base - exact copy from new-york-v4 ui/item.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "shrink-0 group-has-[[data-slot=item-description]]/item:translate-y-0.5 group-has-[[data-slot=item-description]]/item:self-start [&_svg]:pointer-events-none");
            AppendClass(ref cls, GetVariantClass(Variant));
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
    }
}
