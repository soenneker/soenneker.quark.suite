@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IItem

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <div @attributes="BuildAttributes()">@ChildContent</div>
}

@code {
    [Parameter]
    public ItemVariant Variant { get; set; } = ItemVariant.Default;

    [Parameter]
    public ItemSize Size { get; set; } = ItemSize.Default;

    [Parameter]
    public bool AsChild { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        FlexWrap ??= Quark.FlexWrap.Wrap;
        ItemsAlign ??= Items.Center;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        TextSize ??= Quark.TextSize.Sm;
        Transition ??= Quark.Transition.Colors;
        OutlineStyle ??= Quark.OutlineStyle.None;

        ApplyVariantDefaults();
        ApplySizeDefaults();

    }

    private void ApplyVariantDefaults()
    {
        if (ReferenceEquals(Variant, ItemVariant.Outline))
        {
            BorderColor ??= Quark.BorderColor.Border;
            return;
        }

        if (ReferenceEquals(Variant, ItemVariant.Muted))
        {
            BorderColor ??= Quark.BorderColor.Transparent;
            BackgroundColor ??= Quark.BackgroundColor.Token("muted/50");
            return;
        }

        BorderColor ??= Quark.BorderColor.Transparent;
        BackgroundColor ??= Quark.BackgroundColor.Transparent;
    }

    private void ApplySizeDefaults()
    {
        Gap = null;
        Padding = null;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "item";
        attributes["data-variant"] = GetDataVariant(Variant);
        attributes["data-size"] = GetDataSize(Size);

        // shadcn/ui item base - exact copy from new-york-v4 ui/item.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/item duration-100 focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 [a]:transition-colors [a]:hover:bg-muted");

            if (ReferenceEquals(Size, ItemSize.ExtraSmall))
                AppendClass(ref cls, "gap-2 px-2.5 py-2 in-data-[slot=dropdown-menu-content]:p-0");
            else
                AppendClass(ref cls, "gap-2.5 px-3 py-2.5");
        });
    }

    private static string GetDataVariant(ItemVariant? variant)
    {
        if (ReferenceEquals(variant, ItemVariant.Outline))
            return "outline";

        if (ReferenceEquals(variant, ItemVariant.Muted))
            return "muted";

        return "default";
    }

    private static string GetDataSize(ItemSize? size)
    {
        if (ReferenceEquals(size, ItemSize.Small) || ReferenceEquals(size, ItemSize.ExtraSmall))
            return "sm";

        return "default";
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(AsChild);
    }
}
