@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IItem

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildSlotAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <div @attributes="BuildAttributes()">@ChildContent</div>
}

@code {
    [Parameter]
    public ItemVariant Variant { get; set; } = ItemVariant.Default;

    [Parameter]
    public ItemSize Size { get; set; } = ItemSize.Default;

    [Parameter]
    public bool AsChild { get; set; }

    private static string GetVariantClass(ItemVariant? variant)
        => (variant?.Value ?? ItemVariant.DefaultValue) switch
        {
            ItemVariant.OutlineValue => "border-border",
            ItemVariant.MutedValue => "bg-muted/50",
            _ => "bg-transparent"
        };

    private static string GetSizeClass(ItemSize? size)
        => (size?.Value ?? ItemSize.DefaultValue) switch
        {
            ItemSize.ExtraSmallValue => "gap-2 px-2.5 py-2 in-data-[slot=dropdown-menu-content]:p-0",
            ItemSize.SmallValue => "gap-2.5 px-4 py-3",
            _ => "gap-4 p-4"
        };

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        FlexWrap ??= Quark.FlexWrap.Wrap;
        ItemsAlign ??= Items.Center;
        Rounded ??= Quark.Rounded.Md;
        Border ??= Quark.Border.Default;
        TextSize ??= Quark.TextSize.Sm;
        Transition ??= Quark.Transition.Colors;

        if (Variant == ItemVariant.Outline)
            BorderColor ??= Quark.BorderColor.Border;
        else
            BorderColor ??= Quark.BorderColor.Transparent;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "item";
        attributes["data-variant"] = Variant?.Value ?? ItemVariant.Default.Value;
        attributes["data-size"] = Size?.Value switch
        {
            ItemSize.ExtraSmallValue => "xs",
            ItemSize.SmallValue => "sm",
            _ => "default"
        };

        // shadcn/ui item base - exact copy from new-york-v4 ui/item.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/item duration-100 outline-none focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 [a]:transition-colors [a]:hover:bg-accent/50");
            AppendClass(ref cls, GetVariantClass(Variant));
            AppendClass(ref cls, GetSizeClass(Size));
        });
    }

    private IReadOnlyDictionary<string, object> BuildSlotAttributes()
    {
        return BuildAttributes();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(Size);
        hc.Add(AsChild);
    }
}
