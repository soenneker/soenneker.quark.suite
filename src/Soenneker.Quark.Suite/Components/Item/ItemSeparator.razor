@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IItemSeparator

<BradixSeparator Orientation="@BradixOrientation.Horizontal"
                 Decorative="true"
                 AdditionalAttributes="@SeparatorAttributes" />

@code {
    protected override void ApplyDefaultParameters()
    {
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");
        Shrink ??= Quark.Shrink.Is0;
        Height ??= Quark.Height.IsPx;
        Margin ??= Quark.Margin.Is0.OnY;
        Width ??= Quark.Width.IsFull;

        base.ApplyDefaultParameters();
    }

    private IReadOnlyDictionary<string, object> SeparatorAttributes => BuildSeparatorAttributes();

    private IReadOnlyDictionary<string, object> BuildSeparatorAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());
        attributes.Remove("data-orientation");
        return attributes;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "item-separator";
        attributes["data-orientation"] = "horizontal";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, string.Empty);
        });
    }
}
