@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IItemSeparator

<BradixSeparator Orientation="@Orientation.Horizontal"
                 Decorative="true"
                 AdditionalAttributes="@BuildAttributes()" />

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        BackgroundColor ??= Quark.BackgroundColor.Utility("bg-border");
        Shrink ??= Quark.Shrink.Is0;
        Height ??= Quark.Height.IsPx;
        Margin ??= Quark.Margin.Is0.OnY;
        Width ??= Quark.Width.IsFull;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "item-separator";
        attributes["data-orientation"] = "horizontal";
    }
}
