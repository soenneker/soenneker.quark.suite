@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<ol @attributes="BuildAttributes()">
    @ChildContent
</ol>

@code {
    [CascadingParameter(Name = "ParentBreadcrumb")]
    private Breadcrumb? ParentBreadcrumb { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        FlexWrap ??= Quark.FlexWrap.Wrap;
        ItemsAlign ??= Items.Center;
        Gap ??= Quark.Gap.Token("1.5");
        TextSize ??= Quark.TextSize.Sm;
        TextColor ??= Quark.TextColor.MutedForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "breadcrumb-list";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "break-words sm:gap-2.5");

            if (ParentBreadcrumb?.Large == true)
                AppendClass(ref cls, "text-base");

            if (ParentBreadcrumb?.Small == true)
                AppendClass(ref cls, "text-xs");
        });
    }
}
