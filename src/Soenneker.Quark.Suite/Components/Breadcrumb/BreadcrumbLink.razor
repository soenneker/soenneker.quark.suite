@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (AsChild)
{
    <CascadingValue Name="@SlotAttributes.Name" Value="BuildLinkAttributes()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else if (To.HasContent())
{
    <Anchor To="@To" @attributes="BuildLinkAttributes()">
        @ChildContent
    </Anchor>
}
else
{
    <a @attributes="BuildLinkAttributes()">
        @ChildContent
    </a>
}

@code {
    [Parameter]
    public string? To { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private Dictionary<string, object> BuildLinkAttributes()
    {
        var attributes = new Dictionary<string, object>();

        attributes["data-slot"] = "breadcrumb-link";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "transition-colors hover:text-foreground");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(To);
        hc.Add(AsChild);
    }
}
