@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IBreadcrumb

<CascadingValue Name="ParentBreadcrumb" Value="@this" IsFixed="true">
    <nav @attributes="BuildAttributes()">
        @if (Composed)
        {
            @ChildContent
        }
        else
        {
            <ol @attributes="BuildListAttributes()">
                @ChildContent
            </ol>
        }
    </nav>
</CascadingValue>

@code {
    // shadcn Breadcrumb - new-york-v4 ui/breadcrumb.tsx
    /// <summary>
    /// Gets or sets whether the breadcrumb should be displayed in large size.
    /// </summary>
    [Parameter]
    public bool Large { get; set; }

    /// <summary>
    /// Gets or sets whether the breadcrumb should be displayed in small size.
    /// </summary>
    [Parameter]
    public bool Small { get; set; }

    /// <summary>
    /// Gets or sets whether to show dividers between breadcrumb items.
    /// </summary>
    [Parameter]
    public bool Divider { get; set; }

    /// <summary>
    /// Gets or sets the text to use as divider between items.
    /// </summary>
    [Parameter]
    public string? DividerText { get; set; }

    /// <summary>
    /// Gets or sets custom content to render for each separator.
    /// </summary>
    [Parameter]
    public RenderFragment? SeparatorContent { get; set; }

    /// <summary>
    /// Gets or sets whether explicit breadcrumb primitives are being used.
    /// </summary>
    [Parameter]
    public bool Composed { get; set; } = true;

    /// <summary>HTML <c>dir</c> on the navigation root (e.g. <c>rtl</c>); matches shadcn RTL breadcrumb examples.</summary>
    [Parameter]
    public string? Dir { get; set; }

    private readonly List<BreadcrumbItem> _items = [];

    internal bool UseTextDivider => Divider || DividerText.HasContent();

    internal string ResolvedDividerText => DividerText.HasContent() ? DividerText! : "/";

    internal int RegisterItem(BreadcrumbItem item)
    {
        if (!_items.Contains(item))
            _items.Add(item);

        return _items.IndexOf(item);
    }

    internal void UnregisterItem(BreadcrumbItem item)
    {
        if (!_items.Remove(item))
            return;

        for (var i = 0; i < _items.Count; i++)
        {
            _items[i].SetIndex(i);
        }
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "breadcrumb";

        if (Dir.HasContent())
            attributes["dir"] = Dir!;

        BuildClassAttribute(attributes, (ref cls) =>
        {
        });

        if (!attributes.ContainsKey("aria-label"))
            attributes["aria-label"] = AriaLabel.HasContent() ? AriaLabel! : "breadcrumb";
    }

    private Dictionary<string, object> BuildListAttributes()
    {
        var attributes = new Dictionary<string, object>();

        attributes["data-slot"] = "breadcrumb-list";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "flex flex-wrap items-center gap-1.5 text-sm break-words text-muted-foreground sm:gap-2.5");
            if (Large)
                AppendClass(ref cls, "text-base");
            if (Small)
                AppendClass(ref cls, "text-xs");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Large);
        hc.Add(Small);
        hc.Add(Divider);
        hc.Add(DividerText);
        hc.Add(SeparatorContent);
        hc.Add(Composed);
        hc.Add(Dir);
        hc.Add(AriaLabel);
    }
}
