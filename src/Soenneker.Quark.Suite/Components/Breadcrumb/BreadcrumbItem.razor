@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IBreadcrumbItem

@if (To.HasContent() && !AsChild)
{
    <li @attributes="BuildListItemAttributes()">
        @if (ShowSeparator)
        {
            <span @attributes="BuildSeparatorAttributes()">
                @if (ParentBreadcrumb?.UseTextDivider == true)
                {
                    @ParentBreadcrumb.ResolvedDividerText
                }
                else if (ParentBreadcrumb?.SeparatorContent is not null)
                {
                    @ParentBreadcrumb.SeparatorContent
                }
                else
                {
                    <svg class="rtl:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6" />
                    </svg>
                }
            </span>
        }
        <Anchor To="@To" @attributes="BuildLinkAttributes()">
            @ChildContent
        </Anchor>
    </li>
}
else
{
    <li @attributes="BuildListItemAttributes()">
        @if (ShowSeparator)
        {
            <span @attributes="BuildSeparatorAttributes()">
                @if (ParentBreadcrumb?.UseTextDivider == true)
                {
                    @ParentBreadcrumb.ResolvedDividerText
                }
                else if (ParentBreadcrumb?.SeparatorContent is not null)
                {
                    @ParentBreadcrumb.SeparatorContent
                }
                else
                {
                    <svg class="rtl:rotate-180" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="m9 18 6-6-6-6" />
                    </svg>
                }
            </span>
        }
        @if (AsChild)
        {
            <CascadingValue Name="@SlotAttributes.Name" Value="BuildLinkAttributes()" IsFixed="false">
                @ChildContent
            </CascadingValue>
        }
        else if (Active)
        {
            <span @attributes="BuildPageAttributes()">
                @ChildContent
            </span>
        }
        else
        {
            @ChildContent
        }
    </li>
}

@code {
    [CascadingParameter(Name = "ParentBreadcrumb")]
    private Breadcrumb? ParentBreadcrumb { get; set; }

    private Breadcrumb? _registeredParentBreadcrumb;
    private int _index;

    private bool ShowSeparator => _index > 0;

    /// <summary>
    /// Gets or sets the URL to navigate to.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    /// <summary>
    /// Gets or sets whether the breadcrumb item is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    protected override void OnInitialized()
    {
        base.OnInitialized();

        RegisterWithParent();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (!ReferenceEquals(_registeredParentBreadcrumb, ParentBreadcrumb))
        {
            _registeredParentBreadcrumb?.UnregisterItem(this);
            RegisterWithParent();
        }
    }

    private void RegisterWithParent()
    {
        if (ParentBreadcrumb is null)
            return;

        _registeredParentBreadcrumb = ParentBreadcrumb;
        _index = ParentBreadcrumb.RegisterItem(this);
    }

    internal void SetIndex(int index)
    {
        if (_index == index)
            return;

        _index = index;
        _ = InvokeAsync(StateHasChanged);
    }

    private Dictionary<string, object> BuildListItemAttributes()
    {
        var attributes = new Dictionary<string, object>();

        attributes["data-slot"] = "breadcrumb-item";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-breadcrumb-item");
            AppendClass(ref cls, "inline-flex items-center gap-1.5");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildSeparatorAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "breadcrumb-separator",
            ["role"] = "presentation",
            ["aria-hidden"] = "true"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-breadcrumb-separator");
            AppendClass(ref cls, "[&>svg]:size-3.5");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildLinkAttributes()
    {
        var attributes = new Dictionary<string, object>();

        attributes["data-slot"] = "breadcrumb-link";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-breadcrumb-link");
            AppendClass(ref cls, "transition-colors hover:text-foreground");
        });

        if (Active)
            attributes["aria-current"] = "page";

        return attributes;
    }

    private Dictionary<string, object> BuildPageAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "breadcrumb-page",
            ["role"] = "link",
            ["aria-disabled"] = "true",
            ["aria-current"] = "page"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-breadcrumb-page");
            AppendClass(ref cls, "font-normal text-foreground");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(To);
        hc.Add(Active);
        hc.Add(AsChild);
        hc.Add(_index);
        hc.Add(ParentBreadcrumb?.UseTextDivider);
        hc.Add(ParentBreadcrumb?.ResolvedDividerText);
        hc.Add(ParentBreadcrumb?.SeparatorContent);
    }

    public override void Dispose()
    {
        _registeredParentBreadcrumb?.UnregisterItem(this);
        base.Dispose();
    }
}