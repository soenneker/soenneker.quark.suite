@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IBreadcrumbItem

@if (To.HasContent())
{
    <li @attributes="BuildListItemAttributes()">
        <Anchor To="@To" @attributes="BuildLinkAttributes()">
            @ChildContent
        </Anchor>
    </li>
}
else
{
    <li @attributes="BuildListItemAttributes()">
        @if (Active)
        {
            <span @attributes="BuildPageAttributes()">
                @ChildContent
            </span>
        }
        else
        {
            @ChildContent
        }
    </li>
}

@code {
    /// <summary>
    /// Gets or sets the URL to navigate to.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    /// <summary>
    /// Gets or sets whether the breadcrumb item is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    private Dictionary<string, object> BuildListItemAttributes()
    {
        var attributes = new Dictionary<string, object>();

        attributes["data-slot"] = "breadcrumb-item";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-breadcrumb-item");
            AppendClass(ref cls, "inline-flex items-center gap-1.5");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildLinkAttributes()
    {
        var attributes = new Dictionary<string, object>();

        attributes["data-slot"] = "breadcrumb-link";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-breadcrumb-link");
            AppendClass(ref cls, "transition-colors hover:text-foreground");
        });

        if (Active)
            attributes["aria-current"] = "page";

        return attributes;
    }

    private Dictionary<string, object> BuildPageAttributes()
    {
        var attributes = new Dictionary<string, object>
        {
            ["data-slot"] = "breadcrumb-page",
            ["role"] = "link",
            ["aria-disabled"] = "true",
            ["aria-current"] = "page"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-breadcrumb-page");
            AppendClass(ref cls, "font-normal text-foreground");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(To);
        hc.Add(Active);
    }
}