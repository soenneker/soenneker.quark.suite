@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAccordionContent
@using Microsoft.AspNetCore.Components.Web

@if (ContentMounted)
{
    <div @onkeydown="HandleContentKeyDown"
         @onkeydown:preventDefault="_contentEscapePreventDefault"
         @onkeydown:stopPropagation="_contentEscapeStopPropagation"
         @attributes="BuildAttributes()">
        <div @attributes="BuildInnerAttributes()">
            <div @attributes="BuildContentAttributes()">
                @ChildContent
            </div>
        </div>
    </div>
}

@code {
    private bool _contentEscapePreventDefault;
    private bool _contentEscapeStopPropagation;

    [CascadingParameter(Name = nameof(ParentAccordionItem))]
    public AccordionItem? ParentAccordionItem { get; set; }

    /// <summary>When <c>true</c> (default), Escape closes the panel when allowed (Radix/shadcn; focus may be inside the region).</summary>
    [Parameter]
    public bool CloseOnEscape { get; set; } = true;

    /// <summary>When <c>true</c> (default), after Escape closes the panel, focus returns to the trigger.</summary>
    [Parameter]
    public bool RestoreFocusToTriggerOnEscape { get; set; } = true;

    private bool IsOpen => ParentAccordionItem?.IsOpen == true;

    private bool ContentMounted => (ParentAccordionItem?.ForceMount ?? true) || IsOpen;

    private async Task HandleContentKeyDown(KeyboardEventArgs e)
    {
        _contentEscapePreventDefault = false;
        _contentEscapeStopPropagation = false;

        if (!CloseOnEscape || e.Key != "Escape" || ParentAccordionItem is null)
            return;

        var parent = ParentAccordionItem.ParentAccordion;
        if (parent is null || parent.Disabled || ParentAccordionItem.Disabled || !IsOpen)
            return;

        if (!parent.CanEscapeClose(ParentAccordionItem.ResolvedValue))
            return;

        _contentEscapePreventDefault = true;
        _contentEscapeStopPropagation = true;
        await parent.RequestCloseFromContentEscapeAsync(ParentAccordionItem.ResolvedValue, RestoreFocusToTriggerOnEscape);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "accordion-content";
        attributes["data-orientation"] = ParentAccordionItem?.ParentAccordion?.Orientation?.Value ?? AccordionOrientation.Vertical.Value;
        attributes["data-state"] = IsOpen ? "open" : "closed";
        attributes["role"] = "region";
        attributes["aria-hidden"] = IsOpen ? "false" : "true";

        if (!IsOpen)
            attributes["inert"] = true;

        if (ParentAccordionItem is not null)
        {
            attributes["id"] = ParentAccordionItem.ContentId;
            attributes["aria-labelledby"] = ParentAccordionItem.TriggerId;

            if (ParentAccordionItem.Disabled || ParentAccordionItem.ParentAccordion?.Disabled == true)
                attributes["data-disabled"] = "true";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-accordion-content");
            AppendClass(ref cls, "grid overflow-hidden grid-rows-[0fr] transition-[grid-template-rows] duration-200 ease-out");
            AppendClass(ref cls, "data-[state=open]:grid-rows-[1fr]");
        });
    }

    private Dictionary<string, object> BuildInnerAttributes()
    {
        var attributes = new Dictionary<string, object>();

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "min-h-0 overflow-hidden");
        });

        return attributes;
    }

    private Dictionary<string, object> BuildContentAttributes()
    {
        var attributes = new Dictionary<string, object>();

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "pt-0 pb-4 text-sm");
        });

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(IsOpen);
        hc.Add(ParentAccordionItem?.ForceMount == true);
        hc.Add(ParentAccordionItem?.ParentAccordion?.Orientation);
        hc.Add(ParentAccordionItem?.ParentAccordion?.Disabled == true);
        hc.Add(ParentAccordionItem?.Disabled == true);
        hc.Add(CloseOnEscape);
        hc.Add(RestoreFocusToTriggerOnEscape);
    }
}