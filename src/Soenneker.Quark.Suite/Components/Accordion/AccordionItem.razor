@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element
@implements IAccordionItem

<CascadingValue Name="ParentAccordionItem" Value="this">
    <BradixAccordionItem Value="@ResolvedValue"
                         Disabled="@Disabled"
                         AdditionalAttributes="@ItemAttributes">
        @ChildContent
    </BradixAccordionItem>
</CascadingValue>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>When <c>false</c>, panel markup is not rendered while closed. The trigger omits <c>aria-controls</c> while unmounted.</summary>
    [Parameter]
    public bool ForceMount { get; set; } = true;

    private string? _generatedValue;

    internal string ResolvedValue => Value.HasContent() ? Value! : _generatedValue ??= BlazorIdGenerator.New("quark-accordion-item");

    private IReadOnlyDictionary<string, object> ItemAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes())
            {
                ["data-slot"] = "accordion-item"
            };

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "q-accordion-item");
                AppendClass(ref cls, "border-b last:border-b-0");
            });

            return attributes;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(ForceMount);
    }
}
