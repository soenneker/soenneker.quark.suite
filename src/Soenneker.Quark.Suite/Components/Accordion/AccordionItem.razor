@namespace Soenneker.Quark
@using Soenneker.Blazor.Utils.Ids
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element
@implements IAccordionItem

<CascadingValue Name="ParentAccordionItem" Value="this">
    <BradixAccordionItem Value="@ResolvedValue"
                         Disabled="@Disabled"
                         AdditionalAttributes="@ItemAttributes">
        @ChildContent
    </BradixAccordionItem>
</CascadingValue>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>When <c>false</c>, closed panel markup is not rendered. When <c>true</c>, the panel stays mounted and reports its closed state through data attributes.</summary>
    [Parameter]
    public bool ForceMount { get; set; }

    private string? _generatedValue;

    internal string ResolvedValue => Value.HasContent() ? Value! : _generatedValue ??= BlazorIdGenerator.New("quark-accordion-item");

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

    }

    private IReadOnlyDictionary<string, object> ItemAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes())
            {
                ["data-slot"] = "accordion-item"
            };

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "not-last:border-b");
            });

            return attributes;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(ForceMount);
    }
}
