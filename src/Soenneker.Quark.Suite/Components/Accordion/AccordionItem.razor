@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAccordionItem

<CascadingValue Name="ParentAccordionItem" Value="this">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>When <c>false</c>, panel markup is not rendered while closed. The trigger omits <c>aria-controls</c> while unmounted.</summary>
    [Parameter]
    public bool ForceMount { get; set; } = true;

    [CascadingParameter(Name = nameof(ParentAccordion))]
    public Accordion? ParentAccordion { get; set; }

    private string? _generatedValue;

    internal string ResolvedValue => Value.HasContent() ? Value! : _generatedValue ??= $"accordion-item-{Guid.NewGuid():N}";

    internal string TriggerId => $"{ResolvedValue}-trigger";

    internal string ContentId => $"{ResolvedValue}-content";

    internal bool IsOpen => ParentAccordion?.IsItemOpen(ResolvedValue) == true;

    internal async Task Toggle()
    {
        if (ParentAccordion is null || ParentAccordion.Disabled || Disabled)
            return;

        await ParentAccordion.ToggleItem(ResolvedValue);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "accordion-item";
        attributes["data-orientation"] = ParentAccordion?.Orientation?.Value ?? AccordionOrientation.Vertical.Value;
        attributes["data-state"] = IsOpen ? "open" : "closed";

        var effectiveDisabled = Disabled || ParentAccordion?.Disabled == true;
        if (effectiveDisabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-accordion-item");
            AppendClass(ref cls, "border-b last:border-b-0");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Value);
        hc.Add(Disabled);
        hc.Add(ForceMount);
        hc.Add(ParentAccordion?.Disabled == true);
        hc.Add(IsOpen);
    }
}
