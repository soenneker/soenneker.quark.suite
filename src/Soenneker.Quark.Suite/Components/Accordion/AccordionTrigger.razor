@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.TriggerElement
@implements IAccordionTrigger

<BradixAccordionHeader @attributes="HeaderAttributes">
    <BradixAccordionTrigger OnClick="@OnClick"
                            OnKeyDown="@OnKeyDown"
                            @attributes="TriggerAttributes">
        @ChildContent
        @if (ShowChevron)
        {
            <Icon Name="LucideIcon.ChevronDown"
                  data-slot="accordion-trigger-icon"
                  Class="pointer-events-none ms-auto size-4 shrink-0 text-muted-foreground transition-transform duration-200 ease-out motion-reduce:transition-none group-aria-expanded/accordion-trigger:rotate-180" />
        }
    </BradixAccordionTrigger>
</BradixAccordionHeader>

@code {
    [Parameter]
    public bool ShowChevron { get; set; } = true;

    [CascadingParameter(Name = nameof(ParentAccordionItem))]
    public AccordionItem? ParentAccordionItem { get; set; }

    private IReadOnlyDictionary<string, object> HeaderAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new()
            {
                ["data-slot"] = "accordion-header"
            };

            if (Disabled)
                attributes["data-disabled"] = "true";

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "q-accordion-header flex w-full");
            });

            return attributes;
        }
    }

    private IReadOnlyDictionary<string, object> TriggerAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes())
            {
                ["data-slot"] = "accordion-trigger"
            };

            attributes.Remove("onkeydown");

            if (Disabled)
            {
                attributes["disabled"] = true;
                attributes["data-disabled"] = "true";
            }

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "q-accordion-trigger");
                AppendClass(ref cls, "group/accordion-trigger relative flex w-full flex-1 items-start justify-between gap-4 rounded-lg border border-transparent py-2.5 text-start text-sm font-medium transition-all outline-none hover:underline focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 focus-visible:after:border-ring disabled:pointer-events-none disabled:opacity-50");
            });

            return attributes;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ShowChevron);
        hc.Add(Disabled);
        hc.Add(ParentAccordionItem?.ForceMount == true);
    }
}
