@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.TriggerElement
@implements IAccordionTrigger

<BradixAccordionHeader @attributes="HeaderAttributes">
    <BradixAccordionTrigger OnClick="@OnClick" OnKeyDown="@OnKeyDown" @attributes="TriggerAttributes">
        @ChildContent
        @if (ShowChevron)
        {
            <Icon Name="LucideIcon.ChevronDown" data-slot="accordion-trigger-icon" Size="Quark.Size.Is4" Shrink="Quark.Shrink.Is0" TextColor="Quark.TextColor.MutedForeground" PointerEvents="Quark.PointerEvents.None" Transition="Quark.Transition.Transform" Class="group-aria-expanded/accordion-trigger:rotate-180"/>
        }
    </BradixAccordionTrigger>
</BradixAccordionHeader>

@code {

    [Parameter]
    public bool ShowChevron { get; set; } = true;

    [CascadingParameter(Name = nameof(ParentAccordionItem))]
    public AccordionItem? ParentAccordionItem { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.Flex;
        Flex ??= Quark.Flex.Is1;
        ItemsAlign ??= Items.Start;
        Justify ??= Quark.Justify.Between;
        Rounded ??= Quark.Rounded.Lg;
        TextAlign ??= "text-left";
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
        Position ??= Quark.Position.Relative;
        Padding ??= Quark.Padding.OnY.Token("2.5");
        Border ??= Quark.Border.Default;
        BorderColor ??= Quark.BorderColor.Transparent.OnFocusVisible.Ring;
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        Cursor ??= Quark.Cursor.Pointer.OnDisabled.NotAllowed;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }

    private IReadOnlyDictionary<string, object> HeaderAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new()
            {
                ["data-slot"] = "accordion-header",
                ["class"] = "flex"
            };

            if (Disabled)
                attributes["data-disabled"] = "true";

            return attributes;
        }
    }

    private IReadOnlyDictionary<string, object> TriggerAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes())
            {
                ["data-slot"] = "accordion-trigger"
            };

            attributes.Remove("onkeydown");

            if (Disabled)
            {
                attributes["disabled"] = true;
                attributes["data-disabled"] = "true";
            }

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "group/accordion-trigger hover:underline");
                AppendClass(ref cls, "focus-visible:ring-3 focus-visible:after:border-ring");
                AppendClass(ref cls, "**:data-[slot=accordion-trigger-icon]:ml-auto **:data-[slot=accordion-trigger-icon]:size-4 **:data-[slot=accordion-trigger-icon]:text-muted-foreground");
            });

            return attributes;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(ShowChevron);
        hc.Add(Disabled);
        hc.Add(ParentAccordionItem?.ForceMount == true);
    }

}
