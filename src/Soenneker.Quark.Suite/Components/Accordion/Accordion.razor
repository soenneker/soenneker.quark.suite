@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAccordion

<CascadingValue Name="ParentAccordion" Value="this">
    <div @attributes="BuildAttributes()">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public bool Multiple { get; set; }

    [Parameter]
    public bool Collapsible { get; set; }

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? Values { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> ValuesChanged { get; set; }

    private readonly HashSet<string> _openValues = [];
    private readonly HashSet<string> _internalValues = [];
    private readonly List<AccordionTrigger> _triggers = [];
    private string? _internalValue;

    private bool IsSingleControlled => ValueChanged.HasDelegate || Value is not null;
    private bool IsMultipleControlled => ValuesChanged.HasDelegate || Values is not null;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        _openValues.Clear();

        if (Multiple)
        {
            var values = IsMultipleControlled ? Values : _internalValues;

            if (values is not null)
            {
                foreach (var value in values)
                {
                    if (value.HasContent())
                        _openValues.Add(value);
                }
            }

            return;
        }

        var singleValue = IsSingleControlled ? Value : _internalValue;

        if (singleValue.HasContent())
            _openValues.Add(singleValue!);
    }

    internal bool IsItemOpen(string value)
    {
        return _openValues.Contains(value);
    }

    internal async Task ToggleItem(string value)
    {
        if (!value.HasContent())
            return;

        if (Multiple)
        {
            var nextValues = new HashSet<string>(_openValues, StringComparer.Ordinal);

            if (nextValues.Contains(value))
            {
                if (!Collapsible && nextValues.Count == 1)
                    return;

                nextValues.Remove(value);
            }
            else
            {
                nextValues.Add(value);
            }

            _openValues.Clear();

            foreach (var openValue in nextValues)
            {
                _openValues.Add(openValue);
            }

            if (!IsMultipleControlled)
            {
                _internalValues.Clear();

                foreach (var openValue in nextValues)
                {
                    _internalValues.Add(openValue);
                }
            }

            if (ValuesChanged.HasDelegate)
                await ValuesChanged.InvokeAsync(nextValues.ToArray());
        }
        else
        {
            var isOpen = _openValues.Contains(value);

            if (isOpen && !Collapsible)
                return;

            var nextValue = isOpen ? null : value;

            _openValues.Clear();

            if (nextValue.HasContent())
                _openValues.Add(nextValue!);

            if (!IsSingleControlled)
                _internalValue = nextValue;

            if (ValueChanged.HasDelegate)
                await ValueChanged.InvokeAsync(nextValue);
        }

        await InvokeAsync(StateHasChanged);
    }

    internal void RegisterTrigger(AccordionTrigger trigger)
    {
        if (!_triggers.Contains(trigger))
            _triggers.Add(trigger);
    }

    internal void UnregisterTrigger(AccordionTrigger trigger)
    {
        _triggers.Remove(trigger);
    }

    internal void HandleKeyNavigation(string currentValue, string key)
    {
        if (_triggers.Count == 0)
            return;

        var currentIndex = _triggers.FindIndex(trigger => string.Equals(trigger.Value, currentValue, StringComparison.Ordinal));

        if (currentIndex < 0)
            return;

        var nextIndex = key switch
        {
            "ArrowDown" => GetNextEnabledTriggerIndex(currentIndex),
            "ArrowUp" => GetPreviousEnabledTriggerIndex(currentIndex),
            "Home" => GetFirstEnabledTriggerIndex(),
            "End" => GetLastEnabledTriggerIndex(),
            _ => -1
        };

        if (nextIndex >= 0 && nextIndex != currentIndex)
            _ = _triggers[nextIndex].FocusAsync();
    }

    private int GetNextEnabledTriggerIndex(int currentIndex)
    {
        for (var i = currentIndex + 1; i < _triggers.Count; i++)
        {
            if (!_triggers[i].IsDisabled)
                return i;
        }

        return GetFirstEnabledTriggerIndex();
    }

    private int GetPreviousEnabledTriggerIndex(int currentIndex)
    {
        for (var i = currentIndex - 1; i >= 0; i--)
        {
            if (!_triggers[i].IsDisabled)
                return i;
        }

        return GetLastEnabledTriggerIndex();
    }

    private int GetFirstEnabledTriggerIndex()
    {
        for (var i = 0; i < _triggers.Count; i++)
        {
            if (!_triggers[i].IsDisabled)
                return i;
        }

        return -1;
    }

    private int GetLastEnabledTriggerIndex()
    {
        for (var i = _triggers.Count - 1; i >= 0; i--)
        {
            if (!_triggers[i].IsDisabled)
                return i;
        }

        return -1;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "accordion";
        attributes["data-orientation"] = "vertical";
        attributes["data-multiple"] = Multiple ? "true" : "false";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-accordion flex w-full flex-col");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Multiple);
        hc.Add(Collapsible);
        hc.Add(Value);
        hc.Add(_internalValue);
        hc.Add(Values?.Count);

        foreach (var openValue in _openValues.OrderBy(static x => x))
        {
            hc.Add(openValue);
        }

        foreach (var internalOpenValue in _internalValues.OrderBy(static x => x))
        {
            hc.Add(internalOpenValue);
        }
    }
}