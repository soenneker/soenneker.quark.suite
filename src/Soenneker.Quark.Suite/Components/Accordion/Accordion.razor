@namespace Soenneker.Quark
@using Soenneker.Bradix
@inherits Soenneker.Quark.Element
@implements IAccordion

<BradixAccordion Type="@ResolvedType"
                 Collapsible="@Collapsible"
                 Disabled="@Disabled"
                 Orientation="@Orientation"
                 Value="@Value"
                 DefaultValue="@DefaultValue"
                 ValueChanged="@ValueChanged"
                 Values="@Values"
                 DefaultValues="@DefaultValues"
                 ValuesChanged="@ValuesChanged"
                 AdditionalAttributes="@RootAttributes">
    @ChildContent
</BradixAccordion>

@code {
    [Parameter]
    public bool Multiple { get; set; }

    [Parameter]
    public BradixSelectionMode Type { get; set; }

    [Parameter]
    public bool Collapsible { get; set; }

    /// <summary>Radix: disables the entire accordion (no toggles, no roving keyboard on the root).</summary>
    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>Radix/shadcn: <c>vertical</c> (ArrowUp/ArrowDown) or <c>horizontal</c> (ArrowLeft/ArrowRight, mirrored in RTL).</summary>
    [Parameter]
    public BradixOrientation Orientation { get; set; } = BradixOrientation.Vertical;

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public string? DefaultValue { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? Values { get; set; }

    [Parameter]
    public IReadOnlyCollection<string>? DefaultValues { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyCollection<string>> ValuesChanged { get; set; }

    private BradixSelectionMode ResolvedType => Type ?? (Multiple ? BradixSelectionMode.Multiple : BradixSelectionMode.Single);

    private IReadOnlyDictionary<string, object> RootAttributes
    {
        get
        {
            Dictionary<string, object> attributes = new(BuildAttributes())
            {
                ["data-slot"] = "accordion",
                ["data-multiple"] = ResolvedType == BradixSelectionMode.Multiple ? "true" : "false"
            };

            BuildClassAttribute(attributes, (ref cls) =>
            {
                AppendClass(ref cls, "q-accordion");
                AppendClass(ref cls, "flex w-full flex-col");
            });

            return attributes;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Type);
        hc.Add(Multiple);
        hc.Add(Collapsible);
        hc.Add(Disabled);
        hc.Add(Orientation);
        hc.Add(Value);
        hc.Add(DefaultValue);
        hc.Add(Values?.Count);
        hc.Add(DefaultValues?.Count);

        if (Values is not null)
        {
            foreach (var item in Values)
            {
                hc.Add(item);
            }
        }

        if (DefaultValues is not null)
        {
            foreach (var item in DefaultValues)
            {
                hc.Add(item);
            }
        }
    }
}
