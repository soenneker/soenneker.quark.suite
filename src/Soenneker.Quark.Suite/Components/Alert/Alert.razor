@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAlert

<CascadingValue Name="ParentAlert" Value="@this" IsFixed>
    <div @attributes="BuildAttributes()">
        @if (AlertIcon is not null)
        {
            @AlertIcon
        }
        else if (ShowDefaultIcon)
        {
            <Icon Name="@GetDefaultIcon()" Class="size-4 shrink-0 translate-y-0.5" />
        }
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public AlertVariant Variant { get; set; } = AlertVariant.Default;

    /// <summary>
    /// Gets or sets whether to show a thick left accent border in the variant's color.
    /// </summary>
    [Parameter]
    public bool AccentBorder { get; set; }

    /// <summary>
    /// Gets or sets an optional icon to display in the alert (e.g. SVG or icon component).
    /// </summary>
    [Parameter]
    public RenderFragment? AlertIcon { get; set; }

    /// <summary>
    /// Gets or sets whether to show the default icon for the variant when AlertIcon is null.
    /// </summary>
    [Parameter]
    public bool ShowDefaultIcon { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Grid;
        AlignUtility ??= Quark.Align.ItemsStart;
        Position ??= Quark.Position.Relative;
        Width ??= Quark.Width.IsFull;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Is1;
        Padding ??= Quark.Padding.Is3.OnY.Is4.OnX;
        TextSize ??= Quark.TextSize.Sm;

        if (Variant == AlertVariant.Default)
        {
            BackgroundColor ??= Quark.BackgroundColor.Card;
            TextColor ??= Quark.TextColor.CardForeground;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "alert";
        attributes["role"] = "alert";

        // Build alert classes (and any alert-specific style) during attribute construction.
        BuildClassAndStyleAttributes(attributes, (ref cls, ref sty) =>
        {
            AppendClass(ref cls, "grid grid-cols-[0_1fr] items-start gap-y-0.5 has-[svg]:grid-cols-[calc(var(--spacing)*4)_1fr] has-[svg]:gap-x-3 [&>svg]:size-4 [&>svg]:translate-y-0.5 [&>svg]:text-current");

            if (IsDestructiveVariant())
                AppendClass(ref cls, "text-destructive bg-card [&>svg]:text-current *:data-[slot=alert-description]:text-destructive/90");
            else if (Variant != AlertVariant.Default)
                AppendClass(ref cls, AlertVariantClasses.GetVariantClasses(Variant, AccentBorder));

            ApplyAlertBackgroundColor(ref sty, ref cls);
        });
    }

    protected override void ApplyBackgroundColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls)
    {
    }

    protected override void ApplyTextColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls, CssValue<TextColorBuilder>? value)
    {
        if (Variant != AlertVariant.Default)
            return;

        base.ApplyTextColor(ref sty, ref cls, value);
    }

    protected virtual void ApplyAlertBackgroundColor(ref PooledStringBuilder sty, ref PooledStringBuilder cls)
    {
        if (BackgroundColor is null || BackgroundColor.Value.IsEmpty)
            return;

        var v = BackgroundColor.Value.ToString();
        if (v.Length == 0)
            return;

        string? token = null;
        if (BackgroundColor.Value.TryGetThemeToken(out token) && token is not null)
        {
            if (token.Equals("danger", StringComparison.OrdinalIgnoreCase))
                AppendClass(ref cls, "text-destructive bg-card [&>svg]:text-current *:data-[slot=alert-description]:text-destructive/90");
            return;
        }

        if (BackgroundColor.Value.IsCssClass && v.StartsWith("alert-", StringComparison.Ordinal))
        {
            var sub = v.Length > 6 ? v.Substring(6) : null;
            if (sub is not null && sub.Equals("danger", StringComparison.OrdinalIgnoreCase))
                AppendClass(ref cls, "text-destructive bg-card [&>svg]:text-current *:data-[slot=alert-description]:text-destructive/90");
            return;
        }

        AppendStyleDecl(ref sty, "border-color: ");
        sty.Append(v);
        AppendStyleDecl(ref sty, "color: white");
    }

    private LucideIcon GetDefaultIcon() => Variant?.Value switch
    {
        AlertVariant.DestructiveValue => LucideIcon.CircleX,
        "danger" => LucideIcon.CircleX,
        _ => LucideIcon.Info
    };

    private bool IsDestructiveVariant() =>
        Variant?.Value is AlertVariant.DestructiveValue or "danger";

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(AccentBorder);
        hc.Add(AlertIcon != null);
        hc.Add(ShowDefaultIcon);
    }
}
