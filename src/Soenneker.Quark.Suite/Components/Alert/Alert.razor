@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAlert

<CascadingValue Name="ParentAlert" Value="@this" IsFixed>
    <div @attributes="BuildAttributes()">
        @if (AlertIcon is not null)
        {
            @AlertIcon
        }
        else if (ShowDefaultIcon)
        {
            <Icon Name="@GetDefaultIcon()" Size="Quark.Size.Is4" Shrink="Quark.Shrink.Is0" Class="translate-y-0.5" />
        }
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter]
    public AlertVariant Variant { get; set; } = AlertVariant.Default;

    /// <summary>
    /// Legacy alert accent option retained for source compatibility. shadcn Alert only supports default and destructive variants.
    /// </summary>
    [Parameter]
    public bool AccentBorder { get; set; }

    /// <summary>
    /// Gets or sets an optional icon to display in the alert (e.g. SVG or icon component).
    /// </summary>
    [Parameter]
    public RenderFragment? AlertIcon { get; set; }

    /// <summary>
    /// Gets or sets whether to show the default icon for the variant when AlertIcon is null.
    /// </summary>
    [Parameter]
    public bool ShowDefaultIcon { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "alert";
        Position ??= Quark.Position.Relative;
        Display ??= Quark.Display.Grid;
        Width ??= Quark.Width.IsFull;
        Gap ??= Quark.Gap.Is0_5;
        Rounded ??= Quark.Rounded.Lg;
        Border ??= Quark.Border.Default;
        Padding ??= Quark.Padding.OnX.Is2_5.OnY.Is2;
        TextAlign ??= Quark.TextAlign.Start;
        TextSize ??= Quark.TextSize.Sm;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["role"] = "alert";

        // Build alert classes (and any alert-specific style) during attribute construction.
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/alert");
            AppendClass(ref cls, "has-data-[slot=alert-action]:relative has-data-[slot=alert-action]:pr-18");
            AppendClass(ref cls, "has-[>svg]:grid-cols-[auto_1fr] has-[>svg]:gap-x-2");
            AppendClass(ref cls, "*:[svg]:row-span-2 *:[svg]:translate-y-0.5 *:[svg:not([class*='size-'])]:size-4");

            if (IsDestructiveVariant())
            {
                AppendClass(ref cls, "bg-card");
                AppendClass(ref cls, "text-destructive");
                AppendClass(ref cls, "*:data-[slot=alert-description]:text-destructive/90 *:[svg]:text-current");
            }
            else
            {
                AppendClass(ref cls, "bg-card");
                AppendClass(ref cls, "text-card-foreground");
                AppendClass(ref cls, "*:[svg]:text-current");
            }
        });
    }

    private LucideIcon GetDefaultIcon()
    {
        if (IsDestructiveVariant())
            return LucideIcon.CircleX;

        return LucideIcon.Info;
    }

    private bool IsDestructiveVariant() =>
        ReferenceEquals(Variant, AlertVariant.Destructive) || string.Equals(Variant?.Value, "danger", StringComparison.Ordinal);

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Variant);
        hc.Add(AccentBorder);
        hc.Add(AlertIcon != null);
        hc.Add(ShowDefaultIcon);
    }
}
