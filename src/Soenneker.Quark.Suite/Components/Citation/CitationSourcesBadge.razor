@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (ParentCitation is not null)
{
    <div @attributes="BuildAttributes()">
        @if (ShowFavicons)
        {
            <Div DataSlot="citation-favicon-group"
                 Display="Quark.Display.Flex"
                 Space='Quark.Space.X.Token("-2")'
                 Class="*:data-[slot=citation-favicon]:ring-2 *:data-[slot=citation-favicon]:ring-secondary">
                @foreach (var citation in ParentCitation.ResolvedCitations.Take(3))
                {
                    <CitationFavicon Source="@citation" />
                }
            </Div>
        }
        <Span TextSize="Quark.TextSize.Xs" Leading='Quark.Leading.Is4_5' FontWeight="Quark.FontWeight.Normal" TextColor="Quark.TextColor.Primary">@(Label ?? $"{ParentCitation.ResolvedCitations.Count} {(ParentCitation.ResolvedCitations.Count == 1 ? "source" : "sources")}")</Span>
    </div>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public bool ShowFavicons { get; set; } = true;

    [Parameter]
    public string? Label { get; set; }

    private CssValue<PaddingBuilder> SourcesBadgePadding =>
        ShowFavicons
            ? Quark.Padding.FromRight.Is2.FromLeft.Is1
            : Quark.Padding.OnX.Is2;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "citation-sources-badge";

        Margin ??= Quark.Margin.FromTop.Is0;
        Display ??= Quark.Display.Flex;
        Height ??= Quark.Height.Is6;
        Width ??= Quark.Width.IsFit;
        ItemsAlign ??= Quark.Items.Center;
        Gap ??= Quark.Gap.Is1_5;
        Rounded ??= Quark.Rounded.Full;
        BackgroundColor ??= Quark.BackgroundColor.Secondary;
        Padding ??= SourcesBadgePadding;
    }
}
