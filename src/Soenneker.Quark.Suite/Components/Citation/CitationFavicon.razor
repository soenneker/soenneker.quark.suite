@namespace Soenneker.Quark
@inherits Soenneker.Quark.Component

@if (!string.IsNullOrWhiteSpace(ResolvedSource?.FaviconSrc))
{
    <Image Source="@ResolvedSource.FaviconSrc"
           Alt=""
           Attributes="@BuildAttributes()" />
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public ResolvedCitation? Source { get; set; }

    private ResolvedCitation? ResolvedSource => Source ?? ParentCitation?.ActiveCitation;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Size ??= Quark.Size.Is4;
        Shrink ??= Quark.Shrink.Is0;
        Rounded ??= Quark.Rounded.Full;
        BackgroundColor ??= Quark.BackgroundColor.Background;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        SetDefaultDataSlot("citation-favicon");
    }
}
