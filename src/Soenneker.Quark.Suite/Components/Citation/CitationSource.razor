@namespace Soenneker.Quark

@if (ResolvedSource is not null)
{
    <Div Attributes="@BuildAttributes()">
        <CitationFavicon Source="@ResolvedSource" />
        <CitationSiteName Source="@ResolvedSource" />
    </Div>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public ResolvedCitation? Source { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private ResolvedCitation? ResolvedSource => Source ?? ParentCitation?.ActiveCitation;

    private IReadOnlyDictionary<string, object> BuildAttributes() => new Dictionary<string, object>
    {
        ["data-slot"] = "citation-source",
        ["class"] = string.Join(" ", new[] { "mt-2 flex items-center gap-1.5", Class }.Where(x => !string.IsNullOrWhiteSpace(x)))
    };
}
