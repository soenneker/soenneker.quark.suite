@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (ResolvedSource is not null)
{
    <div @attributes="BuildAttributes()">
        <CitationFavicon Source="@ResolvedSource" />
        <CitationSiteName Source="@ResolvedSource" />
    </div>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public ResolvedCitation? Source { get; set; }

    private ResolvedCitation? ResolvedSource => Source ?? ParentCitation?.ActiveCitation;

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "citation-source";

        Margin ??= Quark.Margin.FromTop.Is2;
        Display ??= Quark.Display.Flex;
        ItemsAlign ??= Quark.Items.Center;
        Gap ??= Quark.Gap.Is1_5;
    }
}