@namespace Soenneker.Quark
@inherits Soenneker.Quark.Component

@if (Citation is not null)
{
    <Anchor Href="@Citation.Url" Target="Quark.Target.Blank" rel="noreferrer" Display="Quark.Display.Flex" Width="Quark.Width.IsFull" FlexDirection="Quark.FlexDirection.Col" Gap="Quark.Gap.Is1" Padding="Quark.Padding.Is3" TextAlign="Quark.TextAlign.Start" DecorationLine="Quark.DecorationLine.None" OutlineStyle="Quark.OutlineStyle.None" Attributes="@BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @if (ShowTitle && Citation.Title is not null)
            {
                <H4 DataSlot="citation-title" LineClamp="Quark.LineClamp.Is2" TextSize="Quark.TextSize.Xs" Leading="Quark.Leading.Is4" FontWeight='@("font-[450]")' TextColor="Quark.TextColor.Primary">@Citation.Title</H4>
            }
            @if (ShowDescription && Citation.Description is not null)
            {
                <Paragraph DataSlot="citation-description" LineClamp="Quark.LineClamp.Is3" TextSize="Quark.TextSize.Xs" Leading='Quark.Leading.Is4_5' FontWeight='@("font-[350]")' TextColor="Quark.TextColor.MutedForeground">@Citation.Description</Paragraph>
            }
            @if (ShowSource)
            {
                <CitationSource Source="@Citation" />
            }
        }
    </Anchor>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public int? Index { get; set; }

    [Parameter]
    public bool ShowTitle { get; set; } = true;

    [Parameter]
    public bool ShowDescription { get; set; } = true;

    [Parameter]
    public bool ShowSource { get; set; } = true;

    private ResolvedCitation? Citation => ParentCitation is null
        ? null
        : ParentCitation.ResolvedCitations[Math.Clamp(Index ?? ParentCitation.ActiveIndex, 0, ParentCitation.ResolvedCitations.Count - 1)];

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "citation-item";
    }
}
