@namespace Soenneker.Quark

@if (ResolvedSource is not null)
{
    <Span Attributes="@BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @DefaultContent
        }
    </Span>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public ResolvedCitation? Source { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Class { get; set; }

    private ResolvedCitation? ResolvedSource => Source ?? ParentCitation?.ActiveCitation;

    private RenderFragment DefaultContent => builder => builder.AddContent(0, ResolvedSource?.SiteName);

    private IReadOnlyDictionary<string, object> BuildAttributes() => new Dictionary<string, object>
    {
        ["data-slot"] = "citation-site-name",
        ["class"] = string.Join(" ", new[] { "text-xs leading-4.5 font-normal text-primary", Class }.Where(x => !string.IsNullOrWhiteSpace(x)))
    };
}
