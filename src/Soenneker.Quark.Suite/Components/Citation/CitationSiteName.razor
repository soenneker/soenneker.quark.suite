@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

@if (ResolvedSource is not null)
{
    <span @attributes="BuildAttributes()">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @DefaultContent
        }
    </span>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public ResolvedCitation? Source { get; set; }

    private ResolvedCitation? ResolvedSource => Source ?? ParentCitation?.ActiveCitation;

    private RenderFragment DefaultContent => builder => builder.AddContent(0, ResolvedSource?.SiteName);

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "citation-site-name";

        TextSize ??= Quark.TextSize.Xs;
        Leading ??= Quark.Leading.Token("4.5");
        FontWeight ??= Quark.FontWeight.Normal;
        TextColor ??= Quark.TextColor.Primary;
    }
}