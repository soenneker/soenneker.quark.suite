@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<button type="button" disabled="@(!CanScroll)" @onclick="Scroll" @attributes="BuildAttributes()">
    <Icon Name="LucideIcon.ArrowLeft" Size="Quark.Size.Is4" aria-hidden="true" />
</button>

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    private bool CanScroll => ParentCitation?.CanScrollPrev == true;

    private Task Scroll()
    {
        ParentCitation?.ScrollPrev();
        return Task.CompletedTask;
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "citation-carousel-prev";

        Display ??= Quark.Display.Flex;
        Size ??= Quark.Size.Is6_5;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Full;
        TextColor ??= Quark.TextColor.Primary.OnHover.AccentForeground;
        OutlineStyle ??= Quark.OutlineStyle.None;
        Transition ??= Quark.Transition.All;
        BackgroundColor ??= Quark.BackgroundColor.OnHover.Accent.OnDark.OnHover.Token("accent/50");
        Ring ??= Quark.Ring.Is2.OnFocusVisible;
        RingColor ??= Quark.RingColor.OnFocusVisible.Ring50;
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Cursor ??= Quark.Cursor.Pointer.OnDisabled.NotAllowed;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }
}
