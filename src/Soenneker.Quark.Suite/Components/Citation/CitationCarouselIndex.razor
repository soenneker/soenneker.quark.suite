@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement

@if (ParentCitation is not null)
{
    <span @attributes="BuildAttributes()">@(ParentCitation.ActiveIndex + 1)/@ParentCitation.ResolvedCitations.Count</span>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "citation-carousel-index";

        TextSize ??= Quark.TextSize.Xs;
        Leading ??= Quark.Leading.Is4_5;
        FontWeight ??= Quark.FontWeight.Token("[350]");
        TextColor ??= Quark.TextColor.MutedForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "tabular-nums"));
    }
}
