@namespace Soenneker.Quark

@if (_resolved.Length > 0)
{
    <CascadingValue Value="this" IsFixed="false">
        <HoverCard OpenDelay="@OpenDelay" CloseDelay="@CloseDelay">
            @ChildContent
        </HoverCard>
    </CascadingValue>
}

@code {
    private ResolvedCitation[] _resolved = [];

    internal int ActiveIndex { get; private set; }

    internal ResolvedCitation ActiveCitation => _resolved[Math.Clamp(ActiveIndex, 0, Math.Max(0, _resolved.Length - 1))];

    internal IReadOnlyList<ResolvedCitation> ResolvedCitations => _resolved;

    internal bool CanScrollPrev => ActiveIndex > 0;

    internal bool CanScrollNext => ActiveIndex < _resolved.Length - 1;

    [Parameter]
    public IReadOnlyList<CitationSourceInput> Citations { get; set; } = [];

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public int OpenDelay { get; set; } = 50;

    [Parameter]
    public int CloseDelay { get; set; } = 50;

    internal void ScrollPrev()
    {
        if (CanScrollPrev)
        {
            ActiveIndex--;
            StateHasChanged();
        }
    }

    internal void ScrollNext()
    {
        if (CanScrollNext)
        {
            ActiveIndex++;
            StateHasChanged();
        }
    }

    protected override void OnParametersSet()
    {
        _resolved = BuildResolvedCitations(Citations);

        if (ActiveIndex >= _resolved.Length)
            ActiveIndex = Math.Max(0, _resolved.Length - 1);
    }

    private static ResolvedCitation[] BuildResolvedCitations(IReadOnlyList<CitationSourceInput> citations)
    {
        if (citations.Count == 0)
            return [];

        var resolved = new ResolvedCitation[citations.Count];

        for (var i = 0; i < resolved.Length; i++)
        {
            resolved[i] = CitationSourceResolver.Resolve(citations[i]);
        }

        return resolved;
    }
}
