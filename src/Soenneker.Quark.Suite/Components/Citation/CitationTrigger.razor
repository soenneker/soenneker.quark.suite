@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@if (ParentCitation is not null)
{
    <HoverCardTrigger Attributes="@BuildAttributes()">
        @if (ShowFavicon)
        {
            <CitationFavicon Source="@Primary" />
        }
        @if (HasText)
        {
            <CitationSiteName Source="@Primary">@LabelContent</CitationSiteName>
        }
        @if (MultipleSources)
        {
            <Span DataSlot="citation-extra-count" TextSize="Quark.TextSize.Xs" Leading='Quark.Leading.Is4_5' FontWeight='Quark.FontWeight.Token("[350]")' TextColor="Quark.TextColor.MutedForeground" Class="tabular-nums">+@(ParentCitation.ResolvedCitations.Count - 1)</Span>
        }
    </HoverCardTrigger>
}

@code {
    [CascadingParameter]
    private Citation? ParentCitation { get; set; }

    [Parameter]
    public RenderFragment? Label { get; set; }

    [Parameter]
    public bool ShowFavicon { get; set; } = true;

    [Parameter]
    public bool ShowSiteName { get; set; } = true;

    private ResolvedCitation Primary => ParentCitation!.ResolvedCitations[0];

    private bool MultipleSources => ParentCitation is not null && ParentCitation.ResolvedCitations.Count > 1;

    private bool HasText => Label is not null || ShowSiteName || !ShowFavicon;

    private RenderFragment LabelContent => builder =>
    {
        if (Label is not null)
            builder.AddContent(0, Label);
        else if (ShowSiteName)
            builder.AddContent(1, Primary.SiteName);
        else if (!ShowFavicon)
            builder.AddContent(2, "Source");
    };

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "citation-trigger";

        Display ??= Quark.Display.InlineFlex;
        Height ??= Quark.Height.Is5_5;
        MaxWidth ??= Quark.MaxWidth.IsFull;
        Cursor ??= Quark.Cursor.Default;
        ItemsAlign ??= Quark.Items.Center;
        Rounded ??= Quark.Rounded.Full;
        BackgroundColor ??= Quark.BackgroundColor.Secondary;
        Opacity ??= Quark.Opacity.Is100;
        Transition ??= Quark.Transition.Colors;
        VerticalAlign ??= Quark.VerticalAlign.Middle;

        if (HasText && ShowFavicon)
        {
            Gap ??= Quark.Gap.Is1;
            Padding ??= Quark.Padding.OnY.Is1.FromLeft.Is1.FromRight.Token("1.5");
        }
        else if (HasText)
        {
            Padding ??= Quark.Padding.OnX.Is2.OnY.Is1;
        }
        else if (ShowFavicon)
        {
            Padding ??= Quark.Padding.Is1;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "hover:bg-border data-[state=open]:opacity-100");
        });
    }
}
