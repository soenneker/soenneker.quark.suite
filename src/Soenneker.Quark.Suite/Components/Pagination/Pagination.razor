@namespace Soenneker.Quark

@inherits Soenneker.Quark.Element
@implements IPagination

<CascadingValue Name="ParentPagination" Value="this">
    <nav @attributes="BuildAttributes()">
	    @ChildContent
    </nav>
</CascadingValue>

@code {
    /// <summary>
    /// Gets or sets the size of the pagination component.
    /// </summary>
    [Parameter]
    public CssValue<SizeBuilder>? Size { get; set; } = Quark.Size.Default;

    /// <summary>
    /// Gets or sets whether the pagination should be displayed vertically.
    /// </summary>
    [Parameter]
    public bool Vertical { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        Width ??= Quark.Width.IsFull;
        Margin ??= Quark.Margin.Auto.OnX;
    }

    internal string? GetSizeClass()
    {
        if (Size == Quark.Size.Default)
            return null;

        string? token = null;
        var isTheme = Size?.TryGetThemeToken(out token) == true;
        if (isTheme && token is not null)
            return $"pagination-{token}";

        return Size?.ToString() != null ? $"pagination-{Size}" : null;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "pagination";
        attributes["role"] = "navigation";
        attributes["aria-label"] = "pagination";
        attributes["data-orientation"] = Vertical ? "vertical" : "horizontal";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "justify-center");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        AddIf(ref hc, Size);
        hc.Add(Vertical);
    }
}
