@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IPaginationLink

@if (To.HasContent())
{
    <Anchor To="@To" @attributes="BuildAttributes()">
        @ChildContent
    </Anchor>
}
else
{
    <button type="button" @onclick="HandleClick" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    /// <summary>
    /// Gets or sets whether the pagination link is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets the button size variant used for pagination links.
    /// </summary>
    [Parameter]
    public ButtonSize Size { get; set; } = ButtonSize.Icon;

    /// <summary>
    /// Gets or sets the link target (href). When set, the link navigates; otherwise behaves as button.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;

        if (Active)
        {
            Border ??= Quark.Border.Default;
            BorderColor ??= Quark.BorderColor.Border;
            BackgroundColor ??= Quark.BackgroundColor.Background;
        }
        else
        {
            BorderColor ??= Quark.BorderColor.Transparent;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "pagination-link";
        attributes["data-active"] = Active ? "true" : "false";
        attributes["data-size"] = Button.ResolveButtonSizeDataAttribute(Size?.Value);
        if (Active)
            attributes["aria-current"] = "page";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "shrink-0 outline-none");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, Button.ResolveButtonSizeClass(Size?.Value));

            if (Active)
                AppendClass(ref cls, Button.GetButtonVariantClass(ButtonVariant.OutlineValue));
            else
                AppendClass(ref cls, Button.GetButtonVariantClass(ButtonVariant.GhostValue));

            if (Disabled)
                AppendClass(ref cls, "opacity-50 pointer-events-none");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            // Set tabindex only if not already set via TabIndex property
            if (!attributes.ContainsKey("tabindex"))
                attributes["tabindex"] = -1;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Active);
        hc.Add(Disabled);
        hc.Add(To);
        hc.Add(Size);
    }
}
