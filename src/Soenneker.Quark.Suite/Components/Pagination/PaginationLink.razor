@namespace Soenneker.Quark
@using ButtonSizeType = Soenneker.Quark.ButtonSize
@inherits Soenneker.Quark.FormControlElement
@implements IPaginationLink

<a href="@To" @onclick="HandleClick" @attributes="BuildAttributes()">
    @ChildContent
</a>

@code {
    /// <summary>
    /// Gets or sets whether the pagination link is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets the button size variant used for pagination links.
    /// </summary>
    [Parameter]
    public ButtonSize ButtonSize { get; set; } = ButtonSizeType.Icon;

    /// <summary>
    /// Gets or sets the link target (href). When set, the link navigates; otherwise behaves as button.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        var resolvedButtonSize = ButtonSize?.Value ?? ButtonSizeType.Icon.Value;
        SetDefaultDataSlot("pagination-link");
        attributes["data-size"] = Button.ResolveButtonSizeDataAttribute(resolvedButtonSize);

        if (Active)
        {
            attributes["data-active"] = "true";
            attributes["aria-current"] = "page";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            var variant = Active ? ButtonVariant.Outline : ButtonVariant.Ghost;
            AppendClass(ref cls, "group/button shrink-0 text-sm border bg-clip-padding select-none focus-visible:ring-3 active:not-aria-[haspopup]:translate-y-px");
            if (!Active)
                AppendClass(ref cls, "border-transparent");
            AppendClass(ref cls, "rounded-lg");
            AppendClass(ref cls, Button.GetButtonFocusClass(variant));
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, Button.GetButtonVariantClass(variant));
            AppendClass(ref cls, Button.ResolveButtonSizeClass(resolvedButtonSize, false));

            if (Disabled)
                AppendClass(ref cls, "opacity-50 pointer-events-none");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            // Set tabindex only if not already set via TabIndex property
            if (!attributes.ContainsKey("tabindex"))
                attributes["tabindex"] = -1;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Active);
        hc.Add(Disabled);
        hc.Add(To);
        hc.Add(ButtonSize);
    }

}
