@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IPaginationLink

@if (To.HasContent())
{
    <Anchor To="@To" @attributes="BuildAttributes()">
        @ChildContent
    </Anchor>
}
else
{
    <button type="button" @onclick="HandleClick" @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    /// <summary>
    /// Gets or sets whether the pagination link is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets the link target (href). When set, the link navigates; otherwise behaves as button.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "pagination-link";
        attributes["data-active"] = Active ? "true" : "false";
        if (Active)
            attributes["aria-current"] = "page";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-pagination-link");
            AppendClass(ref cls, "group/button inline-flex size-9 items-center justify-center rounded-lg border border-transparent bg-background text-sm font-medium whitespace-nowrap transition-colors outline-none hover:bg-accent hover:text-accent-foreground focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50");
            if (Active)
                AppendClass(ref cls, "bg-primary text-primary-foreground");
            if (Disabled)
                AppendClass(ref cls, "opacity-50 pointer-events-none");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            // Set tabindex only if not already set via TabIndex property
            if (!attributes.ContainsKey("tabindex"))
                attributes["tabindex"] = -1;
        }
        else if (To.HasContent())
        {
            if (!attributes.ContainsKey("role"))
                attributes["role"] = "button";
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Active);
        hc.Add(Disabled);
        hc.Add(To);
    }
}