@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IPaginationLink

<a href="@To" @onclick="HandleClick" @attributes="BuildAttributes()">
    @ChildContent
</a>

@code {
    /// <summary>
    /// Gets or sets whether the pagination link is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }

    /// <summary>
    /// Gets or sets the button size variant used for pagination links.
    /// </summary>
    [Parameter]
    public ButtonSize Size { get; set; } = ButtonSize.Icon;

    /// <summary>
    /// Gets or sets the link target (href). When set, the link navigates; otherwise behaves as button.
    /// </summary>
    [Parameter]
    public string? To { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Shrink ??= Quark.Shrink.Is0;
        Gap ??= Quark.Gap.Is2;
        Rounded ??= Quark.Rounded.Md;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;

        if (Active)
        {
            BackgroundColor ??= Quark.BackgroundColor.Background;
        }
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "pagination-link";
        attributes["data-size"] = Button.ResolveButtonSizeDataAttribute(Size?.Value);
        attributes["data-active"] = Active ? "true" : "false";

        if (Active)
        {
            attributes["aria-current"] = "page";
        }

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "select-none");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, ResolvePaginationButtonSizeClass(Size?.Value));

            if (Active)
                AppendClass(ref cls, "border bg-background shadow-xs hover:bg-accent hover:text-accent-foreground dark:border-input dark:bg-input/30 dark:hover:bg-input/50");
            else
                AppendClass(ref cls, "hover:bg-accent hover:text-accent-foreground dark:hover:bg-accent/50");

            if (Disabled)
                AppendClass(ref cls, "opacity-50 pointer-events-none");
        });

        if (Disabled)
        {
            attributes["aria-disabled"] = "true";
            // Set tabindex only if not already set via TabIndex property
            if (!attributes.ContainsKey("tabindex"))
                attributes["tabindex"] = -1;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Active);
        hc.Add(Disabled);
        hc.Add(To);
        hc.Add(Size);
    }

    private static string ResolvePaginationButtonSizeClass(string? size)
    {
        return size switch
        {
            "xs" => "h-6 gap-1 rounded-md px-2 text-xs has-[>svg]:px-1.5 [&_svg:not([class*='size-'])]:size-3",
            "sm" => "h-8 gap-1.5 rounded-md px-3 has-[>svg]:px-2.5",
            "lg" => "h-10 rounded-md px-6 has-[>svg]:px-4",
            "icon" => "size-9",
            "icon-xs" => "size-6 rounded-md [&_svg:not([class*='size-'])]:size-3",
            "icon-sm" => "size-8",
            "icon-lg" => "size-10",
            _ => "h-9 px-4 py-2 has-[>svg]:px-3"
        };
    }
}
