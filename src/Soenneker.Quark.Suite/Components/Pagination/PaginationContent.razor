@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<ul @attributes="BuildAttributes()">
    @ChildContent
</ul>

@code {
    [CascadingParameter(Name = "ParentPagination")]
    private Pagination? ParentPagination { get; set; }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.Flex;
        FlexDirection ??= Quark.FlexDirection.Row;
        Gap ??= Quark.Gap.Token("0.5");
        ItemsAlign ??= Items.Center;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "pagination-content";

        BuildClassAttribute(attributes, (ref cls) =>
        {

            var sizeClass = ParentPagination?.GetSizeClass();
            if (sizeClass is not null)
                AppendClass(ref cls, sizeClass);

            if (ParentPagination?.Vertical == true)
                AppendClass(ref cls, "flex-col");
        });
    }
}
