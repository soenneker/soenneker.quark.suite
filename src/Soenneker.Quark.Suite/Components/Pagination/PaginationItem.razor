@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IPaginationItem

<li @attributes="BuildAttributes()">
	@ChildContent
</li>

@code {
    /// <summary>
    /// Gets or sets whether the pagination item is active.
    /// </summary>
    [Parameter]
    public bool Active { get; set; }


    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "pagination-item";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "list-none");
            if (Disabled)
                AppendClass(ref cls, "opacity-50 pointer-events-none");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Active);
        hc.Add(Disabled);
    }
}
