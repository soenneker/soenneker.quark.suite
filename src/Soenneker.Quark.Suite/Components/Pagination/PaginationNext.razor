@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<PaginationItem>
    <PaginationLink To="@To" OnClick="@OnClick" Disabled="@Disabled" @attributes="BuildAttributes()" aria-label="Go to next page">
        <span class="hidden sm:inline">@Text</span>
        <Icon Name="LucideIcon.ChevronRight" class="size-4" />
    </PaginationLink>
</PaginationItem>

@code {
    [Parameter] public string? To { get; set; }
    [Parameter] public string Text { get; set; } = "Next";

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "gap-1 px-2.5 sm:pr-2.5"));
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(To);
        hc.Add(Text);
        hc.Add(Disabled);
    }
}
