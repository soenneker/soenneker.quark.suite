@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement

<PaginationLink To="@To" OnClick="@OnClick" Disabled="@Disabled" ButtonSize="ButtonSize.Default" @attributes="BuildAttributes()" aria-label="Go to next page">
    <Span Display="Quark.Display.None.OnSm.Block">@Text</Span>
    <Icon Name="LucideIcon.ChevronRight" data-icon="inline-end" Class="cn-rtl-flip" />
</PaginationLink>

@code {
    [Parameter] public string? To { get; set; }
    [Parameter] public string Text { get; set; } = "Next";

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        BuildClassAttribute(attributes, (ref cls) => AppendClass(ref cls, "pr-1.5!"));
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(To);
        hc.Add(Text);
        hc.Add(Disabled);
    }
}
