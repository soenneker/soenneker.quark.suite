@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement
@implements IAlertDialogContent

<BradixAlertDialogPortal>
    @if (ParentAlertDialog?.ShowBackdrop == true)
    {
        <BradixAlertDialogOverlay AdditionalAttributes="@OverlayAttributes" />
    }

    <BradixAlertDialogContent Id="@Context?.ContentId"
                              CloseOnEscapeKeyDown="@(ParentAlertDialog?.CloseOnEscape ?? true)"
                              AdditionalAttributes="@ContentAttributes">
        @ChildContent
    </BradixAlertDialogContent>
</BradixAlertDialogPortal>

@code {
    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    /// <summary>
    /// Gets or sets the size variant of the alert dialog content ("default" or "sm").
    /// </summary>
    [Parameter]
    public string Size { get; set; } = "default";

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Position ??= Quark.Position.Fixed;
        Display ??= Quark.Display.Grid;
        Width ??= Quark.Width.IsFull;
        Gap ??= Quark.Gap.Is4;
        Rounded ??= Quark.Rounded.Xl;
        BackgroundColor ??= Quark.BackgroundColor.Popover;
        Padding ??= Quark.Padding.Is4;
        TextColor ??= Quark.TextColor.PopoverForeground;
        Ring ??= Quark.Ring.One;
    }

    private IReadOnlyDictionary<string, object> ContentAttributes => BuildAttributes();

    private IReadOnlyDictionary<string, object> OverlayAttributes => BuildOverlayAttributes();

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var normalizedSize = Size.ToLowerInvariant() switch
        {
            "sm" => "sm",
            _ => "default"
        };

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/alert-dialog-content top-1/2 start-1/2 z-50 -translate-x-1/2 -translate-y-1/2 ring-foreground/10 duration-100 outline-none data-[size=default]:max-w-xs data-[size=sm]:max-w-xs data-[size=default]:sm:max-w-sm data-open:animate-in data-open:fade-in-0 data-open:zoom-in-95 data-closed:animate-out data-closed:fade-out-0 data-closed:zoom-out-95");
        });

        attributes["data-slot"] = "alert-dialog-content";
        attributes["data-size"] = normalizedSize;
    }

    private Dictionary<string, object> BuildOverlayAttributes()
    {
        var attributes = new Dictionary<string, object>();

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "fixed inset-0 isolate z-50 bg-black/10 duration-100 supports-backdrop-filter:backdrop-blur-xs data-open:animate-in data-open:fade-in-0 data-closed:animate-out data-closed:fade-out-0");
        });

        attributes["data-state"] = ParentAlertDialog?.Visible == true ? "open" : "closed";
        attributes["data-slot"] = "alert-dialog-overlay";
        attributes["aria-hidden"] = "true";

        return attributes;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Size);
        hc.Add(ParentAlertDialog?.Visible ?? false);
        hc.Add(ParentAlertDialog?.ShowBackdrop ?? true);
        hc.Add(ParentAlertDialog?.TrapFocus ?? true);
        hc.Add(ParentAlertDialog?.CloseOnEscape ?? true);
        hc.Add(ParentAlertDialog?.CloseOnBackdropClick ?? true);
        hc.Add(ParentAlertDialog?.Static ?? false);
        hc.Add(Context?.ContentId);
    }
}
