@namespace Soenneker.Quark
@inherits Soenneker.Quark.InteractiveElement
@implements IAlertDialogContent

@if (ParentAlertDialog?.Visible == true)
{
    @if (Portal)
    {
        <OverlayPortalPublisher Id="@_portalId" UsePortal="true">
            <OverlayPortalShell CascadeOwnerName="@nameof(ParentAlertDialog)" Owner="ParentAlertDialog" LabelContext="Context">
                <AlertDialogContentSurface Size="@Size">
                    @ChildContent
                </AlertDialogContentSurface>
            </OverlayPortalShell>
        </OverlayPortalPublisher>
    }
    else
    {
        <AlertDialogContentSurface Size="@Size">
            @ChildContent
        </AlertDialogContentSurface>
    }
}

@code {
    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private readonly string _portalId = $"q-alert-dialog-portal-{Guid.NewGuid():N}";

    [Parameter]
    public string Size { get; set; } = "default";

    [Parameter]
    public bool Portal { get; set; } = true;

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Size);
        hc.Add(Portal);
        hc.Add(ParentAlertDialog?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
