@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IAlertDialogTitle

<BradixAlertDialogTitle Id="@Context?.TitleId" AdditionalAttributes="@TitleAttributes">
    @ChildContent
</BradixAlertDialogTitle>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private IReadOnlyDictionary<string, object> TitleAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        TextSize ??= Quark.TextSize.Lg;
        FontWeight ??= Quark.FontWeight.Semibold;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-alert-dialog-title");
            AppendClass(ref cls, "sm:group-data-[size=default]/alert-dialog-content:group-has-data-[slot=alert-dialog-media]/alert-dialog-content:col-start-2");
        });
        attributes["data-slot"] = "alert-dialog-title";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.TitleId);
    }
}
