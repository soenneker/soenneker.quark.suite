@namespace Soenneker.Quark
@inherits Soenneker.Quark.TriggerElement
@implements IAlertDialogTrigger
@using Microsoft.AspNetCore.Components.Web

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <button type="button"
            @onclick="HandleActivate"
            @ref="_elementRef"
            @onkeydown="HandleOverlayDismissKeyDown"
            @onkeydown:preventDefault="_keyPreventDefault"
            @onkeydown:stopPropagation="_keyStopPropagation"
            @attributes="BuildAttributes()">
        @ChildContent
    </button>
}

@code {
    private bool _keyPreventDefault;
    private bool _keyStopPropagation;

    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _elementRef;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "alert-dialog-trigger";
        attributes["data-state"] = ParentAlertDialog?.Visible == true ? "open" : "closed";
        attributes["aria-haspopup"] = "alertdialog";
        attributes["aria-expanded"] = ParentAlertDialog?.Visible == true ? "true" : "false";

        if (Context is not null)
            attributes["id"] = Context.TriggerId;

        if (Disabled)
            attributes["disabled"] = true;

        if (Context is not null && ParentAlertDialog?.Visible == true)
            attributes["aria-controls"] = Context.ContentId;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-alert-dialog-trigger");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    private async Task HandleOverlayDismissKeyDown(KeyboardEventArgs e)
    {
        _keyPreventDefault = false;
        _keyStopPropagation = false;

        if (Disabled || ParentAlertDialog is null || Context is null)
            return;

        if ((e.Key == "Escape" || e.Key == "Enter" || e.Key == " ") && ParentAlertDialog.Visible)
        {
            _keyPreventDefault = true;

            if (e.Key == "Escape")
                _keyStopPropagation = true;

            await ParentAlertDialog.Hide();
        }
    }

    private async Task HandleActivate(MouseEventArgs args)
    {
        if (!Disabled && ParentAlertDialog != null)
        {
            ParentAlertDialog.SetRestoreFocusTarget(_elementRef);
            await ParentAlertDialog.Show();
        }

        await base.HandleClick(args);
    }

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            TriggerId = Context?.TriggerId,
            IsOpen = ParentAlertDialog?.Visible == true,
            DataState = ParentAlertDialog?.Visible == true ? "open" : "closed",
            AriaHasPopup = "alertdialog",
            AriaControls = ParentAlertDialog?.Visible == true ? Context?.ContentId : null,
            OnKeyDown = ParentAlertDialog is null || Context is null
                ? null
                : e => OverlayTriggerKeyDown.HandleDismissWhenOpen(e, ParentAlertDialog.Visible, () => ParentAlertDialog.Hide()),
            RegisterElement = elementReference => _elementRef = elementReference,
            Toggle = ParentAlertDialog is null
                ? null
                : async () =>
                {
                    if (ParentAlertDialog.Visible)
                        await ParentAlertDialog.Hide();
                    else
                    {
                        ParentAlertDialog.SetRestoreFocusTarget(_elementRef);
                        await ParentAlertDialog.Show();
                    }
                },
            Open = ParentAlertDialog is null
                ? null
                : async () =>
                {
                    ParentAlertDialog.SetRestoreFocusTarget(_elementRef);
                    await ParentAlertDialog.Show();
                },
            Close = ParentAlertDialog is null ? null : () => ParentAlertDialog.Hide()
        };
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(Disabled);
        hc.Add(ParentAlertDialog?.Visible ?? false);
        hc.Add(Context?.ContentId);
        hc.Add(Context?.TriggerId);
    }
}
