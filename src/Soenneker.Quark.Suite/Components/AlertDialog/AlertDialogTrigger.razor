@using Soenneker.Bradix
@using Soenneker.Blazor.Utils.Ids

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TriggerElement
@implements IAlertDialogTrigger

@if (AsChild)
{
    <CascadingValue Name="TriggerContext" Value="GetTriggerContext()" IsFixed="false">
        @ChildContent
    </CascadingValue>
}
else
{
    <BradixDialogTrigger Disabled="@Disabled"
                         OnClick="@OnClick"
                         AdditionalAttributes="@TriggerAttributes">
        @ChildContent
    </BradixDialogTrigger>
}

@code {
    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    [CascadingParameter]
    private BradixDialog? BradixDialog { get; set; }

    [Parameter]
    public bool AsChild { get; set; }

    private ElementReference _elementRef;

    private IReadOnlyDictionary<string, object> TriggerAttributes => BuildTriggerAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "alert-dialog-trigger";
        PointerEvents ??= Quark.PointerEvents.None.OnDisabled;
        Opacity ??= Quark.Opacity.Is50.OnDisabled;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-state"] = ParentAlertDialog?.Visible == true ? "open" : "closed";
        attributes["aria-haspopup"] = "dialog";
        attributes["aria-expanded"] = ParentAlertDialog?.Visible == true ? "true" : "false";

        if (Disabled)
            attributes["disabled"] = true;

        if (Context is not null)
            attributes["aria-controls"] = Context.ContentId;

    }

    private IReadOnlyDictionary<string, object> BuildTriggerAttributes()
    {
        Dictionary<string, object> attributes = new(BuildAttributes());

        attributes.Remove("type");
        attributes.Remove("id");
        attributes.Remove("data-state");
        attributes.Remove("aria-haspopup");
        attributes.Remove("aria-expanded");
        attributes.Remove("aria-controls");
        attributes.Remove("disabled");
        attributes.Remove("onclick");

        return attributes;
    }

    private static string? GetOverlayTriggerId(OverlayLabelContext? context) =>
        context?.ContentId is { } contentId ? BlazorIdGenerator.Child(contentId, "trigger") : null;

    private TriggerContext GetTriggerContext()
    {
        return new TriggerContext
        {
            DataSlot = null,
            TriggerId = GetOverlayTriggerId(Context),
            ParentDisabled = Disabled,
            IsOpen = ParentAlertDialog?.Visible == true,
            DataState = ParentAlertDialog?.Visible == true ? "open" : "closed",
            AriaHasPopup = "dialog",
            AriaControls = Context?.ContentId,
            OnPointerDownEvent = ParentAlertDialog is null || Disabled ? null : HandleTriggerPointerDown,
            SuppressClickAfterPointerDown = true,
            RegisterElement = elementReference =>
            {
                _elementRef = elementReference;

                if (BradixDialog is not null)
                    BradixDialog.RegisterTrigger(elementReference, GetOverlayTriggerId(Context));
            },
            Toggle = ParentAlertDialog is null
                ? null
                : async () =>
                {
                    if (ParentAlertDialog.Visible)
                        await ParentAlertDialog.Hide();
                    else
                        await ParentAlertDialog.Show();
                },
            Open = ParentAlertDialog is null
                ? null
                : async () =>
                {
                    await ParentAlertDialog.Show();
                },
            Close = ParentAlertDialog is null ? null : () => ParentAlertDialog.Hide()
        };
    }

    private Task HandleTriggerPointerDown(PointerEventArgs args)
    {
        if (ParentAlertDialog is null || Disabled || args.Button != 0 || args.CtrlKey)
            return Task.CompletedTask;

        return ParentAlertDialog.Visible ? ParentAlertDialog.Hide() : ParentAlertDialog.Show();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AsChild);
        hc.Add(Disabled);
        hc.Add(ParentAlertDialog?.Visible ?? false);
        hc.Add(Context?.ContentId);
    }
}
