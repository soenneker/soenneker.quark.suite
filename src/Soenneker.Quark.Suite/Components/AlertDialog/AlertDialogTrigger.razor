@namespace Soenneker.Quark
@inherits Soenneker.Quark.FormControlElement
@implements IAlertDialogTrigger

<button type="button" @onclick="HandleActivate" @attributes="BuildAttributes()">
    @ChildContent
</button>

@code {
    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "alert-dialog-trigger";

        if (Disabled)
            attributes["disabled"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-alert-dialog-trigger");
            if (Disabled)
                AppendClass(ref cls, "pointer-events-none opacity-50");
        });
    }

    private async Task HandleActivate()
    {
        if (!Disabled && ParentAlertDialog != null)
            await ParentAlertDialog.Show();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Disabled);
    }
}
