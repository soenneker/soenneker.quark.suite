@using Soenneker.Blazor.Extensions.EventCallback
@using Soenneker.Bradix

@namespace Soenneker.Quark
@using ButtonSizeType = Soenneker.Quark.ButtonSize
@inherits Soenneker.Quark.Element
@implements IAlertDialogAction

<BradixAlertDialogAction Disabled="@Disabled"
                         OnClick="HandleActionClick"
                         AdditionalAttributes="@BuildAttributes()">
    @ChildContent
</BradixAlertDialogAction>

@code {
    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    /// <summary>
    /// Gets or sets whether the parent alert dialog should automatically close when clicked.
    /// </summary>
    [Parameter]
    public bool AutoClose { get; set; } = true;

    [Parameter]
    public bool Disabled { get; set; }

    /// <summary>
    /// Gets or sets the callback invoked when the action is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnAction { get; set; }

    /// <summary>
    /// Gets or sets the visual style variant of the action button.
    /// </summary>
    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Default;

    /// <summary>
    /// Gets or sets the size of the action button.
    /// </summary>
    [Parameter]
    public ButtonSize ButtonSize { get; set; } = ButtonSizeType.Default;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "alert-dialog-action";
        attributes["data-variant"] = Variant?.Value ?? ButtonVariant.Default.Value;
        attributes["data-size"] = Button.ResolveButtonSizeDataAttribute(ButtonSize?.Value);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/button border bg-clip-padding select-none focus-visible:ring-3 active:not-aria-[haspopup]:translate-y-px");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, Button.ResolveButtonSizeClass(ButtonSize?.Value));
            AppendClass(ref cls, Button.GetButtonVariantClass(Variant));
        });
    }

    private async Task HandleActionClick(MouseEventArgs _)
    {
        await OnAction.InvokeIfHasDelegate();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Shrink ??= Quark.Shrink.Is0;
        Gap ??= Quark.Gap.Token("1.5");
        Rounded ??= Quark.Rounded.Lg;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AutoClose);
        hc.Add(Variant);
        hc.Add(ButtonSize);
    }
}
