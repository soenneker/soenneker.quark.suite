@using Soenneker.Bradix

@namespace Soenneker.Quark
@inherits Soenneker.Quark.TypographyElement
@implements IAlertDialogDescription

<BradixAlertDialogDescription Id="@Context?.DescriptionId" AdditionalAttributes="@DescriptionAttributes">
    @ChildContent
</BradixAlertDialogDescription>

@code {
    [CascadingParameter]
    private OverlayLabelContext? Context { get; set; }

    private IReadOnlyDictionary<string, object> DescriptionAttributes => BuildAttributes();

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        TextSize ??= Quark.TextSize.Sm;
        TextColor ??= Quark.TextColor.MutedForeground;
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "alert-dialog-description";
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Context?.DescriptionId);
    }
}
