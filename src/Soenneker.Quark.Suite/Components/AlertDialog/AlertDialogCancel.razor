@using Soenneker.Bradix
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@using ButtonSizeType = Soenneker.Quark.ButtonSize
@inherits Soenneker.Quark.Element
@implements IAlertDialogCancel

<BradixAlertDialogCancel Disabled="@Disabled"
                         OnClick="HandleCancelClick"
                         AdditionalAttributes="@BuildAttributes()">
    @ChildContent
</BradixAlertDialogCancel>

@code {
    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    [Parameter]
    public bool AutoClose { get; set; } = true;

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Outline;

    [Parameter]
    public ButtonSize ButtonSize { get; set; } = ButtonSizeType.Default;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "alert-dialog-cancel";
        attributes["data-bradix-alert-dialog-cancel"] = "true";
        attributes["data-variant"] = Variant?.Value ?? ButtonVariant.Default.Value;
        attributes["data-size"] = Button.ResolveButtonSizeDataAttribute(ButtonSize?.Value);

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "group/button border bg-clip-padding select-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50 active:not-aria-[haspopup]:translate-y-px");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-3 aria-invalid:ring-destructive/20 dark:aria-invalid:border-destructive/50 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, Button.ResolveButtonSizeClass(ButtonSize?.Value));
            AppendClass(ref cls, Button.GetButtonVariantClass(Variant));
        });
    }

    private async Task HandleCancelClick(MouseEventArgs _)
    {
        await OnCancel.InvokeIfHasDelegate();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Shrink ??= Quark.Shrink.Is0;
        Gap ??= Quark.Gap.Token("1.5");
        Rounded ??= Quark.Rounded.Lg;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
        OutlineStyle ??= Quark.OutlineStyle.None;

        if (ReferenceEquals(Variant, ButtonVariant.Destructive))
        {
            return;
        }

        if (ReferenceEquals(Variant, ButtonVariant.Outline))
        {
            return;
        }

        if (ReferenceEquals(Variant, ButtonVariant.Secondary))
        {
            return;
        }

        if (ReferenceEquals(Variant, ButtonVariant.Ghost))
        {
            return;
        }

        if (ReferenceEquals(Variant, ButtonVariant.Link))
        {
            return;
        }
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(AutoClose);
        hc.Add(Variant);
        hc.Add(ButtonSize);
    }
}
