@using Soenneker.Bradix
@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAlertDialogCancel

<BradixDialogClose AriaLabel="@((string?)null)"
                   OnClick="HandleCancelClick"
                   AdditionalAttributes="@BuildAttributes()">
    @ChildContent
</BradixDialogClose>

@code {
    [CascadingParameter(Name = nameof(ParentAlertDialog))]
    public AlertDialog? ParentAlertDialog { get; set; }

    [Parameter]
    public bool AutoClose { get; set; } = true;

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Outline;

    [Parameter]
    public ButtonSize Size { get; set; } = ButtonSize.Default;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "alert-dialog-cancel";
        attributes["data-bradix-alert-dialog-cancel"] = "true";
        attributes["data-variant"] = Variant?.Value ?? ButtonVariant.Default.Value;
        attributes["data-size"] = Button.ResolveButtonSizeDataAttribute(Size?.Value);
        attributes["autofocus"] = true;

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "inline-flex shrink-0 items-center justify-center gap-2 whitespace-nowrap outline-none");
            AppendClass(ref cls, "focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50");
            AppendClass(ref cls, "disabled:pointer-events-none disabled:opacity-50");
            AppendClass(ref cls, "aria-invalid:border-destructive aria-invalid:ring-destructive/20 dark:aria-invalid:ring-destructive/40");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
            AppendClass(ref cls, Button.ResolveButtonSizeClass(Size?.Value));
            AppendClass(ref cls, Button.GetButtonVariantClass(Variant?.Value));
        });
    }

    private async Task HandleCancelClick(MouseEventArgs _)
    {
        await OnCancel.InvokeIfHasDelegate();

        if (AutoClose && ParentAlertDialog is not null)
            await ParentAlertDialog.Hide();
    }

    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();

        Display ??= Quark.Display.InlineFlex;
        ItemsAlign ??= Quark.Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Lg;
        TextSize ??= Quark.TextSize.Sm;
        FontWeight ??= Quark.FontWeight.Medium;
        Whitespace ??= Quark.Whitespace.Nowrap;
        Transition ??= Quark.Transition.All;
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(AutoClose);
        hc.Add(Variant);
        hc.Add(Size);
    }
}
