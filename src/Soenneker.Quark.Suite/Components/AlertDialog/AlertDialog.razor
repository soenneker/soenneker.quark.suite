@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.OverlayElement
@implements IAlertDialog

<CascadingValue Name="ParentAlertDialog" Value="@this">
    <CascadingValue Value="_context" IsFixed="false">
        @ChildContent
    </CascadingValue>
</CascadingValue>

@code {
    /// <summary>
    /// Gets or sets the callback invoked when the backdrop is clicked.
    /// </summary>
    [Parameter]
    public EventCallback OnBackdropClick { get; set; }

    /// <summary>
    /// When <c>true</c>, Escape and backdrop clicks do not close the alert dialog.
    /// </summary>
    [Parameter]
    public bool Static { get; set; }

    private readonly OverlayLabelContext _context = new("alert-dialog");

    /// <summary>
    /// Shows the alert dialog.
    /// </summary>
    public async Task Show()
    {
        if (Visible)
            return;

        Visible = true;
        await VisibleChanged.InvokeAsync(Visible);
        await OnShow.InvokeIfHasDelegate();
        await RefreshOffThread();
    }

    /// <summary>
    /// Hides the alert dialog.
    /// </summary>
    public async Task Hide()
    {
        if (!Visible)
            return;

        Visible = false;
        await VisibleChanged.InvokeAsync(Visible);
        await OnHide.InvokeIfHasDelegate();
        await RefreshOffThread();
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        base.ComputeRenderKeyCore(ref hc);
        hc.Add(Visible);
        hc.Add(ShowBackdrop);
        hc.Add(Static);
        hc.Add(CloseOnBackdropClick);
        hc.Add(CloseOnEscape);
        hc.Add(_context.ContentId);
        hc.Add(_context.HasTitle);
        hc.Add(_context.HasDescription);
        hc.Add(_context.TitleId);
        hc.Add(_context.DescriptionId);
    }
}
