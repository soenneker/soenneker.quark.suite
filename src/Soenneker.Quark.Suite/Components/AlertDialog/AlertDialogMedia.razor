@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAlertDialogMedia

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void ApplyDefaultParameters()
    {
        base.ApplyDefaultParameters();
        DataSlot ??= "alert-dialog-media";
        Margin ??= Quark.Margin.Is2.FromBottom;
        Display ??= Quark.Display.InlineFlex;
        Size ??= Quark.Size.Is10;
        ItemsAlign ??= Items.Center;
        Justify ??= Quark.Justify.Center;
        Rounded ??= Quark.Rounded.Md;
        BackgroundColor ??= Quark.BackgroundColor.Muted;

    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        // shadcn AlertDialogMedia - new-york-v4 ui/alert-dialog.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "sm:group-data-[size=default]/alert-dialog-content:row-span-2 *:[svg:not([class*='size-'])]:size-6 *:data-[slot=icon]:size-6");
        });
    }
}