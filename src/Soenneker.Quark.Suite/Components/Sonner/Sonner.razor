@namespace Soenneker.Quark
@inherits Soenneker.Quark.CancellableElement

@inject ISonnerService SonnerService
@inject ISonnerInterop SonnerInterop
@using Microsoft.JSInterop
@using Soenneker.Atomics.ValueBools

@{
    var groups = _groups;
}

@if (groups.Count > 0)
{
    <section @ref="_sectionRef"
             aria-label="@GetAriaLabel()"
             tabindex="-1"
             aria-live="polite"
             aria-relevant="additions text"
             aria-atomic="false">
        @foreach (var group in groups)
        {
            <ol dir="ltr"
                tabindex="-1"
                class="@GetToasterClass()"
                data-sonner-toaster="true"
                data-sonner-theme="@GetThemeAttribute()"
                data-y-position="@GetYPosition(group.Position)"
                data-x-position="@GetXPosition(group.Position)"
                style="@GetToasterStyle(group.Toasts)"
                @onmouseenter="(() => SetExpanded(group.Position, true))"
                @onmousemove="(() => SetExpanded(group.Position, true))"
                @onmouseleave="(() => SetExpanded(group.Position, false))"
                @onfocusin="(() => SetFocused(group.Position, true))"
                @onfocusout="(() => SetFocused(group.Position, false))"
                @onpointerdown="(() => SetInteracting(group.Position, true))"
                @onpointerup="(() => SetInteracting(group.Position, false))">
                @for (var i = 0; i < group.Toasts.Count; i++)
                {
                    var toast = group.Toasts[i];
                    var isVisible = i < VisibleToasts && !toast.Removed;
                    var expanded = IsExpanded(group.Position);

                    <li @key="toast.Id"
                        tabindex="0"
                        class="@GetToastClass()"
                        data-toast-id="@toast.Id"
                        data-sonner-toast=""
                        data-rich-colors="@(RichColors ? "true" : null)"
                        data-styled="true"
                        data-mounted="@GetBoolString(toast.Mounted)"
                        data-promise="@GetBoolString(toast.Promise)"
                        data-swiped="@GetBoolString(IsSwipeDismissed(toast.Id))"
                        data-removed="@GetBoolString(toast.Removed)"
                        data-visible="@GetBoolString(isVisible)"
                        data-y-position="@GetYPosition(group.Position)"
                        data-x-position="@GetXPosition(group.Position)"
                        data-index="@i"
                        data-front="@GetBoolString(i == 0)"
                        data-swiping="false"
                        data-dismissible="@GetBoolString(toast.Dismissible)"
                        data-type="@GetDataType(toast)"
                        data-swipe-out="@GetBoolString(IsSwipeDismissed(toast.Id))"
                        data-expanded="@GetBoolString(expanded)"
                        style="@GetToastStyle(group.Toasts, i)">
                        @if (HasIcon(toast))
                        {
                            <div data-icon>
                                @GetIcon(toast)
                            </div>
                        }

                        <div data-content>
                            @if (toast.Content is not null)
                            {
                                @toast.Content
                            }
                            else
                            {
                                @if (toast.Title.HasContent())
                                {
                                    <div data-title>@toast.Title</div>
                                }

                                @if (toast.Description.HasContent())
                                {
                                    <div data-description>@toast.Description</div>
                                }
                            }
                        </div>

                        @if (toast.Action is not null && toast.ActionLabel.HasContent())
                        {
                            <button type="button"
                                    class="@GetActionButtonClass()"
                                    data-button="true"
                                    data-action="true"
                                    @onclick="() => HandleAction(toast)">
                                @toast.ActionLabel
                            </button>
                        }

                        @if (toast.Dismissible && toast.CloseButton && toast.Type != SonnerToastType.Loading)
                        {
                            <button type="button"
                                    class="@GetCloseButtonClass()"
                                    data-close-button
                                    aria-label="Close toast"
                                    @onclick="() => HandleDismiss(toast.Id)">
                                <Icon Name="LucideIcon.X" Size="Quark.Size.Is3" aria-hidden="true" />
                            </button>
                        }
                    </li>
                }
            </ol>
        }
    </section>
}

@code {
    private const double DefaultToastHeight = 73.3;
    private const int DefaultToastWidth = 356;
    private const int DefaultGap = 14;
    private const int DesktopOffset = 24;
    private const int MobileOffset = 16;
    private const string DefaultToasterId = "";
    private static readonly IReadOnlyList<string> DefaultHotkey = ["altKey", "KeyT"];

    [Parameter]
    public string? ToasterId { get; set; }

    [Parameter]
    public SonnerPosition? ToastPosition { get; set; }

    [Parameter]
    public int? ToastDuration { get; set; }

    [Parameter]
    public bool? CloseButton { get; set; }

    [Parameter]
    public int VisibleToasts { get; set; } = 3;

    [Parameter]
    public bool RichColors { get; set; }

    [Parameter]
    public string Theme { get; set; } = "system";

    [Parameter]
    public string ContainerAriaLabel { get; set; } = "Notifications";

    [Parameter]
    public string HotkeyLabel { get; set; } = "alt+T";

    [Parameter]
    public IReadOnlyList<string>? Hotkey { get; set; } = DefaultHotkey;

    private ElementReference _sectionRef;
    private Dictionary<string, double> _heights = new(StringComparer.Ordinal);
    private readonly HashSet<SonnerPosition> _expandedPositions = [];
    private readonly HashSet<SonnerPosition> _interactingPositions = [];
    private readonly HashSet<SonnerPosition> _focusedPositions = [];
    private readonly HashSet<string> _swipeDismissedToastIds = new(StringComparer.Ordinal);
    private IReadOnlyList<ToastGroup> _groups = [];
    private bool _shouldMeasureHeights = true;
    private string _registeredToasterId = DefaultToasterId;
    private string? _registeredHotkey;
    private DotNetObjectReference<Sonner>? _dotNetReference;
    private bool _hotkeyRegistered;
    private bool _swipeHandlersRegistered;
    private bool _toasterRegistered;
    private ValueAtomicBool _disposed = new(false);

    protected override async Task OnInitializedAsync()
    {
        SonnerService.StateChanged += OnStateChanged;
        await RefreshToastGroups();
    }

    protected override async Task OnParametersSetAsync()
    {
        await RegisterToaster();
        await RefreshToastGroups();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (firstRender)
        {
            try
            {
                await SonnerInterop.Initialize(CancellationToken);
            }
            catch
            {
                return;
            }
        }

        await SyncHotkeyRegistration();
        await SyncSwipeHandlers();

        if (!_shouldMeasureHeights)
            return;

        try
        {
            _shouldMeasureHeights = false;
            var heights = await SonnerInterop.MeasureToastHeights(_sectionRef, CancellationToken);

            if (HaveHeightsChanged(heights))
            {
                _heights = heights;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
        }
    }

    private async Task RefreshToastGroups()
    {
        if (_disposed.Value)
            return;

        var toasts = await SonnerService.GetToasts(CancellationToken);
        var toasterId = NormalizeToasterId(ToasterId);
        var filterPosition = ToastPosition;
        List<SonnerToast>? topLeft = null;
        List<SonnerToast>? topCenter = null;
        List<SonnerToast>? topRight = null;
        List<SonnerToast>? bottomLeft = null;
        List<SonnerToast>? bottomCenter = null;
        List<SonnerToast>? bottomRight = null;

        for (var i = toasts.Count - 1; i >= 0; i--)
        {
            var toast = toasts[i];

            if (!string.Equals(NormalizeToasterId(toast.ToasterId), toasterId, StringComparison.Ordinal))
                continue;

            if (filterPosition is not null && toast.Position != filterPosition)
                continue;

            if (ReferenceEquals(toast.Position, SonnerPosition.TopLeft))
                (topLeft ??= []).Add(toast);
            else if (ReferenceEquals(toast.Position, SonnerPosition.TopCenter))
                (topCenter ??= []).Add(toast);
            else if (ReferenceEquals(toast.Position, SonnerPosition.TopRight))
                (topRight ??= []).Add(toast);
            else if (ReferenceEquals(toast.Position, SonnerPosition.BottomLeft))
                (bottomLeft ??= []).Add(toast);
            else if (ReferenceEquals(toast.Position, SonnerPosition.BottomCenter))
                (bottomCenter ??= []).Add(toast);
            else
                (bottomRight ??= []).Add(toast);
        }

        List<ToastGroup>? groups = null;

        AddGroupIfNotEmpty(ref groups, SonnerPosition.TopLeft, topLeft);
        AddGroupIfNotEmpty(ref groups, SonnerPosition.TopCenter, topCenter);
        AddGroupIfNotEmpty(ref groups, SonnerPosition.TopRight, topRight);
        AddGroupIfNotEmpty(ref groups, SonnerPosition.BottomLeft, bottomLeft);
        AddGroupIfNotEmpty(ref groups, SonnerPosition.BottomCenter, bottomCenter);
        AddGroupIfNotEmpty(ref groups, SonnerPosition.BottomRight, bottomRight);

        _groups = groups ?? [];

        CleanupSwipeDismissedIds();
    }

    private static void AddGroupIfNotEmpty(ref List<ToastGroup>? groups, SonnerPosition position, List<SonnerToast>? toasts)
    {
        if (toasts is null || toasts.Count == 0)
            return;

        (groups ??= new List<ToastGroup>(6)).Add(new ToastGroup(position, toasts));
    }

    private static string GetToasterClass() => "toaster group";

    private string GetAriaLabel() => $"{ContainerAriaLabel} {HotkeyLabel}";

    private static string GetBoolString(bool value) => value ? "true" : "false";

    private string? GetThemeAttribute()
    {
        var theme = Theme.AsSpan().Trim();

        if (theme.Equals("dark", StringComparison.OrdinalIgnoreCase))
            return "dark";

        return theme.Equals("light", StringComparison.OrdinalIgnoreCase) ? "light" : null;
    }

    private static string GetToastClass() => "cn-toast";

    private static string GetActionButtonClass() => "cursor-pointer disabled:cursor-not-allowed";

    private static string GetCloseButtonClass() => "cursor-pointer disabled:cursor-not-allowed";

    private bool IsSwipeDismissed(string toastId)
    {
        return _swipeDismissedToastIds.Contains(toastId);
    }

    private string GetToasterStyle(IReadOnlyList<SonnerToast> toasts)
    {
        var frontHeight = toasts.Count > 0 ? GetToastHeight(toasts[0]) : 0;
        var baseStyle =
            $"--front-toast-height: {frontHeight}px; --width: {DefaultToastWidth}px; --gap: {DefaultGap}px; --normal-bg: var(--popover); --normal-text: var(--popover-foreground); --normal-border: var(--border); --border-radius: var(--radius); --offset-top: {DesktopOffset}px; --offset-right: {DesktopOffset}px; --offset-bottom: {DesktopOffset}px; --offset-left: {DesktopOffset}px; --mobile-offset-top: {MobileOffset}px; --mobile-offset-right: {MobileOffset}px; --mobile-offset-bottom: {MobileOffset}px; --mobile-offset-left: {MobileOffset}px;";

        return Style.HasContent() ? $"{baseStyle} {Style}" : baseStyle;
    }

    private string GetToastStyle(IReadOnlyList<SonnerToast> toasts, int index)
    {
        double offset = 0;

        for (var i = 0; i < index; i++)
        {
            offset += GetToastHeight(toasts[i]) + DefaultGap;
        }

        var initialHeight = GetToastHeight(toasts[index]);
        var zIndex = toasts.Count - index;
        return $"--index: {index}; --toasts-before: {index}; --z-index: {zIndex}; --offset: {offset}px; --initial-height: {initialHeight}px;";
    }

    private static string? GetDataType(SonnerToast toast)
    {
        if (ReferenceEquals(toast.Type, SonnerToastType.Success))
            return "success";

        if (ReferenceEquals(toast.Type, SonnerToastType.Info))
            return "info";

        if (ReferenceEquals(toast.Type, SonnerToastType.Warning))
            return "warning";

        if (ReferenceEquals(toast.Type, SonnerToastType.Error))
            return "error";

        if (ReferenceEquals(toast.Type, SonnerToastType.Loading))
            return "loading";

        return null;
    }

    private static string GetXPosition(SonnerPosition position)
    {
        if (ReferenceEquals(position, SonnerPosition.TopLeft) || ReferenceEquals(position, SonnerPosition.BottomLeft))
            return "left";

        if (ReferenceEquals(position, SonnerPosition.TopCenter) || ReferenceEquals(position, SonnerPosition.BottomCenter))
            return "center";

        return "right";
    }

    private static string GetYPosition(SonnerPosition position)
    {
        if (ReferenceEquals(position, SonnerPosition.TopLeft) || ReferenceEquals(position, SonnerPosition.TopCenter) || ReferenceEquals(position, SonnerPosition.TopRight))
            return "top";

        return "bottom";
    }

    private static bool HasIcon(SonnerToast toast) => !ReferenceEquals(toast.Type, SonnerToastType.Default);

    private static RenderFragment GetIcon(SonnerToast toast) => builder =>
    {
        if (ReferenceEquals(toast.Type, SonnerToastType.Success))
        {
            builder.OpenComponent<Icon>(0);
            builder.AddAttribute(1, "Name", LucideIcon.CircleCheck);
            builder.AddAttribute(2, "Class", "size-4");
            builder.CloseComponent();
            return;
        }

        if (ReferenceEquals(toast.Type, SonnerToastType.Info))
        {
            builder.OpenComponent<Icon>(0);
            builder.AddAttribute(1, "Name", LucideIcon.Info);
            builder.AddAttribute(2, "Class", "size-4");
            builder.CloseComponent();
            return;
        }

        if (ReferenceEquals(toast.Type, SonnerToastType.Warning))
        {
            builder.OpenComponent<Icon>(0);
            builder.AddAttribute(1, "Name", LucideIcon.TriangleAlert);
            builder.AddAttribute(2, "Class", "size-4");
            builder.CloseComponent();
            return;
        }

        if (ReferenceEquals(toast.Type, SonnerToastType.Error))
        {
            builder.OpenComponent<Icon>(0);
            builder.AddAttribute(1, "Name", LucideIcon.OctagonX);
            builder.AddAttribute(2, "Class", "size-4");
            builder.CloseComponent();
            return;
        }

        if (ReferenceEquals(toast.Type, SonnerToastType.Loading))
        {
            builder.OpenComponent<Icon>(0);
            builder.AddAttribute(1, "Name", LucideIcon.LoaderCircle);
            builder.AddAttribute(2, "Class", "size-4 animate-spin");
            builder.CloseComponent();
        }
    };

    private async Task HandleDismiss(string id)
    {
        await SonnerService.Dismiss(id, CancellationToken);
    }

    private async Task HandleAction(SonnerToast toast)
    {
        if (toast.Action is not null)
            await toast.Action();

        await SonnerService.Dismiss(toast.Id, CancellationToken);
    }

    private async Task SyncHotkeyRegistration()
    {
        var hotkeyKey = GetHotkeyKey(Hotkey);

        if (_groups.Count == 0 || hotkeyKey is null)
        {
            await UnregisterHotkey();
            return;
        }

        if (_hotkeyRegistered && string.Equals(_registeredHotkey, hotkeyKey, StringComparison.Ordinal))
            return;

        await UnregisterHotkey();
        await SonnerInterop.RegisterHotkey(_sectionRef, Hotkey, CancellationToken);
        _registeredHotkey = hotkeyKey;
        _hotkeyRegistered = true;
    }

    private async Task UnregisterHotkey()
    {
        if (!_hotkeyRegistered)
            return;

        await SonnerInterop.UnregisterHotkey(_sectionRef, CancellationToken);
        _registeredHotkey = null;
        _hotkeyRegistered = false;
    }

    private async Task SyncSwipeHandlers()
    {
        if (_groups.Count == 0)
        {
            await UnregisterSwipeHandlers();
            return;
        }

        if (_swipeHandlersRegistered)
            return;

        _dotNetReference ??= DotNetObjectReference.Create(this);
        _swipeHandlersRegistered = await SonnerInterop.RegisterSwipeHandlers(_sectionRef, _dotNetReference, CancellationToken);
    }

    private async Task UnregisterSwipeHandlers()
    {
        if (!_swipeHandlersRegistered)
            return;

        await SonnerInterop.UnregisterSwipeHandlers(_sectionRef, CancellationToken);
        _swipeHandlersRegistered = false;
    }

    [JSInvokable]
    public async Task DismissToastFromSwipe(string id)
    {
        if (_disposed.Value || !id.HasContent())
            return;

        _swipeDismissedToastIds.Add(id);
        await SonnerService.Dismiss(id, CancellationToken);
        await InvokeAsync(StateHasChanged);
    }

    private static string? GetHotkeyKey(IReadOnlyList<string>? hotkey)
    {
        if (hotkey is null || hotkey.Count == 0)
            return null;

        using var builder = new PooledStringBuilder(hotkey.Count * 8);

        for (var i = 0; i < hotkey.Count; i++)
        {
            if (i != 0)
                builder.Append('+');

            builder.Append(hotkey[i]);
        }

        return builder.ToString();
    }

    private void OnStateChanged()
    {
        _ = InvokeAsync(HandleStateChanged);
    }

    private async Task HandleStateChanged()
    {
        if (_disposed.Value)
            return;

        _shouldMeasureHeights = true;
        await RefreshToastGroups();
        InvalidateRender();
        StateHasChanged();
    }

    private Task SetExpanded(SonnerPosition position, bool value)
    {
        return SetPositionState(_expandedPositions, position, value);
    }

    private Task SetInteracting(SonnerPosition position, bool value)
    {
        return SetPositionState(_interactingPositions, position, value);
    }

    private Task SetFocused(SonnerPosition position, bool value)
    {
        return SetPositionState(_focusedPositions, position, value);
    }

    private async Task SetPositionState(HashSet<SonnerPosition> state, SonnerPosition position, bool value)
    {
        var wasActive = IsActive(position);
        var changed = value ? state.Add(position) : state.Remove(position);

        if (!changed)
            return;

        var isActive = IsActive(position);

        if (wasActive != isActive)
        {
            if (isActive)
                await SonnerService.Pause(ToasterId, position, CancellationToken);
            else
                await SonnerService.Resume(ToasterId, position, CancellationToken);
        }

        await InvokeAsync(StateHasChanged);
    }

    private bool IsExpanded(SonnerPosition position)
    {
        return IsActive(position);
    }

    private bool IsActive(SonnerPosition position)
    {
        return _expandedPositions.Contains(position) || _interactingPositions.Contains(position) || _focusedPositions.Contains(position);
    }

    private double GetToastHeight(SonnerToast toast)
    {
        return _heights.TryGetValue(toast.Id, out var height) && height > 0 ? height : DefaultToastHeight;
    }

    private bool HaveHeightsChanged(Dictionary<string, double> heights)
    {
        if (heights.Count != _heights.Count)
            return true;

        foreach ((var key, var value) in heights)
        {
            if (!_heights.TryGetValue(key, out var current))
                return true;

            if (Math.Abs(current - value) > 0.5d)
                return true;
        }

        return false;
    }

    private void CleanupSwipeDismissedIds()
    {
        if (_swipeDismissedToastIds.Count == 0)
            return;

        _swipeDismissedToastIds.RemoveWhere(id => !ContainsCurrentToastId(id));
    }

    private bool ContainsCurrentToastId(string id)
    {
        for (var groupIndex = 0; groupIndex < _groups.Count; groupIndex++)
        {
            var toasts = _groups[groupIndex].Toasts;

            for (var toastIndex = 0; toastIndex < toasts.Count; toastIndex++)
            {
                if (string.Equals(toasts[toastIndex].Id, id, StringComparison.Ordinal))
                    return true;
            }
        }

        return false;
    }

    public override async ValueTask DisposeAsync()
    {
        _disposed.Value = true;

        await UnregisterSwipeHandlers();
        await UnregisterHotkey();

        foreach (var position in GetActivePositions())
        {
            await SonnerService.Resume(ToasterId, position, CancellationToken);
        }

        if (_toasterRegistered)
            await SonnerService.UnregisterToaster(_registeredToasterId, CancellationToken);

        SonnerService.StateChanged -= OnStateChanged;
        _dotNetReference?.Dispose();
        await base.DisposeAsync();
    }

    private async Task RegisterToaster()
    {
        var normalizedToasterId = NormalizeToasterId(ToasterId);

        if (_toasterRegistered && !string.Equals(_registeredToasterId, normalizedToasterId, StringComparison.Ordinal))
        {
            foreach (var position in GetActivePositions())
            {
                await SonnerService.Resume(_registeredToasterId, position, CancellationToken);
            }

            await SonnerService.UnregisterToaster(_registeredToasterId, CancellationToken);
        }

        await SonnerService.RegisterToaster(ToasterId, ToastPosition, ToastDuration, CloseButton, CancellationToken);
        _registeredToasterId = normalizedToasterId;
        _toasterRegistered = true;
    }

    private static string NormalizeToasterId(string? toasterId)
    {
        return string.IsNullOrWhiteSpace(toasterId) ? DefaultToasterId : toasterId;
    }

    private IEnumerable<SonnerPosition> GetActivePositions()
    {
        if (IsPositionActive(SonnerPosition.TopLeft))
            yield return SonnerPosition.TopLeft;

        if (IsPositionActive(SonnerPosition.TopCenter))
            yield return SonnerPosition.TopCenter;

        if (IsPositionActive(SonnerPosition.TopRight))
            yield return SonnerPosition.TopRight;

        if (IsPositionActive(SonnerPosition.BottomLeft))
            yield return SonnerPosition.BottomLeft;

        if (IsPositionActive(SonnerPosition.BottomCenter))
            yield return SonnerPosition.BottomCenter;

        if (IsPositionActive(SonnerPosition.BottomRight))
            yield return SonnerPosition.BottomRight;
    }

    private bool IsPositionActive(SonnerPosition position)
    {
        return _expandedPositions.Contains(position) || _interactingPositions.Contains(position) || _focusedPositions.Contains(position);
    }

    private sealed record ToastGroup(SonnerPosition Position, IReadOnlyList<SonnerToast> Toasts);
}
