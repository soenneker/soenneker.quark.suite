@namespace Soenneker.Quark

<CascadingValue Name="@CascadeOwnerName" Value="@Owner" IsFixed="false">
    <CascadingValue Value="@LabelContext" IsFixed="false">
        @ChildContent
    </CascadingValue>
</CascadingValue>

@code {
    /// <summary>
    /// CascadingValue name for the overlay owner (e.g. <c>ParentDialog</c>, <c>ParentSheet</c>).
    /// </summary>
    [Parameter, EditorRequired]
    public string CascadeOwnerName { get; set; } = default!;

    [Parameter]
    public object? Owner { get; set; }

    [Parameter]
    public OverlayLabelContext? LabelContext { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }
}
