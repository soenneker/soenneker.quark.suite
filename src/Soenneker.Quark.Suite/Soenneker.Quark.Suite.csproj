<?xml version="1.0" encoding="utf-8"?>

<Project Sdk="Microsoft.NET.Sdk.Razor">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <Platforms>AnyCPU</Platforms>
        <RootNamespace>Soenneker.Quark</RootNamespace>
        <GenerateDefaultNamespace>false</GenerateDefaultNamespace>
        <NoWarn>$(NoWarn);1591;IDE0130</NoWarn>
    </PropertyGroup>

    <PropertyGroup>
        <Description>The entire suite of Quark elements, all in one library.</Description>
        <Version Condition="'$(BUILD_VERSION)' == ''">4.0.0</Version>
        <Version Condition="'$(BUILD_VERSION)' != ''">$(BUILD_VERSION)</Version>
        <AssemblyName>Soenneker.Quark.Suite</AssemblyName>
        <PackageId>Soenneker.Quark.Suite</PackageId>
        <PackageTags>quark suite html elements blazor ui wrapper css quarksuite blazorlibrary csharp dotnet c# .net</PackageTags>
        <Copyright>Copyright © 2025-2026 Jake Soenneker</Copyright>
        <Authors>Jake Soenneker</Authors>
        <Company>https://soenneker.com</Company>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <IsPackable>true</IsPackable>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/soenneker/soenneker.quark.suite</PackageProjectUrl>
        <RepositoryUrl>https://github.com/soenneker/soenneker.quark.suite</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <RepositoryBranch>main</RepositoryBranch>
        <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <LangVersion>latest</LangVersion>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageIcon>icon.png</PackageIcon>
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
        <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);PackGeneratedTailwindManifest</TargetsForTfmSpecificContentInPackage>
        <PackageReleaseNotes Condition="'$(PACKAGE_RELEASE_NOTES)' != ''">
            $(PACKAGE_RELEASE_NOTES)
        </PackageReleaseNotes>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="\" />
        <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
        <None Include="..\..\icon.png" Pack="true" PackagePath="\" />
    </ItemGroup>

    <Target Name="PackGeneratedTailwindManifest">
        <Error Condition="!Exists('$(MSBuildProjectDirectory)\tailwind\tw-inline.generated.txt')"
               Text="Generated Tailwind manifest not found at '$(MSBuildProjectDirectory)\tailwind\tw-inline.generated.txt'. Build the Suite project before packing." />

        <ItemGroup>
            <TfmSpecificPackageFile Include="$(MSBuildProjectDirectory)\tailwind\tw-inline.generated.txt">
                <PackagePath>tailwind\</PackagePath>
                <BuildAction>None</BuildAction>
            </TfmSpecificPackageFile>
        </ItemGroup>
    </Target>

    <ItemGroup>
        <PackageReference Include="Soenneker.Blazor.Extensions.EventCallback" Version="4.0.444" />
        <PackageReference Include="Soenneker.Extensions.CancellationTokens" Version="4.0.16" />
        <PackageReference Include="Soenneker.Lucide.Enums.Icons" Version="4.0.15" />
        <PackageReference Include="Soenneker.Lucide.Icons" Version="4.0.54" />
        <PackageReference Include="Soenneker.Quark.Components.Core.Cancellable" Version="4.0.60" />
        <PackageReference Include="Soenneker.Quark.Gen.Lucide.Abstractions" Version="4.0.11" />
        <!-- Manifest runs when building the Suite, and the generated file is packed for NuGet consumers. -->
        <PackageReference Include="Soenneker.Quark.Gen.Tailwind.Manifest" Version="4.0.6">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
        </PackageReference>
        <PackageReference Include="Soenneker.Utils.CancellationScopes" Version="4.0.36" />
        <PackageReference Include="Soenneker.Quark.Enums.BoxShadows" Version="4.0.42" />
        <PackageReference Include="Soenneker.Quark.Enums.Breakpoints" Version="4.0.40" />
        <PackageReference Include="Soenneker.Quark.Enums.ButtonTypes" Version="4.0.31" />
        <PackageReference Include="Soenneker.Quark.Enums.ColorTypes" Version="4.0.33" />
        <PackageReference Include="Soenneker.Quark.Enums.ColumnAlignments" Version="4.0.32" />
        <PackageReference Include="Soenneker.Quark.Enums.Cursor" Version="4.0.47" />
        <PackageReference Include="Soenneker.Quark.Enums.DisplayTypes" Version="4.0.45" />
        <PackageReference Include="Soenneker.Quark.Enums.ElementSides" Version="4.0.34" />
        <PackageReference Include="Soenneker.Quark.Enums.Flexes" Version="4.0.42" />
        <PackageReference Include="Soenneker.Quark.Enums.Floats" Version="4.0.44" />
        <PackageReference Include="Soenneker.Quark.Enums.FontStyles" Version="4.0.39" />
        <PackageReference Include="Soenneker.Quark.Enums.FontWeights" Version="4.0.41" />
        <PackageReference Include="Soenneker.Quark.Enums.HtmlElementTypes" Version="4.0.30" />
        <PackageReference Include="Soenneker.Quark.Enums.InputTypes" Version="4.0.30" />
        <PackageReference Include="Soenneker.Quark.Enums.ObjectFits" Version="4.0.41" />
        <PackageReference Include="Soenneker.Quark.Enums.Overflows" Version="4.0.41" />
        <PackageReference Include="Soenneker.Quark.Enums.Placements" Version="4.0.32" />
        <PackageReference Include="Soenneker.Quark.Enums.PointerEvents" Version="4.0.40" />
        <PackageReference Include="Soenneker.Quark.Enums.Positions" Version="4.0.41" />
        <PackageReference Include="Soenneker.Quark.Enums.Scales" Version="4.0.33" />
        <PackageReference Include="Soenneker.Quark.Enums.Size" Version="4.0.34" />
        <PackageReference Include="Soenneker.Quark.Enums.TextAlignments" Version="4.0.42" />
        <PackageReference Include="Soenneker.Quark.Enums.TextBreaks" Version="4.0.40" />
        <PackageReference Include="Soenneker.Quark.Enums.TextDecorations.Line" Version="4.0.41" />
        <PackageReference Include="Soenneker.Quark.Enums.TextDecorations.Style" Version="4.0.40" />
        <PackageReference Include="Soenneker.Quark.Enums.TextOverflows" Version="4.0.31" />
        <PackageReference Include="Soenneker.Quark.Enums.TextTransforms" Version="4.0.40" />
        <PackageReference Include="Soenneker.Quark.Enums.TextWraps" Version="4.0.40" />
        <PackageReference Include="Soenneker.Quark.Enums.UserSelects" Version="4.0.44" />
        <PackageReference Include="Soenneker.Quark.Enums.VerticalAligns" Version="4.0.42" />
        <PackageReference Include="Soenneker.Quark.Enums.Visibilities" Version="4.0.42" />
        <PackageReference Include="Soenneker.Blazor.Utils.ResourceLoader" Version="4.0.1629" />
        <PackageReference Include="Soenneker.DataTables.Dtos.ServerResponse" Version="4.0.15" />
        <PackageReference Include="Soenneker.DataTables.Dtos.ServerSideRequest" Version="4.0.18" />
        <PackageReference Include="Soenneker.DataTables.Dtos.Column" Version="4.0.19" />
        <PackageReference Include="Soenneker.Utils.Debounce" Version="4.0.46" />
        <PackageReference Include="Soenneker.Utils.Json" Version="4.0.2503" />
    </ItemGroup>

</Project>