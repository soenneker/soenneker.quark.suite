<?xml version="1.0" encoding="utf-8"?>

<Project Sdk="Microsoft.NET.Sdk.Razor">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>
        <Platforms>AnyCPU</Platforms>
        <RootNamespace>Soenneker.Quark</RootNamespace>
        <GenerateDefaultNamespace>false</GenerateDefaultNamespace>
        <NoWarn>$(NoWarn);1591;IDE0130</NoWarn>
        <LucideIncludeSvgProvider>false</LucideIncludeSvgProvider>
        <LucideIncludeServiceCollectionExtensions>false</LucideIncludeServiceCollectionExtensions>
    </PropertyGroup>

    <PropertyGroup>
        <Description>The entire suite of Quark elements, all in one library.</Description>
        <Version Condition="'$(BUILD_VERSION)' == ''">4.0.0</Version>
        <Version Condition="'$(BUILD_VERSION)' != ''">$(BUILD_VERSION)</Version>
        <AssemblyName>Soenneker.Quark.Suite</AssemblyName>
        <PackageId>Soenneker.Quark.Suite</PackageId>
        <PackageTags>quark suite html elements blazor ui wrapper css quarksuite blazorlibrary csharp dotnet c# .net</PackageTags>
        <Copyright>Copyright © 2025-2026 Jake Soenneker</Copyright>
        <Authors>Jake Soenneker</Authors>
        <Company>https://soenneker.com</Company>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <IsPackable>true</IsPackable>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/soenneker/soenneker.quark.suite</PackageProjectUrl>
        <RepositoryUrl>https://github.com/soenneker/soenneker.quark.suite</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <RepositoryBranch>main</RepositoryBranch>
        <PackageRequireLicenseAcceptance>false</PackageRequireLicenseAcceptance>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <LangVersion>latest</LangVersion>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageIcon>icon.png</PackageIcon>
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
        <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);PackGeneratedTailwindManifest</TargetsForTfmSpecificContentInPackage>
        <PackageReleaseNotes Condition="'$(PACKAGE_RELEASE_NOTES)' != ''">
            $(PACKAGE_RELEASE_NOTES)
        </PackageReleaseNotes>
        <_GeneratedTailwindManifestPath>$([System.IO.Path]::Combine('$(MSBuildProjectDirectory)', 'tailwind', 'quark-suite-tailwind-manifest.txt'))</_GeneratedTailwindManifestPath>
    </PropertyGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="\" />
        <None Include="..\..\LICENSE" Pack="true" PackagePath="\" />
        <None Include="..\..\icon.png" Pack="true" PackagePath="\" />
    </ItemGroup>

    <Target Name="PackGeneratedTailwindManifest">
        <Error Condition="!Exists('$(_GeneratedTailwindManifestPath)')" Text="Generated Tailwind manifest not found at '$(_GeneratedTailwindManifestPath)'. Build the Suite project before packing." />

        <ItemGroup>
            <TfmSpecificPackageFile Include="$(_GeneratedTailwindManifestPath)">
                <PackagePath>tailwind/</PackagePath>
                <BuildAction>None</BuildAction>
            </TfmSpecificPackageFile>
        </ItemGroup>
    </Target>

    <ItemGroup>
        <PackageReference Include="Soenneker.Asyncs.Initializers" Version="4.0.45" />
        <PackageReference Include="Soenneker.Blazor.Extensions.EventCallback" Version="4.0.445" />
        <PackageReference Include="Soenneker.Lucide.Enums.Icons" Version="4.0.94" />
        <PackageReference Include="Soenneker.Lucide.Icons" Version="4.0.111" />
        <PackageReference Include="Soenneker.Quark.Builders" Version="4.0.4" />
        <PackageReference Include="Soenneker.Quark.Components.Core.Cancellable" Version="4.0.62" />
        <PackageReference Include="Soenneker.Quark.Gen.Lucide" Version="4.0.94">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="Soenneker.Quark.Gen.Lucide.Abstractions" Version="4.0.11" />
        <PackageReference Include="Soenneker.Quark.Gen.Tailwind.Manifest.Suite" Version="4.0.5">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <PackageReference Include="Soenneker.Blazor.Utils.ResourceLoader" Version="4.0.1646" />
        <PackageReference Include="Soenneker.DataTables.Dtos.ServerResponse" Version="4.0.15" />
        <PackageReference Include="Soenneker.DataTables.Dtos.ServerSideRequest" Version="4.0.18" />
        <PackageReference Include="Soenneker.DataTables.Dtos.Column" Version="4.0.19" />
        <PackageReference Include="Soenneker.Utils.Debounce" Version="4.0.46" />
        <PackageReference Include="Soenneker.Utils.Json" Version="4.0.2510" />
    </ItemGroup>
</Project>