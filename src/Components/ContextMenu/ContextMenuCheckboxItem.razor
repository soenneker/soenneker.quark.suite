@using Soenneker.Blazor.Extensions.EventCallback

@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

<div @onclick="OnClickHandler" @attributes="BuildAttributes()">
    <span class="pointer-events-none absolute left-2 flex size-3.5 items-center justify-center">
        @if (Checked)
        {
            <Icon Name="check" Class="size-4" />
        }
    </span>
    @ChildContent
</div>

@code {
    [Parameter]
    public bool Checked { get; set; }

    [Parameter]
    public EventCallback<bool> CheckedChanged { get; set; }

    // Disabled is inherited from Element

    private async Task OnClickHandler()
    {
        if (Disabled)
            return;

        var next = !Checked;
        Checked = next;
        await CheckedChanged.InvokeIfHasDelegate(next);
    }

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "context-menu-checkbox-item";
        attributes["data-state"] = Checked ? "checked" : "unchecked";
        if (Disabled)
            attributes["data-disabled"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-context-menu-checkbox-item");
            AppendClass(ref cls, "relative flex cursor-default items-center gap-2 rounded-sm py-1.5 pr-2 pl-8 text-sm outline-hidden select-none");
            AppendClass(ref cls, "focus:bg-accent focus:text-accent-foreground data-[disabled]:pointer-events-none data-[disabled]:opacity-50");
            AppendClass(ref cls, "[&_svg]:pointer-events-none [&_svg]:shrink-0 [&_svg:not([class*='size-'])]:size-4");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Checked);
        hc.Add(Disabled);
    }
}
