@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IAlertDialogMedia

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "alert-dialog-media";

        // shadcn AlertDialogMedia - new-york-v4 ui/alert-dialog.tsx
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-alert-dialog-media");
            AppendClass(ref cls, "mb-2 inline-flex size-16 items-center justify-center rounded-md bg-muted sm:group-data-[size=default]/alert-dialog-content:row-span-2 *:[svg:not([class*='size-'])]:size-8");
        });
    }
}
