@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements IModalTitle

<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    /// <summary>
    /// Backward-compatibility parameter; shadcn title styles are fixed.
    /// </summary>
    [Parameter]
    public CssValue<ScaleBuilder>? Scale { get; set; } = Quark.Scale.Is5;

    // shadcn DialogTitle - new-york-v4 ui/dialog.tsx
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);
        attributes["data-slot"] = "dialog-title";
        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-modal-title");
            AppendClass(ref cls, "text-lg leading-none font-semibold");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        AddIf(ref hc, Scale);
    }
}
