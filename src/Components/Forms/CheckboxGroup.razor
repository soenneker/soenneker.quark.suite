@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element

@* shadcn - new-york-v4 ui/field.tsx uses data-slot="checkbox-group" with gap-3
   Wrapper for grouped checkboxes; use with Field for consistent layout. *@
<div @attributes="BuildAttributes()">
    @ChildContent
</div>

@code {
    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        attributes["data-slot"] = "checkbox-group";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-checkbox-group");
            AppendClass(ref cls, "flex flex-col gap-3");
        });
    }
}
