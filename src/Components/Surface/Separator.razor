@namespace Soenneker.Quark
@inherits Soenneker.Quark.Element
@implements ISeparator

<div @attributes="BuildAttributes()"></div>

@code {
    /// <summary>
    /// Gets or sets the separator orientation.
    /// </summary>
    [Parameter]
    public SeparatorOrientation Orientation { get; set; } = SeparatorOrientation.Horizontal;

    /// <summary>
    /// Gets or sets whether the separator is purely decorative.
    /// </summary>
    [Parameter]
    public bool Decorative { get; set; } = true;

    protected override void BuildAttributesCore(Dictionary<string, object> attributes)
    {
        base.BuildAttributesCore(attributes);

        var orientation = Orientation == SeparatorOrientation.Vertical ? "vertical" : "horizontal";

        attributes["data-slot"] = "separator";
        attributes["data-orientation"] = orientation;

        if (!Decorative)
            attributes["role"] = "separator";
        else
            attributes["aria-hidden"] = "true";

        BuildClassAttribute(attributes, (ref cls) =>
        {
            AppendClass(ref cls, "q-separator");
            AppendClass(ref cls, "shrink-0 bg-border data-[orientation=horizontal]:h-px data-[orientation=horizontal]:w-full data-[orientation=vertical]:h-full data-[orientation=vertical]:w-px");
        });
    }

    protected override void ComputeRenderKeyCore(ref HashCode hc)
    {
        hc.Add(Orientation);
        hc.Add(Decorative);
    }
}
